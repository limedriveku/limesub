Dialogue: 0,0:08:10.93,0:08:13.93,tanda,,0000,0000,0000,,SAAT MEMALINGKAN PANDANGAN SEBENTAR
Dialogue: 0,0:08:24.11,0:08:24.94,tanda,,0000,0000,0000,,UZUKI SHINOBU
Dialogue: 0,0:08:25.95,0:08:27.07,tanda,,0000,0000,0000,,KIRINO IKO
Dialogue: 0,0:08:27.82,0:08:28.95,tanda,,0000,0000,0000,,HIMEKAWA NENE
Dialogue: 0,0:08:29.57,0:08:30.99,tanda,,0000,0000,0000,,INOHANA RIKKA
Dialogue: 0,0:08:30.99,0:08:33.37,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:09:06.23,0:09:07.31,tanda,,0000,0000,0000,,APOLLO?
Dialogue: 0,0:09:41.61,0:09:43.92,tanda,,0000,0000,0000,,TUNE IN TO THE MIDNIGHT HEART
Dialogue: 0,0:17:15.93,0:17:18.93,tanda,,0000,0000,0000,,LAGU RAHASIA
Dialogue: 0,0:19:14.55,0:19:16.05,tanda,,0000,0000,0000,,500 YEN PER CD
Dialogue: 0,0:19:16.05,0:19:17.55,tanda,,0000,0000,0000,,INOHANA RIKKA
Dialogue: 0,0:22:02.13,0:22:04.64,tanda,,0000,0000,0000,,RUANG SIARAN (SEMENTARA)
Dialogue: 0,0:23:36.98,0:23:39.98,tanda,,0000,0000,0000,,CELESTIAL
Dialogue: 0,0:00:03.86,0:00:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua tanaman hias terlihat sama, ya.
Dialogue: 0,0:00:07.49,0:00:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tidak begitu.
Dialogue: 0,0:00:10.03,0:00:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau kaktus.\NAyo kita beli kaktus.
Dialogue: 0,0:00:12.37,0:00:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu terlihat tidak niat begitu?
Dialogue: 0,0:00:15.12,0:00:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang ingin ada yang hijau-hijau\Ndi ruang ekskul sebelum musim panas?
Dialogue: 0,0:00:19.17,0:00:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Huu, huu.
Dialogue: 0,0:00:21.25,0:00:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamabuki.
Dialogue: 0,0:00:22.63,0:00:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanaman ini namanya apa?
Dialogue: 0,0:00:24.80,0:00:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Ficus benghalensis,\Njenis beringin yang berasal dari Bengal.
Dialogue: 0,0:00:30.09,0:00:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikenal karena umurnya yang panjang\Ndan mudah dipelihara,
Dialogue: 0,0:00:33.18,0:00:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadikannya pilihan bagus bagi pemula.
Dialogue: 0,0:00:35.22,0:00:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi hati-hati dengan getahnya,\N- Maniak rumput, jijik!
Dialogue: 0,0:00:36.98,0:00:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tergantung kondisi, bisa alergi.\N- Kaktus, kaktus...
Dialogue: 0,0:00:39.27,0:00:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai sarung tangan karet saat ingin\Nmemindahkannya ke pot.
Dialogue: 0,0:00:42.61,0:00:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lucu, kan?
Dialogue: 0,0:00:45.61,0:00:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tanaman akuatik, Pachira.
Dialogue: 0,0:00:47.49,0:00:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumbuh sangat cepat\Ndan punya ciri lima daun per batang.
Dialogue: 0,0:00:52.49,0:00:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertumbuhannya sangat pesat\Nantara musim semi dan musim panas.
Dialogue: 0,0:01:00.37,0:01:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita datang jauh-jauh ke sini,
Dialogue: 0,0:01:03.08,0:01:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kamu cuma membeli satu tanaman?
Dialogue: 0,0:01:04.67,0:01:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pilih ini karena lima daunnya\Nmewakili kita di Ekskul Siaran.
Dialogue: 0,0:01:09.05,0:01:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya karena harganya murah.
Dialogue: 0,0:01:11.05,0:01:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku mau kaktus.
Dialogue: 0,0:01:13.22,0:01:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, panas, ya.
Dialogue: 0,0:01:14.80,0:01:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim panas sudah dekat.
Dialogue: 0,0:01:17.77,0:01:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau kulitku terbakar.
Dialogue: 0,0:01:24.90,0:01:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konser tempo hari seru, ya.
Dialogue: 0,0:01:27.78,0:01:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku memang suka\Nmenyanyikan laguku sendiri.
Dialogue: 0,0:01:30.99,0:01:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk konser jalanan juga,\Naku harap bisa tampil bagus lagi.
Dialogue: 0,0:01:35.28,0:01:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku masih takut memikirkannya.
Dialogue: 0,0:01:37.37,0:01:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dipikir, aku belum menulis lagu lagi.
Dialogue: 0,0:01:41.08,0:01:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?\NSebentar lagi liburan musim panas.
Dialogue: 0,0:01:45.71,0:01:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka masih belum menulis lagu barunya.
Dialogue: 0,0:01:49.13,0:01:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin trauma yang dialaminya\Ncukup membekas.
Dialogue: 0,0:01:52.22,0:01:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku harus mencoba pendekatan lain?
Dialogue: 0,0:01:54.76,0:01:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa aku lakukan?
Dialogue: 0,0:01:58.89,0:02:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku bisa melakukan apa pun!
Dialogue: 0,0:02:01.77,0:02:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa tiba-tiba begitu?
Dialogue: 0,0:02:05.61,0:02:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu?
Dialogue: 0,0:02:07.02,0:02:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada yang sedang konser jalanan.
Dialogue: 0,0:02:09.47,0:02:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah dengar lagu ini.
Dialogue: 0,0:02:12.61,0:02:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kalian pulang duluan!
Dialogue: 0,0:02:15.11,0:02:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:16.37,0:02:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Rikka?
Dialogue: 0,0:02:18.41,0:02:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ke toilet.
Dialogue: 0,0:02:19.43,0:02:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa aku jadi mama?
Dialogue: 0,0:02:22.21,0:02:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar hipnotis bagus\Nuntuk mengatasi trauma.
Dialogue: 0,0:02:25.92,0:02:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku harus belajar ke mbakku?
Dialogue: 0,0:02:34.18,0:02:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga itu Aiko.
Dialogue: 0,0:02:35.97,0:02:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung ketahuan dari kebiasaan\Nbermain musiknya.
Dialogue: 0,0:02:38.51,0:02:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, dia masih melanjutkannya, ya.
Dialogue: 0,0:02:42.43,0:02:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti jadi canggung kalau ketahuan,\Ntapi aku mau lanjut dengar.
Dialogue: 0,0:02:49.69,0:02:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:02:51.94,0:02:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya lagu terakhir.
Dialogue: 0,0:02:53.69,0:02:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Mbak.
Dialogue: 0,0:02:55.24,0:03:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang serius dengar konsermu,\Nmasih mau lanjut?
Dialogue: 0,0:03:00.28,0:03:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:03:03.25,0:03:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam, Bodoh!
Dialogue: 0,0:03:05.71,0:03:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan ini karena aku mau!
Dialogue: 0,0:03:07.92,0:03:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa?
Dialogue: 0,0:03:09.42,0:03:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seleramu jelek, sebaiknya berhenti!
Dialogue: 0,0:03:11.50,0:03:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tak punya selera itu kamu!
Dialogue: 0,0:03:13.84,0:03:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kumaafkan siapa pun\Nyang mengejek laguku!
Dialogue: 0,0:03:16.68,0:03:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak akan laku! Hah!
Dialogue: 0,0:03:19.05,0:03:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:03:20.22,0:03:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan datang lagi, Paman Tua!
Dialogue: 0,0:03:23.77,0:03:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dengar lagu terakhirku.
Dialogue: 0,0:03:26.64,0:03:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu ini bukan gubahanku,\Ntapi punya temanku.
Dialogue: 0,0:03:32.73,0:03:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat SMP, kami bermain musik bersama.
Dialogue: 0,0:03:36.61,0:03:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu mahakarya tercipta\Ndan kami berdua senang!
Dialogue: 0,0:03:40.24,0:03:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kirim lagunya ke perusahaan rekaman.
Dialogue: 0,0:03:42.33,0:03:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu balasan datang.
Dialogue: 0,0:03:45.66,0:03:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang menyanyikan bagian reff-nya?
Dialogue: 0,0:03:47.83,0:03:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cukup pakai suara dia saja.
Dialogue: 0,0:03:50.29,0:03:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku senang!
Dialogue: 0,0:03:52.92,0:03:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti mereka mengakui musik kami.
Dialogue: 0,0:03:56.38,0:03:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu aku membicarakannya\Ndengan temanku.
Dialogue: 0,0:03:59.80,0:04:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagunya pasti akan laku!
Dialogue: 0,0:04:02.14,0:04:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musik kami akan jadi nomor satu di Jepang!
Dialogue: 0,0:04:06.52,0:04:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, si Bodoh itu!
Dialogue: 0,0:04:09.23,0:04:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah kabur dari label\Nkarena tidak yakin bisa berhasil!
Dialogue: 0,0:04:12.98,0:04:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa yang kamu lakukan\Nmalah kover lagu idola terus?
Dialogue: 0,0:04:17.24,0:04:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah SMP baru gagal sekali\Njangan langsung menyerah!
Dialogue: 0,0:04:23.66,0:04:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya tugasku\Nadalah terus menyanyikan lagu ini.
Dialogue: 0,0:04:28.16,0:04:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bakatnya memang nyata!
Dialogue: 0,0:04:31.79,0:04:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tidak menempati\Npuncak tangga lagu,
Dialogue: 0,0:04:33.71,0:04:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia seniman yang bisa menjadi\Nnomor satu bagi seseorang.
Dialogue: 0,0:04:37.59,0:04:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang aku inginkan hanyalah\Nseseorang menghargai karyanya.
Dialogue: 0,0:04:41.39,0:04:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tertarik dengan lagu ini,\Ntolong diingat baik-baik.
Dialogue: 0,0:04:45.64,0:04:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyanyian Malam.
Dialogue: 0,0:05:02.66,0:05:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Saat matahari terbenam di tepi air ♪
Dialogue: 0,0:05:06.83,0:05:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku menghela napas panjang ♪
Dialogue: 0,0:05:10.12,0:05:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Airnya seakan menanggapi\Ndengan ombak putih ♪
Dialogue: 0,0:05:16.67,0:05:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Setelah mengucapkan selamat tinggal ♪
Dialogue: 0,0:05:23.76,0:05:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi mengikuti koinnya,\Nsesuatu yang aneh terjadi.
Dialogue: 0,0:05:27.31,0:05:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang lemon itu semanis gula.
Dialogue: 0,0:05:31.81,0:05:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa ini akan berhasil.
Dialogue: 0,0:05:33.48,0:05:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba makan irisan lemon itu.
Dialogue: 0,0:05:37.94,0:05:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asam!
Dialogue: 0,0:05:39.69,0:05:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik napas.\NBuang napas.
Dialogue: 0,0:05:43.61,0:05:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lidahku mati rasa.
Dialogue: 0,0:05:45.07,0:05:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak berhasil.
Dialogue: 0,0:05:46.91,0:05:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira ini bisa\Nmenghilangkan traumanya Rikka!
Dialogue: 0,0:05:52.29,0:05:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konser Rikka akan dimulai.
Dialogue: 0,0:05:55.21,0:05:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, sudah lama tidak lihat, ya.
Dialogue: 0,0:05:57.30,0:06:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo semuanya, meski panas,\Nterima kasih sudah kumpul di sini!
Dialogue: 0,0:06:02.88,0:06:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung saja, tolong dengar lagu pertamaku.
Dialogue: 0,0:06:05.72,0:06:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak sebut judul lagu?
Dialogue: 0,0:06:08.39,0:06:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mau nyanyi apa, ya?
Dialogue: 0,0:06:26.41,0:06:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu apa ini?
Dialogue: 0,0:06:28.70,0:06:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, ini lagu orisinalnya?
Dialogue: 0,0:06:33.96,0:06:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu apa ini?
Dialogue: 0,0:06:36.00,0:06:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku mau dengar yang biasanya.
Dialogue: 0,0:06:39.17,0:06:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak beda dari imej dia, ya.
Dialogue: 0,0:06:42.88,0:06:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku mungkin lebih suka yang ini.
Dialogue: 0,0:06:46.39,0:06:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita asal bersumpah kelingking ♪
Dialogue: 0,0:06:52.56,0:06:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ya! ♪
Dialogue: 0,0:06:55.10,0:06:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Air tenang menyembunyikan bulan ♪
Dialogue: 0,0:06:58.52,0:07:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Karena air tenang menyembunyikan bulan ♪
Dialogue: 0,0:07:01.86,0:07:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Rasanya seolah-olah kita ada\Ndi dunia untuk kita berdua ♪
Dialogue: 0,0:07:08.53,0:07:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Laut menyatu dengan langit ♪
Dialogue: 0,0:07:11.83,0:07:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Keheningan tercipta saat mereka berkumpul ♪
Dialogue: 0,0:07:15.62,0:07:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski tahu hanya ada aku dan kamu ♪
Dialogue: 0,0:07:20.46,0:07:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku berbisik ke telingamu ♪
Dialogue: 0,0:07:24.72,0:07:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan dia menulis ini?
Dialogue: 0,0:07:28.30,0:07:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tanpa bantuan apa pun dariku!
Dialogue: 0,0:07:34.93,0:07:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka!
Dialogue: 0,0:07:36.64,0:07:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kamu menyelesaikan lagu orisinalmu?
Dialogue: 0,0:07:39.65,0:07:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hebat!
Dialogue: 0,0:07:41.23,0:07:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jelas meremehkanmu!
Dialogue: 0,0:07:43.32,0:07:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kamu bisa progres\Nsebesar ini dengan cepat!
Dialogue: 0,0:07:47.07,0:07:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:07:48.91,0:07:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahmu sendiri karena mengabaikanku.
Dialogue: 0,0:07:52.49,0:07:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah...
Dialogue: 0,0:07:54.33,0:07:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menulis lagu ini\Ndengan harapan bisa tercapai
Dialogue: 0,0:07:57.29,0:07:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada orang yang berharga bagiku.
Dialogue: 0,0:07:59.54,0:08:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sahabatku.
Dialogue: 0,0:08:02.92,0:08:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga pendampingku.
Dialogue: 0,0:08:09.05,0:08:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendamping, ya?
Dialogue: 0,0:09:44.77,0:09:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadwal konser jalananmu sudah ditentukan!
Dialogue: 0,0:09:47.07,0:09:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya sudah ada,\Nsisanya tinggal lagu darimu!
Dialogue: 0,0:09:50.24,0:09:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, guncang telingaku ini\Ndengan lagu barumu!
Dialogue: 0,0:09:54.49,0:09:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:09:56.33,0:09:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka masih menulis lagunya!
Dialogue: 0,0:09:58.87,0:09:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:09:59.58,0:10:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, suaramu terlalu keras, Bukki!
Dialogue: 0,0:10:02.12,0:10:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu bilang\Nsudah menyelesaikan lagunya?
Dialogue: 0,0:10:04.54,0:10:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa satu lagu lagi!
Dialogue: 0,0:10:06.88,0:10:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencananya, CD untuk konser kali ini\Nberisi lima lagu!
Dialogue: 0,0:10:10.55,0:10:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi lagu yang terakhir,\Nbelum selesai juga.
Dialogue: 0,0:10:13.80,0:10:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dibandingkan sebelumnya,\Nprogresnya jauh.
Dialogue: 0,0:10:18.18,0:10:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melakukannya dengan baik.
Dialogue: 0,0:10:21.43,0:10:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, tidak baik mengabaikan pujian orang lain!
Dialogue: 0,0:10:24.85,0:10:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka itu bukan perempuan murahan.
Dialogue: 0,0:10:27.40,0:10:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku sudah ada ide\Nuntuk sampul CD-nya.
Dialogue: 0,0:10:30.53,0:10:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lihat!
Dialogue: 0,0:10:33.15,0:10:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:10:34.11,0:10:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benci kelinci?
Dialogue: 0,0:10:35.95,0:10:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lambang damai, bukan kelinci.
Dialogue: 0,0:10:38.66,0:10:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada arti tertentu?
Dialogue: 0,0:10:40.29,0:10:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:10:42.75,0:10:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini simbol pemberontakanku!
Dialogue: 0,0:10:45.17,0:10:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kerja keras agar simbol ini\Nmenyebar ke setiap sudut Jepang!
Dialogue: 0,0:10:49.46,0:10:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku jadi ikut deg-degan.
Dialogue: 0,0:10:52.80,0:10:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami semua pasti akan hadir melihatmu.
Dialogue: 0,0:10:54.84,0:10:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, soal itu...
Dialogue: 0,0:10:57.43,0:11:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk konser kali ini, aku ingin\Nmencoba tanpa bantuan kalian.
Dialogue: 0,0:11:03.14,0:11:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ada kalian,\Naku sangat tenang dan senang.
Dialogue: 0,0:11:07.35,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau terlalu bergantung,\Naku merasa konser ini tak akan ada artinya.
Dialogue: 0,0:11:10.90,0:11:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:11:12.53,0:11:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat disayangkan, tapi ini demi kamu.
Dialogue: 0,0:11:15.32,0:11:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kami paham.
Dialogue: 0,0:11:17.07,0:11:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, kami pasti akan nonton!
Dialogue: 0,0:11:20.24,0:11:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:11:21.37,0:11:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelumnya tak ada progres\Ndan sekarang lancar, ya.
Dialogue: 0,0:11:24.62,0:11:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dapat trik untuk membuat lagu?
Dialogue: 0,0:11:27.21,0:11:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trik?
Dialogue: 0,0:11:29.67,0:11:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai saat ini, aku menulis lagu\Ndengan harapan didengar banyak orang.
Dialogue: 0,0:11:33.38,0:11:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berharap tidak membuat malu\Ndan setidaknya bisa terjual lumayan.
Dialogue: 0,0:11:38.97,0:11:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ternyata gagal.
Dialogue: 0,0:11:40.35,0:11:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat aku menggubah lagu sambil memikirkan\Nwajah orang yang ingin kucapai dengan laguku,
Dialogue: 0,0:11:45.27,0:11:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lirik dan melodinya\Ndatang padaku secara alami.
Dialogue: 0,0:11:48.52,0:11:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir, aku tak punya hal\Nyang mau kusampaikan pada dunia.
Dialogue: 0,0:11:52.86,0:11:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tersadar aku mendalami musik\Nkarena ingin didengarkan orang itu.
Dialogue: 0,0:11:57.74,0:12:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat membuat lagu terakhir,\Npulpenku mendadak berhenti.
Dialogue: 0,0:12:02.41,0:12:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:05.29,0:12:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang sebenarnya ingin kusampaikan
Dialogue: 0,0:12:07.12,0:12:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan dengan lagu,\Ntapi lebih baik dengan bicara langsung.
Dialogue: 0,0:12:12.88,0:12:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:12:14.09,0:12:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedikit terhambat.
Dialogue: 0,0:12:15.76,0:12:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai produser, sudah tugasku\Nuntuk menghilangkan gelisahnya
Dialogue: 0,0:12:19.47,0:12:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dia bisa membuat lagu terbaik!
Dialogue: 0,0:12:22.14,0:12:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:12:23.47,0:12:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hal yang bisa kubantu?
Dialogue: 0,0:12:25.81,0:12:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi, situasi, tenaga orang,\Napa pun akan kuatur untukmu.
Dialogue: 0,0:12:29.44,0:12:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Idih, kalimatnya orang kaya baru keluar!
Dialogue: 0,0:12:31.69,0:12:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin apa pun?
Dialogue: 0,0:12:33.19,0:12:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bagiku, tidak ada yang mustahil!
Dialogue: 0,0:12:36.28,0:12:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:12:44.95,0:12:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamabuki, sini, sini.
Dialogue: 0,0:12:47.04,0:12:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang bilang\Nakan menyiapkan apa pun,
Dialogue: 0,0:12:49.96,0:12:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kenapa ingin mengobrol denganku\Ndi laut malam begini?
Dialogue: 0,0:12:53.71,0:12:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:12:55.17,0:12:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu selalu menggubah lagu\Ndi tengah malam seperti ini.
Dialogue: 0,0:12:58.05,0:13:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mungkin bisa ada kemajuan di sini.
Dialogue: 0,0:13:01.14,0:13:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temani aku mengobrol.
Dialogue: 0,0:13:04.22,0:13:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk di sampingku.
Dialogue: 0,0:13:17.44,0:13:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa yang kamu bilang hari ini.
Dialogue: 0,0:13:19.45,0:13:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat lagu demi seseorang,\Nitu cara yang bagus.
Dialogue: 0,0:13:24.24,0:13:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, Fur Elise dibuat dua abad lalu\Nuntuk orang yang dicintai,
Dialogue: 0,0:13:29.33,0:13:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan masih dikenal sampai sekarang.
Dialogue: 0,0:13:31.92,0:13:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memujimu karena mencapai\Nkesimpulan ini sendiri.
Dialogue: 0,0:13:35.29,0:13:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berusaha, Rikka.
Dialogue: 0,0:13:37.96,0:13:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, lagu yang kamu buat itu untuk siapa?
Dialogue: 0,0:13:40.88,0:13:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Malu kalau kuberitahu.
Dialogue: 0,0:13:44.85,0:13:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena agak canggung,\Naku sempat jaga jarak.
Dialogue: 0,0:13:49.06,0:13:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengumpulkan keberanian\Nuntuk berterus terang dengannya.
Dialogue: 0,0:13:52.85,0:13:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:13:54.10,0:13:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya temannya, Aiko, ya?
Dialogue: 0,0:13:56.73,0:13:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka masih berselisih\Nkarena perbedaan dalam bermusik.
Dialogue: 0,0:13:59.74,0:14:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, untuk orang itu, apa yang ingin\Nkamu sampaikan lewat lagumu?
Dialogue: 0,0:14:05.91,0:14:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bilang di sini?
Dialogue: 0,0:14:07.24,0:14:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan paham kalau kamu tak bilang.
Dialogue: 0,0:14:11.91,0:14:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku mencintaimu."
Dialogue: 0,0:14:16.09,0:14:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu terlalu frontal.
Dialogue: 0,0:14:18.42,0:14:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia ingin mengutarakan perasaan\Ncintanya pada temannya?
Dialogue: 0,0:14:22.67,0:14:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NTidak enak badan?
Dialogue: 0,0:14:24.43,0:14:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:14:25.51,0:14:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka, boleh lihat lirik lagunya?
Dialogue: 0,0:14:28.39,0:14:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:29.01,0:14:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak paham kalau belum lihat.
Dialogue: 0,0:14:30.47,0:14:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tapi...
Dialogue: 0,0:14:31.68,0:14:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah malu sekarang?
Dialogue: 0,0:14:37.86,0:14:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:14:38.69,0:14:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih.
Dialogue: 0,0:14:41.11,0:14:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:14:43.53,0:14:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu sedang kabur?
Dialogue: 0,0:14:45.57,0:14:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Liriknya abstrak dan terlihat\Nmenghindari ekspresi langsung.
Dialogue: 0,0:14:49.79,0:14:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, tak akan sampai.
Dialogue: 0,0:14:51.62,0:14:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detailnya, hal apa\Nyang kamu suka dari orang itu?
Dialogue: 0,0:14:53.87,0:14:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:55.46,0:14:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu...
Dialogue: 0,0:14:57.25,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, dia dengar ocehanku sampai larut malam.
Dialogue: 0,0:15:01.88,0:15:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu mendukung mimpiku.
Dialogue: 0,0:15:05.05,0:15:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, seru saat bicara dengannya\Ndan dia selalu jadi penyelamatku.
Dialogue: 0,0:15:09.35,0:15:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lagi?
Dialogue: 0,0:15:10.85,0:15:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruskan.
Dialogue: 0,0:15:13.56,0:15:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia baik.
Dialogue: 0,0:15:15.52,0:15:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:15:16.48,0:15:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya nyaman didengar.
Dialogue: 0,0:15:18.20,0:15:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teruskan.
Dialogue: 0,0:15:20.90,0:15:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, alasan utamanya
Dialogue: 0,0:15:22.44,0:15:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang sempat kabur,\Ndia tetap sabar selalu menungguku.
Dialogue: 0,0:15:26.49,0:15:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia orang yang baik, ya.
Dialogue: 0,0:15:28.87,0:15:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu bisa lancar menyampaikannya.
Dialogue: 0,0:15:30.83,0:15:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak diekspresikan ke lirikmu?
Dialogue: 0,0:15:32.91,0:15:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kuekspresikan hal sulit lewat lagu
Dialogue: 0,0:15:36.12,0:15:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mulai merasa kalau itu pengecut.
Dialogue: 0,0:15:38.54,0:15:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku mengutarakan perasaanku,\Naku takut dia kecewa.
Dialogue: 0,0:15:44.30,0:15:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang ingin dia mendengarnya,\Nlebih baik diutarakan secara langsung.
Dialogue: 0,0:15:49.89,0:15:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:15:50.72,0:15:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:51.51,0:15:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:15:52.64,0:15:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar manja!
Dialogue: 0,0:15:54.02,0:15:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:54.68,0:15:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah diberkati dengan bakat!
Dialogue: 0,0:15:56.52,0:15:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa berekspresi lewat hal\Nyang orang lain tidak bisa!
Dialogue: 0,0:15:59.23,0:16:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa masih bimbang?
Dialogue: 0,0:16:00.52,0:16:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang lebih baik atau buruk\Ndalam berekspresi!
Dialogue: 0,0:16:02.82,0:16:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besarnya perasaan lebih bisa menggetarkan hati\Ndaripada memikirkan cara menyampaikannya!
Dialogue: 0,0:16:07.03,0:16:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya senjata tapi tak bisa memakainya,\Nitu bertentangan dengan cara keluargaku!
Dialogue: 0,0:16:10.99,0:16:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku namanya Inohana.
Dialogue: 0,0:16:13.70,0:16:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang menyampaikan\Nperasaan padamu lewat lagu,
Dialogue: 0,0:16:17.92,0:16:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu senang?
Dialogue: 0,0:16:21.13,0:16:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:22.67,0:16:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang.
Dialogue: 0,0:16:27.17,0:16:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:16:31.30,0:16:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lagu ini\Ntak akan kumasukkan ke CD.
Dialogue: 0,0:16:34.26,0:16:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tapi semua keresahanmu\Nharusnya sudah teratasi, kan?
Dialogue: 0,0:16:40.35,0:16:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu terakhir ini lagu yang penuh\Ndengan perasaan berharga.
Dialogue: 0,0:16:44.82,0:16:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku bisa menyebut diriku\Nsebagai seniman,
Dialogue: 0,0:16:49.36,0:16:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa berhak\Nmengekspresikan diri melalui musikku.
Dialogue: 0,0:16:55.08,0:16:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan menyimpannya\Nuntuk konser di Budokan?
Dialogue: 0,0:16:57.87,0:16:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sebesar itu.
Dialogue: 0,0:17:00.29,0:17:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau konser jalanan kali ini sukses.
Dialogue: 0,0:17:03.54,0:17:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bisa menjual 50 keping CD.
Dialogue: 0,0:17:08.42,0:17:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu terjadi,
Dialogue: 0,0:17:13.92,0:17:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyanyikannya\Nuntuk orang spesialku.
Dialogue: 0,0:17:20.31,0:17:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsernya di sini?
Dialogue: 0,0:17:22.19,0:17:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Taman ini dianggap\Nsebagai tempat suci bagi musisi jalanan.
Dialogue: 0,0:17:25.77,0:17:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan band Celestial\Nyang baru-baru ini populer
Dialogue: 0,0:17:29.49,0:17:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}konon pernah konser di sini tahun yang lalu.
Dialogue: 0,0:17:32.70,0:17:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, level penonton di sini\Nseleranya cukup tinggi.
Dialogue: 0,0:17:36.03,0:17:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa dapat fan di sini,\Nbisa dipastikan akan populer.
Dialogue: 0,0:17:42.96,0:17:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membagikan brosurnya.
Dialogue: 0,0:17:45.21,0:17:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjaring penonton dimulai\Ndengan impak kesan pertama.
Dialogue: 0,0:17:48.59,0:17:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengamankan tempat terbuka\Nyang bisa dilihat banyak orang.
Dialogue: 0,0:17:53.47,0:17:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadaku terasa sangat sakit.
Dialogue: 0,0:17:55.80,0:17:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan diingat, perasaan ini...
Dialogue: 0,0:17:58.43,0:18:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sangat gugup\Nsaat konser jalanan pertama kali.
Dialogue: 0,0:18:01.23,0:18:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, rasa sakitnya berbeda\Ndengan yang dulu.
Dialogue: 0,0:18:04.35,0:18:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu aku tak tahu apa pun\Ndan tak ada ekspektasi tinggi.
Dialogue: 0,0:18:08.23,0:18:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku cuma merasa takut.
Dialogue: 0,0:18:11.24,0:18:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditatap oleh mata itu lagi...
Dialogue: 0,0:18:13.53,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?\NSepertinya aku tak sanggup.
Dialogue: 0,0:18:16.45,0:18:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya berhenti saja?
Dialogue: 0,0:18:19.41,0:18:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:18:20.70,0:18:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:18:21.91,0:18:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NApa mataku membuatmu takut?
Dialogue: 0,0:18:24.21,0:18:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak juga...
Dialogue: 0,0:18:25.71,0:18:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku menawan, kan?
Dialogue: 0,0:18:27.04,0:18:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sampai bilang begitu.
Dialogue: 0,0:18:30.34,0:18:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Rikka!
Dialogue: 0,0:18:31.51,0:18:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat konser nanti, kalau merasa berat,
Dialogue: 0,0:18:34.01,0:18:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau merasa sulit mengangkat wajah,\Ncukup lihat ke arahku!
Dialogue: 0,0:18:37.55,0:18:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:39.10,0:18:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:18:40.27,0:18:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jaga-jaga, aku bawa ini.
Dialogue: 0,0:18:43.39,0:18:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku terkubur penonton,
Dialogue: 0,0:18:46.52,0:18:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa ditemukan dengan ini!
Dialogue: 0,0:18:48.61,0:18:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan norak,\Nsampai mati pun jangan lakukan itu!
Dialogue: 0,0:18:50.94,0:18:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kamu bilang Yamabuki norak?
Dialogue: 0,0:18:57.16,0:18:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah menghilangkan tegangku, ya.
Dialogue: 0,0:18:59.20,0:19:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:00.29,0:19:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan coba berusaha.
Dialogue: 0,0:19:04.41,0:19:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, semangat.
Dialogue: 0,0:19:06.92,0:19:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan selalu memperhatikanmu.
Dialogue: 0,0:19:23.60,0:19:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagu pertamaku, Hari Membutakan.
Dialogue: 0,0:19:41.99,0:19:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Di tengah langit biru yang bersinar ♪
Dialogue: 0,0:19:45.41,0:19:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa selanjutnya?
Dialogue: 0,0:19:46.29,0:19:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku mengucapkan kata-kata kosong ini ♪
Dialogue: 0,0:19:49.71,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Alasan kita, masa depan kita ♪
Dialogue: 0,0:19:54.05,0:19:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku ingin orang mengetahuinya ♪
Dialogue: 0,0:19:57.97,0:19:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ "Sampai jumpa besok" ♪
Dialogue: 0,0:19:59.05,0:20:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya tidak keluar,\Nritmenya juga tidak terjaga.
Dialogue: 0,0:20:02.68,0:20:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tegangnya\Nbelum bisa teratasi dengan mudah.
Dialogue: 0,0:20:07.35,0:20:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi ini bisa turun\Nke arah yang buruk untuk mentalnya.
Dialogue: 0,0:20:12.65,0:20:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka, tenangkan dirimu dulu!
Dialogue: 0,0:20:16.40,0:20:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga ini akan gagal.
Dialogue: 0,0:20:18.82,0:20:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang berhenti mendengarkan.\NTak ada yang mau mendengarkanku.
Dialogue: 0,0:20:24.37,0:20:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku kira kamu bisa melakukannya.
Dialogue: 0,0:20:28.25,0:20:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku terlalu banyak berharap.
Dialogue: 0,0:20:35.67,0:20:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Aiko.\NSepertinya aku memang tidak bisa...
Dialogue: 0,0:20:39.05,0:20:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rikka.
Dialogue: 0,0:20:46.39,0:20:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kenapa kita bisa tersesat sampai ke sini?
Dialogue: 0,0:20:50.52,0:20:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohongmu terlalu jelas!
Dialogue: 0,0:20:52.27,0:20:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayo, kita bisa ketinggalan kereta!
Dialogue: 0,0:20:56.11,0:21:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangkan saja kami selalu ada\Ndi barisan depan.
Dialogue: 0,0:21:02.74,0:21:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah lupa.
Dialogue: 0,0:21:04.20,0:21:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan ini bukan untuk menarik\Nperhatian banyak orang.
Dialogue: 0,0:21:06.83,0:21:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bernyanyi untuk orang\Nyang ingin mendengarkanku.
Dialogue: 0,0:21:13.92,0:21:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu keduaku, Ask for the Moon.
Dialogue: 0,0:21:26.93,0:21:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menulis lagu ini dengan memikirkan\Nteman-teman di Ekskul Siaran.
Dialogue: 0,0:21:31.60,0:21:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti aku hanya perlu bernyanyi\Nuntuk mereka bertiga.
Dialogue: 0,0:21:36.65,0:21:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku selalu percaya tangan\Ndan suaraku akan menjangkaumu ♪
Dialogue: 0,0:21:53.67,0:21:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jarak antara kita 380.000 kilometer ♪
Dialogue: 0,0:21:59.17,0:22:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanggil mereka untuk jaga-jaga\Nternyata keputusan tepat.
Dialogue: 0,0:22:04.64,0:22:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Dia bohong?
Dialogue: 0,0:22:06.64,0:22:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dia mungkin mengaku\Ntak ingin bergantung pada kita,
Dialogue: 0,0:22:12.14,0:22:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi itu tidak benar.
Dialogue: 0,0:22:13.31,0:22:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak ingin kalian melihatnya gagal.
Dialogue: 0,0:22:16.44,0:22:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia takut kalian memandangnya\Ndengan kecewa.
Dialogue: 0,0:22:20.11,0:22:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kami akan melakukan itu? Bodoh!
Dialogue: 0,0:22:22.99,0:22:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya!
Dialogue: 0,0:22:24.11,0:22:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku diserang?
Dialogue: 0,0:22:25.24,0:22:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita harus bagaimana?
Dialogue: 0,0:22:28.95,0:22:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hanya perlu menonton dari jauh.
Dialogue: 0,0:22:31.87,0:22:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berada di sana untuk Rikka.
Dialogue: 0,0:22:34.29,0:22:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Bercita-cita untuk mendapatkan banyak hal ♪
Dialogue: 0,0:22:37.42,0:22:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terus membaik.
Dialogue: 0,0:22:39.46,0:22:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik perhatian orang-orang!
Dialogue: 0,0:22:41.84,0:22:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu suaramu akan menjangkau mereka!
Dialogue: 0,0:22:44.88,0:22:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menjadi utuh kembali ♪
Dialogue: 0,0:22:47.30,0:22:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Merindukan bulan ♪
Dialogue: 0,0:22:49.72,0:22:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku mengulurkan tangan ♪
Dialogue: 0,0:22:52.06,0:22:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berjinjit, meregang agar makin dekat ♪
Dialogue: 0,0:22:56.86,0:22:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Aku melakukan perjalanan ke luar angkasa ♪
Dialogue: 0,0:22:59.52,0:23:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Percaya bahwa aku akan sampai\Ndi sana suatu hari nanti ♪
Dialogue: 0,0:23:06.24,0:23:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya bagus, ya?
Dialogue: 0,0:23:08.70,0:23:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski aku menempuh jalan\Nyang tidak diketahui ♪
Dialogue: 0,0:23:13.33,0:23:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski aku selalu meminta terlalu banyak ♪
Dialogue: 0,0:23:17.83,0:23:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ 60 sentimeter ke luar angkasa ♪
Dialogue: 0,0:23:22.67,0:23:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Tetap membawaku makin dekat\Nmenyentuh bulan ♪
Dialogue: 0,0:23:31.47,0:23:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat aku ♪
Dialogue: 0,0:23:36.06,0:23:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Inilah aku ♪
