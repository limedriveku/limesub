Dialogue: 0,0:02:12.96,0:02:14.21,tanda,,0000,0000,0000,,LITTLE MINE BOOK, IKKO OWADA
Dialogue: 0,0:06:41.81,0:06:42.77,tanda,,0000,0000,0000,,RONDO ES DARAH
Dialogue: 0,0:08:52.95,0:08:54.95,tanda,,0000,0000,0000,,API HANTU, SERANGAN CEPAT
Dialogue: 0,0:10:41.09,0:10:42.35,tanda,,0000,0000,0000,,K!
Dialogue: 0,0:21:56.02,0:21:57.27,tanda,,0000,0000,0000,,K,
Dialogue: 0,0:01:46.94,0:01:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:01:48.15,0:01:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sampah di Dalam Dinding".
Dialogue: 0,0:01:51.86,0:01:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelek. Buang saja.
Dialogue: 0,0:01:54.40,0:01:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,
Dialogue: 0,0:01:55.90,0:01:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini Pertarungan Gabungan Antarkelas!
Dialogue: 0,0:01:57.82,0:01:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:02:01.12,0:02:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, Ashina…
Dialogue: 0,0:02:03.49,0:02:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat saja nanti.
Dialogue: 0,0:02:06.08,0:02:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber! Panggil Monster Siber.
Dialogue: 0,0:02:09.83,0:02:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber!
Dialogue: 0,0:02:11.79,0:02:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Little Mine Book!
Dialogue: 0,0:02:14.71,0:02:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil Monster Siber!
Dialogue: 0,0:02:16.80,0:02:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau sungguh...
Dialogue: 0,0:02:18.47,0:02:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:02:19.47,0:02:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:02:20.97,0:02:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro, psikokinesismu\Ntinggal sedikit, kan?
Dialogue: 0,0:02:26.14,0:02:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gunakan api untuk hangatkan diri.\NSimpan kekuatanmu.
Dialogue: 0,0:02:31.56,0:02:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika tidak…
Dialogue: 0,0:02:33.07,0:02:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa Api Hantu milikmu,
Dialogue: 0,0:02:35.40,0:02:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}simpan untuk membakar pria itu menjadi abu.
Dialogue: 0,0:02:39.40,0:02:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar Surugi yang menghangatkanmu dulu.
Dialogue: 0,0:02:45.16,0:02:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi agak canggung.
Dialogue: 0,0:02:47.75,0:02:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:02:50.00,0:02:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro, apiku hangat, kan?
Dialogue: 0,0:02:54.63,0:02:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin rasanya membakarmu, tapi kutahan.
Dialogue: 0,0:02:57.21,0:02:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau keterlaluan.
Dialogue: 0,0:03:03.43,0:03:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peliharaan Owada, ya?
Dialogue: 0,0:03:05.51,0:03:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayap yang menyedihkan.
Dialogue: 0,0:03:07.93,0:03:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutunjukkan padamu sayap yang sungguhan!
Dialogue: 0,0:03:11.60,0:03:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi pedang, panah,\Ndan perisai terkuat.
Dialogue: 0,0:03:14.98,0:03:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah simbol kecantikanku.
Dialogue: 0,0:03:17.40,0:03:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Deadly Ice Wings!
Dialogue: 0,0:03:21.36,0:03:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai jatuh!
Dialogue: 0,0:03:23.03,0:03:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusaba, kau tidak apa-apa?
Dialogue: 0,0:03:24.78,0:03:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa.
Dialogue: 0,0:03:26.54,0:03:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasumi, beri aku tugas juga.
Dialogue: 0,0:03:30.62,0:03:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara padaku.\NAku belum memaafkanmu.
Dialogue: 0,0:03:34.67,0:03:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusugawa, bagaimana onsennya?
Dialogue: 0,0:03:37.13,0:03:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma tanganku yang hangat…
Dialogue: 0,0:03:40.42,0:03:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini terlalu dingin?
Dialogue: 0,0:03:42.72,0:03:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kita tak bisa menyerang\Nkalau terus sembunyi di balik dinding.
Dialogue: 0,0:03:45.39,0:03:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:03:49.43,0:03:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu cepat. Aku tak bisa membidik.
Dialogue: 0,0:03:51.94,0:03:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai dia berhenti bergerak sebentar…
Dialogue: 0,0:03:54.27,0:03:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Namekawa akan menyemangati\Nsemuanya dengan tarian!
Dialogue: 0,0:03:58.28,0:03:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti menari!\NAku tak bisa fokus!
Dialogue: 0,0:04:01.74,0:04:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia, Wagari!
Dialogue: 0,0:04:02.91,0:04:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku siap kapan saja, Kasubata!
Dialogue: 0,0:04:07.62,0:04:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terbang?
Dialogue: 0,0:04:08.70,0:04:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh. Kau jadi sasaran empuk.
Dialogue: 0,0:04:12.37,0:04:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:04:15.29,0:04:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan Wagari!
Dialogue: 0,0:04:17.45,0:04:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mendorong kakinya\Ndengan kekuatan minimal.
Dialogue: 0,0:04:21.26,0:04:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayap yang amat kau banggakan,
Dialogue: 0,0:04:23.18,0:04:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kami hancurkan, Ashina!
Dialogue: 0,0:04:25.43,0:04:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan jepit dari kedua sisi!
Dialogue: 0,0:04:30.64,0:04:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berhasil!
Dialogue: 0,0:04:31.77,0:04:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasubata dan Wagari.
Dialogue: 0,0:04:33.31,0:04:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menghancurkan sayap Ashina!
Dialogue: 0,0:04:36.19,0:04:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayapku!
Dialogue: 0,0:04:40.23,0:04:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina!
Dialogue: 0,0:04:41.86,0:04:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kau tahu,
Dialogue: 0,0:04:43.36,0:04:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dahulu aku menyukaimu!
Dialogue: 0,0:04:44.99,0:04:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wagari!
Dialogue: 0,0:04:46.91,0:04:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berbakat!
Dialogue: 0,0:04:48.53,0:04:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski selera estetikamu cenderung obsesif,
Dialogue: 0,0:04:50.16,0:04:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa merasakan keyakinan di dalamnya!
Dialogue: 0,0:04:52.66,0:04:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa…
Dialogue: 0,0:04:54.46,0:04:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:04:57.17,0:05:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak bisa pahami karya seni ini?
Dialogue: 0,0:05:01.59,0:05:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro, jangan terburu-buru.
Dialogue: 0,0:05:03.80,0:05:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatanmu tinggal satu.
Dialogue: 0,0:05:07.34,0:05:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang di saat yang tepat.
Dialogue: 0,0:05:09.26,0:05:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang urus sampai saat itu tiba.
Dialogue: 0,0:05:12.56,0:05:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster Siber miliknya…
Dialogue: 0,0:05:13.68,0:05:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lenyap.
Dialogue: 0,0:05:15.85,0:05:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusaba.
Dialogue: 0,0:05:17.02,0:05:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:05:18.98,0:05:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Psikokinesisnya habis?
Dialogue: 0,0:05:21.98,0:05:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina!
Dialogue: 0,0:05:23.69,0:05:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, salah perhitungan.
Dialogue: 0,0:05:25.86,0:05:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada satu sayap lagi.
Dialogue: 0,0:05:28.95,0:05:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surugi?
Dialogue: 0,0:05:30.87,0:05:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina!
Dialogue: 0,0:05:32.79,0:05:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu
Dialogue: 0,0:05:35.46,0:05:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membencimu.
Dialogue: 0,0:05:37.42,0:05:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara, "Merah Vulgar".
Dialogue: 0,0:05:39.67,0:05:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:40.75,0:05:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu yang pernah kau katakan padaku.
Dialogue: 0,0:05:44.46,0:05:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak pernah tunjukkan\Nsedikit pun ketertarikan padaku.
Dialogue: 0,0:05:49.05,0:05:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh sayapku!
Dialogue: 0,0:05:52.01,0:05:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:05:55.81,0:05:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat bangga pada tubuhmu.
Dialogue: 0,0:05:57.60,0:06:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini ternoda oleh warna merah vulgarku.
Dialogue: 0,0:06:04.48,0:06:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi itu…
Dialogue: 0,0:06:06.32,0:06:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau tunjukkan kebencian padaku!
Dialogue: 0,0:06:09.74,0:06:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melelehkan sayap Ashina.
Dialogue: 0,0:06:11.24,0:06:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu persis alasanmu mengkhianati kami.
Dialogue: 0,0:06:14.70,0:06:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melakukannya karena kemauanmu, kan?
Dialogue: 0,0:06:17.33,0:06:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina, pergilah ke neraka!
Dialogue: 0,0:06:20.83,0:06:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber! Api Hantu.
Dialogue: 0,0:06:25.01,0:06:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gunakan siberkinesis.
Dialogue: 0,0:06:26.47,0:06:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku belum menjebaknya\Ndengan lendir…
Dialogue: 0,0:06:28.97,0:06:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak punya sayap lagi. Cepat!
Dialogue: 0,0:06:32.72,0:06:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bisa bertahan 30 detik.
Dialogue: 0,0:06:34.81,0:06:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menghabisinya sekarang.
Dialogue: 0,0:06:38.60,0:06:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:06:40.15,0:06:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Rondo Es Darah"!
Dialogue: 0,0:06:46.74,0:06:49.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tetap sangat cepat walau tanpa sayap.
Dialogue: 0,0:06:50.11,0:06:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku membeku.
Dialogue: 0,0:06:52.28,0:06:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membekulah sampai mati,
Dialogue: 0,0:06:53.91,0:06:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soji Enishiro!
Dialogue: 0,0:06:57.58,0:07:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku sudah lebih kuat\Nsetelah semua latihan itu.
Dialogue: 0,0:07:02.58,0:07:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat tak berguna.\NKenapa aku lemah sekali?
Dialogue: 0,0:07:06.13,0:07:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang berusaha keras membantuku,\Ntapi aku masih…
Dialogue: 0,0:07:10.09,0:07:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisakah aku mendekatinya?
Dialogue: 0,0:07:17.52,0:07:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patung es raksasa Ashina…
Dialogue: 0,0:07:22.19,0:07:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patungnya bergerak?
Dialogue: 0,0:07:27.53,0:07:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:07:29.11,0:07:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah seni sejati jadi wadah kehidupan?
Dialogue: 0,0:07:32.49,0:07:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seniku telah mencapai tingkat baru.
Dialogue: 0,0:07:37.58,0:07:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haijima?
Dialogue: 0,0:07:38.70,0:07:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiyori!
Dialogue: 0,0:07:40.91,0:07:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master!
Dialogue: 0,0:07:42.54,0:07:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hardcore Gamer-Powered Doll!!
Dialogue: 0,0:07:44.50,0:07:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bentuknya manusia,\Nbisa digunakan sebagai boneka!
Dialogue: 0,0:07:47.75,0:07:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kali pertamaku\Nkendalikan sesuatu sebesar ini.
Dialogue: 0,0:07:50.30,0:07:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan psikokinesisku!
Dialogue: 0,0:07:55.39,0:07:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju, Robot Ashina!
Dialogue: 0,0:07:59.31,0:08:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master!
Dialogue: 0,0:08:06.86,0:08:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:08.29,0:08:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, wajar saja kalau jadinya begini.
Dialogue: 0,0:08:10.99,0:08:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar jika tak bisa bergerak.\NLagi pula, ini kan es!
Dialogue: 0,0:08:17.49,0:08:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahakaryaku yang paling sempurna!
Dialogue: 0,0:08:21.21,0:08:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hiyori.
Dialogue: 0,0:08:22.54,0:08:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantuan yang cantik!
Dialogue: 0,0:08:25.92,0:08:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau tak bisa bergerak, Ashina!
Dialogue: 0,0:08:29.17,0:08:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kuat.
Dialogue: 0,0:08:31.92,0:08:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menang sendirian.
Dialogue: 0,0:08:34.47,0:08:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-temanku membantuku.
Dialogue: 0,0:08:37.42,0:08:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga pernah punya teman.
Dialogue: 0,0:08:39.22,0:08:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri yang tinggalkan mereka!
Dialogue: 0,0:08:41.64,0:08:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kau kalah, Ashina!
Dialogue: 0,0:08:46.56,0:08:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api Hantu, Serangan Cepat!
Dialogue: 0,0:09:05.25,0:09:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum musnah sepenuhnya.
Dialogue: 0,0:09:07.63,0:09:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Psikokinesisku benar-benar habis.
Dialogue: 0,0:09:10.88,0:09:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum boleh pingsan.
Dialogue: 0,0:09:15.55,0:09:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber.
Dialogue: 0,0:09:20.18,0:09:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina…
Dialogue: 0,0:09:21.18,0:09:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:09:23.73,0:09:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusugawa, kau menyelamatkanku.
Dialogue: 0,0:09:26.40,0:09:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh…\N- Kau benar-benar berhasil!
Dialogue: 0,0:09:28.06,0:09:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini belum berakhir.
Dialogue: 0,0:09:30.32,0:09:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:09:32.23,0:09:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hampir mati.
Dialogue: 0,0:09:34.86,0:09:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak boleh musnah sekarang.
Dialogue: 0,0:09:36.91,0:09:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku kembali ke ponselku…
Dialogue: 0,0:09:38.87,0:09:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang
Dialogue: 0,0:09:40.20,0:09:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar mereka yang urus sisanya.
Dialogue: 0,0:09:42.62,0:09:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh menyedihkan.
Dialogue: 0,0:09:44.66,0:09:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat jelek sekarang, Ashina.
Dialogue: 0,0:09:47.88,0:09:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang aku jelek?
Dialogue: 0,0:09:50.96,0:09:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu kami semua\Nyang kau ketahui soal K.
Dialogue: 0,0:09:55.26,0:09:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka kubiarkan kau mati dengan tenang.
Dialogue: 0,0:09:57.18,0:09:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan musnah!
Dialogue: 0,0:09:59.55,0:10:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K sudah berjanji padaku.
Dialogue: 0,0:10:02.14,0:10:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang akan wujudkan mimpiku.
Dialogue: 0,0:10:04.77,0:10:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga akan membawaku ke negeri impian!
Dialogue: 0,0:10:09.27,0:10:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api Hantu! Menjauhlah darinya!
Dialogue: 0,0:10:12.07,0:10:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api… Terima kasih dari lubuk hatiku, K.
Dialogue: 0,0:10:15.24,0:10:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api ini memberiku kekuatan.
Dialogue: 0,0:10:18.57,0:10:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberiku kekuatan lagi.
Dialogue: 0,0:10:24.70,0:10:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:10:36.17,0:10:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terbakar!
Dialogue: 0,0:10:37.55,0:10:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meleleh… Menghilang!
Dialogue: 0,0:10:43.93,0:10:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku tak mau menghilang.
Dialogue: 0,0:10:51.81,0:10:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan menghilang sepenuhnya.
Dialogue: 0,0:10:53.69,0:10:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan akun media sosialmu akan hilang.
Dialogue: 0,0:10:56.61,0:11:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan ada yang melihatmu lagi.
Dialogue: 0,0:11:01.91,0:11:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seharusnya hidup.
Dialogue: 0,0:11:05.62,0:11:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:11:07.70,0:11:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina!
Dialogue: 0,0:11:09.33,0:11:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fotomu akan tersimpan di ponsel kami.
Dialogue: 0,0:11:12.92,0:11:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali kami akan melihatnya\Nuntuk mengenangmu.
Dialogue: 0,0:11:15.46,0:11:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang tak punya teman,
Dialogue: 0,0:11:17.84,0:11:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi seburuk apa pun kondisimu,
Dialogue: 0,0:11:19.17,0:11:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tetap murid Kelas 1-A!
Dialogue: 0,0:11:31.69,0:11:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan K adalah
Dialogue: 0,0:11:34.02,0:11:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}negeri akun gaib.
Dialogue: 0,0:11:37.03,0:11:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negeri akun gaib?
Dialogue: 0,0:11:40.57,0:11:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:11:42.45,0:11:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, maafkan aku.
Dialogue: 0,0:11:55.21,0:11:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Owada.
Dialogue: 0,0:11:56.80,0:11:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menangis, tetaplah tenang.
Dialogue: 0,0:11:59.46,0:12:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medium roh yang menaklukkan akun gaib
Dialogue: 0,0:12:02.26,0:12:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanyalah rutinitas sehari-hari, itu saja.
Dialogue: 0,0:12:05.80,0:12:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wagari luar biasa. Tekadnya sekuat baja.
Dialogue: 0,0:12:14.48,0:12:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badai salju sudah reda.
Dialogue: 0,0:12:19.57,0:12:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan sudah usai.
Dialogue: 0,0:12:22.03,0:12:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ini melelahkan dari berbagai sisi.
Dialogue: 0,0:12:26.28,0:12:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Semuanya.
Dialogue: 0,0:12:27.87,0:12:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus!
Dialogue: 0,0:12:33.29,0:12:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan sikap kalian?
Dialogue: 0,0:12:35.92,0:12:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita baru kehilangan seorang murid.
Dialogue: 0,0:12:38.21,0:12:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, tenang.
Dialogue: 0,0:12:39.71,0:12:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian bercanda?
Dialogue: 0,0:12:41.80,0:12:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga salah Akademi\Nhingga kami masuk perangkap Ashina.
Dialogue: 0,0:12:44.43,0:12:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Semuanya! Ayo kembali ke Akademi.
Dialogue: 0,0:12:47.64,0:12:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:12:48.89,0:12:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusannya belum selesai.
Dialogue: 0,0:12:50.81,0:12:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu?
Dialogue: 0,0:12:54.73,0:12:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali!
Dialogue: 0,0:12:58.69,0:13:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Evaluasi Pertarungan Antarkelas\Nakan diumumkan besok.
Dialogue: 0,0:13:01.74,0:13:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ada pesta hari ini,\Njadi bersenang-senanglah.
Dialogue: 0,0:13:05.95,0:13:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, Pak Azaki.
Dialogue: 0,0:13:07.82,0:13:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang tak ingin bersenang-senang.
Dialogue: 0,0:13:10.08,0:13:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tradisi akademi kita… Bukan.
Dialogue: 0,0:13:12.16,0:13:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tradisi Komunitas Medium Roh.
Dialogue: 0,0:13:14.29,0:13:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap ada yang berkorban dalam misi,\Npesta besar akan digelar.
Dialogue: 0,0:13:18.59,0:13:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu kapan akan mati\Ndalam pekerjaan ini.
Dialogue: 0,0:13:21.05,0:13:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kita rayakan kehidupan\Ndan minum-minum bagi yang telah mati.
Dialogue: 0,0:13:25.76,0:13:27.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bisa kembali.
Dialogue: 0,0:13:27.97,0:13:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bangga pada kalian semua.
Dialogue: 0,0:13:31.31,0:13:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memalukan sekali.
Dialogue: 0,0:13:32.98,0:13:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid-murid kelas 1 ini sungguh hebat.
Dialogue: 0,0:13:35.52,0:13:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kalahkan akun gaib level lanjut,\Nbahkan mantan teman sekelas mereka.
Dialogue: 0,0:13:41.82,0:13:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro sangat menarik.
Dialogue: 0,0:13:44.57,0:13:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi penggemarnya.
Dialogue: 0,0:13:46.91,0:13:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya ingin sekali menggodanya.
Dialogue: 0,0:13:51.33,0:13:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soji Enishiro.
Dialogue: 0,0:13:53.45,0:13:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Nanzo.
Dialogue: 0,0:13:56.58,0:14:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, pihak Akademi terbelah\Nsoal menerimamu atau tidak,
Dialogue: 0,0:14:00.71,0:14:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pengguna Api Hantu.
Dialogue: 0,0:14:03.26,0:14:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan akulah pemimpin penentangnya.
Dialogue: 0,0:14:06.34,0:14:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang melihat pertarungan hari ini.
Dialogue: 0,0:14:09.89,0:14:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada orang di Akademi\Nyang akan menolakmu sekarang.
Dialogue: 0,0:14:15.02,0:14:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah.
Dialogue: 0,0:14:16.35,0:14:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Anda tak perlu minta maaf.
Dialogue: 0,0:14:19.52,0:14:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membebaskan Ashina.
Dialogue: 0,0:14:22.15,0:14:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:36.83,0:14:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro?
Dialogue: 0,0:14:39.21,0:14:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau makanan manis?
Dialogue: 0,0:14:40.67,0:14:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manju-ku tertinggal di saku.
Dialogue: 0,0:14:45.20,0:14:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manju-nya beku.
Dialogue: 0,0:14:53.10,0:14:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali.
Dialogue: 0,0:14:59.06,0:15:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan K, bagaimana perkembangannya?
Dialogue: 0,0:15:02.86,0:15:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obsesinya seharusnya\Nsudah membuahkan hasil sekarang.
Dialogue: 0,0:15:06.74,0:15:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:08.15,0:15:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya dia tumbuh jadi\Nakun gaib yang sangat dinamis.
Dialogue: 0,0:15:13.66,0:15:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina juga mampu melakukannya.\NKesepian sekali.
Dialogue: 0,0:15:18.91,0:15:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku\Nkarena kembali mengingatkanmu padanya.
Dialogue: 0,0:15:24.17,0:15:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina gagal memenuhi harapan Tuan K.
Dialogue: 0,0:15:29.26,0:15:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan membocorkan rencana kita.
Dialogue: 0,0:15:32.85,0:15:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itu bukan tanpa hasil.
Dialogue: 0,0:15:36.06,0:15:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyaksikan perkembangan Soji Enishiro.
Dialogue: 0,0:15:38.48,0:15:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan K.
Dialogue: 0,0:15:40.85,0:15:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menghibur Anda,
Dialogue: 0,0:15:43.02,0:15:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan bagikan informasi baru\Nyang telah kukumpulkan.
Dialogue: 0,0:15:47.53,0:15:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:15:48.78,0:15:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jantungku berdegup kencang sesaat.
Dialogue: 0,0:15:50.78,0:15:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa haus Anda akan pengetahuan\Nsungguh tak terpuaskan, Tuan K.
Dialogue: 0,0:15:54.32,0:15:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku mati sangat cepat saat hidup,
Dialogue: 0,0:15:58.16,0:16:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin memahami\Nsemua hal yang tak diketahui.
Dialogue: 0,0:16:01.12,0:16:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Pak Garan.
Dialogue: 0,0:16:03.71,0:16:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa jauh lebih baik.
Dialogue: 0,0:16:05.75,0:16:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tuan K.
Dialogue: 0,0:16:07.71,0:16:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari peringatan segera tiba.
Dialogue: 0,0:16:10.67,0:16:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus kumpulkan lebih banyak\Npenghuni untuk negeri akun gaib.
Dialogue: 0,0:16:17.26,0:16:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu…
Dialogue: 0,0:16:20.73,0:16:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penginapan onsen sediakan camilan di kamar
Dialogue: 0,0:16:23.77,0:16:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi mencegah kecelakaan\Nakibat gula darah rendah saat berendam.
Dialogue: 0,0:16:27.36,0:16:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:16:35.74,0:16:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa semua orang mandi bersama?
Dialogue: 0,0:16:38.16,0:16:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usai operasi pembasmian roh,\Nsudah lazim masuk ke pemandian.
Dialogue: 0,0:16:41.04,0:16:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga tradisi Akademi Miden.
Dialogue: 0,0:16:44.00,0:16:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah membasmi "kotoran",\Nkita juga harus membersihkan "kotoran".
Dialogue: 0,0:16:48.13,0:16:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namekawa, jangan berenang di sini.
Dialogue: 0,0:16:50.26,0:16:52.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah sewa seluruh tempat,\Njadi tak apa-apa.
Dialogue: 0,0:16:53.01,0:16:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.\NAku paham alasannya sekarang.
Dialogue: 0,0:16:56.30,0:16:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lupakan itu untuk saat ini.
Dialogue: 0,0:16:58.89,0:17:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa para gadis juga di sini?
Dialogue: 0,0:17:01.39,0:17:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:17:02.56,0:17:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti kencan buta, kan?
Dialogue: 0,0:17:05.98,0:17:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sepi kalau cuma dengan tiga gadis.
Dialogue: 0,0:17:09.23,0:17:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro.
Dialogue: 0,0:17:10.81,0:17:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan, Mesum?
Dialogue: 0,0:17:13.24,0:17:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa!
Dialogue: 0,0:17:14.74,0:17:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai baju renang,\Npemandian campuran itu wajar, kan?
Dialogue: 0,0:17:18.99,0:17:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:17:22.50,0:17:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Pemandian campuran?
Dialogue: 0,0:17:25.25,0:17:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa!
Dialogue: 0,0:17:28.38,0:17:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusaba, kau bercanda?
Dialogue: 0,0:17:30.30,0:17:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah pemandian campuran\Ndengan baju renang itu biasa?
Dialogue: 0,0:17:33.63,0:17:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau malu?
Dialogue: 0,0:17:35.93,0:17:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:37.22,0:17:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang malu? Kalau begitu, ayo!
Dialogue: 0,0:17:41.18,0:17:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bercanda, Nona?
Dialogue: 0,0:17:43.60,0:17:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kami harus pedulikan wanita\Ndan mandi pakai celana?
Dialogue: 0,0:17:48.02,0:17:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu?
Dialogue: 0,0:17:49.02,0:17:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria harusnya telanjang!
Dialogue: 0,0:17:52.82,0:17:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melepasnya!
Dialogue: 0,0:17:54.11,0:17:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kau…
Dialogue: 0,0:17:55.11,0:17:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tak keluar,\Naku takkan segan-segan!
Dialogue: 0,0:17:58.16,0:17:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:17:59.41,0:18:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surugi!
Dialogue: 0,0:18:00.91,0:18:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup.
Dialogue: 0,0:18:03.87,0:18:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:06.37,0:18:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:18:07.46,0:18:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih menyenangkan saat kita bersama.
Dialogue: 0,0:18:11.00,0:18:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyenangkan? Mudah saja mengatakannya.
Dialogue: 0,0:18:15.80,0:18:19.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu tradisi Akademi mencari bahagia\Nsaat sulit, bahkan saat seseorang mati.
Dialogue: 0,0:18:19.93,0:18:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro, sepertinya aku pusing.
Dialogue: 0,0:18:24.47,0:18:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kusaba!
Dialogue: 0,0:18:26.85,0:18:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau terlalu bersemangat?
Dialogue: 0,0:18:29.98,0:18:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto.
Dialogue: 0,0:18:32.86,0:18:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu keras padamu\Nsaat Pertarungan Antarkelas.
Dialogue: 0,0:18:37.28,0:18:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama sekali bukan pengecut.
Dialogue: 0,0:18:40.45,0:18:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:18:43.79,0:18:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:18:47.58,0:18:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau tahu betapa hebatnya aku!
Dialogue: 0,0:18:52.13,0:18:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak terbiasa dipuji,\Njadi bingung harus bereaksi apa.
Dialogue: 0,0:18:56.09,0:18:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasumi, aku telah meremehkanmu.
Dialogue: 0,0:18:59.22,0:19:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kau merencanakan itu.
Dialogue: 0,0:19:02.05,0:19:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Hasumi,
Dialogue: 0,0:19:03.68,0:19:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa tak bilang\NWorld Through a Shutter milikmu
Dialogue: 0,0:19:06.18,0:19:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mampu bergerak menembus ruang?
Dialogue: 0,0:19:09.44,0:19:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu,
Dialogue: 0,0:19:11.52,0:19:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu karena aku tak memercayai kalian.
Dialogue: 0,0:19:13.44,0:19:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:16.19,0:19:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salah kalian.
Dialogue: 0,0:19:18.49,0:19:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meragukan semua medium roh,\Nselain Pak Azaki dan Kukuru.
Dialogue: 0,0:19:23.78,0:19:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu hanya saat pertama kali\Nkita masuk Akademi.
Dialogue: 0,0:19:25.79,0:19:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sekarang berbeda.
Dialogue: 0,0:19:28.04,0:19:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Pertarungan Antarkelas,\Naku hanya memikirkan Kelas 1-B.
Dialogue: 0,0:19:32.33,0:19:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan kalian?\NApa yang kalian pikirkan saat itu?
Dialogue: 0,0:19:36.42,0:19:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama pertarungan,\Naku juga memikirkan Kelas 1-B.
Dialogue: 0,0:19:42.85,0:19:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga. Makanya aku tak tahan\Nmereka meremehkan kita.
Dialogue: 0,0:19:47.02,0:19:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku teringat masa kecilku\Nbersama Pak Azaki.
Dialogue: 0,0:19:52.48,0:19:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berada di Kelas 1-B Pak Azaki,\Naku merasa tak boleh payah.
Dialogue: 0,0:19:56.78,0:20:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa suasananya jadi muram?
Dialogue: 0,0:20:00.24,0:20:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berpikir…
Dialogue: 0,0:20:01.24,0:20:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru juga.
Dialogue: 0,0:20:02.36,0:20:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia harus bekerja keras\Nsebagai ketua kelas.
Dialogue: 0,0:20:05.49,0:20:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa…
Dialogue: 0,0:20:06.54,0:20:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Enishiro,\Ndia sangat memotivasinya.
Dialogue: 0,0:20:08.87,0:20:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu!
Dialogue: 0,0:20:10.25,0:20:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:12.12,0:20:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu, Master Haijima?
Dialogue: 0,0:20:15.92,0:20:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Versi Denmi-chan Master!
Dialogue: 0,0:20:19.01,0:20:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bertanya apa aku memikirkanmu?
Dialogue: 0,0:20:21.47,0:20:23.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:20:23.14,0:20:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak, aku takkan berani\Nlakukan gerakan menakutkan itu.
Dialogue: 0,0:20:26.10,0:20:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master!
Dialogue: 0,0:20:28.02,0:20:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita di onsen, lepas bajumu!
Dialogue: 0,0:20:30.48,0:20:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tunggu…\N- Kelas yang luar biasa.
Dialogue: 0,0:20:32.64,0:20:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari mulai dari awal juga.
Dialogue: 0,0:20:35.31,0:20:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Absennya Ashina berdampak besar.
Dialogue: 0,0:20:37.86,0:20:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalah, mungkin kami takkan\Ngabung Proyek Eksorsis K.
Dialogue: 0,0:20:42.11,0:20:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya ide.
Dialogue: 0,0:20:45.20,0:20:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam pertarungan melawan Ashina,
Dialogue: 0,0:20:46.99,0:20:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas 1-A takkan bisa menang\Nkalau kurang satu orang, kan?
Dialogue: 0,0:20:50.66,0:20:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau anggap ini kemenangan\Nbagi semua murid kelas 1?
Dialogue: 0,0:20:54.46,0:20:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita semua ikut proyek eksorsis!
Dialogue: 0,0:20:58.55,0:21:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau orang yang cukup menarik.
Dialogue: 0,0:21:01.84,0:21:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hargai niatmu, tapi kami kalah.\NMemang begitu kenyataannya.
Dialogue: 0,0:21:05.47,0:21:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:06.64,0:21:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda, Berengsek!
Dialogue: 0,0:21:08.39,0:21:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pura-pura\Nkemenangan kita tak terjadi!
Dialogue: 0,0:21:11.31,0:21:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau yang bilang kita menang?
Dialogue: 0,0:21:13.69,0:21:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya kita kalah telak.
Dialogue: 0,0:21:15.98,0:21:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin benar-benar menikmati\Nsensasi kemenangan.
Dialogue: 0,0:21:19.23,0:21:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, biarkan aku ikut!\N- Akari, aku…
Dialogue: 0,0:21:21.32,0:21:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya teman sekarang.
Dialogue: 0,0:21:26.37,0:21:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua orang yang luar biasa.
Dialogue: 0,0:21:30.79,0:21:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku sama sekali tak kesepian.
Dialogue: 0,0:21:36.25,0:21:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga baik-baik saja.
Dialogue: 0,0:21:39.88,0:21:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Autophobia K…
Dialogue: 0,0:21:42.17,0:21:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan lagi sekadar musuh Akari.
Dialogue: 0,0:21:46.59,0:21:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akari,
Dialogue: 0,0:21:48.51,0:21:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan jadi lebih kuat.\NAku harus jadi lebih kuat lagi.
Dialogue: 0,0:21:53.35,0:21:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus berkembang.
Dialogue: 0,0:21:57.35,0:21:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku takkan pernah memaafkanmu.
Dialogue: 0,0:22:00.19,0:22:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tanganku sendiri, aku pasti
Dialogue: 0,0:22:04.11,0:22:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan memusnahkanmu.
