Dialogue: 0,0:04:29.18,0:04:30.85,tanda,,0000,0000,0000,,"KARAOKE"
Dialogue: 0,0:04:36.36,0:04:38.90,tanda,,0000,0000,0000,,"KELUARGA MANASE"
Dialogue: 0,0:04:38.98,0:04:40.28,tanda,,0000,0000,0000,,"AULA PEMAKAMAN"
Dialogue: 0,0:05:01.71,0:05:02.31,tanda,,0000,0000,0000,,"ISU PANAS, BERANDAL MEMBUAT MASALAH"
Dialogue: 0,0:05:02.31,0:05:05.31,tanda,,0000,0000,0000,,"PERILAKU KEJI"
Dialogue: 0,0:05:16.44,0:05:17.94,tanda,,0000,0000,0000,,"SAMPAH DARI SELOKAN\NLEBIH BURUK DARI CACING TANAH"
Dialogue: 0,0:05:17.94,0:05:19.69,tanda,,0000,0000,0000,,"BERANDAL KURANG AJAR, MATI SAJA!"
Dialogue: 0,0:07:02.63,0:07:03.88,tanda,,0000,0000,0000,,"DIUNGGAH"
Dialogue: 0,0:07:03.96,0:07:04.92,tanda,,0000,0000,0000,,"MENGHANCURKAN PROPERTI ORANG LAIN\NBUKAN SEKADAR VANDALISME"
Dialogue: 0,0:07:04.92,0:07:05.48,tanda,,0000,0000,0000,,"MENGINJAK-INJAK PEMILIK DAN\NKERJA KERAS DESAINERNYA"
Dialogue: 0,0:07:05.48,0:07:07.05,tanda,,0000,0000,0000,,"BEDEBAH KERAS KEPALA"
Dialogue: 0,0:07:13.97,0:07:14.97,tanda,,0000,0000,0000,,"BERENGSEK, DIA MIRIP ANAK SMP"
Dialogue: 0,0:07:14.97,0:07:16.22,tanda,,0000,0000,0000,,"MOBIL ITU MUNGKIN BUKAN MILIKNYA"
Dialogue: 0,0:07:16.22,0:07:17.47,tanda,,0000,0000,0000,,"MOBIL RONGSOKAN? TAPI TAMPAK BERFUNGSI"
Dialogue: 0,0:07:17.47,0:07:19.02,tanda,,0000,0000,0000,,"UPAYA SERANGAN TERHADAP MOBIL"
Dialogue: 0,0:07:26.69,0:07:28.86,tanda,,0000,0000,0000,,"HENTIKAN"
Dialogue: 0,0:07:28.94,0:07:30.45,tanda,,0000,0000,0000,,"SUDAH, BERENGSEK! HENTIKAN"
Dialogue: 0,0:07:30.45,0:07:31.36,tanda,,0000,0000,0000,,"BUKANKAH ITU KETERLALUAN?"
Dialogue: 0,0:07:31.36,0:07:32.32,tanda,,0000,0000,0000,,"SADARLAH, EKSTREMIS!"
Dialogue: 0,0:07:32.32,0:07:33.24,tanda,,0000,0000,0000,,"SESEORANG KASIHAN PADAMU"
Dialogue: 0,0:10:48.64,0:10:50.31,tanda,,0000,0000,0000,,"MINORU WAGARI, TIDAK BERDAYA"
Dialogue: 0,0:11:42.24,0:11:44.07,tanda,,0000,0000,0000,,"DEI SURUGI, TIDAK BERDAYA"
Dialogue: 0,0:13:39.82,0:13:40.98,tanda,,0000,0000,0000,,"KELAS 1-B, KASUBATA, HASUMI, URUSUGAWA"
Dialogue: 0,0:13:40.98,0:13:41.50,tanda,,0000,0000,0000,,"KELAS 1-A, WAGARI, SURUGI"
Dialogue: 0,0:13:41.50,0:13:43.32,tanda,,0000,0000,0000,,"NAMEKAWA, KUSABA, OWADA"
Dialogue: 0,0:14:16.27,0:14:21.23,tanda,,0000,0000,0000,,"BAN ASHINA"
Dialogue: 0,0:16:06.63,0:16:09.05,tanda,,0000,0000,0000,,"UNGGAH"
Dialogue: 0,0:16:09.46,0:16:11.13,tanda,,0000,0000,0000,,"SEMUANYA, LIHAT AKU!"
Dialogue: 0,0:16:18.47,0:16:21.02,tanda,,0000,0000,0000,,"POS PERTOLONGAN PERTAMA"
Dialogue: 0,0:19:55.65,0:19:59.74,tanda,,0000,0000,0000,,"AKUN GAIB: BAN ASHINA"
Dialogue: 0,0:00:09.34,0:00:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru.
Dialogue: 0,0:00:11.38,0:00:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:00:14.09,0:00:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah seharusnya\NPak Azaki mengajarinya?
Dialogue: 0,0:00:17.22,0:00:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ketua kelas, kan?\NKuserahkan padamu.
Dialogue: 0,0:00:19.77,0:00:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bercanda?
Dialogue: 0,0:00:20.97,0:00:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu aku benci\Npembasmi roh tipe api, kan?
Dialogue: 0,0:00:23.81,0:00:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sengaja mempermainkanku!
Dialogue: 0,0:00:27.56,0:00:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasannya…
Dialogue: 0,0:00:29.90,0:00:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena…
Dialogue: 0,0:02:05.37,0:02:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ren.
Dialogue: 0,0:02:06.87,0:02:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi dari rumah.
Dialogue: 0,0:02:08.83,0:02:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematian Rota hanyalah pemicunya.
Dialogue: 0,0:02:11.75,0:02:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak.
Dialogue: 0,0:02:13.71,0:02:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lari dari latihan\Nyang menyiksa ini.
Dialogue: 0,0:02:18.97,0:02:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bersenang-senang.
Dialogue: 0,0:02:21.39,0:02:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melampiaskan\Nsemua beban di hatiku.
Dialogue: 0,0:02:26.43,0:02:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kukuru dan Renri.
Dialogue: 0,0:02:28.73,0:02:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus masuk Akademi Miden.
Dialogue: 0,0:02:31.10,0:02:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah.
Dialogue: 0,0:02:32.11,0:02:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu biksu, ya?
Dialogue: 0,0:02:34.02,0:02:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti lagi main peran saja.\NLucu sekali.
Dialogue: 0,0:02:36.15,0:02:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita harus berdoa?
Dialogue: 0,0:02:37.69,0:02:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh tak mau melewatkan\Nanak berbakat seperti kalian.
Dialogue: 0,0:02:41.99,0:02:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya?
Dialogue: 0,0:02:43.58,0:02:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah tak ada urusan\Ndengan medium roh.
Dialogue: 0,0:02:45.66,0:02:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah.
Dialogue: 0,0:02:46.58,0:02:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku tidak berbakat.
Dialogue: 0,0:02:50.37,0:02:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biksunya ditolak.
Dialogue: 0,0:02:52.88,0:02:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah.
Dialogue: 0,0:02:53.92,0:02:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kau berbakat.
Dialogue: 0,0:02:56.09,0:02:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja guru kalian itu bodoh.
Dialogue: 0,0:02:59.17,0:03:00.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan abaikan aku.
Dialogue: 0,0:03:02.26,0:03:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulatih kalian dengan benar.
Dialogue: 0,0:03:04.76,0:03:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shuji!
Dialogue: 0,0:03:05.68,0:03:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:03:06.60,0:03:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur.
Dialogue: 0,0:03:08.02,0:03:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang bersamaan pun,\Nkalian takkan berkutik.
Dialogue: 0,0:03:11.69,0:03:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka Yoimaru Azaki\Nakan mengintai.
Dialogue: 0,0:03:15.23,0:03:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia benar-benar jadi guru.
Dialogue: 0,0:03:18.82,0:03:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tato iblis itu…
Dialogue: 0,0:03:21.07,0:03:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menatonya untuk tegaskan\Ntak ada urusan lagi dengan medium roh?
Dialogue: 0,0:03:24.70,0:03:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niat awalmu mengubah penampilan\Nmalah jadi melenceng.
Dialogue: 0,0:03:26.99,0:03:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda memang lucu.
Dialogue: 0,0:03:29.54,0:03:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi asal tahu saja,
Dialogue: 0,0:03:30.54,0:03:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ular sebenarnya bermakna baik\Ndalam ajaran Buddha.
Dialogue: 0,0:03:32.71,0:03:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyahlah!
Dialogue: 0,0:03:34.29,0:03:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pak Biksu.
Dialogue: 0,0:03:37.09,0:03:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, dia lumayan tampan.
Dialogue: 0,0:03:40.63,0:03:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:03:41.80,0:03:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau minum-minum di barku?
Dialogue: 0,0:03:45.43,0:03:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:03:47.68,0:03:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadamu terlalu terbuka, kan?
Dialogue: 0,0:03:51.89,0:03:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lucu banget.
Dialogue: 0,0:03:53.69,0:03:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menatapnya!
Dialogue: 0,0:03:54.98,0:03:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo, Ren.\N- Dia menatapnya!
Dialogue: 0,0:03:56.19,0:04:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku sudah muak dengan medium roh.\N- Kau manis sekali.
Dialogue: 0,0:04:00.94,0:04:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan kembali ke sana.
Dialogue: 0,0:04:03.16,0:04:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hubungi aku kapan saja!\N- Ayolah.
Dialogue: 0,0:04:05.32,0:04:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibumu juga ingin menemuimu!
Dialogue: 0,0:04:10.04,0:04:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya penyesalanku
Dialogue: 0,0:04:15.29,0:04:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah meninggalkan ibuku di sana,\Nsatu-satunya orang yang baik padaku.
Dialogue: 0,0:04:20.08,0:04:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru.
Dialogue: 0,0:04:22.59,0:04:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun jalan yang kau ambil nanti,
Dialogue: 0,0:04:25.09,0:04:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus jadi orang baik.
Dialogue: 0,0:04:32.60,0:04:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru.
Dialogue: 0,0:04:34.19,0:04:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibumu…
Dialogue: 0,0:04:40.36,0:04:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang ke rumah setelah setahun.
Dialogue: 0,0:04:42.86,0:04:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin minta maaf karena tak sempat\Nmenemuinya untuk terakhir kali.
Dialogue: 0,0:04:48.78,0:04:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru.
Dialogue: 0,0:04:50.45,0:04:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau kembali?
Dialogue: 0,0:04:53.12,0:04:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir tak masalah\Nsekeras apa pun mereka memarahiku.
Dialogue: 0,0:04:57.67,0:04:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sudah melihat ini.
Dialogue: 0,0:05:00.42,0:05:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:05:02.31,0:05:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau aib bagi keluarga Manase!
Dialogue: 0,0:05:05.68,0:05:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu aku yang membuat\Nribut di restoran.
Dialogue: 0,0:05:10.18,0:05:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Video saat aku dipancing berkelahi\Noleh beberapa orang bodoh.
Dialogue: 0,0:05:14.43,0:05:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku direkam, lalu videonya disebar.
Dialogue: 0,0:05:17.94,0:05:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku dihujat.
Dialogue: 0,0:05:19.69,0:05:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibumu sangat terpukul\Nsaat melihat video ini.
Dialogue: 0,0:05:24.40,0:05:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa malu dan kecewa menyiksanya\Nsampai dia tiada.
Dialogue: 0,0:05:28.41,0:05:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meninggal karenamu!
Dialogue: 0,0:05:30.24,0:05:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ngawur, Pak Tua!
Dialogue: 0,0:05:31.62,0:05:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya memang sudah sakit…
Dialogue: 0,0:05:33.12,0:05:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Ren.
Dialogue: 0,0:05:37.00,0:05:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa.
Dialogue: 0,0:05:42.55,0:05:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu dia sengaja\Nmembuatku kesal.
Dialogue: 0,0:05:44.80,0:05:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana jika ibuku…
Dialogue: 0,0:05:47.55,0:05:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan sekecil apa pun\Nmenghancurkan hatiku.
Dialogue: 0,0:05:52.97,0:05:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah orang baik.
Dialogue: 0,0:05:59.56,0:06:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut hitam paling cocok untukmu.
Dialogue: 0,0:06:03.73,0:06:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hanya demi terlihat baik,
Dialogue: 0,0:06:06.82,0:06:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau mengecat hitam rambutmu\Ndan memakai kemeja putih?
Dialogue: 0,0:06:09.07,0:06:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang memulai\Ndari ubah penampilan.
Dialogue: 0,0:06:11.12,0:06:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau blak-blakan sekali.
Dialogue: 0,0:06:13.29,0:06:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tekad seseorang.\NPak Guru, tolong jangan mengejek
Dialogue: 0,0:06:17.04,0:06:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengejeknya.
Dialogue: 0,0:06:19.37,0:06:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya senang.
Dialogue: 0,0:06:20.79,0:06:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:06:21.79,0:06:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang membawamu kembali\Nke dunia medium roh yang kau benci?
Dialogue: 0,0:06:25.88,0:06:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa demi menebus kesalahan pada ibumu?
Dialogue: 0,0:06:27.80,0:06:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau untuk menghukum dirimu sendiri?
Dialogue: 0,0:06:33.14,0:06:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:06:34.52,0:06:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin jalani hidup\Nyang lebih layak.
Dialogue: 0,0:06:39.48,0:06:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru, Renri, selamat datang di Akademi.
Dialogue: 0,0:06:43.23,0:06:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panggil aku Kukuru.
Dialogue: 0,0:06:44.69,0:06:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Haruskah kupanggil kau Manase?
Dialogue: 0,0:06:47.28,0:06:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku mengusirku.
Dialogue: 0,0:06:49.32,0:06:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku ogah kembali\Nke keluarga semacam itu.
Dialogue: 0,0:06:51.78,0:06:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu harus kupanggil apa?
Dialogue: 0,0:06:55.91,0:06:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasubata.
Dialogue: 0,0:06:57.70,0:06:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru Kasubata.
Dialogue: 0,0:06:59.92,0:07:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasubata itu nama keluarga ibuku.
Dialogue: 0,0:07:05.48,0:07:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak hari itu,
Dialogue: 0,0:07:07.05,0:07:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mulai mengkritik\Npara pemancing hujatan itu.
Dialogue: 0,0:07:09.38,0:07:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin mereka sadar\Natas kebodohan mereka
Dialogue: 0,0:07:11.97,0:07:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuat mereka berhenti.
Dialogue: 0,0:07:13.97,0:07:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar sampah.
Dialogue: 0,0:07:14.97,0:07:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Aoringo ini tak bisa kumaafkan.
Dialogue: 0,0:07:16.22,0:07:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Aoringo ini
Dialogue: 0,0:07:17.47,0:07:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak bisa kumaafkan.
Dialogue: 0,0:07:19.02,0:07:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu cuma alasan\Nagar terdengar keren.
Dialogue: 0,0:07:22.44,0:07:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menyakiti diriku sendiri.
Dialogue: 0,0:07:24.57,0:07:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengutuk diriku sendiri.
Dialogue: 0,0:07:26.69,0:07:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya menyenangkan
Dialogue: 0,0:07:28.94,0:07:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengkritik
Dialogue: 0,0:07:30.45,0:07:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para pemancing
Dialogue: 0,0:07:31.36,0:07:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hujatan itu.
Dialogue: 0,0:07:33.24,0:07:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang mengutuk kebodohanku\Nsaat itu.
Dialogue: 0,0:07:37.79,0:07:40.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku membenci tipe api,
Dialogue: 0,0:07:40.87,0:07:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku itu sama seperti mereka.
Dialogue: 0,0:07:43.96,0:07:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa siberkinesis miliknya berevolusi?
Dialogue: 0,0:07:46.30,0:07:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu itu Enflame Hammer…
Dialogue: 0,0:07:49.17,0:07:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasubata.
Dialogue: 0,0:07:50.59,0:07:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuanmu benar-benar\Nmenunjukkan sifat aslimu.
Dialogue: 0,0:07:53.39,0:07:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupotong palu dan lenganmu!
Dialogue: 0,0:07:56.14,0:07:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sever!
Dialogue: 0,0:07:58.89,0:07:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?
Dialogue: 0,0:08:00.06,0:08:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membakar serangannya!
Dialogue: 0,0:08:03.44,0:08:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Wagari,
Dialogue: 0,0:08:05.31,0:08:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekeras apa pun aku perbaiki karakter\Ndan tekun berlatih,
Dialogue: 0,0:08:08.40,0:08:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih menunjukkan sifat asliku.
Dialogue: 0,0:08:09.94,0:08:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku selalu bilang "sial"? Sial!
Dialogue: 0,0:08:13.61,0:08:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap kali aku bilang "sial",
Dialogue: 0,0:08:15.78,0:08:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku diliputi kebencian\Npada diriku sendiri.
Dialogue: 0,0:08:17.78,0:08:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Slice!
Dialogue: 0,0:08:19.49,0:08:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sever!
Dialogue: 0,0:08:21.29,0:08:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:08:22.37,0:08:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mustahil.
Dialogue: 0,0:08:23.79,0:08:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berlatih keras.\NBagaimana bisa kalah?
Dialogue: 0,0:08:29.17,0:08:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:08:31.92,0:08:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wagari adalah sosokku\Nyang tidak kabur.
Dialogue: 0,0:08:34.92,0:08:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku yang kabur\Nbisa mengalahkannya?
Dialogue: 0,0:08:37.64,0:08:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang selalu kupikirkan.
Dialogue: 0,0:08:39.80,0:08:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:08:41.27,0:08:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku bertarung\Nsekeras ini sekarang?
Dialogue: 0,0:08:52.40,0:08:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu tak lari dari masa lalunya\Nsebagai pemancing hujatan.
Dialogue: 0,0:08:55.49,0:08:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghadapinya dan jadi lebih kuat.
Dialogue: 0,0:08:58.16,0:08:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau aku membantu Enishiro?
Dialogue: 0,0:08:59.70,0:09:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus aku?
Dialogue: 0,0:09:00.91,0:09:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin ini yang terbaik.
Dialogue: 0,0:09:03.79,0:09:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya demi Enishiro,
Dialogue: 0,0:09:05.92,0:09:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga demi dirimu sendiri.
Dialogue: 0,0:09:08.75,0:09:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci mengakui
Dialogue: 0,0:09:10.88,0:09:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa aku terpengaruh olehnya\Nkarena tak ingin kalah.
Dialogue: 0,0:09:15.88,0:09:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terbawa suasana!
Dialogue: 0,0:09:17.80,0:09:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pengecut yang kabur dan\Nkembali tanpa rasa malu!
Dialogue: 0,0:09:22.72,0:09:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan Sever terkuatku!
Dialogue: 0,0:09:27.81,0:09:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku memang kabur.
Dialogue: 0,0:09:30.98,0:09:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan berarti hidupku berakhir.
Dialogue: 0,0:09:33.90,0:09:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah dirimu!
Dialogue: 0,0:09:35.95,0:09:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah aku.
Dialogue: 0,0:09:37.53,0:09:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa lalu yang ingin kuhapus,
Dialogue: 0,0:09:41.66,0:09:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua itu,\Nmembentuk diriku yang sekarang!
Dialogue: 0,0:09:46.25,0:09:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:10:02.51,0:10:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang kita berdua tipe api, kan?
Dialogue: 0,0:10:05.02,0:10:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bandingkan aku denganmu.
Dialogue: 0,0:10:06.89,0:10:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan perbedaan kita.
Dialogue: 0,0:10:11.27,0:10:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tak lagi membenciku\Ndan aku kalah darimu,
Dialogue: 0,0:10:15.65,0:10:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau juga akan kehilangan\Nperasaanmu padaku?
Dialogue: 0,0:10:18.86,0:10:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau akhir seperti itu!
Dialogue: 0,0:10:21.74,0:10:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api Langit!
Dialogue: 0,0:10:34.00,0:10:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:10:35.67,0:10:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak kabur.
Dialogue: 0,0:10:38.47,0:10:40.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa pun yang terjadi,
Dialogue: 0,0:10:40.26,0:10:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa melupakan\Nkeinginanku untuk jadi orang baik.
Dialogue: 0,0:10:44.60,0:10:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku. Aku telah menghinamu.
Dialogue: 0,0:10:53.52,0:10:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat.
Dialogue: 0,0:10:55.44,0:10:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh bilang begitu, kan?
Dialogue: 0,0:10:58.49,0:11:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku sungguhan membunuhmu,\NKelas 1-B akan kalah.
Dialogue: 0,0:11:03.70,0:11:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berakhir.
Dialogue: 0,0:11:05.91,0:11:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak menganggapku serius,\Ndan Minoru meninggalkanku.
Dialogue: 0,0:11:09.83,0:11:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mati…
Dialogue: 0,0:11:13.42,0:11:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, tapi ini salahmu sendiri.
Dialogue: 0,0:11:16.59,0:11:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, minta maaf dahulu\Nkarena membakar jepit rambut Akari.
Dialogue: 0,0:11:20.26,0:11:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Maafkan aku.
Dialogue: 0,0:11:22.85,0:11:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, ada apa denganmu?\NKau bikin aku malu.
Dialogue: 0,0:11:26.22,0:11:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kumaafkan.
Dialogue: 0,0:11:29.69,0:11:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:11:31.40,0:11:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau meremehkan Kelas 1-B lagi,
Dialogue: 0,0:11:33.77,0:11:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan benar-benar membunuhmu.
Dialogue: 0,0:11:44.49,0:11:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wagari dan Surugi…
Dialogue: 0,0:11:46.66,0:11:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:11:50.66,0:11:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soji Enishiro.
Dialogue: 0,0:11:54.21,0:11:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soji Enishiro…
Dialogue: 0,0:11:57.80,0:12:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titik reaksi akun gaib ada di depan.
Dialogue: 0,0:12:02.38,0:12:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksinya makin kuat.
Dialogue: 0,0:12:04.76,0:12:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:12:06.47,0:12:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo segera kita periksa.
Dialogue: 0,0:12:10.18,0:12:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku…
Dialogue: 0,0:12:12.19,0:12:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:13.48,0:12:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding perbuatan Wagari padaku,
Dialogue: 0,0:12:17.48,0:12:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini cuma seperti tertusuk tusuk gigi.
Dialogue: 0,0:12:22.24,0:12:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang wajah sedih begitu.
Dialogue: 0,0:12:24.82,0:12:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak gunakan jendelamu\Nuntuk selamatkan kita,
Dialogue: 0,0:12:27.20,0:12:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita mungkin sudah tamat.
Dialogue: 0,0:12:31.75,0:12:32.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru…
Dialogue: 0,0:12:32.75,0:12:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:12:35.38,0:12:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro?
Dialogue: 0,0:12:37.79,0:12:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasubata, kau berantakan sekali.
Dialogue: 0,0:12:39.51,0:12:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:12:41.22,0:12:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau santai sekali.
Dialogue: 0,0:12:43.30,0:12:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:44.76,0:12:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah buat Surugi minta maaf\Nkarena menghina Kelas 1-B.
Dialogue: 0,0:12:51.89,0:12:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengalahkan Surugi? Luar biasa.
Dialogue: 0,0:12:55.65,0:12:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan Kasubata juga.
Dialogue: 0,0:12:57.81,0:13:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengalahkan Wagari? Luar biasa!
Dialogue: 0,0:13:00.86,0:13:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, hasilnya seri.
Dialogue: 0,0:13:03.15,0:13:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukuru dan aku tak bisa bertarung lagi.
Dialogue: 0,0:13:06.74,0:13:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baterai kami hampir habis.
Dialogue: 0,0:13:07.91,0:13:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kita menang.
Dialogue: 0,0:13:15.21,0:13:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro.
Dialogue: 0,0:13:17.46,0:13:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:19.13,0:13:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku hanya berkata jujur.
Dialogue: 0,0:13:23.13,0:13:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.\NKita bicarakan detailnya nanti.
Dialogue: 0,0:13:26.89,0:13:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuka jendela\Nyang selalu ingin kubuka untuk Kukuru.
Dialogue: 0,0:13:32.18,0:13:33.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sungguh membuatku senang.
Dialogue: 0,0:13:34.85,0:13:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski itu juga agak menyebalkan.
Dialogue: 0,0:13:37.81,0:13:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang tak bisa bertarung,
Dialogue: 0,0:13:39.82,0:13:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiga orang tumbang di Kelas 1-B,
Dialogue: 0,0:13:41.50,0:13:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lima orang tumbang di Kelas 1-A.
Dialogue: 0,0:13:43.32,0:13:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:13:45.78,0:13:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya tersisa satu orang.
Dialogue: 0,0:13:47.41,0:13:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ban Ashina.
Dialogue: 0,0:13:50.95,0:13:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:13:52.37,0:13:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang seperti apa dia?
Dialogue: 0,0:13:54.62,0:13:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia…
Dialogue: 0,0:13:56.33,0:13:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu menjuluki dirinya "karya seni"
Dialogue: 0,0:13:59.84,0:14:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terus mengunggah swafoto\Ndi media sosial.
Dialogue: 0,0:14:02.92,0:14:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku wajib tunjukkan kecantikanku\Nkepada umat manusia!
Dialogue: 0,0:14:08.09,0:14:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang perlu kusembunyikan\Ndari tubuhku.
Dialogue: 0,0:14:11.47,0:14:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengikutku,
Dialogue: 0,0:14:13.06,0:14:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saksikan aku sepuasnya!
Dialogue: 0,0:14:16.27,0:14:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, akunnya dibekukan berkali-kali.
Dialogue: 0,0:14:21.57,0:14:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pengguna siberkinesis tipe es.\NMeski dia agak bodoh…
Dialogue: 0,0:14:26.53,0:14:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia lawan yang tangguh.
Dialogue: 0,0:14:28.53,0:14:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber!
Dialogue: 0,0:14:30.74,0:14:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Millennium Suspension!
Dialogue: 0,0:14:38.21,0:14:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara, "Rantai Es Indah".
Dialogue: 0,0:14:53.31,0:14:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber, Millennium Suspension!
Dialogue: 0,0:14:59.65,0:15:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara, "Tirai Es Indah".
Dialogue: 0,0:15:07.24,0:15:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan bisa ubah akun gaib\Nmenjadi karya seni.
Dialogue: 0,0:15:11.53,0:15:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siberkinesis milikku tak tertandingi\Ndalam keindahan.
Dialogue: 0,0:15:17.58,0:15:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe es?
Dialogue: 0,0:15:19.37,0:15:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api dan es.
Dialogue: 0,0:15:21.21,0:15:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertarungan antara panas dan dingin.
Dialogue: 0,0:15:23.88,0:15:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membuat patung es raksasa itu\Nsejak awal.
Dialogue: 0,0:15:26.51,0:15:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti pakai banyak psikokinesis.
Dialogue: 0,0:15:30.84,0:15:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patungnya masih ada?
Dialogue: 0,0:15:32.51,0:15:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan tandinganmu sekarang.
Dialogue: 0,0:15:35.18,0:15:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro.
Dialogue: 0,0:15:36.68,0:15:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami serahkan sisanya padamu.
Dialogue: 0,0:15:39.02,0:15:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:15:39.94,0:15:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembuhkan lukamu dulu,\Ndan bersiaplah untuk perayaan.
Dialogue: 0,0:15:45.19,0:15:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya aku yang tersisa?
Dialogue: 0,0:15:52.57,0:15:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini membuatku makin cantik!
Dialogue: 0,0:15:56.24,0:15:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cermatilah profil ini dengan\Nsedikit sentuhan melankolis.
Dialogue: 0,0:16:00.00,0:16:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecantikan sempurna yang lahir\Ndari rasa kesepian.
Dialogue: 0,0:16:04.17,0:16:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membagikan keindahan ini\Nkepada pengikutku.
Dialogue: 0,0:16:09.46,0:16:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mengunggah ini,
Dialogue: 0,0:16:11.13,0:16:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akunku akan dibekukan lagi.
Dialogue: 0,0:16:13.47,0:16:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tidak masuk akal.
Dialogue: 0,0:16:15.30,0:16:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terlalu cantik itu dosa?
Dialogue: 0,0:16:21.81,0:16:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya selesai.
Dialogue: 0,0:16:23.73,0:16:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kemenangan jadi milik kita,\NKelas 1-B.
Dialogue: 0,0:16:25.73,0:16:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak seyakin itu.
Dialogue: 0,0:16:28.19,0:16:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari jumlah orang yang tersisa,\Nkita kalah jumlah.
Dialogue: 0,0:16:31.95,0:16:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika itu Ashina…
Dialogue: 0,0:16:33.07,0:16:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siberkinesis anak itu sangat kuat.
Dialogue: 0,0:16:36.41,0:16:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun dia bodoh.
Dialogue: 0,0:16:37.87,0:16:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina orang yang luar biasa.
Dialogue: 0,0:16:40.50,0:16:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan membuatkan es serut untuk kita.
Dialogue: 0,0:16:43.71,0:16:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia bodoh.
Dialogue: 0,0:16:46.04,0:16:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihat Enishiro berdarah\Nkarena es si bodoh itu.
Dialogue: 0,0:16:50.05,0:16:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bicara soal bodoh,\NEnishiro sama parahnya!
Dialogue: 0,0:16:53.38,0:16:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan bandingkan\Nmereka seperti itu.
Dialogue: 0,0:16:56.18,0:16:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kochi, tolong bantu.
Dialogue: 0,0:17:01.14,0:17:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian para anak muda\Nterlalu mudah terluka!
Dialogue: 0,0:17:07.60,0:17:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan Antarkelas\Nakhirnya sampai di titik ini.
Dialogue: 0,0:17:12.06,0:17:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Azaki,
Dialogue: 0,0:17:14.15,0:17:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Master,
Dialogue: 0,0:17:16.53,0:17:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto,
Dialogue: 0,0:17:18.57,0:17:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusugawa,
Dialogue: 0,0:17:20.54,0:17:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasumi,
Dialogue: 0,0:17:22.50,0:17:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kasubata,
Dialogue: 0,0:17:24.11,0:17:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka semua membawaku\Nke posisiku saat ini.
Dialogue: 0,0:17:28.08,0:17:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:17:29.55,0:17:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas 1-A-ku… Sial!
Dialogue: 0,0:17:32.63,0:17:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang babak final.
Dialogue: 0,0:17:34.51,0:17:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita saksikan sampai akhir,\NPak Nanzo.
Dialogue: 0,0:17:37.68,0:17:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menerimanya.
Dialogue: 0,0:17:39.35,0:17:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Azaki, kau sudah lupa?
Dialogue: 0,0:17:42.22,0:17:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku dan murid-muridnya\Ndibakar sampai mati oleh Api Hantu K.
Dialogue: 0,0:17:47.40,0:17:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku lupa?
Dialogue: 0,0:17:50.02,0:17:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sahabatku.
Dialogue: 0,0:17:52.69,0:17:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Enishiro bukan K.
Dialogue: 0,0:17:55.11,0:17:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau paham itu, kan?
Dialogue: 0,0:17:57.11,0:17:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanzo.
Dialogue: 0,0:18:03.37,0:18:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali melaporkan.
Dialogue: 0,0:18:06.17,0:18:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi akun gaib yang samar-samar\Nsampai sekarang,
Dialogue: 0,0:18:09.25,0:18:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ini melonjak pesat.
Dialogue: 0,0:18:11.55,0:18:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akun gaib telah muncul\Ndi Kusatsu virtual.
Dialogue: 0,0:18:14.38,0:18:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan para biksu kepala\Ndi lokasi?
Dialogue: 0,0:18:16.59,0:18:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita kirim mereka\Nuntuk menyelidiki?
Dialogue: 0,0:18:18.43,0:18:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu,
Dialogue: 0,0:18:19.76,0:18:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tak bisa menghubungi mereka.
Dialogue: 0,0:18:29.40,0:18:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina, hanya kau yang tersisa\Ndi Kelas 1-A.
Dialogue: 0,0:18:33.32,0:18:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita bertarung.
Dialogue: 0,0:18:36.53,0:18:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah.
Dialogue: 0,0:18:38.45,0:18:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini karya yang baru kuselesaikan.
Dialogue: 0,0:18:41.99,0:18:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judulnya…
Dialogue: 0,0:18:44.24,0:18:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kelemahan yang Membeku".
Dialogue: 0,0:18:47.37,0:18:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu para biksu kepala?
Dialogue: 0,0:18:50.42,0:18:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua mati.
Dialogue: 0,0:18:54.96,0:18:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencoba selesaikan\Npembuatannya, tapi...
Dialogue: 0,0:18:57.26,0:18:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bagus.
Dialogue: 0,0:18:59.76,0:19:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar.
Dialogue: 0,0:19:01.01,0:19:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:02.55,0:19:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:19:04.18,0:19:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di luar batas\NPertarungan Antarkelas.
Dialogue: 0,0:19:05.85,0:19:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:08.44,0:19:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sinilah pertunjukan\Nsebenarnya dimulai.
Dialogue: 0,0:19:11.19,0:19:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahan lagi.
Dialogue: 0,0:19:15.61,0:19:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau dibekukan lagi!
Dialogue: 0,0:19:23.58,0:19:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air mata darah!
Dialogue: 0,0:19:27.37,0:19:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu mendambakan
Dialogue: 0,0:19:29.87,0:19:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akun yang tak bisa dibekukan.
Dialogue: 0,0:19:32.92,0:19:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh yang tak akan membusuk atau menua.
Dialogue: 0,0:19:36.13,0:19:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta sepasang sayap!
Dialogue: 0,0:19:38.22,0:19:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina…
Dialogue: 0,0:19:40.76,0:19:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sumber akun gaibnya?
Dialogue: 0,0:19:45.18,0:19:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mati.
Dialogue: 0,0:19:51.10,0:19:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjadi akun gaib.
Dialogue: 0,0:19:53.52,0:19:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judulnya
Dialogue: 0,0:19:55.65,0:19:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kebangkitan Sang Binatang Cantik".
Dialogue: 0,0:20:00.15,0:20:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akun gaib meneteskan air mata darah.
Dialogue: 0,0:20:03.78,0:20:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah…
Dialogue: 0,0:20:06.12,0:20:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tubuh ini sungguh tak tertandingi.
Dialogue: 0,0:20:08.75,0:20:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan bisa melakukan ini.
Dialogue: 0,0:20:11.58,0:20:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judulnya…
Dialogue: 0,0:20:13.63,0:20:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Pembekuan Besar di Kota Onsen"!
Dialogue: 0,0:20:20.17,0:20:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian terbaiknya adalah\Nkeindahan ini.
Dialogue: 0,0:20:22.76,0:20:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berterima kasih dari\Nlubuk hatiku, K.
Dialogue: 0,0:20:25.10,0:20:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Autophobia K?
Dialogue: 0,0:20:27.22,0:20:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sosok itu mengubahmu\Nmenjadi akun gaib?
Dialogue: 0,0:20:30.98,0:20:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Badai salju?
Dialogue: 0,0:20:33.73,0:20:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali.
Dialogue: 0,0:20:35.19,0:20:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pelindung.
Dialogue: 0,0:20:36.90,0:20:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh Kusatsu virtual\Nditutupi pelindung.
Dialogue: 0,0:20:39.94,0:20:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang bisa keluar
Dialogue: 0,0:20:41.82,0:20:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak ada yang bisa masuk.
Dialogue: 0,0:20:44.49,0:20:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina.
Dialogue: 0,0:20:46.49,0:20:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kita lakukan?
Dialogue: 0,0:20:56.96,0:21:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan K, sepertinya suasana hatimu\Nsedang baik.
Dialogue: 0,0:21:00.67,0:21:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:02.09,0:21:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkan impianku terwujud
Dialogue: 0,0:21:04.43,0:21:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku sangat senang.
Dialogue: 0,0:21:06.80,0:21:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat Tuan K sangat senang,
Dialogue: 0,0:21:10.60,0:21:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku sangat senang juga.
Dialogue: 0,0:21:14.94,0:21:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai dugaan, dia istimewa\Nbagi Tuan K.
Dialogue: 0,0:21:20.19,0:21:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:21:21.99,0:21:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina... Murid Kelas 1-A dibunuh.
Dialogue: 0,0:21:25.57,0:21:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu K mengubahnya\Nmenjadi akun gaib.
Dialogue: 0,0:21:28.58,0:21:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Nanzo.
Dialogue: 0,0:21:31.41,0:21:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang diinginkan Ashina sendiri.
Dialogue: 0,0:21:35.17,0:21:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Azaki.
Dialogue: 0,0:21:37.50,0:21:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa masuk ke Kusatsu virtual.
Dialogue: 0,0:21:39.84,0:21:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelindungnya sangat kuat.
Dialogue: 0,0:21:42.01,0:21:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu akun gaib tingkat menengah...
Dialogue: 0,0:21:45.47,0:21:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu tingkat lanjut.
Dialogue: 0,0:21:49.26,0:21:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ban Ashina, kudengar kau bodoh.
Dialogue: 0,0:21:53.39,0:21:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak kusangka kau sebodoh ini.
Dialogue: 0,0:21:55.94,0:21:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soji Enishiro.
Dialogue: 0,0:21:57.73,0:21:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kugunakan kematianmu
Dialogue: 0,0:21:59.69,0:22:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menuntaskan pekerjaanku\Ndemi K.
Dialogue: 0,0:22:02.53,0:22:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan
Dialogue: 0,0:22:04.19,0:22:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kubasmi dengan tanganku sendiri\Ndi sini!
