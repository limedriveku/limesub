Dialogue: 0,0:00:37.03,0:00:38.22,tanda,,0000,0000,0000,,"SERIBU BELAIAN ANGIN"
Dialogue: 0,0:03:13.48,0:03:15.94,tanda,,0000,0000,0000,,"TERIMA KASIH" "TERLALU INDAH"
Dialogue: 0,0:03:51.89,0:03:53.94,tanda,,0000,0000,0000,,"BAN ASHINA, AKUNMU DITANGGUHKAN"
Dialogue: 0,0:04:02.78,0:04:03.61,tanda,,0000,0000,0000,,"KELAS 1-A"
Dialogue: 0,0:04:03.86,0:04:05.45,tanda,,0000,0000,0000,,"AKADEMI MIDEN"
Dialogue: 0,0:04:42.07,0:04:43.99,tanda,,0000,0000,0000,,"KELAS 1-A"
Dialogue: 0,0:05:30.12,0:05:31.87,tanda,,0000,0000,0000,,"AKUNMU DITANGGUHKAN"
Dialogue: 0,0:05:34.45,0:05:35.96,tanda,,0000,0000,0000,,"KENAPA KEINDAHAN MEMUDAR?"
Dialogue: 0,0:05:37.79,0:05:38.85,tanda,,0000,0000,0000,,"MANA FOTO TELANJANGMU?\NKAU SUDAH MENCAPAI BATAS?"
Dialogue: 0,0:05:38.88,0:05:40.35,tanda,,0000,0000,0000,,"ADA APA INI?\NKAU INDAH, AKU MENDUKUNGMU"
Dialogue: 0,0:05:40.38,0:05:41.71,tanda,,0000,0000,0000,,"APA ARTINYA JIKA TIDAK ABADI?"
Dialogue: 0,0:05:45.22,0:05:46.15,tanda,,0000,0000,0000,,"JANGAN KHAWATIR, AKU MENDUKUNGMU"
Dialogue: 0,0:05:46.18,0:05:47.57,tanda,,0000,0000,0000,,"SEMUA AKAN BAIK-BAIK SAJA,\NKAU INDAH, KAU MAU PENSIUN?"
Dialogue: 0,0:05:47.59,0:05:49.40,tanda,,0000,0000,0000,,"AKU TAK MAU MENGHILANG,\NAKU TAK MAU DIHAPUS"
Dialogue: 0,0:05:52.60,0:05:54.60,tanda,,0000,0000,0000,,"BUAT KEINDAHANMU ABADI"
Dialogue: 0,0:05:57.60,0:06:00.19,tanda,,0000,0000,0000,,"KENAPA TAK ADA YANG MENDENGAR?\NHANYA AKU YANG MEMPERHATIKANMU"
Dialogue: 0,0:06:02.73,0:06:04.78,tanda,,0000,0000,0000,,"AUTOPHOBIA K"
Dialogue: 0,0:06:05.15,0:06:06.36,tanda,,0000,0000,0000,,K.
Dialogue: 0,0:06:23.92,0:06:25.27,tanda,,0000,0000,0000,,"KEINDAHANMU LAYAK\NDIPERTAHANKAN SELAMANYA"
Dialogue: 0,0:06:25.30,0:06:27.63,tanda,,0000,0000,0000,,"JANGAN BIARKAN TUBUHMU TERNODA,\NJADILAH INDAH SELAMANYA"
Dialogue: 0,0:06:39.23,0:06:40.12,tanda,,0000,0000,0000,,"KENAPA BANYAK YANG TAK MENGHARGAI KEINDAHAN?"\NK,
Dialogue: 0,0:06:41.86,0:06:43.17,tanda,,0000,0000,0000,,"BEBASKAN SAJA DIRIMU"
Dialogue: 0,0:06:43.19,0:06:45.40,tanda,,0000,0000,0000,,"BEBASKAN DIRIMU DARI DUNIA\NYANG TAK PAHAMI KEINDAHAN"
Dialogue: 0,0:06:53.20,0:06:54.37,tanda,,0000,0000,0000,,K...
Dialogue: 0,0:06:59.33,0:07:00.79,tanda,,0000,0000,0000,,"KELAS 1-A"
Dialogue: 0,0:07:16.89,0:07:17.78,tanda,,0000,0000,0000,,"AKU AKAN MENDATANGIMU BESOK"
Dialogue: 0,0:07:22.60,0:07:23.44,tanda,,0000,0000,0000,,"AUTOPHOBIA K"
Dialogue: 0,0:07:23.52,0:07:24.71,tanda,,0000,0000,0000,,"HARAPANMU KAN SEGERA TERWUJUD"
Dialogue: 0,0:07:24.73,0:07:27.40,tanda,,0000,0000,0000,,"TERIMA KASIH, AKU MENANTIKANNYA"
Dialogue: 0,0:07:27.53,0:07:28.53,tanda,,0000,0000,0000,,"UNGGAH"
Dialogue: 0,0:07:30.99,0:07:32.47,tanda,,0000,0000,0000,,"SEMUANYA, LIHAT AKU"
Dialogue: 0,0:07:41.67,0:07:42.75,tanda,,0000,0000,0000,,K.
Dialogue: 0,0:07:43.21,0:07:44.54,tanda,,0000,0000,0000,,"IKUTI"
Dialogue: 0,0:07:44.63,0:07:46.50,tanda,,0000,0000,0000,,"MENGIKUTI"
Dialogue: 0,0:09:30.90,0:09:33.69,tanda,,0000,0000,0000,,"POS MEDIS"
Dialogue: 0,0:20:05.70,0:20:06.62,tanda,,0000,0000,0000,,"KELAS 1-A, KELAS 1-B"
Dialogue: 0,0:00:04.42,0:00:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ban Ashina.
Dialogue: 0,0:00:06.50,0:00:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan
Dialogue: 0,0:00:08.38,0:00:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kubasmi sendiri!
Dialogue: 0,0:00:12.17,0:00:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa!
Dialogue: 0,0:00:13.84,0:00:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia biasa punya kemampuan\Nmelompat setinggi itu.
Dialogue: 0,0:00:15.80,0:00:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api biru langit itu memang indah.
Dialogue: 0,0:00:18.97,0:00:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adu keindahan, 'kan?
Dialogue: 0,0:00:21.06,0:00:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keindahan apanya?
Dialogue: 0,0:00:22.39,0:00:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sok keren\Nsaat sedang telanjang?
Dialogue: 0,0:00:25.94,0:00:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukum manusia tak lagi mengikatku.
Dialogue: 0,0:00:28.94,0:00:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puaskan pandanganmu.
Dialogue: 0,0:00:30.53,0:00:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tubuh ini indah?
Dialogue: 0,0:00:32.90,0:00:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang mau lihat?
Dialogue: 0,0:00:34.49,0:00:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya, tangan ini...
Dialogue: 0,0:00:37.03,0:00:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:00:38.24,0:00:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seribu Belaian Dingin!
Dialogue: 0,0:00:42.37,0:00:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat lekuk jari dan kuku\Nyang ramping ini. Sempurna.
Dialogue: 0,0:00:46.63,0:00:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bergerak...
Dialogue: 0,0:00:48.63,0:00:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri sekali.
Dialogue: 0,0:00:49.96,0:00:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku bisa memeluk diriku sendiri.
Dialogue: 0,0:00:53.76,0:00:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bercanda.
Dialogue: 0,0:00:56.13,0:00:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apiku bisa menekan akun gaib.
Dialogue: 0,0:00:59.43,0:01:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma membuatku makin kuat, Bodoh!
Dialogue: 0,0:01:06.35,0:01:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika meleset, seranganmu sia-sia!
Dialogue: 0,0:01:09.61,0:01:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:01:12.69,0:01:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napas Beku Hantu.
Dialogue: 0,0:01:15.11,0:01:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku.
Dialogue: 0,0:01:16.03,0:01:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku!
Dialogue: 0,0:01:16.95,0:01:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihat diriku sendiri.
Dialogue: 0,0:01:17.87,0:01:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:01:19.62,0:01:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertunjukan panggung khusus\Nyang kusiapkan untukmu.
Dialogue: 0,0:01:23.33,0:01:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatilah dari barisan terdepan.
Dialogue: 0,0:01:25.58,0:01:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soji Enishiro!
Dialogue: 0,0:01:31.59,0:01:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh akun gaib...
Dialogue: 0,0:01:34.72,0:01:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa!
Dialogue: 0,0:03:11.40,0:03:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usai membuat ulang akunku,
Dialogue: 0,0:03:13.48,0:03:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengikutku tembus 8.000 akun.
Dialogue: 0,0:03:16.02,0:03:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus terus menyebarkan keindahanku.
Dialogue: 0,0:03:20.15,0:03:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:22.11,0:03:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa menghentikan\Nwaktu yang berlalu.
Dialogue: 0,0:03:24.53,0:03:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini aku lebih tua\Ndaripada sedetik yang lalu.
Dialogue: 0,0:03:28.87,0:03:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takdir yang tak masuk akal.
Dialogue: 0,0:03:31.00,0:03:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini kerugian besar bagi dunia?
Dialogue: 0,0:03:34.59,0:03:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keindahanku takkan bertahan selamanya.
Dialogue: 0,0:03:39.59,0:03:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keliru. Ini sebuah kesalahan.
Dialogue: 0,0:03:42.68,0:03:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini yang salah!
Dialogue: 0,0:03:44.97,0:03:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keindahanku seharusnya menjadi abadi!
Dialogue: 0,0:03:48.18,0:03:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu, berhentilah sekarang juga!
Dialogue: 0,0:03:54.02,0:03:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, akunku
Dialogue: 0,0:03:56.73,0:03:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditangguhkan.
Dialogue: 0,0:04:02.78,0:04:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:04:03.86,0:04:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku potret sekarang.
Dialogue: 0,0:04:07.08,0:04:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ashina.
Dialogue: 0,0:04:08.95,0:04:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menghalangi.\NJangan julurkan kakimu.
Dialogue: 0,0:04:11.46,0:04:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina, hentikan.
Dialogue: 0,0:04:14.42,0:04:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ban Ashina, sudah kubilang berkali-kali.
Dialogue: 0,0:04:17.04,0:04:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu mencolok.
Dialogue: 0,0:04:18.58,0:04:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih baik\Njika ini jadi foto pribadiku?
Dialogue: 0,0:04:22.72,0:04:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini foto peringatan pendaftaran.
Dialogue: 0,0:04:25.18,0:04:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namekawa, aku muak dengan ini.
Dialogue: 0,0:04:27.89,0:04:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan.\NAku tak percaya sekelas dengannya.
Dialogue: 0,0:04:32.81,0:04:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia lumayan tampan.
Dialogue: 0,0:04:35.98,0:04:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusa... Kusaba?
Dialogue: 0,0:04:38.19,0:04:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Nanzo, dia sungguh tak apa?
Dialogue: 0,0:04:42.07,0:04:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penilaianku selalu benar.
Dialogue: 0,0:04:45.24,0:04:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau telanjang?
Dialogue: 0,0:04:47.03,0:04:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan paham nanti.
Dialogue: 0,0:04:52.70,0:04:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sever!
Dialogue: 0,0:04:58.50,0:04:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:05:01.46,0:05:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak pintar.
Dialogue: 0,0:05:04.47,0:05:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia terlahir untuk mati.
Dialogue: 0,0:05:06.22,0:05:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kecelakaan, penyakit,\Natau pembunuhan.
Dialogue: 0,0:05:09.35,0:05:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terhindar dari semua itu,\Nkau tak bisa lari dari penuaan.
Dialogue: 0,0:05:13.93,0:05:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia tak bisa melawan kematian.
Dialogue: 0,0:05:19.77,0:05:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seindah apa pun tubuhmu,
Dialogue: 0,0:05:21.94,0:05:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perlahan akan menua dan membusuk.
Dialogue: 0,0:05:24.65,0:05:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keindahanku takkan\Nbertahan selamanya.
Dialogue: 0,0:05:30.12,0:05:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengerikan sekali.
Dialogue: 0,0:05:36.46,0:05:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:43.38,0:05:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tak ada yang mengerti?
Dialogue: 0,0:05:49.43,0:05:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:02.73,0:06:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Autophobia...
Dialogue: 0,0:06:07.53,0:06:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dahulu, di Timur maupun Barat,\Nmonster terus menggoda manusia.
Dialogue: 0,0:06:13.24,0:06:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika K mengirimimu pesan langsung,\Nsegera laporkan ke Akademi.
Dialogue: 0,0:06:28.05,0:06:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Untuk selamanya".
Dialogue: 0,0:06:29.80,0:06:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frasa yang menenangkan.
Dialogue: 0,0:06:34.47,0:06:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K, akunku ditangguhkan lagi.
Dialogue: 0,0:06:40.15,0:06:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku takut.
Dialogue: 0,0:06:41.86,0:06:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut diriku membusuk.
Dialogue: 0,0:06:45.73,0:06:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menatap ponselnya lagi.
Dialogue: 0,0:06:48.28,0:06:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja.
Dialogue: 0,0:06:49.61,0:06:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat memuja dirinya.
Dialogue: 0,0:06:54.45,0:06:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya K yang memahamiku.
Dialogue: 0,0:07:01.12,0:07:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok Pertarungan Antarkelas,
Dialogue: 0,0:07:02.79,0:07:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas 1-A pasti akan menang.
Dialogue: 0,0:07:05.25,0:07:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahatlah untuk pertarungan besok.
Dialogue: 0,0:07:09.63,0:07:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau bekerja sama denganku?
Dialogue: 0,0:07:13.35,0:07:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupastikan akunmu\Ntakkan dibekukan lagi.
Dialogue: 0,0:07:17.81,0:07:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok...
Dialogue: 0,0:07:19.06,0:07:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keindahanku akan abadi.
Dialogue: 0,0:07:21.69,0:07:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:07:23.52,0:07:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jadi
Dialogue: 0,0:07:24.73,0:07:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}simbol keindahan.
Dialogue: 0,0:07:30.99,0:07:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mengunggah ini,
Dialogue: 0,0:07:32.49,0:07:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akunku akan dibekukan lagi.
Dialogue: 0,0:07:33.99,0:07:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tak masuk akal.
Dialogue: 0,0:07:35.74,0:07:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terlalu indah itu sebuah dosa?
Dialogue: 0,0:07:43.21,0:07:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri aku tubuh
Dialogue: 0,0:07:44.63,0:07:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang keindahannya bukan lagi dosa.
Dialogue: 0,0:07:47.38,0:07:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K, tolong beri aku
Dialogue: 0,0:07:51.34,0:07:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keindahan abadi!
Dialogue: 0,0:08:11.49,0:08:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inspirasi mengalir deras dariku!
Dialogue: 0,0:08:14.32,0:08:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencipta lebih banyak.
Dialogue: 0,0:08:16.37,0:08:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah. Aku tahu kau belum mati.
Dialogue: 0,0:08:20.12,0:08:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melapisi seluruh tubuhmu\Ndengan lapisan tipis Api Hantu?
Dialogue: 0,0:08:23.58,0:08:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu meredam kerusakan, dan juga\Ncegah kau membeku di badai salju.
Dialogue: 0,0:08:28.59,0:08:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa! Teknik tingkat tinggi!
Dialogue: 0,0:08:31.97,0:08:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia menyadarinya?
Dialogue: 0,0:08:33.38,0:08:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi metode itu menguras\Nbanyak psikokinesis.
Dialogue: 0,0:08:38.14,0:08:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa sisa kekuatanmu?
Dialogue: 0,0:08:40.22,0:08:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu aku juga begitu.
Dialogue: 0,0:08:42.39,0:08:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah.
Dialogue: 0,0:08:43.60,0:08:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:08:45.60,0:08:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mahakarya terakhir dan terhebatku.
Dialogue: 0,0:08:49.07,0:08:52.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh banyak psikokinesis\Nhanya untuk menciptakannya.
Dialogue: 0,0:08:53.61,0:08:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu Wagari sering memarahiku.
Dialogue: 0,0:08:55.99,0:08:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang kelemahan terbesarku,\Nyaitu tak punya psikokinesis.
Dialogue: 0,0:08:59.66,0:09:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang,
Dialogue: 0,0:09:01.37,0:09:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada tanda-tanda\Npsikokinesisku terkuras!
Dialogue: 0,0:09:03.91,0:09:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuanku bahkan meningkat\Nke tingkat yang berbeda.
Dialogue: 0,0:09:06.71,0:09:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pujilah tubuh agung ini sepuasnya!
Dialogue: 0,0:09:11.05,0:09:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:09:13.13,0:09:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di awal Pertarungan Antarkelas,
Dialogue: 0,0:09:15.22,0:09:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku terkejut melihat patung itu.
Dialogue: 0,0:09:18.43,0:09:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seni yang kau banggakan\Nsama dengan penampilanmu,
Dialogue: 0,0:09:23.31,0:09:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}layaknya lelucon yang buruk!
Dialogue: 0,0:09:27.48,0:09:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masih terlalu revolusioner untukmu.
Dialogue: 0,0:09:30.90,0:09:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuakhiri pertarunganku denganmu,
Dialogue: 0,0:09:33.94,0:09:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu kuhabisi semua murid Kelas 1.
Dialogue: 0,0:09:37.82,0:09:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dihabisi?
Dialogue: 0,0:09:39.32,0:09:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong macam apa itu?
Dialogue: 0,0:09:40.95,0:09:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ashina!
Dialogue: 0,0:09:42.54,0:09:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia secara sukarela\Nberubah menjadi akun gaib.
Dialogue: 0,0:09:46.12,0:09:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:09:50.00,0:09:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina telah menjadi musuh kita.
Dialogue: 0,0:09:52.88,0:09:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus membasminya di sini.
Dialogue: 0,0:09:55.63,0:09:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Hasumi.
Dialogue: 0,0:09:57.18,0:10:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akun Ashina mengikuti K.
Dialogue: 0,0:10:00.85,0:10:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Divisi Intelijen punya daftar\Nsemua pengikut K.
Dialogue: 0,0:10:04.43,0:10:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia pasti hanya pengikut biasa.
Dialogue: 0,0:10:06.52,0:10:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rencana yang amat terstruktur.
Dialogue: 0,0:10:09.10,0:10:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berniat mengurung semua murid\NKelas 1 dan membunuh kita.
Dialogue: 0,0:10:13.11,0:10:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatinya sudah lama hancur.
Dialogue: 0,0:10:15.61,0:10:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan saatnya buang waktu.
Dialogue: 0,0:10:17.99,0:10:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak!\NPemulihanku belum selesai.
Dialogue: 0,0:10:21.12,0:10:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku hanya akan jadi beban\Ndengan sedikit psikokinesis.
Dialogue: 0,0:10:26.83,0:10:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Owada.
Dialogue: 0,0:10:28.12,0:10:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tersingkir di babak kedua, 'kan?\NPasti psikokinesismu masih banyak.
Dialogue: 0,0:10:35.13,0:10:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piaraanku tak tahan dingin.
Dialogue: 0,0:10:38.55,0:10:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk memulihkan psikokinesis,\Nkenapa kau tak tidur siang saja?
Dialogue: 0,0:10:43.06,0:10:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana bisa tidur di saat begini?
Dialogue: 0,0:10:45.10,0:10:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:10:46.56,0:10:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cuma dia yang bisa kita andalkan?
Dialogue: 0,0:10:50.77,0:10:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghabisi mereka semua?
Dialogue: 0,0:10:52.48,0:10:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bahkan tak ampuni Kelas 1-A?
Dialogue: 0,0:10:54.57,0:10:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah mereka temanmu?
Dialogue: 0,0:10:57.40,0:10:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah punya teman.
Dialogue: 0,0:11:00.20,0:11:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seni adalah cara melampaui diri.
Dialogue: 0,0:11:03.49,0:11:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wagari dan Surugi memang berengsek,
Dialogue: 0,0:11:06.45,0:11:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kaulah yang paling menjijikkan.
Dialogue: 0,0:11:09.04,0:11:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ban Ashina!
Dialogue: 0,0:11:11.17,0:11:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api Langit!
Dialogue: 0,0:11:14.04,0:11:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya terbang lebih tinggi dariku\Nsi pemilik sayap ini?
Dialogue: 0,0:11:17.01,0:11:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu arogan.
Dialogue: 0,0:11:19.59,0:11:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:11:22.01,0:11:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tirai Es Maut.
Dialogue: 0,0:11:26.72,0:11:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api Hantuku...
Dialogue: 0,0:11:28.31,0:11:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apinya padam.
Dialogue: 0,0:11:29.73,0:11:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa begini?
Dialogue: 0,0:11:30.73,0:11:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api Hantu Enishiro seharusnya\Nampuh melawan akun gaib.
Dialogue: 0,0:11:34.11,0:11:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wagari, jurus itu...
Dialogue: 0,0:11:36.73,0:11:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:11:38.03,0:11:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Tirai Es Indah telah berevolusi.
Dialogue: 0,0:11:41.20,0:11:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kaki kananku tak mampu,
Dialogue: 0,0:11:42.87,0:11:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih punya kaki kiri!
Dialogue: 0,0:11:44.70,0:11:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:11:45.95,0:11:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rantai Es Maut!
Dialogue: 0,0:11:49.54,0:11:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakan yang kami latih bersama...
Dialogue: 0,0:11:56.59,0:11:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:11:58.09,0:12:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuhnya Api Biru Langit!
Dialogue: 0,0:12:00.72,0:12:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya karya seni\Nyang menari di udara hanyalah aku!
Dialogue: 0,0:12:04.39,0:12:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatmu di tanah.
Dialogue: 0,0:12:06.85,0:12:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:12:19.69,0:12:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak terluka atau kedinginan.
Dialogue: 0,0:12:22.32,0:12:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bedebah yang tinggalkan\Nteman-temanmu.
Dialogue: 0,0:12:24.36,0:12:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan kau membekukanku!
Dialogue: 0,0:12:31.58,0:12:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.\NApa psikokinesisnya habis?
Dialogue: 0,0:12:33.92,0:12:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu...
Dialogue: 0,0:12:35.92,0:12:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemadaman otomatis akibat suhu rendah.
Dialogue: 0,0:12:37.88,0:12:42.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin ekstrem turunkan voltase\Nperangkat penyalur hingga mati.
Dialogue: 0,0:12:45.76,0:12:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat. Dingin ekstrem ini...
Dialogue: 0,0:12:48.43,0:12:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bergerak.
Dialogue: 0,0:12:50.10,0:12:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rapuh sekali.
Dialogue: 0,0:12:52.02,0:12:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini juga seni.
Dialogue: 0,0:12:54.10,0:12:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:12:55.02,0:12:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ini keterlaluan!
Dialogue: 0,0:12:57.44,0:12:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:13:00.48,0:13:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya menutup tirai.
Dialogue: 0,0:13:04.36,0:13:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah kematian\Ndengan kehormatan tertinggi!
Dialogue: 0,0:13:09.03,0:13:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:13:10.54,0:13:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman Es Maut.
Dialogue: 0,0:13:13.91,0:13:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:13:27.01,0:13:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku terlambat.
Dialogue: 0,0:13:29.30,0:13:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu sibuk ketakutan.
Dialogue: 0,0:13:34.73,0:13:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto, kau datang!
Dialogue: 0,0:13:37.23,0:13:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei...
Dialogue: 0,0:13:38.81,0:13:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu monster Ashina?
Dialogue: 0,0:13:41.11,0:13:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa keadaan jadi sangat serius\Nsaat aku ketakutan?
Dialogue: 0,0:13:48.16,0:13:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya ganggu seniku?
Dialogue: 0,0:13:50.12,0:13:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana hatiku sedang buruk.
Dialogue: 0,0:13:52.24,0:13:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:13:53.75,0:13:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayap Es Maut.
Dialogue: 0,0:13:57.42,0:13:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut.
Dialogue: 0,0:13:59.42,0:14:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan esnya\Ntak bisa tembus dinding ini.
Dialogue: 0,0:14:02.67,0:14:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatanmu menghangatkan diri\Ndan hidupkan ponselmu lagi.
Dialogue: 0,0:14:06.34,0:14:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto!
Dialogue: 0,0:14:07.63,0:14:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak! Kau hangat sekali!
Dialogue: 0,0:14:11.14,0:14:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gunakan aku\Nuntuk hangatkan dirimu!
Dialogue: 0,0:14:12.43,0:14:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, jika fokus musik Emoto hilang,\Ndindingnya akan lenyap.
Dialogue: 0,0:14:18.90,0:14:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ponselku pulih,
Dialogue: 0,0:14:21.65,0:14:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengandalkanmu, Emoto.
Dialogue: 0,0:14:24.15,0:14:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita lihat\Nberapa lama kau bisa bertahan.
Dialogue: 0,0:14:26.99,0:14:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto Pengecut.
Dialogue: 0,0:14:32.74,0:14:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu memikirkannya.
Dialogue: 0,0:14:34.29,0:14:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokuslah.
Dialogue: 0,0:14:39.92,0:14:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto.
Dialogue: 0,0:14:40.92,0:14:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pernah sebut dirimu\Nmedium roh lagi.
Dialogue: 0,0:14:43.34,0:14:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat menjijikkan!
Dialogue: 0,0:14:46.97,0:14:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layaknya seni,
Dialogue: 0,0:14:48.68,0:14:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada mahakarya\Ndan karya yang tak bernilai.
Dialogue: 0,0:14:51.22,0:14:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau, Emoto...
Dialogue: 0,0:14:53.64,0:14:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau tersingkir.
Dialogue: 0,0:14:58.31,0:14:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak yang kau habiskan?
Dialogue: 0,0:14:59.81,0:15:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku takut suara bising.\N- Apa urusannya denganmu?
Dialogue: 0,0:15:01.10,0:15:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku takut suara bising.\N- Itu bukan cuma uangmu.
Dialogue: 0,0:15:02.48,0:15:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Orang tuaku selalu buat keributan itu.\N- Itu bukan cuma uangmu.
Dialogue: 0,0:15:05.40,0:15:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sejak kecil aku selalu tutup telinga.\N- Cari uang, Bodoh!
Dialogue: 0,0:15:09.36,0:15:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku berusaha bersembunyi di sudut\N- Ini menyebalkan.
Dialogue: 0,0:15:11.82,0:15:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berharap suara bising itu\Ntak mengarah padaku.
Dialogue: 0,0:15:15.87,0:15:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari...
Dialogue: 0,0:15:16.91,0:15:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bocah Emoto.
Dialogue: 0,0:15:20.79,0:15:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anggota band tak terkenal\Nyang tinggal di sebelah.
Dialogue: 0,0:15:24.46,0:15:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dinding apartemen ini\Nsangat tipis?
Dialogue: 0,0:15:27.51,0:15:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahmu sangat berisik.
Dialogue: 0,0:15:31.84,0:15:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini, ambillah.
Dialogue: 0,0:15:34.89,0:15:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat keren.
Dialogue: 0,0:15:37.43,0:15:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pemutar MP3 usang pada masanya.
Dialogue: 0,0:15:41.94,0:15:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada satu album band lama\Ndi dalamnya.
Dialogue: 0,0:15:46.69,0:15:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara bisingnya menutupi\Nkebisingan yang tak tertahankan itu.
Dialogue: 0,0:15:51.86,0:15:53.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menjadi tempat perlindunganku.
Dialogue: 0,0:15:58.20,0:15:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan juga.
Dialogue: 0,0:15:59.91,0:16:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku.
Dialogue: 0,0:16:01.75,0:16:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang tak kasatmata menekanku.
Dialogue: 0,0:16:04.13,0:16:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali... Aku bisa mati.
Dialogue: 0,0:16:07.34,0:16:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang besar terjadi lagi.
Dialogue: 0,0:16:09.76,0:16:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya siberkinesisnya di luar kendali.
Dialogue: 0,0:16:11.88,0:16:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal biasa saat pertama kali\Nkemampuanmu bangkit.
Dialogue: 0,0:16:16.72,0:16:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kemampuan bertahan\Nyang ciptakan dinding.
Dialogue: 0,0:16:18.93,0:16:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kemampuan yang hebat.
Dialogue: 0,0:16:20.73,0:16:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan pada putramu?
Dialogue: 0,0:16:23.60,0:16:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak melakukan apa-apa.
Dialogue: 0,0:16:25.27,0:16:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bantu aku.
Dialogue: 0,0:16:27.86,0:16:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak melakukan apa pun?
Dialogue: 0,0:16:30.61,0:16:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tunggu sampai dia\Nkehabisan psikokinesis?
Dialogue: 0,0:16:32.82,0:16:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:16:34.24,0:16:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat lemah sekarang.
Dialogue: 0,0:16:36.20,0:16:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma dia yang kondisinya begini.
Dialogue: 0,0:16:37.99,0:16:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang ini\Nsungguh tak melakukan apa-apa.
Dialogue: 0,0:16:41.54,0:16:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bergegas.
Dialogue: 0,0:16:44.46,0:16:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Pak Azaki!
Dialogue: 0,0:16:46.67,0:16:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia langsung menerobos masuk.
Dialogue: 0,0:16:48.30,0:16:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dia yang bisa gunakan\Nmetode sekasar itu.
Dialogue: 0,0:16:51.22,0:16:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:53.63,0:16:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak... Jangan! Kembalikan!
Dialogue: 0,0:16:58.18,0:16:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tak apa-apa.
Dialogue: 0,0:17:03.35,0:17:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selamat.
Dialogue: 0,0:17:05.02,0:17:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini salah anak tersebut?
Dialogue: 0,0:17:06.15,0:17:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster ini.
Dialogue: 0,0:17:12.56,0:17:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naruhiko Emoto.
Dialogue: 0,0:17:14.78,0:17:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikutlah dengan kami.
Dialogue: 0,0:17:16.86,0:17:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan membawamu\Nke tempat kau bisa gunakan bakatmu.
Dialogue: 0,0:17:20.20,0:17:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah amankan\Nkeselamatan anak itu.
Dialogue: 0,0:17:21.91,0:17:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasus penganiayaan anak ini\Njuga telah dilaporkan ke agensi.
Dialogue: 0,0:17:27.63,0:17:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu banyak soal musik,
Dialogue: 0,0:17:30.59,0:17:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku suka lagu ini.
Dialogue: 0,0:17:33.92,0:17:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, dia merawatku\Nmenggantikan orang tuaku.
Dialogue: 0,0:17:37.22,0:17:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengajariku\Ncara gunakan kemampuanku.
Dialogue: 0,0:17:39.93,0:17:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengecat rambutku\Ndan menindik telingaku.
Dialogue: 0,0:17:41.72,0:17:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma gertakan.
Dialogue: 0,0:17:43.35,0:17:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih benci suara bising\Ndan rasa sakit.
Dialogue: 0,0:17:46.65,0:17:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:48.40,0:17:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah ulang tahun?
Dialogue: 0,0:17:50.32,0:17:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini penyuara jemala terbaru.
Dialogue: 0,0:17:55.03,0:17:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pak Azaki.
Dialogue: 0,0:17:58.99,0:18:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal masuk Akademi Miden...
Dialogue: 0,0:18:03.70,0:18:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melarangku paksakan diri,
Dialogue: 0,0:18:08.92,0:18:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kuputuskan untuk pergi.
Dialogue: 0,0:18:11.21,0:18:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setiap hari, aku terus berpikir
Dialogue: 0,0:18:14.09,0:18:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak cocok di jalan ini.
Dialogue: 0,0:18:16.01,0:18:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto.
Dialogue: 0,0:18:17.26,0:18:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau setakut itu,\Nkenapa masih jadi medium roh?
Dialogue: 0,0:18:21.51,0:18:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:22.81,0:18:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku belum membalas budinya.
Dialogue: 0,0:18:26.94,0:18:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi medium roh\Nyang keren dan buat Pak Azaki bangga!
Dialogue: 0,0:18:31.57,0:18:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengentak-entakkan kepala?
Dialogue: 0,0:18:35.90,0:18:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu ini tetap bagus\Nmeski didengar berkali-kali.
Dialogue: 0,0:18:39.03,0:18:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyuara jemala terbaik.
Dialogue: 0,0:18:40.95,0:18:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tak bisa dengar\Nsuara di luar sana, Pak Azaki.
Dialogue: 0,0:18:46.00,0:18:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menyala kembali!
Dialogue: 0,0:18:49.88,0:18:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktifkan siber, Api Hantu!
Dialogue: 0,0:18:54.51,0:18:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dinding pertahanan masih ada.
Dialogue: 0,0:18:56.59,0:18:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Psikokinesisku tak banyak tersisa.
Dialogue: 0,0:18:58.59,0:18:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo habisi dia!
Dialogue: 0,0:19:00.59,0:19:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:19:03.35,0:19:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto bertahan untukku.
Dialogue: 0,0:19:05.52,0:19:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Emoto tunjukkan keberanian.
Dialogue: 0,0:19:09.85,0:19:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kami tak menghabisinya di sini,
Dialogue: 0,0:19:11.81,0:19:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana bisa kami sebut diri rekan?
Dialogue: 0,0:19:15.36,0:19:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu patung es.
Dialogue: 0,0:19:17.90,0:19:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu palsu.
Dialogue: 0,0:19:18.82,0:19:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:19:21.37,0:19:25.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski itu cuma patung es umpan,\Nkau sudah menghancurkannya.
Dialogue: 0,0:19:25.41,0:19:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat. Posturku di udara...
Dialogue: 0,0:19:28.91,0:19:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak apa-apa. Itu hanya karya gagal.
Dialogue: 0,0:19:32.13,0:19:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan apa-apa\Ndibanding mahakarya itu.
Dialogue: 0,0:19:35.59,0:19:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu harus abadi berabad-abad\Nsebagai monumen kebangkitanku.
Dialogue: 0,0:19:39.93,0:19:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa hindari serangan.
Dialogue: 0,0:19:41.59,0:19:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalamu akan jadi persembahan pertama\Ndari murid Kelas 1.
Dialogue: 0,0:19:44.30,0:19:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habislah aku.
Dialogue: 0,0:19:45.35,0:19:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah dengan indah!
Dialogue: 0,0:19:48.10,0:19:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enishiro!
Dialogue: 0,0:19:55.27,0:19:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusugawa!
Dialogue: 0,0:19:57.69,0:19:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali!
Dialogue: 0,0:20:00.45,0:20:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan ini...
Dialogue: 0,0:20:07.04,0:20:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalian.
Dialogue: 0,0:20:09.58,0:20:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa kalian di sini?
Dialogue: 0,0:20:10.83,0:20:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah psikokinesis kalian hampir habis?
Dialogue: 0,0:20:13.04,0:20:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru saja memulihkannya dengan tidur.
Dialogue: 0,0:20:16.34,0:20:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidur sepuluh menit\Npakai aplikasi Hipnosis Namekawa.
Dialogue: 0,0:20:19.72,0:20:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali...
Dialogue: 0,0:20:21.97,0:20:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, mustahil langsung tertidur\Ndalam situasi begini.
Dialogue: 0,0:20:26.05,0:20:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina!
Dialogue: 0,0:20:27.39,0:20:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami datang untuk membasmimu.
Dialogue: 0,0:20:29.56,0:20:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, terima kasih\Nsudah berkumpul di sini.
Dialogue: 0,0:20:32.48,0:20:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku tak perlu\Nbunuh kalian satu per satu.
Dialogue: 0,0:20:35.86,0:20:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayap Es Maut!
Dialogue: 0,0:20:37.82,0:20:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emo!
Dialogue: 0,0:20:40.61,0:20:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:20:42.20,0:20:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai kesal, Orang Gagal.
Dialogue: 0,0:20:45.16,0:20:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ashina benar-benar mau membunuh kita.
Dialogue: 0,0:20:48.16,0:20:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!\NDia berhasil menangkis serangannya!
Dialogue: 0,0:20:50.62,0:20:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangat sekali.
Dialogue: 0,0:20:52.46,0:20:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emoto bertarung dengan berani\Nuntuk mengulur
Dialogue: 0,0:20:55.29,0:20:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu sepuluh menit\Ndemi pulihkan psikokinesis kami.
Dialogue: 0,0:20:59.00,0:21:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan ada lagi\Nyang menyebutmu pengecut.
Dialogue: 0,0:21:03.22,0:21:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh! Jangan ajak aku bicara!
Dialogue: 0,0:21:05.89,0:21:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tak bisa fokus ke lagunya!
Dialogue: 0,0:21:09.01,0:21:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau bilang sesuatu pada Kelas 1-B.
Dialogue: 0,0:21:11.35,0:21:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kalah telak\Ndi Pertarungan Antarkelas.
Dialogue: 0,0:21:13.48,0:21:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kalahkan kami di pertarungan.
Dialogue: 0,0:21:15.15,0:21:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa dari kami bahkan membunuh.
Dialogue: 0,0:21:19.36,0:21:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, izinkan aku\Nmeminta bantuan kalian.
Dialogue: 0,0:21:22.24,0:21:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan kami bertarung bersama kalian...
Dialogue: 0,0:21:23.61,0:21:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:24.74,0:21:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kami ikut bertarung juga?
Dialogue: 0,0:21:29.03,0:21:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah jelas?
Dialogue: 0,0:21:30.87,0:21:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi pembasmian roh ini
Dialogue: 0,0:21:32.58,0:21:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah tugas seluruh murid Kelas 1.
Dialogue: 0,0:21:35.29,0:21:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, masa kalian\Nhanya menonton saja?
Dialogue: 0,0:21:39.09,0:21:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judul sementara,
Dialogue: 0,0:21:40.30,0:21:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Perusuh dalam Dinding.
Dialogue: 0,0:21:44.01,0:21:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelek. Tak jadi.
Dialogue: 0,0:21:46.55,0:21:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,
Dialogue: 0,0:21:47.93,0:21:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini Pertarungan Total Gabungan Kelas!
Dialogue: 0,0:21:51.60,0:21:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:21:58.98,0:22:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kita mendaki gunung?
Dialogue: 0,0:22:01.48,0:22:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada di sana.
