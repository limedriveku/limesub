Dialogue: 0,0:01:01.37,0:01:03.37,tanda,,0000,0000,0000,,PERTAHANAN WILAYAH SERU\NOLEH TUAN TANAH SANTAI
Dialogue: 0,0:01:03.37,0:01:06.55,tanda,,0000,0000,0000,,MEMBUAT DESA TANPA NAMA MENJADI KOTA\NBENTENG TERKUAT DENGAN SIHIR PRODUKSI
Dialogue: 0,0:01:06.55,0:01:09.13,tanda,,0000,0000,0000,,EPISODE 10: SERANGAN KEJI\NSENJATA RAHASIA DI TANAH AIR
Dialogue: 0,0:02:21.50,0:02:22.69,tanda,,0000,0000,0000,,EPISODE 10: SERANGAN KEJI\NSENJATA RAHASIA DI TANAH AIR
Dialogue: 0,0:14:01.70,0:14:04.99,tanda,,0000,0000,0000,,MARQUIS JALPA BUL ATI FERTIO
Dialogue: 0,0:15:04.42,0:15:07.43,tanda,,0000,0000,0000,,GERBANG SELATAN KOTA BENTENG SCUDET
Dialogue: 0,0:15:51.26,0:15:53.47,tanda,,0000,0000,0000,,GERBANG BARAT KOTA BENTENG SCUDET
Dialogue: 0,0:23:35.02,0:23:42.98,tanda,,0000,0000,0000,,SELANJUTNYA: MEMBALIKKAN KEADAAN\NDENGAN PASUKAN TERKUAT
Dialogue: 0,0:00:04.19,0:00:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern?
Dialogue: 0,0:00:05.90,0:00:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya ada penyihir\Nyang mengendalikannya.
Dialogue: 0,0:00:09.61,0:00:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanselir, bagaimana menurutmu?
Dialogue: 0,0:00:12.20,0:00:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umumnya Wyvern bergerak berkelompok.
Dialogue: 0,0:00:15.29,0:00:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil mereka menyerang desa sendirian.
Dialogue: 0,0:00:19.12,0:00:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melihat penyihir itu...
Dialogue: 0,0:00:21.42,0:00:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada ancaman lain di dekat sini.
Dialogue: 0,0:00:24.42,0:00:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulah Kerajaan Yelenetta, ya?
Dialogue: 0,0:00:26.75,0:00:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan.
Dialogue: 0,0:00:28.13,0:00:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yelenetta menyerang desa ini?
Dialogue: 0,0:00:30.51,0:00:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron, musuh sepertinya bukan hanya Wyvern,
Dialogue: 0,0:00:33.76,0:00:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemungkinan besar ada sejumlah\Npasukan kesatria khusus.
Dialogue: 0,0:00:36.88,0:00:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhati-hatilah.
Dialogue: 0,0:00:38.02,0:00:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:00:40.98,0:00:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:00:42.19,0:00:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau setinggi itu,\Npanah balista tidak akan sampai.
Dialogue: 0,0:00:46.15,0:00:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat,\Nwaktunya pakai senjata baru.
Dialogue: 0,0:02:22.69,0:02:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, kita hampir tiba di wilayah musuh.
Dialogue: 0,0:02:26.83,0:02:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern kita sedang mengintai\Ndari atas Desa Seatoh.
Dialogue: 0,0:02:33.01,0:02:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi penyerbuan desa terpencil saja\Nharus dipimpin segala
Dialogue: 0,0:02:38.10,0:02:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}olehku ini, Unimog Yelenetta,
Dialogue: 0,0:02:40.64,0:02:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Kedelapan Kerajaan Yelenetta.
Dialogue: 0,0:02:44.52,0:02:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena operasi ini sangat penting,
Dialogue: 0,0:02:47.73,0:02:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja menugaskannya langsung padamu.
Dialogue: 0,0:02:51.61,0:02:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta kita,
Dialogue: 0,0:02:53.49,0:02:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah lama bertikai dengan Kerajaan Scuderia\Nyang ada di wilayah perbatasan.
Dialogue: 0,0:02:59.28,0:03:00.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:03:00.37,0:03:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya kita bisa mengakhiri\Npertikaian dengan Scuderia.
Dialogue: 0,0:03:04.16,0:03:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kamulah yang dipercaya memimpin\Nbarisan depan penting kita, Tuan Unimog.
Dialogue: 0,0:03:10.67,0:03:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku yang melakukannya,
Dialogue: 0,0:03:12.30,0:03:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menaklukkan desa terpencil\Nakan sangat mudah.
Dialogue: 0,0:03:16.72,0:03:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, kita sampai.
Dialogue: 0,0:03:23.27,0:03:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ko-Kota benteng macam apa ini?
Dialogue: 0,0:03:25.89,0:03:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa membangun itu\Ndi tempat terpencil begini?
Dialogue: 0,0:03:29.15,0:03:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:03:30.86,0:03:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membangun kota benteng itu\Ntidak mudah, tahu!
Dialogue: 0,0:03:34.69,0:03:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma pajangan palsu\Nyang dibuat menyerupai benteng!
Dialogue: 0,0:03:39.12,0:03:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan tetap maju\Ndan menduduki wilayah musuh!
Dialogue: 0,0:03:42.39,0:03:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu.
Dialogue: 0,0:03:43.91,0:03:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ternyata sungguhan?
Dialogue: 0,0:03:46.25,0:03:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menentangku, bodoh?
Dialogue: 0,0:03:49.42,0:03:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang itu cuma gertakan!
Dialogue: 0,0:03:51.96,0:03:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan kami.
Dialogue: 0,0:03:54.01,0:03:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, hancurkan tembok itu!
Dialogue: 0,0:04:08.73,0:04:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan tidak retak.
Dialogue: 0,0:04:10.68,0:04:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mu-Mustahil, itu tidak mungkin.
Dialogue: 0,0:04:13.23,0:04:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:04:15.44,0:04:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Van, tuan tanah desa ini.
Dialogue: 0,0:04:19.27,0:04:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak sekecil itu?
Dialogue: 0,0:04:21.66,0:04:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian jauh-jauh datang\Ndari Kerajaan Yelenetta?
Dialogue: 0,0:04:26.37,0:04:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu!
Dialogue: 0,0:04:28.08,0:04:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa tahu kami dari Kerajaan Yelenetta?
Dialogue: 0,0:04:31.88,0:04:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar, ya.
Dialogue: 0,0:04:34.12,0:04:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya memancingmu,\Nternyata langsung mengaku, ya.
Dialogue: 0,0:04:39.05,0:04:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya desa ini tidak punya\Nbenteng seperti ini!
Dialogue: 0,0:04:42.76,0:04:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian membangun benteng ini?
Dialogue: 0,0:04:46.68,0:04:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tembok kota dan fasilitas ini
Dialogue: 0,0:04:49.56,0:04:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibangun olehku dan para penduduk desa.
Dialogue: 0,0:04:52.31,0:04:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu mempermainkanku?
Dialogue: 0,0:04:54.82,0:04:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar! Turun sini!
Dialogue: 0,0:04:56.86,0:05:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kira aku akan lembut\Ncuma karena kamu masih kecil!
Dialogue: 0,0:05:00.07,0:05:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern bisa menyerang dari udara, lo!
Dialogue: 0,0:05:03.57,0:05:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok kotamu sia-sia!
Dialogue: 0,0:05:06.33,0:05:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintahkan penyihir pengendali wyvern itu!
Dialogue: 0,0:05:08.95,0:05:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh dia menyerang!
Dialogue: 0,0:05:10.83,0:05:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada kemungkinan diserang balik...
Dialogue: 0,0:05:13.21,0:05:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:05:15.13,0:05:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern adalah naga!\NMana mungkin kalah!
Dialogue: 0,0:05:18.55,0:05:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:05:19.72,0:05:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakanlah kengerian seekor naga!
Dialogue: 0,0:05:25.51,0:05:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera, tolong lakukan.
Dialogue: 0,0:05:30.64,0:05:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:05:46.58,0:05:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:05:49.33,0:05:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu syuriken.
Dialogue: 0,0:05:51.26,0:05:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tipis dan ringan,
Dialogue: 0,0:05:52.83,0:05:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku membuat bom yang diisi banyak syuriken.
Dialogue: 0,0:05:58.34,0:06:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu senjata barunya?
Dialogue: 0,0:06:00.44,0:06:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:01.43,0:06:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal baru pertama kali dipakai,\Nternyata hasilnya lumayan.
Dialogue: 0,0:06:05.89,0:06:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatannya tidak masuk akal.
Dialogue: 0,0:06:08.27,0:06:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa jadi ancaman yang setara\Ndengan empat elemen sihir.
Dialogue: 0,0:06:12.10,0:06:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu...
Dialogue: 0,0:06:14.52,0:06:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Kerajaan Scuderia?
Dialogue: 0,0:06:17.48,0:06:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa seorang raja\Nada di desa terpencil ini?
Dialogue: 0,0:06:22.65,0:06:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian masih mau coba-coba?
Dialogue: 0,0:06:31.00,0:06:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pengecut!
Dialogue: 0,0:06:33.00,0:06:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sedang apa?\NCepat lindungi aku!
Dialogue: 0,0:06:36.04,0:06:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, masih bersemangat, ya?
Dialogue: 0,0:06:38.79,0:06:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera.
Dialogue: 0,0:06:44.68,0:06:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya tidak akan meleset, lo.
Dialogue: 0,0:06:50.51,0:06:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron selalu membuat kita terkejut, ya.
Dialogue: 0,0:06:53.85,0:06:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:06:55.10,0:06:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis Fertio punya putra yang luar biasa.
Dialogue: 0,0:06:59.19,0:07:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah,
Dialogue: 0,0:07:00.27,0:07:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis mengusir Baron Van dari keluarganya.
Dialogue: 0,0:07:04.99,0:07:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti tidak menyangka\Nseseorang beratribut tingkat rendah
Dialogue: 0,0:07:10.20,0:07:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa melakukan hal sehebat ini.
Dialogue: 0,0:07:13.29,0:07:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepulangnya ke ibu kota,
Dialogue: 0,0:07:14.96,0:07:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus meninjau ulang soal atribut sihir.
Dialogue: 0,0:07:23.38,0:07:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran, bisakah kamu beri tahu\Napa rencana kalian?
Dialogue: 0,0:07:29.18,0:07:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin kubocorkan pada kalian.
Dialogue: 0,0:07:31.72,0:07:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:07:34.32,0:07:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Kaien.
Dialogue: 0,0:07:37.69,0:07:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencabut kuku satu per satu,
Dialogue: 0,0:07:40.19,0:07:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau congkel mata?
Dialogue: 0,0:07:43.03,0:07:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau yang mana?
Dialogue: 0,0:07:46.07,0:07:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan!
Dialogue: 0,0:07:47.32,0:07:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku beri tahu! Akan kuberi tahu!
Dialogue: 0,0:07:51.28,0:07:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta kami
Dialogue: 0,0:07:53.41,0:07:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah merencanakan penyerbuan ini\Nsejak beberapa tahun lalu.
Dialogue: 0,0:07:59.67,0:08:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai langkah awal,
Dialogue: 0,0:08:00.84,0:08:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami berniat menyerang desa ini\Nyang merupakan wilayah Marquis Fertio.
Dialogue: 0,0:08:05.80,0:08:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pikir, desa kecil akan mudah diserang.
Dialogue: 0,0:08:11.72,0:08:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya malah kalian yang kalah,\Nbenar-benar konyol.
Dialogue: 0,0:08:15.68,0:08:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berniat menyerang wilayah lain juga?
Dialogue: 0,0:08:19.94,0:08:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini,
Dialogue: 0,0:08:21.27,0:08:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasukan lain sedang menyerang kota\Nyang jadi target utama.
Dialogue: 0,0:08:25.07,0:08:27.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota mana yang diserang?
Dialogue: 0,0:08:28.15,0:08:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota Benteng Scudet.
Dialogue: 0,0:08:35.49,0:08:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia takut padaku\Ndan membocorkan semuanya.
Dialogue: 0,0:08:39.66,0:08:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, target mereka Scudet?
Dialogue: 0,0:08:42.15,0:08:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita segera kembali ke ibu kota.
Dialogue: 0,0:08:46.42,0:08:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus membentuk pasukan
Dialogue: 0,0:08:48.38,0:08:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengirimnya ke Scudet untuk bertahan.
Dialogue: 0,0:08:51.84,0:08:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:08:53.99,0:08:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku punya satu permintaan.
Dialogue: 0,0:08:57.39,0:08:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:08:59.02,0:09:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron Van Nei Fertio.
Dialogue: 0,0:09:01.29,0:09:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu ikut serta\Ndalam mempertahankan Scudet.
Dialogue: 0,0:09:06.88,0:09:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda, kamu tidak mau?
Dialogue: 0,0:09:12.91,0:09:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Normalnya yang begini harus diterima.
Dialogue: 0,0:09:15.45,0:09:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak mau.
Dialogue: 0,0:09:17.01,0:09:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, aku ingin tetap diam di desa!
Dialogue: 0,0:09:21.12,0:09:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa terhormat\Natas permintaan tersebut.
Dialogue: 0,0:09:23.92,0:09:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau meninggalkan desa\Nyang masih dalam pembangunan,
Dialogue: 0,0:09:26.80,0:09:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama saja aku menelantarkannya.
Dialogue: 0,0:09:29.13,0:09:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menjatuhkan wyvern\Ndengan satu serangan,
Dialogue: 0,0:09:33.05,0:09:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan fasilitas pertahanannya mampu\Nmengalahkan kadal zirah dan naga,
Dialogue: 0,0:09:37.47,0:09:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih dianggap "dalam pembangunan"?
Dialogue: 0,0:09:39.89,0:09:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:40.84,0:09:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, sepersepuluh pun belum selesai.
Dialogue: 0,0:09:44.64,0:09:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku masih ingin\Nmembuat banyak hal.
Dialogue: 0,0:09:52.11,0:09:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang menarik, anak muda.
Dialogue: 0,0:09:54.45,0:09:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu penasaran\Nbenda gila apa lagi yang akan kamu buat.
Dialogue: 0,0:09:59.45,0:10:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:10:00.54,0:10:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya kamu terima permintaan ini.
Dialogue: 0,0:10:03.47,0:10:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat negara terancam,\Nsemua bangsawan wajib bekerja sama.
Dialogue: 0,0:10:08.30,0:10:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah jadi perjanjian terikat\Nketika menjadi bangsawan.
Dialogue: 0,0:10:14.84,0:10:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:16.41,0:10:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang kewajiban,\Naku akan ikut serta.
Dialogue: 0,0:10:19.93,0:10:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga punya kewajiban\Nsebagai tuan tanah.
Dialogue: 0,0:10:23.03,0:10:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi biarkan aku yang menentukan\Nformasi pasukan.
Dialogue: 0,0:10:27.82,0:10:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kamu saja.
Dialogue: 0,0:10:31.86,0:10:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah bikin pertahanan\Nyang bagus untuk desa.
Dialogue: 0,0:10:35.23,0:10:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah disuruh bertempur keluar desa.
Dialogue: 0,0:10:39.45,0:10:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Espada, bisakah kamu menjaga desa ini\Nsebagai pengganti tuan tanah?
Dialogue: 0,0:10:44.27,0:10:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu bisa.
Dialogue: 0,0:10:46.33,0:10:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu yakin tidak membawaku?
Dialogue: 0,0:10:49.49,0:10:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, jujur agak khawatir, sih.
Dialogue: 0,0:10:52.01,0:10:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cuma kamu yang bisa\Nmenggantikan peran tuan tanah.
Dialogue: 0,0:10:56.51,0:10:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:58.85,0:11:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dee dan kesatria Seatoh ikut denganku, ya?
Dialogue: 0,0:11:02.73,0:11:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:11:04.03,0:11:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Till dan Kamshin sebaiknya jangan...
Dialogue: 0,0:11:06.06,0:11:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut! Pokoknya ikut!
Dialogue: 0,0:11:08.69,0:11:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut!
Dialogue: 0,0:11:10.32,0:11:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, baiklah.
Dialogue: 0,0:11:13.94,0:11:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa jumlah kita sudah cukup?
Dialogue: 0,0:11:17.16,0:11:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang ibu kota\Ntidak akan bilang sedikit, kan?
Dialogue: 0,0:11:22.91,0:11:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tahu kekuatan Tuan Van
Dialogue: 0,0:11:25.54,0:11:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya sadar ini lebih dari cukup.
Dialogue: 0,0:11:28.17,0:11:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain cerita bagi yang belum tahu.
Dialogue: 0,0:11:30.46,0:11:31.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:11:32.00,0:11:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami siap menerima permintaan mengawal.
Dialogue: 0,0:11:35.16,0:11:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Sungguh?
Dialogue: 0,0:11:36.60,0:11:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya kami ogah terlibat dalam perang.
Dialogue: 0,0:11:39.81,0:11:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi khusus Tuan Van,\Nkami bersedia mengawal.
Dialogue: 0,0:11:43.43,0:11:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya!
Dialogue: 0,0:11:45.52,0:11:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bisa tolong\Npanggilkan petualang yang lain?
Dialogue: 0,0:11:48.95,0:11:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kubayar 1 koin emas besar\Ndan 5 koin emas biasa.
Dialogue: 0,0:11:52.52,0:11:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibayar sebanyak itu?
Dialogue: 0,0:11:54.87,0:11:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya mempertaruhkan nyawa.
Dialogue: 0,0:11:57.16,0:11:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:11:58.70,0:12:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lain pasti akan senang berpartisipasi.
Dialogue: 0,0:12:01.80,0:12:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xara, kamu wajib ikut, ya.
Dialogue: 0,0:12:04.29,0:12:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlakuan tidak adil lagi, nih?
Dialogue: 0,0:12:06.41,0:12:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bicara serius,
Dialogue: 0,0:12:08.33,0:12:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasukan kesatriaku\Ntidak punya pengintai profesional.
Dialogue: 0,0:12:12.09,0:12:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:12:14.84,0:12:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, kan, permintaan.
Dialogue: 0,0:12:16.51,0:12:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya pastikan dulu\Nmau atau tidaknya diriku.
Dialogue: 0,0:12:20.51,0:12:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tapi kalau tidak\Nmenerima permintaanku,
Dialogue: 0,0:12:24.06,0:12:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak akan dapat barbeku.
Dialogue: 0,0:12:26.18,0:12:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah? Enggak dikasih jatah?
Dialogue: 0,0:12:28.56,0:12:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas aku terima, dong!\NTentu saja!
Dialogue: 0,0:12:32.90,0:12:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda.
Dialogue: 0,0:12:36.15,0:12:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pulang dulu\Nuntuk melapor ke Count Ferdinatto.
Dialogue: 0,0:12:39.91,0:12:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru setelahnya membentuk\Npasukan dan menuju Scudet.
Dialogue: 0,0:12:43.20,0:12:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, mungkin kita akan bertemu di sana.
Dialogue: 0,0:12:46.20,0:12:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan senjatanya?
Dialogue: 0,0:12:49.96,0:12:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maunya, sih, bawa sesuatu.
Dialogue: 0,0:12:52.79,0:12:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak bisa bawa balista.
Dialogue: 0,0:12:55.75,0:12:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:12:57.55,0:13:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawa bonekaku.
Dialogue: 0,0:13:00.04,0:13:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka?
Dialogue: 0,0:13:01.49,0:13:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya...
Dialogue: 0,0:13:06.89,0:13:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan jadi ekspedisi pertama\Nuntuk kesatria Seatoh.
Dialogue: 0,0:13:10.77,0:13:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bertugas mempertahankan Scudet,\Nkota benteng terbesar.
Dialogue: 0,0:13:15.07,0:13:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan kita adalah kesatria\NKerajaan Yelenetta.
Dialogue: 0,0:13:17.82,0:13:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berkali-kali\Nbertikai dengan negara kita.
Dialogue: 0,0:13:20.78,0:13:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mereka pasti lebih berpengalaman.
Dialogue: 0,0:13:23.70,0:13:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak perlu takut.
Dialogue: 0,0:13:25.99,0:13:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak akan pergi ke garis depan.
Dialogue: 0,0:13:29.70,0:13:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:13:31.04,0:13:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terus bagaimana kita mengalahkan musuh?\N- Karena,
Dialogue: 0,0:13:33.42,0:13:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tujuan kita adalah pulang ke desa\Ntanpa satu pun korban jiwa.
Dialogue: 0,0:13:39.55,0:13:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tuan tanah,\Naku bertanggung jawab atas nyawa kalian.
Dialogue: 0,0:13:44.26,0:13:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan kulindungi dengan sekuat tenaga.
Dialogue: 0,0:13:47.53,0:13:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga, jaga diri masing-masing.
Dialogue: 0,0:13:51.69,0:13:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selamat dari pertempuran ini,
Dialogue: 0,0:13:54.35,0:13:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari bangun desa ini lagi bersama-sama
Dialogue: 0,0:13:57.82,0:14:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menikmati pesta barbeku!
Dialogue: 0,0:14:01.70,0:14:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scudet diserang?
Dialogue: 0,0:14:04.17,0:14:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:04.99,0:14:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta\Ntelah mengerahkan pasukannya.
Dialogue: 0,0:14:10.08,0:14:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kota sekokoh Scudet
Dialogue: 0,0:14:12.46,0:14:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan jatuh semudah itu.
Dialogue: 0,0:14:15.08,0:14:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera bentuk dan kirim pasukan kita!
Dialogue: 0,0:14:18.13,0:14:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:19.02,0:14:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirim juga utusan ke wilayah sekitar\Nuntuk mengerahkan pasukannya.
Dialogue: 0,0:14:23.51,0:14:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dekat Scudet,
Dialogue: 0,0:14:25.14,0:14:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada desa yang dikelola putramu, Tuan Van.
Dialogue: 0,0:14:28.35,0:14:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana...
Dialogue: 0,0:14:29.22,0:14:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukanlah desa\Nyang mampu mengerahkan pasukan.
Dialogue: 0,0:14:32.77,0:14:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, memenuhi kebutuhan\Npangan saja sudah sulit.
Dialogue: 0,0:14:36.72,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, menurut pedagang keliling dari ibu kota,
Dialogue: 0,0:14:40.73,0:14:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van diberikan gelar Baron
Dialogue: 0,0:14:43.36,0:14:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- karena mengalahkan naga...\N- Omong kosong.
Dialogue: 0,0:14:44.61,0:14:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa empat elemen sihir,\Nmustahil Van mengalahkan naga.
Dialogue: 0,0:14:49.66,0:14:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar, tapi...
Dialogue: 0,0:14:51.66,0:14:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van bukan anak biasa.
Dialogue: 0,0:14:54.63,0:14:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia berbuat hal di luar nalar...
Dialogue: 0,0:14:57.25,0:14:59.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja persiapannya!
Dialogue: 0,0:14:59.88,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan segera menuju Scudet.
Dialogue: 0,0:15:01.88,0:15:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:07.43,0:15:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:15:08.85,0:15:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota sekokoh Scudet hancur?
Dialogue: 0,0:15:12.85,0:15:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yelenetta sialan.
Dialogue: 0,0:15:14.64,0:15:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengerahkan wyvern sebanyak itu.
Dialogue: 0,0:15:18.27,0:15:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mundur sementara!
Dialogue: 0,0:15:20.23,0:15:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:21.94,0:15:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan bantuan Scuderia telah tiba!
Dialogue: 0,0:15:24.36,0:15:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:15:27.57,0:15:29.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata apa itu?
Dialogue: 0,0:15:32.16,0:15:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Jalpa!\NPasukan kita di ambang kehancuran!
Dialogue: 0,0:15:35.08,0:15:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:15:40.92,0:15:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamatlah riwayatku.
Dialogue: 0,0:15:44.55,0:15:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pergi tanpa menghabisiku?
Dialogue: 0,0:15:46.95,0:15:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:16:05.49,0:16:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:16:08.45,0:16:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat panggil semua wyvern!
Dialogue: 0,0:16:11.47,0:16:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik! Segera!
Dialogue: 0,0:16:13.19,0:16:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Automaton, Uno!
Dialogue: 0,0:16:19.29,0:16:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:16:20.36,0:16:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat hancurkan dia!
Dialogue: 0,0:16:26.17,0:16:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut, kamu hebat!
Dialogue: 0,0:16:27.76,0:16:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu bisa melakukan itu!
Dialogue: 0,0:16:30.05,0:16:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka,\NScudet bisa direbut semudah ini.
Dialogue: 0,0:16:34.14,0:16:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara wyvern dan senjata\Nyang belum pernah aku lihat itu, ya.
Dialogue: 0,0:16:38.11,0:16:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang selatan tampaknya rusak parah.
Dialogue: 0,0:16:41.27,0:16:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan kesatria Scuderia seharusnya\Nsedang melakukan perlawanan.
Dialogue: 0,0:16:44.71,0:16:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, melihat kondisi Scudet yang begini,\Nmungkin mereka memilih mundur.
Dialogue: 0,0:16:51.03,0:16:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ogah berlebihan,
Dialogue: 0,0:16:52.82,0:16:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dengan memancing musuh kemari,\Nmungkin bisa sedikit membantu.
Dialogue: 0,0:16:57.29,0:16:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:58.21,0:17:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ulur waktu agar para kesatria bisa mundur.
Dialogue: 0,0:17:01.42,0:17:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:02.27,0:17:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia! Sebelah sini!
Dialogue: 0,0:17:07.26,0:17:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Nona Arut!
Dialogue: 0,0:17:09.88,0:17:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutembak!
Dialogue: 0,0:17:13.93,0:17:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita maju juga!
Dialogue: 0,0:17:15.81,0:17:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:17:17.84,0:17:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Incar mereka!
Dialogue: 0,0:17:19.69,0:17:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eits, tidak akan kubiarkan!
Dialogue: 0,0:17:23.52,0:17:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja, tapi kami tidak boleh kalah!
Dialogue: 0,0:17:27.28,0:17:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:17:31.74,0:17:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hebat.
Dialogue: 0,0:17:40.29,0:17:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut, terima kasih.
Dialogue: 0,0:17:41.96,0:17:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:17:43.04,0:17:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerahkan seluruh pasukan dan habisi mereka!
Dialogue: 0,0:17:48.84,0:17:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, banyak yang datang.
Dialogue: 0,0:17:51.05,0:17:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, seharusnya ini sudah cukup\Nuntuk mengulur waktu.
Dialogue: 0,0:17:54.72,0:17:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, waktunya mundur.
Dialogue: 0,0:17:57.85,0:17:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita betulan mau kabur?
Dialogue: 0,0:17:59.81,0:18:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kita bisa menang, deh.
Dialogue: 0,0:18:02.10,0:18:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang sejak awal.
Dialogue: 0,0:18:04.31,0:18:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan kita adalah pulang ke desa\Ntanpa satu pun korban jiwa.
Dialogue: 0,0:18:09.61,0:18:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bisa menang,
Dialogue: 0,0:18:11.07,0:18:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan senang kalau ada yang mati.
Dialogue: 0,0:18:14.36,0:18:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau, kalian ada yang ingin mati?
Dialogue: 0,0:18:19.83,0:18:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kabur sekuat tenaga!
Dialogue: 0,0:18:23.12,0:18:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:18:27.24,0:18:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Jalpa, apa rencana kita selanjutnya?
Dialogue: 0,0:18:31.01,0:18:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scudet harus kita rebut kembali.
Dialogue: 0,0:18:34.84,0:18:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susun ulang pasukan kita, lakukan segera.
Dialogue: 0,0:18:38.45,0:18:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:40.68,0:18:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipikir-pikir...
Dialogue: 0,0:18:43.23,0:18:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kami bisa selamat.
Dialogue: 0,0:18:46.69,0:18:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:18:48.23,0:18:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahanda.
Dialogue: 0,0:18:50.61,0:18:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murcia, ya?\NKamu lama sekali!
Dialogue: 0,0:18:52.24,0:18:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:18:54.15,0:18:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:18:57.37,0:19:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis Jalpa Bul Ati Fertio.
Dialogue: 0,0:19:00.45,0:19:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membuat anak muda itu ketakutan.
Dialogue: 0,0:19:04.71,0:19:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, maaf membuatmu mendengar ini.
Dialogue: 0,0:19:07.58,0:19:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis, berdirilah.
Dialogue: 0,0:19:09.96,0:19:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi pertempuran di Scudet?
Dialogue: 0,0:19:13.63,0:19:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scudet telah jatuh ke tangan musuh.
Dialogue: 0,0:19:16.47,0:19:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuh?
Dialogue: 0,0:19:19.89,0:19:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan kesatria kami\Nterkena serangan senjata baru
Dialogue: 0,0:19:23.77,0:19:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan nyaris hancur total.
Dialogue: 0,0:19:26.14,0:19:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara kalian bisa kabur?
Dialogue: 0,0:19:28.44,0:19:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu...
Dialogue: 0,0:19:29.73,0:19:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa wyvern berhenti menyerang\Ndan pergi menuju gerbang barat.
Dialogue: 0,0:19:34.86,0:19:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya itu bantuan\Nyang dikerahkan Baron Van.
Dialogue: 0,0:19:39.91,0:19:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Va-Van?
Dialogue: 0,0:19:41.62,0:19:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kabar ini belum sampai\Nke wilayah Marquis, ya.
Dialogue: 0,0:19:45.54,0:19:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahwa Baron Van\Nmengembangkan desa di perbatasan,
Dialogue: 0,0:19:48.33,0:19:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menumpas naga dan diangkat menjadi\Nbangsawan di usia yang sangat muda.
Dialogue: 0,0:19:54.59,0:19:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Van tidak punya empat elemen sihir.
Dialogue: 0,0:19:58.93,0:20:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil dia bisa...
Dialogue: 0,0:20:00.72,0:20:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis.
Dialogue: 0,0:20:02.10,0:20:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bilang bahwa kami berbohong?
Dialogue: 0,0:20:05.31,0:20:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku tidak bermaksud begitu.
Dialogue: 0,0:20:08.31,0:20:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Van...\NKamu telah menjadi bangsawan, ya.
Dialogue: 0,0:20:11.48,0:20:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda.
Dialogue: 0,0:20:12.86,0:20:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kesal karena adikmu\Nmendapatkan gelar duluan?
Dialogue: 0,0:20:16.53,0:20:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru sebaliknya.
Dialogue: 0,0:20:19.49,0:20:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bangga.
Dialogue: 0,0:20:26.61,0:20:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar melelahkan, ya.
Dialogue: 0,0:20:29.71,0:20:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, setelah ini apa rencanamu?
Dialogue: 0,0:20:34.38,0:20:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:20:36.49,0:20:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya kewajibanku sebagai\Nbangsawan sudah terpenuhi.
Dialogue: 0,0:20:39.76,0:20:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau tidak merebut Scudet,\Nmereka akan terus menjadi ancaman.
Dialogue: 0,0:20:45.31,0:20:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, ini pertama kalinya\Naku melihat perang secara langsung.
Dialogue: 0,0:20:49.69,0:20:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat mengerikan yang bahkan\Nmelibatkan warga tidak berdosa.
Dialogue: 0,0:20:55.48,0:20:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku tidak ingin kita ke sana lagi.
Dialogue: 0,0:21:01.70,0:21:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Nona Panamera\Nyang sekutu kita juga ikut serta.
Dialogue: 0,0:21:05.49,0:21:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku harus ikut\Nmembantu dalam beberapa hal.
Dialogue: 0,0:21:12.92,0:21:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:21:15.00,0:21:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya aku akan membuat\Nsenjata baru, yaitu katapel.
Dialogue: 0,0:21:18.68,0:21:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bisa menjangkau medan perang,
Dialogue: 0,0:21:20.55,0:21:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya kita sudah\Ndianggap turut membantu.
Dialogue: 0,0:21:32.27,0:21:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar, ya.
Dialogue: 0,0:21:34.23,0:21:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau buat berapa banyak?
Dialogue: 0,0:21:36.98,0:21:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}20 unit tipe tanam,
Dialogue: 0,0:21:38.86,0:21:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan 5 unit tipe bergerak.
Dialogue: 0,0:21:41.74,0:21:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bakal sulit\Nmembawa sebanyak ini ke Scudet.
Dialogue: 0,0:21:47.12,0:21:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah jalannya rusak parah.
Dialogue: 0,0:21:52.67,0:21:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!\NTinggal aku buat di tempatnya saja!
Dialogue: 0,0:21:55.96,0:21:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga!\NKita bisa pakai cara itu!
Dialogue: 0,0:21:59.71,0:22:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita rapat untuk persiapan besok!
