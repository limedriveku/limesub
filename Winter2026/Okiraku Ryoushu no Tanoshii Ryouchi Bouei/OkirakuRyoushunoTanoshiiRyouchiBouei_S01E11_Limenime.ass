Dialogue: 0,0:01:19.31,0:01:21.27,tanda,,0000,0000,0000,,PERTAHANAN WILAYAH SERU\NOLEH TUAN TANAH SANTAI
Dialogue: 0,0:01:21.27,0:01:24.48,tanda,,0000,0000,0000,,MEMBUAT DESA TANPA NAMA MENJADI KOTA\NBENTENG TERKUAT DENGAN SIHIR PRODUKSI
Dialogue: 0,0:01:24.48,0:01:27.07,tanda,,0000,0000,0000,,EPISODE 11: MEMBALIKKAN KEADAAN\NDENGAN PASUKAN TERKUAT
Dialogue: 0,0:02:38.01,0:02:40.43,tanda,,0000,0000,0000,,EPISODE 11: MEMBALIKKAN KEADAAN\NDENGAN PASUKAN TERKUAT
Dialogue: 0,0:05:23.34,0:05:28.06,tanda,,0000,0000,0000,,COUNT BARIAT SIROCCO FERDINATTO
Dialogue: 0,0:23:34.98,0:23:42.73,tanda,,0000,0000,0000,,SELANJUTNYA: PERTAHANAN WILAYAH YANG SERU\NDAN TUAN TANAH YANG SANTAI
Dialogue: 0,0:00:02.44,0:00:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:00:03.36,0:00:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka.
Dialogue: 0,0:00:04.98,0:00:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar tidak suka.
Dialogue: 0,0:00:07.65,0:00:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski cuma mengantar senjata baru\Nke Kota Benteng Scudet,
Dialogue: 0,0:00:11.78,0:00:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi harus ke medan perang lagi.
Dialogue: 0,0:00:17.50,0:00:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malas banget.
Dialogue: 0,0:00:19.09,0:00:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, lihatlah.
Dialogue: 0,0:00:22.71,0:00:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kota yang paling dekat dengan Scudet.
Dialogue: 0,0:00:34.01,0:00:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat-lihat, ini seperti kota biasa,
Dialogue: 0,0:00:37.40,0:00:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi banyak prajurit berseliweran, ya.
Dialogue: 0,0:00:40.98,0:00:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena kekalahan itu,
Dialogue: 0,0:00:43.01,0:00:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}prajurit Scuderia kita\Nmulai menyusun ulang pasukan.
Dialogue: 0,0:00:48.16,0:00:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata baru Kerajaan Yelenetta\Nmemang luar biasa, sih.
Dialogue: 0,0:01:01.19,0:01:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu,
Dialogue: 0,0:01:03.96,0:01:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Van.
Dialogue: 0,0:02:40.43,0:02:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Ayah.
Dialogue: 0,0:02:43.48,0:02:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Van, sepertinya kamu sudah menjadi Baron.
Dialogue: 0,0:02:46.64,0:02:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, begitulah.
Dialogue: 0,0:02:49.00,0:02:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu berhasil menumpas naga.
Dialogue: 0,0:02:51.90,0:02:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, cuma Naga Hutan, sih.
Dialogue: 0,0:02:54.65,0:02:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Na-Naga Hutan?
Dialogue: 0,0:02:57.13,0:02:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa?
Dialogue: 0,0:02:58.91,0:03:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naga sekelas itu,\Ntidak bisa kukalahkan sendirian.
Dialogue: 0,0:03:03.29,0:03:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan harus dihadapi\Nseluruh pasukan kesatria kita.
Dialogue: 0,0:03:08.46,0:03:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, aku mengalahkannya pakai balista.
Dialogue: 0,0:03:11.55,0:03:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balista?
Dialogue: 0,0:03:13.55,0:03:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:03:14.76,0:03:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil itu dilakukan!
Dialogue: 0,0:03:19.72,0:03:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang jujur pun,\Nkayaknya dia tidak akan percaya.
Dialogue: 0,0:03:24.06,0:03:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda.
Dialogue: 0,0:03:26.44,0:03:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera?
Dialogue: 0,0:03:28.69,0:03:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa aku mengganggu\Nreuni keluarga kalian?
Dialogue: 0,0:03:33.13,0:03:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:03:34.94,0:03:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Raja juga datang?
Dialogue: 0,0:03:36.97,0:03:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:38.03,0:03:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau menunggu kedatanganmu, lo.
Dialogue: 0,0:03:40.53,0:03:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambil penasaran dengan hal menarik lain\Nyang mungkin kamu siapkan.
Dialogue: 0,0:03:44.45,0:03:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah.
Dialogue: 0,0:03:48.42,0:03:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah.
Dialogue: 0,0:03:50.84,0:03:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kuperlihatkan balistanya\Nsetelah menyapa Yang Mulia Raja?
Dialogue: 0,0:03:54.59,0:03:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus.
Dialogue: 0,0:03:56.51,0:04:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis pasti akan percaya\Nkalau melihat langsung.
Dialogue: 0,0:04:00.09,0:04:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada anak panahnya, aku bisa\Nlangsung memamerkan balista punyaku.
Dialogue: 0,0:04:05.39,0:04:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sekarang ada yang lebih bagus dari itu.
Dialogue: 0,0:04:08.98,0:04:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:04:10.69,0:04:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menjualnya padaku?
Dialogue: 0,0:04:12.61,0:04:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, nanti aku siapkan.
Dialogue: 0,0:04:15.23,0:04:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita negosiasi soal harganya, ya.
Dialogue: 0,0:04:19.20,0:04:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar licik.
Dialogue: 0,0:04:25.37,0:04:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Viscount Kaien.
Dialogue: 0,0:04:27.25,0:04:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang membawa Baron Van Nei Fertio.
Dialogue: 0,0:04:32.75,0:04:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan masuk.
Dialogue: 0,0:04:36.51,0:04:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terkesan melihat kesatria pengawal raja?
Dialogue: 0,0:04:39.61,0:04:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengesankan sekali.
Dialogue: 0,0:04:42.11,0:04:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kuat, ya?
Dialogue: 0,0:04:43.93,0:04:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:45.01,0:04:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria pengawal raja\Nmenjunjung tinggi keberanian.
Dialogue: 0,0:04:50.44,0:04:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:04:51.40,0:04:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin anak muda sepertimu juga\Nbisa menang tergantung perlengkapan.
Dialogue: 0,0:04:57.24,0:05:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera sengaja banget.
Dialogue: 0,0:05:02.99,0:05:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo masuk.
Dialogue: 0,0:05:06.54,0:05:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mengenai rencana kali ini,
Dialogue: 0,0:05:09.32,0:05:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan mengumpulkan\Nprajurit terbaik Kerajaan Scuderia
Dialogue: 0,0:05:12.93,0:05:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merebut kembali Kota Benteng Scudet.
Dialogue: 0,0:05:16.90,0:05:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang keberatan?
Dialogue: 0,0:05:23.34,0:05:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu Count Ferdinatto, ayah Arut?
Dialogue: 0,0:05:28.06,0:05:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang agak mirip Arut, sih.
Dialogue: 0,0:05:31.85,0:05:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aperta, adakah yang kamu khawatirkan\Ntentang pertempuran ini?
Dialogue: 0,0:05:36.29,0:05:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:05:37.82,0:05:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan Yelenetta berhasil\Nmenaklukkan Scudet dalam sekejap,
Dialogue: 0,0:05:41.95,0:05:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal kota itu bertahun-tahun\Nsulit ditembus.
Dialogue: 0,0:05:44.84,0:05:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan terbesarnya\Nadalah wyvern dan bola hitam.
Dialogue: 0,0:05:49.33,0:05:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola hitam.
Dialogue: 0,0:05:51.08,0:05:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata baru mereka, ya?
Dialogue: 0,0:05:53.21,0:05:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau bisa menghentikan itu,\Nkita bisa menang?
Dialogue: 0,0:05:57.28,0:05:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:58.39,0:06:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mereka menyerang menggunakan wyvern.
Dialogue: 0,0:06:01.84,0:06:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi akan sulit untuk mengatasinya.
Dialogue: 0,0:06:06.22,0:06:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis Fertio, kamu pernah menerima\Nserangan bola hitam itu, kan?
Dialogue: 0,0:06:11.15,0:06:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:12.67,0:06:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan bantuan Scuderia telah tiba!
Dialogue: 0,0:06:15.69,0:06:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:06:18.40,0:06:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata apa itu?
Dialogue: 0,0:06:22.65,0:06:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Jalpa!\NPasukan kita di ambang kehancuran!
Dialogue: 0,0:06:25.87,0:06:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:06:28.62,0:06:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan dahsyatnya
Dialogue: 0,0:06:30.79,0:06:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyapu bersih pasukan kami.
Dialogue: 0,0:06:36.46,0:06:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron, apa kamu punya rencana\Nuntuk mengatasinya?
Dialogue: 0,0:06:41.21,0:06:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, ya?
Dialogue: 0,0:06:43.63,0:06:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum lawan menyerang pakai bola hitamnya,
Dialogue: 0,0:06:46.55,0:06:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau kita\Njatuhkan dulu wyvern mereka?
Dialogue: 0,0:06:50.51,0:06:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh sekali.
Dialogue: 0,0:06:51.77,0:06:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bualan mulut anak kecil.
Dialogue: 0,0:06:53.93,0:06:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau semudah itu,\N- Biasanya, ide seperti itu mustahil.
Dialogue: 0,0:06:55.10,0:06:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- kita tidak perlu rapat begini.\N- Biasanya, ide seperti itu mustahil.
Dialogue: 0,0:06:59.48,0:07:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Baron yang bilang,\Nrasanya itu memungkinkan.
Dialogue: 0,0:07:04.03,0:07:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, maukah kamu pergi ke garis depan\Nuntuk merebut kembali Scudet?
Dialogue: 0,0:07:08.56,0:07:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf,\Naku tidak berniat pergi ke garis depan.
Dialogue: 0,0:07:13.79,0:07:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya membantah raja!
Dialogue: 0,0:07:15.59,0:07:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa dipercaya.
Dialogue: 0,0:07:17.00,0:07:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia pikirkan?
Dialogue: 0,0:07:18.75,0:07:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:07:19.63,0:07:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau ke garis depan?
Dialogue: 0,0:07:21.67,0:07:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dapat prestasi besar, lo.
Dialogue: 0,0:07:23.21,0:07:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bolehkah aku di belakang saja?
Dialogue: 0,0:07:27.20,0:07:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:28.84,0:07:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:07:30.43,0:07:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau terluka.
Dialogue: 0,0:07:32.72,0:07:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:33.77,0:07:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Egois sekali!
Dialogue: 0,0:07:35.35,0:07:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat keterlaluan.
Dialogue: 0,0:07:37.10,0:07:39.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang keluarga Fertio ajarkan padanya?
Dialogue: 0,0:07:41.19,0:07:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski anak-anak, ucapanmu keterlaluan.
Dialogue: 0,0:07:43.95,0:07:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuma penguasa wilayah kecil\Ndi perbatasan.
Dialogue: 0,0:07:47.11,0:07:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarilah posisimu.
Dialogue: 0,0:07:50.20,0:07:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, aku paham betul soal itu.
Dialogue: 0,0:07:53.99,0:07:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bangsawan besar di sini,
Dialogue: 0,0:07:56.21,0:07:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pernah tahu\Nperjuangan seorang tuan tanah
Dialogue: 0,0:07:59.46,0:08:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mati-matian\Nmelindungi desa kecil, kan?
Dialogue: 0,0:08:02.00,0:08:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:08:04.21,0:08:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquis.
Dialogue: 0,0:08:08.76,0:08:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron, lanjutkan.
Dialogue: 0,0:08:10.89,0:08:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:12.03,0:08:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, aku adalah tuan tanah
Dialogue: 0,0:08:14.68,0:08:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari desa kecil yang hampir hancur.
Dialogue: 0,0:08:17.81,0:08:20.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski punya rekan-rekan hebat,
Dialogue: 0,0:08:20.27,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak pernah dapat bantuan dari keluarga.
Dialogue: 0,0:08:25.36,0:08:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, kami telah\Nberjuang keras memajukan desa.
Dialogue: 0,0:08:30.49,0:08:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu tetaplah desa kecil.
Dialogue: 0,0:08:32.73,0:08:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kerajaan Yelenetta\Nmenyerang selagi aku tidak ada,
Dialogue: 0,0:08:36.30,0:08:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}desa kami pasti kalah.
Dialogue: 0,0:08:38.83,0:08:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa Yelenetta benar-benar\Nmengincar desa sekecil itu?
Dialogue: 0,0:08:44.03,0:08:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:45.17,0:08:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan pengintai mereka\Nmemang datang ke Desa Seatoh.
Dialogue: 0,0:08:48.67,0:08:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, Yelenetta benar-benar\Ningin menghancurkan kita.
Dialogue: 0,0:08:53.72,0:08:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, Yelenetta pasti mengincar
Dialogue: 0,0:08:56.35,0:08:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wilayah yang paling dekat dulu.
Dialogue: 0,0:08:59.48,0:09:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:00.52,0:09:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah kecil pasti bisa\Ndibakar dengan mudah.
Dialogue: 0,0:09:05.07,0:09:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:09:06.48,0:09:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak ada solusinya?
Dialogue: 0,0:09:08.52,0:09:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan harus diperkuat.
Dialogue: 0,0:09:11.57,0:09:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin melindungi desa\Nyang kami bangun bersama.
Dialogue: 0,0:09:15.53,0:09:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku tidak boleh sampai terluka.
Dialogue: 0,0:09:22.29,0:09:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:09:24.59,0:09:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ucapanmu terdengar
Dialogue: 0,0:09:26.92,0:09:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seakan bisa menghadapi\Npasukan Yelenetta sendirian.
Dialogue: 0,0:09:30.59,0:09:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku yakin bisa.
Dialogue: 0,0:09:33.18,0:09:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong!
Dialogue: 0,0:09:34.72,0:09:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka punya wyvern\Ndan senjata bola hitam, lo!
Dialogue: 0,0:09:38.24,0:09:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu bukan masalah.
Dialogue: 0,0:09:42.81,0:09:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, aku tidak bermaksud\Ncuma diam di belakang.
Dialogue: 0,0:09:47.65,0:09:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya,
Dialogue: 0,0:09:48.78,0:09:51.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku siap menyediakan balista\Ndan katapel model baru.
Dialogue: 0,0:09:52.78,0:09:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:53.86,0:09:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh bisa diandalkan.
Dialogue: 0,0:09:56.49,0:09:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi langsung saja,
Dialogue: 0,0:09:58.08,0:10:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan membuat balista\Ndan katapelnya sekarang.
Dialogue: 0,0:10:01.91,0:10:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatnya sekarang?
Dialogue: 0,0:10:03.83,0:10:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Van, kamu belum mengerti situasinya, ya?
Dialogue: 0,0:10:07.88,0:10:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dalam keadaan genting...
Dialogue: 0,0:10:09.34,0:10:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, seperti yang dijanjikan,\Nakan kuperlihatkan langsung.
Dialogue: 0,0:10:24.77,0:10:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:10:26.15,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:10:27.27,0:10:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibuat secepat ini?
Dialogue: 0,0:10:28.61,0:10:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:10:30.61,0:10:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah, bagaimana?
Dialogue: 0,0:10:32.70,0:10:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berguna.
Dialogue: 0,0:10:33.78,0:10:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling fungsinya tidak sebanding\Ndengan tampilannya.
Dialogue: 0,0:10:38.62,0:10:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali menyusun pasukan.
Dialogue: 0,0:10:48.42,0:10:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini luar biasa.
Dialogue: 0,0:10:50.80,0:10:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah senjata barumu, Baron?
Dialogue: 0,0:10:53.59,0:10:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi kamu membuat sesuatu yang gila, ya.
Dialogue: 0,0:10:57.52,0:11:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katapel ini melontarkan syuriken khusus
Dialogue: 0,0:11:00.68,0:11:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menjatuhkan wyvern.
Dialogue: 0,0:11:04.18,0:11:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senjata seperti ini,\Nkita bisa menang?
Dialogue: 0,0:11:07.56,0:11:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bilang "pasti".
Dialogue: 0,0:11:09.97,0:11:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, semua disiapkan sebaik mungkin.
Dialogue: 0,0:11:12.74,0:11:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau musuh tidak melampaui prediksiku,\Nkemungkinan besar kita menang.
Dialogue: 0,0:11:18.37,0:11:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu, Baron.
Dialogue: 0,0:11:20.87,0:11:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:22.87,0:11:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akhiri rapat hari ini.
Dialogue: 0,0:11:25.16,0:11:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lalai dalam menyusun pasukan.
Dialogue: 0,0:11:28.28,0:11:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:11:32.13,0:11:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, terima kasih kerja kerasnya.
Dialogue: 0,0:11:34.79,0:11:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:35.97,0:11:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang menjemputku?
Dialogue: 0,0:11:38.01,0:11:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:39.11,0:11:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Arut juga ikut, lo.
Dialogue: 0,0:11:45.85,0:11:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut?
Dialogue: 0,0:11:47.31,0:11:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayah.
Dialogue: 0,0:11:50.36,0:11:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak durhaka!
Dialogue: 0,0:11:56.49,0:11:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ibu sehat?
Dialogue: 0,0:12:00.70,0:12:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:01.61,0:12:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menjalani hari-hari seperti biasa\Ndi wilayah kita.
Dialogue: 0,0:12:05.25,0:12:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:12:08.04,0:12:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, aku sibuk dengan persiapan perang.
Dialogue: 0,0:12:11.38,0:12:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah situasinya membaik,\Nmari berbincang lagi.
Dialogue: 0,0:12:15.30,0:12:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku menantikannya.
Dialogue: 0,0:12:29.27,0:12:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut, kamu baik-baik saja?
Dialogue: 0,0:12:31.69,0:12:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kondisimu kurang baik,\Nistirahat saja dulu.
Dialogue: 0,0:12:35.33,0:12:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:12:36.87,0:12:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Till, tolong temani dia.
Dialogue: 0,0:12:38.82,0:12:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:42.41,0:12:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Arut, mari.
Dialogue: 0,0:12:48.33,0:12:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, pasukan pemanah\Nkuserahkan padamu, ya, Kamshin?
Dialogue: 0,0:12:52.08,0:12:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:53.08,0:12:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya senjata Tuan Van\Nsangatlah luar biasa.
Dialogue: 0,0:12:57.21,0:12:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuktikannya.
Dialogue: 0,0:12:59.47,0:13:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:00.83,0:13:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, untuk menjatuhkan wyvern,\Nkita harus pakai katapel.
Dialogue: 0,0:13:05.22,0:13:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami para Kesatria Seatoh\Nyang mengawal pasukan Kamshin.
Dialogue: 0,0:13:09.81,0:13:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga akan membantu.
Dialogue: 0,0:13:11.81,0:13:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku lega mendengarnya.
Dialogue: 0,0:13:15.40,0:13:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya pertempuran penentuan.
Dialogue: 0,0:13:18.28,0:13:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yelenetta berhasil menembus\NKota Benteng Scudet,
Dialogue: 0,0:13:21.37,0:13:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan wyvern dan senjata baru.
Dialogue: 0,0:13:25.05,0:13:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:13:26.49,0:13:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}era peperangan\Nmenggunakan empat elemen sihir
Dialogue: 0,0:13:29.83,0:13:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah berakhir.
Dialogue: 0,0:13:32.79,0:13:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, yang saat ini punya\Nkekuatan terbesar adalah
Dialogue: 0,0:13:36.71,0:13:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta?
Dialogue: 0,0:13:38.60,0:13:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau...
Dialogue: 0,0:13:41.47,0:13:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata-senjata buatan anak muda itu.
Dialogue: 0,0:13:55.81,0:13:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi merebut kembali Scudet dimulai!
Dialogue: 0,0:13:59.40,0:14:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:14:02.40,0:14:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:14:05.64,0:14:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai rencana, majulah dalam dua pasukan!
Dialogue: 0,0:14:10.16,0:14:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi merebut kembali Scudet,\Ntarget utama kita adalah menjatuhkan wyvern!
Dialogue: 0,0:14:15.64,0:14:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo raih kemenangan!
Dialogue: 0,0:14:18.46,0:14:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:14:19.42,0:14:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:14:21.22,0:14:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xara! Purriel!
Dialogue: 0,0:14:22.84,0:14:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan bergerilya membantu\Narea yang pertahanannya lemah!
Dialogue: 0,0:14:26.55,0:14:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya!\N- Siap!
Dialogue: 0,0:14:28.35,0:14:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Seatoh!
Dialogue: 0,0:14:29.60,0:14:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bertugas melindungi pasukan pemanah!
Dialogue: 0,0:14:32.94,0:14:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju dengan waspada!
Dialogue: 0,0:14:34.52,0:14:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:14:41.69,0:14:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sepertinya sudah waktunya\Nmereka akan muncul.
Dialogue: 0,0:14:45.99,0:14:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pasukan Scuderia.
Dialogue: 0,0:14:47.65,0:14:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membagi dua pasukan\Nuntuk membobol tembok?
Dialogue: 0,0:14:51.08,0:14:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira mereka akan fokus\Nmenghancurkan gerbang.
Dialogue: 0,0:14:54.62,0:14:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:14:55.87,0:14:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita habisi saja semuanya.
Dialogue: 0,0:14:58.96,0:15:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasang posisi!
Dialogue: 0,0:15:03.38,0:15:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:15:07.14,0:15:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia! Operasi dimulai!
Dialogue: 0,0:15:11.10,0:15:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasang perisai!
Dialogue: 0,0:15:19.65,0:15:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya ditangkis?
Dialogue: 0,0:15:21.59,0:15:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatnya dadakan pakai balok kayu.
Dialogue: 0,0:15:24.36,0:15:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lumayan oke.
Dialogue: 0,0:15:26.11,0:15:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar!
Dialogue: 0,0:15:28.03,0:15:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penyihir, bersiaplah!
Dialogue: 0,0:15:36.71,0:15:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:15:47.13,0:15:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!\NHancurkan perisai-perisai itu!
Dialogue: 0,0:15:49.89,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Perisainya tidak kuat lagi!
Dialogue: 0,0:15:52.68,0:15:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dee!
Dialogue: 0,0:15:57.06,0:16:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perisai apa pun mustahil bisa menahan\Nserangan pasukan Yelenetta!
Dialogue: 0,0:16:04.48,0:16:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang utaranya!
Dialogue: 0,0:16:08.16,0:16:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asalnya?
Dialogue: 0,0:16:11.37,0:16:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Pasukan terpisah?
Dialogue: 0,0:16:14.29,0:16:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan gerbang kastelnya!
Dialogue: 0,0:16:17.48,0:16:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penguasa Badai!
Dialogue: 0,0:16:20.54,0:16:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medan Es!
Dialogue: 0,0:16:23.63,0:16:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembing Api!
Dialogue: 0,0:16:27.07,0:16:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:16:28.05,0:16:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal mereka sudah merencanakan ini!
Dialogue: 0,0:16:30.97,0:16:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, dia terpancing dengan mudah.
Dialogue: 0,0:16:35.02,0:16:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bobol paksa gerbangnya!
Dialogue: 0,0:16:36.98,0:16:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:16:38.02,0:16:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badai Es!
Dialogue: 0,0:16:40.19,0:16:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tombak Api!
Dialogue: 0,0:16:47.28,0:16:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa?
Dialogue: 0,0:16:49.99,0:16:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Count Ferdinatto\Nternyata memang kuat, ya.
Dialogue: 0,0:16:55.37,0:16:56.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:16:56.40,0:16:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serbu ke dalam Kastel Scudet!
Dialogue: 0,0:17:02.50,0:17:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan mereka!
Dialogue: 0,0:17:09.05,0:17:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisi pasukan Scuderia!
Dialogue: 0,0:17:14.76,0:17:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini pasukan khusus Yelenetta?
Dialogue: 0,0:17:17.98,0:17:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:17:19.77,0:17:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepung mereka!
Dialogue: 0,0:17:25.02,0:17:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera!
Dialogue: 0,0:17:26.48,0:17:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan kita!
Dialogue: 0,0:17:28.35,0:17:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:17:39.25,0:17:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan ini pada kami!
Dialogue: 0,0:17:42.00,0:17:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:45.75,0:17:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan jarak dekat, sih, aku jagonya!
Dialogue: 0,0:17:52.63,0:17:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan juga serangan jarak jauh.
Dialogue: 0,0:18:05.65,0:18:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bawahannya Van?
Dialogue: 0,0:18:07.82,0:18:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:18:14.07,0:18:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini...
Dialogue: 0,0:18:15.99,0:18:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, suruh mereka keluarkan itu!
Dialogue: 0,0:18:18.33,0:18:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:18:19.45,0:18:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan! Tidak kusangka akan sesulit ini!
Dialogue: 0,0:18:26.92,0:18:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada wyvern!
Dialogue: 0,0:18:28.38,0:18:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak itu?
Dialogue: 0,0:18:32.13,0:18:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, habislah mereka!
Dialogue: 0,0:18:33.88,0:18:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat jatuhkan bola hitamnya!
Dialogue: 0,0:18:36.93,0:18:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamshin, ini saatnya!
Dialogue: 0,0:18:38.93,0:18:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapkan katapel!
Dialogue: 0,0:18:41.06,0:18:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:18:44.23,0:18:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lempar!
Dialogue: 0,0:18:58.08,0:19:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, sesuai rencana!
Dialogue: 0,0:19:08.63,0:19:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada satu yang hidup!
Dialogue: 0,0:19:12.13,0:19:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:19:17.18,0:19:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Xara!
Dialogue: 0,0:19:18.89,0:19:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:19:25.31,0:19:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mempan!
Dialogue: 0,0:19:27.15,0:19:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! Dia terpancing ke sini!
Dialogue: 0,0:19:29.65,0:19:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balista, tembak!
Dialogue: 0,0:19:36.78,0:19:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:19:38.74,0:19:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakar habis musuh di hadapanku!
Dialogue: 0,0:19:41.95,0:19:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vermillion!
Dialogue: 0,0:19:58.47,0:19:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahagialah!
Dialogue: 0,0:19:59.43,0:20:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan utama wyvern musuh\Ntelah dijatuhkan!
Dialogue: 0,0:20:06.98,0:20:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kekuatan Baron sehebat ini.
Dialogue: 0,0:20:13.82,0:20:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kalah...
Dialogue: 0,0:20:14.99,0:20:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kabur.
Dialogue: 0,0:20:16.61,0:20:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja.
Dialogue: 0,0:20:18.83,0:20:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir bisa kabur?
Dialogue: 0,0:20:20.82,0:20:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah.
Dialogue: 0,0:20:32.04,0:20:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:20:33.50,0:20:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita langsung pulang tanpa menemui Van dulu?
Dialogue: 0,0:20:44.10,0:20:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin selama ini, pemikiranku yang salah.
Dialogue: 0,0:20:54.73,0:20:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta langsung tumbang\Nsaat wyvern dan bola hitamnya teratasi.
Dialogue: 0,0:20:59.99,0:21:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini berkat Tuan Van!
Dialogue: 0,0:21:02.41,0:21:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma memberi instruksi dari belakang.
Dialogue: 0,0:21:05.83,0:21:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini berkat kerja keras kalian.
Dialogue: 0,0:21:08.87,0:21:12.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian semua selamat.
Dialogue: 0,0:21:12.04,0:21:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:13.16,0:21:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van.
Dialogue: 0,0:21:15.42,0:21:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil menangkap komandan Yelenetta.
Dialogue: 0,0:21:21.47,0:21:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya dia punya banyak informasi rahasia.
Dialogue: 0,0:21:26.06,0:21:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, coba kita dengarkan.
Dialogue: 0,0:21:29.81,0:21:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuan kalian?
Dialogue: 0,0:21:36.65,0:21:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, menurut komandan itu,
Dialogue: 0,0:21:39.56,0:21:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta berencana\Nmenyerang dari tiga titik.
Dialogue: 0,0:21:45.03,0:21:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua di antaranya,\Nadalah Desa Seatoh dan Scudet.
Dialogue: 0,0:21:49.37,0:21:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang terakhir adalah...
Dialogue: 0,0:21:52.83,0:21:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah Count Ferdinatto.
Dialogue: 0,0:22:00.05,0:22:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halaman Arut.
