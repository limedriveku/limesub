Dialogue: 0,0:01:09.42,0:01:11.30,tanda,,0000,0000,0000,,PERTAHANAN WILAYAH SERU\NOLEH TUAN TANAH SANTAI
Dialogue: 0,0:01:11.30,0:01:14.55,tanda,,0000,0000,0000,,MEMBUAT DESA TANPA NAMA MENJADI KOTA\NBENTENG TERKUAT DENGAN SIHIR PRODUKSI
Dialogue: 0,0:01:14.55,0:01:17.14,tanda,,0000,0000,0000,,EPISODE 9: TARIAN BONEKA YANG INDAH\NDARI GADIS PENAKUT
Dialogue: 0,0:02:28.00,0:02:29.47,tanda,,0000,0000,0000,,EPISODE 9: TARIAN BONEKA YANG INDAH\NDARI GADIS PENAKUT
Dialogue: 0,0:02:53.03,0:03:00.54,tanda,,0000,0000,0000,,UANG BANYAK
Dialogue: 0,0:03:46.21,0:03:47.96,tanda,,0000,0000,0000,,UANG BANYAK
Dialogue: 0,0:23:34.98,0:23:41.94,tanda,,0000,0000,0000,,SELANJUTNYA:\NSERANGAN KEJI SENJATA RAHASIA DI TANAH AIR
Dialogue: 0,0:00:01.38,0:00:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan kotanya indah, ya.
Dialogue: 0,0:00:03.61,0:00:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:00:04.95,0:00:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sia-sia kita menata kota bersama-sama.
Dialogue: 0,0:00:07.65,0:00:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau desanya sebagus ini,\Nsemua orang pasti bahagia.
Dialogue: 0,0:00:12.24,0:00:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut, kamu sudah lama tinggal di sini,\Njadi bagaimana?
Dialogue: 0,0:00:16.43,0:00:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:00:17.59,0:00:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menetap di desa ini?
Dialogue: 0,0:00:19.00,0:00:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:21.38,0:00:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So-Soal itu...
Dialogue: 0,0:00:23.25,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, lupakan soal pernikahan.
Dialogue: 0,0:00:25.63,0:00:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utamakan saja hal yang paling kamu inginkan.
Dialogue: 0,0:00:31.55,0:00:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang aku inginkan?
Dialogue: 0,0:00:35.71,0:00:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menikah dengan Tuan Van.
Dialogue: 0,0:00:38.69,0:00:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu...
Dialogue: 0,0:00:40.90,0:00:42.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin menikah?
Dialogue: 0,0:00:44.57,0:00:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pura-pura tidak dengar saja, ya?
Dialogue: 0,0:00:46.80,0:00:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:48.03,0:00:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:00:51.11,0:00:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Tuan Van,\Nkenapa kamu terlihat bahagia?
Dialogue: 0,0:00:55.45,0:00:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma perasaanmu, kok.
Dialogue: 0,0:02:29.47,0:02:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van!\NKami sudah kembali dari ibu kota!
Dialogue: 0,0:02:33.26,0:02:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:02:34.81,0:02:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berhasil bikin perusahaan dagang?
Dialogue: 0,0:02:37.14,0:02:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:02:38.22,0:02:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Tuan Van, prosesnya lancar.
Dialogue: 0,0:02:40.89,0:02:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai janji, ini 130 koin platinum.
Dialogue: 0,0:02:44.14,0:02:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon diterima.
Dialogue: 0,0:02:45.35,0:02:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih.
Dialogue: 0,0:02:47.94,0:02:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Till, tolong pegang.
Dialogue: 0,0:02:53.03,0:02:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya aku melihat
Dialogue: 0,0:02:55.32,0:02:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}koin platinum sebanyak ini.
Dialogue: 0,0:02:56.74,0:03:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Nona Panamera tidak kembali ke desa?
Dialogue: 0,0:03:00.54,0:03:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia mau ke sini setelah\Nmelapor ke Count Ferdinatto.
Dialogue: 0,0:03:04.33,0:03:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya daripada gabung ke faksi bangsawan,
Dialogue: 0,0:03:06.62,0:03:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia lebih tertarik gabung dengan Tuan Van.
Dialogue: 0,0:03:09.42,0:03:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Dia mau tinggal di desa ini?
Dialogue: 0,0:03:11.80,0:03:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tampaknya tanah sebelah desa\Nakan dijadikan wilayah kekuasaannya.
Dialogue: 0,0:03:15.80,0:03:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nona Panamera yang minta,\Npasti langsung disetujui.
Dialogue: 0,0:03:19.80,0:03:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, tuh.
Dialogue: 0,0:03:21.43,0:03:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa disadari, kayaknya dia bakal jadi ratu.
Dialogue: 0,0:03:26.10,0:03:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:03:27.69,0:03:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami membawakan barang spesial\Ndari ibu kota.
Dialogue: 0,0:03:32.32,0:03:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan bilang, ini...
Dialogue: 0,0:03:34.82,0:03:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Busur mekanis yang mampu menembakkan\Nsepuluh anak panah beruntun.
Dialogue: 0,0:03:39.45,0:03:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini termasuk teknologi mutakhir di ibu kota.
Dialogue: 0,0:03:42.37,0:03:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:03:43.87,0:03:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini aku bisa bikin balista baru!
Dialogue: 0,0:03:47.96,0:03:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Tuan Van.
Dialogue: 0,0:03:50.42,0:03:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian berdua, terima kasih banyak, ya.\N- Dia lebih bahagia
Dialogue: 0,0:03:51.71,0:03:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalian berdua, terima kasih banyak, ya.\N- daripada saat dapat koin platinum.
Dialogue: 0,0:03:56.05,0:03:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tuas ini ditarik,\Nanak panah berikutnya akan turun, ya.
Dialogue: 0,0:03:59.85,0:04:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van terlihat paling senang\Ndi saat seperti ini.
Dialogue: 0,0:04:02.72,0:04:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, masa?
Dialogue: 0,0:04:09.98,0:04:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:04:11.86,0:04:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kok macet?
Dialogue: 0,0:04:14.69,0:04:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van juga bisa gagal, ya.
Dialogue: 0,0:04:20.45,0:04:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:04:22.02,0:04:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada maksud menyinggung.
Dialogue: 0,0:04:25.87,0:04:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering gagal, tahu.
Dialogue: 0,0:04:27.91,0:04:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula cuma sihir ini\Nyang bisa kubanggakan.
Dialogue: 0,0:04:30.79,0:04:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar!
Dialogue: 0,0:04:32.81,0:04:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakatmu mengagumkan\Ndalam ilmu pedang dan akademik.
Dialogue: 0,0:04:37.66,0:04:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan, aku tidak bisa apa-apa.
Dialogue: 0,0:04:41.18,0:04:42.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bakat?
Dialogue: 0,0:04:42.89,0:04:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berkenan,
Dialogue: 0,0:04:44.31,0:04:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa kenalkan pelayan seperti iblis\Ndan kesatria seperti monster, lo.
Dialogue: 0,0:04:48.18,0:04:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kamu pasti langsung melampauiku, kok.
Dialogue: 0,0:04:53.73,0:04:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, apa atribut sihirmu?
Dialogue: 0,0:05:00.85,0:05:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, Nona Arut.
Dialogue: 0,0:05:03.49,0:05:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van tidak memaksa, kok.
Dialogue: 0,0:05:06.54,0:05:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona tidak perlu menjawab kalau tidak mau.
Dialogue: 0,0:05:10.21,0:05:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:11.12,0:05:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:05:13.85,0:05:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya atribut sihir boneka.
Dialogue: 0,0:05:17.55,0:05:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir boneka itu,\Nsama seperti atribut sihirku.
Dialogue: 0,0:05:21.72,0:05:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dianggap tidak berguna\Ndan dibenci di kalangan bangsawan.
Dialogue: 0,0:05:25.76,0:05:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:05:27.05,0:05:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aku belum pernah melihatnya.
Dialogue: 0,0:05:29.68,0:05:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh lihat, tidak?
Dialogue: 0,0:05:30.89,0:05:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, a-anu...
Dialogue: 0,0:05:34.06,0:05:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat sihirku?
Dialogue: 0,0:05:36.52,0:05:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, jarang ada\Nyang punya sihir boneka, lo.
Dialogue: 0,0:05:41.20,0:05:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena banyak\Nyang menyembunyikannya juga, sih.
Dialogue: 0,0:05:44.62,0:05:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu orang pertama yang aku tahu.
Dialogue: 0,0:05:47.79,0:05:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti takdir, Arut.
Dialogue: 0,0:05:57.80,0:05:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kamu menggerakkan ini?
Dialogue: 0,0:06:11.35,0:06:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang luar biasa!
Dialogue: 0,0:06:13.31,0:06:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensi sihir ini sangat besar, Arut!
Dialogue: 0,0:06:20.65,0:06:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!\NNona Arut memang hebat!
Dialogue: 0,0:06:23.53,0:06:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nona Arut juga bisa menarikan\Ntarian boneka barusan?
Dialogue: 0,0:06:28.16,0:06:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bisa.
Dialogue: 0,0:06:29.83,0:06:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku lebih mahir membuat boneka menari.
Dialogue: 0,0:06:33.87,0:06:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu lebih dari cukup!
Dialogue: 0,0:06:36.46,0:06:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari minta Tuan Van\Nuntuk membuat boneka yang lucu.
Dialogue: 0,0:06:40.00,0:06:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita tunjukkan ke penduduk desa,\Nmereka pasti senang.
Dialogue: 0,0:06:44.55,0:06:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.\NSepertinya menarik.
Dialogue: 0,0:06:47.05,0:06:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan bikin boneka\Ndari mithril yang Arut temukan.
Dialogue: 0,0:06:52.18,0:06:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sihirku tidak pantas\Ndiperlihatkan pada orang lain.
Dialogue: 0,0:06:57.10,0:06:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama, kok.
Dialogue: 0,0:06:59.40,0:07:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir\Nproduksiku sering dianggap tidak berguna.
Dialogue: 0,0:07:04.20,0:07:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku saja mengataiku produk gagal.
Dialogue: 0,0:07:08.32,0:07:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat sihir itu,\Naku bisa membuat semua orang senang.
Dialogue: 0,0:07:12.45,0:07:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir boneka milikmu pun\Npasti bisa membuat orang-orang senang.
Dialogue: 0,0:07:18.41,0:07:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, aku selalu mengira\Nhidupku tidak berharga.
Dialogue: 0,0:07:23.09,0:07:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:07:25.14,0:07:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Tuan Van bilang seperti itu,\Naku akan mencobanya.
Dialogue: 0,0:07:36.35,0:07:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:07:37.31,0:07:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van menyuruh kita kemari.
Dialogue: 0,0:07:39.31,0:07:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, ya?
Dialogue: 0,0:07:50.95,0:07:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, terima kasih sudah datang.
Dialogue: 0,0:07:54.54,0:07:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari saksikan,\Npertunjukan sihir dari Putri Arut.
Dialogue: 0,0:07:59.58,0:08:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertunjukan sihir?
Dialogue: 0,0:08:01.29,0:08:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir apa, ya?
Dialogue: 0,0:08:12.85,0:08:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti hidup sungguhan.
Dialogue: 0,0:08:14.72,0:08:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu...
Dialogue: 0,0:08:16.23,0:08:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir boneka, ya.
Dialogue: 0,0:08:17.94,0:08:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, sihir itu pernah dipakai\Nuntuk menyerang bangsawan, kan?
Dialogue: 0,0:08:22.52,0:08:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak durhaka!
Dialogue: 0,0:08:27.61,0:08:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:29.24,0:08:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok diam?
Dialogue: 0,0:08:30.69,0:08:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga tidak lepas kendali.
Dialogue: 0,0:08:32.95,0:08:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Arut.
Dialogue: 0,0:08:34.95,0:08:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, jangan mengira\Nboneka ini cuma bisa membungkuk.
Dialogue: 0,0:08:39.53,0:08:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sihir para kriminal rendahan",
Dialogue: 0,0:08:41.92,0:08:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itulah cap yang umum dipakai\Nuntuk mendiskriminasi sihir boneka.
Dialogue: 0,0:08:45.80,0:08:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertunjukan sihir Putri Arut\Nbaru akan dimulai, lo.
Dialogue: 0,0:08:48.80,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dia akan dipandang?\NBagaimana dia diperlakukan?
Dialogue: 0,0:08:53.47,0:08:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkan itu pasti membuatnya takut.
Dialogue: 0,0:08:56.87,0:08:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tenang saja.
Dialogue: 0,0:09:42.71,0:09:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarian yang menakjubkan.
Dialogue: 0,0:09:45.61,0:09:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir boneka Arut\Nmenghidupkan benda tak bernyawa.
Dialogue: 0,0:09:51.37,0:09:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar sihir yang luar biasa.
Dialogue: 0,0:10:38.91,0:10:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarian yang indah, ya!
Dialogue: 0,0:10:41.04,0:10:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Sihir yang luar biasa!
Dialogue: 0,0:10:43.04,0:10:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata sihir boneka bisa begini!
Dialogue: 0,0:10:45.08,0:10:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakannya bagus banget!
Dialogue: 0,0:10:47.13,0:10:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sangat takut\Ndan mengiranya sebagai atribut yang buruk.
Dialogue: 0,0:10:55.38,0:10:57.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut, kamu berhasil.
Dialogue: 0,0:11:07.41,0:11:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:13.40,0:11:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, gawat!
Dialogue: 0,0:11:15.36,0:11:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:16.78,0:11:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta kuda berlambang kerajaan\Nsedang menuju ke sini!
Dialogue: 0,0:11:21.41,0:11:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan?
Dialogue: 0,0:11:27.79,0:11:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, anak muda.
Dialogue: 0,0:11:29.21,0:11:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera, lama tidak berjumpa.
Dialogue: 0,0:11:32.21,0:11:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Reaksimu dingin sekali.
Dialogue: 0,0:11:35.67,0:11:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah punya wanita lain, ya?
Dialogue: 0,0:11:37.84,0:11:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Arut\Nsudah lebih akrab dari sebelumnya.
Dialogue: 0,0:11:40.97,0:11:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Nona Panamera.
Dialogue: 0,0:11:45.95,0:11:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda, trik macam apa ini?
Dialogue: 0,0:11:48.81,0:11:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perubahan ini\Nterjadi dalam waktu singkat?
Dialogue: 0,0:11:52.73,0:11:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:11:55.41,0:11:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Arut tidak percaya diri\Ndengan sihirnya,
Dialogue: 0,0:11:58.45,0:12:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku cuma mengatakan bahwa\Nsihirnya luar biasa.
Dialogue: 0,0:12:02.95,0:12:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pandai merayu, ya.
Dialogue: 0,0:12:05.29,0:12:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar ke depannya.
Dialogue: 0,0:12:07.93,0:12:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku terlalu asyik mengobrol.
Dialogue: 0,0:12:11.01,0:12:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, tundukkan kepalamu, anak muda.
Dialogue: 0,0:12:13.44,0:12:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Yang Mulia Raja.
Dialogue: 0,0:12:14.76,0:12:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baik.
Dialogue: 0,0:12:16.97,0:12:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Yang Mulia Raja?
Dialogue: 0,0:12:23.54,0:12:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu Van Nei Fertio?\NAngkat kepalamu.
Dialogue: 0,0:12:28.81,0:12:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Dino En Tsora Bellrinet.
Dialogue: 0,0:12:31.98,0:12:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Kerajaan Scuderia.
Dialogue: 0,0:12:34.53,0:12:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Aperta, Kanselir Kerajaan.
Dialogue: 0,0:12:37.40,0:12:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu telah diangkat menjadi Baron
Dialogue: 0,0:12:40.16,0:12:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bergabung dalam jajaran bangsawan.
Dialogue: 0,0:12:42.83,0:12:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktikan bahwa kamu bisa\Nmemberi manfaat untuk kerajaan.
Dialogue: 0,0:12:46.54,0:12:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku terima dengan penuh hormat.
Dialogue: 0,0:12:49.51,0:12:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengharapkanmu.
Dialogue: 0,0:12:51.29,0:12:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya, sebuah dungeon\Nditemukan di wilayah kekuasaanmu.
Dialogue: 0,0:12:55.95,0:12:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan dilakukan penyelidikan,
Dialogue: 0,0:12:58.05,0:13:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saat waktunya tiba,\Nbicaralah sejujur-jujurnya.
Dialogue: 0,0:13:01.43,0:13:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang ada kebohongan.
Dialogue: 0,0:13:03.80,0:13:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:04.75,0:13:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir,
Dialogue: 0,0:13:05.89,0:13:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penumpasan Naga Hutan\Nadalah pencapaian luar biasa.
Dialogue: 0,0:13:10.06,0:13:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena lokasi kejadiannya di luar perkiraan,
Dialogue: 0,0:13:13.11,0:13:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Raja datang\Nuntuk memastikannya langsung.
Dialogue: 0,0:13:16.07,0:13:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal ini pun, semua pertanyaanku\Nharus dijawab dengan detail.
Dialogue: 0,0:13:20.61,0:13:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bersedia?
Dialogue: 0,0:13:21.82,0:13:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:13:22.87,0:13:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah untuk bercerita dengan jujur.
Dialogue: 0,0:13:25.67,0:13:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mohon berjanjilah akan satu hal.
Dialogue: 0,0:13:28.70,0:13:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:29.96,0:13:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menunjukkan semuanya,
Dialogue: 0,0:13:32.19,0:13:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akan jadi sebuah kebohongan\Nkalau Yang Mulia tidak percaya.
Dialogue: 0,0:13:35.79,0:13:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon berusahalah untuk percaya.
Dialogue: 0,0:13:40.05,0:13:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Kaien benar, kamu memang menarik.
Dialogue: 0,0:13:43.64,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berjanji.
Dialogue: 0,0:13:47.06,0:13:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, desa kecil yang terlihat dari sini\Nadalah Desa Seatoh.
Dialogue: 0,0:13:53.31,0:13:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok,
Dialogue: 0,0:13:54.73,0:13:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gerbang,
Dialogue: 0,0:13:55.81,0:13:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan parit adalah kunci pertahanannya.
Dialogue: 0,0:13:58.94,0:14:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balista yang dipasang di atas tembok\Nadalah kunci penyerangan.
Dialogue: 0,0:14:03.86,0:14:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aperta, bagaimana menurutmu?
Dialogue: 0,0:14:06.08,0:14:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:07.33,0:14:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Balista memang bagus untuk menyerang target\Ndalam jarak dan ukuran tertentu,
Dialogue: 0,0:14:11.79,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi penggunaannya kurang praktis.
Dialogue: 0,0:14:14.37,0:14:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar kami tunjukkan.
Dialogue: 0,0:14:17.17,0:14:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamshin, tolong arahkan ke hutan!
Dialogue: 0,0:14:20.67,0:14:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai!
Dialogue: 0,0:14:28.60,0:14:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan dan jarak tembaknya luar biasa.
Dialogue: 0,0:14:31.10,0:14:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menembak dua kali beruntun pula.
Dialogue: 0,0:14:33.69,0:14:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa mengandalkan pemanah\Natau penyihir kelas satu,
Dialogue: 0,0:14:36.73,0:14:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daya serang sekuat itu sungguh luar biasa.
Dialogue: 0,0:14:40.36,0:14:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok berbentuk bintangnya juga aneh.
Dialogue: 0,0:14:43.74,0:14:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tembok bintang, ya.
Dialogue: 0,0:14:46.75,0:14:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan membuatnya punya banyak sisi,
Dialogue: 0,0:14:49.91,0:14:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa menyerang musuh dari berbagai arah.
Dialogue: 0,0:14:53.12,0:14:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dihujani panah balista itu\Nakan sangat mengerikan.
Dialogue: 0,0:14:57.38,0:15:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh ini, pertahanannya sempurna\Nkecuali dari serangan udara, ya.
Dialogue: 0,0:15:01.38,0:15:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari udara, ya.
Dialogue: 0,0:15:03.20,0:15:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membuat\Nbeberapa rancangan lain, sih.
Dialogue: 0,0:15:06.39,0:15:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi belum tahu hasilnya\Nsebelum diuji langsung.
Dialogue: 0,0:15:09.39,0:15:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seolah\NTuan Baron sendiri yang membuatnya.
Dialogue: 0,0:15:13.27,0:15:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:15:15.27,0:15:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, dilarang ada kebohongan.
Dialogue: 0,0:15:19.27,0:15:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersumpah untuk tidak berbohong.
Dialogue: 0,0:15:23.40,0:15:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, aku mengerti keraguanmu.
Dialogue: 0,0:15:26.36,0:15:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dengarkan dulu penjelasannya.
Dialogue: 0,0:15:28.85,0:15:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kamu akan terkejut.
Dialogue: 0,0:15:30.53,0:15:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang merancang tembok kota ini?
Dialogue: 0,0:15:33.75,0:15:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk dan strukturnya cukup unik.
Dialogue: 0,0:15:36.54,0:15:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri.
Dialogue: 0,0:15:38.17,0:15:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan tata kotanya?
Dialogue: 0,0:15:40.00,0:15:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skala sebesar ini biasanya\Nbutuh bertahun-tahun.
Dialogue: 0,0:15:43.05,0:15:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bekerja keras membangunnya.
Dialogue: 0,0:15:45.26,0:15:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk desa turut membantu\Nmengumpulkan bahan-bahannya.
Dialogue: 0,0:15:48.43,0:15:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, butuh berapa tahun\Nuntuk membangun tembok kota ini?
Dialogue: 0,0:15:52.43,0:15:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, sekitar empat bulan.
Dialogue: 0,0:15:57.19,0:15:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk akal?
Dialogue: 0,0:15:58.77,0:16:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sulit dipercaya.
Dialogue: 0,0:16:01.19,0:16:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia, sebaiknya kita\Nminta pembuktian langsung.
Dialogue: 0,0:16:05.57,0:16:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:16:06.78,0:16:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nmari ke danau di belakang desa.
Dialogue: 0,0:16:11.95,0:16:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van.
Dialogue: 0,0:16:13.33,0:16:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Tuan Van!
Dialogue: 0,0:16:15.08,0:16:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Tuan Van!
Dialogue: 0,0:16:16.58,0:16:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, selamat bekerja.
Dialogue: 0,0:16:18.58,0:16:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:19.83,0:16:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita makan daging sama-sama lagi, ya.
Dialogue: 0,0:16:22.59,0:16:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kami menantikannya.
Dialogue: 0,0:16:25.22,0:16:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Baron, barusan itu penduduk desa?
Dialogue: 0,0:16:28.47,0:16:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:16:30.47,0:16:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, tuan tanah dan rakyatnya\Nbercakap-cakap seperti itu?
Dialogue: 0,0:16:34.47,0:16:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, begitulah.
Dialogue: 0,0:16:51.62,0:16:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:16:53.37,0:16:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ada Tuan Van.
Dialogue: 0,0:16:55.16,0:16:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo! Mau ke mana?
Dialogue: 0,0:16:57.62,0:17:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ke danau dulu.
Dialogue: 0,0:17:00.17,0:17:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sehat?
Dialogue: 0,0:17:01.88,0:17:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas, dong!\NIya, kan, semuanya?
Dialogue: 0,0:17:08.17,0:17:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh semangat seperti biasa, ya.
Dialogue: 0,0:17:11.13,0:17:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan Baron, siapa mereka?
Dialogue: 0,0:17:14.64,0:17:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para petualang.
Dialogue: 0,0:17:16.64,0:17:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami jadi dekat\Nsejak menjelajah dungeon bersama.
Dialogue: 0,0:17:29.15,0:17:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:17:31.15,0:17:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada Menantu.
Dialogue: 0,0:17:33.78,0:17:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Ladavesta, aku bukan menantumu.
Dialogue: 0,0:17:37.79,0:17:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mataku tidak salah lihat,
Dialogue: 0,0:17:40.58,0:17:44.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tampak seperti makhluk\Nlegendaris yang disebut Apkallu.
Dialogue: 0,0:17:44.63,0:17:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh kebetulan, Yang Mulia.
Dialogue: 0,0:17:46.42,0:17:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga melihat hal yang sama.
Dialogue: 0,0:17:48.55,0:17:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka Apkallu menampakkan dirinya\Ndengan begitu terbuka.
Dialogue: 0,0:17:53.39,0:17:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat\Npemandangan seperti ini.
Dialogue: 0,0:17:58.56,0:18:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Espada, ayo kita buat tembok\Ntambahan untuk danaunya?
Dialogue: 0,0:18:13.11,0:18:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal sentuhan terakhir.
Dialogue: 0,0:18:23.21,0:18:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah proses pembuatannya.
Dialogue: 0,0:18:25.92,0:18:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya mau lihat apa lagi?
Dialogue: 0,0:18:33.09,0:18:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menantu, apa dia kepala suku lain?
Dialogue: 0,0:18:37.35,0:18:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seperti Kepala Agung\Nyang memimpin berbagai kepala suku.
Dialogue: 0,0:18:40.85,0:18:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:42.06,0:18:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kita harus menunjukkan\Nrasa hormat setinggi-tingginya.
Dialogue: 0,0:18:45.52,0:18:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menghormati siapa pun\Nyang memimpin suatu suku.
Dialogue: 0,0:18:51.11,0:18:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Agung.
Dialogue: 0,0:18:52.61,0:18:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Ladavesta, kepala suku Lada.
Dialogue: 0,0:18:56.87,0:19:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Dino En Tsora Bellrinet,\Nraja dari kerajaan ini.
Dialogue: 0,0:19:01.77,0:19:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bisa bertemu denganmu, Ladavesta.
Dialogue: 0,0:19:04.87,0:19:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga.
Dialogue: 0,0:19:07.58,0:19:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tanda pertemanan,\Nterimalah oleh-oleh ini.
Dialogue: 0,0:19:11.88,0:19:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan itu...
Dialogue: 0,0:19:13.88,0:19:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orichalcum?
Dialogue: 0,0:19:15.63,0:19:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logam legendaris yang dijuluki\Nsebagai logam para dewa!
Dialogue: 0,0:19:19.26,0:19:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka bisa menjumpai\Nbarang selangka ini.
Dialogue: 0,0:19:22.02,0:19:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membuat pedang dari Orichalcum ini,
Dialogue: 0,0:19:24.27,0:19:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}butuh biaya lebih dari seratus koin platinum!
Dialogue: 0,0:19:27.52,0:19:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa memusingkan uang?
Dialogue: 0,0:19:30.27,0:19:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya pasti akan jadi harta nasional.
Dialogue: 0,0:19:32.73,0:19:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru, jangan batasi penggunaan uangnya!
Dialogue: 0,0:19:37.07,0:19:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya cukup bagus.
Dialogue: 0,0:19:38.66,0:19:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:19:42.12,0:19:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, ya?
Dialogue: 0,0:19:43.37,0:19:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku melihatmu membuat\Npedang dari Orichalcum.
Dialogue: 0,0:19:47.29,0:19:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baron, sudah kubilang dilarang berbohong, kan?
Dialogue: 0,0:19:52.30,0:19:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru saja membuat pedang, kan?
Dialogue: 0,0:19:54.55,0:19:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti maksudmu.
Dialogue: 0,0:19:58.18,0:20:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda, katakan yang sebenarnya.
Dialogue: 0,0:20:01.18,0:20:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan saja permintaanmu.
Dialogue: 0,0:20:03.27,0:20:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji akan memberi bayaran\Nyang pantas atas kejujuranmu.
Dialogue: 0,0:20:07.19,0:20:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tolong beri aku\Nhak tinggal permanen di desa ini.
Dialogue: 0,0:20:11.22,0:20:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjanjilah tidak akan memindahkanku\Nke wilayah lain apa pun yang terjadi.
Dialogue: 0,0:20:15.48,0:20:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:20:16.82,0:20:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:17.78,0:20:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pindah ke ibu kota,\Nkamu akan kuperlakukan istimewa.
Dialogue: 0,0:20:22.08,0:20:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku meninggalkan tempat ini,\Nsiapa yang akan melindungi rakyatnya?
Dialogue: 0,0:20:26.41,0:20:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain sandang, pangan, dan papan.
Dialogue: 0,0:20:28.75,0:20:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk harus dijamin tinggal dengan damai.
Dialogue: 0,0:20:32.00,0:20:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah tugas seorang tuan tanah.
Dialogue: 0,0:20:34.11,0:20:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, sudah tugasku\Nuntuk memakmurkan tanah ini.
Dialogue: 0,0:20:42.47,0:20:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:43.47,0:20:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, sangat disayangkan\Nkalau membiarkan kemampuanmu.
Dialogue: 0,0:20:46.89,0:20:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tanpa harus ke ibu kota,
Dialogue: 0,0:20:49.14,0:20:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kukirim utusan,\Nkamu bersedia bekerja sama, kan?
Dialogue: 0,0:20:52.73,0:20:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, Yang Mulia.
Dialogue: 0,0:20:54.73,0:20:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama memungkinkan,\Naku pasti melakukannya.
Dialogue: 0,0:21:01.24,0:21:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali aku tidak akan terkejut.
Dialogue: 0,0:21:03.53,0:21:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu sudah tidak\Nkuanggap anak-anak lagi.
Dialogue: 0,0:21:07.22,0:21:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya, aku tidak harus pergi ke ibu kota.
Dialogue: 0,0:21:10.54,0:21:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuat tempat ini makin nyaman\Nagar bisa tinggal dengan tenang dan bebas.
Dialogue: 0,0:21:15.00,0:21:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup rebahan!
Dialogue: 0,0:21:18.88,0:21:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, aku tidak bisa\Nmeninggalkan ibu kota lama-lama.
Dialogue: 0,0:21:24.03,0:21:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kita langsung periksa dungeon-nya?
Dialogue: 0,0:21:26.68,0:21:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pergi sekarang,\Nmatahari bisa keburu terbenam.
Dialogue: 0,0:21:30.81,0:21:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya lain hari saja.
Dialogue: 0,0:21:32.94,0:21:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sikapmu padaku\Nsudah makin santai, ya.
Dialogue: 0,0:21:37.98,0:21:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak, kok.
Dialogue: 0,0:21:40.44,0:21:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:21:42.45,0:21:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, ada naga!
Dialogue: 0,0:21:45.74,0:21:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, bersiap untuk bertahan!
Dialogue: 0,0:21:47.41,0:21:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil juga para petualang!
Dialogue: 0,0:21:49.58,0:21:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:21:50.85,0:21:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda, butuh bantuan?
Dialogue: 0,0:21:52.75,0:21:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mohon bantuannya.
Dialogue: 0,0:21:55.63,0:21:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana naganya?
Dialogue: 0,0:21:56.59,0:21:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu!
