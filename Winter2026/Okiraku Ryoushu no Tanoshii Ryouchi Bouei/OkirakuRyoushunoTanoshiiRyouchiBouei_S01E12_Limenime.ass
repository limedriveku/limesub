Dialogue: 0,0:00:45.40,0:00:47.44,tanda,,0000,0000,0000,,PERTAHANAN WILAYAH SERU\NOLEH TUAN TANAH SANTAI
Dialogue: 0,0:00:47.44,0:00:50.53,tanda,,0000,0000,0000,,MEMBUAT DESA TANPA NAMA MENJADI KOTA\NBENTENG TERKUAT DENGAN SIHIR PRODUKSI
Dialogue: 0,0:00:50.53,0:00:53.12,tanda,,0000,0000,0000,,EPISODE 12: PERTAHANAN WILAYAH YANG SERU\NDAN TUAN TANAH YANG SANTAI
Dialogue: 0,0:02:05.98,0:02:09.11,tanda,,0000,0000,0000,,EPISODE 12: PERTAHANAN WILAYAH YANG SERU
Dialogue: 0,0:02:09.11,0:02:14.24,tanda,,0000,0000,0000,,DAN TUAN TANAH YANG SANTAI
Dialogue: 0,0:05:40.53,0:05:45.02,tanda,,0000,0000,0000,,SHARAN TORA FERDINATTO
Dialogue: 0,0:00:09.99,0:00:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:00:14.74,0:00:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halaman Nona Arut...
Dialogue: 0,0:00:21.13,0:00:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak.
Dialogue: 0,0:00:31.51,0:00:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:02:05.98,0:02:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, menurut komandan itu,
Dialogue: 0,0:02:09.11,0:02:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yelenetta
Dialogue: 0,0:02:10.82,0:02:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berencana menyerang dari tiga titik.
Dialogue: 0,0:02:14.57,0:02:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua di antaranya,\Nadalah Desa Seatoh dan Scudet.
Dialogue: 0,0:02:18.92,0:02:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang terakhir adalah...
Dialogue: 0,0:02:22.29,0:02:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah Count Ferdinatto.
Dialogue: 0,0:02:29.09,0:02:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halaman Arut.
Dialogue: 0,0:02:33.59,0:02:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van.
Dialogue: 0,0:02:36.51,0:02:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku pergi ke wilayah Count.
Dialogue: 0,0:02:39.72,0:02:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku ikut.
Dialogue: 0,0:02:41.31,0:02:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan.
Dialogue: 0,0:02:43.35,0:02:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa terus bergantung\Npada Tuan Van.
Dialogue: 0,0:02:46.40,0:02:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku juga terlibat perang.
Dialogue: 0,0:02:51.15,0:02:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masalah keluargaku.
Dialogue: 0,0:02:55.15,0:02:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini Arut sekeras kepala ini.
Dialogue: 0,0:03:07.38,0:03:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:03:10.42,0:03:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Tuan Van sangat mengkhawatirkanku.
Dialogue: 0,0:03:14.63,0:03:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku...
Dialogue: 0,0:03:16.72,0:03:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:03:18.22,0:03:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku yang menyelamatkan\Nwilayah Count Ferdinatto...
Dialogue: 0,0:03:23.18,0:03:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya tuan tanah\Ndesa perbatasan yang kecil.
Dialogue: 0,0:03:26.59,0:03:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diselamatkan olehmu...
Dialogue: 0,0:03:30.19,0:03:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reputasi Count Ferdinatto akan anjlok,
Dialogue: 0,0:03:32.69,0:03:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan wilayahnya akan dikurangi.
Dialogue: 0,0:03:37.24,0:03:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti tidak ada pilihan lain.
Dialogue: 0,0:03:39.47,0:03:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, bolehkah kamu\Nkuberi pengawal?
Dialogue: 0,0:03:43.41,0:03:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:03:44.51,0:03:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kemurahan hatimu.
Dialogue: 0,0:03:47.17,0:03:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, serahkan pada kami.
Dialogue: 0,0:03:50.21,0:03:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan pengawalan kami, semua pasti aman.
Dialogue: 0,0:03:54.09,0:03:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan melindungi calon istri Tuan.
Dialogue: 0,0:03:58.22,0:03:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ortho.
Dialogue: 0,0:03:59.70,0:04:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xara dan Purriel juga.
Dialogue: 0,0:04:02.93,0:04:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, kami cuma ingin membantu Tuan Van.
Dialogue: 0,0:04:06.00,0:04:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, keterlibatan petualang seperti kami
Dialogue: 0,0:04:09.81,0:04:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya tidak jadi masalah.
Dialogue: 0,0:04:13.82,0:04:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:04:15.14,0:04:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tolong jaga Arut.
Dialogue: 0,0:04:29.08,0:04:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:04:32.25,0:04:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona!
Dialogue: 0,0:04:40.05,0:04:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuhkan bola hitamnya!
Dialogue: 0,0:04:52.61,0:04:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Arut, kalau turun sekarang,\Nkita mungkin bisa melakukan sesuatu.
Dialogue: 0,0:04:57.61,0:05:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri aku wewenang memimpin pasukan ini.
Dialogue: 0,0:05:06.54,0:05:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:05:08.29,0:05:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berhak mengusir Kerajaan Yelenetta
Dialogue: 0,0:05:10.71,0:05:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya keluarga Count Ferdinatto.
Dialogue: 0,0:05:13.67,0:05:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana cara menghalau\Npasukan sebesar itu?
Dialogue: 0,0:05:24.18,0:05:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:05:26.76,0:05:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh mengerikan.
Dialogue: 0,0:05:29.06,0:05:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka pasukan Yelenetta\Nakan menyerang kita.
Dialogue: 0,0:05:35.11,0:05:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:05:37.82,0:05:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menangis.
Dialogue: 0,0:05:40.53,0:05:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat terakhir nanti,
Dialogue: 0,0:05:42.11,0:05:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kubuat seolah kamu bunuh diri.
Dialogue: 0,0:05:45.02,0:05:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai putri sulung,
Dialogue: 0,0:05:46.66,0:05:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu akan dikenang sebagai\Nbangsawan yang gugur mulia.
Dialogue: 0,0:05:52.54,0:05:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:05:57.00,0:05:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:05:59.88,0:06:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:06:02.84,0:06:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut?
Dialogue: 0,0:06:05.89,0:06:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah Count Ferdinatto\Nbukan tandingan kita!
Dialogue: 0,0:06:11.02,0:06:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo serang dan taklukkan!
Dialogue: 0,0:06:19.32,0:06:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemenangan di tangan kita.
Dialogue: 0,0:06:30.58,0:06:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:06:32.12,0:06:35.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang kesatria perak\Nmenyerang para wyvern!
Dialogue: 0,0:06:35.88,0:06:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria perak?
Dialogue: 0,0:06:58.23,0:07:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin!
Dialogue: 0,0:07:00.32,0:07:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern sebanyak itu tumbang dalam sekejap?
Dialogue: 0,0:07:04.15,0:07:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:07:06.41,0:07:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan, gawat!
Dialogue: 0,0:07:08.40,0:07:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas bukit ada bendera keluarga Ferdinatto!
Dialogue: 0,0:07:15.83,0:07:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar! Scuderia sialan!
Dialogue: 0,0:07:18.17,0:07:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengirim bala bantuan.
Dialogue: 0,0:07:20.13,0:07:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ubah target ke pasukan di atas bukit!
Dialogue: 0,0:07:22.92,0:07:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang dengan seluruh pasukan!
Dialogue: 0,0:07:25.09,0:07:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan kesatria perak itu?
Dialogue: 0,0:07:27.47,0:07:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pasukan utamanya hancur,\Ndia tidak akan berkutik.
Dialogue: 0,0:07:30.85,0:07:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan mereka sekaligus!
Dialogue: 0,0:07:37.10,0:07:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh mendatangi kita lebih dahulu.
Dialogue: 0,0:07:41.44,0:07:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tidak sehebat Tuan Van.
Dialogue: 0,0:07:45.09,0:07:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmu bertempurku pun minim.
Dialogue: 0,0:07:47.70,0:07:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan tangan ini terus gemetar.
Dialogue: 0,0:07:53.45,0:07:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, aku harus berusaha sebisa mungkin.
Dialogue: 0,0:07:59.65,0:08:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ortho.
Dialogue: 0,0:08:01.63,0:08:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:03.38,0:08:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bisakah kalian membantuku?
Dialogue: 0,0:08:07.47,0:08:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu saja.
Dialogue: 0,0:08:11.72,0:08:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya,
Dialogue: 0,0:08:13.47,0:08:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong pinjamkan kekuatan kalian.
Dialogue: 0,0:08:16.52,0:08:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:08:18.19,0:08:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamatkan kampung halamanku!
Dialogue: 0,0:08:23.82,0:08:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, tolong pinjamkan kekuatan kalian.
Dialogue: 0,0:08:27.73,0:08:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:08:29.18,0:08:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamatkan kampung halamanku!
Dialogue: 0,0:08:33.28,0:08:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencana Nona Arut?
Dialogue: 0,0:08:37.03,0:08:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:08:41.00,0:08:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan turun ke garis depan!
Dialogue: 0,0:08:43.66,0:08:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Arut!
Dialogue: 0,0:08:45.59,0:08:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Automaton, Uno!
Dialogue: 0,0:08:49.84,0:08:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang!
Dialogue: 0,0:08:57.68,0:08:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:08:58.81,0:09:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan gila macam apa itu?
Dialogue: 0,0:09:03.36,0:09:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita maju juga!
Dialogue: 0,0:09:15.45,0:09:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak!
Dialogue: 0,0:09:18.66,0:09:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Tidak bisa bergerak!
Dialogue: 0,0:09:21.79,0:09:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliranku.
Dialogue: 0,0:09:26.34,0:09:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepele.
Dialogue: 0,0:09:28.05,0:09:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar, beraninya menyerang rekan kami!
Dialogue: 0,0:09:32.68,0:09:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xara!
Dialogue: 0,0:09:35.10,0:09:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah!
Dialogue: 0,0:09:42.85,0:09:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangannya...
Dialogue: 0,0:09:47.94,0:09:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih bisa bergerak?
Dialogue: 0,0:09:58.08,0:09:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selamat.
Dialogue: 0,0:09:59.76,0:10:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Nona Arut.
Dialogue: 0,0:10:33.11,0:10:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:10:34.57,0:10:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area ini berhasil diamankan.
Dialogue: 0,0:10:37.37,0:10:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya selesai juga.
Dialogue: 0,0:10:39.62,0:10:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan repot, ya.
Dialogue: 0,0:10:41.75,0:10:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum!
Dialogue: 0,0:10:48.54,0:10:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:50.75,0:10:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:10:52.59,0:10:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern-nya sebanyak itu?
Dialogue: 0,0:10:54.72,0:10:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar 50 ekor.
Dialogue: 0,0:10:58.55,0:11:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk berjaga-jaga,\Naku sudah siapkan bala bantuan.
Dialogue: 0,0:11:03.39,0:11:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, para wyvern!
Dialogue: 0,0:11:05.23,0:11:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan kesatria perak itu!
Dialogue: 0,0:11:09.77,0:11:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, kalau begini...
Dialogue: 0,0:11:17.16,0:11:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya!
Dialogue: 0,0:11:23.16,0:11:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa itu?
Dialogue: 0,0:11:24.62,0:11:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka Nona Arut ada satu lagi?
Dialogue: 0,0:11:28.58,0:11:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:11:29.84,0:11:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengendalikan dua sekaligus?
Dialogue: 0,0:11:35.30,0:11:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sihirku tidak akan bertahan lama.
Dialogue: 0,0:11:40.14,0:11:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan beri mereka celah!
Dialogue: 0,0:11:46.69,0:11:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terlalu banyak.
Dialogue: 0,0:11:53.40,0:11:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan musuh!
Dialogue: 0,0:11:55.36,0:11:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aventador!
Dialogue: 0,0:12:05.12,0:12:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, aku selalu menganggap\Ndiriku tidak berguna.
Dialogue: 0,0:12:11.34,0:12:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski seorang bangsawan,
Dialogue: 0,0:12:13.09,0:12:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atributku adalah sihir boneka.
Dialogue: 0,0:12:22.01,0:12:25.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang dibenci dan dijauhi orang-orang.
Dialogue: 0,0:12:25.82,0:12:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan bersumpah tidak akan memakainya\Ndi depan umum.
Dialogue: 0,0:12:32.70,0:12:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van telah menyelamatkanku\Ndari keterpurukan itu.
Dialogue: 0,0:12:40.41,0:12:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kehadiran Tuan Van,
Dialogue: 0,0:12:42.37,0:12:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa mendapat kepercayaan diri.
Dialogue: 0,0:12:53.46,0:12:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuat sekali.
Dialogue: 0,0:12:55.49,0:12:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari separuhnya lenyap dalam sekejap.
Dialogue: 0,0:12:58.85,0:13:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:13:02.01,0:13:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?
Dialogue: 0,0:13:03.93,0:13:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan mereka!
Dialogue: 0,0:13:12.60,0:13:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:13:19.53,0:13:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyelamatkan orang\Nyang kusayangi dengan sihir ini!
Dialogue: 0,0:13:32.25,0:13:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal yang terakhir!
Dialogue: 0,0:13:42.28,0:13:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin!
Dialogue: 0,0:13:44.80,0:13:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasukan Yelenetta kami...
Dialogue: 0,0:13:48.31,0:13:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau kabur saja!
Dialogue: 0,0:13:49.81,0:13:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu kuat!
Dialogue: 0,0:13:50.85,0:13:52.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil bisa menang!
Dialogue: 0,0:13:53.60,0:13:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:13:54.65,0:13:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita menang!
Dialogue: 0,0:14:12.66,0:14:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat boneka buatan Tuan Van,\Naku bisa menang.
Dialogue: 0,0:14:19.82,0:14:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu bertarung\Nsampai hancur begini.
Dialogue: 0,0:14:25.52,0:14:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih telah menyelamatkan\Nkampung halamanku.
Dialogue: 0,0:14:36.90,0:14:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, siapa yang datang\Nmenyelamatkan kita?
Dialogue: 0,0:14:41.07,0:14:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata kalian di sini.
Dialogue: 0,0:14:45.41,0:14:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang?
Dialogue: 0,0:14:47.14,0:14:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku datang terlambat.
Dialogue: 0,0:14:49.03,0:14:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian selamat.
Dialogue: 0,0:14:50.79,0:14:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tahu tentang bala bantuan yang datang?
Dialogue: 0,0:14:56.11,0:14:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:57.75,0:14:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh yang kutahu,
Dialogue: 0,0:14:59.63,0:15:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya dengan dua boneka, mereka berhasil\Nmemukul mundur pasukan Yelenetta.
Dialogue: 0,0:15:05.88,0:15:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:15:07.51,0:15:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memimpin bala bantuan tersebut
Dialogue: 0,0:15:10.47,0:15:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah gadis kecil berambut putih.
Dialogue: 0,0:15:14.06,0:15:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:15:15.89,0:15:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:17.56,0:15:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:15:19.65,0:15:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:15:21.82,0:15:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh ironis.
Dialogue: 0,0:15:24.32,0:15:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita yang mengusirnya dari rumah ini.
Dialogue: 0,0:15:29.87,0:15:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah berbuat jahat padanya.
Dialogue: 0,0:15:46.47,0:15:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin tidak mau pulang?
Dialogue: 0,0:15:48.76,0:15:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung orang tua Nona ada di sini.
Dialogue: 0,0:15:51.70,0:15:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepulanganku hanya akan\Nmenimbulkan masalah.
Dialogue: 0,0:15:55.98,0:16:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kota ini selamat berkat boneka itu.
Dialogue: 0,0:16:00.48,0:16:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu Nona Arut yang mengendalikannya,
Dialogue: 0,0:16:03.15,0:16:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rakyat pasti sangat bangga.
Dialogue: 0,0:16:05.15,0:16:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tua Nona pun sama.
Dialogue: 0,0:16:06.32,0:16:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:16:09.41,0:16:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sangat membenci sihir bonekaku ini.
Dialogue: 0,0:16:16.12,0:16:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang, Tuan Van sudah menunggu.
Dialogue: 0,0:16:29.26,0:16:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Arut telah kembali!
Dialogue: 0,0:16:35.56,0:16:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut, apa kamu terluka?
Dialogue: 0,0:16:41.56,0:16:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:43.48,0:16:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berguna.
Dialogue: 0,0:16:46.11,0:16:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu berpikir begitu?
Dialogue: 0,0:16:48.69,0:16:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:16:50.78,0:16:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sepercaya diri Tuan Van\Nyang bisa memerintah semua orang.
Dialogue: 0,0:16:56.91,0:17:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, kamu sudah cukup hebat, kok.
Dialogue: 0,0:17:02.96,0:17:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah tidak paham\Nkenapa kamu tidak percaya diri.
Dialogue: 0,0:17:06.93,0:17:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menggerakkan boneka dengan bebas saja\Nsudah luar biasa.
Dialogue: 0,0:17:12.33,0:17:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:13.51,0:17:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera pernah bilang, lo.
Dialogue: 0,0:17:16.31,0:17:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raut wajahmu jauh lebih baik\Ndaripada saat di wilayah Count.
Dialogue: 0,0:17:21.61,0:17:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, Tuan Van sangat baik.
Dialogue: 0,0:17:29.28,0:17:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut.
Dialogue: 0,0:17:33.87,0:17:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berjuang keras.
Dialogue: 0,0:17:55.47,0:17:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arut.
Dialogue: 0,0:17:58.77,0:18:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali.
Dialogue: 0,0:18:06.48,0:18:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:19:48.88,0:19:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng!
Dialogue: 0,0:19:49.92,0:19:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membangun toko\Ndan penginapan baru di pusat desa.
Dialogue: 0,0:19:55.34,0:19:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, bagus sekali!
Dialogue: 0,0:19:57.88,0:19:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:58.68,0:20:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin penduduk desa\Nbisa hidup nyaman.
Dialogue: 0,0:20:06.18,0:20:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pertama datang ke sini,
Dialogue: 0,0:20:08.06,0:20:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sempat ragu bisa bertahan di tempat ini.
Dialogue: 0,0:20:12.86,0:20:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa!
Dialogue: 0,0:20:15.15,0:20:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa yang dulu sangat miskin,\Nkini jadi tempat yang indah!
Dialogue: 0,0:20:19.91,0:20:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:20:21.62,0:20:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan mampir!
Dialogue: 0,0:20:23.79,0:20:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada barang baru dari ibu kota, lo!
Dialogue: 0,0:20:27.12,0:20:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ragu untuk melihat-lihat!
Dialogue: 0,0:20:32.54,0:20:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek, jangan sampai jatuh!
Dialogue: 0,0:20:40.93,0:20:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, ya.
Dialogue: 0,0:20:43.97,0:20:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang desa ini\Npunya usia, sifat, dan ras
Dialogue: 0,0:20:47.68,0:20:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berbeda-beda.
Dialogue: 0,0:20:52.23,0:20:56.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anehnya mereka bisa akur dan terlihat bahagia.
Dialogue: 0,0:20:58.36,0:21:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:21:08.75,0:21:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging ini enak banget, ya.
Dialogue: 0,0:21:11.83,0:21:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Xara, itu dagingku!
Dialogue: 0,0:21:16.88,0:21:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah gelas ke-15, lo.
Dialogue: 0,0:21:18.98,0:21:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Panamera memang hebat.
Dialogue: 0,0:21:22.80,0:21:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terlahir sebagai bangsawan,
Dialogue: 0,0:21:24.72,0:21:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena punya atribut sihir produksi,
Dialogue: 0,0:21:28.06,0:21:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayah mengusirku untuk menjadi tuan tanah\Ndi desa terpencil.
Dialogue: 0,0:21:33.73,0:21:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat itu,
Dialogue: 0,0:21:35.27,0:21:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertemu kawan-kawan luar biasa,\Ndan bisa mengembangkan desa kecil ini.
Dialogue: 0,0:21:42.49,0:21:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang sempat kehilangan rumah,
Dialogue: 0,0:21:45.03,0:21:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kini bisa hidup bahagia dan tanpa sadar,
Dialogue: 0,0:21:48.16,0:21:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}desa ini menjadi tempat berharga bagiku.
Dialogue: 0,0:21:55.14,0:21:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, terima kasih.
Dialogue: 0,0:21:58.17,0:21:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van.
Dialogue: 0,0:22:00.72,0:22:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya belajar.
Dialogue: 0,0:22:04.09,0:22:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuat Tuan belajar dengan giat.
Dialogue: 0,0:22:08.27,0:22:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van!
Dialogue: 0,0:22:10.23,0:22:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang adalah eranya ilmu pedang!
Dialogue: 0,0:22:13.44,0:22:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulatih kamu jadi pendekar\Nnomor satu di kerajaan!
Dialogue: 0,0:22:18.82,0:22:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:22:19.78,0:22:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van akan menjadi\Ncendekiawan terkemuka di kerajaan.
Dialogue: 0,0:22:23.36,0:22:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa kubiarkan.
Dialogue: 0,0:22:27.24,0:22:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau keduanya!
Dialogue: 0,0:22:30.62,0:22:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tuan Van!
Dialogue: 0,0:22:31.96,0:22:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:22:35.50,0:22:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meriah sekali, ya.
Dialogue: 0,0:22:37.34,0:22:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, berjuanglah!
Dialogue: 0,0:22:40.34,0:22:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari sebelum tertangkap!
Dialogue: 0,0:22:44.80,0:22:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berhenti!
Dialogue: 0,0:22:46.85,0:22:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus seperti itu! Lari!
Dialogue: 0,0:22:50.81,0:22:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda, larilah lebih cepat!
Dialogue: 0,0:22:54.10,0:22:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Van, berjuanglah!
Dialogue: 0,0:23:30.76,0:23:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:23:32.02,0:23:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubangun wilayah ini agar lebih\Nmenyenangkan untuk semua orang!
