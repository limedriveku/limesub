Dialogue: 0,0:00:32.00,0:00:35.01,tanda,,0000,0000,0000,,BULAN GELAP: ALTAR BULAN
Dialogue: 0,0:08:42.00,0:08:46.01,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:08:46.01,0:08:50.01,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:20:24.95,0:20:26.91,tanda,,0000,0000,0000,,SEKOLAH KOTA SUNSHINE
Dialogue: 0,0:00:00.81,0:00:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan kalian akan segera hilang.
Dialogue: 0,0:00:05.74,0:00:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kekuatan\Nyang diberikan Tuan Putri menghilang,
Dialogue: 0,0:00:08.46,0:00:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian akan menyadari\Nbahwa kalian bukanlah apa-apa.
Dialogue: 0,0:00:16.00,0:00:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:00:44.65,0:00:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:00:55.74,0:00:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:00:57.04,0:00:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, bertahanlah!
Dialogue: 0,0:00:59.04,0:01:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:01:01.54,0:01:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengeluarkannya dari sini dulu.
Dialogue: 0,0:01:13.01,0:01:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa keluar?
Dialogue: 0,0:01:15.47,0:01:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cahaya ini
Dialogue: 0,0:01:16.98,0:01:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kekuatan kerajaan\Nyang melepaskan segelnya?
Dialogue: 0,0:01:20.31,0:01:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan itu menjebak Sooha di sini.
Dialogue: 0,0:01:23.27,0:01:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:01:27.48,0:01:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak hal\Nyang belum kukatakan padamu.
Dialogue: 0,0:01:32.56,0:01:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam itu,
Dialogue: 0,0:01:34.24,0:01:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku menggigit lehermu,
Dialogue: 0,0:01:36.37,0:01:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya aku sangat ketakutan.
Dialogue: 0,0:01:38.79,0:01:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir akan menyakitimu.
Dialogue: 0,0:01:43.04,0:01:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu juga menunjukkan
Dialogue: 0,0:01:45.63,0:01:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}betapa kamu memercayaiku.
Dialogue: 0,0:01:49.09,0:01:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu membuatku sangat bahagia.
Dialogue: 0,0:01:51.80,0:01:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sekarang,
Dialogue: 0,0:01:53.18,0:01:55.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menghargai kepercayaanmu,
Dialogue: 0,0:01:55.98,0:01:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti akan membebaskanmu.
Dialogue: 0,0:02:00.58,0:02:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:02:03.48,0:02:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha?
Dialogue: 0,0:02:06.38,0:02:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, kamu datang menyelamatkanku lagi.
Dialogue: 0,0:02:12.00,0:02:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik dulu
Dialogue: 0,0:02:13.57,0:02:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun sekarang,
Dialogue: 0,0:02:14.99,0:02:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu selalu
Dialogue: 0,0:02:19.48,0:02:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}datang menyelamatkanku.
Dialogue: 0,0:02:21.58,0:02:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:30.00,0:02:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:02:34.05,0:02:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik dulu maupun sekarang,
Dialogue: 0,0:02:36.43,0:02:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu selalu menghalangiku!
Dialogue: 0,0:02:38.55,0:02:41.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan karenamu,
Dialogue: 0,0:02:41.18,0:02:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri pasti akan memilihku!
Dialogue: 0,0:02:45.44,0:02:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli!
Dialogue: 0,0:02:46.56,0:02:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya di kehidupan ini,\Ndia akan memilihku!
Dialogue: 0,0:02:52.19,0:02:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:02:57.62,0:02:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, sadarlah.
Dialogue: 0,0:02:59.45,0:03:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, bangun.
Dialogue: 0,0:03:02.16,0:03:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kita tidak bisa keluar?
Dialogue: 0,0:03:03.79,0:03:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, bangun!
Dialogue: 0,0:03:11.42,0:03:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:03:13.41,0:03:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini benar-benar berakhir.
Dialogue: 0,0:03:17.64,0:03:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang berusaha menyelamatkanmu
Dialogue: 0,0:03:20.14,0:03:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya telah tumbang.
Dialogue: 0,0:03:23.39,0:03:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan aku masih punya\Nbanyak anak buah.
Dialogue: 0,0:03:28.40,0:03:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang kamu bagi dengan mereka\Ntelah kembali padamu.
Dialogue: 0,0:03:34.40,0:03:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,
Dialogue: 0,0:03:36.32,0:03:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua itu akan menjadi milikku.
Dialogue: 0,0:03:40.41,0:03:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengambil semuanya\Ndarimu di sini,
Dialogue: 0,0:03:43.79,0:03:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kamu hanya bisa\Nberada di sisiku selamanya.
Dialogue: 0,0:03:55.34,0:03:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan!
Dialogue: 0,0:04:05.02,0:04:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku... sudah hilang.
Dialogue: 0,0:04:08.64,0:04:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:04:10.63,0:04:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melindungimu.
Dialogue: 0,0:04:13.61,0:04:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyembuhkan luka kami.
Dialogue: 0,0:04:17.45,0:04:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pun membagi kekuatanmu dengan kami.
Dialogue: 0,0:04:21.57,0:04:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:04:23.58,0:04:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa sekarang aku tidak bisa\Nberbuat apa-apa?
Dialogue: 0,0:04:27.04,0:04:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa kekuatan yang kamu berikan,
Dialogue: 0,0:04:30.74,0:04:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa apa-apa.
Dialogue: 0,0:04:37.97,0:04:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah membuang tenaga.
Dialogue: 0,0:04:41.14,0:04:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kabur?
Dialogue: 0,0:04:42.60,0:04:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoba kabur melalui reinkarnasi lagi?
Dialogue: 0,0:04:45.52,0:04:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja.
Dialogue: 0,0:04:47.06,0:04:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama apa pun itu,
Dialogue: 0,0:04:48.85,0:04:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana pun kamu bersembunyi,
Dialogue: 0,0:04:50.31,0:04:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti akan menemukanmu.
Dialogue: 0,0:04:56.94,0:05:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu aneh?
Dialogue: 0,0:05:00.15,0:05:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu selalu dicurigai sebagai vampir?
Dialogue: 0,0:05:05.07,0:05:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa orang-orang di sekitarmu\Nselalu diserang vampir?
Dialogue: 0,0:05:10.85,0:05:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik, Sooha.
Dialogue: 0,0:05:12.67,0:05:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chris mati karenamu.
Dialogue: 0,0:05:17.67,0:05:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia orang yang paling kamu sayangi.
Dialogue: 0,0:05:22.22,0:05:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menggantikannya,
Dialogue: 0,0:05:24.18,0:05:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengatur kematiannya.
Dialogue: 0,0:05:32.48,0:05:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kamu tahu\Naku orang seperti apa, kan?
Dialogue: 0,0:05:35.27,0:05:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski berhasil kabur dari sini sekarang,
Dialogue: 0,0:05:38.15,0:05:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal yang sama akan terjadi\Ndi kehidupan berikutnya.
Dialogue: 0,0:05:43.66,0:05:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan!
Dialogue: 0,0:05:47.66,0:05:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah terlambat.
Dialogue: 0,0:05:52.54,0:05:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah menghabiskan\Nsisa kekuatanmu, kan?
Dialogue: 0,0:05:56.50,0:06:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja tidak pandai\Nmemakainya seperti dulu.
Dialogue: 0,0:06:01.05,0:06:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sama sekali tidak pantas memilikinya.
Dialogue: 0,0:06:03.88,0:06:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku akan menggantikanmu\Ndan mewarisinya.
Dialogue: 0,0:06:09.06,0:06:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin bisa lebih baik darimu.
Dialogue: 0,0:06:13.73,0:06:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidurlah.
Dialogue: 0,0:06:16.15,0:06:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyelesaikan semuanya\Nselagi kamu tertidur.
Dialogue: 0,0:06:25.93,0:06:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kehilangan kekuatanku.
Dialogue: 0,0:06:28.75,0:06:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tandanya masih bersinar?
Dialogue: 0,0:06:32.16,0:06:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena takut memberi tahu semua orang,
Dialogue: 0,0:06:35.21,0:06:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menyimpan rahasia ini.
Dialogue: 0,0:06:37.19,0:06:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ada darah vampir\Ndan manusia serigala dalam diriku.
Dialogue: 0,0:06:42.41,0:06:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah memberi tahu semuanya,
Dialogue: 0,0:06:44.93,0:06:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tetap di sisiku seperti biasa.
Dialogue: 0,0:06:49.18,0:06:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini
Dialogue: 0,0:06:50.83,0:06:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada
Dialogue: 0,0:06:52.48,0:06:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyelamatkan mereka dan Sooha.
Dialogue: 0,0:06:56.44,0:06:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kali pertama menyadari kekuatanku,
Dialogue: 0,0:06:59.72,0:07:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sama sekali tidak bahagia.
Dialogue: 0,0:07:02.07,0:07:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tidak tahu\Nuntuk apa kekuatan ini.
Dialogue: 0,0:07:07.27,0:07:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kini aku tahu kekuatan ini\Nbukan untuk menyakiti,
Dialogue: 0,0:07:10.99,0:07:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}justru melindungi orang penting.
Dialogue: 0,0:07:13.66,0:07:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa sekarang\Naku tidak bisa menggunakannya?
Dialogue: 0,0:07:17.79,0:07:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, aku bisa langsung bergerak ke sana.
Dialogue: 0,0:07:22.59,0:07:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku tidak akan bisa\Nmelakukan itu lagi?
Dialogue: 0,0:07:27.03,0:07:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menyelamatkan Sooha.
Dialogue: 0,0:07:29.10,0:07:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat genting seperti ini,
Dialogue: 0,0:07:30.88,0:07:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa melakukan apa pun.
Dialogue: 0,0:07:33.27,0:07:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, orang itu...
Dialogue: 0,0:07:36.06,0:07:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin...
Dialogue: 0,0:07:37.77,0:07:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menghajar orang
Dialogue: 0,0:07:41.02,0:07:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membuat Sooha menderita.
Dialogue: 0,0:07:44.22,0:07:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sial!
Dialogue: 0,0:07:48.99,0:07:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau
Dialogue: 0,0:07:51.26,0:07:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehilangan orang yang penting bagiku lagi.
Dialogue: 0,0:07:55.61,0:07:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seseorang yang harus kulindungi.
Dialogue: 0,0:07:58.11,0:07:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku...
Dialogue: 0,0:08:15.47,0:08:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih kecil,
Dialogue: 0,0:08:17.12,0:08:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya aku takut gelap.
Dialogue: 0,0:08:19.90,0:08:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, entah sejak kapan,
Dialogue: 0,0:08:21.98,0:08:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak takut lagi.
Dialogue: 0,0:08:30.57,0:08:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kegelapan adalah wilayahku.
Dialogue: 0,0:08:33.15,0:08:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangan adalah bagian dari diriku.
Dialogue: 0,0:08:37.12,0:08:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mencari cara\Nuntuk membantu mereka semua.
Dialogue: 0,0:08:53.47,0:08:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli!
Dialogue: 0,0:09:05.23,0:09:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja.
Dialogue: 0,0:09:08.28,0:09:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir berhasil!
Dialogue: 0,0:09:13.87,0:09:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, kamu baik-baik saja?
Dialogue: 0,0:09:15.37,0:09:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli!
Dialogue: 0,0:09:17.48,0:09:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noa, kenapa kamu masih bisa\Nmenggunakan kekuatanmu?
Dialogue: 0,0:09:20.92,0:09:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri tidak tahu.
Dialogue: 0,0:09:23.32,0:09:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku tak bisa menggunakannya lagi.
Dialogue: 0,0:09:25.71,0:09:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi entah kenapa,
Dialogue: 0,0:09:27.03,0:09:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba aku merasa,\Nselama ini aku memang memilikinya.
Dialogue: 0,0:09:32.62,0:09:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:34.33,0:09:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jelas merasakannya.
Dialogue: 0,0:09:36.06,0:09:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan kekuatan\Nyang Sooha bagikan pada kita.
Dialogue: 0,0:09:40.02,0:09:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:09:41.39,0:09:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marge pernah bilang
Dialogue: 0,0:09:43.55,0:09:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita adalah bangsawan vampir.
Dialogue: 0,0:09:46.94,0:09:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena lambangnya belum menghilang,
Dialogue: 0,0:09:49.32,0:09:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya kekuatan yang membangkitkan kita\Nsetelah menjadi bangsawan vampir
Dialogue: 0,0:09:52.99,0:09:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum menghilang.
Dialogue: 0,0:09:54.85,0:09:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti melupakan\Nkekuatan kita yang sebenarnya.
Dialogue: 0,0:09:59.91,0:10:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:01.77,0:10:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-Teman, cepat ingat.
Dialogue: 0,0:10:06.38,0:10:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli?
Dialogue: 0,0:10:09.88,0:10:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Heli kembali.
Dialogue: 0,0:10:12.76,0:10:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, dengarkan aku.
Dialogue: 0,0:10:14.97,0:10:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, kekuatan ini adalah milik kita.
Dialogue: 0,0:10:18.81,0:10:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, cepat ingat!
Dialogue: 0,0:10:34.24,0:10:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang akulah rajanya!
Dialogue: 0,0:10:39.95,0:10:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion!
Dialogue: 0,0:10:40.83,0:10:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai lolos!
Dialogue: 0,0:10:43.29,0:10:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan saling bunuh!
Dialogue: 0,0:10:52.01,0:10:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marge, kamu baik-baik saja?
Dialogue: 0,0:10:54.01,0:10:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja, terima kasih.
Dialogue: 0,0:10:56.76,0:10:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:10:57.76,0:10:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menghabisimu dengan ini!
Dialogue: 0,0:11:04.52,0:11:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kekuatan mereka kembali?
Dialogue: 0,0:11:07.73,0:11:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar manusia serigala payah!
Dialogue: 0,0:11:24.52,0:11:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup.
Dialogue: 0,0:11:29.88,0:11:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak.
Dialogue: 0,0:11:37.38,0:11:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengakhiri ini sekarang.
Dialogue: 0,0:11:48.02,0:11:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan!
Dialogue: 0,0:11:57.15,0:12:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menginginkan apa pun lagi.
Dialogue: 0,0:12:00.07,0:12:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik kekuatan Tuan Putri
Dialogue: 0,0:12:02.08,0:12:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun Tuan Putri sendiri.
Dialogue: 0,0:12:04.83,0:12:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak bisa hidup\Nbersama Tuan Putri,
Dialogue: 0,0:12:09.42,0:12:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mati di sini bersamanya
Dialogue: 0,0:12:11.59,0:12:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin tak terlalu buruk.
Dialogue: 0,0:12:19.01,0:12:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:12:20.51,0:12:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:12:44.37,0:12:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:12:46.58,0:12:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, pada akhirnya,\Naku ingin berada di sisimu.
Dialogue: 0,0:12:52.44,0:12:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, sebelum ini,
Dialogue: 0,0:12:58.26,0:13:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menghabisimu lebih dulu.
Dialogue: 0,0:13:28.64,0:13:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, kenapa lagi-lagi...
Dialogue: 0,0:13:37.99,0:13:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha...
Dialogue: 0,0:13:43.24,0:13:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:13:45.01,0:13:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti waktu itu,
Dialogue: 0,0:13:47.81,0:13:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bereinkarnasilah dan temui kami lagi.
Dialogue: 0,0:13:51.64,0:13:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli butuh ribuan\Natau puluhan ribu tahun,
Dialogue: 0,0:13:54.65,0:13:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menemukanmu.
Dialogue: 0,0:13:56.99,0:13:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menemukanmu.
Dialogue: 0,0:14:01.24,0:14:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, maafkan aku.
Dialogue: 0,0:14:05.18,0:14:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bereinkarnasi lagi.
Dialogue: 0,0:14:08.83,0:14:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kehidupan terakhirku.
Dialogue: 0,0:14:15.46,0:14:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di...
Dialogue: 0,0:14:17.82,0:14:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kehidupan ini,
Dialogue: 0,0:14:20.05,0:14:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih bisa bertemu kalian semua,
Dialogue: 0,0:14:23.55,0:14:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi teman,
Dialogue: 0,0:14:26.43,0:14:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghabiskan waktu di sekolah
Dialogue: 0,0:14:29.67,0:14:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku sangat bahagia.
Dialogue: 0,0:14:33.13,0:14:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku puas.
Dialogue: 0,0:14:40.03,0:14:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini kesempatan terakhirku,
Dialogue: 0,0:14:42.18,0:14:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak ingin menyembunyikan\Napa pun lagi.
Dialogue: 0,0:14:47.14,0:14:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, aku mencintaimu.
Dialogue: 0,0:14:52.69,0:14:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mencintaimu.
Dialogue: 0,0:14:59.82,0:15:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:15:02.21,0:15:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah sekarang atau di masa lalu,
Dialogue: 0,0:15:04.22,0:15:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu kesatria terbaik yang pernah kutemui.
Dialogue: 0,0:15:12.00,0:15:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:15:13.81,0:15:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan selalu menjadi\Nkesatria pribadimu.
Dialogue: 0,0:16:03.98,0:16:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini kekuatan Tuan Putri?
Dialogue: 0,0:16:08.70,0:16:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bisa mengendalikannya!
Dialogue: 0,0:16:15.66,0:16:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:16:19.27,0:16:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan.
Dialogue: 0,0:16:20.67,0:16:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena semua kekuatan\Ntelah kembali padaku,
Dialogue: 0,0:16:23.55,0:16:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa memaafkanmu.
Dialogue: 0,0:16:26.97,0:16:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu telah melakukan\Nterlalu banyak kejahatan.
Dialogue: 0,0:16:32.26,0:16:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:16:33.97,0:16:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menginginkan cintamu.
Dialogue: 0,0:16:41.42,0:16:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pria dengan asal-usul sederhana,
Dialogue: 0,0:16:43.61,0:16:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bekerja sangat keras\Nuntuk menjadi Kanselir.
Dialogue: 0,0:16:45.94,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu sekeras apa usahaku.
Dialogue: 0,0:16:48.03,0:16:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang kulakukan sampai sekarang
Dialogue: 0,0:16:49.74,0:16:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya untuk meraih cintamu.
Dialogue: 0,0:16:53.28,0:16:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin kamu mencintaiku!
Dialogue: 0,0:16:56.83,0:17:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan karena itu,\Nuntuk apa aku melakukan semua ini?
Dialogue: 0,0:17:02.82,0:17:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang?
Dialogue: 0,0:17:04.85,0:17:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya mereka yang mengabdikan\Nhidupnya bagi rakyat kerajaan
Dialogue: 0,0:17:09.30,0:17:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dapat mewarisi kekuatan kerajaan.
Dialogue: 0,0:17:13.50,0:17:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertimu yang mencoba\Nmengambilnya secara paksa
Dialogue: 0,0:17:18.02,0:17:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan pernah bisa memilikinya.
Dialogue: 0,0:17:21.09,0:17:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pula dengan cinta.
Dialogue: 0,0:17:23.77,0:17:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama mengetahuinya.
Dialogue: 0,0:17:26.28,0:17:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta tidak pernah berjalan\Nsesuai keinginan seseorang.
Dialogue: 0,0:17:30.89,0:17:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal,
Dialogue: 0,0:17:32.41,0:17:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tahu aku tidak ada di hatimu.
Dialogue: 0,0:17:36.10,0:17:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru karena aku\Nmelihatnya terlalu jelas,
Dialogue: 0,0:17:39.45,0:17:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memakai statusku sebagai alasan\Nuntuk lari dari kenyataan.
Dialogue: 0,0:17:43.13,0:17:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku sudah memahaminya selama ini,
Dialogue: 0,0:17:45.71,0:17:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekeras apa pun usahaku,
Dialogue: 0,0:17:47.92,0:17:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap tak bisa\Nmengubah perasaanku padamu.
Dialogue: 0,0:17:55.43,0:17:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selen.
Dialogue: 0,0:17:57.84,0:18:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, kamu akan selalu menjadi...
Dialogue: 0,0:18:40.68,0:18:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri.
Dialogue: 0,0:18:42.38,0:18:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sekarang Anda adalah Yang Mulia Ratu.
Dialogue: 0,0:18:45.56,0:18:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Ratu?
Dialogue: 0,0:18:47.58,0:18:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil saja aku Sooha.
Dialogue: 0,0:18:49.40,0:18:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:50.32,0:18:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku berterima kasih sekali lagi.
Dialogue: 0,0:18:53.74,0:18:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menemukan mereka.
Dialogue: 0,0:18:56.89,0:18:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya melakukan yang seharusnya.
Dialogue: 0,0:18:59.95,0:19:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, terima kasih\Nsudah datang menyelamatkanku.
Dialogue: 0,0:19:10.96,0:19:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang akan\NAnda lakukan sekarang?
Dialogue: 0,0:19:15.58,0:19:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Kerajaan dan Dardan lenyap,
Dialogue: 0,0:19:20.00,0:19:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin fokus pada hidupku sekarang.
Dialogue: 0,0:19:27.06,0:19:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya kabar baik.
Dialogue: 0,0:19:29.56,0:19:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kamar kosong di asrama baru.
Dialogue: 0,0:19:31.48,0:19:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa pindah ke sana.
Dialogue: 0,0:19:33.94,0:19:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:19:35.68,0:19:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:37.68,0:19:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sulit tinggal di kamar tua itu.
Dialogue: 0,0:19:40.91,0:19:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan punya teman sekamar\Ndi asrama baru.
Dialogue: 0,0:19:43.54,0:19:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berteman yang akur, ya.
Dialogue: 0,0:19:44.83,0:19:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman sekamar?
Dialogue: 0,0:19:50.21,0:19:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:19:51.84,0:19:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:19:54.97,0:19:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kuat sekali.
Dialogue: 0,0:19:58.28,0:20:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin\Nmembersihkan kolong ranjang.
Dialogue: 0,0:20:02.06,0:20:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami bantu.
Dialogue: 0,0:20:03.27,0:20:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:20:04.77,0:20:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, sekrup di ranjang ini...
Dialogue: 0,0:20:06.69,0:20:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:20:09.09,0:20:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:20:10.31,0:20:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua juga di sini!
Dialogue: 0,0:20:11.48,0:20:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:20:12.40,0:20:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami datang untuk membantu.
Dialogue: 0,0:20:13.69,0:20:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang ke sini.
Dialogue: 0,0:20:16.24,0:20:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kami tidak butuh banyak bantuan.
Dialogue: 0,0:20:18.36,0:20:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau minum teh bersama?
Dialogue: 0,0:20:20.45,0:20:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, mari kita buat teh.
Dialogue: 0,0:20:22.12,0:20:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati akan kami terima.
Dialogue: 0,0:20:26.91,0:20:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan, selamat ulang tahun!
Dialogue: 0,0:20:29.46,0:20:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiahmu.
Dialogue: 0,0:20:30.58,0:20:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:31.59,0:20:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, kamu datang!
Dialogue: 0,0:20:34.09,0:20:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kita seru-seruan, yuk!
Dialogue: 0,0:20:37.42,0:20:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang seru?
Dialogue: 0,0:20:39.18,0:20:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bosan begitu masuk.
Dialogue: 0,0:20:42.22,0:20:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, diam di sini hanya membuang waktu.
Dialogue: 0,0:20:45.14,0:20:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang!
Dialogue: 0,0:20:46.14,0:20:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya mengundang Sooha!
Dialogue: 0,0:20:48.52,0:20:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian juga di sini?
Dialogue: 0,0:20:50.65,0:20:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kalian juga merusak\Npesta ulang tahun kami?
Dialogue: 0,0:20:54.11,0:20:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tinggalkan hadiahnya\Ndan pergi, sana!
Dialogue: 0,0:20:56.03,0:20:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya terang-terangan\Nminta hadiah?
Dialogue: 0,0:20:58.03,0:21:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dengan begini, Kak Khan akan senang!\N- Hei, sudah!
Dialogue: 0,0:21:00.20,0:21:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengundangku\Nke pestamu hari ini.
Dialogue: 0,0:21:02.78,0:21:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kamu bisa datang.
Dialogue: 0,0:21:06.02,0:21:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hubunganmu dengan Heli?
Dialogue: 0,0:21:12.78,0:21:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, aku juga pernah bilang.
Dialogue: 0,0:21:15.38,0:21:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia serigala selalu suka orang pertama\Nyang ditemui saat gerhana bulan.
Dialogue: 0,0:21:20.63,0:21:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku juga akan selalu mencintaimu.
Dialogue: 0,0:21:26.93,0:21:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukan itu alasanku menyukaimu.
Dialogue: 0,0:21:29.38,0:21:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyukaimu sebelum malam itu.
Dialogue: 0,0:21:31.77,0:21:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku senang\Nbertemu denganmu malam itu.
Dialogue: 0,0:21:35.98,0:21:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbahagialah.
Dialogue: 0,0:21:38.43,0:21:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu harapan terbesarku.
Dialogue: 0,0:21:44.77,0:21:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Khan.
Dialogue: 0,0:21:46.28,0:21:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti Nona Sooha.
Dialogue: 0,0:21:48.54,0:21:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Luka.\NSuatu kehormatan bertemu denganmu.
Dialogue: 0,0:21:54.88,0:21:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya saudaraku membuat masalah lagi.
Dialogue: 0,0:21:57.05,0:21:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku saudara kembarnya, Louis.
Dialogue: 0,0:21:59.51,0:22:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka, Louis, kapan kalian tiba?
Dialogue: 0,0:22:02.58,0:22:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kami terlambat.
Dialogue: 0,0:22:04.26,0:22:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan kami, Yang Mulia.
Dialogue: 0,0:22:06.18,0:22:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan melindungi Yang Mulia\Nmulai sekarang.
Dialogue: 0,0:22:11.38,0:22:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bersikap seperti ini.\NAku bukan ratu lagi.
Dialogue: 0,0:22:13.81,0:22:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya murid SMA biasa sekarang.
Dialogue: 0,0:22:16.56,0:22:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun.
Dialogue: 0,0:22:18.48,0:22:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang.
Dialogue: 0,0:22:27.31,0:22:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelap sekali.
Dialogue: 0,0:22:28.74,0:22:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyalakan, Jino.
Dialogue: 0,0:22:30.29,0:22:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan senter.
Dialogue: 0,0:22:32.46,0:22:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:22:33.50,0:22:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kali terakhir semua orang\Nmenggunakan kekuatan?
Dialogue: 0,0:22:36.63,0:22:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kita memanggang marshmallow\Nuntuk Sooha?
Dialogue: 0,0:22:38.80,0:22:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa saat latihan Nightball.
Dialogue: 0,0:22:41.21,0:22:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ambil bola yang dilempar Jaan\Nke luar sekolah dengan kekuatan supernya.
Dialogue: 0,0:22:46.05,0:22:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupakai bayanganku untuk membuat kepiting.
Dialogue: 0,0:22:48.10,0:22:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa semua orang menggunakannya\Nuntuk hal sepele?
Dialogue: 0,0:22:51.14,0:22:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:22:53.31,0:22:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali terakhir aku menggunakan kekuatanku
Dialogue: 0,0:22:55.02,0:22:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah memanipulasi Klub Seni\Nuntuk melukis potret diriku.
Dialogue: 0,0:22:57.48,0:22:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gunakan kekuatanmu begitu.
Dialogue: 0,0:22:59.77,0:23:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum menggunakannya sejak saat itu.
Dialogue: 0,0:23:01.86,0:23:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kamu tak bisa melakukan apa pun\Nmeski berubah menjadi serigala.
Dialogue: 0,0:23:05.61,0:23:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:23:06.91,0:23:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telepati Heli\Nmungkin yang paling umum digunakan.
Dialogue: 0,0:23:12.12,0:23:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian berdua.
Dialogue: 0,0:23:13.79,0:23:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian mengobrol lewat telepati tadi?
Dialogue: 0,0:23:16.21,0:23:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kalian melakukannya?
Dialogue: 0,0:23:17.83,0:23:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian bicarakan?
Dialogue: 0,0:23:20.00,0:23:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak membicarakan apa pun.
Dialogue: 0,0:23:21.88,0:23:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:23:22.96,0:23:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakanlah, Heli.
Dialogue: 0,0:23:24.34,0:23:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu kami.
Dialogue: 0,0:23:26.38,0:23:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rahasia.
Dialogue: 0,0:23:27.47,0:23:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Sooha.
Dialogue: 0,0:23:29.39,0:23:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu tersipu, lo!
Dialogue: 0,0:23:33.35,0:23:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei...
