Dialogue: 0,0:03:54.96,0:03:56.93,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:03:56.93,0:04:00.97,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:04:02.97,0:04:05.98,tanda,,0000,0000,0000,,BULAN KABUT: DARAH VARGR
Dialogue: 0,0:10:06.00,0:10:10.09,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:10:10.09,0:10:14.01,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:23:37.02,0:23:39.89,tanda,,0000,0000,0000,,BULAN GELAP: ALTAR BULAN
Dialogue: 0,0:00:00.48,0:00:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:00:02.69,0:00:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku menemukanmu,
Dialogue: 0,0:00:06.24,0:00:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope.
Dialogue: 0,0:00:12.53,0:00:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu adalah orang
Dialogue: 0,0:00:16.70,0:00:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mencariku?
Dialogue: 0,0:00:21.46,0:00:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau kamu sudah tahu.
Dialogue: 0,0:00:23.92,0:00:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:00:25.21,0:00:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya memperlakukan\Nrekan kami seperti itu!
Dialogue: 0,0:00:28.59,0:00:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Najak!
Dialogue: 0,0:00:32.39,0:00:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan macam-macam denganku.
Dialogue: 0,0:00:36.27,0:00:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Altar Darah,
Dialogue: 0,0:00:37.71,0:00:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih banyak rekanmu yang menanti.
Dialogue: 0,0:00:41.10,0:00:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tak peduli\Nkalau mereka hidup atau mati?
Dialogue: 0,0:00:44.47,0:00:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya satu pertanyaan.
Dialogue: 0,0:00:45.86,0:00:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tujuanmu?
Dialogue: 0,0:00:48.65,0:00:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja untuk menguasai kerajaan...
Dialogue: 0,0:00:50.56,0:00:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, untuk menjadi raja dunia ini.
Dialogue: 0,0:01:00.58,0:01:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk melakukan itu, aku butuh darahmu.
Dialogue: 0,0:01:05.50,0:01:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut aku.
Dialogue: 0,0:01:10.22,0:01:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:01:12.01,0:01:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu aku naik takhta,
Dialogue: 0,0:01:14.84,0:01:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak hanya akan melindungi vampir,
Dialogue: 0,0:01:16.68,0:01:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga manusia serigala.
Dialogue: 0,0:01:20.15,0:01:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan konyol!
Dialogue: 0,0:01:23.27,0:01:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa ikut denganmu.
Dialogue: 0,0:01:25.57,0:01:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, berjanjilah kalau\Nkamu tak akan menyakiti teman-temanku.
Dialogue: 0,0:01:29.82,0:01:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, tak jadi masalah.
Dialogue: 0,0:01:35.66,0:01:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kuturuti perkataanmu.
Dialogue: 0,0:01:38.33,0:01:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan!
Dialogue: 0,0:01:39.62,0:01:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:01:40.65,0:01:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan, kamu belum...
Dialogue: 0,0:01:45.08,0:01:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan baik-baik saja.
Dialogue: 0,0:01:49.80,0:01:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga Najak.
Dialogue: 0,0:02:06.83,0:02:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo.
Dialogue: 0,0:02:12.45,0:02:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang ingin kamu temui\Njuga ada di sana.
Dialogue: 0,0:04:18.36,0:04:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion, kamu baik-baik saja?
Dialogue: 0,0:04:21.74,0:04:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:04:23.28,0:04:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Sooha\Nakan menyembuhkan kita lagi nanti.
Dialogue: 0,0:04:26.62,0:04:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lukanya tampak sembuh lebih lambat.
Dialogue: 0,0:04:32.25,0:04:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tanganku tidak bertenaga.
Dialogue: 0,0:04:35.65,0:04:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga.
Dialogue: 0,0:04:38.38,0:04:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada masalah dengan Sooha?
Dialogue: 0,0:04:42.71,0:04:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat.
Dialogue: 0,0:04:44.76,0:04:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang datang.
Dialogue: 0,0:04:56.15,0:04:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian di sini?
Dialogue: 0,0:04:58.07,0:04:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang ingin kutanyakan.
Dialogue: 0,0:05:02.70,0:05:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan membawa Khan?
Dialogue: 0,0:05:06.70,0:05:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu lagi!
Dialogue: 0,0:05:08.87,0:05:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu bulan purnama terbit,
Dialogue: 0,0:05:10.83,0:05:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan mendapatkannya!
Dialogue: 0,0:05:12.21,0:05:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita masih bisa menang?
Dialogue: 0,0:05:14.17,0:05:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkan hal itu terjadi!
Dialogue: 0,0:05:17.17,0:05:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:05:19.05,0:05:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak menduga\NSooha adalah seorang putri.
Dialogue: 0,0:05:37.90,0:05:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:05:43.28,0:05:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia memberikan terlalu banyak kekuatan?
Dialogue: 0,0:05:47.06,0:05:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Putri Selen.
Dialogue: 0,0:05:48.59,0:05:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin bertemu dengannya, kan?
Dialogue: 0,0:05:50.16,0:05:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Selen?
Dialogue: 0,0:05:51.64,0:05:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kamu belum tahu rupanya.
Dialogue: 0,0:05:54.96,0:05:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:05:56.47,0:05:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memberitahumu.
Dialogue: 0,0:06:00.34,0:06:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri kerajaan kuno yang bereinkarnasi?
Dialogue: 0,0:06:05.01,0:06:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga merasakannya, bukan?
Dialogue: 0,0:06:07.60,0:06:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha punya kekuatan\Nuntuk menggerakkan kita.
Dialogue: 0,0:06:10.85,0:06:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkan kalian.
Dialogue: 0,0:06:16.65,0:06:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kita secara naluriah\Ningin melindunginya.
Dialogue: 0,0:06:21.44,0:06:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:22.78,0:06:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian bereinkarnasi seperti Sooha?
Dialogue: 0,0:06:26.78,0:06:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kami...
Dialogue: 0,0:06:30.04,0:06:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Selen menggunakan\Nkekuatan terakhirnya
Dialogue: 0,0:06:33.68,0:06:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengirim jiwa kami\Nberabad-abad ke masa depan.
Dialogue: 0,0:06:37.00,0:06:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kami diselamatkan.
Dialogue: 0,0:06:42.76,0:06:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam ratusan tahun terakhir,
Dialogue: 0,0:06:45.41,0:06:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami semua sudah melupakan kenangan itu.
Dialogue: 0,0:06:48.30,0:06:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya menyembunyikan fakta\Nbahwa kami vampir
Dialogue: 0,0:06:51.73,0:06:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hidup seperti itu sampai sekarang.
Dialogue: 0,0:06:54.64,0:06:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak tahu\Nkenapa kami ada di dunia ini.
Dialogue: 0,0:07:00.40,0:07:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah Tuan Putri\Nbereinkarnasi sebagai Sooha
Dialogue: 0,0:07:03.99,0:07:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bertemu kami,
Dialogue: 0,0:07:05.61,0:07:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingatan kami akhirnya kembali.
Dialogue: 0,0:07:08.16,0:07:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingat apa yang sebenarnya terjadi
Dialogue: 0,0:07:10.33,0:07:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat kerajaan itu runtuh.
Dialogue: 0,0:07:13.45,0:07:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan kami ada untuk melindungi Sooha.
Dialogue: 0,0:07:17.75,0:07:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya tiba saatnya\Nuntuk melawan Dardan.
Dialogue: 0,0:07:21.92,0:07:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menghabisinya kali ini!
Dialogue: 0,0:07:23.79,0:07:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:27.89,0:07:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Sooha...
Dialogue: 0,0:07:30.01,0:07:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, berikan darahmu.
Dialogue: 0,0:07:38.60,0:07:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak menurutiku...
Dialogue: 0,0:07:45.24,0:07:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat khawatir.
Dialogue: 0,0:07:46.89,0:07:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Khan
Dialogue: 0,0:07:48.86,0:07:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya belum pernah\Nberubah menjadi serigala.
Dialogue: 0,0:08:36.53,0:08:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kekuatan darah Vargr!
Dialogue: 0,0:08:40.53,0:08:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, kamu baik-baik saja?\NBertahanlah.
Dialogue: 0,0:08:43.42,0:08:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa bilang\Nkamu boleh menyentuh Tuan Putri?
Dialogue: 0,0:08:54.22,0:08:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sudah kamu lakukan pada Sooha?
Dialogue: 0,0:08:56.68,0:08:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang?
Dialogue: 0,0:08:58.02,0:09:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung sikapmu,
Dialogue: 0,0:09:00.43,0:09:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rekan-rekanmu bisa mati di sini.
Dialogue: 0,0:09:06.90,0:09:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai Lycanthrope,
Dialogue: 0,0:09:09.65,0:09:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak bisa diam saja\Ndan melihat rekan-rekanmu mati, bukan?
Dialogue: 0,0:09:14.03,0:09:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah?
Dialogue: 0,0:09:16.91,0:09:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauhlah dari Tuan Putri sekarang juga.
Dialogue: 0,0:09:25.21,0:09:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang, menjauh darinya.
Dialogue: 0,0:09:27.59,0:09:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mendengarku?
Dialogue: 0,0:09:33.22,0:09:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mencintai Tuan Putri, bukan?
Dialogue: 0,0:09:36.60,0:09:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:09:37.93,0:09:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski harus meninggalkan kaummu,
Dialogue: 0,0:09:39.85,0:09:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu ingin menyelamatkannya, bukan?
Dialogue: 0,0:09:42.10,0:09:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak bisa membuat pilihan jelas,
Dialogue: 0,0:09:44.48,0:09:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak bisa menyelamatkan keduanya!
Dialogue: 0,0:10:03.71,0:10:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataharinya terbenam.
Dialogue: 0,0:10:23.52,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, semuanya sudah selesai.
Dialogue: 0,0:10:27.86,0:10:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantranya,
Dialogue: 0,0:10:29.70,0:10:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri,
Dialogue: 0,0:10:31.53,0:10:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan darah Vargr.
Dialogue: 0,0:10:37.62,0:10:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bulan purnama bersinar\Ndi langit malam,
Dialogue: 0,0:10:42.96,0:10:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu aku mengucapkan mantranya,
Dialogue: 0,0:10:45.12,0:10:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan yang tersegel di altar\Nakan dilepaskan
Dialogue: 0,0:10:49.17,0:10:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar Tuan Putri mewarisi kekuatan itu.
Dialogue: 0,0:10:52.63,0:10:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu
Dialogue: 0,0:10:54.43,0:10:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa membuat kekuatan itu\Nmenjadi milikku.
Dialogue: 0,0:11:04.06,0:11:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku lebih kuat.
Dialogue: 0,0:11:11.98,0:11:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope.
Dialogue: 0,0:11:15.74,0:11:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope.
Dialogue: 0,0:11:18.99,0:11:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu...
Dialogue: 0,0:11:26.33,0:11:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope.
Dialogue: 0,0:11:32.42,0:11:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamulah yang mewarisi darahku,\Ndarah Dewa Serigala Vargr.
Dialogue: 0,0:11:39.64,0:11:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi klan kita, kamu seperti bulan.
Dialogue: 0,0:11:44.63,0:11:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mampu membangkitkan\Nkekuatan ras manusia serigala.
Dialogue: 0,0:11:48.19,0:11:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana caraku membangkitkannya?
Dialogue: 0,0:11:51.90,0:11:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Instingmu akan memberitahumu semuanya.
Dialogue: 0,0:11:56.36,0:11:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakanlah semua orang.
Dialogue: 0,0:11:58.53,0:12:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah bulan klan kita.
Dialogue: 0,0:12:01.86,0:12:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kekuatan itu,
Dialogue: 0,0:12:03.66,0:12:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lindungilah Tuan Putri yang kamu layani.
Dialogue: 0,0:12:27.89,0:12:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pewaris darah Vargr.
Dialogue: 0,0:12:47.50,0:12:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:12:48.46,0:12:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope.
Dialogue: 0,0:12:53.00,0:12:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Lycanthrope.
Dialogue: 0,0:12:55.00,0:12:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang menyelamatkan kita!
Dialogue: 0,0:13:07.81,0:13:11.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, lari! Cepat!
Dialogue: 0,0:13:19.32,0:13:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya melawan.
Dialogue: 0,0:13:34.38,0:13:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melarangku menyentuh Tuan Putri, kan?
Dialogue: 0,0:13:37.63,0:13:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembalikan
Dialogue: 0,0:13:39.17,0:13:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalimat itu padamu!
Dialogue: 0,0:13:41.88,0:13:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkanmu\Nberbuat sesukamu!
Dialogue: 0,0:13:46.97,0:13:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:13:55.94,0:13:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya manusia serigala.
Dialogue: 0,0:13:58.07,0:14:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirmu sekarang bisa mengalahkanku?
Dialogue: 0,0:14:01.20,0:14:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melawan,\Nakan kubunuh kalian semua,
Dialogue: 0,0:14:03.91,0:14:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik itu kamu
Dialogue: 0,0:14:06.15,0:14:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau rekan-rekanmu.
Dialogue: 0,0:14:16.29,0:14:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu?
Dialogue: 0,0:14:17.94,0:14:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada banyak.
Dialogue: 0,0:14:27.64,0:14:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mereka bukan musuh.
Dialogue: 0,0:14:29.85,0:14:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka rekan-rekan kami.
Dialogue: 0,0:14:37.90,0:14:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:14:39.07,0:14:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asal kalian?
Dialogue: 0,0:14:40.07,0:14:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami... Kami datang dari Altar Darah.
Dialogue: 0,0:14:44.07,0:14:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Kak Khan?
Dialogue: 0,0:14:45.23,0:14:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia baik-baik saja?
Dialogue: 0,0:14:46.16,0:14:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan?
Dialogue: 0,0:14:48.24,0:14:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Lycanthrope itu?
Dialogue: 0,0:14:53.08,0:14:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyelamatkan kami.
Dialogue: 0,0:14:58.09,0:14:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Khan...
Dialogue: 0,0:14:59.42,0:15:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil berubah menjadi serigala?
Dialogue: 0,0:15:05.30,0:15:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, di mana Khan sekarang?
Dialogue: 0,0:15:07.26,0:15:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melawan Dardan sendirian di sana.
Dialogue: 0,0:15:21.86,0:15:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbaring saja di sana dengan tenang.
Dialogue: 0,0:15:39.88,0:15:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa segelnya mulai terbuka?
Dialogue: 0,0:15:44.34,0:15:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kekuatan kerajaan kuno\Nyang diwariskan turun-temurun.
Dialogue: 0,0:15:51.14,0:15:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdiri di dekatnya saja
Dialogue: 0,0:15:53.14,0:15:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku merasakan energi mengerikan.
Dialogue: 0,0:15:55.56,0:15:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kekuatan yang luar biasa.
Dialogue: 0,0:15:58.56,0:16:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini akan menjadi milikku.
Dialogue: 0,0:16:04.69,0:16:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri,
Dialogue: 0,0:16:06.82,0:16:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini sudah dimulai.
Dialogue: 0,0:16:35.81,0:16:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:16:36.90,0:16:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada cahaya yang menyilaukan.
Dialogue: 0,0:16:38.44,0:16:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu
Dialogue: 0,0:16:40.56,0:16:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan keluarga kerajaan\Nyang tersegel di altar.
Dialogue: 0,0:16:44.69,0:16:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ritualnya sudah dimulai?
Dialogue: 0,0:16:47.01,0:16:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:16:48.20,0:16:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini...
Dialogue: 0,0:16:50.20,0:16:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini akan menjadi milikku.
Dialogue: 0,0:17:01.79,0:17:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan.
Dialogue: 0,0:17:12.05,0:17:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:17:16.93,0:17:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:17:23.48,0:17:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku tidak bisa
Dialogue: 0,0:17:26.69,0:17:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membiarkanmu hidup!
Dialogue: 0,0:17:36.45,0:17:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bawa dia!
Dialogue: 0,0:17:40.25,0:17:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan, kamu baik-baik saja?
Dialogue: 0,0:17:49.17,0:17:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:17:51.51,0:17:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlambat jika baru datang sekarang.
Dialogue: 0,0:17:57.14,0:17:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:18:00.10,0:18:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warna rambutnya... Mungkinkah...
Dialogue: 0,0:18:02.60,0:18:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan!
Dialogue: 0,0:18:03.81,0:18:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khan.
Dialogue: 0,0:18:04.96,0:18:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terluka parah.
Dialogue: 0,0:18:06.73,0:18:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah.
Dialogue: 0,0:18:10.90,0:18:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:18:13.29,0:18:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan yang lain?
Dialogue: 0,0:18:15.99,0:18:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka baik-baik saja.
Dialogue: 0,0:18:17.67,0:18:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:18:29.00,0:18:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena dia membagi kekuatannya\Ndengan kami?
Dialogue: 0,0:18:37.97,0:18:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini...
Dialogue: 0,0:18:41.77,0:18:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini...
Dialogue: 0,0:18:43.75,0:18:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa seperti terkuras
Dialogue: 0,0:18:46.73,0:18:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari tubuhku.
Dialogue: 0,0:18:51.32,0:18:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang Sooha bagi dengan kami
Dialogue: 0,0:18:54.70,0:18:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perlahan kembali padanya.
Dialogue: 0,0:18:57.03,0:18:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.\NKita harus segera menyingkirkan orang itu.
Dialogue: 0,0:18:59.99,0:19:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah.
Dialogue: 0,0:19:00.96,0:19:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencoba\Nmengalihkan perhatian Dardan nanti.
Dialogue: 0,0:19:03.19,0:19:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi kulakukan itu, bawa Sooha...
Dialogue: 0,0:19:08.67,0:19:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menggunakan Telepati lagi.
Dialogue: 0,0:19:11.69,0:19:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah, bawa Sooha pergi!
Dialogue: 0,0:19:17.59,0:19:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menggunakan kekuatanku.
Dialogue: 0,0:19:21.14,0:19:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertunjukan sesungguhnya baru saja dimulai!
Dialogue: 0,0:19:23.73,0:19:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi Tuan Dardan!
Dialogue: 0,0:19:59.59,0:20:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap di sana dan saksikan
Dialogue: 0,0:20:02.01,0:20:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku mengambil semuanya\Nuntukku sendiri.
Dialogue: 0,0:20:04.77,0:20:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan ini dan Tuan Putri
Dialogue: 0,0:20:07.73,0:20:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah milikku sekarang.
Dialogue: 0,0:20:09.90,0:20:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat baik-baik!
Dialogue: 0,0:20:16.78,0:20:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, ayo!
Dialogue: 0,0:20:33.30,0:20:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan ini pada kami.
Dialogue: 0,0:20:35.13,0:20:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi dan kalahkan Dardan!
Dialogue: 0,0:20:43.05,0:20:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan.
Dialogue: 0,0:20:45.56,0:20:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan teri sepertimu
Dialogue: 0,0:20:47.27,0:20:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak pantas menjadi sainganku lagi.
Dialogue: 0,0:20:59.61,0:21:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggelikan sekali.
Dialogue: 0,0:21:02.03,0:21:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu kamu kesatria terbaik kerajaan itu.
Dialogue: 0,0:21:06.41,0:21:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kamu menyerah\Ndi depanku seperti ini.
Dialogue: 0,0:21:12.50,0:21:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan segera kuhilangkan\Nsemua kekuatan kalian.
Dialogue: 0,0:21:18.55,0:21:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kekuatan\Nyang diberikan Tuan Putri menghilang,
Dialogue: 0,0:21:21.43,0:21:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian akan menyadari
Dialogue: 0,0:21:25.68,0:21:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa kalian bukan apa-apa.
Dialogue: 0,0:23:34.14,0:23:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, di Episode Terakhir,
Dialogue: 0,0:23:37.02,0:23:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan Gelap: Altar Bulan.
