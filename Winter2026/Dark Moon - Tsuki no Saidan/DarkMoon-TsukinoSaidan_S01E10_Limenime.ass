Dialogue: 0,0:03:37.03,0:03:39.07,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:03:39.07,0:03:42.99,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:03:45.00,0:03:48.00,tanda,,0000,0000,0000,,BULAN CEMBUNG AKHIR:\NPERTARUNGAN MATI-MATIAN DI AUTOMNAL
Dialogue: 0,0:12:07.96,0:12:11.96,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:12:11.96,0:12:15.97,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:23:36.64,0:23:39.45,tanda,,0000,0000,0000,,BULAN KABUT: DARAH VARGR
Dialogue: 0,0:00:00.40,0:00:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope?
Dialogue: 0,0:00:04.73,0:00:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope adalah keturunan\NDewa Serigala kerajaan Vargr kuno
Dialogue: 0,0:00:09.70,0:00:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mewarisi darah Vargr.
Dialogue: 0,0:00:12.83,0:00:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, kamu adalah\Nmanusia serigala yang dipilih para dewa.
Dialogue: 0,0:00:19.25,0:00:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti tahu
Dialogue: 0,0:00:21.46,0:00:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa darah manusia serigala\Ndiwariskan dari generasi ke generasi
Dialogue: 0,0:00:24.73,0:00:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersama dengan status dan tradisi.
Dialogue: 0,0:00:27.63,0:00:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan kepemimpinanmu
Dialogue: 0,0:00:30.22,0:00:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kalung bernama "Silver Fang" ini
Dialogue: 0,0:00:33.39,0:00:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah simbol
Dialogue: 0,0:00:36.39,0:00:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pendekar Lycanthrope yang hebat.
Dialogue: 0,0:00:40.77,0:00:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sekarang hanya orang tua sepertiku\Nyang masih tahu akan hal ini.
Dialogue: 0,0:00:47.74,0:00:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, kamu pasti bisa merasakan
Dialogue: 0,0:00:49.99,0:00:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau ada sesuatu yang berbeda dari dirimu\Ndibanding anggota klan lain.
Dialogue: 0,0:00:55.20,0:00:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka secara alami menjadi serigala
Dialogue: 0,0:00:57.04,0:01:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat terpapar sinar bulan\Npada malam bulan purnama.
Dialogue: 0,0:01:01.37,0:01:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hanya aku yang berbeda?
Dialogue: 0,0:01:04.75,0:01:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku benar-benar punya kekurangan?
Dialogue: 0,0:01:09.34,0:01:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanmu berbeda dari anggota klan lain
Dialogue: 0,0:01:12.39,0:01:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah karena kamu terlahir\Ndengan takdir untuk memimpin kami.
Dialogue: 0,0:01:20.10,0:01:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:01:21.73,0:01:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu target mereka.
Dialogue: 0,0:01:25.52,0:01:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan menangkap manusia serigala\Ntanpa pandang bulu satu per satu
Dialogue: 0,0:01:29.65,0:01:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mendapatkan darah Vargr\Nyang kamu miliki.
Dialogue: 0,0:01:33.36,0:01:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara klan kami,
Dialogue: 0,0:01:34.78,0:01:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beberapa terluka dan beberapa tewas.
Dialogue: 0,0:01:40.25,0:01:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini
Dialogue: 0,0:01:41.54,0:01:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gara-gara aku?
Dialogue: 0,0:01:45.79,0:01:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:01:47.80,0:01:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak termaafkan!
Dialogue: 0,0:01:50.17,0:01:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu yang lainnya dikirim ke Automnal?
Dialogue: 0,0:01:54.05,0:01:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:56.68,0:01:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Camill dan yang lainnya\Npasti ada di sana juga.
Dialogue: 0,0:02:03.19,0:02:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menyelamatkan\Nrekan-rekan kita.
Dialogue: 0,0:02:07.40,0:02:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Tua.
Dialogue: 0,0:02:08.22,0:02:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petunjuk apa pun boleh.\NTolong beri tahu aku.
Dialogue: 0,0:03:58.38,0:04:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum ketemu juga?
Dialogue: 0,0:04:01.47,0:04:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:04:02.85,0:04:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih belum tertangkap...
Dialogue: 0,0:04:04.27,0:04:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup. Terus cari!
Dialogue: 0,0:04:09.27,0:04:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan.
Dialogue: 0,0:04:11.27,0:04:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera bebaskan Tuan Putri.
Dialogue: 0,0:04:13.52,0:04:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum terlambat untuk berhenti sekarang.
Dialogue: 0,0:04:15.86,0:04:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang sudah kamu lakukan ini\Nadalah perbuatan tak termaafkan!
Dialogue: 0,0:04:21.95,0:04:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih mengungkit statusku lagi?
Dialogue: 0,0:04:23.83,0:04:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini masalah kelayakan.
Dialogue: 0,0:04:27.50,0:04:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak semua anggota keluarga kerajaan\Nbisa mewarisi kekuatan itu.
Dialogue: 0,0:04:31.04,0:04:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya yang layak saja\Nyang bisa mendapatkannya.
Dialogue: 0,0:04:34.00,0:04:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kerajaan\Nhanya mengikuti peraturan ini.
Dialogue: 0,0:04:37.47,0:04:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sepertimu tidak layak.
Dialogue: 0,0:04:39.72,0:04:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski lahir di keluarga kerajaan,
Dialogue: 0,0:04:42.64,0:04:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang sepertimu\Nyang dibutakan oleh keegoisan
Dialogue: 0,0:04:44.85,0:04:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terus mengorbankan orang lain\Ntidak akan pernah mendapat kekuatan itu.
Dialogue: 0,0:04:50.02,0:04:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus saja menyombongkan dirimu seperti itu.
Dialogue: 0,0:04:54.73,0:04:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kemampuanmu, kamu bahkan\Ntidak bisa melakukan apa pun.
Dialogue: 0,0:04:57.61,0:05:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuktikan bahwa aku benar,\Nbaik di masa lalu maupun masa kini.
Dialogue: 0,0:05:27.14,0:05:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan kota ini?
Dialogue: 0,0:05:28.77,0:05:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tak bernyawa.
Dialogue: 0,0:05:30.64,0:05:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang di sini
Dialogue: 0,0:05:32.02,0:05:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah vampir.
Dialogue: 0,0:05:34.86,0:05:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mereka tidak menyerang kita.
Dialogue: 0,0:05:39.40,0:05:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menatap mata mereka.
Dialogue: 0,0:05:44.49,0:05:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya
Dialogue: 0,0:05:45.45,0:05:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kota ini sudah dikuasai oleh Dardan?
Dialogue: 0,0:05:48.70,0:05:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita dikepung musuh?
Dialogue: 0,0:05:51.87,0:05:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, sekarang kita harus\Nmenemukan pedang itu dulu.
Dialogue: 0,0:05:59.80,0:06:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Museum itu sepertinya berada\Ndi rubanah Balai Kota.
Dialogue: 0,0:06:07.46,0:06:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Museum Automnal.
Dialogue: 0,0:06:11.18,0:06:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Theresa, kurator di sini.
Dialogue: 0,0:06:13.77,0:06:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan ikuti aku.
Dialogue: 0,0:06:26.78,0:06:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, hati-hati.
Dialogue: 0,0:06:29.70,0:06:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan vampir biasa.
Dialogue: 0,0:06:34.25,0:06:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai.
Dialogue: 0,0:06:35.67,0:06:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pameran artefak kuno.
Dialogue: 0,0:06:39.50,0:06:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan melihat-lihat.
Dialogue: 0,0:06:57.36,0:06:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukannya.
Dialogue: 0,0:07:05.24,0:07:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mengambilnya?
Dialogue: 0,0:07:06.36,0:07:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba.
Dialogue: 0,0:07:09.95,0:07:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar, kalian datang\Nuntuk pedang itu.
Dialogue: 0,0:07:13.75,0:07:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan menyerahkan pedang itu.
Dialogue: 0,0:07:16.00,0:07:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalian semua akan mati di sini!
Dialogue: 0,0:07:25.63,0:07:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli, ambil pedangnya sekarang!
Dialogue: 0,0:07:34.27,0:07:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?\NTanganku bergerak sendiri.
Dialogue: 0,0:07:46.78,0:07:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli!
Dialogue: 0,0:07:49.12,0:07:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:07:51.24,0:07:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanganku...
Dialogue: 0,0:07:53.16,0:07:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku...
Dialogue: 0,0:07:55.83,0:07:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bergerak.
Dialogue: 0,0:08:00.88,0:08:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli\Nbetapa berbahayanya pedang ini,
Dialogue: 0,0:08:02.88,0:08:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terpenting adalah\Npada siapa pedang itu mengarah.
Dialogue: 0,0:08:08.34,0:08:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang berhak memutuskan itu.
Dialogue: 0,0:08:12.56,0:08:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang yang membunuh rekan-rekanku
Dialogue: 0,0:08:15.39,0:08:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kali ini akan diarahkan ke teman-temanmu!
Dialogue: 0,0:08:19.40,0:08:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus dikendalikan gadis ini,
Dialogue: 0,0:08:21.27,0:08:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka benar-benar bisa mati!
Dialogue: 0,0:08:22.86,0:08:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku tak bisa bergerak.
Dialogue: 0,0:08:26.40,0:08:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah gadis itu mengendalikan\Nkita bertujuh sendirian?
Dialogue: 0,0:08:30.57,0:08:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion!
Dialogue: 0,0:08:31.62,0:08:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa lakukan sesuatu?
Dialogue: 0,0:08:32.90,0:08:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa menghipnosis!
Dialogue: 0,0:08:49.97,0:08:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion!
Dialogue: 0,0:08:52.39,0:08:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion!
Dialogue: 0,0:08:58.39,0:08:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:09:06.44,0:09:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noa.
Dialogue: 0,0:09:07.44,0:09:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada gunanya.
Dialogue: 0,0:09:14.20,0:09:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noa!
Dialogue: 0,0:09:15.20,0:09:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa mengendalikan tubuhku.
Dialogue: 0,0:09:20.46,0:09:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noa!
Dialogue: 0,0:09:21.42,0:09:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan!
Dialogue: 0,0:09:35.39,0:09:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}So...
Dialogue: 0,0:09:39.39,0:09:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Solon!
Dialogue: 0,0:09:54.82,0:09:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, semuanya menjadi milikku!
Dialogue: 0,0:10:00.12,0:10:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sama seperti dulu.
Dialogue: 0,0:10:03.04,0:10:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Solon.
Dialogue: 0,0:10:04.75,0:10:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa begini?
Dialogue: 0,0:10:12.93,0:10:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noa!
Dialogue: 0,0:10:13.84,0:10:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:10:15.05,0:10:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kita lakukan?
Dialogue: 0,0:10:18.85,0:10:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi kalian luar biasa!
Dialogue: 0,0:10:20.93,0:10:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang hanya bisa kukagumi sendiri.
Dialogue: 0,0:10:24.27,0:10:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir, aku tidak akan\Nmembunuh kalian dengan mudah.
Dialogue: 0,0:10:28.07,0:10:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa membiarkan\Nkesenangan ini berakhir begitu cepat.
Dialogue: 0,0:10:39.62,0:10:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Beraninya kamu!
Dialogue: 0,0:10:45.58,0:10:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jino!
Dialogue: 0,0:10:48.59,0:10:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya\Nsaling membunuh teman sendiri?
Dialogue: 0,0:10:58.14,0:10:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyedihkan sekali.
Dialogue: 0,0:10:59.76,0:11:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kesempatan bagus.
Dialogue: 0,0:11:02.93,0:11:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:11:04.02,0:11:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah akhirnya.
Dialogue: 0,0:11:18.74,0:11:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah...
Dialogue: 0,0:11:23.70,0:11:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, hanya tersisa satu.
Dialogue: 0,0:11:26.87,0:11:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penggal kepalanya.
Dialogue: 0,0:11:32.00,0:11:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan.
Dialogue: 0,0:11:44.98,0:11:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan coba-coba untuk menentangku!
Dialogue: 0,0:11:52.69,0:11:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:12:22.01,0:12:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:12:31.48,0:12:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya menentangku\Ndi hadapan kematian?
Dialogue: 0,0:12:40.32,0:12:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:12:41.78,0:12:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, masih terlalu dangkal!
Dialogue: 0,0:12:44.12,0:12:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melambat karena pendarahan.
Dialogue: 0,0:12:51.58,0:12:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah!
Dialogue: 0,0:12:58.84,0:13:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukanya sembuh.
Dialogue: 0,0:13:02.18,0:13:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini kekuatan Sooha?
Dialogue: 0,0:13:06.64,0:13:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, teman-teman yang lain...
Dialogue: 0,0:13:19.78,0:13:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak baik kalau terus begini.
Dialogue: 0,0:13:21.36,0:13:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus segera mengakhiri ini.
Dialogue: 0,0:13:25.58,0:13:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tua itu bilang
Dialogue: 0,0:13:26.99,0:13:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kapal yang dinaiki teman-teman kita
Dialogue: 0,0:13:28.91,0:13:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menuju ke Automnal, bukan?
Dialogue: 0,0:13:31.25,0:13:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:32.75,0:13:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kita memeriksa dermaga?
Dialogue: 0,0:13:37.55,0:13:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:13:39.13,0:13:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tahel?
Dialogue: 0,0:13:40.59,0:13:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu menyadari sesuatu?
Dialogue: 0,0:13:42.18,0:13:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya sangat samar,
Dialogue: 0,0:13:44.09,0:13:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku bisa mencium\Naroma Kak Camill dan yang lain di sana.
Dialogue: 0,0:13:57.73,0:13:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa bergerak!
Dialogue: 0,0:13:58.94,0:14:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendali gadis itu\Njadi melemah setelah terluka.
Dialogue: 0,0:14:04.09,0:14:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia juga tidak bisa\Nmengendalikan tujuh orang sekaligus.
Dialogue: 0,0:14:07.74,0:14:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya bisa bebas\Nmengendalikan satu orang.
Dialogue: 0,0:14:10.20,0:14:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya dia membuat\Nkami berenam tidak bergerak.
Dialogue: 0,0:14:14.12,0:14:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini dia bahkan tidak bisa\Nmengendalikan satu orang.
Dialogue: 0,0:14:19.63,0:14:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya dia hampir mencapai batasnya.
Dialogue: 0,0:14:26.43,0:14:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak!
Dialogue: 0,0:14:30.43,0:14:31.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang saatnya!
Dialogue: 0,0:14:39.15,0:14:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terena!
Dialogue: 0,0:14:40.03,0:14:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:14:41.40,0:14:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu lagi?
Dialogue: 0,0:14:48.16,0:14:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya menyakiti Theresa\Nsampai sejauh ini.
Dialogue: 0,0:14:53.37,0:14:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkanmu lolos.
Dialogue: 0,0:14:59.59,0:15:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresa membuat kalian tidak bergerak,
Dialogue: 0,0:15:01.21,0:15:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku yang akan\Nmemenggal kepala kalian.
Dialogue: 0,0:15:03.05,0:15:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:15:04.51,0:15:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian tidak bisa mengalahkan kami!
Dialogue: 0,0:15:11.01,0:15:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan!
Dialogue: 0,0:15:14.14,0:15:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah!
Dialogue: 0,0:15:17.65,0:15:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion!
Dialogue: 0,0:15:31.95,0:15:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa?
Dialogue: 0,0:15:51.14,0:15:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma.
Dialogue: 0,0:16:03.23,0:16:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, hanya kamu yang tersisa.
Dialogue: 0,0:16:08.82,0:16:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memenggal kepalamu\Ndengan satu tebasan!
Dialogue: 0,0:16:13.87,0:16:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:16:18.04,0:16:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha?
Dialogue: 0,0:16:22.75,0:16:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha?
Dialogue: 0,0:16:29.72,0:16:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresa.
Dialogue: 0,0:16:33.39,0:16:34.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresa...
Dialogue: 0,0:16:38.19,0:16:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin?
Dialogue: 0,0:16:51.74,0:16:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang mengubahku menjadi vampir.
Dialogue: 0,0:16:57.04,0:17:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu mati...
Dialogue: 0,0:17:08.33,0:17:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:17:10.26,0:17:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kamu?
Dialogue: 0,0:17:11.83,0:17:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku salah?
Dialogue: 0,0:17:13.65,0:17:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tadi dia tadi di sini?
Dialogue: 0,0:17:16.64,0:17:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak mungkin salah.
Dialogue: 0,0:17:20.94,0:17:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, kamu baik-baik saja?
Dialogue: 0,0:17:23.81,0:17:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah ke hutan.
Dialogue: 0,0:17:24.90,0:17:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan?
Dialogue: 0,0:17:25.98,0:17:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ritualnya akan diadakan\Npada malam bulan purnama.
Dialogue: 0,0:17:30.53,0:17:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah ke Hutan Hivernal sebelum itu.
Dialogue: 0,0:17:33.95,0:17:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sebelum Dardan mengambil kekuatannya.
Dialogue: 0,0:17:38.41,0:17:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:18:02.64,0:18:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diragukan lagi.\NIni kemampuan misterius Tuan Putri.
Dialogue: 0,0:18:07.82,0:18:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga melakukan ini saat itu.
Dialogue: 0,0:18:10.61,0:18:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri...
Dialogue: 0,0:18:22.62,0:18:25.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mendapatkan kembali\Nkekuatan aslinya?
Dialogue: 0,0:18:26.13,0:18:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kurasa dia belum bisa\Nmenggunakannya dengan bebas.
Dialogue: 0,0:18:32.59,0:18:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Nsemua ini akan menjadi milikku!
Dialogue: 0,0:18:37.30,0:18:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Dardan.
Dialogue: 0,0:18:39.22,0:18:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:40.06,0:18:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menemukan Lycanthrope itu.
Dialogue: 0,0:18:46.86,0:18:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha tadi di sini?
Dialogue: 0,0:18:49.03,0:18:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:50.23,0:18:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu dia tiba-tiba muncul,\Nlalu menghilang?
Dialogue: 0,0:18:53.45,0:18:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu kemampuan Sooha.
Dialogue: 0,0:18:56.28,0:18:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha bilang
Dialogue: 0,0:18:58.70,0:19:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia dikurung di Altar Darah\Ndi Hutan Hivernal.
Dialogue: 0,0:19:03.58,0:19:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hutan Hivernal?
Dialogue: 0,0:19:05.69,0:19:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:19:09.50,0:19:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini.
Dialogue: 0,0:19:11.34,0:19:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada malam bulan purnama,
Dialogue: 0,0:19:13.20,0:19:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa akan diadakan semacam ritual.
Dialogue: 0,0:19:15.30,0:19:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menyelamatkan Sooha\Nsebelum itu terjadi.
Dialogue: 0,0:19:17.93,0:19:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, Dardan\Nakan mengambil kekuatannya.
Dialogue: 0,0:19:20.85,0:19:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan purnama...\NBukankah itu malam ini?
Dialogue: 0,0:19:24.73,0:19:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian baik-baik saja?
Dialogue: 0,0:19:29.27,0:19:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir kamu bicara dengan siapa?
Dialogue: 0,0:19:32.82,0:19:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu kami baik-baik saja.
Dialogue: 0,0:19:36.36,0:19:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara aku, kalian sampai...
Dialogue: 0,0:19:37.78,0:19:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bergegas, bulan akan terbit.
Dialogue: 0,0:19:42.54,0:19:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:19:51.00,0:19:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo!
Dialogue: 0,0:20:00.05,0:20:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh dengan mayat.
Dialogue: 0,0:20:01.85,0:20:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:20:03.27,0:20:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah karena kakak beradik itu mati?
Dialogue: 0,0:20:06.69,0:20:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayat-mayat ini
Dialogue: 0,0:20:07.89,0:20:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti vampir tingkat rendah\Nyang mereka ciptakan.
Dialogue: 0,0:20:11.57,0:20:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal-usul semua ini
Dialogue: 0,0:20:13.11,0:20:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Dardan sang leluhur.
Dialogue: 0,0:20:14.99,0:20:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kita mengalahkannya,
Dialogue: 0,0:20:16.65,0:20:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua vampir yang dia ciptakan\Njuga akan menghilang.
Dialogue: 0,0:20:21.99,0:20:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana teman-temanku?
Dialogue: 0,0:20:24.58,0:20:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mereka...
Dialogue: 0,0:20:25.95,0:20:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya menyuruhku.
Dialogue: 0,0:20:29.92,0:20:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sesak...
Dialogue: 0,0:20:31.75,0:20:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia serigala dikurung\Ndi salah satu ruangan ini, kan?
Dialogue: 0,0:20:37.76,0:20:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan kuncinya.
Dialogue: 0,0:20:49.10,0:20:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camill! Ruslan!
Dialogue: 0,0:20:50.56,0:20:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Khan, semuanya!
Dialogue: 0,0:20:52.81,0:20:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:20:54.36,0:20:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mahan, kamu baik-baik saja?
Dialogue: 0,0:20:58.03,0:20:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:21:00.99,0:21:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terluka?
Dialogue: 0,0:21:02.74,0:21:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kami baik-baik saja.
Dialogue: 0,0:21:04.95,0:21:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kami bisa kabur.
Dialogue: 0,0:21:06.75,0:21:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tetap di sana\Nuntuk mencari tahu apa yang terjadi.
Dialogue: 0,0:21:09.29,0:21:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuat kalian khawatir.
Dialogue: 0,0:21:11.33,0:21:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa\Nasal kamu tidak terluka.
Dialogue: 0,0:21:16.67,0:21:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana yang lainnya?
Dialogue: 0,0:21:18.01,0:21:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dibawa ke tempat lain.
Dialogue: 0,0:21:22.51,0:21:25.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke tempat bernama "Altar Darah".
Dialogue: 0,0:21:25.22,0:21:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Altar Darah?
Dialogue: 0,0:21:27.43,0:21:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar letaknya ada di hutan dekat sini.
Dialogue: 0,0:21:32.06,0:21:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo.
Dialogue: 0,0:21:46.28,0:21:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:21:47.99,0:21:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku menemukanmu,
Dialogue: 0,0:21:52.04,0:21:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope.
Dialogue: 0,0:23:33.35,0:23:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, di Episode 11,
Dialogue: 0,0:23:36.64,0:23:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan Kabut: Darah Vargr.
