Dialogue: 0,0:03:11.05,0:03:13.10,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:03:13.10,0:03:16.97,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:03:18.97,0:03:21.97,tanda,,0000,0000,0000,,BULAN BERKABUT: KABUT HITAM RAILGUN
Dialogue: 0,0:09:51.70,0:09:53.70,tanda,,0000,0000,0000,,SEKOLAH KOTA SUNSHINE
Dialogue: 0,0:12:16.97,0:12:20.97,tanda,,0000,0000,0000,,DARK MOON: THE BLOOD ALTAR
Dialogue: 0,0:12:20.97,0:12:24.97,tanda,,0000,0000,0000,,ORIGINAL BY DARK MOON:\NTHE BLOOD ALTAR WITH ENHYPEN
Dialogue: 0,0:23:36.06,0:23:37.99,tanda,,0000,0000,0000,,BULAN CEMBUNG AKHIR:
Dialogue: 0,0:23:37.99,0:23:39.96,tanda,,0000,0000,0000,,PERTARUNGAN MATI-MATIAN DI AUTOMNAL
Dialogue: 0,0:00:00.45,0:00:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:00:03.07,0:00:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, legenda itu
Dialogue: 0,0:00:05.65,0:00:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rupanya tentang kami, ya?
Dialogue: 0,0:00:12.33,0:00:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sekarang kalian sudah ingat?
Dialogue: 0,0:00:15.16,0:00:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dan Sooha
Dialogue: 0,0:00:16.63,0:00:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah lama saling mengenal?
Dialogue: 0,0:00:20.00,0:00:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:21.33,0:00:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kita sangat tertarik padanya\Nsaat kali pertama bertemu.
Dialogue: 0,0:00:25.13,0:00:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Marge sebenarnya\Nmelindungi kita dari Dardan.
Dialogue: 0,0:00:29.88,0:00:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah, apa kamu bisa merasakan energi Sooha?
Dialogue: 0,0:00:33.39,0:00:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini... tidak bisa.
Dialogue: 0,0:00:37.43,0:00:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada dua alasan\Nenerginya sangat lemah.
Dialogue: 0,0:00:40.94,0:00:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, dia tidak sadarkan diri.
Dialogue: 0,0:00:42.86,0:00:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua,
Dialogue: 0,0:00:44.90,0:00:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mungkin sudah mati.
Dialogue: 0,0:00:46.90,0:00:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya selama ini kulakukan?
Dialogue: 0,0:00:49.52,0:00:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku melindungi Sooha!
Dialogue: 0,0:00:52.88,0:00:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke Panti Asuhan Vamfield.
Dialogue: 0,0:00:57.91,0:01:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan mungkin pergi ke sana\Nuntuk mencari sesuatu.
Dialogue: 0,0:01:02.29,0:01:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari apa?
Dialogue: 0,0:01:03.79,0:01:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gulungan yang berkaitan\Ndengan Kerajaan Vargr kuno.
Dialogue: 0,0:01:06.49,0:01:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vaonis.
Dialogue: 0,0:01:08.53,0:01:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vaonis.
Dialogue: 0,0:01:10.09,0:01:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kerajaan itu sudah lama runtuh,
Dialogue: 0,0:01:12.55,0:01:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya segelintir orang\Nyang tahu rahasia itu.
Dialogue: 0,0:01:16.40,0:01:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mendapatkan kekuatan,
Dialogue: 0,0:01:18.47,0:01:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan harus mendapatkan rahasia itu.
Dialogue: 0,0:01:31.82,0:01:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka kita akan bersatu kembali\Ndalam situasi seperti ini.
Dialogue: 0,0:01:35.74,0:01:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Putri pasti menyatukan kita semua.
Dialogue: 0,0:01:39.66,0:01:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha pasti masih hidup.
Dialogue: 0,0:01:41.74,0:01:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi,\Nkita akan menyelamatkannya.
Dialogue: 0,0:03:30.48,0:03:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:03:32.08,0:03:34.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga kita akan kembali ke sini.
Dialogue: 0,0:03:34.45,0:03:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kita kembali atas kemauan sendiri.
Dialogue: 0,0:03:56.51,0:03:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vaonis hilang!
Dialogue: 0,0:03:58.51,0:04:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita terlambat?
Dialogue: 0,0:04:00.17,0:04:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mereka mungkin masih di sini.
Dialogue: 0,0:04:03.51,0:04:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berpencar.
Dialogue: 0,0:04:04.97,0:04:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memeriksa kamar tidur.
Dialogue: 0,0:04:06.60,0:04:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memeriksa lantai tiga.
Dialogue: 0,0:04:24.29,0:04:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, datang ke ruang santai.
Dialogue: 0,0:04:30.67,0:04:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah.
Dialogue: 0,0:04:32.71,0:04:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dia yang tersisa.
Dialogue: 0,0:04:34.49,0:04:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan menangkapnya.
Dialogue: 0,0:04:36.82,0:04:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:38.26,0:04:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura Marge menghilang dari tempat ini.
Dialogue: 0,0:04:47.60,0:04:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah...
Dialogue: 0,0:04:49.02,0:04:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana kalian membawa Marge?
Dialogue: 0,0:04:51.69,0:04:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Dardan mengirim kalian?
Dialogue: 0,0:04:53.40,0:04:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kaki tanganmu?
Dialogue: 0,0:04:56.65,0:04:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menanyainya.
Dialogue: 0,0:04:59.57,0:05:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana kalian membawa Sooha dan Marge?
Dialogue: 0,0:05:07.95,0:05:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Vaonis yang kamu curi dari kami?
Dialogue: 0,0:05:12.21,0:05:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab aku!
Dialogue: 0,0:05:16.25,0:05:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Printanier.
Dialogue: 0,0:05:18.53,0:05:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Printanier?
Dialogue: 0,0:05:20.13,0:05:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Printanier cukup jauh dari sini.
Dialogue: 0,0:05:22.39,0:05:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa di Printanier?
Dialogue: 0,0:05:24.78,0:05:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Dardan juga di sana?
Dialogue: 0,0:05:50.50,0:05:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.\NSeharusnya aku membunuhnya lebih awal.
Dialogue: 0,0:05:54.92,0:05:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, lupakan saja.
Dialogue: 0,0:06:00.34,0:06:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, akhirnya kita bisa menjadi satu.
Dialogue: 0,0:06:06.14,0:06:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu, para penguasa kerajaan ini\Nmewarisi darah Syaman.
Dialogue: 0,0:06:11.60,0:06:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mereka turun takhta,
Dialogue: 0,0:06:14.58,0:06:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menyegel semua kekuatannya\Ndi Altar Darah
Dialogue: 0,0:06:18.46,0:06:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melakukan ritual\Npada malam bulan purnama
Dialogue: 0,0:06:21.22,0:06:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mewariskannya\Npada penguasa berikutnya.
Dialogue: 0,0:06:26.03,0:06:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam bulan purnama.
Dialogue: 0,0:06:28.45,0:06:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkatmu, akhirnya aku bisa\Nmelepaskan segel itu di altar.
Dialogue: 0,0:06:32.04,0:06:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, aku akan mewarisi kekuatan itu
Dialogue: 0,0:06:35.12,0:06:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadi penguasa baru.
Dialogue: 0,0:06:39.21,0:06:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku hanya perlu\Nmendapatkan Darah Vargr.
Dialogue: 0,0:06:45.01,0:06:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini,\Naku pasti akan mendapatkan semuanya.
Dialogue: 0,0:06:56.69,0:06:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski lahir di keluarga yang hancur,
Dialogue: 0,0:06:59.47,0:07:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap meraih jabatan kanselir.
Dialogue: 0,0:07:05.24,0:07:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa kurangnya dariku?
Dialogue: 0,0:07:14.91,0:07:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selen yang cantik,
Dialogue: 0,0:07:16.55,0:07:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pasti akan menjadi milikku!
Dialogue: 0,0:07:38.06,0:07:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Vargr.
Dialogue: 0,0:07:42.27,0:07:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan! Sedang apa kamu di sana?
Dialogue: 0,0:07:46.65,0:07:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan Vaonis!
Dialogue: 0,0:07:51.82,0:07:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gulungan yang hanya bisa dibaca\Noleh keluarga kerajaan.
Dialogue: 0,0:07:55.45,0:07:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status...
Dialogue: 0,0:07:57.92,0:07:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi soal status?
Dialogue: 0,0:07:59.88,0:08:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak mendengarnya!
Dialogue: 0,0:08:01.63,0:08:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya kamu rencanakan?
Dialogue: 0,0:08:04.13,0:08:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin mendapatkan kekuatan.
Dialogue: 0,0:08:07.25,0:08:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah alasanmu membaca buku terlarang?
Dialogue: 0,0:08:09.72,0:08:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kerajaan tidak akan memaafkanmu!
Dialogue: 0,0:08:17.10,0:08:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku terlarang yang tujuannya hanya melindungi\Nkekuasaan keluarga kerajaan, bukan?
Dialogue: 0,0:08:22.90,0:08:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong! Siapa saja, tolong!
Dialogue: 0,0:08:30.49,0:08:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah Vargr.
Dialogue: 0,0:08:34.58,0:08:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selen, kamu sudah sadar?
Dialogue: 0,0:08:38.00,0:08:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, kamu baik-baik saja sekarang.
Dialogue: 0,0:08:41.04,0:08:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu.
Dialogue: 0,0:08:42.91,0:08:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertemu Dewa Vargr.
Dialogue: 0,0:08:46.47,0:08:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Vargr.
Dialogue: 0,0:08:52.76,0:08:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:08:54.10,0:08:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak apa pun darah yang kuminum,\Naku masih sangat haus!
Dialogue: 0,0:08:56.93,0:09:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, sedikit saja terpapar sinar matahari...
Dialogue: 0,0:09:00.77,0:09:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah minum darah Vargr\Nseperti Tuan Putri.
Dialogue: 0,0:09:04.02,0:09:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kurang banyak?
Dialogue: 0,0:09:05.32,0:09:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau karena aku tak punya kekuatan Syaman?
Dialogue: 0,0:09:08.11,0:09:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku membaca seluruh isi Vaonis.
Dialogue: 0,0:09:12.53,0:09:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku tak bisa menjadi\Nvampir yang sempurna?
Dialogue: 0,0:09:20.04,0:09:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku harus...
Dialogue: 0,0:09:33.76,0:09:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kenapa aku harus membawakan\Nuntuk semuanya, sih?
Dialogue: 0,0:09:37.22,0:09:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa suruh kamu payah bersuten.
Dialogue: 0,0:09:41.60,0:09:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:09:44.48,0:09:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:09:49.32,0:09:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahan!
Dialogue: 0,0:09:54.20,0:09:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:09:55.53,0:09:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Camill dan Ruslan?
Dialogue: 0,0:09:57.66,0:09:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dibawa pergi.
Dialogue: 0,0:10:01.00,0:10:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bar bernama Railgun di Printanier.
Dialogue: 0,0:10:05.00,0:10:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya vampir sering ke sana,\Nkami pun menyelinap masuk.
Dialogue: 0,0:10:08.96,0:10:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kami tak menduga itu sarang vampir.
Dialogue: 0,0:10:13.09,0:10:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kami pikir mereka sudah kalah,
Dialogue: 0,0:10:16.14,0:10:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba orang itu muncul.
Dialogue: 0,0:10:23.89,0:10:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat siuman,
Dialogue: 0,0:10:25.84,0:10:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku terkunci di gudang.
Dialogue: 0,0:10:31.32,0:10:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camill! Ruslan!
Dialogue: 0,0:10:37.95,0:10:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak manusia serigala\Nyang dikurung di sana.
Dialogue: 0,0:10:43.12,0:10:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:45.16,0:10:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu motifnya.
Dialogue: 0,0:10:47.75,0:10:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil kabur,
Dialogue: 0,0:10:50.46,0:10:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak bisa menemukan Camill dan Ruslan.
Dialogue: 0,0:10:53.51,0:10:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan salahmu.
Dialogue: 0,0:10:55.51,0:10:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sulit untuk melarikan diri.
Dialogue: 0,0:10:57.09,0:10:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahan.
Dialogue: 0,0:10:58.60,0:11:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa antar kami ke gudang itu?
Dialogue: 0,0:11:00.94,0:11:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa bisa.
Dialogue: 0,0:11:02.10,0:11:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi sekarang.
Dialogue: 0,0:11:03.85,0:11:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita selamatkan Camill dan Ruslan.
Dialogue: 0,0:11:16.45,0:11:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha.
Dialogue: 0,0:11:18.20,0:11:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:11:26.58,0:11:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:11:30.17,0:11:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha, kamu baik-baik saja?
Dialogue: 0,0:11:33.77,0:11:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Altar... Darah.
Dialogue: 0,0:11:39.39,0:11:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa pedang itu
Dialogue: 0,0:11:41.43,0:11:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Altar Darah.
Dialogue: 0,0:11:43.47,0:11:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang?
Dialogue: 0,0:11:47.85,0:11:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sooha!
Dialogue: 0,0:11:53.82,0:11:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja memimpikan Sooha.
Dialogue: 0,0:11:56.78,0:11:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:11:58.11,0:11:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga memimpikannya.
Dialogue: 0,0:11:59.76,0:12:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ada di tempat yang sangat aneh.
Dialogue: 0,0:12:01.85,0:12:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat sangat gelap, seperti gua.
Dialogue: 0,0:12:05.41,0:12:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya berbaring di sana.
Dialogue: 0,0:12:08.87,0:12:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Sooha menyebutkan "pedang"?
Dialogue: 0,0:12:12.84,0:12:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang kita harus membawa pedang itu\Nke Altar Darah.
Dialogue: 0,0:12:38.07,0:12:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya?
Dialogue: 0,0:12:39.72,0:12:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah, kamu merasakan energi Sooha?
Dialogue: 0,0:12:42.37,0:12:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:12:43.74,0:12:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marge atau Dardan juga tidak ada.
Dialogue: 0,0:12:45.61,0:12:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Vaonis benar-benar ada\Ndi tempat seperti ini?
Dialogue: 0,0:12:48.79,0:12:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi orang itu membawa korek api dari sini.
Dialogue: 0,0:12:51.95,0:12:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada alasannya.
Dialogue: 0,0:12:53.38,0:12:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, hati-hati.
Dialogue: 0,0:12:55.34,0:12:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang tidak biasa di sekitar sini.
Dialogue: 0,0:12:57.59,0:13:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada energi yang sangat kuat dari dalam.
Dialogue: 0,0:13:01.51,0:13:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berbeda dari apa pun\Nyang pernah kurasakan.
Dialogue: 0,0:13:12.60,0:13:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Tidak ada orang di dalam.
Dialogue: 0,0:13:15.32,0:13:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hari ini tutup?
Dialogue: 0,0:13:17.67,0:13:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pintunya terbuka.
Dialogue: 0,0:13:21.32,0:13:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana.
Dialogue: 0,0:13:23.07,0:13:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi orang itu berasal dari sana.
Dialogue: 0,0:13:36.63,0:13:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini gudang?
Dialogue: 0,0:13:43.34,0:13:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melihat apa pun di depan.
Dialogue: 0,0:13:45.51,0:13:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya agak berkabut.
Dialogue: 0,0:13:53.90,0:13:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintunya tertutup.
Dialogue: 0,0:13:55.81,0:13:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kucoba.
Dialogue: 0,0:13:59.82,0:14:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau terbuka,\Nakan coba kudobrak.
Dialogue: 0,0:14:03.91,0:14:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:05.95,0:14:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba aku merasa lemah.
Dialogue: 0,0:14:10.87,0:14:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang tidak beres.\NAku tidak bisa bernapas.
Dialogue: 0,0:14:20.09,0:14:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama menunggu kalian.
Dialogue: 0,0:14:23.30,0:14:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga kalian akan datang ke sini.
Dialogue: 0,0:14:26.89,0:14:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa orang ini?
Dialogue: 0,0:14:29.89,0:14:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabut ini tidak akan langsung\Nmembuat kalian pingsan.
Dialogue: 0,0:14:34.81,0:14:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan langsung menguras\Nkekuatan dari tubuh kalian.
Dialogue: 0,0:14:38.02,0:14:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, ayo pergi dari sini!
Dialogue: 0,0:14:42.24,0:14:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbuka!
Dialogue: 0,0:15:01.34,0:15:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada malam bulan purnama,
Dialogue: 0,0:15:03.30,0:15:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu akan menerima kekuatan\Nyang disegel di altar ini.
Dialogue: 0,0:15:08.51,0:15:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi semua itu\Nakhirnya akan menjadi milikku.
Dialogue: 0,0:15:15.64,0:15:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, kamu punya kekuatan itu.
Dialogue: 0,0:15:19.01,0:15:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku mencintaimu.
Dialogue: 0,0:15:21.29,0:15:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, kuharap sebaliknya.
Dialogue: 0,0:15:23.46,0:15:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang punya kekuatan itu
Dialogue: 0,0:15:25.06,0:15:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kamu akan mencintaiku.
Dialogue: 0,0:15:35.08,0:15:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan, lari!
Dialogue: 0,0:15:41.25,0:15:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku hilang.
Dialogue: 0,0:15:50.26,0:15:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku tidak bisa berubah\Nmeski aku mau.
Dialogue: 0,0:15:53.31,0:15:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus mengalahkan orang\Nyang mengendalikan kabut ini!
Dialogue: 0,0:15:56.31,0:15:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah, cari orang itu!
Dialogue: 0,0:16:06.86,0:16:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak bisa menggunakan\Nkekuatan kalian lagi, bukan?
Dialogue: 0,0:16:16.96,0:16:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heli.
Dialogue: 0,0:16:18.87,0:16:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Solon.
Dialogue: 0,0:16:21.04,0:16:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion.
Dialogue: 0,0:16:23.46,0:16:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jino.
Dialogue: 0,0:16:25.80,0:16:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaan.
Dialogue: 0,0:16:27.97,0:16:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jakah.
Dialogue: 0,0:16:29.93,0:16:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noa.
Dialogue: 0,0:16:34.26,0:16:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ingat.
Dialogue: 0,0:16:40.31,0:16:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, kalian semua bangsawan vampir.
Dialogue: 0,0:17:30.36,0:17:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:31.79,0:17:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kekuatan mereka kembali?
Dialogue: 0,0:17:34.24,0:17:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Kalau begitu...
Dialogue: 0,0:17:39.71,0:17:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabutnya makin tebal!
Dialogue: 0,0:17:43.25,0:17:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NSekarang kalian tak bisa bergerak, kan?
Dialogue: 0,0:17:47.96,0:17:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertangkap! Dia di sini!
Dialogue: 0,0:18:12.70,0:18:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabutnya hilang.
Dialogue: 0,0:18:17.53,0:18:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?\NMereka semua tumbang.
Dialogue: 0,0:18:20.37,0:18:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena kita membunuh orang itu?
Dialogue: 0,0:18:22.91,0:18:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin jadi vampir\Nkarena orang itu menggigit mereka.
Dialogue: 0,0:18:25.52,0:18:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka akan mati bersamanya.
Dialogue: 0,0:18:27.38,0:18:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya baik-baik saja?
Dialogue: 0,0:18:28.94,0:18:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:30.51,0:18:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran kenapa tiba-tiba\Nada tanda di tanganku.
Dialogue: 0,0:18:32.99,0:18:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku sadar.
Dialogue: 0,0:18:34.63,0:18:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu saja.
Dialogue: 0,0:18:36.34,0:18:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku juga jauh lebih ringan\Ndaripada sebelumnya.
Dialogue: 0,0:18:38.51,0:18:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa lebih kuat.
Dialogue: 0,0:18:41.39,0:18:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat tanda ini muncul di tanganku,
Dialogue: 0,0:18:43.45,0:18:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa berubah menjadi serigala.
Dialogue: 0,0:18:45.15,0:18:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Sooha membantu kita.
Dialogue: 0,0:18:52.24,0:18:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:18:54.24,0:18:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada satu yang hidup.
Dialogue: 0,0:18:55.99,0:18:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana perginya teman-temanmu?
Dialogue: 0,0:19:00.54,0:19:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istana.
Dialogue: 0,0:19:09.63,0:19:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya istana sebelumnya?
Dialogue: 0,0:19:12.21,0:19:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu seribu tahun lalu.
Dialogue: 0,0:19:14.76,0:19:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dulu istana itu ada di sekitar sini.
Dialogue: 0,0:19:21.39,0:19:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Automnal?
Dialogue: 0,0:19:23.43,0:19:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reruntuhan istana itu menjadi Balai Kota.
Dialogue: 0,0:19:33.44,0:19:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangnya.
Dialogue: 0,0:19:36.24,0:19:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali terakhir aku memegang pedang\Nadalah saat melawan Dardan di istana itu.
Dialogue: 0,0:19:42.29,0:19:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin...
Dialogue: 0,0:19:50.75,0:19:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sinilah teman-teman kita\Ndikurung sebelumnya.
Dialogue: 0,0:19:54.21,0:19:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada orang di sini.
Dialogue: 0,0:19:55.51,0:19:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah ini tempatnya?
Dialogue: 0,0:19:58.59,0:20:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah dipindahkan.
Dialogue: 0,0:20:05.39,0:20:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya tempat vampir\Nmengurung kami untuk sementara.
Dialogue: 0,0:20:10.73,0:20:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya mereka akan dikirim ke kapal
Dialogue: 0,0:20:13.84,0:20:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dipindahkan ke kota bernama Automnal.
Dialogue: 0,0:20:17.11,0:20:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:20:18.16,0:20:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka meninggalkanku.
Dialogue: 0,0:20:19.97,0:20:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa pria tua tak terlalu berguna.
Dialogue: 0,0:20:23.79,0:20:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana nasib rekan-rekan kita\Nyang dikirim ke sana?
Dialogue: 0,0:20:26.96,0:20:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu.
Dialogue: 0,0:20:28.56,0:20:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya tahu\Nmereka mencari serigala istimewa.
Dialogue: 0,0:20:35.09,0:20:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serigala istimewa?
Dialogue: 0,0:20:39.68,0:20:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dardan, leluhur vampir, menginginkan\Nkemampuan manusia serigala kita.
Dialogue: 0,0:20:45.89,0:20:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengendalikan kita,
Dialogue: 0,0:20:48.32,0:20:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menginginkan kekuatan serigala itu.
Dialogue: 0,0:20:56.65,0:20:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka keluar satu per satu.
Dialogue: 0,0:20:59.95,0:21:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini bukan vampir biasa.
Dialogue: 0,0:21:03.26,0:21:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, bertarunglah sekuat tenaga!
Dialogue: 0,0:21:07.37,0:21:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia orangnya?
Dialogue: 0,0:21:08.87,0:21:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti itu...
Dialogue: 0,0:21:16.00,0:21:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak Muda!
Dialogue: 0,0:21:17.01,0:21:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana kamu mendapatkan kalung itu?
Dialogue: 0,0:21:20.88,0:21:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini warisan keluargaku\Nselama beberapa generasi.
Dialogue: 0,0:21:24.47,0:21:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak diragukan lagi.\NIni simbol Lycanthrope.
Dialogue: 0,0:21:29.17,0:21:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope?
Dialogue: 0,0:21:34.61,0:21:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:21:36.13,0:21:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:21:37.79,0:21:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:21:39.82,0:21:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lycanthrope adalah keturunan\NDewa Serigala Kerajaan Vargr kuno,
Dialogue: 0,0:21:44.82,0:21:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mewarisi darah Vargr.
Dialogue: 0,0:21:47.81,0:21:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, kamu manusia serigala\Nyang dipilih para dewa.
Dialogue: 0,0:23:33.06,0:23:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, di Episode 10,
Dialogue: 0,0:23:36.06,0:23:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan Cembung Akhir:
Dialogue: 0,0:23:37.99,0:23:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan Mati-matian di Automnal.
