Dialogue: 0,0:04:19.23,0:04:21.72,tanda,,0000,0000,0000,,"ANGGOTA LEGISLATIF ITU MENDUKUNG CALON WANITA"
Dialogue: 0,0:04:26.50,0:04:29.14,tanda,,0000,0000,0000,,"PUTRA KANDUNG MANTAN ANGGOTA B-KOMACHI, HOSHINO"
Dialogue: 0,0:04:51.33,0:04:52.26,tanda,,0000,0000,0000,,SUKA!\NAKU SELALU MENDUKUNGMU!
Dialogue: 0,0:10:40.20,0:10:42.66,tanda,,0000,0000,0000,,STUDIO GOTANDA
Dialogue: 0,0:10:42.66,0:10:44.52,tanda,,0000,0000,0000,,AI
Dialogue: 0,0:11:06.81,0:11:10.48,tanda,,0000,0000,0000,,PROPOSAL\N"KEBOHONGAN 15 TAHUN JUDUL SEMENTARA)
Dialogue: 0,0:11:14.92,0:11:16.94,tanda,,0000,0000,0000,,PROPOSAL\N"KEBOHONGAN 15 TAHUN JUDUL SEMENTARA)
Dialogue: 0,0:11:53.40,0:11:54.31,tanda,,0000,0000,0000,,AWAL DARI SEGALANYA
Dialogue: 0,0:13:42.16,0:13:44.92,tanda,,0000,0000,0000,,"B-KOMACHI"
Dialogue: 0,0:15:14.01,0:15:15.75,tanda,,0000,0000,0000,,KEBOHONGAN 15 TAHUN
Dialogue: 0,0:16:12.45,0:16:13.64,tanda,,0000,0000,0000,,PROPOSAL: KEBOHONGAN 15 TAHUN\NNASKAH: GOTANDA TAISHI, HOSHINO AQUA
Dialogue: 0,0:16:32.93,0:16:34.06,tanda,,0000,0000,0000,,NASKAH: GOTANDA TAISHI, HOSHINO AQUA
Dialogue: 0,0:16:50.48,0:16:51.75,tanda,,0000,0000,0000,,KEBOHONGAN
Dialogue: 0,0:17:11.76,0:17:12.31,tanda,,0000,0000,0000,,PROPOSAL: KEBOHONGAN 15 TAHUN\NNASKAH: GOTANDA TAISHI, HOSHINO AQUA
Dialogue: 0,0:17:41.12,0:17:42.26,tanda,,0000,0000,0000,,KATAYOSE YURA
Dialogue: 0,0:18:03.56,0:18:05.52,tanda,,0000,0000,0000,,SISTEM KEANGGOTAAN\NBAR MARUCHAN
Dialogue: 0,0:18:20.41,0:18:21.04,tanda,,0000,0000,0000,,AKTRIS\NKATAYOSE YURA
Dialogue: 0,0:18:31.59,0:18:32.84,tanda,,0000,0000,0000,,PETUNJUK TV\NEDISI SPESIAL - KATAYOSE YURA
Dialogue: 0,0:22:06.55,0:22:09.93,tanda,,0000,0000,0000,,EPISODE 32: RENCANA
Dialogue: 0,0:00:00.00,0:00:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}【OSHI NO KO】
Dialogue: 0,0:01:32.32,0:01:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, kedua anak Nona Ai\Naktif di dunia hiburan.
Dialogue: 0,0:01:37.18,0:01:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka telah bangkit dari tragedi...
Dialogue: 0,0:01:41.23,0:01:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?!
Dialogue: 0,0:01:43.06,0:01:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus lakukan ini.
Dialogue: 0,0:01:45.17,0:01:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kebaikan Arima,
Dialogue: 0,0:01:47.10,0:01:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga untuk kita berdua.
Dialogue: 0,0:01:49.32,0:01:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk "kita"?
Dialogue: 0,0:01:51.21,0:01:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong!
Dialogue: 0,0:01:51.95,0:01:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbuatanmu itu sama seperti\Nmenggali kuburan orang.
Dialogue: 0,0:01:54.17,0:01:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau telah merusak reputasi Mama!
Dialogue: 0,0:01:57.32,0:02:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebohongan yang Mama pertahankan\Nsebagai idola...
Dialogue: 0,0:02:00.86,0:02:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah kau hancurkan dengan cara ini...
Dialogue: 0,0:02:04.26,0:02:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau tak sedih saat melakukan ini?
Dialogue: 0,0:02:06.88,0:02:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku sedih.
Dialogue: 0,0:02:08.74,0:02:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri pernah bilang,
Dialogue: 0,0:02:10.43,0:02:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu mau menyelamatkan teman\Nmeski metodenya menyakitkan.
Dialogue: 0,0:02:16.81,0:02:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira apa pendapat Mama\Nsaat melihat kita dari surga?
Dialogue: 0,0:02:20.13,0:02:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dikhianati\Noleh putra kandungnya sendiri.
Dialogue: 0,0:02:22.50,0:02:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin Ai
Dialogue: 0,0:02:24.26,0:02:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan tersenyum dan berkata,\N"Waduh, akhirnya ketahuan juga."
Dialogue: 0,0:02:28.75,0:02:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai sudah tiada.
Dialogue: 0,0:02:32.03,0:02:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi ini harus dimanfaatkan\Noleh orang-orang yang masih hidup.
Dialogue: 0,0:02:39.90,0:02:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:02:41.67,0:02:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu pemikiranmu.
Dialogue: 0,0:02:45.21,0:02:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:02:46.53,0:02:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, reputasi Senior terselamatkan,
Dialogue: 0,0:02:48.57,0:02:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan popularitas kita akan ikut meningkat.
Dialogue: 0,0:02:51.41,0:02:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada pihak yang dirugikan, ya.
Dialogue: 0,0:02:54.26,0:02:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berubah.
Dialogue: 0,0:02:56.41,0:03:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aqua yang dulu akan selalu\Nmengutamakan kebaikan Ai.
Dialogue: 0,0:03:00.88,0:03:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rela berkorban segala macam demi Ai,
Dialogue: 0,0:03:05.08,0:03:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kamu menyayangi Mama\Nlebih dari siapa pun...
Dialogue: 0,0:03:08.15,0:03:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa merasakan ikatan\Nyang menyerupai sebuah keluarga.
Dialogue: 0,0:03:12.75,0:03:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang kamu tak berpikir\Nseperti itu lagi, 'kan?
Dialogue: 0,0:03:16.08,0:03:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah.
Dialogue: 0,0:03:17.15,0:03:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong.
Dialogue: 0,0:03:18.86,0:03:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong, pembohong.
Dialogue: 0,0:03:21.55,0:03:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembohong, pembohong, pembohong.
Dialogue: 0,0:03:24.19,0:03:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua pembohong.
Dialogue: 0,0:03:27.17,0:03:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan pernah\Nmenganggap Aqua keluargaku lagi.
Dialogue: 0,0:03:32.92,0:03:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, Kak.
Dialogue: 0,0:03:41.12,0:03:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku juga menganggap\Nkalian sebagai keluargaku.
Dialogue: 0,0:03:45.43,0:03:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu memang dirut agensi,\Nmanfaatkan situasi ini dengan baik.
Dialogue: 0,0:03:59.19,0:04:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hal yang perlu dilakukan.
Dialogue: 0,0:04:01.99,0:04:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya demi memastikan kamu\Ntetap hidup di dunia ini setelah aku tak ada.
Dialogue: 0,0:04:10.79,0:04:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aqua dan Ruby mengungkapkan\Nbahwa mereka anak kandung Ai.
Dialogue: 0,0:04:15.23,0:04:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah satu minggu, dua minggu berlalu...
Dialogue: 0,0:04:19.23,0:04:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan setelah beberapa waktu setelah itu,
Dialogue: 0,0:04:22.35,0:04:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artikel tentangku tak pernah\Ndimuat koran atau majalah.
Dialogue: 0,0:04:26.50,0:04:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}AQUA Alasannya tak perlu dipikirkan lagi,
Dialogue: 0,0:04:29.75,0:04:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aqua telah melindungiku.
Dialogue: 0,0:04:34.30,0:04:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia lakukan ini\Ndemi melindungi seluruh B-Komachi,
Dialogue: 0,0:04:39.32,0:04:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau mungkin dia punya perhitungan lain.
Dialogue: 0,0:04:43.28,0:04:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artikel itu menyebabkan kegemparan besar.
Dialogue: 0,0:04:46.51,0:04:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang bergabung dalam topik ini,
Dialogue: 0,0:04:49.35,0:04:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menimbulkan berbagai perdebatan.
Dialogue: 0,0:04:52.26,0:04:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, mereka hanya anak-anak\Nyang bekerja sebagai penghormatan untuk sang ibu,
Dialogue: 0,0:04:57.42,0:05:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan itulah yang mengukuhkan cerita itu\Nsebagai kisah yang menyentuh.
Dialogue: 0,0:05:03.26,0:05:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di detik-detik terakhirnya,\Nibuku sempat berkata,
Dialogue: 0,0:05:06.08,0:05:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ruby, mungkin saat besar nanti,\Nkamu akan menjadi idola."
Dialogue: 0,0:05:10.10,0:05:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Impianku adalah
Dialogue: 0,0:05:12.03,0:05:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mewujudkan impian yang tak sempat\NIbu wujudkan, yaitu tampil di Dome.
Dialogue: 0,0:05:19.92,0:05:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Aqua, 'kan?
Dialogue: 0,0:05:23.15,0:05:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu... Aku selalu mendukungmu!
Dialogue: 0,0:05:26.75,0:05:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada beberapa situasi\Nyang menyulitkanmu, tapi berjuanglah!
Dialogue: 0,0:05:30.66,0:05:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Popularitas mereka berdua meningkat pesat\Nsehingga dicari banyak stasiun televisi,
Dialogue: 0,0:05:35.35,0:05:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan perlahan menjadi\Nsalah seorang bintang papan atas.
Dialogue: 0,0:05:39.32,0:05:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga dapat sedikit banyak\Nkeuntungannya,
Dialogue: 0,0:05:43.21,0:05:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pekerjaan untukku mulai bertambah,
Dialogue: 0,0:05:45.35,0:05:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan semua orang menjalani\Nhari-hari yang sibuk.
Dialogue: 0,0:06:06.17,0:06:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah baca artikelnya.
Dialogue: 0,0:06:11.61,0:06:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku ingat-ingat lagi,
Dialogue: 0,0:06:13.08,0:06:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat kita pertama bertemu,\NAi juga ikut berakting.
Dialogue: 0,0:06:18.57,0:06:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang saat itu jauh lebih ceria\Ndibandingkan yang sekarang.
Dialogue: 0,0:06:23.79,0:06:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih belum bisa merelakannya, ya?
Dialogue: 0,0:06:26.46,0:06:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:06:27.83,0:06:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berbohong.
Dialogue: 0,0:06:29.46,0:06:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, hatimu jauh lebih sensitif\Ndari yang kamu bayangkan.
Dialogue: 0,0:06:33.08,0:06:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok tahu.
Dialogue: 0,0:06:36.39,0:06:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang tahu, kok.
Dialogue: 0,0:06:38.03,0:06:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hanya sedikit,
Dialogue: 0,0:06:39.81,0:06:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku paham betapa sakitnya\Nmelihat orang yang kita sayang pergi menjauh.
Dialogue: 0,0:06:44.63,0:06:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ibuku...
Dialogue: 0,0:06:46.77,0:06:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau memang masih hidup,\Ntapi saat aku meniti karier di dunia hiburan,
Dialogue: 0,0:06:50.26,0:06:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau perlahan berhenti memedulikanku.
Dialogue: 0,0:06:53.66,0:06:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, masalahku tak seberapa\Njika dibandingkan denganmu.
Dialogue: 0,0:06:59.39,0:07:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:07:07.79,0:07:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu melakukan hal seperti itu?
Dialogue: 0,0:07:10.32,0:07:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu untuk membatalkan artikel tentangku?
Dialogue: 0,0:07:13.15,0:07:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau iya,
Dialogue: 0,0:07:14.46,0:07:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rahasia sebesar ini tak sepadan\Ndengan masalah yang kuakibatkan.
Dialogue: 0,0:07:19.06,0:07:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau... kamu punya alasan lain?
Dialogue: 0,0:07:22.08,0:07:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tak perlu memikirkan soal itu.
Dialogue: 0,0:07:24.86,0:07:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu?
Dialogue: 0,0:07:26.46,0:07:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, kamu, Ruby, dan MEM
Dialogue: 0,0:07:28.55,0:07:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa melanjutkan aktivitas B-Komachi.
Dialogue: 0,0:07:32.03,0:07:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja sudah cukup, 'kan?
Dialogue: 0,0:07:35.75,0:07:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:07:37.48,0:07:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga,\Naku berterima kasih padamu.
Dialogue: 0,0:07:40.77,0:07:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seratus kali lebih gampangan\Ndari yang kamu pikirkan.
Dialogue: 0,0:07:43.90,0:07:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, lebih waspada\N100 kali lipat dari sekarang.
Dialogue: 0,0:07:46.01,0:07:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:07:50.17,0:07:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku akan segera berhenti\Nmenjadi idola.
Dialogue: 0,0:07:55.77,0:07:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:07:57.39,0:07:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku harus menentukan sikap.
Dialogue: 0,0:08:00.12,0:08:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, insiden kali ini\Nmembuatku menyadari satu hal.
Dialogue: 0,0:08:04.21,0:08:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada dasarnya, aku tak cocok\Nmenjadi seorang idola,
Dialogue: 0,0:08:07.48,0:08:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bagaimanapun juga,\Naku ingin menjadi seorang aktris.
Dialogue: 0,0:08:11.21,0:08:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku bukan bermaksud berhenti\Nhari ini atau besok.
Dialogue: 0,0:08:14.26,0:08:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi Ruby dan MEM, aku berencana\Nuntuk terus berjuang sampai saat-saat terakhir.
Dialogue: 0,0:08:19.72,0:08:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:08:22.70,0:08:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau jadi penggemarku,\Nini kesempatanmu.
Dialogue: 0,0:08:26.52,0:08:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pepatahnya, 'kan?\N"Dukung idolamu selagi masih sempat."
Dialogue: 0,0:08:30.90,0:08:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-kata yang bijak.
Dialogue: 0,0:08:38.95,0:08:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau muncul di hadapanku\Nsetelah melakukan hal semacam itu!
Dialogue: 0,0:08:44.81,0:08:46.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin diskusi denganmu.
Dialogue: 0,0:08:46.01,0:08:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Diskusi apa?!
Dialogue: 0,0:08:48.46,0:08:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menggali kuburan ibumu sendiri
Dialogue: 0,0:08:51.52,0:08:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menghancurkan reputasinya!
Dialogue: 0,0:08:53.32,0:08:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria biadab yang menghalalkan segala cara\Nhanya untuk terkenal...
Dialogue: 0,0:08:56.41,0:08:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diskusi macam apa yang harus\Nkulakukan denganmu, hah?!
Dialogue: 0,0:08:59.83,0:09:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu nama pria
Dialogue: 0,0:09:01.43,0:09:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menjadi dalang kasus itu
Dialogue: 0,0:09:03.75,0:09:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyebabkan kematian Ai.
Dialogue: 0,0:09:08.15,0:09:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:09:09.68,0:09:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelaku yang membunuh Ai...?
Dialogue: 0,0:09:11.10,0:09:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?\NCepat katakan!
Dialogue: 0,0:09:12.51,0:09:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:09:13.90,0:09:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku menjawabmu, kamu pasti\Nlangsung pergi membunuh pria itu.
Dialogue: 0,0:09:17.08,0:09:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:09:18.23,0:09:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bisa membiarkan bajingan itu\Nhidup tenang di dunia ini?!
Dialogue: 0,0:09:22.57,0:09:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:09:25.90,0:09:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekadar membunuhnya tak akan cukup.
Dialogue: 0,0:09:32.68,0:09:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa rencanamu?
Dialogue: 0,0:09:34.90,0:09:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebenarnya niatmu\Nmemberitahuku hal ini?
Dialogue: 0,0:09:40.30,0:09:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil aku terus berpikir,
Dialogue: 0,0:09:44.88,0:09:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan cara apa aku harus\Nmembalas dendam pada pria itu.
Dialogue: 0,0:09:48.23,0:09:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Metode seperti apa\Nyang akan paling menyiksanya.
Dialogue: 0,0:09:52.59,0:09:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, rencana awal yang kutulis\Nberdasarkan imajinasiku belaka
Dialogue: 0,0:09:56.30,0:09:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada bedanya dengan coretan\Nanak kecil yang sedang merajuk.
Dialogue: 0,0:09:59.57,0:10:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana yang egois, sok tahu, dan ceroboh.
Dialogue: 0,0:10:03.92,0:10:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:10:05.99,0:10:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak hari aku mengetahui perasaan Ai,
Dialogue: 0,0:10:08.81,0:10:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kartu-kartu ideal\Ntelah berkumpul di tanganku.
Dialogue: 0,0:10:12.88,0:10:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana yang mustahil terwujud\Ntanpa suatu mukjizat itu
Dialogue: 0,0:10:18.08,0:10:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya selesai,\Ndan benar-benar bisa dilakukan.
Dialogue: 0,0:10:22.66,0:10:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku hanya perlu lakukan.
Dialogue: 0,0:10:25.63,0:10:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Babak terakhir telah dimulai.
Dialogue: 0,0:10:28.37,0:10:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di detik berita tentang Ai dipublikasikan,
Dialogue: 0,0:10:30.79,0:10:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak bisa mundur lagi.
Dialogue: 0,0:10:34.03,0:10:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bantu aku
Dialogue: 0,0:10:36.48,0:10:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyudutkan pria itu.
Dialogue: 0,0:10:44.55,0:10:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Hoshino Ai.
Dialogue: 0,0:10:47.15,0:10:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua anakmu tumbuh besar\Ndengan sehat walafiat.
Dialogue: 0,0:11:11.55,0:11:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tiba saatnya aku menepati janji.
Dialogue: 0,0:11:23.78,0:11:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh.
Dialogue: 0,0:11:25.85,0:11:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ketiduran.
Dialogue: 0,0:11:31.27,0:11:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bawa anak ini pulang bersamamu.
Dialogue: 0,0:11:34.05,0:11:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:11:35.63,0:11:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih ingin melihatnya lebih lama.
Dialogue: 0,0:11:37.32,0:11:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:11:38.87,0:11:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena jarang-jarang Aqua\Nbisa akrab dengan orang lain.
Dialogue: 0,0:11:42.05,0:11:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia menganggapmu\Nsebagai ayah kandungnya.
Dialogue: 0,0:11:45.47,0:11:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:11:46.87,0:11:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tiga puluhan yang masih melajang\Npasti senang dengar itu.
Dialogue: 0,0:11:54.34,0:11:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Sutradara,\Nkamu yang menulis cerita ini, 'kan?
Dialogue: 0,0:11:58.36,0:12:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari naskahnya saja kelihatan\Nini film yang menarik.
Dialogue: 0,0:12:00.72,0:12:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caramu bisa\Nmenulis cerita sebagus ini?
Dialogue: 0,0:12:03.40,0:12:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:05.18,0:12:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, semua bergantung pada\Nbisa tidaknya kamu menulis emosi yang asli.
Dialogue: 0,0:12:10.09,0:12:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya, dalam karya ini,
Dialogue: 0,0:12:12.09,0:12:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}fokus utamanya adalah inferioritas\Nsi protagonis dan keinginannya menjadi cantik.
Dialogue: 0,0:12:15.98,0:12:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan memalsukan emosi itu\Nhanya demi kemudahan alur cerita.
Dialogue: 0,0:12:20.54,0:12:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambil emosi yang asli.
Dialogue: 0,0:12:22.80,0:12:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu poin penting
Dialogue: 0,0:12:24.27,0:12:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menciptakan sebuah karya.
Dialogue: 0,0:12:28.67,0:12:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, butuh keahlian untuk memperlihatkan\Nhal itu dengan baik pada penonton.
Dialogue: 0,0:12:33.20,0:12:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah.
Dialogue: 0,0:12:34.80,0:12:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya hebat.\NKayak profesional!
Dialogue: 0,0:12:37.18,0:12:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:39.83,0:12:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya!
Dialogue: 0,0:12:40.98,0:12:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agensi kami merencanakan pembuatan\Nfilm dokumenter tentang B-Komachi.
Dialogue: 0,0:12:45.76,0:12:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau Pak Sutradara\Nyang buatkan filmnya?
Dialogue: 0,0:12:48.58,0:12:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa harus aku?
Dialogue: 0,0:12:50.69,0:12:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku merasa Pak Sutradara\Nbisa buat film yang bagus.
Dialogue: 0,0:12:54.00,0:12:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau, ya? Ya?
Dialogue: 0,0:12:55.96,0:12:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembarangan saja.
Dialogue: 0,0:12:56.98,0:12:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terlihat seperti ini,\Naku orang yang sibuk.
Dialogue: 0,0:12:59.03,0:13:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu, dong.\NKumohon.
Dialogue: 0,0:13:01.23,0:13:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang...
Dialogue: 0,0:13:02.16,0:13:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, terima saja.
Dialogue: 0,0:13:03.76,0:13:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:04.65,0:13:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:13:05.96,0:13:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang...
Dialogue: 0,0:13:07.49,0:13:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:13:36.03,0:13:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak saat itu,
Dialogue: 0,0:13:37.76,0:13:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sesekali meluangkan waktu\Nmembuat dokumentasi formasi lama B-Komachi.
Dialogue: 0,0:13:42.16,0:13:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal tayangnya sudah ditentukan.
Dialogue: 0,0:13:45.07,0:13:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu syuting\Ncuplikan konser di Dome.
Dialogue: 0,0:13:49.94,0:13:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat di saat itulah
Dialogue: 0,0:13:52.85,0:13:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}insiden itu terjadi.
Dialogue: 0,0:13:55.89,0:13:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai tewas dibunuh.
Dialogue: 0,0:13:57.83,0:13:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segalanya pun menjadi sia-sia.
Dialogue: 0,0:14:00.98,0:14:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, Ai menitipkan pesan\Nmenjelang kematiannya,
Dialogue: 0,0:14:03.72,0:14:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bilang ingin minta maaf padaku.
Dialogue: 0,0:14:06.78,0:14:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal akulah yang seharusnya\Nmeminta maaf padanya.
Dialogue: 0,0:14:10.94,0:14:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah salah satu dari sedikit orang dewasa\Nyang bisa membantunya.
Dialogue: 0,0:14:23.47,0:14:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun, dah.
Dialogue: 0,0:14:24.85,0:14:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terakhir membuat film dokumenter\Nsaat masih sekolah dulu.
Dialogue: 0,0:14:29.00,0:14:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik.
Dialogue: 0,0:14:30.45,0:14:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sutradaranya,\Naku janji karya ini takkan membosankan.
Dialogue: 0,0:14:34.36,0:14:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu melakukan akting-akting aneh,
Dialogue: 0,0:14:36.63,0:14:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menunjukkan sosok yang dibentuk\Ndengan kebohongan seperti biasanya,
Dialogue: 0,0:14:40.72,0:14:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa menghentikan syutingnya kapan saja.
Dialogue: 0,0:14:44.65,0:14:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Sutradara pernah bilang,
Dialogue: 0,0:14:46.74,0:14:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu hanya ingin mengambil emosi asli.
Dialogue: 0,0:14:49.52,0:14:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kamu yakin ingin emosi yang asli?
Dialogue: 0,0:14:52.89,0:14:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syuting dengan aku tanpa kebohongan
Dialogue: 0,0:14:55.20,0:14:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan menjadi bagian\Nyang tak bisa dipakai, lo.
Dialogue: 0,0:14:58.96,0:15:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tak masalah dengan itu,
Dialogue: 0,0:15:01.36,0:15:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan berhenti berbohong.
Dialogue: 0,0:15:06.25,0:15:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong rekam aku yang sesungguhnya.
Dialogue: 0,0:15:15.78,0:15:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Film yang diangkat dari kisah nyata, ya.
Dialogue: 0,0:15:20.27,0:15:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naskahnya secara garis besar sudah rampung.
Dialogue: 0,0:15:23.07,0:15:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengisahkan seorang idola\Nyang menjadi bintang besar,
Dialogue: 0,0:15:26.14,0:15:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dibunuh oleh penggemar\Npada hari dia tampil di panggung Dome.
Dialogue: 0,0:15:31.14,0:15:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hal seperti ini bisa terjadi?
Dialogue: 0,0:15:33.63,0:15:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konspirasi apa yang tersembunyi\Ndi balik semuanya?
Dialogue: 0,0:15:38.07,0:15:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang Ai, ya?
Dialogue: 0,0:15:39.67,0:15:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:41.20,0:15:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini film adaptasi realistis berdasarkan\Nkasus pembunuhan idola yang terjadi 14 tahun lalu.
Dialogue: 0,0:15:46.45,0:15:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin reka ulang kejadiannya\Ndengan aktor-aktor masa kini.
Dialogue: 0,0:15:55.34,0:15:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi ceritanya memang sangat menarik,
Dialogue: 0,0:15:58.49,0:15:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini agak sulit dieksekusi.
Dialogue: 0,0:16:00.87,0:16:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak adegan yang terlalu sensitif\Ndan spekulasi terhadap insiden itu.
Dialogue: 0,0:16:06.03,0:16:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah pastikan semua ini fakta?
Dialogue: 0,0:16:08.45,0:16:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai ada yang salah,\Nkamu bisa dituntut banyak pihak.
Dialogue: 0,0:16:13.67,0:16:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Distributor film besar dan sponsor\Ntak akan mau bergabung.
Dialogue: 0,0:16:17.29,0:16:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita tak bisa dapat dana.
Dialogue: 0,0:16:20.12,0:16:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, proyek ini...
Dialogue: 0,0:16:21.47,0:16:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya sudah diverifikasi.
Dialogue: 0,0:16:24.29,0:16:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena semuanya diucapkan oleh Ai sendiri.
Dialogue: 0,0:16:29.67,0:16:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang menulis naskah ini\Nadalah Pak Sutradara
Dialogue: 0,0:16:34.09,0:16:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan anak kandung Ai, yaitu aku sendiri.
Dialogue: 0,0:16:40.94,0:16:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:42.83,0:16:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu ceritanya.
Dialogue: 0,0:16:45.56,0:16:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku merasa, baik Gotanda\Nmaupun aku, telah disetir olehmu...
Dialogue: 0,0:16:51.78,0:16:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika memang begitu,\Nproyek ini pasti sangat menarik.
Dialogue: 0,0:16:57.20,0:16:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti.
Dialogue: 0,0:17:01.07,0:17:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:02.63,0:17:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang memegang\Ntanggung jawab atas film ini.
Dialogue: 0,0:17:05.96,0:17:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya aku yang pantas menjadi\Nproduser film ini.
Dialogue: 0,0:17:12.33,0:17:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daftar aktor sementara sebagai berikut.
Dialogue: 0,0:17:15.29,0:17:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoshino Ruby.
Dialogue: 0,0:17:16.78,0:17:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}MEM-Cho.
Dialogue: 0,0:17:18.05,0:17:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arima Kana.
Dialogue: 0,0:17:19.31,0:17:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Narushima Melt.
Dialogue: 0,0:17:20.86,0:17:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shuranui Frill.
Dialogue: 0,0:17:22.56,0:17:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurokawa Akane.
Dialogue: 0,0:17:24.27,0:17:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himekawa Taiki.
Dialogue: 0,0:17:26.16,0:17:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Hoshino Aqua.
Dialogue: 0,0:17:30.45,0:17:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara diatur seperti ini.
Dialogue: 0,0:17:32.18,0:17:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, siapa protagonis,\Nyang memerankan Ai?
Dialogue: 0,0:17:35.14,0:17:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya mencari aktris\Nyang sedang naik daun.
Dialogue: 0,0:17:38.27,0:17:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku punya satu kandidat di benakku.
Dialogue: 0,0:17:42.29,0:17:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Katayose Yura.
Dialogue: 0,0:17:44.45,0:17:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kalian mengosongkan\Njadwal musim semi tahun depannya untukku?
Dialogue: 0,0:17:48.54,0:17:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar...
Dialogue: 0,0:17:50.47,0:17:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada beberapa tawaran dari tempat lain,
Dialogue: 0,0:17:53.18,0:17:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami banyak berutang budi\Npada Pak Kaburagi.
Dialogue: 0,0:17:56.47,0:17:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jamin dia dapat peran utama.
Dialogue: 0,0:17:59.78,0:18:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:18:01.16,0:18:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya untuk\Nmusim semi tahun depan.
Dialogue: 0,0:18:08.80,0:18:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asli. Bikin orang tidak tenang saja!
Dialogue: 0,0:18:12.47,0:18:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, tambah satu gelas\Nracikan spesial Maru lagi.
Dialogue: 0,0:18:15.25,0:18:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:16.67,0:18:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.
Dialogue: 0,0:18:18.38,0:18:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau ada penggemarmu yang lihat?
Dialogue: 0,0:18:21.07,0:18:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktris yang begitu populer\Nmalah minum-minum seperti ini.
Dialogue: 0,0:18:26.58,0:18:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph.
Dialogue: 0,0:18:27.87,0:18:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, pekerjaan ini\Nhanya bisa menumpuk stres.
Dialogue: 0,0:18:32.87,0:18:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan sanggup\Nkalau tak ada tempat pelampiasan.
Dialogue: 0,0:18:37.20,0:18:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu, tidak? Hari ini manajerku\Nbawa tawaran film.
Dialogue: 0,0:18:41.29,0:18:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya minta kosongkan waktu,\Ntapi isinya belum bisa dipastikan.
Dialogue: 0,0:18:46.80,0:18:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu hal lumrah\Nuntuk syuting sinetron, 'kan?
Dialogue: 0,0:18:49.67,0:18:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini tawaran film, lo.
Dialogue: 0,0:18:52.52,0:18:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manajer dan Pak Produser\Nbenar-benar memperlakukanku dengan asal.
Dialogue: 0,0:18:57.07,0:19:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang saja, rasanya mereka\Nhanya memanfaatkan popularitasku.
Dialogue: 0,0:19:01.18,0:19:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin tidak seperti itu.
Dialogue: 0,0:19:03.23,0:19:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yura punya wajah yang cantik\Ndan bakat akting yang diakui publik.
Dialogue: 0,0:19:07.20,0:19:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:08.83,0:19:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang, ya. Kalau mau minum\Nharus ajak Kak Miki!
Dialogue: 0,0:19:10.94,0:19:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo. Minum lagi.
Dialogue: 0,0:19:11.94,0:19:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ah... Wah...
Dialogue: 0,0:19:14.31,0:19:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan yang dikenalkan oleh produser itu
Dialogue: 0,0:19:16.75,0:19:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebanyakan adaptasi suatu karya\Nyang targetnya anak-anak muda.
Dialogue: 0,0:19:20.03,0:19:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah 25 tahun,\Nmana cocok pakai seragam sekolah.
Dialogue: 0,0:19:23.80,0:19:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peran seperti itu sebaiknya\Ndimainkan oleh siswi SMA sungguhan.
Dialogue: 0,0:19:28.00,0:19:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiranui Frill masih siswi SMA, 'kan?
Dialogue: 0,0:19:31.88,0:19:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melihat belakangan ini...
Dialogue: 0,0:19:34.52,0:19:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, lo. Hoshino Ruby.
Dialogue: 0,0:19:36.96,0:19:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang menjadi perhatian publik, 'kan?
Dialogue: 0,0:19:38.98,0:19:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia.
Dialogue: 0,0:19:41.03,0:19:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sedang memerhatikannya.
Dialogue: 0,0:19:42.85,0:19:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:19:44.16,0:19:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sedang kebanjiran\Ntawaran pekerjaan.
Dialogue: 0,0:19:47.03,0:19:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,\Nwajah cantik selalu laku di pasaran.
Dialogue: 0,0:19:50.67,0:19:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku yakin pihak produksi\Ningin pakai aktor yang lebih muda.
Dialogue: 0,0:19:56.54,0:20:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, tak ada aktor muda\Nyang cukup terkenal untuk posisi itu,
Dialogue: 0,0:20:00.63,0:20:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya mereka mencariku\Nuntuk memainkannya.
Dialogue: 0,0:20:05.89,0:20:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi aku tak mau diperlakukan\Nlayaknya panda untuk menarik pengunjung.
Dialogue: 0,0:20:11.07,0:20:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pola pikir yang patut dikagumi.
Dialogue: 0,0:20:15.78,0:20:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu?
Dialogue: 0,0:20:17.45,0:20:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin terus mengasah kemampuan aktingku,
Dialogue: 0,0:20:19.56,0:20:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meningkatkan popularitasku,
Dialogue: 0,0:20:21.12,0:20:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga menjadi aktris yang tak bisa\Ndidikte oleh pertimbangan komersial!
Dialogue: 0,0:20:25.69,0:20:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampil di banyak film bagus,
Dialogue: 0,0:20:28.12,0:20:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadi pemeran utama\Ndalam sebuah mahakarya
Dialogue: 0,0:20:30.92,0:20:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diingat hingga 100 tahun!
Dialogue: 0,0:20:34.63,0:20:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, apa aku bisa?
Dialogue: 0,0:20:37.78,0:20:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakatmu sangat nyata,
Dialogue: 0,0:20:40.27,0:20:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin kamu pasti bisa.
Dialogue: 0,0:20:42.23,0:20:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:43.87,0:20:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuti besok?
Dialogue: 0,0:20:46.12,0:20:46.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:47.65,0:20:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menyelesaikan proyek besar,
Dialogue: 0,0:20:49.67,0:20:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu ambil cuti selama 1 bulan\Nuntuk bersantai.
Dialogue: 0,0:20:53.96,0:20:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi mendaki gunung minggu depan!
Dialogue: 0,0:20:56.92,0:20:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir-akhir ini, aku hobi mendaki gunung.
Dialogue: 0,0:20:58.72,0:21:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, aku pakai aplikasi untuk mencatat\Ngunung yang sudah kudaki.
Dialogue: 0,0:21:03.03,0:21:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya bagus.
Dialogue: 0,0:21:04.40,0:21:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga suka gunung.
Dialogue: 0,0:21:06.96,0:21:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hati-hati, ya.
Dialogue: 0,0:21:09.38,0:21:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terjadi sesuatu di gunung,
Dialogue: 0,0:21:11.56,0:21:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada kemungkinan kamu\Ntakkan bisa ditemukan lagi.
Dialogue: 0,0:21:16.34,0:21:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, hati-hati saat melangkah.
Dialogue: 0,0:21:31.20,0:21:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih hidup?
Dialogue: 0,0:21:33.49,0:21:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah ingatkan, lo.
Dialogue: 0,0:21:35.25,0:21:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati saat melangkah.
Dialogue: 0,0:21:40.78,0:21:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh...
Dialogue: 0,0:21:48.74,0:21:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:21:50.76,0:21:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahayanya telah menghilang.
Dialogue: 0,0:21:56.34,0:21:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merenggut nyawa satu orang lagi...
Dialogue: 0,0:22:01.36,0:22:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ai.
