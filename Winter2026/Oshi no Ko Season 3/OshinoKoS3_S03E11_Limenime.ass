Dialogue: 0,0:02:48.68,0:02:49.81,tanda,,0,0,0,,HOSHINO AQUA
Dialogue: 0,0:05:46.66,0:05:47.53,tanda,,0,0,0,,SEMOGA AKU BISA PERGI\NNONTON KONSER B-KOMACHI
Dialogue: 0,0:05:47.53,0:05:48.53,tanda,,0,0,0,,SEMOGA AKU DAPAT IZIN PERGI KE LUAR
Dialogue: 0,0:05:48.53,0:05:53.54,tanda,,0,0,0,,SEMOGA AYAH DAN IBU\NTIDAK PERNAH SAKIT
Dialogue: 0,0:06:24.52,0:06:28.90,tanda,,0,0,0,,"MAMA, SELAMAT ULANG TAHUN YANG KE-54"
Dialogue: 0,0:07:45.50,0:07:46.36,tanda,,0,0,0,,KELAS BAHASA ESPERANTO
Dialogue: 0,0:07:48.53,0:07:49.29,tanda,,0,0,0,,JALAN DI HUTAN\NUNGKAPAN BAHASA INGGRIS
Dialogue: 0,0:11:58.58,0:12:00.83,tanda,,0,0,0,,KARENA IBU MEMBENCI AKU.
Dialogue: 0,0:13:15.99,0:13:18.00,tanda,,0,0,0,,TENDOUJI
Dialogue: 0,0:13:36.87,0:13:38.49,tanda,,0,0,0,,TENDOUJI
Dialogue: 0,0:16:15.93,0:16:17.62,tanda,,0,0,0,,"HEART'S KISS"
