Dialogue: 0,0:17:13.33,0:17:15.30,tanda,,0,0,0,,B-KOMACHI
Dialogue: 0,0:23:56.87,0:23:57.70,tanda,,0,0,0,,AI ADALAH IDOLAKU YANG TAK TERGANTIKAN\NSEPANJANG MASA!
Dialogue: 0,0:33:19.51,0:33:20.87,tanda,,0,0,0,,SELAMAT!\NUPACARA PENERIMAAN SISWA BARU
Dialogue: 0,0:33:50.42,0:33:53.13,tanda,,0,0,0,,BAR SAMIDARE, LANTAI TIGA
Dialogue: 0,0:36:35.33,0:36:37.29,tanda,,0,0,0,,JALUR CEPAT, STASIUN SHINJUKU
Dialogue: 0,0:37:54.66,0:37:56.37,tanda,,0,0,0,,GADIS GENERASI BARU YANG MENJADI "SOROTAN"\NMAHASISWI BERDADA BESAR, MIYAKO
Dialogue: 0,0:38:19.62,0:38:20.31,tanda,,0,0,0,,"MENYAMBUNGKAN"
Dialogue: 0,0:38:20.31,0:38:21.65,tanda,,0,0,0,,"PESAN DITERIMA, 0 BUAH"
