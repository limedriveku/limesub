Dialogue: 0,0:01:29.99,0:01:30.83,tanda,,0000,0000,0000,,B - ROMBONGAN DISTRIK DAGANG KITAGUCHI\NA - KLUB DANSA HULA HULA
Dialogue: 0,0:01:30.85,0:01:31.69,tanda,,0000,0000,0000,,C - AUDISI PRIBADI, KLUB REKREASI HIMAWARI\N- YASUOKA
Dialogue: 0,0:08:38.04,0:08:38.49,tanda,,0000,0000,0000,,KEBOHONGAN 15 TAHUN
Dialogue: 0,0:10:53.92,0:10:55.67,tanda,,0000,0000,0000,,ARIMA KANA\NPENGUMUMAN UNTUK SEMUA.
Dialogue: 0,0:11:29.96,0:11:34.93,tanda,,0000,0000,0000,,"FANS MEM-CHO, FANS ARIMA KANA, FANS RUBY"
Dialogue: 0,0:12:38.07,0:12:38.47,tanda,,0000,0000,0000,,PANDA BESAR, PANDA KECIL
Dialogue: 0,0:19:25.98,0:19:27.94,tanda,,0000,0000,0000,,PENULIS NASKAH, SUTRADARA\NGOTANDA TAISHI - PENGAJUAN NASKAH VERSI FINAL
Dialogue: 0,0:19:27.94,0:19:29.65,tanda,,0000,0000,0000,,PRODUSER - MENYETUJUI
Dialogue: 0,0:19:29.65,0:19:33.15,tanda,,0000,0000,0000,,KOMITE PRODUKSI - MENYELESAIKAN PENINJAUAN
Dialogue: 0,0:19:33.15,0:19:34.95,tanda,,0000,0000,0000,,RUMAH PRODUKSI - SUDAH FINAL
Dialogue: 0,0:19:34.95,0:19:36.66,tanda,,0000,0000,0000,,TIM PENCAHAYAAN, KAMERA - SUDAH FINAL
Dialogue: 0,0:19:36.66,0:19:38.41,tanda,,0000,0000,0000,,TIM SUARA DAN MUSIK\NSUDAH FINAL
Dialogue: 0,0:19:38.41,0:19:40.79,tanda,,0000,0000,0000,,TIM KOSTUM DAN SENI\NSUDAH FINAL
Dialogue: 0,0:19:42.04,0:19:44.00,tanda,,0000,0000,0000,,DAFTAR PEMERAN DAN JADWAL SYUTING\N- SUDAH FINAL
Dialogue: 0,0:19:47.92,0:19:50.58,tanda,,0000,0000,0000,,DISTRIBUTOR FILM - MENYETUJUI
Dialogue: 0,0:19:50.58,0:19:52.96,tanda,,0000,0000,0000,,FILM "KEBOHONGAN 15 TAHUN"\NRESMI MULAI SYUTING
Dialogue: 0,0:20:05.68,0:20:10.18,tanda,,0000,0000,0000,,EPISODE 34:\NAUDISI PRIBADI
Dialogue: 0,0:21:40.19,0:21:43.12,tanda,,0000,0000,0000,,KEBOHONGAN 15 TAHUN
Dialogue: 0,0:21:59.46,0:22:01.42,tanda,,0000,0000,0000,,KEBOHONGAN 15 TAHUN
Dialogue: 0,0:22:41.67,0:22:43.90,tanda,,0000,0000,0000,,KEBOHONGAN 15 TAHUN
Dialogue: 0,0:23:16.83,0:23:19.83,tanda,,0000,0000,0000,,PAK SUTRADARA, AKU MAU TANYA.\NMENGENAI ADEGAN "IBU" INI...
Dialogue: 0,0:00:00.00,0:00:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}【Oshi No Ko】
Dialogue: 0,0:01:31.72,0:01:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, selanjutnya giliran Ruby.
Dialogue: 0,0:01:34.75,0:01:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ini adalah audisi biasa,
Dialogue: 0,0:01:37.37,0:01:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruby mustahil bisa menang.
Dialogue: 0,0:01:39.27,0:01:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, alasan dia datang ke tempat ini...
Dialogue: 0,0:01:42.62,0:01:43.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karakter ini adalah...
Dialogue: 0,0:01:44.20,0:01:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Film ini...
Dialogue: 0,0:01:46.02,0:01:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Ruby.
Dialogue: 0,0:01:47.67,0:01:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagimu, kebohongan itu apa?
Dialogue: 0,0:01:53.52,0:01:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akting sebagai pembohong, ya?
Dialogue: 0,0:01:59.80,0:02:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebohongan... Pembohong itu apa?
Dialogue: 0,0:02:03.32,0:02:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa akting juga termasuk kebohongan?
Dialogue: 0,0:02:07.72,0:02:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mahir berakting.
Dialogue: 0,0:02:09.40,0:02:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan Aqua pernah bilang\Nmungkin aku bisa jadi aktris di masa depan.
Dialogue: 0,0:02:15.90,0:02:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya,
Dialogue: 0,0:02:17.50,0:02:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu berakting.
Dialogue: 0,0:02:20.50,0:02:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memerankan "Hoshino Ruby".
Dialogue: 0,0:02:23.55,0:02:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memerankan karakter yang cocok\Nmenjadi "putri Hoshino Ai".
Dialogue: 0,0:02:27.47,0:02:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memerankan idola polos dan ceria
Dialogue: 0,0:02:29.04,0:02:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berhasil melewati tragedi\Nkematian sang ibu.
Dialogue: 0,0:02:33.42,0:02:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku merasa Mama\Ningin aku tumbuh seperti itu.
Dialogue: 0,0:02:42.20,0:02:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga selalu memerankan
Dialogue: 0,0:02:46.17,0:02:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tendouji Sarina".
Dialogue: 0,0:02:49.92,0:02:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis tegar dan malang\Nyang selalu memaklumi orang tuanya
Dialogue: 0,0:02:53.10,0:02:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sibuk bekerja
Dialogue: 0,0:02:55.89,0:02:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga tak sempat datang menjenguk.
Dialogue: 0,0:02:59.80,0:03:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku paham, jika tak lakukan itu,
Dialogue: 0,0:03:01.62,0:03:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang terlalu lemah untuk lakukan apa pun\Ntanpa bantuan orang lain
Dialogue: 0,0:03:06.10,0:03:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}takkan sanggup menjalani hidup.
Dialogue: 0,0:03:10.77,0:03:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyembunyikan emosi buruk\Ndi dalam hatiku.
Dialogue: 0,0:03:16.42,0:03:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Mama juga sama?
Dialogue: 0,0:03:20.70,0:03:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama, idola sempurna\Nyang menyembunyikan fakta ia memiliki anak.
Dialogue: 0,0:03:25.55,0:03:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama yang selalu terlihat\Npolos dan ceria.
Dialogue: 0,0:03:32.25,0:03:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semua itu juga hanya akting?
Dialogue: 0,0:03:36.57,0:03:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia juga menyembunyikan\Nberbagai macam emosi?
Dialogue: 0,0:03:41.52,0:03:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia sama sepertiku yang sekarang...
Dialogue: 0,0:03:45.30,0:03:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Mama juga pembohong...
Dialogue: 0,0:03:50.70,0:03:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit.
Dialogue: 0,0:03:52.42,0:03:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benci. Sesak.
Dialogue: 0,0:03:54.65,0:03:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini konyol. Kenapa?
Dialogue: 0,0:03:56.80,0:03:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan. Tak bisa diampuni.
Dialogue: 0,0:03:58.42,0:04:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri. Menjijikkan.
Dialogue: 0,0:04:00.40,0:04:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejamnya. Sangat sakit.
Dialogue: 0,0:04:05.00,0:04:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih memimpikan hari kematian Mama.
Dialogue: 0,0:04:10.10,0:04:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Pak Dokter juga meninggal?
Dialogue: 0,0:04:13.95,0:04:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap terpikir bahwa semua orang\Nyang kusayang akan mati,
Dialogue: 0,0:04:18.89,0:04:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak berani menyukai siapa pun lagi.
Dialogue: 0,0:04:22.22,0:04:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pergi ke tempat mereka juga.
Dialogue: 0,0:04:27.07,0:04:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mati.
Dialogue: 0,0:04:33.77,0:04:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda!
Dialogue: 0,0:04:35.62,0:04:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong, kok.\NAku tak pernah memikirkan hal itu.
Dialogue: 0,0:04:38.12,0:04:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memproses semua emosi itu.
Dialogue: 0,0:04:40.82,0:04:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian.
Dialogue: 0,0:04:43.30,0:04:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bilangnya, ya?
Dialogue: 0,0:04:44.82,0:04:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku paham sekarang.
Dialogue: 0,0:04:47.32,0:04:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Kurokawa?
Dialogue: 0,0:04:49.17,0:04:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Menurutku cukup bagus.
Dialogue: 0,0:04:51.50,0:04:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau banyak bagian yang ingin kukomentari.
Dialogue: 0,0:04:53.95,0:04:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama berlatih dengan baik, dia pasti bisa.
Dialogue: 0,0:04:56.82,0:04:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar ketat soal akting, ya.
Dialogue: 0,0:04:59.25,0:05:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:00.77,0:05:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tampil sesuai tema.
Dialogue: 0,0:05:19.97,0:05:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:05:22.72,0:05:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Frill.
Dialogue: 0,0:05:24.37,0:05:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang kamu incar, 'kan?
Dialogue: 0,0:05:27.15,0:05:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:05:29.25,0:05:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ayolah.
Dialogue: 0,0:05:30.70,0:05:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frill, kamulah pembohong terbesar\Ndi ruangan ini.
Dialogue: 0,0:05:33.85,0:05:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frill, kamu sejak awal sudah berniat\Nmenyerahkan peran ini untuk Ruby, 'kan?
Dialogue: 0,0:05:38.80,0:05:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lakukan ini untuk menyingkirkan aku\Nyang jadi kandidat kedua, ya?
Dialogue: 0,0:05:43.80,0:05:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:05:45.97,0:05:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tebakanku saja, sih.
Dialogue: 0,0:05:47.67,0:05:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini audisi untuk\Nmenentukan pemeran Hoshino Ai.
Dialogue: 0,0:05:53.42,0:05:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Film yang akan disutradarai Pak Gotanda\Nadalah film tentang Hoshino Ai.
Dialogue: 0,0:05:59.10,0:06:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:06:00.75,0:06:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begitu?
Dialogue: 0,0:06:02.82,0:06:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini hal yang akan terpikir oleh Aqua.
Dialogue: 0,0:06:06.60,0:06:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, dia tak bisa bedakan\Nbaik dan buruk.
Dialogue: 0,0:06:08.92,0:06:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin mencapai tujuannya,\Nmeski harus dibenci orang-orang di sekitar.
Dialogue: 0,0:06:14.40,0:06:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aqua.
Dialogue: 0,0:06:15.70,0:06:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dia ingin cari cuan pakai Mama?
Dialogue: 0,0:06:18.80,0:06:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa bukan.
Dialogue: 0,0:06:22.40,0:06:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku cukup terkejut\Nsaat membaca naskah ini.
Dialogue: 0,0:06:26.47,0:06:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah membaca naskah\Nyang begitu penuh dengan niat jahat.
Dialogue: 0,0:06:31.97,0:06:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku tak sebodoh itu.
Dialogue: 0,0:06:34.72,0:06:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya sadar.
Dialogue: 0,0:06:36.35,0:06:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aqua
Dialogue: 0,0:06:38.12,0:06:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berencana membalas dendam\Nmelalui karya ini.
Dialogue: 0,0:06:40.92,0:06:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bersama Pak Gotanda.
Dialogue: 0,0:06:46.05,0:06:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aqua, dia...
Dialogue: 0,0:06:48.82,0:06:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang Kurokawa katakan tadi,
Dialogue: 0,0:06:50.72,0:06:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karya ini menggambarkan\Nseparuh hidup Hoshino Ai.
Dialogue: 0,0:06:54.77,0:06:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat yang bersamaan,
Dialogue: 0,0:06:56.30,0:06:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}film ini juga ingin menghukum\Npembunuh Ai.
Dialogue: 0,0:06:59.92,0:07:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, hasilnya bergantung pada\Nperforma pemeran Ai.
Dialogue: 0,0:07:05.92,0:07:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya bergantung pada bisa atau\Ntidaknya Ai memaafkan pembunuhnya.
Dialogue: 0,0:07:11.80,0:07:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kita membicarakan siapa\Nyang bisa menuangkan tekad Ai ke dalam aktingnya.
Dialogue: 0,0:07:17.15,0:07:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekad Mama.
Dialogue: 0,0:07:21.12,0:07:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, jawabannya aku.
Dialogue: 0,0:07:24.15,0:07:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mempelajari Ai secara menyeluruh
Dialogue: 0,0:07:26.67,0:07:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memahami emosi serta kebiasaannya.
Dialogue: 0,0:07:29.17,0:07:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin diriku bisa menyampaikan\Nhal-hal yang ingin dia sampaikan.
Dialogue: 0,0:07:34.40,0:07:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruby, apa kamu yang masih amatir\Nmerasa bisa berakting lebih baik dariku?
Dialogue: 0,0:07:39.35,0:07:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:41.25,0:07:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hanya aku yang paham perasaan Mama.
Dialogue: 0,0:07:45.80,0:07:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang lebih paham\Npenderitaan Mama dibandingkan aku.
Dialogue: 0,0:07:50.45,0:07:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang akan membalaskan dendam\NMama dan Pak Dokter.
Dialogue: 0,0:07:54.35,0:07:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang harus membalaskan dendam mereka!
Dialogue: 0,0:07:57.92,0:07:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tanggung jawabku.
Dialogue: 0,0:08:01.25,0:08:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang,\Naku kesal karena mengikuti kemauan Aqua.
Dialogue: 0,0:08:04.02,0:08:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sempat pasrah\Nkalau kalah dalam audisi ini.
Dialogue: 0,0:08:07.67,0:08:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang berbeda.
Dialogue: 0,0:08:09.47,0:08:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertanding sampai menang.
Dialogue: 0,0:08:10.97,0:08:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lakukan yang terbaik\Nsampai kalian semua puas!
Dialogue: 0,0:08:19.47,0:08:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Canggung banget.
Dialogue: 0,0:08:22.32,0:08:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga,\Naku pernah dipanggil "Kakak" olehnya.
Dialogue: 0,0:08:25.52,0:08:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu,\Ndia saksi langsung kematian ibunya.
Dialogue: 0,0:08:28.52,0:08:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mentalku tak sekuat itu\Nuntuk terus bersikeras bahwa akulah
Dialogue: 0,0:08:33.52,0:08:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang lebih memahami ibunya daripada dia.
Dialogue: 0,0:08:37.02,0:08:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:08:38.52,0:08:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin ikut,\Naku tak harus memerankan Ai.
Dialogue: 0,0:08:42.54,0:08:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggu kata-kata itu!
Dialogue: 0,0:08:44.55,0:08:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tekadmu semantap itu,
Dialogue: 0,0:08:45.90,0:08:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau pasti bisa melewati berbagai\Nmacam pelatihan!
Dialogue: 0,0:08:47.97,0:08:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane!
Dialogue: 0,0:08:49.95,0:08:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin akhiri topik ini\Ndengan kalimat itu!
Dialogue: 0,0:08:53.15,0:08:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mulai!
Dialogue: 0,0:08:56.92,0:08:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu,
Dialogue: 0,0:08:58.92,0:09:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}audisi terus berlangsung\Nsampai semua pihak merasa puas.
Dialogue: 0,0:09:03.05,0:09:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kualitas akting Kurokawa terus menurun,
Dialogue: 0,0:09:06.57,0:09:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedangkan aku sudah berniat\Nmenyerahkan peran ini pada Ruby.
Dialogue: 0,0:09:10.30,0:09:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Audisi pribadi pun berakhir\Ndengan Ruby sebagai pemenang.
Dialogue: 0,0:09:16.47,0:09:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.\NTerima kasih atas kerja kerasnya.
Dialogue: 0,0:09:18.70,0:09:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:09:21.22,0:09:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akane, Frill.
Dialogue: 0,0:09:22.97,0:09:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha.
Dialogue: 0,0:09:24.75,0:09:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:36.10,0:09:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku paham alasan\Naudisi harus melibatkan orang dewasa.
Dialogue: 0,0:09:40.80,0:09:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompromi dan diskusi
Dialogue: 0,0:09:42.67,0:09:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sekali lagi! Sekali lagi!\N- menghabiskan terlalu banyak waktu.
Dialogue: 0,0:09:45.82,0:09:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, makin sering dilakukan,\Nakting Ruby juga semakin baik.
Dialogue: 0,0:09:51.02,0:09:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang berbakat memang ada di mana saja.
Dialogue: 0,0:09:55.72,0:09:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai ganti menolak peran Ai,\Naku akan minta peran lain.
Dialogue: 0,0:10:00.02,0:10:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,
Dialogue: 0,0:10:01.90,0:10:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa mencapai tujuanku.
Dialogue: 0,0:10:04.50,0:10:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan biarkan\NAqua berbuat sesukanya.
Dialogue: 0,0:10:08.22,0:10:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai?
Dialogue: 0,0:10:12.20,0:10:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa.
Dialogue: 0,0:10:15.12,0:10:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kamu tak mau\Nberurusan lagi denganku.
Dialogue: 0,0:10:18.27,0:10:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rencana awalku.
Dialogue: 0,0:10:21.90,0:10:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa daya,\Naku tak punya hak casting.
Dialogue: 0,0:10:25.65,0:10:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:10:28.90,0:10:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu ingin buat film,\Naku bersedia membantumu.
Dialogue: 0,0:10:32.80,0:10:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika kamu berniat\Nmenjalankan rencana lebih lanjut sendirian,
Dialogue: 0,0:10:37.95,0:10:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menghentikanmu.
Dialogue: 0,0:10:41.10,0:10:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:10:50.00,0:10:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja kalau kamu bisa,
Dialogue: 0,0:10:52.17,0:10:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurokawa Akane.
Dialogue: 0,0:10:59.35,0:11:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena tiba-tiba\Nmengumumkan kabar seperti ini.
Dialogue: 0,0:11:03.95,0:11:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Arima Kana,\Nakan lulus dari B-Komachi.
Dialogue: 0,0:11:08.82,0:11:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, dua tahun bersama B-Komachi
Dialogue: 0,0:11:10.57,0:11:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah pengalaman yang berbeda\Ndan tak tergantikan.
Dialogue: 0,0:11:15.22,0:11:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melalui pengalaman aktivitas sebagai idola,\Naku telah melihat banyak hal
Dialogue: 0,0:11:19.05,0:11:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memberiku waktu untuk memikirkan
Dialogue: 0,0:11:20.60,0:11:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang hal yang ingin kukejar,\Nmimpi, dan harapanku.
Dialogue: 0,0:11:24.85,0:11:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi seorang aktris.
Dialogue: 0,0:11:28.42,0:11:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini aku sadar
Dialogue: 0,0:11:29.96,0:11:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa keinginan itu sangatlah besar.
Dialogue: 0,0:11:38.00,0:11:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akun.
Dialogue: 0,0:11:39.52,0:11:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:40.70,0:11:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba cerita sesuatu yang lucu.
Dialogue: 0,0:11:44.87,0:11:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan perandaian\Nbahwa Arima Kana adalah seekor panda?
Dialogue: 0,0:11:48.05,0:11:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu?
Dialogue: 0,0:11:49.70,0:11:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada tahun 1825,
Dialogue: 0,0:11:51.77,0:11:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada orang barat yang pertama kali\Nmelihat "Lesser Panda" di Pegunungan Himalaya.
Dialogue: 0,0:11:55.92,0:11:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dia bertanya pada penduduk lokal Nepal,\N"Hewan apa itu?"
Dialogue: 0,0:12:00.15,0:12:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang Nepal menjawab,\N"Itu Nigalya ponya".
Dialogue: 0,0:12:03.92,0:12:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena logat daerah, kata "ponya"\Nsalah didengar menjadi "panda".
Dialogue: 0,0:12:07.35,0:12:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi makna dari "Nigalya ponya" sendiri
Dialogue: 0,0:12:10.57,0:12:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya "pemakan bambu".
Dialogue: 0,0:12:13.82,0:12:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,
Dialogue: 0,0:12:15.65,0:12:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arima Kana yang sedang makan rebung\Nadalah seekor panda.
Dialogue: 0,0:12:18.95,0:12:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:12:20.07,0:12:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuberi 84 poin!
Dialogue: 0,0:12:21.37,0:12:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau kamu suka.
Dialogue: 0,0:12:23.47,0:12:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengetahuanmu benar-benar luas, ya.
Dialogue: 0,0:12:26.47,0:12:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Macam anggota Quiz Kn**k saja.
Dialogue: 0,0:12:27.95,0:12:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebai.
Dialogue: 0,0:12:30.05,0:12:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kata "panda" awalnya\Ndipakai untuk menyebut "Lesser Panda".
Dialogue: 0,0:12:34.35,0:12:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sejak panda hitam-putih\Npopuler pada tahun 1869,
Dialogue: 0,0:12:38.50,0:12:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka pisahkan jadi "Giant Panda"\Ndan "Lesser Panda".
Dialogue: 0,0:12:42.25,0:12:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, "Lesser" punya makna inferior.
Dialogue: 0,0:12:45.05,0:12:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah ditekankan, dong.
Dialogue: 0,0:12:51.32,0:12:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ceritanya mirip\Ndengan kondisi dunia hiburan.
Dialogue: 0,0:12:55.40,0:12:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang populer bisa merebut\Ngelar dan legitimasi,
Dialogue: 0,0:12:58.95,0:13:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sementara yang tidak,\Ndianggap produk inferior.
Dialogue: 0,0:13:02.02,0:13:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang itulah akhir maskot\Nyang tak bisa menarik penonton.
Dialogue: 0,0:13:06.37,0:13:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi.
Dialogue: 0,0:13:10.70,0:13:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku sudah lihat unggahanmu.
Dialogue: 0,0:13:13.50,0:13:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah...
Dialogue: 0,0:13:14.95,0:13:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kuumumkan juga.
Dialogue: 0,0:13:17.15,0:13:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku tak bisa mundur lagi.
Dialogue: 0,0:13:19.85,0:13:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa, ya?
Dialogue: 0,0:13:21.47,0:13:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dua tahun sejak kamu\Nmembujukku menjadi idola.
Dialogue: 0,0:13:24.82,0:13:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua tahun.
Dialogue: 0,0:13:26.32,0:13:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya. Aku sudah memaksamu gabung.
Dialogue: 0,0:13:29.62,0:13:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu.
Dialogue: 0,0:13:31.02,0:13:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku bersyukur bisa ada di sini.
Dialogue: 0,0:13:35.25,0:13:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kamu tidak mengajakku waktu itu,
Dialogue: 0,0:13:37.50,0:13:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin Arima Kana sebagai artis\Nakan mati begitu saja...
Dialogue: 0,0:13:42.52,0:13:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku sedang bersantai\Nmenjalani hari di suatu universitas.
Dialogue: 0,0:13:46.85,0:13:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya opsi itu lebih bagus.
Dialogue: 0,0:13:49.40,0:13:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lah.
Dialogue: 0,0:13:51.07,0:13:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, merintis karier di dunia hiburan\Nadalah judi jangka panjang aktor kabuki.
Dialogue: 0,0:13:55.07,0:13:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak seorang pun tahu\Nsiapa yang menang dan kalah.
Dialogue: 0,0:14:00.47,0:14:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku meninggalkan B-Komachi,
Dialogue: 0,0:14:12.62,0:14:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi berkat itu pula,\Naku masih merasa bisa terus bertaruh di jalur ini.
Dialogue: 0,0:14:18.12,0:14:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktivitas B-Komachi benar-benar seru.
Dialogue: 0,0:14:22.65,0:14:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi capeknya juga setara dengan serunya!
Dialogue: 0,0:14:25.60,0:14:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, aku hanya merasakan sakitnya,
Dialogue: 0,0:14:28.52,0:14:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata itu sangat membantuku.
Dialogue: 0,0:14:31.15,0:14:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menang dalam taruhan ini\Ndan jadi panda yang luar biasa.
Dialogue: 0,0:14:36.47,0:14:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sudi dipanggil "Lesser".
Dialogue: 0,0:14:40.57,0:14:41.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:42.97,0:14:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru ingat lagi...
Dialogue: 0,0:14:44.32,0:14:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sutradara menawarkan peran di film itu.
Dialogue: 0,0:14:47.55,0:14:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, aku memerankan anggota B-Komachi lama\Nyang sangat membenci Ai.
Dialogue: 0,0:14:52.55,0:14:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terima, lo.\NKamu tidak masalah, 'kan?
Dialogue: 0,0:14:55.47,0:14:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini hanya akting,\Ntapi aku akan memaki ibumu macam-macam, lo.
Dialogue: 0,0:14:59.67,0:15:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:15:01.92,0:15:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Arima, aku tak keberatan.
Dialogue: 0,0:15:04.05,0:15:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau "aku" yang main?
Dialogue: 0,0:15:05.85,0:15:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:07.70,0:15:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu sosok yang spesial untukku.
Dialogue: 0,0:15:14.45,0:15:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:15:15.90,0:15:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:15:16.90,0:15:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham.\NSpesial dari mana, coba?!
Dialogue: 0,0:15:19.92,0:15:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak jelas!
Dialogue: 0,0:15:21.15,0:15:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku mau beli minuman dulu!
Dialogue: 0,0:15:25.40,0:15:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sedang berusaha\Nmemerankan teman yang baik!
Dialogue: 0,0:15:28.45,0:15:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia malah bilang\Nsesuatu yang ambigu?!
Dialogue: 0,0:15:30.37,0:15:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bodoh, ya?\NDasar tidak pekaan!
Dialogue: 0,0:15:32.02,0:15:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu sebenarnya naksir aku?!
Dialogue: 0,0:15:40.85,0:15:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kalimat manis saja\Nlangsung sepanik itu.
Dialogue: 0,0:15:47.00,0:15:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus lebih pandai\Nmencurigai orang lain, Arima Kana.
Dialogue: 0,0:15:51.60,0:15:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mau dikendalikan\Ndan dimanfaatkan oleh orang sepertiku,
Dialogue: 0,0:15:58.30,0:16:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kamu akan hancur nanti.
Dialogue: 0,0:16:05.05,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemerannya mulai terpilih satu per satu.
Dialogue: 0,0:16:09.40,0:16:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini,\Naku bisa bersiap untuk mulai syuting.
Dialogue: 0,0:16:13.65,0:16:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:16:17.12,0:16:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoshino Ruby sebagai pemeran utama, ya?
Dialogue: 0,0:16:21.37,0:16:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagal merekrut Shiranui Frill dan Kurokawa Akane\Nadalah pukulan yang besar.
Dialogue: 0,0:16:28.07,0:16:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masalah jadwal, mereka mau terima\Nselama bukan pemeran utama, ya...
Dialogue: 0,0:16:33.42,0:16:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tak sesederhana kelihatannya.
Dialogue: 0,0:16:37.15,0:16:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sutradara dan Aqua\Njuga punya pemikiran lain.
Dialogue: 0,0:16:41.30,0:16:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tebak sampai batas tertentu...
Dialogue: 0,0:16:44.92,0:16:48.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini untuk menghukum, atau balas dendam?
Dialogue: 0,0:16:49.70,0:16:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau...
Dialogue: 0,0:16:51.20,0:16:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang lebih jauh dari itu.
Dialogue: 0,0:16:55.07,0:16:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang,\Nkita harus terima Hoshino Ruby, ya.
Dialogue: 0,0:16:57.75,0:17:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia harus bisa jadi maskot\Nyang menarik banyak penonton.
Dialogue: 0,0:17:29.90,0:17:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang memikirkan apa?
Dialogue: 0,0:17:33.85,0:17:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikmu?
Dialogue: 0,0:17:35.42,0:17:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan pacar?
Dialogue: 0,0:17:37.17,0:17:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang menaksir dirimu?
Dialogue: 0,0:17:41.00,0:17:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin... ibumu?
Dialogue: 0,0:17:45.95,0:17:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sengaja datang ke sini\Nuntuk menyindir, ya?
Dialogue: 0,0:17:48.80,0:17:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marah, ya?
Dialogue: 0,0:17:50.80,0:17:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku pernah bilang,\N"Hoshino Ai tak ada lagi di dunia ini".
Dialogue: 0,0:17:56.10,0:17:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:17:57.27,0:17:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar dewa pembawa sial.
Dialogue: 0,0:17:58.50,0:18:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu tetap\Nmemikirkan kemungkinan itu, 'kan?
Dialogue: 0,0:18:02.27,0:18:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpikir bahwa Hoshino Ai\Nsama seperti kalian,
Dialogue: 0,0:18:05.40,0:18:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bereinkarnasi, dan hidup bahagia\Ndi suatu tempat.
Dialogue: 0,0:18:09.85,0:18:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah.
Dialogue: 0,0:18:12.37,0:18:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kisah Hoshino Ai sudah berakhir hari itu,\Ndi tempat itu.
Dialogue: 0,0:18:16.25,0:18:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu fakta yang tak terelakkan.
Dialogue: 0,0:18:20.12,0:18:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa Hoshino Ai sudah benar-benar lenyap,
Dialogue: 0,0:18:23.77,0:18:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kembali ke lautan bintang-bintang.
Dialogue: 0,0:18:26.65,0:18:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu takkan pernah terbentuk lagi.
Dialogue: 0,0:18:32.47,0:18:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematian adalah kematian.
Dialogue: 0,0:18:36.30,0:18:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hoshino Ai tak bisa merasakan,\Natau pikirkan apa pun lagi.
Dialogue: 0,0:18:41.97,0:18:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia takkan pernah tersenyum lagi.
Dialogue: 0,0:18:44.15,0:18:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kau lakukan setelah ini...
Dialogue: 0,0:18:47.70,0:18:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau juga katakan itu pada Ruby?
Dialogue: 0,0:18:50.22,0:18:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu seram banget, deh.
Dialogue: 0,0:18:52.57,0:18:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku tak katakan itu padanya,
Dialogue: 0,0:18:54.95,0:18:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia juga akan memenuhi\Ntugasnya sendiri di masa depan.
Dialogue: 0,0:18:58.80,0:19:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sebaiknya kamu pikir-pikir lagi.
Dialogue: 0,0:19:03.25,0:19:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa jiwamu bisa masuk\Nke dalam tubuh itu?
Dialogue: 0,0:19:13.37,0:19:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak perlu katakan itu padaku.
Dialogue: 0,0:19:16.27,0:19:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan aku terlahir seperti ini...
Dialogue: 0,0:19:19.27,0:19:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya punya
Dialogue: 0,0:19:21.37,0:19:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu misi.
Dialogue: 0,0:19:58.10,0:19:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuda A.
Dialogue: 0,0:20:01.12,0:20:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah kandung kami.
Dialogue: 0,0:21:43.12,0:21:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, ceritanya benar-benar gelap.
Dialogue: 0,0:21:49.80,0:21:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Berarti, Ibu tetaplah seorang perempuan."
Dialogue: 0,0:21:55.25,0:21:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia tak bisa menjadi seorang ibu."
Dialogue: 0,0:21:58.10,0:21:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia suka lelaki,
Dialogue: 0,0:21:59.46,0:22:01.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membenci perempuan..."
Dialogue: 0,0:22:01.92,0:22:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mungkin ini juga alasannya,"
Dialogue: 0,0:22:03.62,0:22:06.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ibu tak datang menjemputku."
Dialogue: 0,0:22:07.47,0:22:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:22:08.77,0:22:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ibu tak datang menjemput"...
Dialogue: 0,0:22:11.45,0:22:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ibu tidak"...
Dialogue: 0,0:22:13.90,0:22:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:22:15.70,0:22:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:22:16.80,0:22:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu?
Dialogue: 0,0:22:19.20,0:22:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu... Ibu!
Dialogue: 0,0:22:22.22,0:22:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berkeringat.
Dialogue: 0,0:22:24.60,0:22:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior.
Dialogue: 0,0:22:26.17,0:22:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah istirahat, belum?
Dialogue: 0,0:22:27.92,0:22:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dicari banyak orang\Ndengan jadwal yang luar biasa padat.
Dialogue: 0,0:22:32.15,0:22:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:22:33.52,0:22:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadwal saat syuting\Nsudah diatur dengan baik.
Dialogue: 0,0:22:36.80,0:22:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, dia belum istirahat sama sekali.
Dialogue: 0,0:22:41.67,0:22:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan terlalu memaksakan diri".
Dialogue: 0,0:22:43.90,0:22:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalimat seperti itu tak pantas diucapkan\Nsetelah membaca naskah ini.
Dialogue: 0,0:22:49.05,0:22:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- "Ibu tak mau datang"...\N- Jika aku Ruby,
Dialogue: 0,0:22:51.20,0:22:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti tak ingin diganggu siapa pun.
Dialogue: 0,0:22:53.57,0:22:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ibu... Ibu...\N- Aku pasti akan memaksakan diri hingga melewati batas.
Dialogue: 0,0:22:58.12,0:22:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruby.
Dialogue: 0,0:22:59.32,0:23:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, coba tidur saat\Ndi jalan menuju lokasi.
Dialogue: 0,0:23:01.97,0:23:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja bisa membuatmu jauh lebih baik.
Dialogue: 0,0:23:04.70,0:23:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saran dari mantan aktris cilik terkenal.
Dialogue: 0,0:23:07.77,0:23:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:23:08.90,0:23:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Senior.
Dialogue: 0,0:23:20.22,0:23:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:23:21.62,0:23:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:23:25.42,0:23:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Kaburagi, Pak Gotanda.
Dialogue: 0,0:23:28.32,0:23:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kami bisa menyapa\Nkalian berdua sebentar?
Dialogue: 0,0:23:31.02,0:23:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu.
Dialogue: 0,0:23:33.75,0:23:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau adalah Nyonya Tendouji\Ndari agensi periklanan.
