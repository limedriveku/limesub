Dialogue: 0,0:00:01.87,0:00:03.46,tanda,,0000,0000,0000,,"POPURI"
Dialogue: 0,0:00:03.71,0:00:05.67,tanda,,0000,0000,0000,,"TIBA-TIBA"
Dialogue: 0,0:00:38.45,0:00:40.12,tanda,,0000,0000,0000,,"ALBUM HARI JADI SATU TAHUN"
Dialogue: 0,0:01:58.45,0:02:03.20,tanda,,0000,0000,0000,,"YOU AND I ARE POLAR OPPOSITES"
Dialogue: 0,0:03:21.74,0:03:23.32,tanda,,0000,0000,0000,,"10/31, SEHARI SEBELUM ULANG TAHUN TANI"
Dialogue: 0,0:04:03.78,0:04:05.87,tanda,,0000,0000,0000,,"1 NOVEMBER"
Dialogue: 0,0:04:05.95,0:04:07.41,tanda,,0000,0000,0000,,"ULANG TAHUN TANI"
Dialogue: 0,0:04:11.37,0:04:12.79,tanda,,0000,0000,0000,,"DINGIN…"
Dialogue: 0,0:04:18.50,0:04:20.08,tanda,,0000,0000,0000,,"SEBENARNYA AKU SANGAT BERTERIMA KASIH"
Dialogue: 0,0:04:21.22,0:04:25.30,tanda,,0000,0000,0000,,"REAKSI YANG AKAN MEMBUAT MEREKA SENANG"
Dialogue: 0,0:04:25.39,0:04:26.72,tanda,,0000,0000,0000,,"WAH - GAMBAR"
Dialogue: 0,0:05:25.99,0:05:27.82,tanda,,0000,0000,0000,,"10/10 - ULANG TAHUN TAIRA"
Dialogue: 0,0:07:29.99,0:07:31.28,tanda,,0000,0000,0000,,"KAU…"
Dialogue: 0,0:07:54.85,0:07:56.68,tanda,,0000,0000,0000,,"TANI TIDUR LEBIH AWAL"
Dialogue: 0,0:08:22.29,0:08:25.50,tanda,,0000,0000,0000,,"PANGGILAN DARI MIYU SUZUKI"
Dialogue: 0,0:09:34.90,0:09:37.70,tanda,,0000,0000,0000,,"MENDENGKUR - TERTIDUR"
Dialogue: 0,0:09:45.66,0:09:48.21,tanda,,0000,0000,0000,,"GIRANG"
Dialogue: 0,0:09:57.13,0:09:57.97,tanda,,0000,0000,0000,,"INI DIA"
Dialogue: 0,0:09:58.05,0:09:59.01,tanda,,0000,0000,0000,,"PERMEN GUMMY LEZAT"
Dialogue: 0,0:10:07.81,0:10:09.10,tanda,,0000,0000,0000,,"COKELAT THUNDER"
Dialogue: 0,0:10:25.12,0:10:27.08,tanda,,0000,0000,0000,,"POPURI"
Dialogue: 0,0:12:22.24,0:12:24.74,tanda,,0000,0000,0000,,"AKU TIDAK LUPA MENYIAPKANNYA\NUNTUKKU JUGA"
Dialogue: 0,0:12:58.36,0:13:00.11,tanda,,0000,0000,0000,,"SANGAT BERSEMANGAT"
Dialogue: 0,0:13:17.50,0:13:19.63,tanda,,0000,0000,0000,,"GUGUP"
Dialogue: 0,0:14:11.43,0:14:12.51,tanda,,0000,0000,0000,,"CIUM…"
Dialogue: 0,0:14:30.74,0:14:32.03,tanda,,0000,0000,0000,,"RENCANA KENCAN…"
Dialogue: 0,0:14:32.12,0:14:34.12,tanda,,0000,0000,0000,,"MAU KE MANA - MELAKUKAN APA"
Dialogue: 0,0:14:36.33,0:14:38.46,tanda,,0000,0000,0000,,"TIDAK TERTARIK BERJALAN-JALAN"
Dialogue: 0,0:14:46.67,0:14:48.47,tanda,,0000,0000,0000,,"BERSIKAP MANIS…"
Dialogue: 0,0:15:21.33,0:15:23.34,tanda,,0000,0000,0000,,"FILM: 2 JAM 30 MENIT"
Dialogue: 0,0:15:24.17,0:15:26.05,tanda,,0000,0000,0000,,"KEBUN BINATANG: 2 SAMPAI 3 JAM"
Dialogue: 0,0:15:27.05,0:15:29.13,tanda,,0000,0000,0000,,"AKUARIUM: 1 SAMPAI 2 JAM"
Dialogue: 0,0:15:30.76,0:15:33.47,tanda,,0000,0000,0000,,"MUSEUM: 3 SAMPAI 4 JAM"
Dialogue: 0,0:15:37.98,0:15:38.93,tanda,,0000,0000,0000,,"PAMERAN KHUSUS: DUNIA HARTA KARUN"
Dialogue: 0,0:16:04.25,0:16:06.42,tanda,,0000,0000,0000,,"30 MENIT KEMUDIAN"
Dialogue: 0,0:16:50.30,0:16:51.55,tanda,,0000,0000,0000,,"DIA MEMELIHARA NGENGAT"
Dialogue: 0,0:17:26.63,0:17:27.75,tanda,,0000,0000,0000,,"SYUKURLAH"
Dialogue: 0,0:17:40.35,0:17:42.60,tanda,,0000,0000,0000,,"TUTUP SEMENTARA"
Dialogue: 0,0:17:59.20,0:18:01.95,tanda,,0000,0000,0000,,"WAKTU ANTRE + MAKAN = WAKTU UNTUK PULANG"
Dialogue: 0,0:18:07.62,0:18:10.17,tanda,,0000,0000,0000,,"SUSHI"
Dialogue: 0,0:18:10.88,0:18:13.17,tanda,,0000,0000,0000,,"SUP"
Dialogue: 0,0:18:13.26,0:18:15.67,tanda,,0000,0000,0000,,"DIBAWA PULANG"
Dialogue: 0,0:18:29.81,0:18:30.73,tanda,,0000,0000,0000,,"AKU MAU KE SANA - KE SINI"
Dialogue: 0,0:18:30.81,0:18:33.19,tanda,,0000,0000,0000,,"HMM… - JADWAL"
Dialogue: 0,0:19:27.20,0:19:28.04,tanda,,0000,0000,0000,,"APA?"
Dialogue: 0,0:20:17.84,0:20:20.42,tanda,,0000,0000,0000,,"YANG ARTINYA PESTA ULANG TAHUN MERIAH"
Dialogue: 0,0:22:20.00,0:22:21.92,tanda,,0000,0000,0000,,"SAMPAI JUMPA EPISODE BERIKUTNYA"
Dialogue: 0,0:00:01.87,0:00:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kalian tahu,
Dialogue: 0,0:00:03.71,0:00:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanggal 1 November sudah dekat.
Dialogue: 0,0:00:05.75,0:00:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hari ulang tahun Tani.
Dialogue: 0,0:00:08.71,0:00:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulang tahun Tani?
Dialogue: 0,0:00:09.92,0:00:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu.
Dialogue: 0,0:00:11.09,0:00:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejutan apa yang harus kusiapkan, ya?
Dialogue: 0,0:00:13.05,0:00:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi kepikiran.
Dialogue: 0,0:00:14.76,0:00:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan cuma mengobrol di sini.
Dialogue: 0,0:00:16.68,0:00:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Tani mengisyaratkan sesuatu\Nyang dia inginkan belakangan ini?
Dialogue: 0,0:00:20.68,0:00:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:00:21.77,0:00:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa enggak tanya dia langsung?
Dialogue: 0,0:00:23.77,0:00:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pernah dapat hadiah\Nyang membuatmu sangat senang,
Dialogue: 0,0:00:26.69,0:00:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau dapat kejutan yang masih berkesan?
Dialogue: 0,0:00:32.49,0:00:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:00:33.82,0:00:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tanya Yamada?
Dialogue: 0,0:00:36.28,0:00:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe mereka berdua kan beda banget.
Dialogue: 0,0:00:38.45,0:00:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin semacam album foto?
Dialogue: 0,0:00:40.33,0:00:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!
Dialogue: 0,0:00:42.87,0:00:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang berpengalaman…
Dialogue: 0,0:00:44.62,0:00:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:00:46.08,0:00:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu apa-apa\Nsoal kehidupan asmaranya,
Dialogue: 0,0:00:48.25,0:00:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku merasa ada jarak yang jauh\Ndi antara kami sekarang.
Dialogue: 0,0:00:50.75,0:00:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau, Taira?
Dialogue: 0,0:00:52.92,0:00:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu?
Dialogue: 0,0:00:58.51,0:01:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada situasi seperti ini,\Nintinya bukan di hadiahnya, kan?
Dialogue: 0,0:01:04.31,0:01:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyadari ada yang mengingat ulang tahunmu
Dialogue: 0,0:01:07.69,0:01:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merayakannya bersamamu,\Nitu yang paling bikin bahagia.
Dialogue: 0,0:01:12.03,0:01:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku kurang paham, sih.
Dialogue: 0,0:01:14.03,0:01:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menatap…
Dialogue: 0,0:01:21.87,0:01:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemikiranmu dewasa banget.
Dialogue: 0,0:01:23.41,0:01:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:01:27.04,0:01:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ingin memberinya kejutan\Ndan merayakannya diam-diam.
Dialogue: 0,0:01:31.96,0:01:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau niat sekali.
Dialogue: 0,0:01:33.67,0:01:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini ulang tahun pertamanya\Nsejak kami jadian!
Dialogue: 0,0:01:37.05,0:01:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memberi Tani kejutan\Nyang tak akan pernah dia lupakan,
Dialogue: 0,0:01:41.31,0:01:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar dia enggak mau
Dialogue: 0,0:01:42.47,0:01:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merayakan ulang tahun yang biasa lagi.
Dialogue: 0,0:01:43.60,0:01:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu semacam kutukan?
Dialogue: 0,0:01:44.52,0:01:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram sekali.
Dialogue: 0,0:03:18.49,0:03:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Halloween!
Dialogue: 0,0:03:21.74,0:03:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:23.62,0:03:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani.
Dialogue: 0,0:03:24.53,0:03:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok kau enggak ada les\Natau tugas pustakawan, kan?
Dialogue: 0,0:03:28.29,0:03:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita pulang bareng, ya.
Dialogue: 0,0:03:31.37,0:03:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:03:33.38,0:03:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti kencan ulang tahun\Nsepulang sekolah!
Dialogue: 0,0:03:38.05,0:03:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:03:40.76,0:03:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia akan memberiku kejutan.
Dialogue: 0,0:03:45.30,0:03:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu SMP…
Dialogue: 0,0:03:48.02,0:03:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinacchi, selamat ulang tahun!
Dialogue: 0,0:03:50.98,0:03:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, semuanya! Aku senang sekali!
Dialogue: 0,0:03:55.11,0:03:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya tradisi\Nsaling merayakan ulang tahun.
Dialogue: 0,0:03:59.07,0:04:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan kalau ada yang enggak dirayakan,
Dialogue: 0,0:04:01.65,0:04:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, semua orang diperlakukan sama.
Dialogue: 0,0:04:03.78,0:04:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tibalah giliranku.
Dialogue: 0,0:04:07.66,0:04:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun, Tani.
Dialogue: 0,0:04:09.91,0:04:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat…
Dialogue: 0,0:04:11.37,0:04:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:14.71,0:04:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksinya dingin sekali.
Dialogue: 0,0:04:18.50,0:04:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih enggak tahu reaksi yang tepat
Dialogue: 0,0:04:20.17,0:04:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk situasi seperti itu.
Dialogue: 0,0:04:26.80,0:04:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini merepotkan.
Dialogue: 0,0:04:28.68,0:04:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak yakin\Nbisa berlagak terkejut dengan natural.
Dialogue: 0,0:04:32.18,0:04:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi Taira lucu.
Dialogue: 0,0:04:33.98,0:04:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, menggodanya terasa sangat memuaskan.
Dialogue: 0,0:04:40.61,0:04:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:04:41.78,0:04:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang paling parah.
Dialogue: 0,0:04:45.49,0:04:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah.
Dialogue: 0,0:04:48.53,0:04:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, aku mau tanya.
Dialogue: 0,0:04:52.54,0:04:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal yang perlu kuingat saat bereaksi?
Dialogue: 0,0:04:54.96,0:04:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menganggapku apa?
Dialogue: 0,0:04:57.46,0:04:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, giliran kita!
Dialogue: 0,0:05:03.67,0:05:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejutan dari Suzuki itu maksudnya apa, ya?
Dialogue: 0,0:05:25.07,0:05:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hujan…
Dialogue: 0,0:05:29.32,0:05:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau hujan atau cerah, sama saja.
Dialogue: 0,0:05:32.58,0:05:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, enggak ada yang tahu\Nkapan ulang tahunku.
Dialogue: 0,0:05:39.17,0:05:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun
Dialogue: 0,0:05:42.05,0:05:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayumi, selamat ulang tahun!\N- Selamat ulang tahun
Dialogue: 0,0:05:45.47,0:05:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa siaran ini untukku?\N- Selamat ulang tahun
Dialogue: 0,0:05:47.43,0:05:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Astaga! Memalukan sekali!\N- Ayumi tersayang
Dialogue: 0,0:05:50.80,0:05:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun
Dialogue: 0,0:05:54.64,0:05:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memalukan sekali…
Dialogue: 0,0:05:56.81,0:06:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesaat, kupikir mereka memberiku kejutan.
Dialogue: 0,0:06:01.65,0:06:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira.
Dialogue: 0,0:06:03.48,0:06:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu merah sekali.
Dialogue: 0,0:06:06.53,0:06:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Kau flu?
Dialogue: 0,0:06:09.03,0:06:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, bukan apa-apa.
Dialogue: 0,0:06:12.24,0:06:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:06:15.45,0:06:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, mana payungmu?
Dialogue: 0,0:06:17.08,0:06:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawa, kok.
Dialogue: 0,0:06:18.83,0:06:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi repot pakai payung\Nsaat gerimis begini.
Dialogue: 0,0:06:21.17,0:06:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semua laki-laki memang begini?
Dialogue: 0,0:06:24.25,0:06:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada petir…
Dialogue: 0,0:06:27.47,0:06:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepat masuk.
Dialogue: 0,0:06:29.72,0:06:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:06:34.35,0:06:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:06:37.98,0:06:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial sekali aku hari ini.
Dialogue: 0,0:06:40.77,0:06:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini hari ulang tahunmu.
Dialogue: 0,0:06:45.07,0:06:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu?
Dialogue: 0,0:06:46.53,0:06:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita sempat tanya jawab\Ndi kelas bahasa Inggris?
Dialogue: 0,0:06:49.61,0:06:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru ingat.
Dialogue: 0,0:06:50.82,0:06:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:51.91,0:06:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal 10 Oktober.
Dialogue: 0,0:06:54.33,0:06:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anehnya, pelafalanmu bagus. Itu agak lucu.
Dialogue: 0,0:06:56.16,0:06:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berisik sekali.
Dialogue: 0,0:06:57.83,0:07:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tadi menantikan siaran\Nwaktu makan siang, ya?
Dialogue: 0,0:07:01.92,0:07:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja enggak.
Dialogue: 0,0:07:03.25,0:07:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bercanda.
Dialogue: 0,0:07:05.46,0:07:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ini hadiah untukmu.
Dialogue: 0,0:07:08.17,0:07:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini stiker dari roti\Nyang kumakan siang tadi.
Dialogue: 0,0:07:12.30,0:07:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahmu kelihatan jijik begitu?
Dialogue: 0,0:07:14.05,0:07:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, tanganku kotor. Nanti kuambil.
Dialogue: 0,0:07:18.73,0:07:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:24.57,0:07:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini stiker yeti.
Dialogue: 0,0:07:26.48,0:07:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu kau suka barang-barang lucu.
Dialogue: 0,0:07:28.11,0:07:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat enggak terduga.
Dialogue: 0,0:07:35.45,0:07:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang memberikannya padamu, kan?
Dialogue: 0,0:07:37.79,0:07:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau setia sekali.
Dialogue: 0,0:07:51.97,0:07:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku harus bergadang sampai tengah malam?
Dialogue: 0,0:07:56.76,0:08:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dia menelepon\Ndan aku enggak menjawab?
Dialogue: 0,0:08:04.15,0:08:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, mungkin aku cuma kegeeran.
Dialogue: 0,0:08:27.38,0:08:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:08:29.17,0:08:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kau masih bangun.
Dialogue: 0,0:08:31.22,0:08:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau jangan-jangan\Nkau terbangun karena teleponku?
Dialogue: 0,0:08:33.76,0:08:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bangun, kok.
Dialogue: 0,0:08:34.84,0:08:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, suaramu terdengar\Nseperti orang bangun tidur.
Dialogue: 0,0:08:37.35,0:08:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku akan langsung mematikannya\Nsetelah bilang ini.
Dialogue: 0,0:08:39.80,0:08:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi.
Dialogue: 0,0:08:45.35,0:08:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, selamat ulang tahun.
Dialogue: 0,0:08:48.86,0:08:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya aku ingin menyiapkan kejutan\Nyang lebih niat,
Dialogue: 0,0:08:53.61,0:08:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kuputuskan untuk merayakannya sederhana\Ndan langsung memberimu ucapan selamat.
Dialogue: 0,0:09:00.62,0:09:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:03.83,0:09:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membangunkanmu.
Dialogue: 0,0:09:05.83,0:09:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum tidur, kok.
Dialogue: 0,0:09:06.88,0:09:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bohong.
Dialogue: 0,0:09:08.71,0:09:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak…
Dialogue: 0,0:09:11.09,0:09:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaramu terdengar mengantuk.
Dialogue: 0,0:09:13.30,0:09:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa. Selamat malam.
Dialogue: 0,0:09:15.09,0:09:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa besok.
Dialogue: 0,0:09:22.64,0:09:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sayang kamu.
Dialogue: 0,0:09:24.98,0:09:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda, deng.
Dialogue: 0,0:09:29.65,0:09:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sayang kamu.
Dialogue: 0,0:09:44.00,0:09:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Tani!
Dialogue: 0,0:09:45.66,0:09:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun!
Dialogue: 0,0:09:50.09,0:09:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini ulang tahun Tani?
Dialogue: 0,0:09:51.71,0:09:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun!
Dialogue: 0,0:09:52.84,0:09:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun! Kau mau stiker?
Dialogue: 0,0:09:55.05,0:09:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:57.13,0:09:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, ini.
Dialogue: 0,0:09:58.05,0:09:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gummy.
Dialogue: 0,0:09:59.09,0:10:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gummy.
Dialogue: 0,0:10:00.08,0:10:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:02.68,0:10:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani.
Dialogue: 0,0:10:10.06,0:10:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:11.48,0:10:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duluan, ya. Aku harus kerja.
Dialogue: 0,0:10:13.15,0:10:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma menutupi rasa malunya.
Dialogue: 0,0:10:14.82,0:10:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira memang begitu.
Dialogue: 0,0:10:16.40,0:10:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, kudengar ini ulang tahunmu.
Dialogue: 0,0:10:18.74,0:10:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umur berapa sekarang?
Dialogue: 0,0:10:20.82,0:10:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama denganmu.
Dialogue: 0,0:10:23.20,0:10:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir…
Dialogue: 0,0:10:29.29,0:10:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira sudah mulai sifnya.
Dialogue: 0,0:10:32.79,0:10:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua…
Dialogue: 0,0:10:34.34,0:10:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak perlu repot-repot datang,\Napalagi di hari ulang tahunmu.
Dialogue: 0,0:10:38.18,0:10:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulang tahunnya belum selesai, kok.
Dialogue: 0,0:10:48.10,0:10:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau beli juga?
Dialogue: 0,0:10:51.19,0:10:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mampir.
Dialogue: 0,0:10:53.23,0:10:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun.
Dialogue: 0,0:10:56.44,0:10:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu ulang tahunmu sudah lewat.
Dialogue: 0,0:11:00.03,0:11:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi enggak enak\Nkarena cuma aku yang dapat hadiah.
Dialogue: 0,0:11:02.53,0:11:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:03.70,0:11:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baru dengar dari Azu.
Dialogue: 0,0:11:05.87,0:11:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak perlu seformal itu.
Dialogue: 0,0:11:08.91,0:11:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat ulang tahun!\N- Ini.
Dialogue: 0,0:11:12.88,0:11:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo, Tani.
Dialogue: 0,0:11:14.67,0:11:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya acara utama hari ini!
Dialogue: 0,0:11:16.46,0:11:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku cuma penampil pembuka?
Dialogue: 0,0:11:17.71,0:11:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun!
Dialogue: 0,0:11:27.22,0:11:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:28.52,0:11:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, ada kabar baik, ya?
Dialogue: 0,0:11:32.02,0:11:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak… Bukan apa-apa.
Dialogue: 0,0:11:39.32,0:11:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:11:40.36,0:11:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korek api dan lilin.
Dialogue: 0,0:11:42.82,0:11:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau siap sekali.
Dialogue: 0,0:11:47.45,0:11:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga…
Dialogue: 0,0:11:51.54,0:11:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku berlebihan?
Dialogue: 0,0:11:56.80,0:11:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita nyalakan.
Dialogue: 0,0:12:01.72,0:12:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya…
Dialogue: 0,0:12:06.81,0:12:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, usiamu 17 tahun sekarang.\NMari lewati tahun yang luar biasa.
Dialogue: 0,0:12:11.35,0:12:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:13.44,0:12:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali.
Dialogue: 0,0:12:25.95,0:12:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget!
Dialogue: 0,0:12:29.33,0:12:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo tukaran.
Dialogue: 0,0:12:31.25,0:12:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:12:41.76,0:12:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, ini hadiah ulang tahunmu.
Dialogue: 0,0:12:45.51,0:12:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syal?
Dialogue: 0,0:12:47.22,0:12:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku memberikannya\Nterlalu awal, ya.
Dialogue: 0,0:12:50.27,0:12:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku memberimu barang yang cuma\Nbisa dipakai saat jalan-jalan,
Dialogue: 0,0:12:52.64,0:12:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kesempatanku melihatmu\Nmemakainya bakal sedikit.
Dialogue: 0,0:12:55.40,0:12:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau memakainya ke sekolah,\Naku pasti sangat
Dialogue: 0,0:12:58.36,0:13:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}senang!
Dialogue: 0,0:13:05.07,0:13:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki.
Dialogue: 0,0:13:13.54,0:13:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ini…
Dialogue: 0,0:13:17.50,0:13:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mau ciuman, kan?
Dialogue: 0,0:13:22.84,0:13:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:24.93,0:13:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali.
Dialogue: 0,0:13:47.95,0:13:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udaranya belum terlalu\Ndingin untuk pakai syal.
Dialogue: 0,0:13:50.20,0:13:51.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini darimu.
Dialogue: 0,0:13:53.20,0:13:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir pekan ini, kita pergi ke mana pun\Ndan melakukan apa pun yang kau suka.
Dialogue: 0,0:13:57.04,0:13:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kumau?
Dialogue: 0,0:13:58.33,0:14:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kita selalu pergi\Nke tempat yang kuinginkan.
Dialogue: 0,0:14:01.80,0:14:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, nanti kupikirkan.
Dialogue: 0,0:14:04.34,0:14:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik! Aku tunggu, ya!
Dialogue: 0,0:14:24.32,0:14:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir pekan ini, kita pergi ke mana pun
Dialogue: 0,0:14:26.45,0:14:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melakukan apa pun yang kau suka.
Dialogue: 0,0:14:29.07,0:14:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan, ya?
Dialogue: 0,0:14:30.74,0:14:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin dipikirkan,
Dialogue: 0,0:14:32.12,0:14:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku makin merasa…
Dialogue: 0,0:14:34.62,0:14:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, ke mana saja boleh.
Dialogue: 0,0:14:39.25,0:14:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh aku bilang begitu?
Dialogue: 0,0:14:43.09,0:14:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak…
Dialogue: 0,0:14:44.00,0:14:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga mau sekalian makan?
Dialogue: 0,0:14:45.09,0:14:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kususun rencana terbaik\Nuntuk mengajakmu jalan-jalan!
Dialogue: 0,0:14:46.67,0:14:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya satu permintaan lagi.
Dialogue: 0,0:14:49.13,0:14:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku terlalu pasif, ya?
Dialogue: 0,0:15:02.52,0:15:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Museum!
Dialogue: 0,0:15:07.32,0:15:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir kali aku ke sini sepertinya\Nwaktu karyawisata SD.
Dialogue: 0,0:15:10.03,0:15:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sering ke sini?
Dialogue: 0,0:15:11.78,0:15:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang. Aku cuma ingat\Nkalau aku suka tempat ini waktu masih kecil.
Dialogue: 0,0:15:14.74,0:15:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kelihatan, sih.
Dialogue: 0,0:15:17.83,0:15:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salah satu alasannya, tapi…
Dialogue: 0,0:15:21.33,0:15:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Film yang sedang tayang enggak terlalu bagus.
Dialogue: 0,0:15:24.17,0:15:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pernah.
Dialogue: 0,0:15:27.05,0:15:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya agak singkat.
Dialogue: 0,0:15:33.55,0:15:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keputusan yang dia ambil\Nsetelah banyak pertimbangan.
Dialogue: 0,0:15:37.98,0:15:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung sudah di sini,
Dialogue: 0,0:15:39.02,0:15:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau kita lihat\Npameran khususnya juga?
Dialogue: 0,0:15:40.14,0:15:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:15:41.56,0:15:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pameran khusus ini ternyata ramai banget.
Dialogue: 0,0:15:44.94,0:15:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:49.86,0:15:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa melihat apa-apa.
Dialogue: 0,0:15:54.95,0:15:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tani, kau di mana?
Dialogue: 0,0:15:58.04,0:16:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, aku di sini!
Dialogue: 0,0:16:12.30,0:16:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bisa melihat kepala orang-orang.
Dialogue: 0,0:16:23.52,0:16:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:16:24.90,0:16:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa minta maaf?
Dialogue: 0,0:16:25.86,0:16:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak perlu minta maaf, kok.
Dialogue: 0,0:16:30.32,0:16:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum lihat pameran regulernya, kan?
Dialogue: 0,0:16:32.65,0:16:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo kita keliling lagi!
Dialogue: 0,0:16:41.00,0:16:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini terlihat jelas.
Dialogue: 0,0:16:43.00,0:16:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam luas sekali, ya.
Dialogue: 0,0:16:48.50,0:16:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hewan yang dipelihara Emil juga?
Dialogue: 0,0:16:50.30,0:16:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak…
Dialogue: 0,0:16:52.38,0:16:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu sekali!
Dialogue: 0,0:16:55.55,0:16:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakinya lucu banget!
Dialogue: 0,0:17:05.77,0:17:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak banget yang bisa dilihat!
Dialogue: 0,0:17:15.49,0:17:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar sudah gelap.
Dialogue: 0,0:17:17.49,0:17:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak hal menarik di sini.
Dialogue: 0,0:17:18.91,0:17:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari sudah gelap\Ntapi kita belum selesai melihat semuanya.
Dialogue: 0,0:17:21.16,0:17:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Museum ini seru banget!
Dialogue: 0,0:17:24.71,0:17:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali!
Dialogue: 0,0:17:29.09,0:17:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar banget.
Dialogue: 0,0:17:30.92,0:17:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan dulu sebelum pulang.
Dialogue: 0,0:17:33.05,0:17:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada restoran enak di dekat sini.
Dialogue: 0,0:17:35.76,0:17:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke sana.
Dialogue: 0,0:17:37.26,0:17:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah mencari tahu, ya.
Dialogue: 0,0:17:39.05,0:17:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:17:42.68,0:17:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:17:43.60,0:17:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa. Mau bagaimana lagi.
Dialogue: 0,0:17:45.44,0:17:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya ada tempat lain di sekitar sini.
Dialogue: 0,0:17:48.44,0:17:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar sudah\Nmerencanakan semuanya, ya!
Dialogue: 0,0:17:51.73,0:17:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh…
Dialogue: 0,0:17:53.90,0:17:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau makan ramen atau semacamnya,\Nantreannya pasti lumayan cepat.
Dialogue: 0,0:17:57.53,0:17:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Mau ikut antre?
Dialogue: 0,0:18:02.04,0:18:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cari tempat lain saja, yuk.
Dialogue: 0,0:18:04.75,0:18:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas kita enggak\Nsanggup bayar di sini…
Dialogue: 0,0:18:07.62,0:18:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau makan di sini kalau sudah dewasa nanti.
Dialogue: 0,0:18:10.88,0:18:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tempat makan murah!
Dialogue: 0,0:18:16.72,0:18:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udaranya jadi sangat dingin\Nsetelah matahari terbenam.
Dialogue: 0,0:18:22.18,0:18:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hangatnya.
Dialogue: 0,0:18:24.31,0:18:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya semua usulku hari ini\Nenggak ada yang berjalan lancar.
Dialogue: 0,0:18:29.81,0:18:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya,
Dialogue: 0,0:18:30.81,0:18:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama ini aku terlalu mengandalkannya, ya?
Dialogue: 0,0:18:33.78,0:18:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, kau pasti capek berjalan seharian.
Dialogue: 0,0:18:36.61,0:18:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, lumayan!
Dialogue: 0,0:18:38.03,0:18:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena banyak jalan,\Nmakanannya jadi terasa lebih lezat.
Dialogue: 0,0:18:42.37,0:18:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali kita enggak bisa makan\Ndi restoran yang kau temukan.
Dialogue: 0,0:18:46.54,0:18:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menurutku makan seperti ini juga seru.
Dialogue: 0,0:18:50.33,0:18:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini kita selalu\Nmelakukan hal yang kusuka.
Dialogue: 0,0:18:53.30,0:18:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kuharap kita bisa melakukan\Nhal yang kau inginkan hari ini.
Dialogue: 0,0:18:57.22,0:19:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung-ujungnya, aku lagi yang\Npaling bersenang-senang hari ini.
Dialogue: 0,0:19:03.97,0:19:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:19:05.56,0:19:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka melihatmu bersenang-senang.
Dialogue: 0,0:19:10.15,0:19:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal ke mana aku ingin pergi\Natau apa yang ingin kulakukan…
Dialogue: 0,0:19:14.02,0:19:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari sekadar tempat atau rencananya,
Dialogue: 0,0:19:17.99,0:19:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah cukup senang bisa\Nmenghabiskan waktu bersamamu.
Dialogue: 0,0:19:23.95,0:19:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:19:25.12,0:19:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham!
Dialogue: 0,0:19:28.12,0:19:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga begitu!
Dialogue: 0,0:19:31.04,0:19:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang sering membahas apa yang\Ningin kulakukan dan ke mana aku mau pergi,
Dialogue: 0,0:19:35.25,0:19:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi itu semua karena aku\Ningin melakukannya bersamamu.
Dialogue: 0,0:19:39.93,0:19:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sama.
Dialogue: 0,0:19:43.01,0:19:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukankah begitu, ya?
Dialogue: 0,0:19:47.60,0:19:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku juga sama.
Dialogue: 0,0:19:50.14,0:19:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, terima kasih untuk semuanya,\Nseperti biasa.
Dialogue: 0,0:19:53.15,0:19:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tiba-tiba bilang begitu?\NHentikan.
Dialogue: 0,0:19:58.44,0:20:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu begitu?
Dialogue: 0,0:20:00.49,0:20:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja aku menyusun\Nrencananya dengan lebih baik.
Dialogue: 0,0:20:03.87,0:20:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa, kok.
Dialogue: 0,0:20:05.91,0:20:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku senang kau sudah berusaha.
Dialogue: 0,0:20:09.04,0:20:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bilangnya, ya?
Dialogue: 0,0:20:10.58,0:20:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih ingin merayakan\Nbirthday bash-mu hari ini,
Dialogue: 0,0:20:15.25,0:20:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akhirnya malah membuatmu\Nmerasa enggak nyaman.
Dialogue: 0,0:20:17.84,0:20:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Birthday ba…
Dialogue: 0,0:20:20.67,0:20:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, aku saja\Nyang terlalu banyak pikiran.
Dialogue: 0,0:20:24.26,0:20:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, museumnya menyenangkan, kok.
Dialogue: 0,0:20:27.22,0:20:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:20:28.27,0:20:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, aku juga mau\Npergi ke museum seni di dekat sini.
Dialogue: 0,0:20:32.31,0:20:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:20:33.48,0:20:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lukisan warna-warni membuatku senang.\N- Aku agak tertarik sejarah seni Barat.
Dialogue: 0,0:20:40.44,0:20:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku kurang punya rasa ingin tahu\Nsoal hal-hal akademis…
Dialogue: 0,0:20:44.49,0:20:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, sepertinya aku saja\Nyang enggak punya jiwa seni.
Dialogue: 0,0:20:56.92,0:20:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai jumpa besok di sekolah.
Dialogue: 0,0:21:32.96,0:21:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:21:56.23,0:21:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:22:14.75,0:22:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!
Dialogue: 0,0:22:16.50,0:22:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kelihatan senang banget!
