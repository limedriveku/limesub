Dialogue: 0,0:00:06.65,0:00:11.23,tanda,,0000,0000,0000,,"PANDUAN WISATA"
Dialogue: 0,0:00:24.83,0:00:26.13,tanda,,0000,0000,0000,,"DIA"
Dialogue: 0,0:00:26.16,0:00:27.75,tanda,,0000,0000,0000,,"DIA"
Dialogue: 0,0:01:16.88,0:01:18.13,tanda,,0000,0000,0000,,"MENAMPIKNYA"
Dialogue: 0,0:01:19.68,0:01:20.97,tanda,,0000,0000,0000,,"TAPI AKU SELAMAT…"
Dialogue: 0,0:01:33.52,0:01:38.36,tanda,,0000,0000,0000,,"YOU AND I ARE POLAR OPPOSITES"
Dialogue: 0,0:02:54.08,0:02:56.21,tanda,,0000,0000,0000,,"BATU RAMALAN CINTA"
Dialogue: 0,0:04:37.94,0:04:39.11,tanda,,0000,0000,0000,,"CINTA"
Dialogue: 0,0:05:01.42,0:05:03.42,tanda,,0000,0000,0000,,"TERTAWA"
Dialogue: 0,0:06:01.31,0:06:03.64,tanda,,0000,0000,0000,,"NISHI, KAU LUAR BIASA."
Dialogue: 0,0:06:04.02,0:06:06.32,tanda,,0000,0000,0000,,"FOTO SEBELUMNYA"
Dialogue: 0,0:06:23.79,0:06:26.21,tanda,,0000,0000,0000,,"BISAKAH KAU KELUAR SEKARANG?"
Dialogue: 0,0:06:45.65,0:06:47.52,tanda,,0000,0000,0000,,"AKU DI LOBI DENGAN BANYAK KURSI."
Dialogue: 0,0:07:21.02,0:07:22.18,tanda,,0000,0000,0000,,"TAMBAHKAN TEMAN"
Dialogue: 0,0:07:28.40,0:07:29.44,tanda,,0000,0000,0000,,"KETAHUAN…"
Dialogue: 0,0:08:54.99,0:08:57.11,tanda,,0000,0000,0000,,"SUDAH HAMPIR GILIRAN KITA MANDI."
Dialogue: 0,0:09:52.71,0:09:54.80,tanda,,0000,0000,0000,,"SEMENTARA ITU, DI TEMPAT LAIN"
Dialogue: 0,0:09:54.88,0:09:56.88,tanda,,0000,0000,0000,,"MENGHEMBUSKAN NAPAS"
Dialogue: 0,0:10:29.59,0:10:31.34,tanda,,0000,0000,0000,,"PANDUAN WISATA"
Dialogue: 0,0:10:31.42,0:10:32.46,tanda,,0000,0000,0000,,"HARI 3: AKTIVITAS KELAS"
Dialogue: 0,0:11:15.97,0:11:17.02,tanda,,0000,0000,0000,,"AZUMA TAHU DIRIKU YANG LAMA."
Dialogue: 0,0:11:17.05,0:11:18.65,tanda,,0000,0000,0000,,"AKU BIASA TERPURUK."
Dialogue: 0,0:11:18.68,0:11:20.07,tanda,,0000,0000,0000,,"AKU TIDAK MAU DIA BERPIKIR\NAKU MENCOBA BERSIKAP KEREN."
Dialogue: 0,0:11:25.77,0:11:28.65,tanda,,0000,0000,0000,,"KERUPUK RUSA"
Dialogue: 0,0:12:28.42,0:12:30.92,tanda,,0000,0000,0000,,"MENGURUS PERMAINAN BUS"
Dialogue: 0,0:12:52.94,0:12:53.83,tanda,,0000,0000,0000,,"YAMADA MENGATUR PERMAINAN"
Dialogue: 0,0:12:53.86,0:12:55.04,tanda,,0000,0000,0000,,"TANI PINDAH KURSI"
Dialogue: 0,0:12:55.07,0:12:56.78,tanda,,0000,0000,0000,,"SUZUKI MENGATUR PERMAINAN"
Dialogue: 0,0:13:03.37,0:13:04.92,tanda,,0000,0000,0000,,"BISKUIT KOALA, YONYON, PERMEN MELETUS"
Dialogue: 0,0:13:16.59,0:13:19.26,tanda,,0000,0000,0000,,"PERMEN KARET ROLET RUSIA"
Dialogue: 0,0:14:42.55,0:14:44.56,tanda,,0000,0000,0000,,"DIA BACA DI INTERNET"
Dialogue: 0,0:14:46.34,0:14:48.68,tanda,,0000,0000,0000,,"ASTAGA"
Dialogue: 0,0:16:51.01,0:16:53.47,tanda,,0000,0000,0000,,"SEMENTARA ITU, DI TEMPAT LAIN "2")
Dialogue: 0,0:16:58.73,0:17:00.91,tanda,,0000,0000,0000,,"ULTRA SUPER JUMBO LAND"
Dialogue: 0,0:17:00.94,0:17:02.52,tanda,,0000,0000,0000,,"PANDUAN WISATA"
Dialogue: 0,0:17:02.61,0:17:03.77,tanda,,0000,0000,0000,,"HARI TERAKHIR: WAKTU BEBAS"
Dialogue: 0,0:20:05.96,0:20:08.87,tanda,,0000,0000,0000,,"PENGHARGAAN CEMAS TAHUNAN"
Dialogue: 0,0:21:34.67,0:21:35.77,tanda,,0000,0000,0000,,"SEKELOMPOK ANJING"
Dialogue: 0,0:21:35.80,0:21:36.93,tanda,,0000,0000,0000,,"RAMAH"
Dialogue: 0,0:21:36.96,0:21:38.63,tanda,,0000,0000,0000,,"RAMAH"
Dialogue: 0,0:21:39.17,0:21:41.01,tanda,,0000,0000,0000,,"MENATAP…"
Dialogue: 0,0:21:50.89,0:21:51.78,tanda,,0000,0000,0000,,"AKU TAK PERCAYA KAU MEMAKAI ITU…"
Dialogue: 0,0:21:51.81,0:21:54.89,tanda,,0000,0000,0000,,"AKU TAK PERCAYA KAU MEMAKAI ITU…"
Dialogue: 0,0:22:19.51,0:22:22.01,tanda,,0000,0000,0000,,"SAMPAI JUMPA EPISODE BERIKUTNYA"
Dialogue: 0,0:00:06.65,0:00:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisata Kelulusan Hari 2: Aktivitas Grup.
Dialogue: 0,0:00:12.57,0:00:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun musim gugur\Ndan tamannya sungguh indah.
Dialogue: 0,0:00:15.74,0:00:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun musim gugur memang indah,
Dialogue: 0,0:00:17.91,0:00:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi waktu kita enggak pernah pas.
Dialogue: 0,0:00:19.82,0:00:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:00:21.62,0:00:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pura-pura enggak tahu?
Dialogue: 0,0:00:23.70,0:00:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau pergi
Dialogue: 0,0:00:24.83,0:00:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke tempat yang sama dengannya?
Dialogue: 0,0:00:26.16,0:00:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, begini…
Dialogue: 0,0:00:27.83,0:00:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya berharap\Nkita kebetulan bertemu.
Dialogue: 0,0:00:31.71,0:00:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah senang\Nbisa mengambil foto yang bagus.
Dialogue: 0,0:00:35.92,0:00:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku sempat berharap…
Dialogue: 0,0:00:39.85,0:00:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuma berharap pada kebetulan.
Dialogue: 0,0:00:43.35,0:00:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian enggak\Nmembuat rencana bertemu?
Dialogue: 0,0:00:47.48,0:00:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berduaan di luar sekolah?
Dialogue: 0,0:00:50.98,0:00:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak mungkin berani melakukannya.
Dialogue: 0,0:00:53.48,0:00:57.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku enggak tega\Nmeninggalkanmu sendirian.
Dialogue: 0,0:00:59.07,0:01:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Itu alasanmu? Yang benar saja?
Dialogue: 0,0:01:03.54,0:01:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku. Aku membuat alasan konyol.
Dialogue: 0,0:01:06.62,0:01:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku memaafkanmu.
Dialogue: 0,0:01:08.42,0:01:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci orang yang berbohong\Ndemi menyembunyikan perasaannya.
Dialogue: 0,0:01:11.46,0:01:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:01:14.17,0:01:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian bicarakan?
Dialogue: 0,0:01:16.88,0:01:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:01:18.76,0:01:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berbohong.
Dialogue: 0,0:02:56.59,0:02:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu ini membawa\Nkeberuntungan cinta!
Dialogue: 0,0:02:58.88,0:02:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:02:59.97,0:03:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berjalan ke arah batu itu\Ndengan mata terpejam,
Dialogue: 0,0:03:03.72,0:03:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harapan cintamu akan terwujud.
Dialogue: 0,0:03:07.56,0:03:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, rasanya tetap memalukan.
Dialogue: 0,0:03:09.85,0:03:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku! Biar aku saja!
Dialogue: 0,0:03:17.07,0:03:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa, Yamada!
Dialogue: 0,0:03:18.82,0:03:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:03:20.49,0:03:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada-man!
Dialogue: 0,0:03:21.65,0:03:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada berhasil melakukannya.
Dialogue: 0,0:03:23.36,0:03:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanan!
Dialogue: 0,0:03:24.49,0:03:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiri!
Dialogue: 0,0:03:25.57,0:03:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiri, kanan!
Dialogue: 0,0:03:26.49,0:03:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke arah mana?
Dialogue: 0,0:03:29.12,0:03:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjuangan yang bagus!
Dialogue: 0,0:03:31.33,0:03:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kau menemukan cintamu.
Dialogue: 0,0:03:33.62,0:03:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morimo!
Dialogue: 0,0:03:34.96,0:03:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau? Jangan halangi aku!
Dialogue: 0,0:03:37.34,0:03:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mau!
Dialogue: 0,0:03:38.38,0:03:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badanku lebih besar dari batu ini,\Nberkatnya pasti jauh lebih kuat.
Dialogue: 0,0:03:42.22,0:03:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logika aneh macam apa itu?
Dialogue: 0,0:03:49.64,0:03:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang memakai\Nseragam sekolah kita di sini.
Dialogue: 0,0:03:53.35,0:03:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Kelas 7?
Dialogue: 0,0:03:55.90,0:03:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sapa saja dia.
Dialogue: 0,0:03:57.81,0:04:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sedang bersama teman-temannya.
Dialogue: 0,0:04:00.44,0:04:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mungkin mengganggu obrolan mereka.
Dialogue: 0,0:04:03.53,0:04:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau pikir begitu, lupakan saja.
Dialogue: 0,0:04:07.53,0:04:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, lihat ke sini.
Dialogue: 0,0:04:09.87,0:04:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tani, tersenyumlah.
Dialogue: 0,0:04:11.29,0:04:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah macam apa itu di depan kamera?
Dialogue: 0,0:04:13.46,0:04:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, lihat kamera dan tersenyumlah.
Dialogue: 0,0:04:15.75,0:04:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini studio foto anak?
Dialogue: 0,0:04:16.88,0:04:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, wajahmu kaku sekali.
Dialogue: 0,0:04:18.88,0:04:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, wajahmu aneh.
Dialogue: 0,0:04:20.55,0:04:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahku aneh?
Dialogue: 0,0:04:22.13,0:04:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat potret.
Dialogue: 0,0:04:24.26,0:04:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau memotretnya.
Dialogue: 0,0:04:26.09,0:04:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lumayan bagus.
Dialogue: 0,0:04:28.05,0:04:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisata kelulusan dengan pacar\Nterdengar menyenangkan.
Dialogue: 0,0:04:33.81,0:04:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun punya pacar,\Naku takkan seterbuka itu.
Dialogue: 0,0:04:39.19,0:04:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja membeli jimat.
Dialogue: 0,0:04:40.61,0:04:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikan masa depanku.
Dialogue: 0,0:04:42.61,0:04:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licik sekali.\NKau kemari hanya untuk menggangguku.
Dialogue: 0,0:04:45.32,0:04:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mendapat berkat.
Dialogue: 0,0:04:47.91,0:04:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada.
Dialogue: 0,0:04:54.54,0:04:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau mendadak.
Dialogue: 0,0:04:56.96,0:04:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebetulan melihatmu.
Dialogue: 0,0:05:03.92,0:05:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin mengobrol denganmu.
Dialogue: 0,0:05:11.56,0:05:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:13.43,0:05:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Nishi!
Dialogue: 0,0:05:14.93,0:05:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita berfoto bersama.
Dialogue: 0,0:05:19.27,0:05:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya sangat indah.
Dialogue: 0,0:05:21.15,0:05:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mendadak begini?
Dialogue: 0,0:05:29.16,0:05:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada mengirim foto yang baru diambil.
Dialogue: 0,0:05:32.58,0:05:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak pasangan enggak terduga\Ndi foto-foto ini.
Dialogue: 0,0:05:35.58,0:05:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:05:37.29,0:05:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bukan\Nkarena wisata kelulusan,
Dialogue: 0,0:05:39.42,0:05:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita takkan pernah berfoto bersama.
Dialogue: 0,0:05:46.05,0:05:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, ini kesempatan langka.
Dialogue: 0,0:05:47.59,0:05:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian berdua enggak berfoto saja?
Dialogue: 0,0:05:50.30,0:05:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku berfoto denganmu?
Dialogue: 0,0:05:54.51,0:05:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa, terlalu banyak orang.
Dialogue: 0,0:05:57.39,0:06:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengajaknya bicara saja\Nsudah menguras seluruh tenagaku.
Dialogue: 0,0:06:01.31,0:06:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah berusaha sangat keras.
Dialogue: 0,0:06:04.02,0:06:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Yamada itu bodoh.
Dialogue: 0,0:06:06.40,0:06:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tambahkan aku ke grup obrolan.
Dialogue: 0,0:06:07.78,0:06:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia enggak mengirimnya ke Nishi?
Dialogue: 0,0:06:10.03,0:06:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodohnya. Dia enggak tahu apa-apa.
Dialogue: 0,0:06:11.16,0:06:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini kesempatan bagus\Nuntuk menghubunginya?
Dialogue: 0,0:06:14.99,0:06:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pesan baru.
Dialogue: 0,0:06:16.12,0:06:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu foto?
Dialogue: 0,0:06:22.54,0:06:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto apa itu?
Dialogue: 0,0:06:27.34,0:06:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pesan ini untukku?
Dialogue: 0,0:06:29.59,0:06:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Pukul berapa ini?
Dialogue: 0,0:06:31.80,0:06:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:06:35.26,0:06:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nishi, temuilah dia!
Dialogue: 0,0:06:36.85,0:06:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku enggak tega meninggalkanmu\Nsendirian di kamar.
Dialogue: 0,0:06:39.35,0:06:42.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada siaran langsung yang ingin kutonton,\Njadi enggak masalah.
Dialogue: 0,0:06:42.56,0:06:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:06:44.73,0:06:45.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei,
Dialogue: 0,0:06:45.65,0:06:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tunggu aku!
Dialogue: 0,0:06:48.90,0:06:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lebih banyak orang berkeliaran\Ndaripada dugaanku.
Dialogue: 0,0:06:53.66,0:06:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu Yamada.\N- Hei, Yamada!
Dialogue: 0,0:06:56.45,0:06:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada\N- Hai.
Dialogue: 0,0:06:57.37,0:06:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- beberapa gadis yang enggak kukenal.\N- Hai.
Dialogue: 0,0:06:58.91,0:07:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua berjalan lancar?
Dialogue: 0,0:07:00.16,0:07:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ya.\N- Apa?
Dialogue: 0,0:07:01.41,0:07:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan dia enggak\Nhanya meneleponku?
Dialogue: 0,0:07:05.92,0:07:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dah.
Dialogue: 0,0:07:06.84,0:07:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mereka pergi.\N- Dah.
Dialogue: 0,0:07:08.46,0:07:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Saat kupikirkan itu,\N- Hai.
Dialogue: 0,0:07:09.59,0:07:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada orang lain lagi yang datang.
Dialogue: 0,0:07:11.01,0:07:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka saling menyapa dengan gaya\Nyang hanya ada di luar negeri.
Dialogue: 0,0:07:14.18,0:07:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, Yamada\Nsepertinya sering bergaul dengan gadis.
Dialogue: 0,0:07:19.18,0:07:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh.
Dialogue: 0,0:07:21.02,0:07:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa…
Dialogue: 0,0:07:22.31,0:07:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini, aku selalu menganggap\Nsikap Yamada kepadaku
Dialogue: 0,0:07:25.31,0:07:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai tanda sayangnya.
Dialogue: 0,0:07:27.44,0:07:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu memikirkan semuanya
Dialogue: 0,0:07:28.40,0:07:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sendirian.
Dialogue: 0,0:07:30.03,0:07:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika ini hanya kesalahpahaman\Nyang sangat memalukan?
Dialogue: 0,0:07:34.16,0:07:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang langka bagiku
Dialogue: 0,0:07:36.07,0:07:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin saja sangat normal bagi Yamada.
Dialogue: 0,0:07:38.83,0:07:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?\NAku sangat enggak berpengalaman.
Dialogue: 0,0:07:40.95,0:07:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan enggak pernah berpikir\Nuntuk meragukannya.
Dialogue: 0,0:07:43.96,0:07:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:07:45.00,0:07:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau di sini,\Nseharusnya kau meneleponku.
Dialogue: 0,0:07:49.38,0:07:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihatmu bersama orang lain.
Dialogue: 0,0:07:54.22,0:07:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak mau terlihat?
Dialogue: 0,0:07:56.09,0:07:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu…
Dialogue: 0,0:07:58.39,0:08:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku terlalu peduli omongan orang.
Dialogue: 0,0:08:01.02,0:08:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:08:03.64,0:08:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga enggak suka sekarang.
Dialogue: 0,0:08:06.02,0:08:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sekarang"…
Dialogue: 0,0:08:08.11,0:08:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:08:09.44,0:08:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke tempat yang tenang\Ndan bicara berdua saja.
Dialogue: 0,0:08:17.45,0:08:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua pikiran negatif\Nyang berantakan di benakku
Dialogue: 0,0:08:20.95,0:08:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lenyap seketika.
Dialogue: 0,0:08:30.46,0:08:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapan dan sikap Yamada selalu lugas.
Dialogue: 0,0:08:37.89,0:08:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kucing ini masih di sini\Nsaat kau lewat tadi?
Dialogue: 0,0:08:41.01,0:08:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak.
Dialogue: 0,0:08:42.22,0:08:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali.
Dialogue: 0,0:08:43.92,0:08:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Taira, yang baru kusebutkan.
Dialogue: 0,0:08:46.44,0:08:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku pernah melihatnya.
Dialogue: 0,0:08:48.65,0:08:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Azuma.
Dialogue: 0,0:08:50.36,0:08:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bersikap seperti kakak.
Dialogue: 0,0:08:51.69,0:08:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cowok berbadan besar\Ndan berambut cepak ini adalah Morimo.
Dialogue: 0,0:08:53.28,0:08:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morimo?
Dialogue: 0,0:08:57.41,0:08:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus kembali.
Dialogue: 0,0:08:58.95,0:09:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:09:04.83,0:09:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:09:07.33,0:09:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah wisata kelulusan ini,\Nkau mau jalan-jalan?
Dialogue: 0,0:09:12.75,0:09:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke tempat di mana kita\Ntakkan bertemu teman sekelas.
Dialogue: 0,0:09:15.76,0:09:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana saja boleh.
Dialogue: 0,0:09:17.43,0:09:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita berdua.
Dialogue: 0,0:09:21.10,0:09:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:22.93,0:09:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menjawab apa?
Dialogue: 0,0:09:31.40,0:09:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mulai memikirkan perasaan Yamada,
Dialogue: 0,0:09:33.86,0:09:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada banyak hal yang enggak bisa kupahami.
Dialogue: 0,0:09:37.28,0:09:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci orang yang berbohong\Nuntuk menyembunyikan perasaannya.
Dialogue: 0,0:09:41.53,0:09:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa lagi menyembunyikan…
Dialogue: 0,0:09:45.87,0:09:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perasaanku ini.
Dialogue: 0,0:09:49.46,0:09:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukainya.
Dialogue: 0,0:09:54.88,0:09:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasku memang yang terbaik!
Dialogue: 0,0:09:59.02,0:10:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat SMP,
Dialogue: 0,0:10:00.52,0:10:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku enggan ikut wisata kelulusan,
Dialogue: 0,0:10:01.64,0:10:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi enggak bisa menolaknya.
Dialogue: 0,0:10:02.60,0:10:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku pergi dengan terpaksa.
Dialogue: 0,0:10:04.06,0:10:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin segera pulang,\Nmenahannya sepanjang jalan.
Dialogue: 0,0:10:09.53,0:10:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang…
Dialogue: 0,0:10:21.91,0:10:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya,
Dialogue: 0,0:10:24.25,0:10:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa sangat bahagia.
Dialogue: 0,0:10:27.79,0:10:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisata Kelulusan Hari 3:
Dialogue: 0,0:10:29.59,0:10:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aktivitas Kelas.
Dialogue: 0,0:10:36.26,0:10:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru, bolehkah kami beli es krim?
Dialogue: 0,0:10:39.01,0:10:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini santai sekali.
Dialogue: 0,0:10:40.77,0:10:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, boleh.
Dialogue: 0,0:10:41.68,0:10:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:10:43.02,0:10:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita selesai lebih awal\Ndari rencana.
Dialogue: 0,0:10:45.48,0:10:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:10:46.61,0:10:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa disadari,\Nenggak ada kelas lain di sekitar sini.
Dialogue: 0,0:10:49.69,0:10:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kalian kembali\Nsebelum bus berangkat,
Dialogue: 0,0:10:52.03,0:10:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bebas pergi ke mana pun.
Dialogue: 0,0:10:53.86,0:10:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:10:55.49,0:10:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:10:56.57,0:10:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore…
Dialogue: 0,0:10:57.53,0:10:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita beli es krim.
Dialogue: 0,0:10:59.58,0:11:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:00.91,0:11:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:11:01.95,0:11:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menatapku seperti itu.
Dialogue: 0,0:11:06.00,0:11:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan saat akhirnya aku bebas\Ndari kampung halamanku
Dialogue: 0,0:11:08.25,0:11:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan nyaris terbawa suasana,
Dialogue: 0,0:11:11.21,0:11:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku berkaca pada diriku sendiri,\Naku mulai menahan diri.
Dialogue: 0,0:11:14.76,0:11:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama saat
Dialogue: 0,0:11:15.97,0:11:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bersama Azuma.
Dialogue: 0,0:11:17.05,0:11:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segala macam pikiran selalu muncul.
Dialogue: 0,0:11:20.10,0:11:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harga diriku yang setengah matang\Nserta rasa rendah diriku…
Dialogue: 0,0:11:23.64,0:11:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba membahas ini?
Dialogue: 0,0:11:25.77,0:11:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membeli biskuit rusa.
Dialogue: 0,0:11:29.02,0:11:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu bungkus isi sepuluh potong.\NAku akan membaginya.
Dialogue: 0,0:11:30.82,0:11:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:11:32.65,0:11:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:33.57,0:11:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:11:34.61,0:11:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, ayo kita bagi ini.
Dialogue: 0,0:11:37.49,0:11:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:11:41.79,0:11:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah ditunggu.
Dialogue: 0,0:11:44.00,0:11:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya rusa-rusa itu terbiasa diberi makan.
Dialogue: 0,0:11:47.42,0:11:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali yang datang.
Dialogue: 0,0:11:49.38,0:11:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, ini mulai terasa menakutkan.
Dialogue: 0,0:11:52.50,0:11:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air liur.
Dialogue: 0,0:11:53.42,0:11:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:11:54.63,0:11:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam… Tunggu, diam…
Dialogue: 0,0:11:56.17,0:11:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, diamlah…
Dialogue: 0,0:11:57.59,0:12:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, tunggu…\N- Yamada terus mengajak rusa bicara.
Dialogue: 0,0:12:00.93,0:12:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rusa itu memakannya dan langsung pergi.
Dialogue: 0,0:12:06.31,0:12:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa bukan itu masalahnya.
Dialogue: 0,0:12:08.85,0:12:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah habis!
Dialogue: 0,0:12:10.23,0:12:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira sangat populer di kalangan rusa.
Dialogue: 0,0:12:13.98,0:12:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan hanya tertawa! Bantu aku!
Dialogue: 0,0:12:23.79,0:12:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:28.42,0:12:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kita tiba di hotel nanti,
Dialogue: 0,0:12:31.00,0:12:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersabarlah denganku sebentar.
Dialogue: 0,0:12:33.80,0:12:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat tangan\Nyang masih semangat berpesta!
Dialogue: 0,0:12:37.67,0:12:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:12:39.30,0:12:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meniru pembawa acara konser!
Dialogue: 0,0:12:41.89,0:12:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani di barisan depan,\Nbagaimana mabuk daratmu?
Dialogue: 0,0:12:46.81,0:12:49.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembawa acara ini sangat bias.
Dialogue: 0,0:12:49.39,0:12:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira.
Dialogue: 0,0:12:51.44,0:12:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduklah di sini.
Dialogue: 0,0:12:52.94,0:12:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya,
Dialogue: 0,0:12:53.86,0:12:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan bermain
Dialogue: 0,0:12:55.07,0:12:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}teka-teki.
Dialogue: 0,0:12:56.86,0:12:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teka-teki pertama!
Dialogue: 0,0:12:58.78,0:13:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua hewan apa
Dialogue: 0,0:13:00.16,0:13:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang bersembunyi di tanggal 1 April?\N- Aku beli banyak camilan. Ayo makan.
Dialogue: 0,0:13:03.37,0:13:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu banyak!
Dialogue: 0,0:13:04.95,0:13:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mirip
Dialogue: 0,0:13:05.91,0:13:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- camilan karyawisata anak SD.\N- Ada yang tahu jawabannya?
Dialogue: 0,0:13:07.87,0:13:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat bernostalgia.
Dialogue: 0,0:13:08.91,0:13:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nabe yang merekomendasikannya.\N- Yamada, jawablah.
Dialogue: 0,0:13:10.58,0:13:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Entahlah.
Dialogue: 0,0:13:11.50,0:13:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ada masalah dengan pilihanku?\N- Jangan menjawab terlalu keras!
Dialogue: 0,0:13:13.34,0:13:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku enggak mengeluh. Duduklah.\N- Jawabannya ada di tanggal 1 April.
Dialogue: 0,0:13:16.59,0:13:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, salah satunya adalah kejutan.
Dialogue: 0,0:13:19.34,0:13:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, ambillah. Beri tahu aku\Njika kau yang beruntung.
Dialogue: 0,0:13:24.60,0:13:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kau enggak akan mengerti.
Dialogue: 0,0:13:28.35,0:13:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asam sekali.
Dialogue: 0,0:13:29.39,0:13:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Reaksi yang sangat membosankan.\N- Berikutnya, teka-teki ketiga!
Dialogue: 0,0:13:30.89,0:13:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu reaksi yang normal?
Dialogue: 0,0:13:32.69,0:13:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu berharap.
Dialogue: 0,0:13:33.61,0:13:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebutan untuk sembilan burung\Nyang berkumpul?
Dialogue: 0,0:13:37.90,0:13:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu!
Dialogue: 0,0:13:39.15,0:13:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zuma, terima kasih\Natas partisipasi aktifmu!
Dialogue: 0,0:13:41.86,0:13:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung myna!
Dialogue: 0,0:13:42.91,0:13:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah!
Dialogue: 0,0:13:43.82,0:13:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sayang sekali!\N- Dia salah.
Dialogue: 0,0:13:46.08,0:13:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa? Padahal aku sangat yakin.\N- Sayang sekali. Jawabannya merpati.
Dialogue: 0,0:13:49.96,0:13:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa merpati?
Dialogue: 0,0:13:51.12,0:13:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Karena memakai
Dialogue: 0,0:13:52.33,0:13:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau terkejut aku salah?\N- huruf kanji "sembilan" dan "burung".
Dialogue: 0,0:13:54.25,0:13:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Enggak.\N- Yamada, bisa menulis kanji 'merpati'?
Dialogue: 0,0:13:55.96,0:13:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa Azuma\N- Itu nyaris mustahil.
Dialogue: 0,0:13:58.59,0:14:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- selalu seperti ini?\N- Kau baik-baik saja?
Dialogue: 0,0:14:04.93,0:14:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, kau baik-baik saja?
Dialogue: 0,0:14:07.39,0:14:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan malam hari ini prasmanan.
Dialogue: 0,0:14:09.14,0:14:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa makan?
Dialogue: 0,0:14:10.06,0:14:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging!
Dialogue: 0,0:14:11.69,0:14:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuat dia membayangkannya.
Dialogue: 0,0:14:13.85,0:14:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin cari udara segar.\NKalian pergilah.
Dialogue: 0,0:14:16.94,0:14:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dirimu.
Dialogue: 0,0:14:18.28,0:14:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungi aku jika kau bingung arahnya.
Dialogue: 0,0:14:20.65,0:14:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:22.03,0:14:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus kehabisan teh saat ini…
Dialogue: 0,0:14:25.37,0:14:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa. Terima kasih.
Dialogue: 0,0:14:32.46,0:14:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum soda sebelum prasmanan?
Dialogue: 0,0:14:36.42,0:14:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak perlu seterkejut itu.
Dialogue: 0,0:14:39.00,0:14:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kudengar minum soda
Dialogue: 0,0:14:42.55,0:14:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa meredakan mabuk darat.
Dialogue: 0,0:14:44.59,0:14:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh perhatian!
Dialogue: 0,0:14:46.34,0:14:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan bersikap begitu!
Dialogue: 0,0:14:49.64,0:14:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sering mabuk darat?
Dialogue: 0,0:14:52.60,0:14:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak juga.
Dialogue: 0,0:14:54.85,0:14:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga enggak tahu kenapa.
Dialogue: 0,0:14:56.02,0:14:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sudah baik-baik saja sekarang.
Dialogue: 0,0:14:57.81,0:14:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:14:59.36,0:15:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang enggak enak badan?\NMasih ada satu hari lagi besok.
Dialogue: 0,0:15:03.61,0:15:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:15:05.07,0:15:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar agak dingin,\Nayo kembali ke dalam dan mencari…
Dialogue: 0,0:15:13.33,0:15:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah bersamaku sedikit lebih lama.
Dialogue: 0,0:15:18.79,0:15:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:36.44,0:15:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan itu? Sia-sia saja aku cemas!
Dialogue: 0,0:15:42.44,0:15:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:15:43.49,0:15:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjiwa muda sekali! Aku terkejut.
Dialogue: 0,0:15:46.91,0:15:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya indah. Sangat seru.
Dialogue: 0,0:15:48.66,0:15:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sama sekali enggak bagus atau seru.
Dialogue: 0,0:15:51.79,0:15:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah, aku akan meminumnya sendiri.
Dialogue: 0,0:15:58.75,0:16:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:16:02.13,0:16:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku enggak kuat. Perutku sakit!
Dialogue: 0,0:16:04.71,0:16:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menertawakan penderitaan orang!
Dialogue: 0,0:16:06.76,0:16:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar untuk tertawa dalam situasi ini.
Dialogue: 0,0:16:15.73,0:16:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa…
Dialogue: 0,0:16:17.19,0:16:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau lebih terasa seperti
Dialogue: 0,0:16:20.48,0:16:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}teman sekelasku daripada yang kuduga.
Dialogue: 0,0:16:28.95,0:16:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu sudah jelas?
Dialogue: 0,0:16:32.20,0:16:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya apa lagi?
Dialogue: 0,0:16:33.87,0:16:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kan selalu mengobrol dengan santai,
Dialogue: 0,0:16:36.75,0:16:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kita sekelas juga tahun lalu, kan?
Dialogue: 0,0:16:40.00,0:16:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar…
Dialogue: 0,0:16:44.21,0:16:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bilang bahwa dia sudah berubah.
Dialogue: 0,0:16:47.13,0:16:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, untuk apa kukatakan itu?\NItu menjijikkan.
Dialogue: 0,0:16:51.01,0:16:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa itu tadi?
Dialogue: 0,0:16:53.56,0:16:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu enggak adil! Dia sangat manis!
Dialogue: 0,0:16:58.73,0:17:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari terakhir wisata kelulusan!
Dialogue: 0,0:17:00.94,0:17:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu bebas!
Dialogue: 0,0:17:07.10,0:17:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahana mana yang harus kita naiki dulu?
Dialogue: 0,0:17:08.70,0:17:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi waktu kita enggak banyak.
Dialogue: 0,0:17:11.31,0:17:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian akan pergi berduaan saja, kan?
Dialogue: 0,0:17:13.78,0:17:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebakanmu terang-terangan sekali.
Dialogue: 0,0:17:14.95,0:17:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selamat berkencan!
Dialogue: 0,0:17:16.75,0:17:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun kita berpapasan,\Nkami akan pura-pura enggak melihat.
Dialogue: 0,0:17:19.04,0:17:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, enggak perlu berlebihan begitu.
Dialogue: 0,0:17:21.50,0:17:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasangan sering bertengkar\Nsaat kencan di taman hiburan.
Dialogue: 0,0:17:23.96,0:17:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhati-hatilah.
Dialogue: 0,0:17:25.13,0:17:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mulai lagi…
Dialogue: 0,0:17:27.58,0:17:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika pria menunjukkan sifat aslinya\Nsaat mengantre atau menyetir,
Dialogue: 0,0:17:31.38,0:17:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anggap saja itu sifat aslinya.
Dialogue: 0,0:17:33.51,0:17:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak bicara dari pengalaman, kan?
Dialogue: 0,0:17:37.35,0:17:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus melakukan apa dulu?
Dialogue: 0,0:17:39.39,0:17:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tempat yang ingin kudatangi\Nlebih dulu.
Dialogue: 0,0:17:41.60,0:17:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:17:42.52,0:17:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ember berondong jagung.
Dialogue: 0,0:17:44.36,0:17:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengalungkannya\Ndan berjalan-jalan.
Dialogue: 0,0:17:46.69,0:17:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat manis, bukan?
Dialogue: 0,0:17:47.98,0:17:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali…
Dialogue: 0,0:17:52.41,0:17:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau akan menyukainya.
Dialogue: 0,0:17:54.74,0:17:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin melihat topi dan bando.
Dialogue: 0,0:17:58.58,0:18:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersemangat!
Dialogue: 0,0:18:06.71,0:18:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihan Tani enggak terduga.
Dialogue: 0,0:18:08.76,0:18:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini…
Dialogue: 0,0:18:10.47,0:18:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau akan cocok memakainya.
Dialogue: 0,0:18:12.84,0:18:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku akan memakainya?
Dialogue: 0,0:18:15.18,0:18:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu ini akan cocok untukku?
Dialogue: 0,0:18:17.47,0:18:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:18:18.93,0:18:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira mana yang cocok untukmu?
Dialogue: 0,0:18:22.94,0:18:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak butuh itu.
Dialogue: 0,0:18:25.40,0:18:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:18:28.36,0:18:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku terlalu bersemangat\Nsendirian lagi.
Dialogue: 0,0:18:31.74,0:18:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendalikan dirimu.
Dialogue: 0,0:18:32.78,0:18:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau enggak, aku bakal kelihatan\Naneh sendiri di sebelahnya.
Dialogue: 0,0:18:37.16,0:18:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di lubuk hatiku, aku berharap\Nbisa memakai bando yang sama.
Dialogue: 0,0:18:42.62,0:18:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan tipe orang seperti itu, kan?
Dialogue: 0,0:18:46.92,0:18:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kita beli bando yang sama?
Dialogue: 0,0:18:48.67,0:18:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari beli barang seperti sebelumnya saja.
Dialogue: 0,0:18:57.10,0:19:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli barang dagangan boleh,\Ntapi bando enggak?
Dialogue: 0,0:19:00.22,0:19:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa membayangkan diriku\Nmemakai barang seperti itu.
Dialogue: 0,0:19:04.31,0:19:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cocok untukmu,
Dialogue: 0,0:19:05.81,0:19:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akan terlihat aneh padaku, kan?
Dialogue: 0,0:19:07.77,0:19:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali enggak aneh.
Dialogue: 0,0:19:09.98,0:19:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ini tempat untuk bersantai.
Dialogue: 0,0:19:13.70,0:19:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali jika enggak membebaskan diri.
Dialogue: 0,0:19:16.16,0:19:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah dari cangkangmu, Yusuke.
Dialogue: 0,0:19:21.20,0:19:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak sangat enggan.
Dialogue: 0,0:19:22.79,0:19:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa. Jangan memaksakan diri.
Dialogue: 0,0:19:29.63,0:19:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba? Silakan.
Dialogue: 0,0:19:31.59,0:19:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:38.30,0:19:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku mulai merasa ini manis.
Dialogue: 0,0:19:41.68,0:19:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baru merasa ini manis sekarang?
Dialogue: 0,0:19:56.61,0:19:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali!
Dialogue: 0,0:19:59.91,0:20:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nabe dan yang lainnya bilang\Nantreannya sangat panjang.
Dialogue: 0,0:20:02.79,0:20:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyuruhku berhati-hati\Nagar enggak bertengkar denganmu.
Dialogue: 0,0:20:05.96,0:20:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi lebih sulit untuk enggak menikmatinya.
Dialogue: 0,0:20:10.00,0:20:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:11.96,0:20:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurasa kita enggak punya waktu\Nuntuk mengantre.
Dialogue: 0,0:20:15.13,0:20:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya hampir habis?
Dialogue: 0,0:20:19.39,0:20:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dapat pesan dari Azu.
Dialogue: 0,0:20:22.26,0:20:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya semua orang sudah berkumpul.
Dialogue: 0,0:20:24.77,0:20:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita temui mereka juga.
Dialogue: 0,0:20:28.31,0:20:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah harus kembali?\NSayang sekali.
Dialogue: 0,0:20:36.07,0:20:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi
Dialogue: 0,0:20:43.29,0:20:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yu…
Dialogue: 0,0:20:47.50,0:20:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:49.42,0:20:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini…
Dialogue: 0,0:20:52.04,0:20:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita cari jalan memutar.
Dialogue: 0,0:20:57.88,0:21:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yusuke, aku agak…
Dialogue: 0,0:21:02.30,0:21:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini…
Dialogue: 0,0:21:04.26,0:21:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, kemarin juga.
Dialogue: 0,0:21:06.31,0:21:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, bahkan sebelum itu.
Dialogue: 0,0:21:09.48,0:21:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mencoba membunuhku?
Dialogue: 0,0:21:13.32,0:21:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengatakannya, ya?
Dialogue: 0,0:21:15.53,0:21:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa…
Dialogue: 0,0:21:17.32,0:21:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga menjadi aneh.
Dialogue: 0,0:21:20.91,0:21:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tertawa?
Dialogue: 0,0:21:28.21,0:21:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tampak lucu.
Dialogue: 0,0:21:29.62,0:21:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian memakai itu?
Dialogue: 0,0:21:31.08,0:21:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan kalian?
Dialogue: 0,0:21:32.29,0:21:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ingin tampil manis.
Dialogue: 0,0:21:33.71,0:21:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Staf mengejek kami
Dialogue: 0,0:21:34.67,0:21:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke mana pun kami pergi.
Dialogue: 0,0:21:35.80,0:21:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu mereka akan bicara
Dialogue: 0,0:21:36.96,0:21:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan orang seperti itu.
Dialogue: 0,0:21:49.35,0:21:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira…
Dialogue: 0,0:21:50.89,0:21:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:51.81,0:21:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau hanya bereaksi begitu padaku?
Dialogue: 0,0:21:55.32,0:21:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ayo berfoto bersama.
Dialogue: 0,0:21:57.94,0:21:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:22:01.86,0:22:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau berpikir seharusnya\Nkau bersantai dan mengikuti alurnya?
Dialogue: 0,0:22:05.37,0:22:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak…
Dialogue: 0,0:22:06.49,0:22:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, bersiap ya.
Dialogue: 0,0:22:08.29,0:22:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit.
Dialogue: 0,0:22:10.50,0:22:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu…\N- Baik, senyum!
Dialogue: 0,0:22:13.33,0:22:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kembali lagi kapan-kapan.
