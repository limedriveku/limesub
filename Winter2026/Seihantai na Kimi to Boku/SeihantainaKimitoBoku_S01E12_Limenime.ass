Dialogue: 0,0:00:10.15,0:00:11.11,tanda,,0000,0000,0000,,"HAI"
Dialogue: 0,0:00:24.37,0:00:26.12,tanda,,0000,0000,0000,,"...AH"
Dialogue: 0,0:01:18.84,0:01:21.39,tanda,,0000,0000,0000,,"ENTAH HANYA PERASAANKU..."
Dialogue: 0,0:01:21.47,0:01:24.39,tanda,,0000,0000,0000,,"HEHEHE..."
Dialogue: 0,0:01:24.68,0:01:26.20,tanda,,0000,0000,0000,,"SEPULANG SEKOLAH"
Dialogue: 0,0:01:35.65,0:01:36.79,tanda,,0000,0000,0000,,"TEMAN SEKAMAR DI KAMAR BERSAMA"
Dialogue: 0,0:01:41.95,0:01:43.66,tanda,,0000,0000,0000,,"MENATAP..."
Dialogue: 0,0:02:22.61,0:02:25.43,tanda,,0000,0000,0000,,"BUKANNYA AKU INGIN FOTO DIRIKU SENDIRI."\N"AKU HANYA INGIN "REKAMAN"."
Dialogue: 0,0:03:21.51,0:03:26.64,tanda,,0000,0000,0000,,"YOU AND I ARE POLAR OPPOSITES"
Dialogue: 0,0:04:57.50,0:05:00.38,tanda,,0000,0000,0000,,"TERTAWA"
Dialogue: 0,0:05:00.46,0:05:01.85,tanda,,0000,0000,0000,,"APA AKU TERLIHAT ANEH?"
Dialogue: 0,0:05:01.88,0:05:03.84,tanda,,0000,0000,0000,,"APA AKU TERLIHAT ANEH?"
Dialogue: 0,0:05:13.10,0:05:13.99,tanda,,0000,0000,0000,,"SEPERTI SAAT WISATA KELULUSAN"
Dialogue: 0,0:05:14.02,0:05:15.66,tanda,,0000,0000,0000,,"SAAT PAKAIANKU HAMPIR SAMA PERSIS"
Dialogue: 0,0:05:15.68,0:05:17.54,tanda,,0000,0000,0000,,"BERSEMANGAT"
Dialogue: 0,0:05:22.69,0:05:23.57,tanda,,0000,0000,0000,,"BERTEKAD..."
Dialogue: 0,0:05:23.61,0:05:24.71,tanda,,0000,0000,0000,,"HON SELALU ADA DI PIKIRANKU..."
Dialogue: 0,0:05:26.15,0:05:27.92,tanda,,0000,0000,0000,,"AKU MEMBELI AKSESORI CANTIK"
Dialogue: 0,0:05:27.95,0:05:29.55,tanda,,0000,0000,0000,,"SAAT KEBETULAN MELIHATNYA"
Dialogue: 0,0:05:29.57,0:05:31.66,tanda,,0000,0000,0000,,"JADI, GAYAKU TIDAK KONSISTEN"
Dialogue: 0,0:05:54.89,0:05:56.06,tanda,,0000,0000,0000,,"WAH..."
Dialogue: 0,0:05:56.14,0:05:57.89,tanda,,0000,0000,0000,,"SANGAT MERIAH"
Dialogue: 0,0:06:15.99,0:06:19.21,tanda,,0000,0000,0000,,"STASIUN TEMPAT MEREKA BERTEMU"
Dialogue: 0,0:06:19.54,0:06:21.58,tanda,,0000,0000,0000,,"BERLEBIHAN"
Dialogue: 0,0:06:24.42,0:06:26.17,tanda,,0000,0000,0000,,"DENGAN PANIK"
Dialogue: 0,0:06:28.38,0:06:30.63,tanda,,0000,0000,0000,,"AKU DI SINI! KAU DI MANA?"
Dialogue: 0,0:07:48.84,0:07:50.80,tanda,,0000,0000,0000,,"PUTAR - WAX - KERASKAN"
Dialogue: 0,0:07:57.93,0:07:59.45,tanda,,0000,0000,0000,,"TERUS MELIHAT BAGIAN INI"
Dialogue: 0,0:07:59.47,0:08:01.76,tanda,,0000,0000,0000,,"TERUS MELIHAT BAGIAN INI"
Dialogue: 0,0:08:06.40,0:08:08.48,tanda,,0000,0000,0000,,"PECINAN"
Dialogue: 0,0:09:40.45,0:09:41.34,tanda,,0000,0000,0000,,"ATURAN YAMADA SENDIRI"
Dialogue: 0,0:09:43.74,0:09:45.05,tanda,,0000,0000,0000,,"MENATAP..."
Dialogue: 0,0:13:55.84,0:13:57.40,tanda,,0000,0000,0000,,"KOMENTATOR YETI"
Dialogue: 0,0:13:57.42,0:13:59.50,tanda,,0000,0000,0000,,"STASIUN TEMPAT MEREKA BERTEMU"
Dialogue: 0,0:14:29.87,0:14:30.75,tanda,,0000,0000,0000,,"TETAP BERDEKATAN..."
Dialogue: 0,0:14:36.71,0:14:39.75,tanda,,0000,0000,0000,,"TIDAK ADA REAKSI..."
Dialogue: 0,0:14:41.59,0:14:44.55,tanda,,0000,0000,0000,,"MEMELUKNYA ERAT..."
Dialogue: 0,0:14:45.64,0:14:47.05,tanda,,0000,0000,0000,,"PECINAN"
Dialogue: 0,0:15:07.20,0:15:09.57,tanda,,0000,0000,0000,,"PENGLIHATAN 20/10"
Dialogue: 0,0:15:10.12,0:15:11.79,tanda,,0000,0000,0000,,"SET..."
Dialogue: 0,0:15:46.86,0:15:48.95,tanda,,0000,0000,0000,,"BERSEMANGAT"
Dialogue: 0,0:17:21.25,0:17:23.33,tanda,,0000,0000,0000,,"AKU MEMBUATNYA TERTAWA..."
Dialogue: 0,0:17:54.41,0:17:56.54,tanda,,0000,0000,0000,,"MENATAP..."
Dialogue: 0,0:19:30.92,0:19:31.92,tanda,,0000,0000,0000,,"BERPISAH"
Dialogue: 0,0:19:58.49,0:20:02.49,tanda,,0000,0000,0000,,"JANTUNG BERDEBAR"
Dialogue: 0,0:20:59.47,0:21:01.60,tanda,,0000,0000,0000,,"INI DIA"
Dialogue: 0,0:21:05.68,0:21:07.39,tanda,,0000,0000,0000,,"SUP KRIM JAGUNG"
Dialogue: 0,0:21:38.92,0:21:41.43,tanda,,0000,0000,0000,,"ITU SAMA SEKALI TIDAK NATURAL..."
Dialogue: 0,0:21:57.44,0:21:58.57,tanda,,0000,0000,0000,,"TEGANG"
Dialogue: 0,0:22:04.78,0:22:06.99,tanda,,0000,0000,0000,,"MENYERINGAI"
Dialogue: 0,0:22:16.55,0:22:18.46,tanda,,0000,0000,0000,,"HEHE..."
Dialogue: 0,0:22:19.84,0:22:22.01,tanda,,0000,0000,0000,,"SAMPAI JUMPA MUSIM BERIKUTNYA"
Dialogue: 0,0:00:00.97,0:00:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah wisata kelulusan\Nyang menyenangkan...
Dialogue: 0,0:00:04.77,0:00:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani!
Dialogue: 0,0:00:07.27,0:00:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami jadi jauh lebih dekat\Ndaripada sebelumnya.
Dialogue: 0,0:00:10.15,0:00:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:00:11.53,0:00:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelahmu sudah hilang\Nsetelah wisata kelulusan?
Dialogue: 0,0:00:14.69,0:00:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri bagaimana, Suzuki?
Dialogue: 0,0:00:16.61,0:00:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja.
Dialogue: 0,0:00:19.74,0:00:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ada apa?
Dialogue: 0,0:00:22.41,0:00:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Suzuki..."
Dialogue: 0,0:00:27.04,0:00:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu.
Dialogue: 0,0:00:31.42,0:00:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memanggil nama belakangku\Nsekarang, 'kan?
Dialogue: 0,0:00:35.09,0:00:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Benarkah?
Dialogue: 0,0:00:37.18,0:00:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, ini sekolah.
Dialogue: 0,0:00:39.34,0:00:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya agak...
Dialogue: 0,0:00:40.93,0:00:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:43.39,0:00:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya kita berdua,\Npasti akan luar biasa.
Dialogue: 0,0:00:47.02,0:00:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti luar biasa.\NKau akan lebih proaktif.
Dialogue: 0,0:00:51.19,0:00:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sengaja mempersulitnya.
Dialogue: 0,0:00:54.15,0:00:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski enggak banyak perkembangan\Natau kemajuan drastis,
Dialogue: 0,0:00:58.45,0:01:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih merasakan\Nperubahan positif yang kecil.
Dialogue: 0,0:01:01.20,0:01:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba berbicara begitu?
Dialogue: 0,0:01:03.95,0:01:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengumpulkan sejarah\Naset budaya penting.
Dialogue: 0,0:01:07.75,0:01:09.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wabi-sabi Jepang.
Dialogue: 0,0:01:09.50,0:01:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisan tangan Sato bagus.
Dialogue: 0,0:01:11.46,0:01:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:01:12.75,0:01:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sangat bangga?
Dialogue: 0,0:01:16.72,0:01:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:01:18.84,0:01:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi negatif Azuma
Dialogue: 0,0:01:21.47,0:01:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya sudah berkurang.
Dialogue: 0,0:01:24.68,0:01:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, kau sudah memesan
Dialogue: 0,0:01:26.22,0:01:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}foto wisata kelulusan?
Dialogue: 0,0:01:27.73,0:01:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum.
Dialogue: 0,0:01:28.73,0:01:33.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa disadari, lingkaran pertemanan\NTani menjadi sedikit lebih besar.
Dialogue: 0,0:01:33.98,0:01:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pilih dua ini.
Dialogue: 0,0:01:35.65,0:01:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fotomu bagus di sini.
Dialogue: 0,0:01:36.82,0:01:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak berpikir begitu, 'kan?
Dialogue: 0,0:01:38.24,0:01:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mungkin aku membeli ini.
Dialogue: 0,0:01:41.95,0:01:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki sepertinya menatapku.
Dialogue: 0,0:01:43.74,0:01:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lihat Tani yang fotogenik.
Dialogue: 0,0:01:47.75,0:01:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan foto ini?
Dialogue: 0,0:01:49.62,0:01:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fotografer memotretnya\Nsaat dia ke kamar bersama.
Dialogue: 0,0:01:54.38,0:01:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini versi lainnya.
Dialogue: 0,0:01:55.88,0:01:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol sekali.
Dialogue: 0,0:01:57.84,0:02:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Tani enggak membelinya,\Naku akan memesannya.
Dialogue: 0,0:02:00.34,0:02:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak perlu membelinya.
Dialogue: 0,0:02:04.64,0:02:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang harus kubeli berikutnya?
Dialogue: 0,0:02:06.89,0:02:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harganya akan sangat mahal.\NKalau kupesan terlalu banyak,
Dialogue: 0,0:02:10.63,0:02:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gapacho mengatakan,\Nuntuk wisata kelulusan SMP-nya,
Dialogue: 0,0:02:14.27,0:02:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia memesan banyak foto\Nyang isinya hanya pemandangan.
Dialogue: 0,0:02:16.69,0:02:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, orang tuanya memarahinya.
Dialogue: 0,0:02:18.57,0:02:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya foto pemandangan?
Dialogue: 0,0:02:20.20,0:02:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gapacho memiliki selera yang bagus.
Dialogue: 0,0:02:21.70,0:02:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti maksudmu.
Dialogue: 0,0:02:25.45,0:02:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak mengambil banyak,\Njadi enggak apa-apa.
Dialogue: 0,0:02:29.29,0:02:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau mengambil banyak.
Dialogue: 0,0:02:30.33,0:02:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:02:31.96,0:02:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpura-puralah enggak melihatnya.\NKau mengerti maksudku?
Dialogue: 0,0:02:35.96,0:02:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku enggak akan menjadi\Npetugas kelas untuk sementara.
Dialogue: 0,0:02:38.21,0:02:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa lega.
Dialogue: 0,0:02:39.42,0:02:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak aku dipilih menjadi\Npetugas kelas saat sedang sakit,
Dialogue: 0,0:02:41.80,0:02:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku enggak menyukai kelas kita.
Dialogue: 0,0:02:43.72,0:02:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, entah kenapa,\Nwisata kelulusan cukup menyenangkan.
Dialogue: 0,0:02:48.27,0:02:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarnya.
Dialogue: 0,0:03:03.28,0:03:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalian berdua mau ke mana?
Dialogue: 0,0:03:07.28,0:03:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:04:41.73,0:04:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:04:43.86,0:04:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau pergi kapan-kapan?
Dialogue: 0,0:04:45.74,0:04:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita berdua.
Dialogue: 0,0:04:48.11,0:04:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan gayaku, tapi mari kita coba.
Dialogue: 0,0:04:52.99,0:04:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berdandan.
Dialogue: 0,0:04:55.33,0:04:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu, ibuku...
Dialogue: 0,0:04:57.50,0:05:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ada apa? Kau berdandan.
Dialogue: 0,0:05:00.46,0:05:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pernah mengatakan itu.
Dialogue: 0,0:05:01.88,0:05:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa agak malu.
Dialogue: 0,0:05:04.09,0:05:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jarang mengenakan gaun,\Nbagaimana kalau aku mencobanya?
Dialogue: 0,0:05:08.39,0:05:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enggak apa-apa?\NAku akan terlihat aneh mengenakan ini?
Dialogue: 0,0:05:12.18,0:05:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya aku
Dialogue: 0,0:05:13.10,0:05:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya memikirkan kenyamanan.
Dialogue: 0,0:05:14.02,0:05:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku enggak tahu.
Dialogue: 0,0:05:15.68,0:05:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting mengenakan yang kuinginkan.
Dialogue: 0,0:05:17.56,0:05:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau orang mencoba melabeliku
Dialogue: 0,0:05:18.85,0:05:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau mengatakan ada hal lain\Nyang lebih cocok untukku,
Dialogue: 0,0:05:20.27,0:05:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku enggak peduli. Menyebalkan sekali!
Dialogue: 0,0:05:22.69,0:05:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:24.73,0:05:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan langka.
Dialogue: 0,0:05:26.15,0:05:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah membeli aksesori ini,
Dialogue: 0,0:05:27.95,0:05:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi enggak pernah sempat memakainya.
Dialogue: 0,0:05:29.57,0:05:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencobanya.
Dialogue: 0,0:05:34.49,0:05:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:05:36.25,0:05:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:39.17,0:05:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:05:41.21,0:05:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa jantungku\Nenggak mau berhenti berdebar.
Dialogue: 0,0:05:49.26,0:05:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat!
Dialogue: 0,0:05:50.51,0:05:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau mau berangkat?
Dialogue: 0,0:05:53.05,0:05:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:05:54.89,0:05:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil keluar
Dialogue: 0,0:05:56.14,0:05:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa diketahui keluargaku!
Dialogue: 0,0:05:59.27,0:06:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru menyadarinya\Nsaat akan mengenakannya.
Dialogue: 0,0:06:01.73,0:06:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak punya jaket atau sepatu\Nyang cocok dengan gaun ini.
Dialogue: 0,0:06:05.53,0:06:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya membeli barang\Nyang menurutku manis.
Dialogue: 0,0:06:08.11,0:06:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak pernah memikirkan cara\Nmemadukannya dengan yang kumiliki.
Dialogue: 0,0:06:14.37,0:06:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana...
Dialogue: 0,0:06:15.99,0:06:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak pernah menyadarinya sebelumnya,
Dialogue: 0,0:06:19.54,0:06:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi para gadis di jalanan
Dialogue: 0,0:06:21.67,0:06:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat modis.
Dialogue: 0,0:06:24.42,0:06:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kulepaskan.
Dialogue: 0,0:06:31.05,0:06:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga di sini.
Dialogue: 0,0:06:34.76,0:06:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di eskalator di belakang peron.
Dialogue: 0,0:06:49.49,0:06:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Nishi?
Dialogue: 0,0:06:50.86,0:06:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Kau tersesat?
Dialogue: 0,0:06:53.24,0:06:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah di sini.
Dialogue: 0,0:06:55.58,0:06:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:06:57.04,0:07:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di alun-alun\Nsetelah kau naik eskalator.
Dialogue: 0,0:07:06.42,0:07:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama sekali\Nenggak melihat ke arah sini.
Dialogue: 0,0:07:09.51,0:07:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dekat gerbang tiket.
Dialogue: 0,0:07:11.76,0:07:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sampai.
Dialogue: 0,0:07:12.84,0:07:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinyalnya buruk.
Dialogue: 0,0:07:15.05,0:07:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:07:16.05,0:07:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau sangat kaku?
Dialogue: 0,0:07:17.81,0:07:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa terkejut?
Dialogue: 0,0:07:19.31,0:07:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku menabrak orang asing.
Dialogue: 0,0:07:22.02,0:07:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kau sangat kaku sedari tadi.
Dialogue: 0,0:07:26.44,0:07:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau gugup?
Dialogue: 0,0:07:27.90,0:07:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau harus menanyakan itu?
Dialogue: 0,0:07:31.99,0:07:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:36.12,0:07:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu "mm-hmm".
Dialogue: 0,0:07:42.54,0:07:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Omong-omong, aku merasa...
Dialogue: 0,0:07:45.00,0:07:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rambut Yamada berbeda dari biasanya.
Dialogue: 0,0:07:48.84,0:07:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sungguh berusaha.
Dialogue: 0,0:07:51.67,0:07:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:07:52.72,0:07:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku lupa\Nseperti apa dia biasanya.
Dialogue: 0,0:07:55.93,0:07:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Sering kali...
Dialogue: 0,0:07:57.93,0:07:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jarang menatap matanya
Dialogue: 0,0:07:59.47,0:08:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku berbicara dengannya.
Dialogue: 0,0:08:06.40,0:08:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami belum pernah mengunjungi tempat ini.
Dialogue: 0,0:08:08.73,0:08:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mengenakan pakaian biasa, bukan seragam
Dialogue: 0,0:08:11.44,0:08:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berjalan bersama.
Dialogue: 0,0:08:16.95,0:08:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa lebih canggung\Ndaripada biasanya.
Dialogue: 0,0:08:22.33,0:08:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa aku terlihat aneh\Nberdiri di sampingnya.
Dialogue: 0,0:08:26.33,0:08:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lapar?
Dialogue: 0,0:08:28.08,0:08:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat lapar...
Dialogue: 0,0:08:29.84,0:08:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kelaparan.
Dialogue: 0,0:08:31.71,0:08:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lapar, ayo lekas mencari makanan.
Dialogue: 0,0:08:36.47,0:08:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat bersikap tenang,\Ntetapi berubah di tengah jalan.
Dialogue: 0,0:08:39.42,0:08:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:08:41.92,0:08:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tampak lezat.
Dialogue: 0,0:08:44.81,0:08:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini agak terlambat,
Dialogue: 0,0:08:46.65,0:08:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau enggak keberatan datang\Nke tempat yang kuinginkan?
Dialogue: 0,0:08:50.15,0:08:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba aku sangat ingin\Nmemakan bakpao daging yang lezat.
Dialogue: 0,0:08:53.94,0:08:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena cuacanya makin dingin.
Dialogue: 0,0:08:55.40,0:08:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:56.91,0:09:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering memakan camilan kukus di toserba,
Dialogue: 0,0:09:00.49,0:09:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi saat pulang kerja tempo hari,
Dialogue: 0,0:09:02.33,0:09:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mencium aroma bakpao daging\Ndari rumah seseorang.
Dialogue: 0,0:09:04.50,0:09:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kupikir, "Benar, Pecinan!"
Dialogue: 0,0:09:08.12,0:09:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira bekerja paruh waktu\Ndi toserba langgananku.
Dialogue: 0,0:09:11.34,0:09:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira. Yang berambut cokelat.
Dialogue: 0,0:09:14.46,0:09:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Morimo benar-benar\Nmembuat Mini tertawa.
Dialogue: 0,0:09:17.43,0:09:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai mengingat banyak nama orang\Nmelalui Yamada.
Dialogue: 0,0:09:21.43,0:09:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku memberi tahu Gapacho soal ini...
Dialogue: 0,0:09:24.72,0:09:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berbicara tanpa henti.
Dialogue: 0,0:09:26.60,0:09:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:09:30.90,0:09:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camilan kukus di toserba...
Dialogue: 0,0:09:34.15,0:09:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diam-diam penasaran
Dialogue: 0,0:09:35.69,0:09:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kau menyebut bakpao daging\N"camilan kukus".
Dialogue: 0,0:09:38.95,0:09:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada bakpao piza juga,
Dialogue: 0,0:09:40.45,0:09:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ya, 'kan?
Dialogue: 0,0:09:41.37,0:09:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:09:43.74,0:09:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa lagi kali ini?
Dialogue: 0,0:09:45.08,0:09:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma makanan orang lain.
Dialogue: 0,0:09:47.29,0:09:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu kari, aku bisa mengerti.
Dialogue: 0,0:09:48.83,0:09:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aroma bakpao daging?
Dialogue: 0,0:09:50.46,0:09:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kau pasti bisa menciumnya!
Dialogue: 0,0:09:52.17,0:09:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum pernah melihat orang\Nmembawa makanan di kereta?
Dialogue: 0,0:09:55.05,0:09:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma itu sungguh menyiksa.
Dialogue: 0,0:09:58.55,0:09:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Benar, Pecinan!"
Dialogue: 0,0:10:00.05,0:10:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah berlalu.\NKau selalu seperti ini.
Dialogue: 0,0:10:02.93,0:10:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menunggu terlalu lama,\Norang takkan tahu maksudmu.
Dialogue: 0,0:10:06.31,0:10:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:10:07.52,0:10:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku itu menarik.
Dialogue: 0,0:10:08.56,0:10:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa aku harus mengatakan sesuatu,\Ntetapi aku enggak ingin menyela.
Dialogue: 0,0:10:11.61,0:10:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sela saja sesukamu.
Dialogue: 0,0:10:13.06,0:10:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih memalukan diejek setelah sekian lama.
Dialogue: 0,0:10:16.86,0:10:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Itu sungguh menyiksa."
Dialogue: 0,0:10:18.40,0:10:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menertawakannya sekarang?
Dialogue: 0,0:10:22.37,0:10:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pergi ke mana pada waktu luang\Nsaat wisata kelulusan?
Dialogue: 0,0:10:25.16,0:10:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pergi ke teater komedi.
Dialogue: 0,0:10:28.21,0:10:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berfoto di depan papan nama
Dialogue: 0,0:10:30.29,0:10:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu pergi ke pusat elektronik,\Ndan semacamnya.
Dialogue: 0,0:10:33.17,0:10:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebanyakan dari kelas kami menginap\Ndi Ultra Super Jumbo Land.
Dialogue: 0,0:10:36.76,0:10:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto grup Inoopy yang kau kirimkan
Dialogue: 0,0:10:39.55,0:10:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku tertawa terbahak-bahak.
Dialogue: 0,0:10:40.51,0:10:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung aku membelinya,
Dialogue: 0,0:10:42.26,0:10:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi itu enggak berguna di tempat lain.
Dialogue: 0,0:10:46.10,0:10:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku gugup\Nkarena kami enggak berada di sekolah,
Dialogue: 0,0:10:50.19,0:10:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi aku mulai bersantai\Nsedikit demi sedikit.
Dialogue: 0,0:10:53.02,0:10:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sebenarnya aku merasa lebih tenang\N- Aku enggak bisa memotret pemandangannya.
Dialogue: 0,0:10:55.86,0:10:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- di tempat yang enggak kukenal.\N- Bagaimana kalau format horizontal?
Dialogue: 0,0:11:04.16,0:11:06.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap dia merasakan hal yang sama.
Dialogue: 0,0:11:08.33,0:11:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat jembatan itu juga.
Dialogue: 0,0:11:29.68,0:11:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini luar biasa.
Dialogue: 0,0:11:32.23,0:11:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya indah.
Dialogue: 0,0:11:34.65,0:11:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:11:37.15,0:11:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, jantungku seakan mau meledak.
Dialogue: 0,0:11:41.15,0:11:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak sanggup melihat wajahnya.
Dialogue: 0,0:11:43.45,0:11:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin.
Dialogue: 0,0:11:44.91,0:11:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali di tepi laut.
Dialogue: 0,0:11:46.49,0:11:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada sangat tenang.
Dialogue: 0,0:11:48.91,0:11:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya perasaanku saja yang kacau
Dialogue: 0,0:11:51.87,0:11:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti orang bodoh?
Dialogue: 0,0:11:58.63,0:11:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:12:10.68,0:12:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lari!\N- Baik!
Dialogue: 0,0:12:13.02,0:12:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali!
Dialogue: 0,0:12:13.94,0:12:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Nishi!\NKau menjatuhkan sesuatu!
Dialogue: 0,0:12:17.40,0:12:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu menakutkan.
Dialogue: 0,0:12:21.74,0:12:25.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,\Nbagian akhirnya menjadi sangat aneh.
Dialogue: 0,0:12:25.78,0:12:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, jam malamku terlalu awal.
Dialogue: 0,0:12:29.24,0:12:31.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa.
Dialogue: 0,0:12:32.00,0:12:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, napasmu baik-baik saja?
Dialogue: 0,0:12:33.71,0:12:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kita berlari tadi...
Dialogue: 0,0:12:37.08,0:12:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menjatuhkan banyak barang.
Dialogue: 0,0:12:40.05,0:12:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau enggak mengenakan ini hari ini, 'kan?
Dialogue: 0,0:12:42.09,0:12:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu membawanya?
Dialogue: 0,0:12:43.51,0:12:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:12:45.97,0:12:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung di sini,\Naku akan memasangkannya untukmu.
Dialogue: 0,0:12:48.47,0:12:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini manis.
Dialogue: 0,0:12:49.72,0:12:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis?
Dialogue: 0,0:12:51.01,0:12:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lembut.
Dialogue: 0,0:12:52.97,0:12:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya itu lembut.
Dialogue: 0,0:12:56.10,0:12:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Menjepitnya sulit.
Dialogue: 0,0:12:58.23,0:12:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita memang luar biasa.
Dialogue: 0,0:13:00.65,0:13:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa ini aneh?
Dialogue: 0,0:13:03.99,0:13:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:13:06.07,0:13:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, lebih mudah untuk bertatapan.
Dialogue: 0,0:13:08.66,0:13:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau enggak pernah menatapku.
Dialogue: 0,0:13:11.70,0:13:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya bukan poniku, melainkan aku.
Dialogue: 0,0:13:16.87,0:13:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:13:19.58,0:13:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menatap matamu.
Dialogue: 0,0:13:23.34,0:13:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menutup matamu\Nsebelum selesai berbicara.
Dialogue: 0,0:13:25.72,0:13:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali...
Dialogue: 0,0:13:27.68,0:13:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali?
Dialogue: 0,0:13:31.05,0:13:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi lagi.
Dialogue: 0,0:13:32.43,0:13:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita berdua.
Dialogue: 0,0:13:47.24,0:13:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lari!\N- Baik!
Dialogue: 0,0:13:55.84,0:13:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara Yamada dan Nishi
Dialogue: 0,0:13:57.42,0:13:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertemu di stasiun,
Dialogue: 0,0:13:59.59,0:14:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada hari yang sama,\Nsekitar satu jam lalu...
Dialogue: 0,0:14:04.30,0:14:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dek observasi!
Dialogue: 0,0:14:06.81,0:14:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langit biru, pemandangan laut,\Ntempat wisata populer.
Dialogue: 0,0:14:11.27,0:14:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terasa...
Dialogue: 0,0:14:14.15,0:14:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlalu mirip kencan.
Dialogue: 0,0:14:17.52,0:14:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?\NAku menjadi sangat gugup.
Dialogue: 0,0:14:20.36,0:14:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memang berdua saat wisata kelulusan,
Dialogue: 0,0:14:23.53,0:14:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi kami lebih sering bersama grup,\Ndan semua orang berada di dekat kami.
Dialogue: 0,0:14:30.79,0:14:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa sedikit menempel\Ndan mendekat hari ini, 'kan?
Dialogue: 0,0:14:33.92,0:14:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa? Menurutku itu bagus!
Dialogue: 0,0:14:41.59,0:14:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak peduli hari ini.
Dialogue: 0,0:14:45.64,0:14:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula...
Dialogue: 0,0:14:47.43,0:14:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tampak lezat.
Dialogue: 0,0:14:49.14,0:14:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini agak jauh dari rumah.
Dialogue: 0,0:14:51.60,0:14:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ada kami berdua.
Dialogue: 0,0:14:52.85,0:14:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencoba Bakpao Goreng Sirip Hiu.
Dialogue: 0,0:14:55.56,0:14:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Yusuke?
Dialogue: 0,0:14:56.65,0:14:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku akan menikmati
Dialogue: 0,0:14:57.90,0:15:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- perubahan suasana ini.\N- Lumpia itu tampak lezat.
Dialogue: 0,0:15:00.98,0:15:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu juga enak.
Dialogue: 0,0:15:03.03,0:15:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:15:07.20,0:15:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo makan siang di sini.
Dialogue: 0,0:15:11.87,0:15:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:15:13.08,0:15:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shh. Jangan bersuara.
Dialogue: 0,0:15:15.00,0:15:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menoleh ke belakang.\NLakukan saja perintahku.
Dialogue: 0,0:15:17.38,0:15:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ancaman?
Dialogue: 0,0:15:18.79,0:15:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan bersuara. Masuk ke toko.\N- Aku berniat bersikap tenang,
Dialogue: 0,0:15:20.92,0:15:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa?\N- tetapi berubah di tengah jalan.
Dialogue: 0,0:15:21.84,0:15:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:15:25.68,0:15:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:27.14,0:15:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hendak menggunakan
Dialogue: 0,0:15:28.18,0:15:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mode pacar manja yang enggak biasa hari ini.
Dialogue: 0,0:15:32.14,0:15:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa mereka berkencan?
Dialogue: 0,0:15:34.68,0:15:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mereka dalam kondisi ambigu\Nsebelum berkencan?
Dialogue: 0,0:15:38.15,0:15:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimanapun, kalau mereka berkencan,
Dialogue: 0,0:15:40.48,0:15:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu artinya berjalan lancar.
Dialogue: 0,0:15:42.23,0:15:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yamada.
Dialogue: 0,0:15:44.36,0:15:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:15:45.95,0:15:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan sangat bahagia
Dialogue: 0,0:15:46.86,0:15:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendapat kabar terbaru lain kali.
Dialogue: 0,0:15:50.16,0:15:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini cerah. Ini bagus.
Dialogue: 0,0:15:59.67,0:16:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren sekali.
Dialogue: 0,0:16:01.67,0:16:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren?
Dialogue: 0,0:16:03.17,0:16:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunan itu membuat jantungku berdebar.
Dialogue: 0,0:16:04.88,0:16:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:10.89,0:16:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana...
Dialogue: 0,0:16:12.35,0:16:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat pemandangan malam dengan lampu neon\Ndi pinggir teluk
Dialogue: 0,0:16:15.02,0:16:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terasa sangat dewasa,\Ndan sangat mirip kencan.
Dialogue: 0,0:16:17.69,0:16:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kau bisa bahasa Inggris.
Dialogue: 0,0:16:19.90,0:16:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi rasanya kita berpura-pura\Nmenjadi orang dewasa.
Dialogue: 0,0:16:23.94,0:16:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:16:25.07,0:16:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti kencan. Ini agak memalukan.
Dialogue: 0,0:16:35.54,0:16:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa Yamada dan yang lainnya\Nakan datang ke sini nanti.
Dialogue: 0,0:16:38.83,0:16:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Yamada mengakui perasaannya\Ndi tempat yang elegan,
Dialogue: 0,0:16:41.38,0:16:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nishi akan benar-benar terpesona\Ndan jatuh cinta.
Dialogue: 0,0:16:44.30,0:16:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mereka ada di dekat sini sekarang?
Dialogue: 0,0:16:48.13,0:16:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka enggak ada di sini?
Dialogue: 0,0:16:49.63,0:16:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini indah.
Dialogue: 0,0:16:51.60,0:16:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangannya.
Dialogue: 0,0:16:56.43,0:16:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu.
Dialogue: 0,0:16:58.39,0:17:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke sana?
Dialogue: 0,0:17:04.44,0:17:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yusuke...
Dialogue: 0,0:17:09.45,0:17:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini luar biasa!
Dialogue: 0,0:17:11.10,0:17:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, ini di kota.
Dialogue: 0,0:17:12.61,0:17:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu diam-diam ingin naik kincir ria\Ndengan orang yang kusukai.
Dialogue: 0,0:17:17.20,0:17:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam-diam?
Dialogue: 0,0:17:18.41,0:17:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, itu bohong. Terang-terangan.
Dialogue: 0,0:17:20.21,0:17:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terang-terangan...
Dialogue: 0,0:17:23.71,0:17:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan seperti ini lazim\Ndi adaptasi manga shojo.
Dialogue: 0,0:17:26.80,0:17:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku selalu menginginkannya.
Dialogue: 0,0:17:28.26,0:17:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya live-action?
Dialogue: 0,0:17:30.38,0:17:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:17:32.43,0:17:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik kincir ria berdua\Ndengan orang yang kau sukai.
Dialogue: 0,0:17:39.02,0:17:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku duduk di sampingmu?
Dialogue: 0,0:17:49.11,0:17:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi yang kuinginkan...
Dialogue: 0,0:17:54.41,0:17:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menatap kita.
Dialogue: 0,0:17:56.62,0:17:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang bisa melihatmu dengan mudah\Ndi kincir ria.
Dialogue: 0,0:18:00.71,0:18:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berfoto untuk kenang-kenangan.
Dialogue: 0,0:18:06.59,0:18:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sekali.
Dialogue: 0,0:18:08.96,0:18:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku ingin lebih intim,
Dialogue: 0,0:18:12.72,0:18:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi aku enggak ingin menjadi\Nsatu-satunya yang bersemangat.
Dialogue: 0,0:18:16.26,0:18:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lampu-lampunya sangat cantik.
Dialogue: 0,0:18:18.56,0:18:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah seperti Natal.
Dialogue: 0,0:18:20.73,0:18:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:22.19,0:18:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka suasana yang meriah
Dialogue: 0,0:18:24.19,0:18:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjelang liburan seperti Natal.
Dialogue: 0,0:18:27.82,0:18:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyukai musim ini.
Dialogue: 0,0:18:30.03,0:18:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jingle bells, jingle bells.
Dialogue: 0,0:18:42.00,0:18:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kau lakukan saat Natal?
Dialogue: 0,0:18:47.92,0:18:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ya?
Dialogue: 0,0:18:51.30,0:18:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama aku bisa bersamamu,
Dialogue: 0,0:18:53.47,0:18:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa saja boleh.
Dialogue: 0,0:18:56.30,0:18:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:18:59.76,0:19:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:19:07.31,0:19:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:19:10.07,0:19:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enggak ada orang sekarang.
Dialogue: 0,0:19:32.34,0:19:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil!
Dialogue: 0,0:19:38.14,0:19:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:39.68,0:19:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu! Yusuke!
Dialogue: 0,0:19:41.85,0:19:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:19:44.60,0:19:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja.
Dialogue: 0,0:19:47.40,0:19:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang enggak akan pulang\Nuntuk makan malam,
Dialogue: 0,0:19:49.02,0:19:51.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi, kami pergi mencari makan.
Dialogue: 0,0:19:51.57,0:19:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yusuke, rumahmu ke arah sini?
Dialogue: 0,0:19:54.65,0:19:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Terima kasih.
Dialogue: 0,0:20:04.45,0:20:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian naik kincir ria.
Dialogue: 0,0:20:06.04,0:20:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan malamnya indah.
Dialogue: 0,0:20:08.00,0:20:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti lebih menyenangkan\Njika berputar lebih cepat.
Dialogue: 0,0:20:11.59,0:20:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi, Suzuki, akhirnya kau...\N- Itu wahana yang berbeda.
Dialogue: 0,0:20:14.09,0:20:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:15.01,0:20:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuwujudkan impian lain\Nsebagai penggemar adaptasi manga.
Dialogue: 0,0:20:19.18,0:20:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nishi, jepit rambut itu manis.
Dialogue: 0,0:20:23.18,0:20:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:24.81,0:20:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:20:26.60,0:20:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bersenang-senang?
Dialogue: 0,0:20:30.23,0:20:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pergi ke Pecinan? Bagus.
Dialogue: 0,0:20:33.40,0:20:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakpao dagingnya sangat lezat.
Dialogue: 0,0:20:35.78,0:20:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada juga pergi ke Pecinan?
Dialogue: 0,0:20:38.41,0:20:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan siapa?
Dialogue: 0,0:20:39.78,0:20:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, aku takkan mengatakan apa pun.
Dialogue: 0,0:20:45.50,0:20:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih sore, tetapi sudah gelap.
Dialogue: 0,0:20:50.46,0:20:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jari-jariku dingin.
Dialogue: 0,0:20:52.54,0:20:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu, kenapa tanganmu hangat sekali?
Dialogue: 0,0:20:56.92,0:20:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yusuke, lihat.
Dialogue: 0,0:20:59.47,0:21:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lebih banyak pilihan minuman panas
Dialogue: 0,0:21:01.68,0:21:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mesin penjual otomatis sekarang.
Dialogue: 0,0:21:04.47,0:21:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:21:05.68,0:21:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini membuatku merasa
Dialogue: 0,0:21:07.48,0:21:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti inilah akhir tahun.
Dialogue: 0,0:21:08.94,0:21:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menantikannya setiap tahun?
Dialogue: 0,0:21:11.40,0:21:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita bersenang-senang lagi.
Dialogue: 0,0:21:14.44,0:21:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus dikocok sebelum dibuka.
Dialogue: 0,0:21:16.11,0:21:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau enggak, hal buruk akan terjadi.
Dialogue: 0,0:21:17.74,0:21:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:21:18.65,0:21:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu agak berlebihan?
Dialogue: 0,0:21:22.16,0:21:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti merasakan pergantian musim.
Dialogue: 0,0:21:25.08,0:21:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menikmati perubahan kecil\Nyang indah secara perlahan.
Dialogue: 0,0:21:29.96,0:21:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi... atau lebih tepatnya, Miyu.
Dialogue: 0,0:21:32.50,0:21:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ragu, panggil saja nama depanku.
Dialogue: 0,0:21:41.59,0:21:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau suka saat aku memanggilmu begitu?
Dialogue: 0,0:21:44.05,0:21:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau memanggilku begitu,
Dialogue: 0,0:21:46.10,0:21:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa kau akan merasa lebih malu.
Dialogue: 0,0:21:53.81,0:21:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan macam apa itu?
Dialogue: 0,0:21:57.44,0:21:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu.
Dialogue: 0,0:21:59.40,0:22:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu wajahnya yang enggak malu?
Dialogue: 0,0:22:02.11,0:22:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berubah sedikit demi sedikit.
Dialogue: 0,0:22:13.08,0:22:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu hal lagi.
Dialogue: 0,0:22:16.55,0:22:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang membuatnya seperti ini.
Dialogue: 0,0:22:18.55,0:22:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
