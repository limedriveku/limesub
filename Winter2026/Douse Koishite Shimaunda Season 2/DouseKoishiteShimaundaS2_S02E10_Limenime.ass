Dialogue: 0,0:03:14.01,0:03:16.51,tanda,,0000,0000,0000,,TUTUP
Dialogue: 0,0:07:14.00,0:07:17.54,tanda,,0000,0000,0000,,ENOSHIMA DAIKOKU
Dialogue: 0,0:08:48.26,0:08:53.05,tanda,,0000,0000,0000,,KUIL ENOSHIMA
Dialogue: 0,0:14:16.46,0:14:18.50,tanda,,0000,0000,0000,,HARI INI HARUS MENANG\NKAMU PASTI BISA
Dialogue: 0,0:17:52.05,0:17:54.18,tanda,,0000,0000,0000,,NISHINO
Dialogue: 0,0:23:54.58,0:23:56.29,tanda,,0000,0000,0000,,PINTU MASUK UGD
Dialogue: 0,0:24:10.01,0:24:15.02,tanda,,0000,0000,0000,,EPISODE 23: LAMARAN
Dialogue: 0,0:00:11.28,0:00:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:00:14.41,0:00:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, jadwal tur nasional idolaku\Nsangat banyak.
Dialogue: 0,0:00:18.16,0:00:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:00:19.17,0:00:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil nonton semuanya,
Dialogue: 0,0:00:20.79,0:00:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setidaknya aku ingin datang ke yang dekat...
Dialogue: 0,0:00:23.63,0:00:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu mendengarkanku?
Dialogue: 0,0:00:25.88,0:00:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:26.42,0:00:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi responsmu asal-asalan.
Dialogue: 0,0:00:29.18,0:00:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sedang kepikiran sesuatu.
Dialogue: 0,0:00:33.55,0:00:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada masalah, cerita saja.
Dialogue: 0,0:00:36.73,0:00:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, aku dibilang licik oleh seseorang.
Dialogue: 0,0:00:42.65,0:00:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu fakta?
Dialogue: 0,0:00:44.36,0:00:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin, iya.
Dialogue: 0,0:00:46.07,0:00:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku cuma bisa diam.
Dialogue: 0,0:00:49.15,0:00:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terus dipikirkan,\Nbelum ada jawabannya.
Dialogue: 0,0:00:53.28,0:00:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku sering kepikiran tiba-tiba.
Dialogue: 0,0:00:55.70,0:00:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:00:57.75,0:00:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kamu sudah melalui banyak hal.
Dialogue: 0,0:01:00.46,0:01:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebesar apa rasa cinta,
Dialogue: 0,0:01:02.00,0:01:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasa sedih putus cinta,
Dialogue: 0,0:01:04.37,0:01:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan rasa sakit saat melukai hati seseorang.
Dialogue: 0,0:01:08.13,0:01:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin kita dewasa,
Dialogue: 0,0:01:10.09,0:01:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makin sulit mencari jawaban sederhana.
Dialogue: 0,0:01:13.22,0:01:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahmu serius begitu?
Dialogue: 0,0:01:15.76,0:01:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:01:19.14,0:01:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya enak!
Dialogue: 0,0:01:20.69,0:01:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini piza margherita dengan ekstra tomat.
Dialogue: 0,0:01:23.60,0:01:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Menu rahasia?
Dialogue: 0,0:01:25.86,0:01:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini hidangan spesial.
Dialogue: 0,0:01:29.11,0:01:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makin mirip Pak Hoshikawa, ya.
Dialogue: 0,0:01:33.36,0:01:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:01:36.87,0:01:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Mizuho.
Dialogue: 0,0:01:38.16,0:01:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:01:39.41,0:01:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhir pekan ini, kamu luang?
Dialogue: 0,0:03:26.02,0:03:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama, Mizuho.\NAyo naik.
Dialogue: 0,0:03:28.27,0:03:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, naik mobil?
Dialogue: 0,0:03:29.94,0:03:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mau pergi jauh?
Dialogue: 0,0:03:31.27,0:03:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, wisata kuliner ke Enoshima.
Dialogue: 0,0:03:34.15,0:03:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena butuh bantuan\Nmengembangkan menu baru,
Dialogue: 0,0:03:38.25,0:03:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira kita akan uji cicip makanan\Ndi restoranmu.
Dialogue: 0,0:03:41.66,0:03:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengembangan menu juga butuh riset, kan?
Dialogue: 0,0:03:46.25,0:03:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:03:47.50,0:03:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tapi restorannya bagaimana?
Dialogue: 0,0:03:50.00,0:03:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:03:51.00,0:03:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kutitipkan pada kakakku.
Dialogue: 0,0:03:53.63,0:03:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tougo!
Dialogue: 0,0:03:54.42,0:03:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu.
Dialogue: 0,0:03:57.01,0:04:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada kakakmu yang hebat ini\Ndan bersenang-senanglah.
Dialogue: 0,0:04:00.43,0:04:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Tougo.
Dialogue: 0,0:04:02.21,0:04:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mengobrol kapan-kapan.
Dialogue: 0,0:04:04.60,0:04:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:04:07.60,0:04:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Mizuho.
Dialogue: 0,0:04:15.82,0:04:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski lama tidak bertemu,\Nsyukurlah dia sehat.
Dialogue: 0,0:04:19.16,0:04:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:20.16,0:04:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih riang seperti biasanya.
Dialogue: 0,0:04:22.74,0:04:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sesekali datang untuk membantumu?
Dialogue: 0,0:04:25.45,0:04:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:26.21,0:04:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya saat libur\Natau saat restoran ramai.
Dialogue: 0,0:04:29.46,0:04:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para siswa dan wali murid sekolahnya\Nsuka datang sebagai pelanggan juga.
Dialogue: 0,0:04:35.17,0:04:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:04:36.17,0:04:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Guru Tougo memang sangat populer.
Dialogue: 0,0:04:39.22,0:04:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:56.69,0:05:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat berhenti kuliah\Ndan mewarisi restoran kita.
Dialogue: 0,0:05:01.86,0:05:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kembalilah menjadi guru.
Dialogue: 0,0:05:06.91,0:05:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata soal itu.
Dialogue: 0,0:05:08.82,0:05:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:05:11.00,0:05:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah merelakan profesi itu.
Dialogue: 0,0:05:13.04,0:05:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan saat ini pun cukup pas buatku.
Dialogue: 0,0:05:16.34,0:05:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, soalnya aku jago di semua hal.
Dialogue: 0,0:05:19.92,0:05:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menyembunyikan isi hatimu melulu.
Dialogue: 0,0:05:25.72,0:05:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu kamu memikul semuanya sendirian.
Dialogue: 0,0:05:29.10,0:05:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, lah.
Dialogue: 0,0:05:31.14,0:05:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta kadang tidak perlu diungkapkan.
Dialogue: 0,0:05:37.36,0:05:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sudut pandangmu,\Nmungkin aku tampak selalu menahan diri.
Dialogue: 0,0:05:43.36,0:05:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini pilihanku sendiri,
Dialogue: 0,0:05:46.24,0:05:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena menyayangi keluarga dan semuanya.
Dialogue: 0,0:05:49.83,0:05:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu tidak perlu memikirkannya.
Dialogue: 0,0:05:52.37,0:05:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga memilih jalanku sendiri.
Dialogue: 0,0:05:55.38,0:05:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lisensi koki sudah di tanganku.
Dialogue: 0,0:05:59.92,0:06:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan demi dirimu,\Nmemang inilah yang ingin kulakukan.
Dialogue: 0,0:06:05.89,0:06:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, lakukanlah apa yang kamu juga inginkan.
Dialogue: 0,0:06:09.81,0:06:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalilah menjadi guru.
Dialogue: 0,0:06:12.10,0:06:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar merepotkan.
Dialogue: 0,0:06:14.06,0:06:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu merasa harus melindungimu.
Dialogue: 0,0:06:20.15,0:06:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sadar, kamu juga tumbuh dewasa.
Dialogue: 0,0:06:28.16,0:06:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengaku kalah, terima kasih.
Dialogue: 0,0:06:34.17,0:06:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:06:35.33,0:06:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong buatkan camilan oleh-oleh\Nuntuk kubawa saat kembali bekerja.
Dialogue: 0,0:06:38.85,0:06:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puding Italia buatan sendiri atau semacamnya.
Dialogue: 0,0:06:41.21,0:06:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus aku?
Dialogue: 0,0:06:43.51,0:06:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini permintaan kakakmu yang baik, lo.
Dialogue: 0,0:06:48.97,0:06:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:07:18.08,0:07:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat wisata kuliner,\Ninilah tempat yang tepat.
Dialogue: 0,0:07:21.67,0:07:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shugo, kamu mau makan apa?
Dialogue: 0,0:07:23.51,0:07:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo datangi tempat\Nyang membuatmu tertarik.
Dialogue: 0,0:07:26.76,0:07:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pasti dimulai dengan takoyaki.
Dialogue: 0,0:07:29.51,0:07:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Mizuho!
Dialogue: 0,0:07:32.47,0:07:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya, tahu.\NPerhatikanlah jalanmu baik-baik.
Dialogue: 0,0:07:35.73,0:07:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku akan berhati-hati.
Dialogue: 0,0:07:39.68,0:07:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shugo?
Dialogue: 0,0:07:40.69,0:07:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa, bergandengan tangan akan lebih aman.
Dialogue: 0,0:07:45.86,0:07:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan anak kecil lagi.
Dialogue: 0,0:07:47.74,0:07:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memalukan.
Dialogue: 0,0:07:50.24,0:07:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau takoyaki, kan?
Dialogue: 0,0:07:52.16,0:07:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, jalan.
Dialogue: 0,0:07:53.12,0:07:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Shugo.
Dialogue: 0,0:08:01.25,0:08:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, ada bubuk nori di pipimu.
Dialogue: 0,0:08:04.13,0:08:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:08:05.21,0:08:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bohong.
Dialogue: 0,0:08:06.42,0:08:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:08:07.51,0:08:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sedang viral di media sosial, lo.
Dialogue: 0,0:08:09.80,0:08:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:08:10.80,0:08:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:08:12.22,0:08:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya biasa saja, kan?
Dialogue: 0,0:08:15.35,0:08:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, kok.
Dialogue: 0,0:08:24.61,0:08:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tertarik membuat\Nmasakan yang tampilannya unik?
Dialogue: 0,0:08:28.03,0:08:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupertimbangkan.
Dialogue: 0,0:08:33.87,0:08:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:08:44.42,0:08:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyang sekali.
Dialogue: 0,0:08:45.96,0:08:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo istirahat dulu.
Dialogue: 0,0:08:47.52,0:08:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:59.27,0:09:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anginnya sejuk sekali.
Dialogue: 0,0:09:01.19,0:09:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:02.52,0:09:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:09:03.69,0:09:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu juga ada orang\Nyang bermain paralayang, kan?
Dialogue: 0,0:09:07.19,0:09:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling suka pemandangan di sini.
Dialogue: 0,0:09:09.86,0:09:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat?
Dialogue: 0,0:09:11.03,0:09:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:09:13.37,0:09:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat, saat itu\Ndiriku ingin menjadi nomor satu...
Dialogue: 0,0:09:18.62,0:09:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pemain utama seperti kalian\Ntidak akan mengerti.
Dialogue: 0,0:09:22.71,0:09:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi paling seru dalam percintaan\Nadalah pemain ketiga!
Dialogue: 0,0:09:29.63,0:09:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham?
Dialogue: 0,0:09:30.55,0:09:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, esensi dari cinta adalah...
Dialogue: 0,0:09:33.72,0:09:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cinta bertepuk sebelah tangan.
Dialogue: 0,0:09:38.81,0:09:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shugo?
Dialogue: 0,0:09:40.06,0:09:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan apa-apa.
Dialogue: 0,0:09:42.14,0:09:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita lanjut.
Dialogue: 0,0:09:43.56,0:09:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana?
Dialogue: 0,0:09:44.81,0:09:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akuarium.
Dialogue: 0,0:09:46.32,0:09:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:09:47.53,0:09:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tidak pergi ke akuarium.
Dialogue: 0,0:09:49.90,0:09:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, kita semua menonton\Npertunjukan lumba-lumba, kan?
Dialogue: 0,0:09:53.36,0:09:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, cuma kamu dan aku.
Dialogue: 0,0:09:55.12,0:09:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, iya.
Dialogue: 0,0:09:58.24,0:10:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, boleh tolong memfoto kami?
Dialogue: 0,0:10:01.37,0:10:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh, maukah kamu\Nberfoto bersama kami?
Dialogue: 0,0:10:04.58,0:10:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sedang bersama orang\Nyang penting buatku.
Dialogue: 0,0:10:08.46,0:10:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Mizuho.
Dialogue: 0,0:10:19.39,0:10:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal, dulu aku bisa\Nnaik turun dengan mudah.
Dialogue: 0,0:10:23.73,0:10:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang olahraga, ya?
Dialogue: 0,0:10:25.23,0:10:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:10:27.19,0:10:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, Shugo hari ini...
Dialogue: 0,0:10:29.65,0:10:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu memang banyak berubah, Mizuho.
Dialogue: 0,0:10:34.15,0:10:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi cantik.
Dialogue: 0,0:10:36.28,0:10:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya!
Dialogue: 0,0:10:37.49,0:10:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:10:41.58,0:10:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sepertinya aku terluka.
Dialogue: 0,0:10:43.79,0:10:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakimu terkilir?
Dialogue: 0,0:10:45.29,0:10:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:46.25,0:10:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku lupa\Nkamu memakai sepatu hak tinggi.
Dialogue: 0,0:10:49.21,0:10:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti lelah berjalan terus.
Dialogue: 0,0:10:51.55,0:10:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini bukan salahmu.
Dialogue: 0,0:10:54.93,0:10:56.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meronta, ya.
Dialogue: 0,0:10:58.22,0:10:59.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shugo!
Dialogue: 0,0:10:59.31,0:11:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau meronta, kamu bakal jatuh.
Dialogue: 0,0:11:02.22,0:11:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turunkan aku!\NAku bisa berjalan, kok.
Dialogue: 0,0:11:05.27,0:11:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terkilir dan pakai sepatu hak tinggi?
Dialogue: 0,0:11:09.02,0:11:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, itu kayak di sinetron!
Dialogue: 0,0:11:11.15,0:11:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, ganteng banget!
Dialogue: 0,0:11:14.03,0:11:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil kita di dekat sini.
Dialogue: 0,0:11:15.91,0:11:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke akuariumnya lain kali saja.
Dialogue: 0,0:11:18.07,0:11:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kita pulang dulu.
Dialogue: 0,0:11:20.33,0:11:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, merepotkanmu.
Dialogue: 0,0:11:30.42,0:11:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Shugo.
Dialogue: 0,0:11:32.17,0:11:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mampir ke rumah sakit?
Dialogue: 0,0:11:33.67,0:11:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah, pakai koyok juga bakal sembuh.
Dialogue: 0,0:11:37.18,0:11:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kita obati di rumahmu saja.
Dialogue: 0,0:11:39.60,0:11:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian, akan kubuatkan makanan enak.
Dialogue: 0,0:11:45.73,0:11:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, dia memang beda dari biasanya.
Dialogue: 0,0:12:03.37,0:12:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:12:05.25,0:12:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan membantu.
Dialogue: 0,0:12:07.21,0:12:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, duduk saja.
Dialogue: 0,0:12:09.58,0:12:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kamu obati,\Nkakiku sudah tidak sakit lagi.
Dialogue: 0,0:12:15.17,0:12:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kamu bikin sup, ya.
Dialogue: 0,0:12:17.22,0:12:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:24.97,0:12:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mencicip?
Dialogue: 0,0:12:29.52,0:12:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:12:30.56,0:12:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:12:31.69,0:12:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buatanku, tentu saja enak.
Dialogue: 0,0:12:36.53,0:12:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, masakanmu memang luar biasa.
Dialogue: 0,0:12:40.16,0:12:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piza yang kita makan di Enoshima\Nmemang enak,
Dialogue: 0,0:12:43.24,0:12:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi masih kalah dari piza buatanmu.
Dialogue: 0,0:12:48.62,0:12:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sesuka itu,\Naku bisa membuatkannya tiap hari.
Dialogue: 0,0:12:52.00,0:12:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?\NAku bakal bahagia, dong.
Dialogue: 0,0:12:54.75,0:12:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:56.30,0:12:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang membahagiakanmu.
Dialogue: 0,0:13:20.32,0:13:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada lebih banyak waktu,\Naku bisa buatkan hidangan penutup.
Dialogue: 0,0:13:24.20,0:13:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa makan masakan lezat\Nbuatanmu saja sudah bagus.
Dialogue: 0,0:13:27.58,0:13:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali, akan kubuatkan\Nmenu lengkap khusus untukmu.
Dialogue: 0,0:13:30.58,0:13:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!\NTuan Shugo memang hebat!
Dialogue: 0,0:13:33.21,0:13:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:13:34.41,0:13:37.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, humoris, dan pandai memasak.
Dialogue: 0,0:13:37.50,0:13:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Shugo memang hebat, kan?
Dialogue: 0,0:13:39.59,0:13:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memuji sebanyak itu.
Dialogue: 0,0:13:41.55,0:13:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku yang sekarang,
Dialogue: 0,0:13:44.05,0:13:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah bukan pemain ketiga,
Dialogue: 0,0:13:46.35,0:13:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan pemain utama, kan?
Dialogue: 0,0:13:52.90,0:13:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemain ketiga?\NApa itu?
Dialogue: 0,0:13:56.15,0:13:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:13:57.61,0:14:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama kamu yang buat,\Nsemuanya pasti enak.
Dialogue: 0,0:14:00.24,0:14:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, apa maksudmu?
Dialogue: 0,0:14:04.87,0:14:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:14:07.99,0:14:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini naskah komikus yang sedang kutangani.
Dialogue: 0,0:14:11.11,0:14:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sketsa kasarnya baru jadi.
Dialogue: 0,0:14:14.79,0:14:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:14:19.13,0:14:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Sekolah Renang Mitsuman.
Dialogue: 0,0:14:22.95,0:14:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, jadi nostalgia.
Dialogue: 0,0:14:25.26,0:14:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:14:26.51,0:14:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, aku dan komikus itu\Npergi melakukan wawancara.
Dialogue: 0,0:14:33.02,0:14:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki?
Dialogue: 0,0:14:36.15,0:14:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Narasumbernya adalah Kizuki.
Dialogue: 0,0:14:39.36,0:14:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memfotonya sebagai bahan referensi.
Dialogue: 0,0:14:44.86,0:14:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisi Kizuki?
Dialogue: 0,0:14:47.83,0:14:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat bersemangat.
Dialogue: 0,0:14:50.08,0:14:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan hingga terasa menyilaukan.
Dialogue: 0,0:14:52.87,0:14:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang melihatnya pun\Nserasa kembali ke masa SMA.
Dialogue: 0,0:15:05.80,0:15:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\NKizuki akan selalu ada di hati Mizuho...
Dialogue: 0,0:15:11.14,0:15:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi nostalgia.
Dialogue: 0,0:15:16.06,0:15:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, hari-hari terasa berkilau.
Dialogue: 0,0:15:23.32,0:15:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti saat itulah masa mudaku.
Dialogue: 0,0:15:26.97,0:15:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyampaikan\Nhal yang kupendam selama ini.
Dialogue: 0,0:15:33.08,0:15:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mizuho...\N- Aku jadi ikut merasa tidak boleh kalah.
Dialogue: 0,0:15:42.71,0:15:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, aku juga tidak boleh kalah.
Dialogue: 0,0:15:46.63,0:15:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi yang terdekat dengan Mizuho.
Dialogue: 0,0:15:49.05,0:15:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin jadi yang pertama di hati Mizuho.
Dialogue: 0,0:15:51.64,0:15:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, ada yang ingin kusampaikan padamu.
Dialogue: 0,0:15:56.48,0:15:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shugo?
Dialogue: 0,0:15:58.60,0:16:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau di mata Mizuho hanya ada Kizuki.
Dialogue: 0,0:16:02.77,0:16:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau itu akan membuatnya kerepotan...
Dialogue: 0,0:16:05.82,0:16:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, maukah...
Dialogue: 0,0:16:09.57,0:16:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu ayahku.
Dialogue: 0,0:16:11.45,0:16:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman?
Dialogue: 0,0:16:12.91,0:16:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang berada di Tokyo?
Dialogue: 0,0:16:14.45,0:16:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:16.71,0:16:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki?
Dialogue: 0,0:16:19.00,0:16:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok ada Kizuki?
Dialogue: 0,0:16:21.21,0:16:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:16:24.00,0:16:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, maaf datang tiba-tiba.
Dialogue: 0,0:16:26.87,0:16:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:28.18,0:16:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:16:31.55,0:16:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Shugo ada di sini?
Dialogue: 0,0:16:33.72,0:16:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kata-kataku.
Dialogue: 0,0:16:35.56,0:16:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, hentikan.
Dialogue: 0,0:16:37.89,0:16:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada perlu apa?
Dialogue: 0,0:16:39.73,0:16:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku hanya mampir sebelum latihan.
Dialogue: 0,0:16:44.02,0:16:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kusampaikan padamu.
Dialogue: 0,0:16:45.98,0:16:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:16:48.20,0:16:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bisa ikut kompetisi lagi.
Dialogue: 0,0:16:51.37,0:16:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:16:52.70,0:16:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Kizuki!
Dialogue: 0,0:16:54.37,0:16:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, aku ingin\Nmengatakannya langsung padamu.
Dialogue: 0,0:16:58.85,0:17:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian ingin melihat wajahmu.
Dialogue: 0,0:17:01.38,0:17:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, kamu sudah bisa ikut kompetisi.
Dialogue: 0,0:17:05.00,0:17:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mendukungmu.
Dialogue: 0,0:17:06.80,0:17:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Kizuki.
Dialogue: 0,0:17:11.68,0:17:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, kamu dan Shugo sedang apa?
Dialogue: 0,0:17:14.81,0:17:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:15.47,0:17:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:17:16.81,0:17:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kencan ke Enoshima,
Dialogue: 0,0:17:18.89,0:17:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masak makan malam bersama,
Dialogue: 0,0:17:21.14,0:17:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedang minum kopi sekarang.
Dialogue: 0,0:17:23.73,0:17:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Mizuho?
Dialogue: 0,0:17:25.27,0:17:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:17:27.56,0:17:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bakal sekalian menginap.
Dialogue: 0,0:17:31.28,0:17:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, Shugo selalu suka bercanda.
Dialogue: 0,0:17:34.95,0:17:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya ada panggilan kantor.
Dialogue: 0,0:17:36.83,0:17:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku cek dulu sebentar.
Dialogue: 0,0:17:55.93,0:17:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:17:57.76,0:17:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang dulu.
Dialogue: 0,0:17:59.10,0:18:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:18:02.48,0:18:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa bilang...
Dialogue: 0,0:18:04.23,0:18:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, aku mencintaimu.
Dialogue: 0,0:18:11.70,0:18:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, dia masih saja bertindak semaunya.
Dialogue: 0,0:18:22.79,0:18:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, sangat merepotkan.
Dialogue: 0,0:18:25.08,0:18:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Kizuki.
Dialogue: 0,0:18:27.34,0:18:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu spontan dan bertindak semaunya.
Dialogue: 0,0:18:33.76,0:18:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shugo, tadi kamu mau bilang sesuatu, kan?
Dialogue: 0,0:18:37.40,0:18:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal apa...
Dialogue: 0,0:18:41.06,0:18:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, aku...
Dialogue: 0,0:18:44.73,0:18:46.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memberitahunya.
Dialogue: 0,0:18:46.02,0:18:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin terus begini\Ndan tidak akan melepaskannya.
Dialogue: 0,0:19:01.57,0:19:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:19:05.37,0:19:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu selalu tersenyum.
Dialogue: 0,0:19:09.75,0:19:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berharap kamu bahagia.
Dialogue: 0,0:19:12.34,0:19:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:13.13,0:19:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Shugo?
Dialogue: 0,0:19:17.59,0:19:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:19:20.06,0:19:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramah ke teman masa kecil yang membantuku\Nmengembangkan menu itu wajar, kan?
Dialogue: 0,0:19:27.56,0:19:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membantuku hari ini.
Dialogue: 0,0:19:30.03,0:19:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:31.15,0:19:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:19:32.53,0:19:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyenangkan sekali.\NNanti kita ke sana lagi, ya.
Dialogue: 0,0:19:38.24,0:19:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NAda barang ketinggalan?
Dialogue: 0,0:19:40.91,0:19:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak ada, kok.
Dialogue: 0,0:19:43.63,0:19:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan paksakan kakimu, ya.
Dialogue: 0,0:19:45.71,0:19:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:19:47.42,0:19:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sampai jumpa.
Dialogue: 0,0:20:02.35,0:20:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:20:04.72,0:20:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu mengungkapkan\Nperasaannya dengan jujur,
Dialogue: 0,0:20:07.60,0:20:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memonopoli hati Mizuho.
Dialogue: 0,0:20:19.91,0:20:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Mizuho.
Dialogue: 0,0:20:21.70,0:20:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, ini tidak bisa aku lepaskan.
Dialogue: 0,0:20:24.45,0:20:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akan kuakhiri perasaan ini.
Dialogue: 0,0:20:40.26,0:20:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya kami persembahkan lagu ini.
Dialogue: 0,0:20:43.56,0:20:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}My Regret Heart,
Dialogue: 0,0:20:45.97,0:20:48.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Penyesalan di Dalam Hatiku".
Dialogue: 0,0:20:52.11,0:20:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiraishi.
Dialogue: 0,0:20:53.61,0:20:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku memberanikan diri, tapi ditolak,
Dialogue: 0,0:20:56.86,0:20:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maukah kamu menghiburku?
Dialogue: 0,0:21:01.16,0:21:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:02.45,0:21:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akan kumainkan lagu ini untukmu.
Dialogue: 0,0:21:27.39,0:21:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dewasa nanti, kamu pasti menyesal.
Dialogue: 0,0:21:31.56,0:21:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, aku sama sekali tidak menyesal.
Dialogue: 0,0:23:34.89,0:23:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, ini Nishino.
Dialogue: 0,0:23:37.05,0:23:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Rumah Sakit\NUniversitas Kedokteran Touou.
Dialogue: 0,0:23:39.06,0:23:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Anda, Tuan Nishino Tsuyoshi,\Ndibawa ke rumah sakit dengan ambulans.
Dialogue: 0,0:23:42.32,0:23:43.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:44.07,0:23:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang melakukan\Npemeriksaan dan pengobatan untuknya.
Dialogue: 0,0:23:47.91,0:23:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menjelaskan kondisi saat ini\Ndan penanganan selanjutnya,
Dialogue: 0,0:23:50.95,0:23:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami harap pihak keluarga dapat\Nsegera datang ke rumah sakit.
Dialogue: 0,0:24:02.00,0:24:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Nishino!
Dialogue: 0,0:24:03.46,0:24:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, kamu bisa mendengarku?
