Dialogue: 0,0:01:14.93,0:01:19.31,tanda,,0000,0000,0000,,ANYWAY, I'M FALLING IN LOVE WITH YOU.
Dialogue: 0,0:04:47.02,0:04:50.02,tanda,,0000,0000,0000,,RUMAH SAKIT UNIVERSITAS KEDOKTERAN TOUOU
Dialogue: 0,0:07:24.92,0:07:25.78,tanda,,0000,0000,0000,,TERIMA KASIH ATAS KERJA KERASNYA, AKU YODA,\NSERIALISASI KARYA NONA KAWAGUCHI
Dialogue: 0,0:07:25.78,0:07:26.83,tanda,,0000,0000,0000,,YANG BERJUDUL "PERCIKAN BIRU" TELAH DIPASTIKAN.\NSELAMAT, AKU SANGAT MENANTIKANNYA.
Dialogue: 0,0:07:26.83,0:07:27.43,tanda,,0000,0000,0000,,MERAWAT KELUARGA PASTI SANGAT MELELAHKAN,\NJANGAN TERLALU MEMAKSAKAN DIRI SENDIRI.
Dialogue: 0,0:15:02.51,0:15:05.51,tanda,,0000,0000,0000,,RUMAH SAKIT UNIVERSITAS KEDOKTERAN TOUOU
Dialogue: 0,0:20:31.92,0:20:34.88,tanda,,0000,0000,0000,,KENANGAN LIBURAN MUSIM PANAS
Dialogue: 0,0:23:54.66,0:23:57.29,tanda,,0000,0000,0000,,TAHUN 2020,\NSAAT ITU AKU TIDAK MENYADARINYA.
Dialogue: 0,0:23:57.29,0:23:59.14,tanda,,0000,0000,0000,,AKU INGIN MENJADI PACAR MIZUHO.\NAKU DIKELILINGI BANYAK HAL MENYILAUKAN.
Dialogue: 0,0:23:59.14,0:23:59.96,tanda,,0000,0000,0000,,UJUNGNYA, AKU JATUH CINTA PADAMU.
Dialogue: 0,0:00:05.74,0:00:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho.
Dialogue: 0,0:00:07.11,0:00:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kita naik kereta gantung,
Dialogue: 0,0:00:09.16,0:00:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pernah bilang padamu, kan?
Dialogue: 0,0:00:13.03,0:00:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah siap berpacaran denganmu.
Dialogue: 0,0:00:18.75,0:00:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu juga sudah siap,\Nberi tahu aku.
Dialogue: 0,0:00:24.50,0:00:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:25.51,0:00:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat kaget waktu itu.
Dialogue: 0,0:00:28.26,0:00:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tahu perasaan Kizuki padamu.
Dialogue: 0,0:00:32.04,0:00:34.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun sudah tahu kalian pacaran.
Dialogue: 0,0:00:35.64,0:00:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memutuskan untuk pacaran dengan Kizuki.
Dialogue: 0,0:00:40.44,0:00:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menyerah soal kamu.
Dialogue: 0,0:00:44.15,0:00:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana hidupku tanpa dirimu.
Dialogue: 0,0:00:47.61,0:00:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:00:49.57,0:00:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup demi dirimu.
Dialogue: 0,0:00:52.41,0:00:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu juga ke depannya.
Dialogue: 0,0:00:54.45,0:00:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi bahagia bersamamu.
Dialogue: 0,0:01:04.45,0:01:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikahlah denganku.
Dialogue: 0,0:02:56.70,0:02:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo sini, Payah.
Dialogue: 0,0:03:02.45,0:03:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini cara menjawabnya.
Dialogue: 0,0:03:07.17,0:03:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong izinkan kami semua\Nmengadakan Festival SMA Ao.
Dialogue: 0,0:03:15.68,0:03:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin.
Dialogue: 0,0:03:17.64,0:03:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasinya sudah selesai.
Dialogue: 0,0:03:20.22,0:03:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil.
Dialogue: 0,0:03:25.10,0:03:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:03:34.82,0:03:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:37.45,0:03:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini maupun nanti,
Dialogue: 0,0:03:40.99,0:03:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu adalah orang yang penting bagiku.
Dialogue: 0,0:03:45.37,0:03:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak bisa menikah denganmu.
Dialogue: 0,0:03:50.63,0:03:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku padamu bukanlah cinta.
Dialogue: 0,0:03:55.84,0:03:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:57.43,0:04:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamanya aku hanyalah teman, ya.
Dialogue: 0,0:04:00.26,0:04:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:01.64,0:04:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan minta maaf.
Dialogue: 0,0:04:02.97,0:04:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melamarmu bukan untuk melihat\Nekspresimu yang seperti itu.
Dialogue: 0,0:04:07.44,0:04:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:04:15.01,0:04:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya perasaanku\Nselama 10 tahun ini terutarakan.
Dialogue: 0,0:04:25.87,0:04:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:04:29.04,0:04:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut terluka, ya.
Dialogue: 0,0:04:32.75,0:04:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Payah.
Dialogue: 0,0:04:36.51,0:04:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:04:57.90,0:04:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin.
Dialogue: 0,0:05:00.03,0:05:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, bagaimana kondisimu?
Dialogue: 0,0:05:03.16,0:05:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar baik.
Dialogue: 0,0:05:05.45,0:05:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau minta segera pulang,\Napa aku akan dimarahi?
Dialogue: 0,0:05:09.83,0:05:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan segera pulang, kok.
Dialogue: 0,0:05:14.71,0:05:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman.
Dialogue: 0,0:05:15.59,0:05:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:16.67,0:05:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:17.92,0:05:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin, aku melamar Mizuho\Ndan ditolak olehnya.
Dialogue: 0,0:05:24.51,0:05:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:25.43,0:05:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Melamar?
Dialogue: 0,0:05:30.10,0:05:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, sakit!
Dialogue: 0,0:05:31.69,0:05:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?\NTenanglah.
Dialogue: 0,0:05:35.44,0:05:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, cuma sedikit terkejut.
Dialogue: 0,0:05:38.65,0:05:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengejutkanmu.
Dialogue: 0,0:05:42.91,0:05:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah bertemu Mizuho,\Naku bertekad menjadi dokter
Dialogue: 0,0:05:47.37,0:05:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan telah jadi orang yang sedikit berguna.
Dialogue: 0,0:05:50.20,0:05:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh bersyukur bisa mencintai Mizuho.
Dialogue: 0,0:05:55.21,0:05:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:57.21,0:05:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:00.80,0:06:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang mendengarmu berkata begitu.
Dialogue: 0,0:06:03.22,0:06:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah sangat hebat sejak dulu.
Dialogue: 0,0:06:07.47,0:06:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah 10 tahun berlalu sejak saat itu.
Dialogue: 0,0:06:19.03,0:06:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arungilah masa muda
Dialogue: 0,0:06:22.86,0:06:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tiada tandingan!
Dialogue: 0,0:06:33.29,0:06:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho adalah masa mudaku.
Dialogue: 0,0:06:45.18,0:06:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo kita minum-minum.
Dialogue: 0,0:06:49.56,0:06:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembuh dulu.
Dialogue: 0,0:06:54.35,0:06:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tahu, kok.
Dialogue: 0,0:07:03.32,0:07:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menginap di rumah lagi hari ini.
Dialogue: 0,0:07:05.49,0:07:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau butuh sesuatu, bilang, ya.
Dialogue: 0,0:07:07.66,0:07:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:07:08.99,0:07:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:10.37,0:07:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istirahatlah dengan baik.
Dialogue: 0,0:07:18.17,0:07:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emailnya menumpuk.
Dialogue: 0,0:07:28.30,0:07:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:07:29.68,0:07:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu iri?
Dialogue: 0,0:07:37.19,0:07:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, kamu tidak bisa jadi komikus.
Dialogue: 0,0:07:40.44,0:07:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu iri?
Dialogue: 0,0:07:43.36,0:07:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:45.40,0:07:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau iri pun,
Dialogue: 0,0:07:47.24,0:07:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap tidak bisa kembali\Nke masa-masa berkilau itu.
Dialogue: 0,0:07:55.83,0:07:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah.
Dialogue: 0,0:07:57.83,0:08:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan tidak bisa kembali,
Dialogue: 0,0:08:01.00,0:08:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}justru masa itu berlanjut hingga kini.
Dialogue: 0,0:08:04.51,0:08:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan saja sesuai keinginanmu.
Dialogue: 0,0:08:07.13,0:08:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin mau diam saja di sini?
Dialogue: 0,0:08:10.76,0:08:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut terluka, ya.
Dialogue: 0,0:08:17.69,0:08:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tertatih-tatih, sejak itu\Nkamu terus maju, kan?
Dialogue: 0,0:08:21.86,0:08:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah tahu perasaanmu saat ini, kan?
Dialogue: 0,0:08:25.48,0:08:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:26.61,0:08:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, jangan takut, lah.
Dialogue: 0,0:08:29.91,0:08:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah dewasa.
Dialogue: 0,0:08:31.45,0:08:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang iya, tahu.
Dialogue: 0,0:08:33.62,0:08:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangatlah, diriku.
Dialogue: 0,0:08:47.09,0:08:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus pergi.
Dialogue: 0,0:09:45.19,0:09:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki!
Dialogue: 0,0:09:52.36,0:09:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki.
Dialogue: 0,0:09:54.24,0:09:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho?
Dialogue: 0,0:09:58.66,0:10:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, kenapa kamu kemari?
Dialogue: 0,0:10:03.37,0:10:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir, kamu pasti masih berlatih.
Dialogue: 0,0:10:06.46,0:10:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar.
Dialogue: 0,0:10:08.96,0:10:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu pikirkan, sih?
Dialogue: 0,0:10:11.13,0:10:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:12.05,0:10:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya larut malam begini\Ndatang sendirian kemari!
Dialogue: 0,0:10:16.89,0:10:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masih SMA,
Dialogue: 0,0:10:19.06,0:10:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pernah membawakan cokelat valentin\Nuntukmu yang sedang pelatihan.
Dialogue: 0,0:10:23.35,0:10:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu pun, kamu memarahiku\Nkarena khawatir, kan?
Dialogue: 0,0:10:26.73,0:10:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kamu berkata akan kacau balau\Nkalau sesuatu terjadi padaku.
Dialogue: 0,0:10:31.99,0:10:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang masih mengkhawatirkanku.
Dialogue: 0,0:10:35.03,0:10:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus...
Dialogue: 0,0:10:36.45,0:10:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa kamu menghilang?
Dialogue: 0,0:10:39.66,0:10:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa...
Dialogue: 0,0:10:41.50,0:10:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu tidak berada di sisiku?
Dialogue: 0,0:10:44.12,0:10:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sudah tidak bisa berenang!
Dialogue: 0,0:10:48.34,0:10:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini aku hanya bisa berenang.
Dialogue: 0,0:10:53.59,0:10:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:10:54.55,0:10:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin selalu kamu perhatikan,
Dialogue: 0,0:10:58.22,0:11:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kubisa hanyalah berenang!
Dialogue: 0,0:11:02.10,0:11:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, kamu baik-baik saja?
Dialogue: 0,0:11:07.19,0:11:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, aku harus latihan lebih keras
Dialogue: 0,0:11:09.69,0:11:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena sudah lama vakum.
Dialogue: 0,0:11:15.49,0:11:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki!
Dialogue: 0,0:11:20.70,0:11:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho?
Dialogue: 0,0:11:29.13,0:11:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, apa yang kamu...
Dialogue: 0,0:11:30.84,0:11:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan merepotkanku lagi!
Dialogue: 0,0:11:32.46,0:11:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:34.59,0:11:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berhenti bekerja\Ndan mulai berenang lagi.
Dialogue: 0,0:11:37.80,0:11:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar nekat.
Dialogue: 0,0:11:39.85,0:11:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlatih sampai larut begini\Ndengan bahu terluka.
Dialogue: 0,0:11:43.64,0:11:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dewasa, tapi saking naifnya\Nkamu sampai lupa sekitar.
Dialogue: 0,0:11:47.94,0:11:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dirimu yang meresahkan itu
Dialogue: 0,0:11:50.52,0:11:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}justru membuatku\Nlebih khawatir dari waktu dulu.
Dialogue: 0,0:11:54.74,0:11:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:11:55.90,0:11:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}10 tahun maupun 20 tahun kemudian,
Dialogue: 0,0:11:58.91,0:12:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin tetap berada di sisimu!
Dialogue: 0,0:12:05.29,0:12:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga selalu memikirkanmu.
Dialogue: 0,0:12:09.67,0:12:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah melupakanmu.
Dialogue: 0,0:12:12.92,0:12:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kecil sampai dewasa,\Nkamu segalanya bagiku.
Dialogue: 0,0:12:23.64,0:12:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:12:49.71,0:12:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mizuho.
Dialogue: 0,0:12:51.72,0:12:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:53.08,0:12:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertanding nanti...
Dialogue: 0,0:12:55.09,0:12:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:56.38,0:12:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepayah atau seburuk apa pun diriku,
Dialogue: 0,0:12:59.68,0:13:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetaplah lihat aku.
Dialogue: 0,0:13:01.51,0:13:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:02.47,0:13:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tahu bahwa kamu melihatku.
Dialogue: 0,0:13:05.31,0:13:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan hingga kini,\Naku merasa bisa melakukan apa pun.
Dialogue: 0,0:13:09.52,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:12.40,0:13:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku mengucapkannya juga.
Dialogue: 0,0:13:15.94,0:13:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}10 tahun maupun 20 tahun kemudian,
Dialogue: 0,0:13:21.32,0:13:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari bersama selamanya.
Dialogue: 0,0:13:23.74,0:13:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:27.12,0:13:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, aku mencintaimu.
Dialogue: 0,0:13:37.50,0:13:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para atlet putra harap bersiap
Dialogue: 0,0:13:39.51,0:13:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk babak final gaya bebas 100 meter.
Dialogue: 0,0:13:53.90,0:13:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mau mulai, deh.
Dialogue: 0,0:13:55.65,0:13:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalah jangan nangis, ya, Kizuki.
Dialogue: 0,0:13:58.61,0:14:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertandingan kembalinya sahabatmu, lo.
Dialogue: 0,0:14:01.82,0:14:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dukunglah dengan lebih tulus.
Dialogue: 0,0:14:04.07,0:14:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beginilah caraku mengungkapkannya.
Dialogue: 0,0:14:08.58,0:14:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:10.08,0:14:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang mau kamu bicarakan?
Dialogue: 0,0:14:13.79,0:14:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pergi ke Italia Selatan\Nuntuk belajar masak.
Dialogue: 0,0:14:18.34,0:14:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap begini,
Dialogue: 0,0:14:20.01,0:14:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}restoran ini cuma akan mentok di kondisi ini.
Dialogue: 0,0:14:22.51,0:14:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:14:23.59,0:14:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap begini, aku tidak akan bisa
Dialogue: 0,0:14:26.76,0:14:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengejar Ayah sebagai seorang koki
Dialogue: 0,0:14:30.14,0:14:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku...
Dialogue: 0,0:14:31.77,0:14:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat terharu!
Dialogue: 0,0:14:34.06,0:14:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan aku, menyebalkan!
Dialogue: 0,0:14:38.48,0:14:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah punya aura seorang koki, ya.
Dialogue: 0,0:14:41.15,0:14:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang, inilah yang ingin kulakukan.
Dialogue: 0,0:14:44.78,0:14:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak percaya?
Dialogue: 0,0:14:48.49,0:14:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku datang terlambat.
Dialogue: 0,0:14:52.00,0:14:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, pertandingannya belum mulai, kok.
Dialogue: 0,0:14:56.63,0:14:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak berjumpa, Kurashiki.
Dialogue: 0,0:14:59.00,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Hoshikawa, halo.
Dialogue: 0,0:15:10.85,0:15:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata hari ini ada jadwal operasi.
Dialogue: 0,0:15:13.35,0:15:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu ingin pergi\Nmendukungnya, kan?
Dialogue: 0,0:15:17.15,0:15:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, soalnya ini jalan yang kupilih.
Dialogue: 0,0:15:21.28,0:15:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti.
Dialogue: 0,0:15:31.66,0:15:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi mulai.
Dialogue: 0,0:15:35.79,0:15:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya?
Dialogue: 0,0:15:38.25,0:15:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airu?
Dialogue: 0,0:15:40.38,0:15:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:15:41.75,0:15:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang memotret untuk majalah olahraga.
Dialogue: 0,0:15:44.30,0:15:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:45.63,0:15:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihatmu masih sehat.
Dialogue: 0,0:15:47.43,0:15:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga.
Dialogue: 0,0:15:50.18,0:15:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini, foto atlet Hazawa Kizuki.
Dialogue: 0,0:15:53.64,0:15:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya keren juga.
Dialogue: 0,0:15:56.06,0:16:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, sekarang aku bisa mengerti\Nalasanmu mencintainya saat itu.
Dialogue: 0,0:16:04.57,0:16:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabarmu?
Dialogue: 0,0:16:09.53,0:16:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah bertemu orang\Nyang bisa kucintai dengan tulus.
Dialogue: 0,0:16:13.91,0:16:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tinggal bersama teman SMP\Nyang kutemui kembali di London.
Dialogue: 0,0:16:18.58,0:16:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:20.79,0:16:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu denganmu,\Naku belum memahami diri sendiri.
Dialogue: 0,0:16:25.09,0:16:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf telah menyakitimu.
Dialogue: 0,0:16:28.68,0:16:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyelamatkanku dari kesepian
Dialogue: 0,0:16:31.05,0:16:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuatku menemukan jati diri.
Dialogue: 0,0:16:33.10,0:16:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku bisa bahagia,\Nberkat bertemu denganmu.
Dialogue: 0,0:16:38.39,0:16:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, terima kasih.
Dialogue: 0,0:16:41.61,0:16:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:43.44,0:16:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku turut senang, Airu.
Dialogue: 0,0:16:46.03,0:16:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:16:51.03,0:16:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku kembali bekerja.
Dialogue: 0,0:16:57.00,0:16:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Touya!
Dialogue: 0,0:16:59.08,0:16:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:01.29,0:17:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kamu juga bisa bahagia.
Dialogue: 0,0:17:05.42,0:17:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:08.58,0:17:10.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal, Touya.
Dialogue: 0,0:17:11.39,0:17:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airu.
Dialogue: 0,0:17:12.64,0:17:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amon.
Dialogue: 0,0:17:17.43,0:17:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah itu dia?
Dialogue: 0,0:17:19.52,0:17:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:20.48,0:17:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penyelamatku.
Dialogue: 0,0:17:21.94,0:17:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku bisa berterima kasih padanya.
Dialogue: 0,0:17:26.44,0:17:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, ayo pergi untuk memberi semangat.
Dialogue: 0,0:17:38.41,0:17:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kashiwagi.
Dialogue: 0,0:17:41.16,0:17:43.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:17:43.17,0:17:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama operasi,\Naku akan terus menemanimu.
Dialogue: 0,0:17:47.09,0:17:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:17:48.42,0:17:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak takut.
Dialogue: 0,0:17:52.05,0:17:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai dan kamu sehat kembali,
Dialogue: 0,0:17:53.93,0:17:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo main pesawat kertas lagi sama-sama.
Dialogue: 0,0:17:56.47,0:17:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:57.14,0:17:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji, ya!
Dialogue: 0,0:17:59.18,0:18:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Untuk babak final gaya bebas 100 meter putra,\N- Sudah mau mulai, ya.
Dialogue: 0,0:18:04.69,0:18:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para atlet harap masuk ke arena.
Dialogue: 0,0:18:06.69,0:18:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, kamu juga harus semangat.
Dialogue: 0,0:18:10.40,0:18:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo bersiap.
Dialogue: 0,0:18:12.70,0:18:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:17.45,0:18:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:18:31.34,0:18:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atlet Hazawa Kizuki.
Dialogue: 0,0:18:43.98,0:18:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepayah atau seburuk apa pun diriku,
Dialogue: 0,0:18:47.11,0:18:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetaplah lihat aku.
Dialogue: 0,0:18:49.40,0:18:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:50.23,0:18:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tahu bahwa kamu melihatku.
Dialogue: 0,0:18:53.20,0:18:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan hingga kini,\Naku merasa bisa melakukan apa pun.
Dialogue: 0,0:18:57.03,0:18:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:07.13,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:19:13.63,0:19:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi deklarasi kemenangan itu,\Nmantap, lah.
Dialogue: 0,0:19:16.72,0:19:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka Kizuki
Dialogue: 0,0:19:18.93,0:19:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa kembali hingga sejauh ini.
Dialogue: 0,0:19:21.31,0:19:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Hoshikawa juga\Nkembali menjadi guru, kan?
Dialogue: 0,0:19:24.35,0:19:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:19:26.31,0:19:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, sekolah membutuhkan\Nguru sepertimu.
Dialogue: 0,0:19:33.32,0:19:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru sepertiku?
Dialogue: 0,0:19:35.32,0:19:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan adanya guru unik sepertimu,
Dialogue: 0,0:19:38.74,0:19:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para siswa akan lebih ceria.
Dialogue: 0,0:19:41.16,0:19:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu pujian?
Dialogue: 0,0:19:44.79,0:19:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pujian.
Dialogue: 0,0:19:47.46,0:19:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurashiki.
Dialogue: 0,0:19:48.50,0:19:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:19:49.54,0:19:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:50.72,0:19:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:19:56.09,0:19:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, Mizuho.
Dialogue: 0,0:19:58.47,0:20:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua harus semangat.
Dialogue: 0,0:20:22.45,0:20:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, lihatlah baik-baik.
Dialogue: 0,0:20:26.00,0:20:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap.
Dialogue: 0,0:20:30.04,0:20:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dihalangi tembok tinggi.
Dialogue: 0,0:20:31.92,0:20:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terluka begitu dalam.
Dialogue: 0,0:20:34.88,0:20:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang telah melewati\Nmasa muda itu pasti bisa.
Dialogue: 0,0:20:38.84,0:20:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bisa melangkah dengan kuat lagi.
Dialogue: 0,0:20:42.60,0:20:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pasti bisa berenang
Dialogue: 0,0:20:45.02,0:20:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di cahaya biru itu!
Dialogue: 0,0:20:48.89,0:20:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, semangat!
Dialogue: 0,0:22:54.35,0:22:56.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, selamat pagi.
Dialogue: 0,0:22:58.11,0:22:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:23:03.11,0:23:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun...
Dialogue: 0,0:23:05.78,0:23:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kembali lagi ke hari itu,
Dialogue: 0,0:23:08.62,0:23:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan tetap memimpikan hal yang sama,
Dialogue: 0,0:23:11.75,0:23:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terjatuh di tempat yang sama,
Dialogue: 0,0:23:14.12,0:23:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu menangis dan tertawa\Ndi tempat yang sama.
Dialogue: 0,0:23:17.67,0:23:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjalan bersama teman yang sama,
Dialogue: 0,0:23:22.84,0:23:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berjalan beriringan,
Dialogue: 0,0:23:27.14,0:23:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjalani hari-hari berharga\Nyang tidak akan pernah terulang.
Dialogue: 0,0:23:35.98,0:23:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:23:37.65,0:23:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti jatuh cinta pada orang yang sama.
