Dialogue: 0,0:00:32.50,0:00:34.64,tanda,,0000,0000,0000,,PINTU MASUK UGD
Dialogue: 0,0:02:28.00,0:02:29.05,tanda,,0000,0000,0000,,PINTU MASUK UGD
Dialogue: 0,0:02:35.34,0:02:36.76,tanda,,0000,0000,0000,,PENDAFTARAN UGD
Dialogue: 0,0:04:12.94,0:04:15.69,tanda,,0000,0000,0000,,AIRU\NPANGGILAN MASUK
Dialogue: 0,0:05:29.13,0:05:33.77,tanda,,0000,0000,0000,,SHUGO
Dialogue: 0,0:05:45.70,0:05:47.79,tanda,,0000,0000,0000,,RUMAH SAKIT UNIVERSITAS KEDOKTERAN TOUOU
Dialogue: 0,0:07:06.16,0:07:08.16,tanda,,0000,0000,0000,,KIZUKI\NPANGGILAN MASUK
Dialogue: 0,0:09:11.59,0:09:12.91,tanda,,0000,0000,0000,,PRIORITASKAN AMBULANS
Dialogue: 0,0:09:21.58,0:09:23.13,tanda,,0000,0000,0000,,PINTU MASUK UGD
Dialogue: 0,0:24:09.97,0:24:14.97,tanda,,0000,0000,0000,,EPISODE 24: UJUNGNYA, AKU JATUH CINTA PADAMU
Dialogue: 0,0:00:12.91,0:00:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, ini Nishino.
Dialogue: 0,0:00:15.20,0:00:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Rumah Sakit\NUniversitas Kedokteran Touou.
Dialogue: 0,0:00:17.12,0:00:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Anda, Tuan Nishino Tsuyoshi,\Ndibawa ke rumah sakit dengan ambulans.
Dialogue: 0,0:00:20.85,0:00:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:22.00,0:00:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang melakukan\Npemeriksaan dan pengobatan untuknya.
Dialogue: 0,0:00:25.88,0:00:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menjelaskan kondisi saat ini\Ndan penanganan selanjutnya,
Dialogue: 0,0:00:28.88,0:00:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami harap pihak keluarga dapat\Nsegera datang ke rumah sakit.
Dialogue: 0,0:00:39.94,0:00:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Nishino!
Dialogue: 0,0:00:41.31,0:00:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, kamu bisa mendengarku?
Dialogue: 0,0:00:43.11,0:00:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini rumah sakit, sudah tidak apa-apa.
Dialogue: 0,0:00:47.90,0:00:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kashiwagi, kamu mengenalnya?
Dialogue: 0,0:00:50.07,0:00:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:50.95,0:00:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter, izinkan aku ikut menanganinya.
Dialogue: 0,0:02:29.05,0:02:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, aku Nishino Mizuho.
Dialogue: 0,0:02:31.46,0:02:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diberi tahu dari telepon\Nkalau ayahku dibawa kemari.
Dialogue: 0,0:02:35.34,0:02:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tunggu sebentar.
Dialogue: 0,0:02:37.47,0:02:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho.
Dialogue: 0,0:02:39.01,0:02:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin!
Dialogue: 0,0:02:40.52,0:02:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah bisa bertemu kamu sebelum operasi.
Dialogue: 0,0:02:43.10,0:02:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, bagaimana kondisi ayahku?
Dialogue: 0,0:02:46.10,0:02:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kondisinya stabil.
Dialogue: 0,0:02:48.02,0:02:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti membaik kalau dioperasi.
Dialogue: 0,0:02:51.35,0:02:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:54.15,0:02:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, jangan khawatir.
Dialogue: 0,0:02:56.95,0:02:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ikut menanganinya,
Dialogue: 0,0:02:59.24,0:03:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akan andil saat operasi.
Dialogue: 0,0:03:01.54,0:03:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga?
Dialogue: 0,0:03:04.18,0:03:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir, buat apa aku jadi dokter?
Dialogue: 0,0:03:10.63,0:03:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin.
Dialogue: 0,0:03:12.38,0:03:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:03:14.59,0:03:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupercayakan Ayah padamu.
Dialogue: 0,0:03:18.47,0:03:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:45.83,0:03:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah berjuang keras sejak saat itu.
Dialogue: 0,0:03:50.38,0:03:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda dengan diriku yang dulu.
Dialogue: 0,0:03:53.63,0:03:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku pasti bisa menyelamatkannya.
Dialogue: 0,0:04:00.68,0:04:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan,\NMizuho mengalami hal itu lagi.
Dialogue: 0,0:04:04.89,0:04:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, tolong selamatkan Ayah.
Dialogue: 0,0:04:18.07,0:04:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airu, ada apa?
Dialogue: 0,0:04:20.51,0:04:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikabari Shugo.\NPaman baik-baik saja, kan?
Dialogue: 0,0:04:23.49,0:04:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang dioperasi...
Dialogue: 0,0:04:26.45,0:04:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menunggu operasinya selesai.
Dialogue: 0,0:04:28.86,0:04:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, kamu baik-baik saja?
Dialogue: 0,0:04:31.42,0:04:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak bisa menemanimu.
Dialogue: 0,0:04:33.63,0:04:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:04:34.88,0:04:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaramu sudah membuatku tenang.
Dialogue: 0,0:04:37.26,0:04:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:38.84,0:04:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja aku tunda sedikit\Njadwal kembali ke London.
Dialogue: 0,0:04:43.05,0:04:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kamu sedang sendirian?
Dialogue: 0,0:04:47.21,0:04:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:48.39,0:04:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking paniknya,
Dialogue: 0,0:04:50.14,0:04:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku baru sempat mengabari Shugo saja.
Dialogue: 0,0:04:53.11,0:04:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NBagaimana dengan Shin?
Dialogue: 0,0:04:56.11,0:04:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kerja di situ, kan?
Dialogue: 0,0:04:58.07,0:05:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Shin juga ada di ruang operasi.
Dialogue: 0,0:05:02.87,0:05:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NKalau begitu, sudah aman.
Dialogue: 0,0:05:06.45,0:05:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:07.62,0:05:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita yang paling tahu betapa hebatnya Shin,
Dialogue: 0,0:05:11.50,0:05:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan?
Dialogue: 0,0:05:14.79,0:05:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya aman, tenang saja.
Dialogue: 0,0:05:19.80,0:05:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:20.57,0:05:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, aku akan percaya dan menunggu.
Dialogue: 0,0:05:23.76,0:05:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Airu.
Dialogue: 0,0:05:25.97,0:05:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:29.13,0:05:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki juga sudah kukabari,
Dialogue: 0,0:05:31.06,0:05:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mungkin dia sedang berlatih.
Dialogue: 0,0:05:33.77,0:05:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, si Gila Renang itu...
Dialogue: 0,0:05:39.22,0:05:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah, Shin.
Dialogue: 0,0:05:57.92,0:05:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urus sisanya.
Dialogue: 0,0:05:59.26,0:06:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:06:00.30,0:06:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Kashiwagi.
Dialogue: 0,0:06:04.18,0:06:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:15.52,0:06:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, aku bisa membantu.
Dialogue: 0,0:06:18.61,0:06:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lega rasanya.
Dialogue: 0,0:06:23.90,0:06:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin.
Dialogue: 0,0:06:25.57,0:06:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasinya sudah selesai.
Dialogue: 0,0:06:28.49,0:06:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berhasil.
Dialogue: 0,0:06:33.08,0:06:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:06:35.08,0:06:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman masih tidur karena obat bius,
Dialogue: 0,0:06:37.04,0:06:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya besok siang dia bangun.
Dialogue: 0,0:06:39.09,0:06:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:42.67,0:06:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan segera pulih.
Dialogue: 0,0:06:45.55,0:06:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:47.30,0:06:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyelamatkan ayahku.
Dialogue: 0,0:06:53.06,0:06:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, kamu ada waktu?
Dialogue: 0,0:06:55.02,0:06:55.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:56.67,0:07:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kukatakan padamu.
Dialogue: 0,0:07:09.41,0:07:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki?
Dialogue: 0,0:07:11.58,0:07:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf baru datang.
Dialogue: 0,0:07:13.41,0:07:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru dengar pesan dari Shugo.
Dialogue: 0,0:07:16.17,0:07:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kamu langsung datang kemari?
Dialogue: 0,0:07:19.17,0:07:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:20.50,0:07:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena khawatir.
Dialogue: 0,0:07:21.92,0:07:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya pakailah payung.
Dialogue: 0,0:07:25.26,0:07:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, terima kasih.
Dialogue: 0,0:07:27.18,0:07:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bagaimana kondisi Paman?
Dialogue: 0,0:07:30.18,0:07:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:31.39,0:07:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Operasi jantungnya berhasil.
Dialogue: 0,0:07:33.60,0:07:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal diobservasi selama beberapa hari.
Dialogue: 0,0:07:35.95,0:07:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah aman.
Dialogue: 0,0:07:37.69,0:07:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya, syukurlah.
Dialogue: 0,0:07:40.19,0:07:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin memang hebat.
Dialogue: 0,0:07:41.69,0:07:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:42.92,0:07:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diberi tahu\Nbahwa Shin yang mengoperasinya,
Dialogue: 0,0:07:46.61,0:07:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah pasti sangat terkejut.
Dialogue: 0,0:07:49.41,0:07:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau pulang?
Dialogue: 0,0:07:51.47,0:07:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengantarmu.
Dialogue: 0,0:07:55.00,0:07:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menemani Ayah sampai dia bangun.
Dialogue: 0,0:07:58.42,0:07:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku juga ikut.
Dialogue: 0,0:08:00.50,0:08:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya keluarga pasien\Nyang boleh ke ruang ICU.
Dialogue: 0,0:08:04.76,0:08:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang mengantar Mizuho pulang.
Dialogue: 0,0:08:07.07,0:08:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya pulang saja,
Dialogue: 0,0:08:09.22,0:08:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}takut kamu terkena flu.
Dialogue: 0,0:08:13.76,0:08:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nishino.
Dialogue: 0,0:08:15.98,0:08:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:08:16.89,0:08:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menyela obrolannya.
Dialogue: 0,0:08:18.87,0:08:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjelaskan beberapa hal\Nsoal prosedur rawat inap ayah Anda.
Dialogue: 0,0:08:23.19,0:08:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku akan kembali.
Dialogue: 0,0:08:27.03,0:08:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, terima kasih sudah datang.
Dialogue: 0,0:08:29.78,0:08:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Ayah sudah baik-baik saja.
Dialogue: 0,0:08:31.99,0:08:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:08:33.09,0:08:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perlu bantuanku, hubungi saja.
Dialogue: 0,0:08:36.25,0:08:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, sampai nanti.
Dialogue: 0,0:08:39.00,0:08:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:39.78,0:08:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Shin.
Dialogue: 0,0:08:43.91,0:08:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Mizuho tidak menangis.
Dialogue: 0,0:08:51.30,0:08:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya tidak tahu saja.
Dialogue: 0,0:08:55.06,0:08:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jaga Paman dan Mizuho.
Dialogue: 0,0:08:57.31,0:08:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:58.06,0:09:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, aku tidak akan pernah\Nmembiarkan Mizuho menangis,
Dialogue: 0,0:09:05.07,0:09:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun merasa galau.
Dialogue: 0,0:09:07.90,0:09:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatnya bahagia\Ndengan caraku sendiri.
Dialogue: 0,0:09:11.59,0:09:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:12.91,0:09:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:09:13.57,0:09:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal ingin membahagiakan Mizuho,\Naku tidak kalah darimu.
Dialogue: 0,0:09:29.51,0:09:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, maaf merepotkan kalian.
Dialogue: 0,0:09:33.80,0:09:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, ini sama sekali tidak lucu.
Dialogue: 0,0:09:36.64,0:09:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar kaget, lo.
Dialogue: 0,0:09:39.23,0:09:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:09:40.48,0:09:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu observasi\Nselama dua sampai tiga minggu.
Dialogue: 0,0:09:42.60,0:09:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada masalah, kamu bisa pulang.
Dialogue: 0,0:09:45.40,0:09:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Shin.
Dialogue: 0,0:09:47.73,0:09:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka, Shin akan menyelamatkanku.
Dialogue: 0,0:09:52.61,0:09:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin telah jadi sangat bisa diandalkan.
Dialogue: 0,0:09:56.91,0:09:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku mau menelepon yang lain juga.
Dialogue: 0,0:10:00.26,0:10:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:06.79,0:10:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman.
Dialogue: 0,0:10:07.99,0:10:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:10:08.67,0:10:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman masih ingat\Nhal yang pernah kuucapkan dulu?
Dialogue: 0,0:10:11.38,0:10:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:13.09,0:10:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah benar-benar jadi dokter.
Dialogue: 0,0:10:19.27,0:10:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah jadi dokter nanti,\Nbolehkah aku melamar Mizuho?
Dialogue: 0,0:10:28.44,0:10:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin?
Dialogue: 0,0:10:30.78,0:10:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, beristirahatlah\Nbeberapa hari ke depan.
Dialogue: 0,0:10:37.83,0:10:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, sih, mana bisa istirahat.
Dialogue: 0,0:10:45.37,0:10:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:10:48.46,0:10:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:10:50.50,0:10:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kukatakan padamu.
Dialogue: 0,0:11:01.14,0:11:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:11:03.48,0:11:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kerjaanmu sudah selesai?
Dialogue: 0,0:11:07.39,0:11:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ini buatmu.
Dialogue: 0,0:11:10.65,0:11:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roti lapis buah!
Dialogue: 0,0:11:12.65,0:11:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan dari Enokiya, sih.
Dialogue: 0,0:11:14.82,0:11:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu belum makan sejak kemarin, kan?
Dialogue: 0,0:11:17.22,0:11:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan, nanti mabuk kendaraan, lo.
Dialogue: 0,0:11:19.91,0:11:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Shin.
Dialogue: 0,0:11:21.79,0:11:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:11:29.13,0:11:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget!
Dialogue: 0,0:11:30.88,0:11:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa lelah di tubuhku hilang.
Dialogue: 0,0:11:33.13,0:11:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebai, ah.
Dialogue: 0,0:11:35.97,0:11:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kashiwagi sudah mau pulang?
Dialogue: 0,0:11:38.93,0:11:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter, siapa orang ini?
Dialogue: 0,0:11:40.97,0:11:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacar?
Dialogue: 0,0:11:43.27,0:11:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!\NDokter Shin itu pacarku!
Dialogue: 0,0:11:48.02,0:11:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan, Dokter?
Dialogue: 0,0:11:49.77,0:11:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:11:54.26,0:11:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kondisi kalian baik,\Njangan berlarian dulu, ya.
Dialogue: 0,0:11:58.36,0:11:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya...
Dialogue: 0,0:12:02.95,0:12:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesawat kertas?
Dialogue: 0,0:12:04.62,0:12:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesawat kertas ini tidak bisa terbang.
Dialogue: 0,0:12:07.92,0:12:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami berlarian demi menerbangkannya.
Dialogue: 0,0:12:11.17,0:12:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Mizuho.
Dialogue: 0,0:12:12.76,0:12:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar lagi, ya?
Dialogue: 0,0:12:14.96,0:12:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:12:15.92,0:12:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mau kuajari dulu\Ncara melipat pesawat kertas.
Dialogue: 0,0:12:24.68,0:12:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Asyik!\N- Aku juga mau.
Dialogue: 0,0:12:26.77,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergantian, ya.
Dialogue: 0,0:12:28.77,0:12:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:12:40.95,0:12:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung jatuh lagi, deh.
Dialogue: 0,0:12:43.08,0:12:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesawat kertas Shin terbang paling jauh, ya.
Dialogue: 0,0:12:46.58,0:12:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bedanya sama punya kami?
Dialogue: 0,0:12:49.46,0:12:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja di bagian sini.
Dialogue: 0,0:12:53.21,0:12:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda di cara melipatnya.
Dialogue: 0,0:12:56.46,0:13:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja kita bisa sama-sama terbang jauh.
Dialogue: 0,0:13:06.60,0:13:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, sini kuajari triknya.
Dialogue: 0,0:13:09.98,0:13:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, kemarilah.
Dialogue: 0,0:13:14.73,0:13:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh beruntung.
Dialogue: 0,0:13:16.19,0:13:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Shin.
Dialogue: 0,0:13:17.90,0:13:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:21.20,0:13:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini.
Dialogue: 0,0:13:22.36,0:13:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat garis tengahnya dan lipat\Nsisi kiri dan kanan secara simetris.
Dialogue: 0,0:13:26.20,0:13:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, naikkan sedikit sudut sayapnya.
Dialogue: 0,0:13:31.54,0:13:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi.
Dialogue: 0,0:13:33.42,0:13:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo lempar bersamaan.
Dialogue: 0,0:13:35.50,0:13:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:13:36.78,0:13:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, mulai!
Dialogue: 0,0:13:49.52,0:13:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hebat sekali!\N- Luar biasa!
Dialogue: 0,0:13:53.48,0:13:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku merasa bisa terbang\Nke mana pun bersama semuanya.
Dialogue: 0,0:14:04.07,0:14:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:14:06.58,0:14:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:14:09.33,0:14:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin.
Dialogue: 0,0:14:10.41,0:14:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia lakukan\Nsetelah dewasa pun tidak berubah.
Dialogue: 0,0:14:24.09,0:14:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara lempar apa itu.
Dialogue: 0,0:14:30.47,0:14:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dilempar bersamaan,\Narah majunya beda-beda, ya.
Dialogue: 0,0:14:36.86,0:14:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu aku sangat tahu\Njalan mana yang ingin ditempuh
Dialogue: 0,0:14:41.08,0:14:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa ada keraguan.
Dialogue: 0,0:14:43.45,0:14:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dewasa, ternyata tidak semudah itu.
Dialogue: 0,0:14:48.12,0:14:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:14:53.71,0:14:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku dalam masa\Nmenentukan spesialisasi.
Dialogue: 0,0:14:57.58,0:15:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin banyak yang kuketahui,\Nmakin banyak kemungkinan baru terlihat.
Dialogue: 0,0:15:17.27,0:15:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menempuh jalan mana pun,\Nkamu pasti bisa melaluinya.
Dialogue: 0,0:15:22.44,0:15:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendukungmu.
Dialogue: 0,0:15:24.24,0:15:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:25.17,0:15:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:36.32,0:15:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin memang hebat.
Dialogue: 0,0:15:39.04,0:15:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin Shin terasa sangat percaya diri.
Dialogue: 0,0:15:42.50,0:15:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:44.51,0:15:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tampan, seorang dokter,\Ndan menyelamatkan nyawa Paman pula.
Dialogue: 0,0:15:49.26,0:15:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan kamu hanyalah\Nperenang pengangguran.
Dialogue: 0,0:15:54.03,0:15:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek normal enggak akan memilihmu.
Dialogue: 0,0:15:58.43,0:16:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kamu sebutkan satu saja kelebihanku?
Dialogue: 0,0:16:03.19,0:16:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, nih.
Dialogue: 0,0:16:04.40,0:16:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepribadian yang fokus maju ke depan\Ntanpa memikirkan apa pun.
Dialogue: 0,0:16:08.66,0:16:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan pujian, kan?
Dialogue: 0,0:16:11.16,0:16:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pujian, kok.
Dialogue: 0,0:16:13.37,0:16:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, selamat berjuang.
Dialogue: 0,0:16:16.40,0:16:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:17.11,0:16:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kutelepon lagi.
Dialogue: 0,0:16:20.32,0:16:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki, cepatlah sadar.
Dialogue: 0,0:16:27.80,0:16:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:29.83,0:16:34.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepribadianmu itulah yang mengalahkanku.
Dialogue: 0,0:16:39.27,0:16:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini cukup?
Dialogue: 0,0:16:40.90,0:16:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, ini juga.
Dialogue: 0,0:16:42.60,0:16:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memasukkan semua barang\Nyang akan digunakan di kamar mandi.
Dialogue: 0,0:16:45.69,0:16:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih,\Nkamu benar-benar bisa diandalkan.
Dialogue: 0,0:16:49.49,0:16:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo pergi.
Dialogue: 0,0:16:50.61,0:16:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:16:59.71,0:17:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto? Paman pasti sangat senang.
Dialogue: 0,0:17:03.46,0:17:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:04.92,0:17:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada Ibu, dia tidak akan kesepian.
Dialogue: 0,0:17:08.16,0:17:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu lama.
Dialogue: 0,0:17:16.97,0:17:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih ingat kartu itu?
Dialogue: 0,0:17:18.83,0:17:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:17:20.06,0:17:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kamu sudah tidak menyimpannya.
Dialogue: 0,0:17:22.59,0:17:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:17:24.98,0:17:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kartu ilustrasi yang aku buat\Nwaktu Festival SMA Ao.
Dialogue: 0,0:17:29.36,0:17:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu pun, kamu banyak membantuku.
Dialogue: 0,0:17:33.87,0:17:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kerja kerasmu, aku bisa\Nmeninggalkan kenangan berharga.
Dialogue: 0,0:17:37.74,0:17:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:17:40.00,0:17:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berkat kerja keras kita semua.
Dialogue: 0,0:17:43.96,0:17:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:46.15,0:17:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, sudah waktunya pergi.
Dialogue: 0,0:17:48.21,0:17:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:17:51.68,0:17:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:17:56.81,0:17:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat laut memang bikin tenang.
Dialogue: 0,0:17:59.42,0:18:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:01.23,0:18:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, aku terus memikirkanmu.
Dialogue: 0,0:18:05.73,0:18:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berterima kasih padamu.
Dialogue: 0,0:18:08.94,0:18:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk soal ayahku juga.
Dialogue: 0,0:18:10.90,0:18:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu mendukungku.
Dialogue: 0,0:18:15.41,0:18:16.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, aku...
Dialogue: 0,0:18:16.91,0:18:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kartu itu...
Dialogue: 0,0:18:18.12,0:18:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:19.66,0:18:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih tertempel di lokerku di rumah sakit.
Dialogue: 0,0:18:23.42,0:18:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenangan bersamamu di dalam kelas saat itu...
Dialogue: 0,0:18:29.57,0:18:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Shin.\NIngatlah selamanya.
Dialogue: 0,0:18:36.01,0:18:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal 18 September, pukul 17.20.
Dialogue: 0,0:18:40.06,0:18:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bersama di ruang kelas SMA Ao.
Dialogue: 0,0:18:50.65,0:18:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simpan kartu ilustrasi itu\Nsebagai kenang-kenangan hari ini.
Dialogue: 0,0:18:58.28,0:18:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:02.19,0:19:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bagiku juga, itu kenangan berharga.
Dialogue: 0,0:19:05.63,0:19:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka kamu menjaganya sejauh itu.
Dialogue: 0,0:19:10.08,0:19:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat masa sekolah,\Nmembantumu belajar dan menjagamu.
Dialogue: 0,0:19:14.74,0:19:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski semua itu\Nkulakukan demi kepuasan sendiri,
Dialogue: 0,0:19:19.41,0:19:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap bersyukur masuk ke SMA Ao.
Dialogue: 0,0:19:23.14,0:19:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat hebat, ya.
Dialogue: 0,0:19:25.23,0:19:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sampai jadi ketua OSIS pula.
Dialogue: 0,0:19:28.06,0:19:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang menyuruhku jadi ketua OSIS, kan?
Dialogue: 0,0:19:32.94,0:19:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kita merayakan kelulusan SMP, ya?
Dialogue: 0,0:19:37.95,0:19:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pita seragam SMA Ao lucu sekali.
Dialogue: 0,0:19:41.41,0:19:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki akan masuk klub renang, kan?
Dialogue: 0,0:19:43.81,0:19:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:44.75,0:19:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin mau melakukan apa?
Dialogue: 0,0:19:46.50,0:19:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:46.92,0:19:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:19:49.29,0:19:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua OSIS atau sejenisnya?
Dialogue: 0,0:19:51.21,0:19:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus, Mizuho.
Dialogue: 0,0:19:53.51,0:19:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sesenggang itu.
Dialogue: 0,0:19:55.26,0:19:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi bilang begitu.\NDasar pria membosankan.
Dialogue: 0,0:19:58.97,0:20:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, nikmati masa muda kita!
Dialogue: 0,0:20:01.01,0:20:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, Kizuki, pegang kaki Shin.
Dialogue: 0,0:20:05.27,0:20:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Siap.
Dialogue: 0,0:20:06.48,0:20:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, mulai!
Dialogue: 0,0:20:11.31,0:20:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian apa-apaan, sih?
Dialogue: 0,0:20:14.78,0:20:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita basah kuyup, deh.
Dialogue: 0,0:20:16.65,0:20:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap, ini baru masa muda.
Dialogue: 0,0:20:20.36,0:20:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Shin.
Dialogue: 0,0:20:26.25,0:20:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa terus bersamamu,
Dialogue: 0,0:20:29.54,0:20:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa senang.
Dialogue: 0,0:20:36.72,0:20:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal waktu itu.
Dialogue: 0,0:20:38.51,0:20:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu baru gagal\Nmasuk SMP pilihan utamamu,
Dialogue: 0,0:20:41.80,0:20:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah bilang senang.
Dialogue: 0,0:20:43.97,0:20:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saja, lagi pula aku tidak gagal.
Dialogue: 0,0:20:45.97,0:20:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:47.23,0:20:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ingin bersama semuanya\Ndan juga bersamamu,
Dialogue: 0,0:20:49.60,0:20:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pura-pura gagal.
Dialogue: 0,0:20:50.60,0:20:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?\NKamu melepas SMA Seikai itu?
Dialogue: 0,0:20:54.65,0:20:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku selalu dipandu olehmu.
Dialogue: 0,0:20:58.53,0:20:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:21:01.16,0:21:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ibumu meninggal,
Dialogue: 0,0:21:03.95,0:21:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu terlihat sangat sedih.
Dialogue: 0,0:21:06.29,0:21:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak ingin melihat\Nekspresi itu lagi darimu,
Dialogue: 0,0:21:10.00,0:21:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertekad jadi pria yang bisa\Nmenyelamatkan nyawa orang di sekitarmu.
Dialogue: 0,0:21:16.05,0:21:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu.
Dialogue: 0,0:21:17.67,0:21:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kita selalu bersama.
Dialogue: 0,0:21:20.84,0:21:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi dirimu, apa pun bisa kulakukan.
Dialogue: 0,0:21:30.85,0:21:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho.
Dialogue: 0,0:21:32.17,0:21:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kita naik kereta gantung,
Dialogue: 0,0:21:34.17,0:21:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pernah bilang padamu, kan?
Dialogue: 0,0:21:38.15,0:21:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah siap berpacaran denganmu.
Dialogue: 0,0:21:43.82,0:21:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu juga sudah siap,\Nberi tahu aku.
Dialogue: 0,0:21:49.58,0:21:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:50.71,0:21:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat kaget waktu itu.
Dialogue: 0,0:21:53.28,0:21:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tahu perasaan Kizuki padamu.
Dialogue: 0,0:21:57.17,0:21:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun sudah tahu kalian pacaran.
Dialogue: 0,0:22:00.80,0:22:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memutuskan untuk pacaran dengan Kizuki.
Dialogue: 0,0:22:05.68,0:22:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menyerah soal kamu.
Dialogue: 0,0:22:09.31,0:22:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bagaimana hidupku tanpa dirimu.
Dialogue: 0,0:22:12.64,0:22:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:22:14.55,0:22:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup demi dirimu.
Dialogue: 0,0:22:17.44,0:22:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu juga ke depannya.
Dialogue: 0,0:22:19.57,0:22:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi bahagia bersamamu.
Dialogue: 0,0:22:31.16,0:22:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikahlah denganku.
