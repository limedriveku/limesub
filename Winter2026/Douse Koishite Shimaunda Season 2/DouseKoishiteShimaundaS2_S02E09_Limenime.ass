Dialogue: 0,0:03:40.78,0:03:44.00,tanda,,0000,0000,0000,,SEKOLAH RENANG MITSUMAN\NMENGENAI PERMINTAAN WAWANCARA
Dialogue: 0,0:03:47.04,0:03:49.54,tanda,,0000,0000,0000,,TAMAN HAPPE KOTA KOIGAHAMA\NTAMAN OLAHRAGA KUGENUMA
Dialogue: 0,0:04:09.06,0:04:11.17,tanda,,0000,0000,0000,,PETUNJUK SEBELUM BERENANG
Dialogue: 0,0:10:54.86,0:10:57.01,tanda,,0000,0000,0000,,AKU AKAN BANGKIT KEMBALI
Dialogue: 0,0:13:09.16,0:13:11.60,tanda,,0000,0000,0000,,KAI WAKTU KECIL, ADIKNYA SHIN
Dialogue: 0,0:14:54.12,0:14:57.84,tanda,,0000,0000,0000,,NISHINO
Dialogue: 0,0:16:22.46,0:16:24.96,tanda,,0000,0000,0000,,MERAYAKAN SEMUANYA MASUK UNIVERSITAS\NAIRU JUGA MASUK SEKOLAH KEJURUAN
Dialogue: 0,0:16:24.96,0:16:27.47,tanda,,0000,0000,0000,,PERMAINAN BERAKHIR\NLANJUTKAN? YA/TIDAK
Dialogue: 0,0:17:29.19,0:17:32.11,tanda,,0000,0000,0000,,MASUKLAH DI MATA KULIAH SELANJUTNYA\NKALAU KAMU MAU LULUS, KURODA
Dialogue: 0,0:19:35.74,0:19:37.32,tanda,,0000,0000,0000,,UNTUK SHIN. KAI MENITIPKAN\NLAUK BUATAN BIBI UNTUKMU.
Dialogue: 0,0:19:37.32,0:19:38.74,tanda,,0000,0000,0000,,SUDAH KUTARUH DI KULKAS.\NLEKAS SEMBUH, MIZUHO.
Dialogue: 0,0:24:09.93,0:24:14.93,tanda,,0000,0000,0000,,EPISODE 22: KATA-KATA YANG SELAMA INI\NINGIN DIUCAPKAN
Dialogue: 0,0:00:10.53,0:00:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sia-sia.
Dialogue: 0,0:00:13.82,0:00:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sia-sia!
Dialogue: 0,0:00:15.32,0:00:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu pun tidak mau menyerah, kan?
Dialogue: 0,0:00:19.11,0:00:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga
Dialogue: 0,0:00:20.86,0:00:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyerah dari cita-citamu jadi komikus
Dialogue: 0,0:00:23.46,0:00:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan malah kerja kantoran, kan?
Dialogue: 0,0:02:17.99,0:02:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepribadian karakter ini\Nkayaknya kurang mencolok.
Dialogue: 0,0:02:29.96,0:02:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:02:30.96,0:02:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi, apa kabar?
Dialogue: 0,0:02:33.41,0:02:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata Ayah.
Dialogue: 0,0:02:35.47,0:02:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok reaksimu begitu?
Dialogue: 0,0:02:37.76,0:02:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah sakit hati, nih.
Dialogue: 0,0:02:39.60,0:02:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, barusan aku sedang bekerja.
Dialogue: 0,0:02:43.36,0:02:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai selarut ini?
Dialogue: 0,0:02:45.10,0:02:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelelahan?
Dialogue: 0,0:02:47.07,0:02:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah makan belum?
Dialogue: 0,0:02:49.71,0:02:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjaan editor banyak, kan?
Dialogue: 0,0:02:52.07,0:02:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus mengurusi senior galak\Natau komikus yang ribet.
Dialogue: 0,0:02:58.42,0:03:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah tersedak, tuh!
Dialogue: 0,0:03:00.01,0:03:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaralah pelan-pelan.
Dialogue: 0,0:03:04.21,0:03:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, akhir-akhir ini batuknya tambah sering.
Dialogue: 0,0:03:08.96,0:03:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Ayah sudah tua.
Dialogue: 0,0:03:12.12,0:03:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:03:13.36,0:03:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada perlu apa?
Dialogue: 0,0:03:15.35,0:03:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada, sih.
Dialogue: 0,0:03:18.47,0:03:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, sudah dengar belum?
Dialogue: 0,0:03:22.31,0:03:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang apa?
Dialogue: 0,0:03:23.56,0:03:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang Kizuki.
Dialogue: 0,0:03:26.06,0:03:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki kenapa?
Dialogue: 0,0:03:29.26,0:03:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dari ibunya,
Dialogue: 0,0:03:32.15,0:03:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki berhenti bekerja.
Dialogue: 0,0:03:34.71,0:03:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:50.46,0:03:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nishino, terima kasih\Nsudah mengatur jadwalnya.
Dialogue: 0,0:03:54.82,0:03:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karyanya akan lebih meyakinkan\Ndengan wawancara langsung.
Dialogue: 0,0:03:59.16,0:03:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:04.18,0:04:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:04:05.81,0:04:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, mari aku antar.
Dialogue: 0,0:04:09.06,0:04:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih tetap sama, ya.
Dialogue: 0,0:04:12.06,0:04:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona pernah ke sini?
Dialogue: 0,0:04:14.87,0:04:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman masa kecilku dulu\Nlatihan berenang di sini.
Dialogue: 0,0:04:17.91,0:04:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:04:20.20,0:04:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dari ibunya...
Dialogue: 0,0:04:28.52,0:04:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya.
Dialogue: 0,0:04:35.46,0:04:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kolamnya besar sekali.
Dialogue: 0,0:04:39.12,0:04:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu adalah
Dialogue: 0,0:04:40.56,0:04:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atlet kami yang akan
Dialogue: 0,0:04:42.92,0:04:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi narasumber.
Dialogue: 0,0:04:44.72,0:04:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:49.86,0:04:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa...
Dialogue: 0,0:06:14.97,0:06:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho?
Dialogue: 0,0:06:24.96,0:06:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar, kira-kira seperti itu.
Dialogue: 0,0:06:28.96,0:06:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu referensi yang sangat berguna.
Dialogue: 0,0:06:31.26,0:06:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?\NSyukurlah.
Dialogue: 0,0:06:36.86,0:06:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hazawa?
Dialogue: 0,0:06:38.21,0:06:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf.
Dialogue: 0,0:06:41.51,0:06:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sudah lama tidak berenang,
Dialogue: 0,0:06:44.96,0:06:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi infonya mungkin agak usang.
Dialogue: 0,0:06:47.66,0:06:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:06:52.41,0:06:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena cedera bahu,
Dialogue: 0,0:06:54.10,0:06:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sempat menyerah sepenuhnya pada renang.
Dialogue: 0,0:06:58.11,0:06:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena putus asa,
Dialogue: 0,0:06:59.42,0:07:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bahkan melepas\Norang-orang yang mendukungku.
Dialogue: 0,0:07:09.97,0:07:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, karena tidak mau lari lagi,
Dialogue: 0,0:07:14.21,0:07:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berhenti bekerja
Dialogue: 0,0:07:16.16,0:07:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kembali kemari.
Dialogue: 0,0:07:18.16,0:07:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kembali, Kizuki berbuat sejauh itu...
Dialogue: 0,0:07:23.30,0:07:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu keputusan yang sangat besar?
Dialogue: 0,0:07:26.82,0:07:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak merasa bimbang?
Dialogue: 0,0:07:29.22,0:07:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:31.17,0:07:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini keputusan yang nekat.
Dialogue: 0,0:07:35.23,0:07:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku ingin unjuk gigi lagi
Dialogue: 0,0:07:38.71,0:07:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di depan seseorang.
Dialogue: 0,0:07:48.12,0:07:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi bahumu belum pulih total.
Dialogue: 0,0:07:51.21,0:07:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kupulihkan, kok.
Dialogue: 0,0:07:55.96,0:07:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melambat.
Dialogue: 0,0:08:02.27,0:08:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren sekali.
Dialogue: 0,0:08:04.76,0:08:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki memang memukau saat berenang.
Dialogue: 0,0:08:14.77,0:08:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisimu sudah jauh membaik, ya.
Dialogue: 0,0:08:21.27,0:08:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak untuk hari ini.
Dialogue: 0,0:08:23.67,0:08:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar referensi bagus.
Dialogue: 0,0:08:26.01,0:08:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sungkan, ini demi karya yang bagus.
Dialogue: 0,0:08:29.62,0:08:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Tuan Hazawa,
Dialogue: 0,0:08:30.96,0:08:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gambaran lawan\Ndari tokoh utamanya makin jelas.
Dialogue: 0,0:08:34.01,0:08:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalau begitu.
Dialogue: 0,0:08:37.46,0:08:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:08:40.28,0:08:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman masa kecil perenang\Nyang Nona ceritakan itu,
Dialogue: 0,0:08:43.90,0:08:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Hazawa, ya?
Dialogue: 0,0:08:47.66,0:08:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar.
Dialogue: 0,0:08:49.21,0:08:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona Kawaguchi cenayang, ya?
Dialogue: 0,0:08:51.56,0:08:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tahu\Nkalau dia kembali berenang, ya?
Dialogue: 0,0:08:54.91,0:08:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:56.01,0:08:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tidak bilang, ya?
Dialogue: 0,0:09:02.41,0:09:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu adalah masa mudamu, kan?
Dialogue: 0,0:09:06.72,0:09:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu...
Dialogue: 0,0:09:09.86,0:09:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho!
Dialogue: 0,0:09:11.81,0:09:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki?
Dialogue: 0,0:09:16.85,0:09:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merindukanmu.
Dialogue: 0,0:09:17.96,0:09:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:19.67,0:09:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nishino.
Dialogue: 0,0:09:23.96,0:09:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, jiwa berkaryaku mulai membara.
Dialogue: 0,0:09:27.86,0:09:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang dan menggambar draf.
Dialogue: 0,0:09:31.12,0:09:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:32.43,0:09:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku pamit.
Dialogue: 0,0:09:38.81,0:09:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Mizuho.
Dialogue: 0,0:09:39.96,0:09:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:40.96,0:09:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kabur selama tiga tahun ini,
Dialogue: 0,0:09:43.07,0:09:45.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersikap egois, dan menyakitimu.
Dialogue: 0,0:09:45.71,0:09:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh menyesal!
Dialogue: 0,0:09:48.66,0:09:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut.
Dialogue: 0,0:09:50.22,0:09:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak disangka kamu ada di sini.
Dialogue: 0,0:09:53.62,0:09:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih marah?
Dialogue: 0,0:09:55.24,0:09:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku marah, pada diriku sendiri.
Dialogue: 0,0:09:59.56,0:10:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit pun, aku tidak mencoba memahamimu.
Dialogue: 0,0:10:03.91,0:10:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kamu menderita cedera,
Dialogue: 0,0:10:05.97,0:10:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah bilang "jangan menyerah"
Dialogue: 0,0:10:07.86,0:10:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan "apa kamu baik-baik saja".
Dialogue: 0,0:10:09.76,0:10:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya kamu terpojok.
Dialogue: 0,0:10:11.51,0:10:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:10:14.96,0:10:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru dukungan darimu
Dialogue: 0,0:10:17.66,0:10:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memotivasiku kembali berenang.
Dialogue: 0,0:10:20.57,0:10:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:10:21.72,0:10:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho, aku akan kembali\Nmencoba jadi atlet renang.
Dialogue: 0,0:10:26.81,0:10:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah bisa kembali ke kondisi\Nwaktu itu atau tidak, tapi...
Dialogue: 0,0:10:30.76,0:10:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menggapai kembali hal yang hilang.
Dialogue: 0,0:10:33.91,0:10:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik itu renang maupun dirimu.
Dialogue: 0,0:10:36.61,0:10:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:10:39.86,0:10:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatmu mencintaiku lagi.
Dialogue: 0,0:10:51.86,0:10:54.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bangkit kembali.
Dialogue: 0,0:10:57.01,0:10:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risetnya berguna, sih...
Dialogue: 0,0:11:00.76,0:11:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:11:05.21,0:11:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior berisik banget dari tadi.
Dialogue: 0,0:11:08.66,0:11:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:11:09.66,0:11:12.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking tersentuhnya, aku kehilangan akal.
Dialogue: 0,0:11:12.78,0:11:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ubah suasana hatimu\Ndengan membantuku.
Dialogue: 0,0:11:16.52,0:11:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:17.57,0:11:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini, nih.
Dialogue: 0,0:11:19.52,0:11:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana?
Dialogue: 0,0:11:21.43,0:11:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini...
Dialogue: 0,0:11:23.54,0:11:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bingung sama kelanjutannya.
Dialogue: 0,0:11:26.97,0:11:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tokoh utamanya ditembak dua orang...
Dialogue: 0,0:11:29.93,0:11:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berpacaran.
Dialogue: 0,0:11:32.21,0:11:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:11:33.76,0:11:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu...
Dialogue: 0,0:11:35.22,0:11:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku memastikan...
Dialogue: 0,0:11:37.20,0:11:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih mencintaimu atau tidak.
Dialogue: 0,0:11:45.06,0:11:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menggapai kembali hal yang hilang.
Dialogue: 0,0:11:48.22,0:11:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik itu renang maupun dirimu.
Dialogue: 0,0:11:50.91,0:11:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki...
Dialogue: 0,0:11:54.17,0:11:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatmu mencintaiku lagi.
Dialogue: 0,0:12:02.21,0:12:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memikirkannya juga.
Dialogue: 0,0:12:06.06,0:12:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tersentuh lagi?
Dialogue: 0,0:12:13.42,0:12:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura.
Dialogue: 0,0:12:15.46,0:12:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:12:16.85,0:12:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kamu lakukan
Dialogue: 0,0:12:18.97,0:12:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau...
Dialogue: 0,0:12:19.52,0:12:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nishino.
Dialogue: 0,0:12:21.41,0:12:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu buatmu di resepsionis.
Dialogue: 0,0:12:25.12,0:12:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:27.26,0:12:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak janji dengan siapa pun.
Dialogue: 0,0:12:31.57,0:12:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu bernama Kashiwagi.
Dialogue: 0,0:12:33.37,0:12:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kashiwagi?
Dialogue: 0,0:12:35.81,0:12:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia sangat tampan.
Dialogue: 0,0:12:37.92,0:12:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tampan?
Dialogue: 0,0:12:39.66,0:12:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hubungan kalian?
Dialogue: 0,0:12:50.01,0:12:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho.
Dialogue: 0,0:12:50.87,0:12:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai, untuk apa kamu kemari?
Dialogue: 0,0:12:53.86,0:12:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menemuimu, lah.
Dialogue: 0,0:12:55.87,0:12:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:12:57.06,0:13:00.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mau berhenti bekerja\Ndan menikah denganku?
Dialogue: 0,0:13:00.22,0:13:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa SMA Tampan, menikah?
Dialogue: 0,0:13:03.16,0:13:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imutnya.
Dialogue: 0,0:13:04.46,0:13:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Nishino hoki banget.
Dialogue: 0,0:13:06.66,0:13:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mau, lah, bodoh.
Dialogue: 0,0:13:09.16,0:13:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikah denganku dan tinggallah di rumah ini.
Dialogue: 0,0:13:13.56,0:13:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifatmu masih saja seperti anak SD.
Dialogue: 0,0:13:18.76,0:13:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ada komikus, tidak?
Dialogue: 0,0:13:20.72,0:13:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:13:21.76,0:13:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:13:22.56,0:13:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kai, kamu tidak sekolah?
Dialogue: 0,0:13:25.41,0:13:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:13:29.07,0:13:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku datang buat survei kampus.
Dialogue: 0,0:13:32.76,0:13:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, ambil.
Dialogue: 0,0:13:35.41,0:13:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kasih ke kakakku yang gila kerja.
Dialogue: 0,0:13:39.64,0:13:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke Shin? Buat apa?
Dialogue: 0,0:13:41.46,0:13:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, dia jatuh sakit karena flu.
Dialogue: 0,0:13:44.06,0:13:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ibu menitipkan ini itu.
Dialogue: 0,0:13:46.62,0:13:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bahaya kalau peserta\Nujian sepertiku tertular.
Dialogue: 0,0:13:50.02,0:13:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolong, ya.
Dialogue: 0,0:13:51.60,0:13:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, Kai.
Dialogue: 0,0:13:53.31,0:13:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi serbasalah kalau begini.
Dialogue: 0,0:13:55.48,0:13:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:59.86,0:14:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa serbasalah?
Dialogue: 0,0:14:02.15,0:14:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:14:04.62,0:14:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada masalah di antara kalian?
Dialogue: 0,0:14:08.49,0:14:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, kok.
Dialogue: 0,0:14:10.20,0:14:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:14:11.83,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada bingung begitu,
Dialogue: 0,0:14:14.00,0:14:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pilih saja aku.
Dialogue: 0,0:14:19.05,0:14:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kamu bisa, kan?
Dialogue: 0,0:14:20.92,0:14:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah, maaf merepotkan.
Dialogue: 0,0:14:22.51,0:14:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu...
Dialogue: 0,0:14:57.84,0:14:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho.
Dialogue: 0,0:14:58.92,0:15:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, kamu datang tepat waktu.
Dialogue: 0,0:15:01.55,0:15:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janji hari ini kita undur, ya.
Dialogue: 0,0:15:04.21,0:15:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:04.87,0:15:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, asma Kizuki kambuh.
Dialogue: 0,0:15:08.37,0:15:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabari juga yang lain.
Dialogue: 0,0:15:10.76,0:15:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau menjenguk Kizuki dulu.
Dialogue: 0,0:15:21.35,0:15:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho,
Dialogue: 0,0:15:22.86,0:15:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagimu, aku ini...
Dialogue: 0,0:15:30.91,0:15:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NBerisik sekali.
Dialogue: 0,0:15:34.50,0:15:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho?
Dialogue: 0,0:15:44.97,0:15:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:47.34,0:15:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertengkar sama Kizuki?
Dialogue: 0,0:15:50.14,0:15:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:15:51.43,0:15:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat karena telah diterima\Ndi Universitas Touou.
Dialogue: 0,0:15:59.52,0:16:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:02.86,0:16:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:10.91,0:16:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Shin, syukurlah!\N- Kamu memang hebat, Kutu Buku!
Dialogue: 0,0:16:12.16,0:16:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku selalu percaya kamu bisa!\N- Kamu memang hebat, Kutu Buku!
Dialogue: 0,0:16:15.00,0:16:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku selalu percaya kamu bisa!\N- Terima kasih juga, semuanya.
Dialogue: 0,0:16:17.54,0:16:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua berkat kerja kerasmu.
Dialogue: 0,0:16:36.38,0:16:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo, aku ketiduran?
Dialogue: 0,0:16:50.07,0:16:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho tidak akan membutuhkanku\Nsampai kapan pun.
Dialogue: 0,0:16:59.12,0:17:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para atlet dan pihak terkait.
Dialogue: 0,0:17:02.08,0:17:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih telah datang\Nke kompetisi renang hari ini.
Dialogue: 0,0:17:06.71,0:17:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompetisi resmi berakhir...
Dialogue: 0,0:17:20.38,0:17:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semringah banget, ya.
Dialogue: 0,0:17:23.60,0:17:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:17:34.83,0:17:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku tidak berusaha,
Dialogue: 0,0:17:38.95,0:17:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho akan tetap bahagia.
Dialogue: 0,0:17:42.74,0:17:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:43.96,0:17:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kizuki muncul saat festival kembang api.
Dialogue: 0,0:17:46.67,0:17:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:53.72,0:17:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang datang untuk menemuiku.
Dialogue: 0,0:17:56.43,0:18:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal hubungan kami\Nsudah berakhir sejak lama.
Dialogue: 0,0:18:02.60,0:18:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}...Mizuho tidak membiarkanku menyerah.
Dialogue: 0,0:18:17.53,0:18:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho?
Dialogue: 0,0:18:20.04,0:18:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku membangunkanmu?
Dialogue: 0,0:18:23.54,0:18:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang, ya?
Dialogue: 0,0:18:26.25,0:18:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:27.25,0:18:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin, kayaknya kamu masih demam.
Dialogue: 0,0:18:29.88,0:18:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisimu aman?
Dialogue: 0,0:18:31.05,0:18:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku sudah minum obat.
Dialogue: 0,0:18:33.18,0:18:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga demamnya turun.
Dialogue: 0,0:18:35.80,0:18:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lanjut tidur saja lagi.
Dialogue: 0,0:18:38.76,0:18:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:39.81,0:18:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:18:41.39,0:18:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titipan dari Kai
Dialogue: 0,0:18:43.14,0:18:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah kutaruh di kulkasmu.
Dialogue: 0,0:18:45.10,0:18:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, aku pergi dulu.
Dialogue: 0,0:18:47.06,0:18:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi.
Dialogue: 0,0:18:49.82,0:18:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu iri
Dialogue: 0,0:18:52.32,0:18:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena tiap Kizuki sakit,\Ndia selalu memonopolimu.
Dialogue: 0,0:18:56.87,0:18:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:19:09.42,0:19:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dan Kizuki,\Nmasih saling berkomunikasi?
Dialogue: 0,0:19:15.84,0:19:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatmu mencintaiku lagi.
Dialogue: 0,0:19:22.74,0:19:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:26.52,0:19:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa memaafkannya
Dialogue: 0,0:19:31.36,0:19:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena telah menyakitimu.
Dialogue: 0,0:19:41.70,0:19:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin?
Dialogue: 0,0:19:44.25,0:19:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan kubiarkan\Npergi ke mana pun.
Dialogue: 0,0:19:48.07,0:19:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho.
Dialogue: 0,0:19:50.92,0:19:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetaplah di sisiku.
Dialogue: 0,0:19:53.38,0:19:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Shin?
Dialogue: 0,0:19:55.01,0:19:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak seperti biasanya.
Dialogue: 0,0:20:14.07,0:20:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin...
Dialogue: 0,0:20:16.86,0:20:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih demam.
Dialogue: 0,0:20:18.82,0:20:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mizuho...
Dialogue: 0,0:22:00.09,0:22:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nishino?
Dialogue: 0,0:22:05.39,0:22:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter Kuroda.
Dialogue: 0,0:22:07.85,0:22:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk waktu itu.
Dialogue: 0,0:22:15.77,0:22:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:22:16.65,0:22:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membantu ibu Shin\Nmengantar lauk penyemangat untuknya.
Dialogue: 0,0:22:20.86,0:22:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja.
Dialogue: 0,0:22:28.74,0:22:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, anu...
Dialogue: 0,0:22:31.41,0:22:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku pamit dulu.
Dialogue: 0,0:22:41.72,0:22:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:22:46.14,0:22:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku tanya sesuatu?
Dialogue: 0,0:22:48.93,0:22:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagimu, Kashiwagi itu...
Dialogue: 0,0:22:54.81,0:22:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok seperti apa?
Dialogue: 0,0:22:57.25,0:22:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:04.40,0:23:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shin adalah teman masa kecilku.
Dialogue: 0,0:23:09.87,0:23:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licik.
Dialogue: 0,0:23:11.45,0:23:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:12.16,0:23:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu licik.
Dialogue: 0,0:23:14.12,0:23:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sebenarnya sadar, kan?
Dialogue: 0,0:23:16.91,0:23:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kashiwagi tidak berpikir seperti itu.
Dialogue: 0,0:23:21.46,0:23:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus menyembunyikan perasaan di dalam hati
Dialogue: 0,0:23:26.30,0:23:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangatlah menyakitkan.
Dialogue: 0,0:23:28.80,0:23:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sanggup lagi menghadapi Kashiwagi.
Dialogue: 0,0:23:33.98,0:23:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:23:35.14,0:23:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:23:37.02,0:23:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya cemburu.
Dialogue: 0,0:23:50.37,0:23:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lupakan saja.
