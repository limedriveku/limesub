Dialogue: 0,0:02:43.53,0:02:44.58,tanda,,0000,0000,0000,,{\an8}MENGGUMAM
Dialogue: 0,0:03:54.35,0:03:55.27,tanda,,0000,0000,0000,,SERANGAN TEPAT SASARAN
Dialogue: 0,0:09:26.73,0:09:27.73,tanda,,0000,0000,0000,,PERDATA, KLASIFIKASI KRIMINAL, KAU, SEMUA\NSOAL AKURASI TINGGI, SEDANG, RENDAH
Dialogue: 0,0:09:51.92,0:09:52.84,tanda,,0000,0000,0000,,KANTOR HUKUM HIGURUMA
Dialogue: 0,0:15:49.86,0:15:50.69,tanda,,0000,0000,0000,,{\an8}PEDANG ALGOJO
Dialogue: 0,0:23:33.03,0:23:34.78,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:34.84,0:01:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspansi Domain. Hukuman Mati.
Dialogue: 0,0:01:39.01,0:01:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebelum dia dapat mengaktifkan\Nteknik domainnya…{\i0}
Dialogue: 0,0:01:43.39,0:01:44.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku akan mengalahkannya!{\i0}
Dialogue: 0,0:01:54.73,0:01:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, semua tindak kekerasan dilarang.
Dialogue: 0,0:01:58.86,0:02:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kita berdua.
Dialogue: 0,0:02:00.57,0:02:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua?
Dialogue: 0,0:02:05.95,0:02:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Maaf. Kekerasan verbal tidak termasuk.
Dialogue: 0,0:02:10.42,0:02:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judgeman, mulai.
Dialogue: 0,0:02:16.55,0:02:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuji Itadori,
Dialogue: 0,0:02:18.80,0:02:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meskipun berusia di bawah 18 tahun,
Dialogue: 0,0:02:21.76,0:02:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada 16 Juli 2017,
Dialogue: 0,0:02:25.14,0:02:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau diduga memasuki Maji Vegas,\Narena {\i1}pachinko{\i0} di Sendai, Miyagi,
Dialogue: 0,0:02:29.27,0:02:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pelanggan.
Dialogue: 0,0:02:34.61,0:02:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:36.28,0:02:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu…
Dialogue: 0,0:02:39.70,0:02:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judgeman tahu segalanya\Ntentang semua orang di domain ini.
Dialogue: 0,0:02:44.58,0:02:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jangan khawatir.
Dialogue: 0,0:02:46.58,0:02:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mendapatkan informasi itu.
Dialogue: 0,0:02:49.71,0:02:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putusan hanya didasarkan\Npada dua argumen kita.
Dialogue: 0,0:02:55.04,0:02:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali bukti ini.
Dialogue: 0,0:02:59.38,0:03:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kau…
Dialogue: 0,0:03:01.09,0:03:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukti yang diajukan oleh Judgeman.
Dialogue: 0,0:03:05.10,0:03:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti ini tidak serta-merta\Nmembuktikan kau bersalah.
Dialogue: 0,0:03:09.81,0:03:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan memberitahumu isinya.
Dialogue: 0,0:03:12.85,0:03:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, berikan pembelaanmu,\Nhapus kecurigaan,
Dialogue: 0,0:03:16.86,0:03:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menangkan vonis bebas dari Judgeman.
Dialogue: 0,0:03:21.65,0:03:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan dalam bentuk persidangan…{\i0}
Dialogue: 0,0:03:25.87,0:03:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lencana itu…\NJadi, dia benar-benar pengacara?{\i0}
Dialogue: 0,0:03:29.41,0:03:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, ini terasa\Nlebih seperti pendakwaan.{\i0}
Dialogue: 0,0:03:33.25,0:03:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Higuruma adalah Penyihir Jujutsu modern,{\i0}
Dialogue: 0,0:03:35.25,0:03:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi domain inilah\Nyang dimaksud Master Tengen…{\i0}
Dialogue: 0,0:03:39.13,0:03:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, domain adalah teknologi standar
Dialogue: 0,0:03:41.59,0:03:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk Penyihir Jujutsu lama.
Dialogue: 0,0:03:46.43,0:03:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasannya adalah domain lama sering kali
Dialogue: 0,0:03:51.18,0:03:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak menyertakan\Nefek serangan yang fatal.
Dialogue: 0,0:03:55.27,0:03:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya memaksa Teknik Kutukanmu\Nmengenai target, atau tepat sasaran.
Dialogue: 0,0:04:00.99,0:04:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah domain yang umum pada masa itu.
Dialogue: 0,0:04:05.53,0:04:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena orang-orang terobsesi\Ndengan serangan fatal,
Dialogue: 0,0:04:08.49,0:04:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}persyaratannya menjadi lebih berat,
Dialogue: 0,0:04:11.08,0:04:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}domain menjadi lebih mutakhir,
Dialogue: 0,0:04:14.67,0:04:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan semakin sedikit orang\Nyang mampu menggunakannya.
Dialogue: 0,0:04:17.92,0:04:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, domain ini bukan jenis yang fatal.{\i0}
Dialogue: 0,0:04:21.30,0:04:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Domain ini tidak bisa melukaiku\Nsecara fisik,{\i0}
Dialogue: 0,0:04:23.97,0:04:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan sampai batas tertentu,\Naturan mainnya juga dijelaskan.{\i0}
Dialogue: 0,0:04:27.26,0:04:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebuah sumpah yang mengikat\Nyang membuatnya bekerja.{\i0}
Dialogue: 0,0:04:31.14,0:04:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendapat satu kesempatan\Nuntuk bersaksi. Begitu juga denganku.
Dialogue: 0,0:04:35.81,0:04:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kau,\Naku akan menanggapi satu kali,
Dialogue: 0,0:04:38.73,0:04:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasarkan bukti,
Dialogue: 0,0:04:40.94,0:04:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu Judgeman akan menyampaikan putusan
Dialogue: 0,0:04:44.07,0:04:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasarkan Enam Kitab Undang-Undang.
Dialogue: 0,0:04:46.99,0:04:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi\Njika aku dinyatakan bersalah?
Dialogue: 0,0:04:49.45,0:04:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, aku tidak berkewajiban\Nuntuk menjelaskan hal itu.
Dialogue: 0,0:04:53.45,0:04:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku akan memberitahumu ini,\Nsebagai kompensasi.
Dialogue: 0,0:04:58.21,0:05:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya tiga pilihan.
Dialogue: 0,0:05:00.63,0:05:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungkam. Pengakuan. Atau penyangkalan.
Dialogue: 0,0:05:04.01,0:05:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan penyangkalan itu termasuk berbohong.
Dialogue: 0,0:05:08.01,0:05:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, berbohong itu boleh?\NDalam persidangan?
Dialogue: 0,0:05:12.14,0:05:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika semua orang berkata jujur,
Dialogue: 0,0:05:14.52,0:05:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tidak membutuhkan persidangan.
Dialogue: 0,0:05:18.10,0:05:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Berikan alasanmu.
Dialogue: 0,0:05:20.86,0:05:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judgeman tidak sabar.
Dialogue: 0,0:05:25.57,0:05:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku memang pergi ke arena{\i0} pachinko {\i1}itu.{\i0}
Dialogue: 0,0:05:28.24,0:05:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bermain, dan mungkin aku juga menang.{\i0}
Dialogue: 0,0:05:31.83,0:05:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau mau mengaku tidak bersalah,\Naku harus berbohong.{\i0}
Dialogue: 0,0:05:35.54,0:05:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku perlu mencari tahu{\i0}
Dialogue: 0,0:05:38.92,0:05:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}apa sebenarnya bukti itu.{\i0}
Dialogue: 0,0:05:41.84,0:05:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti ini tidak serta-merta\Nmembuktikan kau bersalah.
Dialogue: 0,0:05:47.43,0:05:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Opsi pertama. Jika bukti itu\Ntidak menyatakan aku masuk ke arena,{\i0}
Dialogue: 0,0:05:51.76,0:05:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa bungkam atau menyangkalnya.{\i0}
Dialogue: 0,0:05:54.18,0:05:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}- Tidak.\N- Opsi kedua.{\i0}
Dialogue: 0,0:05:55.39,0:05:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika bukti itu\Nhanya membuktikan aku masuk,{\i0}
Dialogue: 0,0:05:58.10,0:06:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}aku bisa mencoba alasan yang memberi\Nruang untuk keringanan hukuman.{\i0}
Dialogue: 0,0:06:00.40,0:06:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku hanya perlu ke toilet.{\i0}
Dialogue: 0,0:06:02.69,0:06:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}- Namun, jika itu pilihan pertama…\N- Kau masuk, bukan?{\i0}
Dialogue: 0,0:06:04.48,0:06:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}- Itu sama saja menggali kuburan sendiri.\N- Y… Ya!{\i0}
Dialogue: 0,0:06:06.57,0:06:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Karena aku akan mengakui bahwa aku masuk.{\i0}
Dialogue: 0,0:06:08.91,0:06:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Opsi ketiga. Jika bukti itu membuktikan\Naku tidak hanya masuk,{\i0}
Dialogue: 0,0:06:12.12,0:06:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi benar-benar bermain, habislah aku.{\i0}
Dialogue: 0,0:06:16.04,0:06:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku menyesalinya…{\i0}
Dialogue: 0,0:06:17.46,0:06:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kalau begitu, aku harus mengaku\Ndan berharap vonisnya lebih ringan.{\i0}
Dialogue: 0,0:06:20.46,0:06:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Apa persidangan ini\Nmengukur tingkat keseriusan perkara?{\i0}
Dialogue: 0,0:06:25.17,0:06:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:06:27.05,0:06:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masuk ke arena {\i1}pachinko{\i0} itu, Maji Vegas,
Dialogue: 0,0:06:30.55,0:06:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku hanya menggunakan toilet\Nkarena itu keadaan darurat.
Dialogue: 0,0:06:35.43,0:06:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:37.06,0:06:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku membuang opsi ketiga.{\i0}
Dialogue: 0,0:06:38.73,0:06:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Entah keringanan hukuman berlaku\Natau tidak,{\i0}
Dialogue: 0,0:06:42.36,0:06:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi ini terdengar seperti kesan terbaik…{\i0}
Dialogue: 0,0:06:44.57,0:06:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurasa begitu.{\i0}
Dialogue: 0,0:06:46.19,0:06:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, giliranku.
Dialogue: 0,0:06:53.07,0:06:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari hari kejadian,
Dialogue: 0,0:06:54.62,0:06:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dari toko barang bekas dekat Maji Vegas.\N- Apa?
Dialogue: 0,0:06:58.45,0:07:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang, ini foto kamera keamanan\Ndari loket pencairan uang.
Dialogue: 0,0:07:06.59,0:07:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciri wajah, bentuk tubuh…
Dialogue: 0,0:07:08.34,0:07:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah kami berasumsi\Nbahwa itu kau, Yuji Itadori?
Dialogue: 0,0:07:15.85,0:07:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau sudah mengaku masuk,
Dialogue: 0,0:07:18.10,0:07:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sudah melihat foto ini,
Dialogue: 0,0:07:20.44,0:07:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alasanmu tentang toilet\Ntidak dapat dipercaya.
Dialogue: 0,0:07:24.11,0:07:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kemungkinan kau masuk untuk bermain,
Dialogue: 0,0:07:27.11,0:07:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meskipun berusia di bawah 18 tahun.
Dialogue: 0,0:07:31.24,0:07:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa… Kejahatan apa itu?
Dialogue: 0,0:07:35.24,0:07:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko itu
Dialogue: 0,0:07:36.74,0:07:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}secara eksplisit melarang anak\Ndi bawah usia 18 tahun.
Dialogue: 0,0:07:40.46,0:07:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, artinya itu masuk tanpa izin.
Dialogue: 0,0:07:43.46,0:07:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasal 130 KUHP.
Dialogue: 0,0:07:45.67,0:07:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak di bawah umur tidak dipidana secara\Nlangsung berdasarkan UU Usaha Hiburan.
Dialogue: 0,0:07:50.92,0:07:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu curang.
Dialogue: 0,0:07:52.93,0:07:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kukatakan, itu tidak penting.
Dialogue: 0,0:07:55.39,0:07:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, itu opsi ketiga?{\i0}
Dialogue: 0,0:07:57.14,0:07:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan?
Dialogue: 0,0:07:59.18,0:08:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Jepang, perjudian ilegal.
Dialogue: 0,0:08:01.43,0:08:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, toko dan loket pencairan uang itu\Nadalah entitas hukum terpisah.
Dialogue: 0,0:08:04.65,0:08:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang beberapa toko berbagi satu loket.
Dialogue: 0,0:08:07.61,0:08:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ditanyakan di sini hanyalah
Dialogue: 0,0:08:09.48,0:08:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau memasuki Maji Vegas.
Dialogue: 0,0:08:12.53,0:08:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang perlu kau lakukan hanya mengatakan,\N"Aku tidak mengenal tempat itu,"
Dialogue: 0,0:08:16.12,0:08:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyangkal tuduhan tersebut.
Dialogue: 0,0:08:20.16,0:08:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu.\NKita belum sampai pada putusan.
Dialogue: 0,0:08:28.96,0:08:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bersalah. Penyitaan.
Dialogue: 0,0:08:34.88,0:08:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami kembali ke dunia nyata.{\i0}
Dialogue: 0,0:08:37.30,0:08:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku bersalah,{\i0}
Dialogue: 0,0:08:39.64,0:08:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi tak ada yang berubah…{\i0}
Dialogue: 0,0:08:50.15,0:08:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa ini?{\i0}
Dialogue: 0,0:08:55.86,0:08:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Palu hakim ini…{\i0}
Dialogue: 0,0:08:57.57,0:08:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia bisa memanggilnya\Ndan menyingkirkannya kapan pun dia mau,{\i0}
Dialogue: 0,0:08:59.95,0:09:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan bahkan mengubah ukurannya.{\i0}
Dialogue: 0,0:09:02.50,0:09:03.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, yang lebih penting…{\i0}
Dialogue: 0,0:09:05.21,0:09:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tangguh.
Dialogue: 0,0:09:07.21,0:09:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gayaku.
Dialogue: 0,0:09:13.80,0:09:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak bisa mengerahkan\NEnergi Kutukanku!{\i0}
Dialogue: 0,0:09:18.51,0:09:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kelas Pelatihan Ke-59.{\i0}
Dialogue: 0,0:09:21.22,0:09:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hiromi Higuruma, 36 tahun,{\i0}
Dialogue: 0,0:09:23.27,0:09:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}anggota Asosiasi Advokat Iwate.{\i0}
Dialogue: 0,0:09:27.73,0:09:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia melamar ke Fakultas Hukum\Ndi Universitas T.{\i0}
Dialogue: 0,0:09:30.06,0:09:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia melewati setiap rintangan utama\Ndalam satu percobaan,{\i0}
Dialogue: 0,0:09:33.73,0:09:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}termasuk ujian advokat lama sebelum\Nsistem sekolah hukum diperkenalkan.{\i0}
Dialogue: 0,0:09:37.61,0:09:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagi Higuruma, itu sederhana.{\i0}
Dialogue: 0,0:09:39.53,0:09:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Masukkan pengetahuan apa pun\Nyang dibutuhkan,{\i0}
Dialogue: 0,0:09:42.03,0:09:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}keluarkan apa yang dibutuhkan.{\i0}
Dialogue: 0,0:09:47.33,0:09:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Seorang genius,"{\i0}
Dialogue: 0,0:09:49.42,0:09:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bisik orang-orang yang mengenal dia.{\i0}
Dialogue: 0,0:09:52.84,0:09:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, bakat mentahnya\Nyang paling cemerlang{\i0}
Dialogue: 0,0:09:56.97,0:10:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah sebagai Penyihir Jujutsu.{\i0}
Dialogue: 0,0:10:02.68,0:10:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan domain bawaan, dia menganalisis\NTeknik Kutukannya sendiri,{\i0}
Dialogue: 0,0:10:07.35,0:10:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan sembari berproses,\Njuga menguasai Teknik Penghalang.{\i0}
Dialogue: 0,0:10:12.57,0:10:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan cara membedah Teknik Penghalang,{\i0}
Dialogue: 0,0:10:14.94,0:10:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia dapat pemahaman tentang penguatan\Nmelalui pengendalian Energi Kutukan,{\i0}
Dialogue: 0,0:10:18.32,0:10:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan dalam 12 hari setelah bangkit,{\i0}
Dialogue: 0,0:10:20.78,0:10:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia tumbuh ke level yang sebanding{\i0}
Dialogue: 0,0:10:22.91,0:10:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan Penyihir Jujutsu Tingkat Satu.{\i0}
Dialogue: 0,0:10:26.25,0:10:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebelum memasuki koloni, dia mengusir\NRoh Kutukan yang tak terhitung jumlahnya,{\i0}
Dialogue: 0,0:10:30.25,0:10:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan bahkan mengalahkan{\i0}
Dialogue: 0,0:10:32.88,0:10:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lebih dari 20 pemain.{\i0}
Dialogue: 0,0:11:13.38,0:11:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau tidak bisa mengerahkan\NEnergi Kutukan sekarang?
Dialogue: 0,0:11:17.17,0:11:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang melakukan ini, bukan?
Dialogue: 0,0:11:20.34,0:11:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyitaan menonaktifkan sementara
Dialogue: 0,0:11:23.55,0:11:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penggunaan suatu Teknik Kutukan.
Dialogue: 0,0:11:25.97,0:11:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari yang kulihat, sejak awal\Nkau tidak memiliki Teknik Kutukan.
Dialogue: 0,0:11:30.31,0:11:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hukumannya mungkin bergeser menjadi,\N"Tak boleh menggunakan Energi Kutukan."
Dialogue: 0,0:11:35.77,0:11:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, penyitaan biasanya
Dialogue: 0,0:11:37.57,0:11:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}digunakan sebagai hukuman tambahan\Ndan tidak pernah dijatuhkan sendirian.
Dialogue: 0,0:11:41.99,0:11:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mengerikan sekali\Nkalau diucapkan langsung.{\i0}
Dialogue: 0,0:11:45.53,0:11:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana kau bisa mengimbangiku,\Ntanpa Energi Kutukan?{\i0}
Dialogue: 0,0:11:50.00,0:11:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah itu bukan karena Teknik Kutukannya,\Nmelainkan kekuatan fisik alaminya?{\i0}
Dialogue: 0,0:11:53.50,0:11:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebagai makhluk hidup,\Nmungkinkah daya tahannya sangat tinggi?{\i0}
Dialogue: 0,0:11:57.29,0:12:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagi sebagian besar Penyihir Jujutsu,\Nsetelah kehilangan Teknik Kutukan,{\i0}
Dialogue: 0,0:12:00.34,0:12:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kontrol dasar Energi Kutukan mereka\Nmenjadi kacau.{\i0}
Dialogue: 0,0:12:04.05,0:12:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin waktu menumpulkan insting mereka.{\i0}
Dialogue: 0,0:12:06.60,0:12:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, situasi dia lebih buruk.\NEnergi Kutukannya mati total.{\i0}
Dialogue: 0,0:12:10.93,0:12:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, dia masih bisa\Nbertarung sebaik ini.{\i0}
Dialogue: 0,0:12:14.40,0:12:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kebanyakan orang pasti akan kalah\Npada pukulan pertama.{\i0}
Dialogue: 0,0:12:19.82,0:12:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika salah langkah,\Naku akan menerima akibatnya.{\i0}
Dialogue: 0,0:12:23.07,0:12:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan menghancurkan dia dengan semua…{\i0}
Dialogue: 0,0:13:05.91,0:13:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau luar biasa.
Dialogue: 0,0:13:07.24,0:13:10.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rasanya seperti melawan boneka\Nyang tak bisa dihancurkan.{\i0}
Dialogue: 0,0:13:10.95,0:13:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gawat! Berapa lama ini akan berlangsung?{\i0}
Dialogue: 0,0:13:14.54,0:13:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cepat! Energi Kutukan, ayo bangkit!{\i0}
Dialogue: 0,0:13:17.71,0:13:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia memiliki kekuatan sebesar ini, jadi…{\i0}
Dialogue: 0,0:13:20.34,0:13:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti ada kondisi\Nyang bisa merugikan dia, bukan?{\i0}
Dialogue: 0,0:13:24.80,0:13:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pikirkan…{\i0}
Dialogue: 0,0:13:28.34,0:13:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan persidangan… Persidangan…{\i0}
Dialogue: 0,0:13:39.15,0:13:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higuruma! Aku ingin persidangan ulang!\NSekali lagi!
Dialogue: 0,0:13:52.54,0:13:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyadarinya.
Dialogue: 0,0:13:56.58,0:13:58.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi nyaris saja.
Dialogue: 0,0:13:58.00,0:14:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persidangan kedua, ya?
Dialogue: 0,0:14:01.67,0:14:04.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siapa pun yang dinyatakan bersalah\Noleh Judgeman{\i0}
Dialogue: 0,0:14:04.46,0:14:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan dihukum{\i0}
Dialogue: 0,0:14:07.09,0:14:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bisa meminta persidangan ulang\Nhingga dua kali,{\i0}
Dialogue: 0,0:14:09.13,0:14:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}selama mereka tidak mengakui kesalahan.{\i0}
Dialogue: 0,0:14:14.01,0:14:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Judgeman tidak akan pernah menolak.{\i0}
Dialogue: 0,0:14:19.94,0:14:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan lagi! Sekali lagi!
Dialogue: 0,0:14:25.15,0:14:27.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuji Itadori dicurigai
Dialogue: 0,0:14:27.32,0:14:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melakukan pembunuhan massal di Shibuya
Dialogue: 0,0:14:30.74,0:14:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada 31 Oktober 2018.
Dialogue: 0,0:14:38.08,0:14:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku membunuh mereka.
Dialogue: 0,0:14:40.71,0:14:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan kebohongan atau penyangkalan.
Dialogue: 0,0:14:45.30,0:14:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bersalah!
Dialogue: 0,0:14:46.80,0:14:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penyitaan!
Dialogue: 0,0:14:49.30,0:14:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hukuman mati!
Dialogue: 0,0:14:55.39,0:14:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Higuruma.{\i0}
Dialogue: 0,0:15:02.86,0:15:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Yoshizawa.
Dialogue: 0,0:15:04.98,0:15:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika soal drafnya,\Naku sudah mengirim itu tadi.
Dialogue: 0,0:15:09.86,0:15:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, bukan itu.
Dialogue: 0,0:15:12.16,0:15:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membacanya. Sangat bagus.
Dialogue: 0,0:15:15.49,0:15:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, itu bisa digunakan\Nsebagai putusan apa adanya.
Dialogue: 0,0:15:20.29,0:15:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang ingin menjadi jaksa penuntut\Natau pengacara pembela, bukan?
Dialogue: 0,0:15:25.46,0:15:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:27.05,0:15:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan ini?
Dialogue: 0,0:15:29.80,0:15:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak bercita-cita\Nmenjadi hakim?
Dialogue: 0,0:15:41.89,0:15:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hukuman terberat\Nyang dapat dijatuhkan Judgeman.{\i0}
Dialogue: 0,0:15:46.02,0:15:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hukuman mati dengan penyitaan.{\i0}
Dialogue: 0,0:15:52.07,0:15:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan penyitaan, Teknik Kutukannya,{\i0}
Dialogue: 0,0:15:55.28,0:15:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}atau dalam kasus Itadori,{\i0}
Dialogue: 0,0:15:56.66,0:15:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Energi Kutukannya dinonaktifkan.{\i0}
Dialogue: 0,0:15:59.87,0:16:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, Higuruma menerima Pedang Algojo.{\i0}
Dialogue: 0,0:16:04.71,0:16:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siapa pun yang ditebas oleh pedang itu{\i0}
Dialogue: 0,0:16:08.38,0:16:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}akan mati{\i0}
Dialogue: 0,0:16:10.46,0:16:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tanpa terkecuali.{\i0}
Dialogue: 0,0:16:13.38,0:16:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berdiri di samping hati seseorang{\i0}
Dialogue: 0,0:16:15.97,0:16:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}berarti memahami kelemahan mereka.{\i0}
Dialogue: 0,0:16:19.81,0:16:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kelemahan korban. Kelemahan pelaku.{\i0}
Dialogue: 0,0:16:24.56,0:16:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hari demi hari…{\i0}
Dialogue: 0,0:16:28.40,0:16:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku muak dengan itu.{\i0}
Dialogue: 0,0:16:31.57,0:16:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jelek. Semakin aku berinteraksi\Ndengan orang-orang,{\i0}
Dialogue: 0,0:16:35.03,0:16:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}semakin aku mulai berpikir begitu.{\i0}
Dialogue: 0,0:16:38.37,0:16:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama, Itadori!
Dialogue: 0,0:16:42.45,0:16:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang lemah dan jelek!
Dialogue: 0,0:16:46.25,0:16:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak peduli seberapa mulia jiwa\Nyang kau dambakan…
Dialogue: 0,0:16:52.46,0:16:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada apa pun yang menanti!
Dialogue: 0,0:16:54.59,0:16:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik kegelapan,\Nhanya ada kegelapan yang lebih pekat!
Dialogue: 0,0:16:58.30,0:16:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meskipun kau menyalakan lampu,{\i0}
Dialogue: 0,0:17:00.56,0:17:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehampaan lain yang menyilaukan\Nakan menyebar lebih luas!
Dialogue: 0,0:17:09.61,0:17:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:17:11.28,0:17:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menjadi hakim.
Dialogue: 0,0:17:18.66,0:17:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu rupanya. Bolehkah setidaknya\Naku bertanya alasannya?{\i0}
Dialogue: 0,0:17:23.25,0:17:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang lemah dan jelek.
Dialogue: 0,0:17:28.83,0:17:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu tak cocok untuk orang sepertiku\Nyang tak tertarik untuk dipromosikan.{\i0}
Dialogue: 0,0:17:33.55,0:17:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, saat itu…{\i0}
Dialogue: 0,0:17:36.63,0:17:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setidaknya sampai saat itu…{\i0}
Dialogue: 0,0:17:39.26,0:17:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}aku percaya bahwa noda dan cela,\Nyang hanya dimiliki manusia,{\i0}
Dialogue: 0,0:17:42.35,0:17:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}adalah sesuatu yang layak untuk dihormati!{\i0}
Dialogue: 0,0:17:45.68,0:17:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa?{\i0}
Dialogue: 0,0:17:47.27,0:17:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yuji Itadori…{\i0}
Dialogue: 0,0:17:49.48,0:17:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa kau mengakui kesalahanmu?{\i0}
Dialogue: 0,0:17:51.82,0:17:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Isi dari bukti yang diberikan\Noleh Judgeman{\i0}
Dialogue: 0,0:17:55.15,0:17:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}diberitahukan pada Penyihir Jujutsu\Nbahkan sebelum buktinya dibuka.{\i0}
Dialogue: 0,0:17:59.57,0:18:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukti itu mengenai iblis{\i0}
Dialogue: 0,0:18:01.08,0:18:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang bersemayam di dalam dirimu,\Nyaitu Sukuna!{\i0}
Dialogue: 0,0:18:05.75,0:18:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau tak membunuh mereka!{\i0}
Dialogue: 0,0:18:08.12,0:18:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa?{\i0}
Dialogue: 0,0:18:32.44,0:18:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasal 39, Ayat Satu.
Dialogue: 0,0:18:36.82,0:18:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kemampuan untuk membedakan
Dialogue: 0,0:18:40.16,0:18:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kemampuan mengendalikan tidak ada,\Nterdakwa dianggap gila secara hukum.
Dialogue: 0,0:18:45.29,0:18:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Shibuya, tubuhmu dirasuki oleh Sukuna.
Dialogue: 0,0:18:49.58,0:18:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu tentang Sukuna?
Dialogue: 0,0:18:52.38,0:18:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,\Nkau tidak memegang kendali.
Dialogue: 0,0:18:55.50,0:18:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tidak secara sukarela\Nmelepaskan kendali itu.
Dialogue: 0,0:18:59.38,0:19:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berarti…
Dialogue: 0,0:19:01.22,0:19:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak bersalah.
Dialogue: 0,0:19:04.81,0:19:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak melakukan kejahatan apa pun.
Dialogue: 0,0:19:08.60,0:19:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja, itu salahku.
Dialogue: 0,0:19:12.52,0:19:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku terlalu lemah.
Dialogue: 0,0:19:18.28,0:19:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:20.49,0:19:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higuruma…
Dialogue: 0,0:19:22.11,0:19:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau melepaskan Teknik Kutukanmu?
Dialogue: 0,0:19:28.04,0:19:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali ke titik awalku.
Dialogue: 0,0:19:31.92,0:19:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itadori,
Dialogue: 0,0:19:33.38,0:19:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin masih ada orang lain
Dialogue: 0,0:19:37.00,0:19:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memiliki kelemahan sepertimu.
Dialogue: 0,0:19:40.72,0:19:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenakan pakaianmu, lalu duduklah.\NAku akan memberimu 100 poin.
Dialogue: 0,0:19:58.69,0:19:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itadori.
Dialogue: 0,0:20:01.28,0:20:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernahkah kau membunuh seseorang\Natas kemauanmu sendiri?
Dialogue: 0,0:20:12.29,0:20:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah.
Dialogue: 0,0:20:19.17,0:20:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:22.38,0:20:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti terasa mengerikan.{\i0}
Dialogue: 0,0:21:56.02,0:21:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kogane, tambahkan peraturan baru.
Dialogue: 0,0:21:59.35,0:22:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan pemain untuk mentransfer poin\Nsatu sama lain.
Dialogue: 0,0:22:03.94,0:22:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, ini termasuk\Ndalam Peraturan Delapan, "Penyesuaian".
Dialogue: 0,0:22:08.91,0:22:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disetujui.
Dialogue: 0,0:22:10.99,0:22:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Peraturan Sepuluh. Seorang pemain dapat\Nmentransfer sejumlah poin ke pemain lain.{\i0}
Dialogue: 0,0:22:18.79,0:22:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kogane, transfer satu poin ke Itadori.
Dialogue: 0,0:22:22.21,0:22:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:22:25.84,0:22:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu poin telah ditransfer\Ndari Hiromi Higuruma.
Dialogue: 0,0:22:30.39,0:22:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 19 hari ke depan, tak satu pun\Ndari kita dapat dicabut Teknik Kutukannya.
Dialogue: 0,0:22:35.52,0:22:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dirimu.
Dialogue: 0,0:22:37.43,0:22:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higuruma, apa yang akan\Nkau lakukan sekarang?
Dialogue: 0,0:22:40.77,0:22:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bersedia,\Nmaukah kau membantu kami?
Dialogue: 0,0:22:45.86,0:22:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua poin yang tersisa
Dialogue: 0,0:22:47.24,0:22:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}milik hakim dan jaksa yang kubunuh{\i0}
Dialogue: 0,0:22:49.78,0:22:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebelum datang ke Tokyo.{\i0}
Dialogue: 0,0:22:53.08,0:22:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat penghalang terbuka,
Dialogue: 0,0:22:54.87,0:22:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin aku akan menyerahkan diri.
Dialogue: 0,0:22:57.54,0:23:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, aku akan memikirkan apa\Nyang harus kulakukan.
Dialogue: 0,0:23:01.54,0:23:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, berada di dekatmu membuatku\Nsemakin membenci diriku sendiri.
Dialogue: 0,0:23:07.42,0:23:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku tidak menyalahkanmu.
Dialogue: 0,0:23:12.01,0:23:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:23:21.69,0:23:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peraturan baru akan segera ditambahkan.
Dialogue: 0,0:23:23.36,0:23:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemain dapat mentransfer\Nsejumlah poin sesuka hati.
Dialogue: 0,0:23:25.98,0:23:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau kau akan melakukannya, seranglah\Nkami dengan tekad untuk membunuh.{\i0}
Dialogue: 0,0:23:27.78,0:23:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin soal itu? Seumur hidupmu… Wi-fi!
Dialogue: 0,0:23:30.15,0:23:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serahkan semua poinmu.{\i0}
Dialogue: 0,0:23:34.78,0:23:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Hendra Hong
