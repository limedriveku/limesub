Dialogue: 0,0:02:42.53,0:02:43.57,tanda,,0000,0000,0000,,{\an8}MENGGUMAM
Dialogue: 0,0:03:53.35,0:03:54.27,tanda,,0000,0000,0000,,SERANGAN TEPAT SASARAN
Dialogue: 0,0:09:25.73,0:09:26.73,tanda,,0000,0000,0000,,PERDATA, KLASIFIKASI KRIMINAL, KAU, SEMUA\NSOAL AKURASI TINGGI, SEDANG, RENDAH
Dialogue: 0,0:09:50.92,0:09:51.84,tanda,,0000,0000,0000,,KANTOR HUKUM HIGURUMA
Dialogue: 0,0:15:48.86,0:15:49.69,tanda,,0000,0000,0000,,{\an8}PEDANG ALGOJO
Dialogue: 0,0:23:32.03,0:23:33.78,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:33.84,0:01:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspansi Domain. Hukuman Mati.
Dialogue: 0,0:01:38.01,0:01:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebelum dia dapat mengaktifkan\Nteknik domainnya…{\i0}
Dialogue: 0,0:01:42.39,0:01:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku akan mengalahkannya!{\i0}
Dialogue: 0,0:01:53.73,0:01:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, semua tindak kekerasan dilarang.
Dialogue: 0,0:01:57.86,0:01:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kita berdua.
Dialogue: 0,0:01:59.57,0:02:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua?
Dialogue: 0,0:02:04.95,0:02:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Maaf. Kekerasan verbal tidak termasuk.
Dialogue: 0,0:02:09.42,0:02:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judgeman, mulai.
Dialogue: 0,0:02:15.55,0:02:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuji Itadori,
Dialogue: 0,0:02:17.80,0:02:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meskipun berusia di bawah 18 tahun,
Dialogue: 0,0:02:20.76,0:02:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada 16 Juli 2017,
Dialogue: 0,0:02:24.14,0:02:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau diduga memasuki Maji Vegas,\Narena {\i1}pachinko{\i0} di Sendai, Miyagi,
Dialogue: 0,0:02:28.27,0:02:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai pelanggan.
Dialogue: 0,0:02:33.61,0:02:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:35.28,0:02:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu…
Dialogue: 0,0:02:38.70,0:02:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judgeman tahu segalanya\Ntentang semua orang di domain ini.
Dialogue: 0,0:02:43.58,0:02:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jangan khawatir.
Dialogue: 0,0:02:45.58,0:02:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mendapatkan informasi itu.
Dialogue: 0,0:02:48.71,0:02:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putusan hanya didasarkan\Npada dua argumen kita.
Dialogue: 0,0:02:54.04,0:02:56.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali bukti ini.
Dialogue: 0,0:02:58.38,0:02:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kau…
Dialogue: 0,0:03:00.09,0:03:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukti yang diajukan oleh Judgeman.
Dialogue: 0,0:03:04.10,0:03:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti ini tidak serta-merta\Nmembuktikan kau bersalah.
Dialogue: 0,0:03:08.81,0:03:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan memberitahumu isinya.
Dialogue: 0,0:03:11.85,0:03:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, berikan pembelaanmu,\Nhapus kecurigaan,
Dialogue: 0,0:03:15.86,0:03:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menangkan vonis bebas dari Judgeman.
Dialogue: 0,0:03:20.65,0:03:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan dalam bentuk persidangan…{\i0}
Dialogue: 0,0:03:24.87,0:03:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lencana itu…\NJadi, dia benar-benar pengacara?{\i0}
Dialogue: 0,0:03:28.41,0:03:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, ini terasa\Nlebih seperti pendakwaan.{\i0}
Dialogue: 0,0:03:32.25,0:03:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Higuruma adalah Penyihir Jujutsu modern,{\i0}
Dialogue: 0,0:03:34.25,0:03:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi domain inilah\Nyang dimaksud Master Tengen…{\i0}
Dialogue: 0,0:03:38.13,0:03:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, domain adalah teknologi standar
Dialogue: 0,0:03:40.59,0:03:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk Penyihir Jujutsu lama.
Dialogue: 0,0:03:45.43,0:03:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasannya adalah domain lama sering kali
Dialogue: 0,0:03:50.18,0:03:53.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak menyertakan\Nefek serangan yang fatal.
Dialogue: 0,0:03:54.27,0:03:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya memaksa Teknik Kutukanmu\Nmengenai target, atau tepat sasaran.
Dialogue: 0,0:03:59.98,0:04:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah domain yang umum pada masa itu.
Dialogue: 0,0:04:04.53,0:04:07.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena orang-orang terobsesi\Ndengan serangan fatal,
Dialogue: 0,0:04:07.49,0:04:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}persyaratannya menjadi lebih berat,
Dialogue: 0,0:04:10.08,0:04:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}domain menjadi lebih mutakhir,
Dialogue: 0,0:04:13.67,0:04:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan semakin sedikit orang\Nyang mampu menggunakannya.
Dialogue: 0,0:04:16.92,0:04:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, domain ini bukan jenis yang fatal.{\i0}
Dialogue: 0,0:04:20.30,0:04:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Domain ini tidak bisa melukaiku\Nsecara fisik,{\i0}
Dialogue: 0,0:04:22.97,0:04:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan sampai batas tertentu,\Naturan mainnya juga dijelaskan.{\i0}
Dialogue: 0,0:04:26.26,0:04:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebuah sumpah yang mengikat\Nyang membuatnya bekerja.{\i0}
Dialogue: 0,0:04:30.14,0:04:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mendapat satu kesempatan\Nuntuk bersaksi. Begitu juga denganku.
Dialogue: 0,0:04:34.81,0:04:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kau,\Naku akan menanggapi satu kali,
Dialogue: 0,0:04:37.73,0:04:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasarkan bukti,
Dialogue: 0,0:04:39.94,0:04:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu Judgeman akan menyampaikan putusan
Dialogue: 0,0:04:43.07,0:04:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasarkan Enam Kitab Undang-Undang.
Dialogue: 0,0:04:45.99,0:04:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi\Njika aku dinyatakan bersalah?
Dialogue: 0,0:04:48.45,0:04:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, aku tidak berkewajiban\Nuntuk menjelaskan hal itu.
Dialogue: 0,0:04:52.45,0:04:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku akan memberitahumu ini,\Nsebagai kompensasi.
Dialogue: 0,0:04:57.21,0:04:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya tiga pilihan.
Dialogue: 0,0:04:59.63,0:05:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungkam. Pengakuan. Atau penyangkalan.
Dialogue: 0,0:05:03.01,0:05:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan penyangkalan itu termasuk berbohong.
Dialogue: 0,0:05:07.01,0:05:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, berbohong itu boleh?\NDalam persidangan?
Dialogue: 0,0:05:11.14,0:05:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika semua orang berkata jujur,
Dialogue: 0,0:05:13.52,0:05:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita tidak membutuhkan persidangan.
Dialogue: 0,0:05:17.10,0:05:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Berikan alasanmu.
Dialogue: 0,0:05:19.86,0:05:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judgeman tidak sabar.
Dialogue: 0,0:05:24.57,0:05:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku memang pergi ke arena{\i0} pachinko {\i1}itu.{\i0}
Dialogue: 0,0:05:27.24,0:05:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku bermain, dan mungkin aku juga menang.{\i0}
Dialogue: 0,0:05:30.83,0:05:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau mau mengaku tidak bersalah,\Naku harus berbohong.{\i0}
Dialogue: 0,0:05:34.54,0:05:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku perlu mencari tahu{\i0}
Dialogue: 0,0:05:37.92,0:05:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}apa sebenarnya bukti itu.{\i0}
Dialogue: 0,0:05:40.84,0:05:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti ini tidak serta-merta\Nmembuktikan kau bersalah.
Dialogue: 0,0:05:46.42,0:05:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Opsi pertama. Jika bukti itu\Ntidak menyatakan aku masuk ke arena,{\i0}
Dialogue: 0,0:05:50.76,0:05:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa bungkam atau menyangkalnya.{\i0}
Dialogue: 0,0:05:53.18,0:05:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}- Tidak.\N- Opsi kedua.{\i0}
Dialogue: 0,0:05:54.39,0:05:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika bukti itu\Nhanya membuktikan aku masuk,{\i0}
Dialogue: 0,0:05:57.10,0:05:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}aku bisa mencoba alasan yang memberi\Nruang untuk keringanan hukuman.{\i0}
Dialogue: 0,0:05:59.40,0:06:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku hanya perlu ke toilet.{\i0}
Dialogue: 0,0:06:01.69,0:06:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}- Namun, jika itu pilihan pertama…\N- Kau masuk, bukan?{\i0}
Dialogue: 0,0:06:03.48,0:06:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}- Itu sama saja menggali kuburan sendiri.\N- Y… Ya!{\i0}
Dialogue: 0,0:06:05.57,0:06:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Karena aku akan mengakui bahwa aku masuk.{\i0}
Dialogue: 0,0:06:07.90,0:06:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Opsi ketiga. Jika bukti itu membuktikan\Naku tidak hanya masuk,{\i0}
Dialogue: 0,0:06:11.12,0:06:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi benar-benar bermain, habislah aku.{\i0}
Dialogue: 0,0:06:15.04,0:06:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku menyesalinya…{\i0}
Dialogue: 0,0:06:16.45,0:06:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kalau begitu, aku harus mengaku\Ndan berharap vonisnya lebih ringan.{\i0}
Dialogue: 0,0:06:19.46,0:06:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Apa persidangan ini\Nmengukur tingkat keseriusan perkara?{\i0}
Dialogue: 0,0:06:24.17,0:06:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:06:26.05,0:06:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masuk ke arena {\i1}pachinko{\i0} itu, Maji Vegas,
Dialogue: 0,0:06:29.55,0:06:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku hanya menggunakan toilet\Nkarena itu keadaan darurat.
Dialogue: 0,0:06:34.43,0:06:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:36.06,0:06:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku membuang opsi ketiga.{\i0}
Dialogue: 0,0:06:37.73,0:06:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Entah keringanan hukuman berlaku\Natau tidak,{\i0}
Dialogue: 0,0:06:41.35,0:06:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi ini terdengar seperti kesan terbaik…{\i0}
Dialogue: 0,0:06:43.56,0:06:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurasa begitu.{\i0}
Dialogue: 0,0:06:45.19,0:06:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, giliranku.
Dialogue: 0,0:06:52.07,0:06:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dari hari kejadian,
Dialogue: 0,0:06:53.62,0:06:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dari toko barang bekas dekat Maji Vegas.\N- Apa?
Dialogue: 0,0:06:57.45,0:07:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang, ini foto kamera keamanan\Ndari loket pencairan uang.
Dialogue: 0,0:07:05.59,0:07:07.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciri wajah, bentuk tubuh…
Dialogue: 0,0:07:07.34,0:07:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah kami berasumsi\Nbahwa itu kau, Yuji Itadori?
Dialogue: 0,0:07:14.85,0:07:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau sudah mengaku masuk,
Dialogue: 0,0:07:17.10,0:07:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sudah melihat foto ini,
Dialogue: 0,0:07:19.43,0:07:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alasanmu tentang toilet\Ntidak dapat dipercaya.
Dialogue: 0,0:07:23.10,0:07:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kemungkinan kau masuk untuk bermain,
Dialogue: 0,0:07:26.11,0:07:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meskipun berusia di bawah 18 tahun.
Dialogue: 0,0:07:30.24,0:07:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa… Kejahatan apa itu?
Dialogue: 0,0:07:34.24,0:07:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko itu
Dialogue: 0,0:07:35.74,0:07:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}secara eksplisit melarang anak\Ndi bawah usia 18 tahun.
Dialogue: 0,0:07:39.45,0:07:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, artinya itu masuk tanpa izin.
Dialogue: 0,0:07:42.46,0:07:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasal 130 KUHP.
Dialogue: 0,0:07:44.67,0:07:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak di bawah umur tidak dipidana secara\Nlangsung berdasarkan UU Usaha Hiburan.
Dialogue: 0,0:07:49.92,0:07:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu curang.
Dialogue: 0,0:07:51.92,0:07:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kukatakan, itu tidak penting.
Dialogue: 0,0:07:54.39,0:07:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, itu opsi ketiga?{\i0}
Dialogue: 0,0:07:56.14,0:07:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan?
Dialogue: 0,0:07:58.18,0:08:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Jepang, perjudian ilegal.
Dialogue: 0,0:08:00.43,0:08:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, toko dan loket pencairan uang itu\Nadalah entitas hukum terpisah.
Dialogue: 0,0:08:03.64,0:08:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang beberapa toko berbagi satu loket.
Dialogue: 0,0:08:06.61,0:08:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ditanyakan di sini hanyalah
Dialogue: 0,0:08:08.48,0:08:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau memasuki Maji Vegas.
Dialogue: 0,0:08:11.53,0:08:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang perlu kau lakukan hanya mengatakan,\N"Aku tidak mengenal tempat itu,"
Dialogue: 0,0:08:15.11,0:08:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyangkal tuduhan tersebut.
Dialogue: 0,0:08:19.16,0:08:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu.\NKita belum sampai pada putusan.
Dialogue: 0,0:08:27.96,0:08:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bersalah. Penyitaan.
Dialogue: 0,0:08:33.88,0:08:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami kembali ke dunia nyata.{\i0}
Dialogue: 0,0:08:36.30,0:08:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku bersalah,{\i0}
Dialogue: 0,0:08:38.64,0:08:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi tak ada yang berubah…{\i0}
Dialogue: 0,0:08:49.15,0:08:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa ini?{\i0}
Dialogue: 0,0:08:54.86,0:08:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Palu hakim ini…{\i0}
Dialogue: 0,0:08:56.57,0:08:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia bisa memanggilnya\Ndan menyingkirkannya kapan pun dia mau,{\i0}
Dialogue: 0,0:08:58.95,0:09:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan bahkan mengubah ukurannya.{\i0}
Dialogue: 0,0:09:01.49,0:09:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, yang lebih penting…{\i0}
Dialogue: 0,0:09:04.21,0:09:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tangguh.
Dialogue: 0,0:09:06.21,0:09:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gayaku.
Dialogue: 0,0:09:12.80,0:09:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak bisa mengerahkan\NEnergi Kutukanku!{\i0}
Dialogue: 0,0:09:17.51,0:09:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kelas Pelatihan Ke-59.{\i0}
Dialogue: 0,0:09:20.22,0:09:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hiromi Higuruma, 36 tahun,{\i0}
Dialogue: 0,0:09:22.27,0:09:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}anggota Asosiasi Advokat Iwate.{\i0}
Dialogue: 0,0:09:26.73,0:09:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia melamar ke Fakultas Hukum\Ndi Universitas T.{\i0}
Dialogue: 0,0:09:29.06,0:09:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia melewati setiap rintangan utama\Ndalam satu percobaan,{\i0}
Dialogue: 0,0:09:32.73,0:09:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}termasuk ujian advokat lama sebelum\Nsistem sekolah hukum diperkenalkan.{\i0}
Dialogue: 0,0:09:36.61,0:09:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagi Higuruma, itu sederhana.{\i0}
Dialogue: 0,0:09:38.53,0:09:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Masukkan pengetahuan apa pun\Nyang dibutuhkan,{\i0}
Dialogue: 0,0:09:41.03,0:09:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}keluarkan apa yang dibutuhkan.{\i0}
Dialogue: 0,0:09:46.33,0:09:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Seorang genius,"{\i0}
Dialogue: 0,0:09:48.42,0:09:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bisik orang-orang yang mengenal dia.{\i0}
Dialogue: 0,0:09:51.84,0:09:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, bakat mentahnya\Nyang paling cemerlang{\i0}
Dialogue: 0,0:09:55.97,0:09:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah sebagai Penyihir Jujutsu.{\i0}
Dialogue: 0,0:10:01.68,0:10:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan domain bawaan, dia menganalisis\NTeknik Kutukannya sendiri,{\i0}
Dialogue: 0,0:10:06.35,0:10:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan sembari berproses,\Njuga menguasai Teknik Penghalang.{\i0}
Dialogue: 0,0:10:11.56,0:10:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan cara membedah Teknik Penghalang,{\i0}
Dialogue: 0,0:10:13.94,0:10:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia dapat pemahaman tentang penguatan\Nmelalui pengendalian Energi Kutukan,{\i0}
Dialogue: 0,0:10:17.32,0:10:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan dalam 12 hari setelah bangkit,{\i0}
Dialogue: 0,0:10:19.78,0:10:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia tumbuh ke level yang sebanding{\i0}
Dialogue: 0,0:10:21.91,0:10:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan Penyihir Jujutsu Tingkat Satu.{\i0}
Dialogue: 0,0:10:25.24,0:10:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebelum memasuki koloni, dia mengusir\NRoh Kutukan yang tak terhitung jumlahnya,{\i0}
Dialogue: 0,0:10:29.25,0:10:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan bahkan mengalahkan{\i0}
Dialogue: 0,0:10:31.88,0:10:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}lebih dari 20 pemain.{\i0}
Dialogue: 0,0:11:12.38,0:11:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau tidak bisa mengerahkan\NEnergi Kutukan sekarang?
Dialogue: 0,0:11:16.17,0:11:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang melakukan ini, bukan?
Dialogue: 0,0:11:19.34,0:11:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyitaan menonaktifkan sementara
Dialogue: 0,0:11:22.55,0:11:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penggunaan suatu Teknik Kutukan.
Dialogue: 0,0:11:24.97,0:11:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari yang kulihat, sejak awal\Nkau tidak memiliki Teknik Kutukan.
Dialogue: 0,0:11:29.31,0:11:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hukumannya mungkin bergeser menjadi,\N"Tak boleh menggunakan Energi Kutukan."
Dialogue: 0,0:11:34.77,0:11:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, penyitaan biasanya
Dialogue: 0,0:11:36.57,0:11:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}digunakan sebagai hukuman tambahan\Ndan tidak pernah dijatuhkan sendirian.
Dialogue: 0,0:11:40.99,0:11:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mengerikan sekali\Nkalau diucapkan langsung.{\i0}
Dialogue: 0,0:11:44.53,0:11:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana kau bisa mengimbangiku,\Ntanpa Energi Kutukan?{\i0}
Dialogue: 0,0:11:48.99,0:11:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah itu bukan karena Teknik Kutukannya,\Nmelainkan kekuatan fisik alaminya?{\i0}
Dialogue: 0,0:11:52.50,0:11:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebagai makhluk hidup,\Nmungkinkah daya tahannya sangat tinggi?{\i0}
Dialogue: 0,0:11:56.29,0:11:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagi sebagian besar Penyihir Jujutsu,\Nsetelah kehilangan Teknik Kutukan,{\i0}
Dialogue: 0,0:11:59.34,0:12:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kontrol dasar Energi Kutukan mereka\Nmenjadi kacau.{\i0}
Dialogue: 0,0:12:03.05,0:12:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin waktu menumpulkan insting mereka.{\i0}
Dialogue: 0,0:12:05.59,0:12:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, situasi dia lebih buruk.\NEnergi Kutukannya mati total.{\i0}
Dialogue: 0,0:12:09.93,0:12:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, dia masih bisa\Nbertarung sebaik ini.{\i0}
Dialogue: 0,0:12:13.39,0:12:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kebanyakan orang pasti akan kalah\Npada pukulan pertama.{\i0}
Dialogue: 0,0:12:18.82,0:12:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika salah langkah,\Naku akan menerima akibatnya.{\i0}
Dialogue: 0,0:12:22.07,0:12:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan menghancurkan dia dengan semua…{\i0}
Dialogue: 0,0:13:04.90,0:13:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau luar biasa.
Dialogue: 0,0:13:06.24,0:13:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rasanya seperti melawan boneka\Nyang tak bisa dihancurkan.{\i0}
Dialogue: 0,0:13:09.95,0:13:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gawat! Berapa lama ini akan berlangsung?{\i0}
Dialogue: 0,0:13:13.54,0:13:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cepat! Energi Kutukan, ayo bangkit!{\i0}
Dialogue: 0,0:13:16.71,0:13:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia memiliki kekuatan sebesar ini, jadi…{\i0}
Dialogue: 0,0:13:19.34,0:13:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti ada kondisi\Nyang bisa merugikan dia, bukan?{\i0}
Dialogue: 0,0:13:23.80,0:13:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pikirkan…{\i0}
Dialogue: 0,0:13:27.34,0:13:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan persidangan… Persidangan…{\i0}
Dialogue: 0,0:13:38.15,0:13:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higuruma! Aku ingin persidangan ulang!\NSekali lagi!
Dialogue: 0,0:13:51.53,0:13:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyadarinya.
Dialogue: 0,0:13:55.58,0:13:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi nyaris saja.
Dialogue: 0,0:13:57.00,0:13:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persidangan kedua, ya?
Dialogue: 0,0:14:00.67,0:14:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siapa pun yang dinyatakan bersalah\Noleh Judgeman{\i0}
Dialogue: 0,0:14:03.46,0:14:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan dihukum{\i0}
Dialogue: 0,0:14:06.09,0:14:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bisa meminta persidangan ulang\Nhingga dua kali,{\i0}
Dialogue: 0,0:14:08.13,0:14:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}selama mereka tidak mengakui kesalahan.{\i0}
Dialogue: 0,0:14:13.01,0:14:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Judgeman tidak akan pernah menolak.{\i0}
Dialogue: 0,0:14:18.94,0:14:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan lagi! Sekali lagi!
Dialogue: 0,0:14:24.15,0:14:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuji Itadori dicurigai
Dialogue: 0,0:14:26.32,0:14:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melakukan pembunuhan massal di Shibuya
Dialogue: 0,0:14:29.74,0:14:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada 31 Oktober 2018.
Dialogue: 0,0:14:37.08,0:14:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku membunuh mereka.
Dialogue: 0,0:14:39.71,0:14:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan kebohongan atau penyangkalan.
Dialogue: 0,0:14:44.30,0:14:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bersalah!
Dialogue: 0,0:14:45.80,0:14:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penyitaan!
Dialogue: 0,0:14:48.30,0:14:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hukuman mati!
Dialogue: 0,0:14:54.39,0:14:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Higuruma.{\i0}
Dialogue: 0,0:15:01.85,0:15:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Yoshizawa.
Dialogue: 0,0:15:03.98,0:15:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika soal drafnya,\Naku sudah mengirim itu tadi.
Dialogue: 0,0:15:08.86,0:15:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, bukan itu.
Dialogue: 0,0:15:11.16,0:15:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membacanya. Sangat bagus.
Dialogue: 0,0:15:14.49,0:15:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, itu bisa digunakan\Nsebagai putusan apa adanya.
Dialogue: 0,0:15:19.29,0:15:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang ingin menjadi jaksa penuntut\Natau pengacara pembela, bukan?
Dialogue: 0,0:15:24.46,0:15:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:26.05,0:15:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan ini?
Dialogue: 0,0:15:28.80,0:15:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak bercita-cita\Nmenjadi hakim?
Dialogue: 0,0:15:40.89,0:15:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hukuman terberat\Nyang dapat dijatuhkan Judgeman.{\i0}
Dialogue: 0,0:15:45.02,0:15:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Hukuman mati dengan penyitaan.{\i0}
Dialogue: 0,0:15:51.07,0:15:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan penyitaan, Teknik Kutukannya,{\i0}
Dialogue: 0,0:15:54.28,0:15:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}atau dalam kasus Itadori,{\i0}
Dialogue: 0,0:15:55.66,0:15:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Energi Kutukannya dinonaktifkan.{\i0}
Dialogue: 0,0:15:58.87,0:16:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, Higuruma menerima Pedang Algojo.{\i0}
Dialogue: 0,0:16:03.71,0:16:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siapa pun yang ditebas oleh pedang itu{\i0}
Dialogue: 0,0:16:07.38,0:16:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}akan mati{\i0}
Dialogue: 0,0:16:09.46,0:16:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tanpa terkecuali.{\i0}
Dialogue: 0,0:16:12.38,0:16:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berdiri di samping hati seseorang{\i0}
Dialogue: 0,0:16:14.97,0:16:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}berarti memahami kelemahan mereka.{\i0}
Dialogue: 0,0:16:18.81,0:16:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kelemahan korban. Kelemahan pelaku.{\i0}
Dialogue: 0,0:16:23.56,0:16:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hari demi hari…{\i0}
Dialogue: 0,0:16:27.40,0:16:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku muak dengan itu.{\i0}
Dialogue: 0,0:16:30.57,0:16:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jelek. Semakin aku berinteraksi\Ndengan orang-orang,{\i0}
Dialogue: 0,0:16:34.03,0:16:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}semakin aku mulai berpikir begitu.{\i0}
Dialogue: 0,0:16:37.37,0:16:39.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama, Itadori!
Dialogue: 0,0:16:41.45,0:16:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang lemah dan jelek!
Dialogue: 0,0:16:45.25,0:16:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak peduli seberapa mulia jiwa\Nyang kau dambakan…
Dialogue: 0,0:16:51.46,0:16:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak ada apa pun yang menanti!
Dialogue: 0,0:16:53.59,0:16:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik kegelapan,\Nhanya ada kegelapan yang lebih pekat!
Dialogue: 0,0:16:57.30,0:16:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meskipun kau menyalakan lampu,{\i0}
Dialogue: 0,0:16:59.56,0:17:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehampaan lain yang menyilaukan\Nakan menyebar lebih luas!
Dialogue: 0,0:17:08.61,0:17:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:17:10.27,0:17:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menjadi hakim.
Dialogue: 0,0:17:17.66,0:17:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu rupanya. Bolehkah setidaknya\Naku bertanya alasannya?{\i0}
Dialogue: 0,0:17:22.24,0:17:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang lemah dan jelek.
Dialogue: 0,0:17:27.83,0:17:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu tak cocok untuk orang sepertiku\Nyang tak tertarik untuk dipromosikan.{\i0}
Dialogue: 0,0:17:32.55,0:17:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, saat itu…{\i0}
Dialogue: 0,0:17:35.63,0:17:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setidaknya sampai saat itu…{\i0}
Dialogue: 0,0:17:38.26,0:17:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}aku percaya bahwa noda dan cela,\Nyang hanya dimiliki manusia,{\i0}
Dialogue: 0,0:17:41.35,0:17:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}adalah sesuatu yang layak untuk dihormati!{\i0}
Dialogue: 0,0:17:44.68,0:17:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa?{\i0}
Dialogue: 0,0:17:46.27,0:17:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yuji Itadori…{\i0}
Dialogue: 0,0:17:48.48,0:17:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa kau mengakui kesalahanmu?{\i0}
Dialogue: 0,0:17:50.81,0:17:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Isi dari bukti yang diberikan\Noleh Judgeman{\i0}
Dialogue: 0,0:17:54.15,0:17:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}diberitahukan pada Penyihir Jujutsu\Nbahkan sebelum buktinya dibuka.{\i0}
Dialogue: 0,0:17:58.57,0:18:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bukti itu mengenai iblis{\i0}
Dialogue: 0,0:18:00.07,0:18:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang bersemayam di dalam dirimu,\Nyaitu Sukuna!{\i0}
Dialogue: 0,0:18:04.75,0:18:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau tak membunuh mereka!{\i0}
Dialogue: 0,0:18:07.12,0:18:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa?{\i0}
Dialogue: 0,0:18:31.44,0:18:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasal 39, Ayat Satu.
Dialogue: 0,0:18:35.82,0:18:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kemampuan untuk membedakan
Dialogue: 0,0:18:39.15,0:18:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kemampuan mengendalikan tidak ada,\Nterdakwa dianggap gila secara hukum.
Dialogue: 0,0:18:44.28,0:18:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Shibuya, tubuhmu dirasuki oleh Sukuna.
Dialogue: 0,0:18:48.58,0:18:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu tentang Sukuna?
Dialogue: 0,0:18:51.38,0:18:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,\Nkau tidak memegang kendali.
Dialogue: 0,0:18:54.50,0:18:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga tidak secara sukarela\Nmelepaskan kendali itu.
Dialogue: 0,0:18:58.38,0:18:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang berarti…
Dialogue: 0,0:19:00.22,0:19:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak bersalah.
Dialogue: 0,0:19:03.80,0:19:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak melakukan kejahatan apa pun.
Dialogue: 0,0:19:07.60,0:19:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja, itu salahku.
Dialogue: 0,0:19:11.52,0:19:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku terlalu lemah.
Dialogue: 0,0:19:17.28,0:19:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:19.49,0:19:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higuruma…
Dialogue: 0,0:19:21.11,0:19:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau melepaskan Teknik Kutukanmu?
Dialogue: 0,0:19:27.04,0:19:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali ke titik awalku.
Dialogue: 0,0:19:30.91,0:19:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itadori,
Dialogue: 0,0:19:32.37,0:19:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin masih ada orang lain
Dialogue: 0,0:19:36.00,0:19:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memiliki kelemahan sepertimu.
Dialogue: 0,0:19:39.72,0:19:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenakan pakaianmu, lalu duduklah.\NAku akan memberimu 100 poin.
Dialogue: 0,0:19:57.69,0:19:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itadori.
Dialogue: 0,0:20:00.28,0:20:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernahkah kau membunuh seseorang\Natas kemauanmu sendiri?
Dialogue: 0,0:20:11.29,0:20:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah.
Dialogue: 0,0:20:18.17,0:20:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:21.38,0:20:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pasti terasa mengerikan.{\i0}
Dialogue: 0,0:21:55.02,0:21:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kogane, tambahkan peraturan baru.
Dialogue: 0,0:21:58.35,0:22:01.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan pemain untuk mentransfer poin\Nsatu sama lain.
Dialogue: 0,0:22:02.94,0:22:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, ini termasuk\Ndalam Peraturan Delapan, "Penyesuaian".
Dialogue: 0,0:22:07.90,0:22:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disetujui.
Dialogue: 0,0:22:09.99,0:22:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Peraturan Sepuluh. Seorang pemain dapat\Nmentransfer sejumlah poin ke pemain lain.{\i0}
Dialogue: 0,0:22:17.79,0:22:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kogane, transfer satu poin ke Itadori.
Dialogue: 0,0:22:21.21,0:22:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:22:24.84,0:22:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu poin telah ditransfer\Ndari Hiromi Higuruma.
Dialogue: 0,0:22:29.38,0:22:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 19 hari ke depan, tak satu pun\Ndari kita dapat dicabut Teknik Kutukannya.
Dialogue: 0,0:22:34.51,0:22:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dirimu.
Dialogue: 0,0:22:36.43,0:22:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Higuruma, apa yang akan\Nkau lakukan sekarang?
Dialogue: 0,0:22:39.77,0:22:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau bersedia,\Nmaukah kau membantu kami?
Dialogue: 0,0:22:44.86,0:22:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua poin yang tersisa
Dialogue: 0,0:22:46.23,0:22:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}milik hakim dan jaksa yang kubunuh{\i0}
Dialogue: 0,0:22:48.78,0:22:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebelum datang ke Tokyo.{\i0}
Dialogue: 0,0:22:52.07,0:22:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat penghalang terbuka,
Dialogue: 0,0:22:53.87,0:22:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin aku akan menyerahkan diri.
Dialogue: 0,0:22:56.54,0:22:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, aku akan memikirkan apa\Nyang harus kulakukan.
Dialogue: 0,0:23:00.54,0:23:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, berada di dekatmu membuatku\Nsemakin membenci diriku sendiri.
Dialogue: 0,0:23:06.42,0:23:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku tidak menyalahkanmu.
Dialogue: 0,0:23:11.01,0:23:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:23:20.69,0:23:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peraturan baru akan segera ditambahkan.
Dialogue: 0,0:23:22.35,0:23:24.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemain dapat mentransfer\Nsejumlah poin sesuka hati.
Dialogue: 0,0:23:24.98,0:23:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau kau akan melakukannya, seranglah\Nkami dengan tekad untuk membunuh.{\i0}
Dialogue: 0,0:23:26.78,0:23:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin soal itu? Seumur hidupmu… Wi-fi!
Dialogue: 0,0:23:29.15,0:23:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serahkan semua poinmu.{\i0}
Dialogue: 0,0:23:33.78,0:23:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Hendra Hong
