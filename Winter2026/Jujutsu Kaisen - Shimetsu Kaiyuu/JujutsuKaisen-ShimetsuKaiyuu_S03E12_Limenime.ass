Dialogue: 0,0:00:24.69,0:00:25.60,tanda,,0000,0000,0000,,1. PENYERAHAN POIN.\N2. MUNDUR DARI CULLING GAME.
Dialogue: 0,0:00:29.69,0:00:30.48,tanda,,0000,0000,0000,,3. KOMUNIKASI MELALUI PENGHALANG.\N4. MEMASUKI DAN MENINGGALKAN PENGHALANG.
Dialogue: 0,0:02:28.73,0:02:30.65,tanda,,0000,0000,0000,,{\an8}PEDANG KEHIDUPAN MEMBUSUK
Dialogue: 0,0:16:25.81,0:16:26.81,tanda,,0000,0000,0000,,PASUKAN PEMBUNUH LANGSUNG KLAN FUJIWARA\NPASUKAN MATAHARI, BULAN, DAN BINTANG
Dialogue: 0,0:16:26.81,0:16:27.81,tanda,,0000,0000,0000,,HIDUP DALAM BAYANG-BAYANG,\NBERDEDIKASI TANPA PAMRIH
Dialogue: 0,0:16:27.82,0:16:28.73,tanda,,0000,0000,0000,,BAHKAN DILARANG MEMILIKI NAMA
Dialogue: 0,0:16:29.90,0:16:30.94,tanda,,0000,0000,0000,,KLAN MEMBERIKU NAMA
Dialogue: 0,0:16:30.94,0:16:31.94,tanda,,0000,0000,0000,,SEBAGAI PENGGANTI UNTUK ANGGOTA KLAN\NYANG MEREKA BUNUH
Dialogue: 0,0:16:31.94,0:16:32.82,tanda,,0000,0000,0000,,DEMI MENGEKSEKUSIKU
Dialogue: 0,0:20:56.04,0:20:58.83,tanda,,0000,0000,0000,,{\an8}MARI KERAHKAN SEGALANYA
Dialogue: 0,0:26:15.61,0:26:18.36,tanda,,0000,0000,0000,,{\an8}POIN
Dialogue: 0,0:26:18.36,0:26:22.12,tanda,,0000,0000,0000,,TERIMA KASIH ATAS TRANSFER POIN\NDARI TAKAKO URO DAN RYU ISHIGORI
Dialogue: 0,0:26:22.12,0:26:24.62,tanda,,0000,0000,0000,,YUTA OKKOTSU, POIN YANG DIMILIKI 190
Dialogue: 0,0:26:57.90,0:27:00.86,tanda,,0000,0000,0000,,{\an8}‎BERSAMBUNG
Dialogue: 0,0:00:04.25,0:00:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Karena sumber daya terbatas,{\i0}
Dialogue: 0,0:00:06.29,0:00:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}kami membutuhkan peraturan\Nuntuk keluar masuk koloni.{\i0}
Dialogue: 0,0:00:10.84,0:00:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, pemain serampangan seperti Dhruv{\i0}
Dialogue: 0,0:00:12.88,0:00:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak boleh dibiarkan keluar\Ndari penghalang.{\i0}
Dialogue: 0,0:00:18.01,0:00:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami harus lebih dulu menyingkirkan\Npemain serupa di koloni lain.{\i0}
Dialogue: 0,0:00:22.64,0:00:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kontak dengan koloni adalah kuncinya.{\i0}
Dialogue: 0,0:00:25.60,0:00:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dua peraturan yang diusulkan Fushiguro.{\i0}
Dialogue: 0,0:00:27.90,0:00:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Metode kontak. Keluar masuk koloni.{\i0}
Dialogue: 0,0:00:30.48,0:00:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Empat penambahan peraturan diperlukan\Nuntuk menyelesaikan ini.{\i0}
Dialogue: 0,0:00:34.90,0:00:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua orang kelelahan\Nakibat insiden di Shibuya.{\i0}
Dialogue: 0,0:00:36.87,0:00:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tubuh dan mental mereka\Nsudah mencapai batasnya.{\i0}
Dialogue: 0,0:00:40.66,0:00:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pak Gojo…{\i0}
Dialogue: 0,0:00:42.70,0:00:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak akan biarkan dia\Nmembunuh sahabatnya dua kali.{\i0}
Dialogue: 0,0:00:46.75,0:00:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan membunuh Kenjaku.{\i0}
Dialogue: 0,0:00:48.71,0:00:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan mendapat 400 poin sendiri.{\i0}
Dialogue: 0,0:00:57.93,0:00:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalian bisa keluar sekarang.
Dialogue: 0,0:01:00.26,0:01:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita menuju utara ke tepi penghalang.
Dialogue: 0,0:01:03.89,0:01:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gendong aku.
Dialogue: 0,0:01:05.56,0:01:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah.
Dialogue: 0,0:01:07.56,0:01:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mari kita istirahat sejenak.
Dialogue: 0,0:01:09.44,0:01:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Stadion itu wilayah Penyihir Jujutsu\Nyang sangat kuat.
Dialogue: 0,0:01:13.90,0:01:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Kurasa belum ada yang akan ke sini…\N- Suara apa itu?
Dialogue: 0,0:01:22.20,0:01:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Larilah ke dalam stadion.
Dialogue: 0,0:01:26.37,0:01:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa?\N- Cepat!
Dialogue: 0,0:01:27.54,0:01:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Apa yang terjadi?\N- Tolong…
Dialogue: 0,0:01:35.09,0:01:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:01:41.81,0:01:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kecoak-kecoak ini… Apa mereka nyata?{\i0}
Dialogue: 0,0:01:46.06,0:01:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sialan.{\i0}
Dialogue: 0,0:01:53.27,0:01:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rika, jatuhkan itu!
Dialogue: 0,0:01:54.53,0:01:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:01:56.82,0:01:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:02:11.96,0:02:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kogane, benda itu juga pemain?
Dialogue: 0,0:02:15.38,0:02:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ya, itu Kurourushi.
Dialogue: 0,0:02:19.18,0:02:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Jadi, Roh Kutukan\Njuga bisa menjadi pemain?{\i0}
Dialogue: 0,0:02:38.03,0:02:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:49.08,0:02:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sedang diawasi.{\i0}
Dialogue: 0,0:02:51.04,0:02:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin oleh dua pemain\Ndengan skor tinggi.{\i0}
Dialogue: 0,0:02:54.13,0:02:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau ikut campur?
Dialogue: 0,0:02:56.59,0:02:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurourushi adalah Roh Kutukan.{\i0}
Dialogue: 0,0:02:58.84,0:03:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau membunuh kami?
Dialogue: 0,0:03:01.93,0:03:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau soal Roh Kutukan,{\i0}
Dialogue: 0,0:03:03.43,0:03:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa membasminya\Ndengan menembakkan energi positif{\i0}
Dialogue: 0,0:03:06.85,0:03:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ke dalam tubuhnya.{\i0}
Dialogue: 0,0:03:08.85,0:03:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seharusnya aku yang menanyakan itu.\N- Tapi…
Dialogue: 0,0:03:12.69,0:03:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka rasa besi!
Dialogue: 0,0:03:18.61,0:03:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak ingin dua yang lain tahu{\i0}
Dialogue: 0,0:03:21.32,0:03:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}aku bisa menggunakan\NTeknik Kutukan Pembalik.{\i0}
Dialogue: 0,0:03:23.57,0:03:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rika melindungi semua orang di stadion.{\i0}
Dialogue: 0,0:03:26.53,0:03:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus menghabisi Kurourushi\Ntanpa menggunakan{\i0}
Dialogue: 0,0:03:28.66,0:03:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rika atau Teknik Kutukan Pembalik!{\i0}
Dialogue: 0,0:03:36.42,0:03:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buta.
Dialogue: 0,0:04:53.04,0:04:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima poin telah ditambahkan.
Dialogue: 0,0:04:55.46,0:04:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, kau bisa menggunakannya?{\i0}
Dialogue: 0,0:04:58.25,0:04:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik Kutukan Pembalik.
Dialogue: 0,0:05:07.51,0:05:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa itu?{\i0}
Dialogue: 0,0:05:09.05,0:05:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serangan?{\i0}
Dialogue: 0,0:05:20.40,0:05:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lenganku sudah kembali.\NTidak ada yang salah.{\i0}
Dialogue: 0,0:05:23.15,0:05:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia mungkin memanipulasi ruang,{\i0}
Dialogue: 0,0:05:26.32,0:05:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi mungkin dia tidak bisa\Nmeremukkan orang dengan itu?{\i0}
Dialogue: 0,0:05:29.57,0:05:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rasanya seperti menciptakan distorsi…\Nseperti aberasi lensa.{\i0}
Dialogue: 0,0:05:33.41,0:05:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik Kutukanku menganggap "langit"
Dialogue: 0,0:05:35.54,0:05:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai "permukaan".
Dialogue: 0,0:05:39.58,0:05:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:05:41.63,0:05:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia mengungkapkan Teknik Kutukannya.{\i0}
Dialogue: 0,0:05:44.01,0:05:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayo, cepat serang aku…{\i0}
Dialogue: 0,0:05:46.42,0:05:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bertanya, tapi…
Dialogue: 0,0:05:48.93,0:05:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tidak keberatan dibunuh, ya?
Dialogue: 0,0:05:51.55,0:05:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti kenapa\Nyang lemah bertarung mati-matian,
Dialogue: 0,0:05:54.72,0:05:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau bisa mendapatkan poin\Nkapan pun kau mau.
Dialogue: 0,0:05:58.69,0:06:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa bertarung begitu agresif?
Dialogue: 0,0:06:01.77,0:06:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Orang ini…{\i0}
Dialogue: 0,0:06:03.48,0:06:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:04.44,0:06:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah bereinkarnasi jadi Penyihir Jujutsu\Nsudah menjadi hal biasa sekarang?
Dialogue: 0,0:06:07.82,0:06:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kami, ini adalah kebangkitan.\NKebangkitan!
Dialogue: 0,0:06:11.95,0:06:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak seorang pun tanpa penyesalan\Ndi kehidupan pertama
Dialogue: 0,0:06:14.33,0:06:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menerima tawaran Kenjaku.
Dialogue: 0,0:06:17.25,0:06:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ya Tuhan, dia menyebalkan.{\i0}
Dialogue: 0,0:06:19.37,0:06:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Culling Game hanya tahap pertama\Ndari kehidupan kedua kita.
Dialogue: 0,0:06:23.96,0:06:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenjaku berada di balik semua ini.
Dialogue: 0,0:06:27.51,0:06:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus berusaha mendapatkan poin\Nuntuk bersiap menghadapi skenario apa pun.
Dialogue: 0,0:06:31.47,0:06:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak punya teman atau pasangan?
Dialogue: 0,0:06:36.43,0:06:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:37.56,0:06:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya teman\Nsampai baru-baru ini,
Dialogue: 0,0:06:41.40,0:06:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku masih tak bisa memahamimu.
Dialogue: 0,0:06:44.19,0:06:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Perasaan ini…{\i0}
Dialogue: 0,0:06:45.86,0:06:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seperti ada seseorang menyentuh\Ntepat di tepi amarahku.{\i0}
Dialogue: 0,0:06:49.40,0:06:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya karena kau punya penyesalan,\Nkau membunuh orang ratusan tahun kemudian…
Dialogue: 0,0:06:53.99,0:06:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau melakukan semuanya\Nhanya untuk kepentingan sendiri?
Dialogue: 0,0:06:57.50,0:06:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau…
Dialogue: 0,0:06:59.37,0:07:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau keturunan Fujiwara?
Dialogue: 0,0:07:01.58,0:07:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa dipahami oleh klan
Dialogue: 0,0:07:03.71,0:07:05.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti klanmu?
Dialogue: 0,0:07:15.64,0:07:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granite Blast.
Dialogue: 0,0:07:26.90,0:07:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu Ishigori?{\i0}
Dialogue: 0,0:07:28.61,0:07:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Atap itu, ya? Dia cukup dekat.{\i0}
Dialogue: 0,0:07:32.57,0:07:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahkan dengan Rika di sana,\Nserangan langsung{\i0}
Dialogue: 0,0:07:36.08,0:07:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}pada level ini bisa membunuh manusia.{\i0}
Dialogue: 0,0:07:39.70,0:07:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pertama adalah Ishigori.{\i0}
Dialogue: 0,0:07:41.58,0:07:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah Kurourushi dan Dhruv lenyap,{\i0}
Dialogue: 0,0:07:44.04,0:07:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak ada alasan\Nmembiarkan Ishigori berkeliaran bebas.{\i0}
Dialogue: 0,0:07:46.88,0:07:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Okkotsu juga.{\i0}
Dialogue: 0,0:07:48.50,0:07:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berburu.{\i0}
Dialogue: 0,0:07:51.63,0:07:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granite Blast.
Dialogue: 0,0:08:06.15,0:08:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei. Jangan mengecewakanku sekarang.
Dialogue: 0,0:08:11.65,0:08:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pergi? Benar.
Dialogue: 0,0:08:13.70,0:08:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarak yang dibuat Okkotsu tadi…
Dialogue: 0,0:08:20.24,0:08:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bertarunglah lebih efisien.
Dialogue: 0,0:08:23.46,0:08:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akankah itu mengenyangkan perutmu,
Dialogue: 0,0:08:25.88,0:08:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Okkotsu?
Dialogue: 0,0:08:31.42,0:08:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau akan memberi tahu\Nseorang anak sebelum pesta
Dialogue: 0,0:08:34.22,0:08:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk makan lebih tenang?
Dialogue: 0,0:08:38.68,0:08:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku akan melakukannya.
Dialogue: 0,0:08:41.31,0:08:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.\NAku mungkin akan mengatakan itu.
Dialogue: 0,0:08:44.23,0:08:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contoh yang kuberikan buruk.
Dialogue: 0,0:08:46.48,0:08:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan pertamaku\Nsekitar 80 persen kenyang.
Dialogue: 0,0:08:51.19,0:08:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertarung dengan lawan kuat\Ndan bertemu beberapa wanita hebat.
Dialogue: 0,0:08:56.20,0:09:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, kalau kau bertanya apa aku\Npunya penyesalan, sebenarnya tidak juga.
Dialogue: 0,0:09:02.12,0:09:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa haus yang samar ini\Nbenar-benar menyebalkan, Okkotsu.
Dialogue: 0,0:09:07.25,0:09:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang menatapku dan berpikir,\N"Apa yang membuatmu tidak puas?"
Dialogue: 0,0:09:12.96,0:09:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokok ini… Rasanya sedikit manis\Nsetelah kau isap.
Dialogue: 0,0:09:18.34,0:09:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku
Dialogue: 0,0:09:20.22,0:09:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa hidangan penutup.
Dialogue: 0,0:09:23.10,0:09:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia menyerang.{\i0}
Dialogue: 0,0:09:32.98,0:09:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang membuatku tidak puas?{\i0}
Dialogue: 0,0:09:35.82,0:09:37.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau sudah tahu jawabannya!{\i0}
Dialogue: 0,0:09:44.79,0:09:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak puas karena aku belum kenyang!{\i0}
Dialogue: 0,0:10:02.39,0:10:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kau jangan hancur dulu.
Dialogue: 0,0:10:20.87,0:10:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit.
Dialogue: 0,0:10:39.68,0:10:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baiklah.{\i0}
Dialogue: 0,0:10:47.31,0:10:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak memanggil shikigami-mu?
Dialogue: 0,0:10:50.98,0:10:52.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melakukannya.
Dialogue: 0,0:10:52.98,0:10:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak selagi kau mengamuk seperti ini.
Dialogue: 0,0:10:55.19,0:10:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:11:00.03,0:11:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia mencoba mempersempit pilihanku, tapi…{\i0}
Dialogue: 0,0:11:02.99,0:11:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dari depan…{\i0}
Dialogue: 0,0:11:05.99,0:11:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan menerobos langsung!{\i0}
Dialogue: 0,0:11:08.54,0:11:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap!
Dialogue: 0,0:11:09.71,0:11:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang kumaksud, Okkotsu!\NKalau begitu, terima ini!
Dialogue: 0,0:11:15.84,0:11:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kepadatan Energi Kutukannya\Nbaru saja melonjak! Celaka!{\i0}
Dialogue: 0,0:11:23.34,0:11:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! Ini hadiahmu.
Dialogue: 0,0:11:29.81,0:11:31.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Astaga.{\i0}
Dialogue: 0,0:11:31.19,0:11:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku kepanasan.
Dialogue: 0,0:11:41.95,0:11:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lumayan, Okkotsu.{\i0}
Dialogue: 0,0:11:43.99,0:11:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau… hidangan penutupku?{\i0}
Dialogue: 0,0:11:54.54,0:11:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau…
Dialogue: 0,0:11:55.54,0:11:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau luar biasa!
Dialogue: 0,0:12:02.72,0:12:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kuserang bukan orang,
Dialogue: 0,0:12:04.93,0:12:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan permukaan langit.
Dialogue: 0,0:12:08.76,0:12:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemecah Es Tipis.
Dialogue: 0,0:12:13.48,0:12:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir! Dasar orang aneh!
Dialogue: 0,0:12:18.65,0:12:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam, dasar sampah!!
Dialogue: 0,0:12:27.91,0:12:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Begitu gigih…{\i0}
Dialogue: 0,0:12:29.70,0:12:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Aku putuskan\Nuntuk membuatmu menderita.
Dialogue: 0,0:12:34.67,0:12:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kena telak.
Dialogue: 0,0:12:36.21,0:12:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya aku\Nterkena Teknik Kutukanku sendiri.
Dialogue: 0,0:12:39.75,0:12:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Pembalik\Nmemang jadi masalah,{\i0}
Dialogue: 0,0:12:42.38,0:12:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi Energi Kutukan yang terpakai\Nsangat besar.{\i0}
Dialogue: 0,0:12:47.22,0:12:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Akhirnya aku bisa\Nmelihat dasarnya, Okkotsu.{\i0}
Dialogue: 0,0:12:51.39,0:12:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahkan restoran terbaik bisa mengecewakan{\i0}
Dialogue: 0,0:12:53.98,0:12:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}ketika nyaris kosong sebelum tutup.{\i0}
Dialogue: 0,0:12:59.32,0:13:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ternyata bukan kau?
Dialogue: 0,0:13:06.99,0:13:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku ingin menjauh lagi{\i0}
Dialogue: 0,0:13:08.95,0:13:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dari stadion tempat semua orang berada,{\i0}
Dialogue: 0,0:13:11.29,0:13:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi apa boleh buat.{\i0}
Dialogue: 0,0:13:17.58,0:13:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncullah, Rika.
Dialogue: 0,0:13:20.50,0:13:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri aku segalanya.
Dialogue: 0,0:13:24.76,0:13:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manifestasi penuh shikigami?
Dialogue: 0,0:13:27.05,0:13:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Bagaimana bisa?{\i0}
Dialogue: 0,0:13:28.80,0:13:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Energi Kutukannya melonjak lagi!{\i0}
Dialogue: 0,0:13:32.22,0:13:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuta, mana yang kau inginkan?
Dialogue: 0,0:13:35.43,0:13:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Yang itu.
Dialogue: 0,0:13:39.94,0:13:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah Rika Orimoto meninggal,\NRika yang sekarang adalah{\i0}
Dialogue: 0,0:13:42.73,0:13:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}teknik eksternal dan cadangan Energi\NKutukan yang ditinggalkan untuk Okkotsu.{\i0}
Dialogue: 0,0:13:48.07,0:13:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat terhubung dengan Rika melalui cincin,{\i0}
Dialogue: 0,0:13:50.45,0:13:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dia dapat menggunakan Teknik Kutukan\Nyang tersimpan, memanifestasikan Rika,{\i0}
Dialogue: 0,0:13:54.62,0:13:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan memanfaatkan pasokan Energi\NKutukan Rika, selama durasi tersebut.{\i0}
Dialogue: 0,0:13:59.08,0:14:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Waktu koneksi maksimum adalah lima menit.{\i0}
Dialogue: 0,0:14:05.42,0:14:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:06.97,0:14:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:14:08.84,0:14:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan remehkan aku!{\i0}
Dialogue: 0,0:14:14.93,0:14:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan bergerak.{\i0}
Dialogue: 0,0:14:17.06,0:14:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mata dan taring ular…\NAku tidak bisa bergerak!{\i0}
Dialogue: 0,0:14:25.19,0:14:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:14:26.69,0:14:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu lembut!
Dialogue: 0,0:14:31.03,0:14:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rika!\N- Ya.
Dialogue: 0,0:14:32.37,0:14:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ayo!{\i0}
Dialogue: 0,0:14:34.83,0:14:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seranganku gagal!{\i0}
Dialogue: 0,0:14:41.08,0:14:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja!
Dialogue: 0,0:14:44.13,0:14:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sombong dulu!
Dialogue: 0,0:15:15.87,0:15:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan…
Dialogue: 0,0:15:18.37,0:15:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memaafkanmu!
Dialogue: 0,0:15:31.05,0:15:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa?{\i0}
Dialogue: 0,0:15:32.59,0:15:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan ini!
Dialogue: 0,0:15:36.93,0:15:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:15:38.52,0:15:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahkan ini tidak cukup untuk menangkisnya.{\i0}
Dialogue: 0,0:15:43.65,0:15:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bermain?
Dialogue: 0,0:16:13.84,0:16:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemecah Es Tipis!
Dialogue: 0,0:16:33.99,0:16:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fujiwara!
Dialogue: 0,0:16:36.49,0:16:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nafsu makanku
Dialogue: 0,0:16:38.37,0:16:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus bertambah!
Dialogue: 0,0:16:41.91,0:16:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo makan!
Dialogue: 0,0:16:45.42,0:16:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu kau!
Dialogue: 0,0:16:47.42,0:16:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu kau yang menghalangi jalanku!
Dialogue: 0,0:16:49.55,0:16:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sebegitu takut
Dialogue: 0,0:16:51.67,0:16:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menjadi sosok berarti?
Dialogue: 0,0:17:00.64,0:17:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dhruv Lakdawalla, dikalahkan oleh Okkotsu.{\i0}
Dialogue: 0,0:17:04.73,0:17:08.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik Kutukannya memperlakukan\Njalur shikigami
Dialogue: 0,0:17:08.81,0:17:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebagai domainnya, dan apa pun\Nyang disentuhnya akan terkoyak habis.{\i0}
Dialogue: 0,0:17:14.65,0:17:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini…{\i0}
Dialogue: 0,0:17:15.78,0:17:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Dhruv?{\i0}
Dialogue: 0,0:17:18.16,0:17:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkinkah…{\i0}
Dialogue: 0,0:17:19.28,0:17:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Okkotsu adalah…{\i0}
Dialogue: 0,0:17:21.29,0:17:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Copy?
Dialogue: 0,0:17:35.42,0:17:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa\Nyang leluhurku lakukan padamu,
Dialogue: 0,0:17:39.26,0:17:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hidup hanya untuk dirimu sendiri
Dialogue: 0,0:17:41.72,0:17:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mencapai batasnya suatu hari nanti.
Dialogue: 0,0:17:43.81,0:17:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam. "Hiduplah untuk orang lain."
Dialogue: 0,0:17:47.19,0:17:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kau tidak perlu menjadi apa pun."
Dialogue: 0,0:17:50.81,0:17:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang mengatakan itu selalu…
Dialogue: 0,0:17:53.32,0:17:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang yang sudah\Nmenjadi sosok berarti!
Dialogue: 0,0:18:11.67,0:18:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup bicaranya!\NSetelah kau sampai sejauh ini…
Dialogue: 0,0:18:16.59,0:18:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kata-kata tidak lagi berguna!
Dialogue: 0,0:18:23.76,0:18:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ekspansi Domain.
Dialogue: 0,0:18:27.98,0:18:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan Yuta!
Dialogue: 0,0:18:30.98,0:18:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun seseorang memasuki domain nanti…
Dialogue: 0,0:18:33.86,0:18:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini bukan untuk mengulur waktu.
Dialogue: 0,0:18:35.94,0:18:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita akhiri ini dengan bersih!
Dialogue: 0,0:18:40.20,0:18:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pada saat itu,\Niblis hitam dari zaman modern…{\i0}
Dialogue: 0,0:18:44.16,0:18:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka rasa besi!
Dialogue: 0,0:18:48.41,0:18:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}…menerobos ke dalam domain.{\i0}
Dialogue: 0,0:18:53.42,0:18:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebelum memasuki fase dorman, Kurourushi{\i0}
Dialogue: 0,0:18:55.17,0:18:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menyelesaikan partenogenesis.{\i0}
Dialogue: 0,0:18:59.93,0:19:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurourushi masih hidup\Nsebagai Roh Kutukan.{\i0}
Dialogue: 0,0:19:04.18,0:19:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bentrokan domain tiga arah yang kacau.{\i0}
Dialogue: 0,0:19:09.02,0:19:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serta penyusup yang tidak direncanakan.{\i0}
Dialogue: 0,0:19:13.19,0:19:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Domainnya…{\i0}
Dialogue: 0,0:19:17.44,0:19:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}runtuh.{\i0}
Dialogue: 0,0:19:24.53,0:19:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa Kurourushi ada di sini?{\i0}
Dialogue: 0,0:19:28.83,0:19:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Astaga…{\i0}
Dialogue: 0,0:19:31.29,0:19:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sial! Tepat setelah Ekspansi Domain,\NTeknik Kutukanku…{\i0}
Dialogue: 0,0:19:41.80,0:19:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau melakukan itu\Npada lenganku… Fujiwara!
Dialogue: 0,0:19:45.43,0:19:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sudah,
Dialogue: 0,0:19:47.06,0:19:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uro.
Dialogue: 0,0:19:48.43,0:19:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak diundang ke meja ini.
Dialogue: 0,0:19:53.48,0:19:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granite Blast.
Dialogue: 0,0:19:58.61,0:20:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Ishigori\Nadalah Pelepasan Energi Kutukan.{\i0}
Dialogue: 0,0:20:02.45,0:20:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serangan yang sangat sederhana ini{\i0}
Dialogue: 0,0:20:06.91,0:20:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bekerja pada level yang sama\Nbahkan saat Teknik Kutukannya padam.{\i0}
Dialogue: 0,0:20:18.13,0:20:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah…
Dialogue: 0,0:20:22.51,0:20:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita duduk untuk makan,
Dialogue: 0,0:20:25.76,0:20:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Okkotsu.
Dialogue: 0,0:20:28.39,0:20:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Rika.
Dialogue: 0,0:20:35.19,0:20:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hanya selama manifestasi penuh Rika{\i0}
Dialogue: 0,0:20:37.44,0:20:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Okkotsu dapat menggunakan Energi Kutukan\Ndengan keluaran tinggi.{\i0}
Dialogue: 0,0:20:41.90,0:20:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, keluaran puncaknya\Nsedikit di bawah Ishigori.{\i0}
Dialogue: 0,0:20:47.37,0:20:50.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Okkotsu mengisi dan melepaskannya{\i0}
Dialogue: 0,0:20:50.58,0:20:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebelum Ishigori\Ndapat mencapai keluaran maksimal.{\i0}
Dialogue: 0,0:20:53.91,0:20:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu rencananya…{\i0}
Dialogue: 0,0:20:58.84,0:21:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kerinduan selama lebih dari 400 tahun,{\i0}
Dialogue: 0,0:21:01.76,0:21:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tatapan membara yang sebanding\Ndengan dahaga itu{\i0}
Dialogue: 0,0:21:05.01,0:21:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}meluluhkan hati Yuta Okkotsu,{\i0}
Dialogue: 0,0:21:09.72,0:21:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang tidak menemukan makna\Ndalam pertarungan itu sendiri.{\i0}
Dialogue: 0,0:21:14.14,0:21:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali ini saja, ya?
Dialogue: 0,0:21:34.87,0:21:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar manis, Okkotsu!
Dialogue: 0,0:21:48.80,0:21:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik! Mari kita lakukan ini lagi dan lagi!
Dialogue: 0,0:21:56.14,0:21:58.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang besar juga bisa menembak sendiri…{\i0}
Dialogue: 0,0:21:58.90,0:21:59.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi…{\i0}
Dialogue: 0,0:22:01.06,0:22:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dayanya sangat lemah.{\i0}
Dialogue: 0,0:22:04.44,0:22:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ekspansi Domain,\Nditambah pertarungan denganku…{\i0}
Dialogue: 0,0:22:07.78,0:22:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tahu kau hebat, tapi bahkan kau\Nhampir tidak bisa memulihkan lagi.{\i0}
Dialogue: 0,0:22:12.49,0:22:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya menyelesaikan ini.
Dialogue: 0,0:22:14.41,0:22:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granite Blast!
Dialogue: 0,0:22:21.42,0:22:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Okkotsu…{\i0}
Dialogue: 0,0:22:24.55,0:22:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sudah pulih.{\i0}
Dialogue: 0,0:22:29.72,0:22:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Uro?{\i0}
Dialogue: 0,0:22:32.05,0:22:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia bukan hanya pengguna ucapan kutukan.{\i0}
Dialogue: 0,0:22:34.56,0:22:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benda besar itu mungkin{\i0}
Dialogue: 0,0:22:35.81,0:22:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}punya Teknik Kutukan lain\Nyang berbeda dari Okkotsu.{\i0}
Dialogue: 0,0:22:39.44,0:22:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku keliru! Teknik Kutukannya adalah Copy!{\i0}
Dialogue: 0,0:22:43.07,0:22:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tetapi harus ada syaratnya.\NKapan syaratnya terpenuhi?{\i0}
Dialogue: 0,0:22:46.32,0:22:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat aku tidak memperhatikan?{\i0}
Dialogue: 0,0:22:48.61,0:22:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mungkin Teknik Kutukannya tanpa syarat?{\i0}
Dialogue: 0,0:22:54.62,0:22:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah saat itu?{\i0}
Dialogue: 0,0:22:57.08,0:22:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemecah Es Tipis!
Dialogue: 0,0:23:09.63,0:23:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lima menit telah berlalu.{\i0}
Dialogue: 0,0:23:11.13,0:23:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hubungan antara Rika dan Okkotsu terputus.{\i0}
Dialogue: 0,0:23:20.60,0:23:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuta!
Dialogue: 0,0:23:26.19,0:23:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:23:31.53,0:23:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bahwa masih ada sesuatu yang tersisa\Nsetelah mengerahkan segalanya!{\i0}
Dialogue: 0,0:23:37.62,0:23:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, ini… hidangan penutupnya!{\i0}
Dialogue: 0,0:24:02.94,0:24:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cukup sudah.{\i0}
Dialogue: 0,0:24:08.19,0:24:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Apa?{\i0}
Dialogue: 0,0:24:09.82,0:24:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa sasarannya di sini?{\i0}
Dialogue: 0,0:24:28.42,0:24:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini… Teknik Kutukanku…{\i0}
Dialogue: 0,0:24:33.93,0:24:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat itu, dia memakai Teknik Kutukan Uro{\i0}
Dialogue: 0,0:24:36.76,0:24:38.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}untuk mengalihkan lintasan.{\i0}
Dialogue: 0,0:24:42.27,0:24:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:24:50.65,0:24:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenyang.
Dialogue: 0,0:25:10.59,0:25:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu lembut, Okkotsu.
Dialogue: 0,0:25:13.97,0:25:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan aku tidak mengatakan itu\Nsebagai pujian.
Dialogue: 0,0:25:15.88,0:25:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membiarkan Penyihir Jujutsu hidup\Nsetelah pertarungan…
Dialogue: 0,0:25:17.89,0:25:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada keuntungan\Nyang didapat dari itu.
Dialogue: 0,0:25:20.89,0:25:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uro mengatakan hal yang sama.
Dialogue: 0,0:25:22.68,0:25:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia selamat?
Dialogue: 0,0:25:26.48,0:25:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ledakan setelah Ekspansi Domain\Ntidak mungkin terlalu kuat.
Dialogue: 0,0:25:30.98,0:25:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terus berbicara tentang sesuatu.
Dialogue: 0,0:25:33.74,0:25:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertengkaran sepasang kekasih?
Dialogue: 0,0:25:35.45,0:25:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih seperti itu.
Dialogue: 0,0:25:37.57,0:25:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu mempersulit itu.
Dialogue: 0,0:25:39.37,0:25:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa kukatakan padanya.
Dialogue: 0,0:25:43.45,0:25:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang kukatakan\Nakan terasa seperti kekerasan.
Dialogue: 0,0:25:46.67,0:25:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sangat beruntung.
Dialogue: 0,0:25:50.09,0:25:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika demikian menurutmu.\NAku tidak begitu mengerti, tapi…
Dialogue: 0,0:25:54.84,0:25:56.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas dari itu,
Dialogue: 0,0:25:56.97,0:25:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berikan poinmu padaku.
Dialogue: 0,0:26:01.55,0:26:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:26:03.27,0:26:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa ini, kau pasti\Nsudah membunuh kami, bukan?
Dialogue: 0,0:26:08.23,0:26:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk dipastikan.
Dialogue: 0,0:26:12.94,0:26:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berterima kasih saja pada rekan timku.
Dialogue: 0,0:26:27.29,0:26:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau yang akan mencapai batas kemampuanmu.{\i0}
Dialogue: 0,0:26:33.92,0:26:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melihatnya.
Dialogue: 0,0:26:39.51,0:26:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hal yang bahkan melampaui batas pandang{\i0}
Dialogue: 0,0:26:41.64,0:26:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penyihir Jujutsu, Roh Kutukan,\Ndan orang-orang kuat…{\i0}
Dialogue: 0,0:26:45.64,0:26:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rasa percaya diri yang luar biasa.{\i0}
Dialogue: 0,0:26:48.39,0:26:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebuah malapetaka{\i0}
Dialogue: 0,0:26:50.65,0:26:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang tidak memedulikan hal lain.{\i0}
Dialogue: 0,0:28:29.12,0:28:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Hendra Hong
