Dialogue: 0,0:08:03.64,0:08:06.19,tanda,,0000,0000,0000,,PLUP
Dialogue: 0,0:17:18.32,0:17:19.87,tanda,,0000,0000,0000,,HANYA SEBEGINI
Dialogue: 0,0:20:05.53,0:20:06.32,tanda,,0000,0000,0000,,{\an8}PREFEKTUR MIYAGI, KOTA SENDAI\N12 NOVEMBER, PUKUL 11.28
Dialogue: 0,0:23:39.33,0:23:40.50,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:00:07.04,0:00:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspansi Domain.
Dialogue: 0,0:00:08.96,0:00:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taman Bayangan Khimaira.
Dialogue: 0,0:00:17.35,0:00:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik Esoterik: Keranjang Anyaman Hampa.
Dialogue: 0,0:00:22.39,0:00:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keranjang Anyaman Hampa.{\i0}
Dialogue: 0,0:00:24.52,0:00:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Purwarupa Domain Sederhana\NJurus Bayangan Baru.{\i0}
Dialogue: 0,0:00:27.98,0:00:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan ini menetralkan domain{\i0}
Dialogue: 0,0:00:29.98,0:00:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan membatalkan efek tepat sasaran.{\i0}
Dialogue: 0,0:00:33.65,0:00:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali untukmu…
Dialogue: 0,0:00:36.32,0:00:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yang digunakan Jogo dan Hanami di Shibuya,\NAmplifikasi Domain,{\i0}
Dialogue: 0,0:00:39.74,0:00:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menciptakan domain yang cukup besar untuk\Nmembawa efek tepat sasaran dan fatal…{\i0}
Dialogue: 0,0:00:46.88,0:00:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa serangannya tetap mengenaiku?{\i0}
Dialogue: 0,0:00:48.88,0:00:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan sengaja tidak menyertakan\NTeknik Kutukan ke dalam domain,{\i0}
Dialogue: 0,0:00:51.88,0:00:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tercipta ruang kosong{\i0}
Dialogue: 0,0:00:53.51,0:00:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}yang memungkinkan Teknik Kutukan Gojo\Nmengalir ke dalamnya,{\i0}
Dialogue: 0,0:00:55.84,0:00:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sehingga menetralkan\NTeknik Kutukan Tanpa Batas.{\i0}
Dialogue: 0,0:00:58.18,0:01:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keranjang Anyaman Hampa\Ndan Domain Sederhana sendiri{\i0}
Dialogue: 0,0:01:01.26,0:01:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak dapat menetralkan Teknik Kutukan.{\i0}
Dialogue: 0,0:01:05.02,0:01:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kedua teknik itu menetralkan penghalang\Nyang telah disertai Teknik Kutukan,{\i0}
Dialogue: 0,0:01:08.90,0:01:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sehingga membatalkan efek tepat sasaran\Ndari Teknik Kutukan tersebut.{\i0}
Dialogue: 0,0:01:16.11,0:01:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Domain Fushiguro belum sempurna.{\i0}
Dialogue: 0,0:01:19.41,0:01:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seringaimu sudah hilang sekarang.
Dialogue: 0,0:01:21.53,0:01:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bocah kurang ajar.
Dialogue: 0,0:01:25.16,0:01:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan memanfaatkan gimnasium itu sendiri{\i0}
Dialogue: 0,0:01:26.96,0:01:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}sebagai ruang domainnya,{\i0}
Dialogue: 0,0:01:30.46,0:01:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}penghalang yang dipaksa tertutup tersebut{\i0}
Dialogue: 0,0:01:32.80,0:01:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak disertai\Ndengan Teknik Kutukan tepat sasaran.{\i0}
Dialogue: 0,0:01:37.26,0:01:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berlagak\Nseolah-olah kau sudah menang…
Dialogue: 0,0:01:40.55,0:01:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:01:42.35,0:01:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Di sini, dia menggunakan\NTaman Bayangan Khimaira{\i0}
Dialogue: 0,0:01:43.97,0:01:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}untuk memperluas Teknik Sepuluh Bayangan{\i0}
Dialogue: 0,0:01:48.19,0:01:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan mengeluarkan 120 persen potensinya.{\i0}
Dialogue: 0,0:01:53.73,0:01:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, kondisi yang belum sempurna itu\Njustru membuat Reggie Star lengah.{\i0}
Dialogue: 0,0:01:58.57,0:02:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Klona ini dan para{\i0} shikigami {\i1}itu sudah\Nmemiliki wujud fisik sebelum menyentuhku.{\i0}
Dialogue: 0,0:02:02.70,0:02:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Artinya, penghalang ini tidak disertai\Ndengan Teknik Kutukan tepat sasaran.{\i0}
Dialogue: 0,0:02:07.66,0:02:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Peningkatan Teknik Kutukan\Ndi dalam domain ini luar biasa.{\i0}
Dialogue: 0,0:02:11.71,0:02:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jauh lebih sulit dihadapi\Ndaripada domain tepat sasaran yang normal.{\i0}
Dialogue: 0,0:02:15.13,0:02:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika dia mengeluarkan Gajah Maksimal\Ndi sini dan menekanku dengan serangan air,{\i0}
Dialogue: 0,0:02:18.93,0:02:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pilihanku akan berkurang drastis,\Ndan pada dasarnya aku tamat!
Dialogue: 0,0:02:29.69,0:02:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, tentu saja,{\i0}
Dialogue: 0,0:02:33.23,0:02:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}hal itu tidak berlaku bagiku, bukan?{\i0}
Dialogue: 0,0:02:37.19,0:02:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nue!
Dialogue: 0,0:02:42.82,0:02:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu lamban!
Dialogue: 0,0:02:48.29,0:02:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:02:52.00,0:02:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pijakanku sudah terasa aneh\Nsejak beberapa waktu lalu.
Dialogue: 0,0:02:54.50,0:02:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak diperkuat dengan Energi Kutukan,\Naku merasa seperti akan tersedot ke dalam.
Dialogue: 0,0:03:01.97,0:03:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segala sesuatu di bawah domain ini\Nadalah bayanganmu, bukan?
Dialogue: 0,0:03:06.31,0:03:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menyimpan, mengeluarkan benda,\Ndan memindahkan dirimu masuk dan keluar.
Dialogue: 0,0:03:09.77,0:03:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Praktis, bukan?
Dialogue: 0,0:03:11.69,0:03:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, ada satu hal yang mengusikku.
Dialogue: 0,0:03:14.36,0:03:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persediaan senjatamu sangat minim.
Dialogue: 0,0:03:16.73,0:03:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh ini, aku hanya melihat\Nsatu Senjata Kutukan murahan.
Dialogue: 0,0:03:20.15,0:03:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kapasitasmu sangat kecil,
Dialogue: 0,0:03:21.70,0:03:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga kau harus menyisakan ruang\Nuntuk dirimu sendiri,
Dialogue: 0,0:03:26.28,0:03:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kau
Dialogue: 0,0:03:27.79,0:03:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang harus memikul bobot dari semua\Nyang tersimpan di sana.
Dialogue: 0,0:03:34.71,0:03:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan bingo, ternyata yang terakhir.
Dialogue: 0,0:03:37.05,0:03:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memanfaatkan pengaturan domainmu\Nuntuk melawanmu.
Dialogue: 0,0:03:40.51,0:03:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberat tiga mobil penumpang.
Dialogue: 0,0:03:42.68,0:03:45.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, beratmu sekitar 2,4 ton.
Dialogue: 0,0:03:45.93,0:03:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klonamu tidak sanggup menahannya,
Dialogue: 0,0:03:48.18,0:03:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku penasaran, bisakah kau tetap\Nmengeluarkan {\i1}shikigami{\i0} milikmu?
Dialogue: 0,0:03:52.31,0:03:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, aku hanya perlu menjaga\Npijakanku dan terus menambah beban
Dialogue: 0,0:03:55.48,0:03:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai kau hancur
Dialogue: 0,0:03:57.77,0:04:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tertindih bobotmu sendiri.
Dialogue: 0,0:04:02.65,0:04:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau melupakan sesuatu?
Dialogue: 0,0:04:04.78,0:04:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:06.20,0:04:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun belum sempurna,\Ndomain tetaplah domain.
Dialogue: 0,0:04:11.87,0:04:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas kita juga ada bayangan!
Dialogue: 0,0:04:25.76,0:04:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat siapa\Nyang akan tumbang lebih dulu!
Dialogue: 0,0:04:28.22,0:04:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reggie!
Dialogue: 0,0:06:05.07,0:06:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Konon, manusia kehilangan kesadaran{\i0}
Dialogue: 0,0:06:07.99,0:06:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}pada kisaran lima hingga enam G.{\i0}
Dialogue: 0,0:06:11.07,0:06:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dua koma empat ton…{\i0}
Dialogue: 0,0:06:13.24,0:06:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dengan asumsi Fushiguro\Nmemiliki berat 60 kilogram,{\i0}
Dialogue: 0,0:06:16.41,0:06:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tubuhnya kini berada di bawah beban 40 G.{\i0}
Dialogue: 0,0:06:21.54,0:06:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untuk mencegah gaya gravitasi menyebabkan\Npenumpukan darah di tubuh bagian bawah{\i0}
Dialogue: 0,0:06:25.17,0:06:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan menyebabkan otak\Nkekurangan suplai darah,{\i0}
Dialogue: 0,0:06:28.22,0:06:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Fushiguro merendahkan kuda-kudanya{\i0}
Dialogue: 0,0:06:30.72,0:06:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan memperkuat seluruh tubuhnya\Ndengan Energi Kutukan,{\i0}
Dialogue: 0,0:06:32.85,0:06:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dengan fokus utama\Npada tubuh bagian bawah.{\i0}
Dialogue: 0,0:06:37.31,0:06:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gajah Afrika dewasa\Nberbobot tiga hingga enam ton.{\i0}
Dialogue: 0,0:06:43.19,0:06:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Berkat peningkatan presisi\Ndi dalam domain,{\i0}
Dialogue: 0,0:06:46.40,0:06:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gajah Maksimal mereproduksi bobot tersebut\Nsecara realistis.{\i0}
Dialogue: 0,0:06:50.11,0:06:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagi Reggie Star,\Nyang menerimanya secara langsung,{\i0}
Dialogue: 0,0:06:53.78,0:06:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tulang betis kanan dan tumitnya retak.{\i0}
Dialogue: 0,0:06:57.25,0:06:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mereka berdua dalam situasi\Ndi mana, satu detik kemudian,{\i0}
Dialogue: 0,0:06:59.83,0:07:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tidak aneh jika mereka berdua\Ntewas terimpit.{\i0}
Dialogue: 0,0:07:05.09,0:07:07.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku mengacau.{\i0}
Dialogue: 0,0:07:07.05,0:07:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika aku menyimpan truk itu,\Npertarungan ini pasti sudah berakhir.{\i0}
Dialogue: 0,0:07:09.76,0:07:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang harus kulakukan?{\i0}
Dialogue: 0,0:07:12.05,0:07:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia menyiramku dengan air,\Ntapi kartu asku masih aman!{\i0}
Dialogue: 0,0:07:16.06,0:07:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan menyelam ke dalam bayangan,\Nlalu membuat ulang kartu asku dari dalam{\i0}
Dialogue: 0,0:07:20.14,0:07:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan meremukkan dia untuk selamanya.{\i0}
Dialogue: 0,0:07:24.61,0:07:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak!{\i0}
Dialogue: 0,0:07:25.52,0:07:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Fakta bahwa dia tidak melepaskan\Ndomain berarti{\i0}
Dialogue: 0,0:07:27.86,0:07:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}apa pun yang sudah ditelan{\i0}
Dialogue: 0,0:07:30.74,0:07:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tetap terperangkap di dalam\Nbahkan setelah domain berakhir!{\i0}
Dialogue: 0,0:07:34.03,0:07:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan jika aku terjebak di sana selamanya{\i0}
Dialogue: 0,0:07:35.83,0:07:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}setelah dia mati…{\i0}
Dialogue: 0,0:07:38.74,0:07:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seperti apa sebenarnya di dalam sana?{\i0}
Dialogue: 0,0:07:41.21,0:07:44.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bentuknya seperti cairan,\Ntapi bisakah kau bernapas?{\i0}
Dialogue: 0,0:07:45.63,0:07:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, menyelam ke dalam bayangan\Nterlalu berisiko.{\i0}
Dialogue: 0,0:07:49.59,0:07:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan melakukannya di sini,\Ndalam keadaan ini!{\i0}
Dialogue: 0,0:07:53.43,0:07:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan mengeluarkan kartu asku\Ndan mengaktifkannya!{\i0}
Dialogue: 0,0:08:00.73,0:08:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penciptaan Ulang Kontraktual!
Dialogue: 0,0:08:23.54,0:08:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terlambat.{\i0}
Dialogue: 0,0:08:25.21,0:08:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan sesuai perkiraanku,\Ntidak ada oksigen di dalam bayangan!{\i0}
Dialogue: 0,0:08:29.96,0:08:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak ada daya apung. Tidak ada hambatan.{\i0}
Dialogue: 0,0:08:35.38,0:08:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau hanya…{\i0}
Dialogue: 0,0:08:38.26,0:08:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tenggelam…{\i0}
Dialogue: 0,0:08:41.06,0:08:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kesadaranku…{\i0}
Dialogue: 0,0:08:43.52,0:08:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}mulai…{\i0}
Dialogue: 0,0:08:50.65,0:08:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Belum. Bertahanlah.{\i0}
Dialogue: 0,0:08:52.99,0:08:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan melepaskan domain\Nhanya setelah dia benar-benar mati!{\i0}
Dialogue: 0,0:08:55.86,0:08:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lalu, aku bisa mengeluarkan semua\Nyang ada di dalam bayangan!{\i0}
Dialogue: 0,0:09:31.40,0:09:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua benda\Nyang kuciptakan ulang menghilang
Dialogue: 0,0:09:33.73,0:09:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah mereka melaksanakan perintah\Nyang kuberikan pada mereka.
Dialogue: 0,0:09:37.95,0:09:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memberi perintah apa pun\Npada mobil-mobil yang tenggelam.
Dialogue: 0,0:09:41.28,0:09:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, aku tidak mungkin\Nmembiarkan mereka menghilang.
Dialogue: 0,0:09:44.45,0:09:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, masih ada ruang\Nuntuk memberi perintah pada salah satunya.
Dialogue: 0,0:09:47.71,0:09:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa aku naik bersamamu.
Dialogue: 0,0:09:50.42,0:09:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat satu mobil hilang,\Ntetapi berkat itu, aku selamat.
Dialogue: 0,0:09:59.01,0:10:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kuakui.
Dialogue: 0,0:10:00.51,0:10:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kuat.
Dialogue: 0,0:10:03.14,0:10:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku…
Dialogue: 0,0:10:06.06,0:10:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih kuat.
Dialogue: 0,0:10:08.39,0:10:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penciptaan Ulang Kontraktual!
Dialogue: 0,0:10:16.90,0:10:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah kayu dua lantai
Dialogue: 0,0:10:19.49,0:10:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan luas tapak 132 m²!
Dialogue: 0,0:10:22.41,0:10:25.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat rangkanya saja minimal 30 ton!
Dialogue: 0,0:10:25.79,0:10:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurlah!
Dialogue: 0,0:11:01.66,0:11:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang terjadi?{\i0}
Dialogue: 0,0:11:03.28,0:11:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa aku jatuh ke dalam bayangan lagi?{\i0}
Dialogue: 0,0:11:07.12,0:11:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak. Ini air sungguhan. Kenapa?{\i0}
Dialogue: 0,0:11:11.96,0:11:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku merasa berat.\NBocah itukah yang menahanku?{\i0}
Dialogue: 0,0:11:16.13,0:11:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kekuatan yang luar biasa…{\i0}
Dialogue: 0,0:11:18.46,0:11:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, tunggu…{\i0}
Dialogue: 0,0:11:20.22,0:11:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Mungkinkah ini bobot ekstra\Ndari dua mobil yang kutambahkan?{\i0}
Dialogue: 0,0:11:25.85,0:11:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini gawat…{\i0}
Dialogue: 0,0:11:27.47,0:11:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kali ini, aku benar-benar akan tenggelam.{\i0}
Dialogue: 0,0:11:29.93,0:11:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus membatalkan\NPenciptaan Ulang Kontraktual.{\i0}
Dialogue: 0,0:11:51.16,0:11:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku mengerti…{\i0}
Dialogue: 0,0:11:53.00,0:11:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini gimnasium.{\i0}
Dialogue: 0,0:11:54.92,0:11:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan di bawahnya, di ruang bawah tanah,\Nada kolam renang air hangat!{\i0}
Dialogue: 0,0:12:01.05,0:12:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Jadi, dia kabur ke dalam bayangan,\Nlalu melepaskan domain,{\i0}
Dialogue: 0,0:12:03.59,0:12:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}membuat aku menghancurkan lantai\Ndan menjatuhkan kami ke kolam renang?{\i0}
Dialogue: 0,0:12:10.89,0:12:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kau sudah basah kuyup,\Nstruk-struk itu tidak berguna.
Dialogue: 0,0:12:18.52,0:12:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kau tidak langsung menindaklanjuti.\NKau menunggu.{\i0}
Dialogue: 0,0:12:21.65,0:12:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kau memulihkan Teknik Kutukanmu\Nsetelah mengurasnya habis di dalam domain.{\i0}
Dialogue: 0,0:12:26.03,0:12:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bagaimana denganmu?
Dialogue: 0,0:12:29.95,0:12:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa memanggil\N{\i1}shikigami{\i0} apa pun sekarang, bukan?
Dialogue: 0,0:12:34.83,0:12:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kau juga tahu itu.
Dialogue: 0,0:12:37.92,0:12:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang…
Dialogue: 0,0:12:40.67,0:12:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Apa pun yang kau panggil,\Npasti bukan anjing itu.{\i0}
Dialogue: 0,0:12:44.38,0:12:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Dan tidak ada shikigami lain\Nyang memiliki kekuatan pemungkas.{\i0}
Dialogue: 0,0:12:46.68,0:12:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Ayo gunakan saja.{\i0}
Dialogue: 0,0:12:48.47,0:12:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Begitu kau melakukannya, akan kutunggu kau\Nlengah dan kubunuh dengan serangan balik!{\i0}
Dialogue: 0,0:13:42.86,0:13:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anjing Ilahi tidak begitu lemah\Nsehingga tidak dapat digunakan
Dialogue: 0,0:13:46.32,0:13:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya karena itu.
Dialogue: 0,0:13:48.57,0:13:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Jujutsu hidup\Ndan mati dengan berbohong…
Dialogue: 0,0:14:09.30,0:14:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Domain itu dan rencana penenggelaman itu.
Dialogue: 0,0:14:13.06,0:14:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta menyembunyikan anjingmu, dan\Nmengecohku seolah kau telah kehilangannya.
Dialogue: 0,0:14:17.60,0:14:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau tidak lari ke gimnasium.
Dialogue: 0,0:14:21.23,0:14:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memancingku ke sana.
Dialogue: 0,0:14:23.57,0:14:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengira akan dikalahkan
Dialogue: 0,0:14:25.44,0:14:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh Penyihir Jujutsu modern,\Nbocah sepertimu pula.
Dialogue: 0,0:14:31.20,0:14:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun aku ingin lari, Nue tidak bisa\Nmembawa seseorang terlalu lama.
Dialogue: 0,0:14:35.08,0:14:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar itu\Ndari pengalaman pahit sebelumnya.
Dialogue: 0,0:14:43.09,0:14:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau… Apa hubunganmu dengan Master Tengen?
Dialogue: 0,0:14:50.63,0:14:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengen?
Dialogue: 0,0:14:54.64,0:14:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya. Jadi, dia masih hidup, ya?
Dialogue: 0,0:14:59.31,0:15:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si penyendiri itu?
Dialogue: 0,0:15:01.60,0:15:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya. Cukup.
Dialogue: 0,0:15:05.44,0:15:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Reggie menyebut penjelasan Master Tengen\Nsoal tujuan{\i0} Culling Game {\i1}sebagai gertakan.{\i0}
Dialogue: 0,0:15:10.36,0:15:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus mempertimbangkan kemungkinan\Nbahwa Master Tengen dan Kenjaku{\i0}
Dialogue: 0,0:15:13.28,0:15:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}bekerja sama,\Ndan memberi kami tujuan palsu…{\i0}
Dialogue: 0,0:15:18.20,0:15:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, dari reaksinya, mungkin tidak…{\i0}
Dialogue: 0,0:15:24.63,0:15:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kogane.
Dialogue: 0,0:15:26.46,0:15:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan semua poinku kepada orang ini.
Dialogue: 0,0:15:30.51,0:15:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:33.26,0:15:37.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat puluh satu poin\Ntelah ditransfer dari Reggie Star.
Dialogue: 0,0:15:37.51,0:15:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:15:39.64,0:15:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cara yang sangat buruk untuk bertanya.
Dialogue: 0,0:15:42.69,0:15:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku melakukan\Nsatu perbuatan baik.
Dialogue: 0,0:15:46.27,0:15:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya seorang pengamat.
Dialogue: 0,0:15:48.78,0:15:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Kenjaku bukan teman baik.
Dialogue: 0,0:15:52.07,0:15:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya punya firasat bahwa ini\Nakan membuat segalanya lebih menarik…
Dialogue: 0,0:15:56.12,0:15:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya firasat.
Dialogue: 0,0:15:59.54,0:16:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku. Kau orang yang membunuhku.
Dialogue: 0,0:16:04.54,0:16:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, biarlah takdir mempermainkanmu,
Dialogue: 0,0:16:07.84,0:16:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan biarlah kau mati sebagai badut.
Dialogue: 0,0:16:34.41,0:16:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima poin telah ditambahkan.
Dialogue: 0,0:16:49.88,0:16:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah berhasil?
Dialogue: 0,0:16:51.96,0:16:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan lengah.
Dialogue: 0,0:16:55.72,0:16:58.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia gigih.\N- Apa-apaan ini?
Dialogue: 0,0:16:59.01,0:17:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berlumur losion?
Dialogue: 0,0:17:01.10,0:17:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu saus kental.
Dialogue: 0,0:17:02.56,0:17:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dan matilah!
Dialogue: 0,0:17:05.69,0:17:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, benarkah ini saus kental?
Dialogue: 0,0:17:08.15,0:17:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ada apa dengan orang ini?{\i0}
Dialogue: 0,0:17:11.32,0:17:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sudah meledakkan dia berulang kali.{\i0}
Dialogue: 0,0:17:13.49,0:17:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seharusnya itu sudah\Nmembunuh dia lima kali!{\i0}
Dialogue: 0,0:17:15.99,0:17:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana mungkin dia\Nhanya sedikit terluka?{\i0}
Dialogue: 0,0:17:19.87,0:17:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benci saus kental?
Dialogue: 0,0:17:21.79,0:17:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan luka pertama yang dia derita\Njuga telah hilang.{\i0}
Dialogue: 0,0:17:24.96,0:17:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, rasanya dia tidak menggunakan\NTeknik Terkutuk Pembalik seperti aku.{\i0}
Dialogue: 0,0:17:29.88,0:17:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Semua ini tidak masuk akal.{\i0}
Dialogue: 0,0:17:32.25,0:17:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hazenoki.
Dialogue: 0,0:17:33.55,0:17:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:35.01,0:17:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reggie Star sudah meninggal.
Dialogue: 0,0:17:42.35,0:17:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:17:43.27,0:17:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi. Persetan dengan ini.
Dialogue: 0,0:17:46.14,0:17:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:17:47.23,0:17:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mandi dan gosok gigimu.
Dialogue: 0,0:17:52.57,0:17:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau 100 poin, Kanchi?
Dialogue: 0,0:17:55.57,0:17:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti mengikutiku.
Dialogue: 0,0:17:56.86,0:18:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, seperti memesan soba\Ndi Tahun Baru.
Dialogue: 0,0:18:00.45,0:18:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah.
Dialogue: 0,0:18:01.87,0:18:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Teknik Kutukan Takaba, si komedian,{\i0}
Dialogue: 0,0:18:04.41,0:18:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}membuat apa pun yang dia anggap lucu\Nmenjadi kenyataan.{\i0}
Dialogue: 0,0:18:08.96,0:18:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini Teknik Kutukan yang bahkan bisa\Nmenyaingi Teknik Kutukan Satoru Gojo.{\i0}
Dialogue: 0,0:18:14.67,0:18:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Takaba tidak tahu apa-apa{\i0}
Dialogue: 0,0:18:17.59,0:18:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tentang Teknik Kutukannya sendiri.{\i0}
Dialogue: 0,0:18:27.98,0:18:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak tahu!{\i0}
Dialogue: 0,0:18:29.90,0:18:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Setelah dewasa,\Nada banyak hal yang tidak kau mengerti!{\i0}
Dialogue: 0,0:18:39.11,0:18:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku pernah dengar\Nbahwa pria adalah serigala,{\i0}
Dialogue: 0,0:18:41.82,0:18:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi selalu serigala yang menyelesaikan\Nhal-hal yang tidak kumengerti!{\i0}
Dialogue: 0,0:18:49.92,0:18:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serigala selalu melakukan segalanya.{\i0}
Dialogue: 0,0:18:52.84,0:18:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jadi, aku tidak perlu\Nmemikirkan apa pun sama sekali.{\i0}
Dialogue: 0,0:18:55.75,0:18:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu karena aku imut, bukan?{\i0}
Dialogue: 0,0:19:05.60,0:19:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serigala selalu… selalu…{\i0}
Dialogue: 0,0:19:17.32,0:19:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Jangan, Megumi.{\i0}
Dialogue: 0,0:19:27.24,0:19:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau yakin?
Dialogue: 0,0:19:36.67,0:19:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:19:41.68,0:19:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sialan…
Dialogue: 0,0:20:03.28,0:20:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Keadaan berubah dengan cepat\Ndi Koloni Sendai.
Dialogue: 0,0:20:06.33,0:20:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Pertempuran di sana jauh melampaui{\i0}
Dialogue: 0,0:20:07.95,0:20:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}keganasan di Koloni Tokyo.{\i0}
Dialogue: 0,0:20:13.87,0:20:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dhruv Lakdawalla.{\i0}
Dialogue: 0,0:20:15.71,0:20:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat ini memiliki 91 poin.{\i0}
Dialogue: 0,0:20:18.46,0:20:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Inkarnasi keduanya.{\i0}
Dialogue: 0,0:20:21.05,0:20:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seorang tetua yang seorang diri{\i0}
Dialogue: 0,0:20:22.55,0:20:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}menaklukkan kepulauan\Nselama Perang Saudara Wa.{\i0}
Dialogue: 0,0:20:27.01,0:20:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia menggunakan dua{\i0} shikigami {\i1}otonom{\i0}
Dialogue: 0,0:20:29.43,0:20:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan memperlakukan lintasan gerak mereka\Nsebagai domainnya.{\i0}
Dialogue: 0,0:20:36.77,0:20:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ryu Ishigori.{\i0}
Dialogue: 0,0:20:38.48,0:20:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat ini memiliki 77 poin.{\i0}
Dialogue: 0,0:20:41.90,0:20:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Meriam dengan keluaran Energi Kutukan\Ntertinggi di antara para pemain.{\i0}
Dialogue: 0,0:20:47.99,0:20:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Takako Uro. Saat ini memiliki 70 poin.{\i0}
