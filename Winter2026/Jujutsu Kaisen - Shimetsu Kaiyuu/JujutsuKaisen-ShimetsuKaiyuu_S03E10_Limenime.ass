Dialogue: 0,0:04:09.54,0:04:10.54,tanda,,0000,0000,0000,,{\an8}IORI HAZENOKI\NPOIN YANG DIMILIKI: 35
Dialogue: 0,0:04:23.13,0:04:23.84,tanda,,0000,0000,0000,,STRUK BENSIN
Dialogue: 0,0:04:41.11,0:04:41.86,tanda,,0000,0000,0000,,{\an8}REGGIE STAR\NPOIN YANG DIMILIKI: 41
Dialogue: 0,0:05:54.68,0:05:55.64,tanda,,0000,0000,0000,,{\an8}CHIZURU HARI\NPOIN YANG DIMILIKI: 28
Dialogue: 0,0:06:08.53,0:06:09.65,tanda,,0000,0000,0000,,ATURAN SEPULUH: SEORANG PEMAIN DAPAT\NMENTRANSFER SEJUMLAH POIN KE PEMAIN LAIN
Dialogue: 0,0:09:47.00,0:09:48.21,tanda,,0000,0000,0000,,{\an8}FUMIHIKO TAKABA\NPOIN YANG DIMILIKI: NOL
Dialogue: 0,0:11:01.16,0:11:01.82,tanda,,0000,0000,0000,,TERKUTUK
Dialogue: 0,0:12:36.17,0:12:37.84,tanda,,0000,0000,0000,,{\an8}HIROMI HIGURUMA: 100 POIN\NKOLONI TOKYO
Dialogue: 0,0:17:21.41,0:17:22.41,tanda,,0000,0000,0000,,STRUK\NHOSHIZORA TEI
Dialogue: 0,0:18:50.37,0:18:51.04,tanda,,0000,0000,0000,,STRUK TELEPON SELULER
Dialogue: 0,0:18:51.04,0:18:52.29,tanda,,0000,0000,0000,,PUKUL 14.02\NSENIN, 12 NOVEMBER
Dialogue: 0,0:21:42.84,0:21:45.59,tanda,,0000,0000,0000,,{\an8}EKSPANSI DOMAIN\NTAMAN BAYANGAN KHIMAIRA
Dialogue: 0,0:23:39.29,0:23:40.96,tanda,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:01:36.47,0:01:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}"Keabadian" dalam Peraturan\Nhanyalah kedok.{\i0}
Dialogue: 0,0:01:39.34,0:01:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tabir asap untuk rencana sebenarnya.{\i0}
Dialogue: 0,0:01:42.51,0:01:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku yakin akan hal itu.{\i0}
Dialogue: 0,0:01:44.60,0:01:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat yang kuat saja yang tersisa,{\i0}
Dialogue: 0,0:01:46.73,0:01:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenjaku akan menjatuhkan bom,{\i0}
Dialogue: 0,0:01:49.02,0:01:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan saat itulah{\i0} Culling Game\N{\i1}telah memenuhi tujuannya.{\i0}
Dialogue: 0,0:01:52.90,0:01:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita tidak tahu bom apa itu.{\i0}
Dialogue: 0,0:01:56.36,0:01:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan ledakannya tidak akan lama lagi.{\i0}
Dialogue: 0,0:01:59.95,0:02:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi sekarang.
Dialogue: 0,0:02:02.74,0:02:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kami mengumpulkan sekutu kuat
Dialogue: 0,0:02:06.50,0:02:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menimbun poin sebagai persiapan.
Dialogue: 0,0:02:09.00,0:02:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada beberapa hal yang ingin kutanyakan.
Dialogue: 0,0:02:12.00,0:02:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dia tidak sekuat itu.
Dialogue: 0,0:02:14.50,0:02:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia umpan. Dia memikat pemain ke sini\Ndengan alasan apa pun yang bisa dipakai.
Dialogue: 0,0:02:19.59,0:02:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita lebih jarang dicurigai.
Dialogue: 0,0:02:23.26,0:02:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan saat dia tak berguna, kau bunuh\Ndan ubah dia menjadi poin.
Dialogue: 0,0:02:28.39,0:02:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bicarakan?
Dialogue: 0,0:02:29.89,0:02:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:02:32.77,0:02:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Reggie adalah kesatria sejatiku.
Dialogue: 0,0:02:36.03,0:02:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama aku melayaninya,\Ndia akan melindungiku!
Dialogue: 0,0:02:39.70,0:02:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhalusinasi.
Dialogue: 0,0:02:41.87,0:02:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dan sekutumu bersama-sama\Nmendapatkan 100 poin, bukan?
Dialogue: 0,0:02:46.91,0:02:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih begitu.
Dialogue: 0,0:02:49.04,0:02:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peraturan baru akan segera ditambahkan.
Dialogue: 0,0:02:51.37,0:02:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peraturan ini akan memungkinkan\Ntransfer poin antarpemain.
Dialogue: 0,0:02:55.80,0:02:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan
Dialogue: 0,0:02:57.96,0:02:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua poinmu.
Dialogue: 0,0:02:59.34,0:03:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negosiasi sudah gagal…
Dialogue: 0,0:03:07.18,0:03:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:10.94,0:03:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:03:12.10,0:03:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nue!
Dialogue: 0,0:03:17.73,0:03:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pernah menunjukkan\Nwajah itu lagi padaku.
Dialogue: 0,0:03:25.53,0:03:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:03:28.29,0:03:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau lembek.\NTernyata kau memang tak bisa membunuh dia.
Dialogue: 0,0:03:31.71,0:03:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menginginkan poin kami, bukan?
Dialogue: 0,0:03:34.83,0:03:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:03:36.79,0:03:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kau belum siap membunuh,
Dialogue: 0,0:03:39.42,0:03:42.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan menyesalinya setelah kau mati.
Dialogue: 0,0:04:06.62,0:04:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:04:07.74,0:04:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku masih di sini.
Dialogue: 0,0:04:10.54,0:04:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia sudah mati?
Dialogue: 0,0:04:20.26,0:04:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin?
Dialogue: 0,0:04:24.63,0:04:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bau itu!{\i0}
Dialogue: 0,0:04:40.19,0:04:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sudah selesai?
Dialogue: 0,0:04:42.69,0:04:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum. Seperti kau,
Dialogue: 0,0:04:45.24,0:04:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia masuk ke ruangan\Ntepat sebelum ledakan.
Dialogue: 0,0:04:49.53,0:04:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat.
Dialogue: 0,0:04:51.49,0:04:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku yakin kita sudah\Nmemangkas lumayan banyak.
Dialogue: 0,0:05:01.84,0:05:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kau mengerti, bukan?
Dialogue: 0,0:05:04.22,0:05:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak berniat melindungimu.
Dialogue: 0,0:05:09.68,0:05:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau mengerti, enyah sana!
Dialogue: 0,0:05:20.23,0:05:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:05:22.98,0:05:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, katakan!
Dialogue: 0,0:05:27.28,0:05:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Reggie sudah mengatakannya!
Dialogue: 0,0:05:29.82,0:05:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan kau akan melindungiku!
Dialogue: 0,0:05:31.83,0:05:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan kau menyukaiku!
Dialogue: 0,0:05:33.91,0:05:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan!
Dialogue: 0,0:05:41.42,0:05:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang-orang sepertimu.
Dialogue: 0,0:05:43.88,0:05:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah yang menganggap kata-kata
Dialogue: 0,0:05:46.84,0:05:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih penting daripada tindakan.
Dialogue: 0,0:05:49.89,0:05:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, terima kasih untuk tadi.
Dialogue: 0,0:05:53.14,0:05:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kau kelihatan kacau.
Dialogue: 0,0:05:55.64,0:05:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Naik kembali ke sini itu tidak mudah.
Dialogue: 0,0:05:58.02,0:06:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Gunakan tangga, Manusia Gua.
Dialogue: 0,0:06:00.56,0:06:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ring-ring!
Dialogue: 0,0:06:03.90,0:06:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah peraturan telah ditambahkan
Dialogue: 0,0:06:07.03,0:06:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada {\i1}Culling Game{\i0} oleh seorang pemain.
Dialogue: 0,0:06:09.66,0:06:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aturan sepuluh.{\i0}
Dialogue: 0,0:06:10.82,0:06:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Seorang pemain dapat mentransfer{\i0}
Dialogue: 0,0:06:13.74,0:06:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejumlah poin ke pemain lain.
Dialogue: 0,0:06:16.37,0:06:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peaturan apa ini?
Dialogue: 0,0:06:51.91,0:06:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gajah Maksimal!
Dialogue: 0,0:06:56.29,0:06:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi?
Dialogue: 0,0:07:11.30,0:07:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan kau!
Dialogue: 0,0:07:20.27,0:07:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa yang aku… lakukan?{\i0}
Dialogue: 0,0:07:24.02,0:07:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami masih membutuhkan poin setelah ini.{\i0}
Dialogue: 0,0:07:26.44,0:07:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, Tsumiki tidak akan dipaksa\Nmembunuh siapa pun lagi.{\i0}
Dialogue: 0,0:07:30.70,0:07:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan terburu-buru.\NPercaya pada semua orang.{\i0}
Dialogue: 0,0:07:33.53,0:07:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan terobsesi dengan poin mereka.{\i0}
Dialogue: 0,0:07:36.45,0:07:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku hanya perlu memberikan segalanya{\i0}
Dialogue: 0,0:07:38.70,0:07:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}dan menyingkirkan rintangan\Nyang mengadang.{\i0}
Dialogue: 0,0:07:41.75,0:07:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima poin telah ditambahkan.
Dialogue: 0,0:07:45.75,0:07:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh sia-sia poin-poin itu.
Dialogue: 0,0:07:48.13,0:07:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbunuh sebelum sempat menggunakan\NTeknik Kutukan itu menyedihkan.
Dialogue: 0,0:07:53.84,0:07:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Remi mundur?{\i0}
Dialogue: 0,0:07:55.72,0:07:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meskipun iya, itu dua lawan satu.{\i0}
Dialogue: 0,0:07:57.85,0:08:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sialan. Ledakan pertama itu\Nmembuatku babak belur.{\i0}
Dialogue: 0,0:08:01.06,0:08:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Melarikan diri bukan pilihan.{\i0}
Dialogue: 0,0:08:04.35,0:08:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Haruskah aku menggunakan… domainku?{\i0}
Dialogue: 0,0:08:07.69,0:08:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Namun, domainku belum lengkap.{\i0}
Dialogue: 0,0:08:10.15,0:08:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tidak bisa menutup rapat penghalangnya\Ndan menjebak mereka di dalam.{\i0}
Dialogue: 0,0:08:14.20,0:08:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika mereka lolos dan aku gagal,{\i0}
Dialogue: 0,0:08:15.53,0:08:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}pertandingan ulang\Nadalah skenario terburuk.{\i0}
Dialogue: 0,0:08:22.37,0:08:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir…
Dialogue: 0,0:08:23.71,0:08:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saja!
Dialogue: 0,0:08:33.80,0:08:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua lawan satu…
Dialogue: 0,0:08:36.59,0:08:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar berpikir
Dialogue: 0,0:08:40.47,0:08:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu pembagian yang adil?
Dialogue: 0,0:08:43.27,0:08:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu apa sebutan\Nuntuk orang sepertimu?
Dialogue: 0,0:08:47.48,0:08:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Pengecut.
Dialogue: 0,0:08:50.32,0:08:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan pengecut tidak akan berhasil!
Dialogue: 0,0:08:53.32,0:08:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:08:56.45,0:08:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerusakan nol!
Dialogue: 0,0:09:48.21,0:09:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Nak, aku akan mendukungmu.
Dialogue: 0,0:09:50.38,0:09:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usiaku 35 tahun.
Dialogue: 0,0:09:52.42,0:09:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dengan melihat wajah seseorang,\Naku bisa tahu apakah mereka jahat.
Dialogue: 0,0:09:58.76,0:10:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:00.01,0:10:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu juga terlihat cukup mengerikan!
Dialogue: 0,0:10:03.43,0:10:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:04.77,0:10:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah.
Dialogue: 0,0:10:06.10,0:10:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini penilaian relatif. {\i1}Yutori.{\i0}
Dialogue: 0,0:10:08.56,0:10:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah {\i1}Yutori{\i0} itu\Ntentang penilaian absolut?
Dialogue: 0,0:10:11.02,0:10:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia melindungiku.{\i0}
Dialogue: 0,0:10:12.86,0:10:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Untuk saat ini,\Naku bisa memercayai dia, bukan?{\i0}
Dialogue: 0,0:10:16.24,0:10:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Hazenoki?
Dialogue: 0,0:10:18.49,0:10:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum pernah melihat dia.\NLebih cepat bertanya saja.
Dialogue: 0,0:10:21.70,0:10:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:10:23.20,0:10:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berada di pihak mana?
Dialogue: 0,0:10:30.71,0:10:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:10:32.00,0:10:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau bertanya…
Dialogue: 0,0:10:34.67,0:10:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah aku lucu…
Dialogue: 0,0:10:36.05,0:10:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tidak, ya?
Dialogue: 0,0:10:40.97,0:10:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Dari era apa kau berasal…
Dialogue: 0,0:10:43.30,0:10:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kostum ini terinspirasi seorang pahlawan
Dialogue: 0,0:10:46.43,0:10:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengajariku arti sebenarnya\Ndari "tertawa terbahak-bahak"!
Dialogue: 0,0:10:51.19,0:10:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tidak bisa mengacaukan lelucon
Dialogue: 0,0:10:52.81,0:10:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat memakai kostum ini!
Dialogue: 0,0:10:55.44,0:10:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lelucon yang baru saja aku buat.
Dialogue: 0,0:10:58.44,0:11:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunakan itu di depan gadis yang kau suka.
Dialogue: 0,0:11:04.41,0:11:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu datang.
Dialogue: 0,0:11:13.33,0:11:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urus Wi-Fi-mu sendiri!
Dialogue: 0,0:11:25.43,0:11:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Penonton yang menyebalkan!
Dialogue: 0,0:11:27.81,0:11:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang, ada yang seperti kau!
Dialogue: 0,0:11:29.60,0:11:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lupa cara tersenyum,
Dialogue: 0,0:11:32.69,0:11:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal duduk di baris depan\Ndi sebuah pertunjukan!
Dialogue: 0,0:11:35.86,0:11:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu masalahmu.{\i0}
Dialogue: 0,0:11:38.07,0:11:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku…
Dialogue: 0,0:11:39.07,0:11:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia mengingatkan aku padanya.{\i0}
Dialogue: 0,0:11:40.49,0:11:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun begitu,\Naku tidak akan meninggalkanmu.
Dialogue: 0,0:11:43.66,0:11:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku…
Dialogue: 0,0:11:47.45,0:11:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang komedian…
Dialogue: 0,0:11:55.46,0:11:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia cepat.\NEnergi Kutukannya melonjak cepat.{\i0}
Dialogue: 0,0:11:58.50,0:12:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keluarannya berayun liar.{\i0}
Dialogue: 0,0:12:00.59,0:12:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Pria ini… Dia kuat…{\i0}\N- Hati-hati.
Dialogue: 0,0:12:04.34,0:12:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku komedian jadul
Dialogue: 0,0:12:06.85,0:12:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang pro-kekerasan.
Dialogue: 0,0:12:10.35,0:12:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang akan kau lakukan, Nak?
Dialogue: 0,0:12:17.77,0:12:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Aku akan memisahkan mereka.\N- Ya.
Dialogue: 0,0:12:20.19,0:12:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Teknik Kutukan Hazenoki mungkin mengubah\Nbagian tubuhnya menjadi bom.
Dialogue: 0,0:12:24.45,0:12:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Juga, pakai Teknik Kutukan Pembalik…\N- Ya.
Dialogue: 0,0:12:27.28,0:12:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}- Terlalu dekat!\N- Ya.
Dialogue: 0,0:12:28.78,0:12:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kogane!\N- Ya.
Dialogue: 0,0:12:31.45,0:12:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat info Hiromi Higuruma!
Dialogue: 0,0:12:34.42,0:12:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itadori yang menambahkan peraturan itu.{\i0}
Dialogue: 0,0:12:38.54,0:12:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah selesai dengan koloni ini.
Dialogue: 0,0:12:42.17,0:12:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau mundur,\Naku akan membiarkanmu pergi.
Dialogue: 0,0:12:44.93,0:12:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:46.47,0:12:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau sehingga berani mengatakan itu?
Dialogue: 0,0:12:48.39,0:12:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengumpulkan poin dari Hari,\Nyang kau bunuh.
Dialogue: 0,0:12:52.31,0:12:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau.\N- Aku Takaba!
Dialogue: 0,0:12:55.98,0:12:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau akan membunuh pria bom itu,
Dialogue: 0,0:12:59.02,0:12:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lakukanlah, kalau kau bisa.
Dialogue: 0,0:13:00.48,0:13:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, pertama-tama, ambil poinnya.
Dialogue: 0,0:13:04.53,0:13:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Nak.
Dialogue: 0,0:13:06.32,0:13:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengar permintaanmu dengan jelas.
Dialogue: 0,0:13:13.95,0:13:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku seorang komedian.
Dialogue: 0,0:13:16.71,0:13:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan melakukan sesuatu\Nyang mencuri senyum seseorang selamanya.
Dialogue: 0,0:13:20.13,0:13:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan apa saja, asal kau menang.
Dialogue: 0,0:13:30.72,0:13:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Menyala!{\i0}
Dialogue: 0,0:13:37.10,0:13:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Teknik Kutukan yang berbahaya!
Dialogue: 0,0:13:40.23,0:13:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas ledakan!
Dialogue: 0,0:13:41.94,0:13:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan tetapi!
Dialogue: 0,0:13:43.94,0:13:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di acara hiburan TV…
Dialogue: 0,0:13:50.37,0:13:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghilang!
Dialogue: 0,0:13:53.91,0:13:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merah itu terlarang, Bung.
Dialogue: 0,0:14:01.00,0:14:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan macam-macam denganku!
Dialogue: 0,0:14:08.59,0:14:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Takaba bukan musuh.
Dialogue: 0,0:14:11.51,0:14:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kalimat yang selalu ingin kudengar!
Dialogue: 0,0:14:16.14,0:14:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Nak! Jangan mati!
Dialogue: 0,0:14:21.36,0:14:23.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mati, bukan?
Dialogue: 0,0:14:23.44,0:14:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dipermalukan seperti itu\Nakan membuat Hazenoki mulai serius.
Dialogue: 0,0:14:26.94,0:14:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khawatirkan dirimu sendiri.\NSudah kubilang, bukan?
Dialogue: 0,0:14:30.41,0:14:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mencapai tujuanku di koloni ini.
Dialogue: 0,0:14:33.58,0:14:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku bisa bertarung sungguhan.\NTidak perlu menahan diri.
Dialogue: 0,0:15:17.91,0:15:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gajah Maksimal!
Dialogue: 0,0:15:25.17,0:15:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau juga punya itu?
Dialogue: 0,0:16:52.76,0:16:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah mengetahui Teknik Kutukanku.
Dialogue: 0,0:16:56.14,0:16:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, menenggelamkan aku itu\Nterlalu kentara, bukan?
Dialogue: 0,0:17:04.85,0:17:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mewujudkan apa yang ada di struk…
Dialogue: 0,0:17:07.40,0:17:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, bukan itu, tapi…
Dialogue: 0,0:17:09.86,0:17:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:11.32,0:17:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk diungkapkan dengan kata-kata,
Dialogue: 0,0:17:13.32,0:17:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi lebih tepatnya\N"menciptakan ulang kontrak".
Dialogue: 0,0:17:16.24,0:17:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, aku juga bisa melakukan ini.
Dialogue: 0,0:17:18.99,0:17:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penciptaan Ulang Kontraktual!
Dialogue: 0,0:17:26.00,0:17:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang baru saja kugunakan
Dialogue: 0,0:17:27.75,0:17:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}adalah struk penginapan bintang lima,\NHoshizora Tei.{\i0}
Dialogue: 0,0:17:30.25,0:17:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dua malam, tiga hari,{\i0}
Dialogue: 0,0:17:33.51,0:17:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}termasuk perawatan minyak.{\i0}
Dialogue: 0,0:17:35.38,0:17:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kini aku akan berendam perlahan\Ndi mata air panas, mengendurkan otot,
Dialogue: 0,0:17:40.43,0:17:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu tidur nyenyak dan istirahat\Nselama dua hari penuh.
Dialogue: 0,0:17:45.43,0:17:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding kau, bagaimana denganmu?
Dialogue: 0,0:17:47.98,0:17:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terluka dalam pertarungan terakhir,
Dialogue: 0,0:17:50.19,0:17:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan beberapa {\i1}shikigami,{\i0}\Ndan kau kelelahan, bukan?
Dialogue: 0,0:17:55.11,0:17:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku menggunakan beberapa{\i0} shikigami\N{\i1}sekaligus, sepanjang waktu.{\i0}
Dialogue: 0,0:17:57.45,0:17:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Masalahnya adalah Gajah Maksimal{\i0}
Dialogue: 0,0:17:59.24,0:18:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tercampur di sana,\Npadahal seharusnya digunakan sendirian.{\i0}
Dialogue: 0,0:18:03.91,0:18:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memanggil dan menyingkirkan\N{\i1}shikigami{\i0} dengan cepat,
Dialogue: 0,0:18:07.71,0:18:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi begitu salah satu rusak,\Ntidak bisa semudah itu, bukan?
Dialogue: 0,0:18:11.71,0:18:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bisa mengeluarkan anjing yang\Nbisa berlari, menyerang, dan bertahan.
Dialogue: 0,0:18:15.26,0:18:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau hanya bisa
Dialogue: 0,0:18:16.22,0:18:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggabungkan {\i1}shikigami{\i0} trik tunggal.
Dialogue: 0,0:18:20.43,0:18:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak satu pun dari kita punya jurus hebat\Nuntuk menyelesaikan pertarungan ini.
Dialogue: 0,0:18:25.02,0:18:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tamat.
Dialogue: 0,0:18:26.48,0:18:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin kau bisa membunuhku.
Dialogue: 0,0:18:30.81,0:18:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar. Jadi, aku akan lari.
Dialogue: 0,0:18:34.02,0:18:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:43.95,0:18:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak akan terjadi.
Dialogue: 0,0:18:57.55,0:18:59.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimnasium, ya?
Dialogue: 0,0:18:59.88,0:19:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya berlari,\Natau kau mencoba memancingku?
Dialogue: 0,0:19:03.05,0:19:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memaksamu keluar dengan api,
Dialogue: 0,0:19:05.01,0:19:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bermain kejar-kejaran lagi\Nterdengar merepotkan.
Dialogue: 0,0:19:08.60,0:19:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa yang akan kulakukan?
Dialogue: 0,0:19:12.48,0:19:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baiklah. Persis yang kubayangkan.{\i0}
Dialogue: 0,0:19:15.36,0:19:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ukurannya sempurna.{\i0}
Dialogue: 0,0:19:18.49,0:19:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rencanakan, Bocah Nakal?
Dialogue: 0,0:19:23.91,0:19:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang merencanakan sesuatu, bukan?
Dialogue: 0,0:19:31.92,0:19:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Jujutsu hidup dan mati\Ndengan berbohong.
Dialogue: 0,0:20:30.72,0:20:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kuciptakan kembali\Npada dasarnya seperti {\i1}shikigami.{\i0}
Dialogue: 0,0:20:34.52,0:20:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku bisa memberinya\Nperintah sederhana.
Dialogue: 0,0:20:37.69,0:20:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau dapur biasanya\Ntidak terbang sendiri, bukan?
Dialogue: 0,0:20:41.49,0:20:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin tidak ada gunanya bagimu,
Dialogue: 0,0:20:44.32,0:20:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku akan tetap bertanya.
Dialogue: 0,0:20:45.66,0:20:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau menyerahkan poinmu,\Naku akan melakukannya dengan cepat.
Dialogue: 0,0:20:50.08,0:20:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik penghalang itu sulit, bukan?
Dialogue: 0,0:20:54.54,0:20:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama apa pun aku mencoba,
Dialogue: 0,0:20:56.25,0:20:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa merasakan cara melapiskan
Dialogue: 0,0:20:59.25,0:21:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ruang semu yang diperkecil\Ndi atas ruang nyata.
Dialogue: 0,0:21:01.71,0:21:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi…
Dialogue: 0,0:21:03.72,0:21:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jangan-jangan…{\i0}
Dialogue: 0,0:21:06.68,0:21:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengubah\Nfungsi ruang gimnasium ini
Dialogue: 0,0:21:10.01,0:21:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai domainku.
Dialogue: 0,0:21:13.23,0:21:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa melakukan itu?
Dialogue: 0,0:21:34.75,0:21:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspansi Domain.
Dialogue: 0,0:21:36.92,0:21:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taman Bayangan Khimaira.
Dialogue: 0,0:21:45.59,0:21:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah jadi penyihir tingkat lanjut\Nsemacam itu, ya…
Dialogue: 0,0:21:49.68,0:21:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah bilang aku tak punya
Dialogue: 0,0:21:51.47,0:21:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jurus pemungkas yang hebat.
Dialogue: 0,0:23:27.28,0:23:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Meski belum lengkap,\Ndomain tetaplah domain.{\i0}
Dialogue: 0,0:23:30.15,0:23:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Keluarkan "kartu truf"-mu{\i0}
Dialogue: 0,0:23:31.74,0:23:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- dan aktifkan!\N- Belum.{\i0}
Dialogue: 0,0:23:33.49,0:23:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Bertahanlah.\N- Akan kuberikan padamu.{\i0}
Dialogue: 0,0:23:35.24,0:23:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kita lihat siapa yang hancur lebih dulu!{\i0}
Dialogue: 0,0:23:36.95,0:23:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hancurlah!{\i0}
Dialogue: 0,0:23:40.96,0:23:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjemahan subtitle oleh Hendra Hong
