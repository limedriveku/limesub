Dialogue: 0,0:00:19.35,0:00:21.81,tanda,,0000,0000,0000,,"RUANG KONSELING NATSUKI ISHIBASHI"
Dialogue: 0,0:00:31.74,0:00:33.82,tanda,,0000,0000,0000,,"MURID SMA YANG TINGGAL DI TOKYO"
