Dialogue: 0,0:10:21.91,0:10:22.91,tanda,,0000,0000,0000,,"MOTOR MORVLA"
Dialogue: 0,0:11:57.00,0:11:59.09,tanda,,0000,0000,0000,,"PANIK"
Dialogue: 0,0:13:48.41,0:13:50.28,tanda,,0000,0000,0000,,"PROPOSAL FESTIVAL BUDAYA - KEDAI MAKANAN"
