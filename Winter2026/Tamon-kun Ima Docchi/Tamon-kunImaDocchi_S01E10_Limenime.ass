Dialogue: 0,0:02:59.55,0:03:00.88,tanda,,0000,0000,0000,,"SMA TACHIBANA METROPOLITAN TOKYO"
Dialogue: 0,0:03:05.26,0:03:06.68,tanda,,0000,0000,0000,,"EPISODE 10: TIPE MUSIM SEMI HANGAT"
Dialogue: 0,0:04:07.83,0:04:10.08,tanda,,0000,0000,0000,,"BIAS SAMA ATAU TIDAK?"
Dialogue: 0,0:04:11.87,0:04:13.08,tanda,,0000,0000,0000,,"PENGGEMAR TAMON - MERAH"
Dialogue: 0,0:04:14.63,0:04:15.92,tanda,,0000,0000,0000,,"PENGGEMAR NATSUKI - KUNING"
Dialogue: 0,0:04:37.31,0:04:39.48,tanda,,0000,0000,0000,,"SYUTING ACARA KULINER"
Dialogue: 0,0:04:53.41,0:04:54.87,tanda,,0000,0000,0000,,"APOTEK"
Dialogue: 0,0:05:01.38,0:05:02.42,tanda,,0000,0000,0000,,"LIP GLOSS PRODUKSI NATSUKI"
