Dialogue: 0,0:01:08.11,0:01:10.73,tanda,,0000,0000,0000,,TAMON'S B-SIDE
Dialogue: 0,0:01:31.88,0:01:35.34,tanda,,0000,0000,0000,,EPISODE 11: APA AKU PANTAS\NBERADA DI SINI?
Dialogue: 0,0:01:47.14,0:01:49.40,tanda,,0000,0000,0000,,"SAMPAH BESAR"
Dialogue: 0,0:02:11.67,0:02:12.63,tanda,,0000,0000,0000,,DEGUP
Dialogue: 0,0:02:23.56,0:02:24.39,tanda,,0000,0000,0000,,DEGUP
Dialogue: 0,0:04:43.53,0:04:44.92,tanda,,0000,0000,0000,,"TUNGGAKAN"
Dialogue: 0,0:07:34.87,0:07:35.70,tanda,,0000,0000,0000,,DONBEI
Dialogue: 0,0:08:41.27,0:08:42.15,tanda,,0000,0000,0000,,KEJUARAAN JUDO SMA PREFEKTUR OSAKA
Dialogue: 0,0:09:02.96,0:09:04.34,tanda,,0000,0000,0000,,"TAKOYAKI KODAMA"
Dialogue: 0,0:09:31.61,0:09:33.24,tanda,,0000,0000,0000,,KEJUARAAN JUDO SMA KANSAI
Dialogue: 0,0:10:07.19,0:10:09.41,tanda,,0000,0000,0000,,SETELAH EVALUASI MENDALAM,\NSAYANGNYA KAU TIDAK LOLOS SELEKSI
Dialogue: 0,0:11:06.04,0:11:06.92,tanda,,0000,0000,0000,,TERIMA KASIH ATAS PARTISIPASINYA
Dialogue: 0,0:11:06.95,0:11:08.63,tanda,,0000,0000,0000,,SETELAH EVALUASI KETAT,\NSELAMAT KARENA MAJU KE BABAK FINAL
Dialogue: 0,0:12:07.51,0:12:09.93,tanda,,0000,0000,0000,,"TAMON'S B-SIDE"
Dialogue: 0,0:13:42.57,0:13:43.54,tanda,,0000,0000,0000,,"NATSUKI, BERI AKU KECUPAN JAUH"
Dialogue: 0,0:14:56.18,0:14:58.10,tanda,,0000,0000,0000,,STASIUN KICHIJOJI
Dialogue: 0,0:14:58.19,0:15:00.77,tanda,,0000,0000,0000,,KAMERA PENGAWAS\NWASPADAI ORANG MENCURIGAKAN
Dialogue: 0,0:15:00.85,0:15:01.77,tanda,,0000,0000,0000,,MIDORIYAMA DARI SUITS
Dialogue: 0,0:15:27.13,0:15:27.97,tanda,,0000,0000,0000,,DEGUP
Dialogue: 0,0:15:42.06,0:15:42.90,tanda,,0000,0000,0000,,MENETESKAN AIR MATA
Dialogue: 0,0:15:44.94,0:15:46.73,tanda,,0000,0000,0000,,PENGILAP BIBIR BUATAN NATSUKI ISHIBASHI
Dialogue: 0,0:19:44.49,0:19:45.23,tanda,,0000,0000,0000,,UGH
Dialogue: 0,0:20:11.62,0:20:13.46,tanda,,0000,0000,0000,,E/YES DEWASA\NKLUB PENDUKUNG NATSUKI ISHIBASHI
Dialogue: 0,0:20:21.22,0:20:22.63,tanda,,0000,0000,0000,,TAMON, LEPASKAN
Dialogue: 0,0:20:46.41,0:20:47.30,tanda,,0000,0000,0000,,UNGGAHAN BARU DARI ASSU_0000
Dialogue: 0,0:20:52.25,0:20:55.00,tanda,,0000,0000,0000,,AKU MENGAWASIMU, KENDALIKAN DIRIMU
Dialogue: 0,0:21:45.63,0:21:48.55,tanda,,0000,0000,0000,,"F/ACE SCHOOL",
Dialogue: 0,0:21:48.64,0:21:51.03,tanda,,0000,0000,0000,,"SMA TACHIBANA METROPOLITAN TOKYO"
Dialogue: 0,0:01:35.42,0:01:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya, saat aku bekerja\Ndi rumah Tamon…
Dialogue: 0,0:01:37.72,0:01:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendengarnya lagi.
Dialogue: 0,0:01:39.51,0:01:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menuruti permintaan Tamon.
Dialogue: 0,0:01:42.14,0:01:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibatnya…
Dialogue: 0,0:01:43.35,0:01:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti berpikir\Naku menjijikkan, bukan?
Dialogue: 0,0:01:46.23,0:01:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:01:47.14,0:01:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya jadi seperti ini.
Dialogue: 0,0:01:49.48,0:01:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fukuhara.
Dialogue: 0,0:01:51.73,0:01:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini selalu saja\Nkehilangan rasa percaya diri!
Dialogue: 0,0:01:57.82,0:02:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu masih bersikap seperti biasa,
Dialogue: 0,0:02:01.33,0:02:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah kenapa membuatku\Ningin menyerah saja.
Dialogue: 0,0:02:02.95,0:02:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:02:04.08,0:02:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan goyah oleh perkataan\Ndan tindakan penggemar biasa.
Dialogue: 0,0:02:07.71,0:02:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kau cuma penggemar.
Dialogue: 0,0:02:10.25,0:02:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang itu penting.
Dialogue: 0,0:02:13.17,0:02:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:02:14.46,0:02:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat lengah,
Dialogue: 0,0:02:15.38,0:02:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku hanya memikirkan diriku sendiri lagi.
Dialogue: 0,0:02:17.13,0:02:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:02:18.72,0:02:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinoshita, bagaimana kabarmu hari ini?
Dialogue: 0,0:02:20.93,0:02:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:02:22.43,0:02:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:02:25.31,0:02:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah, hatiku.
Dialogue: 0,0:02:28.85,0:02:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinoshita, semua ucapanmu benar.
Dialogue: 0,0:02:32.81,0:02:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau menjaga jarak\Ndemi kebaikanku.
Dialogue: 0,0:02:36.69,0:02:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja…
Dialogue: 0,0:02:39.36,0:02:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarak!
Dialogue: 0,0:02:43.12,0:02:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa agak kesepian.
Dialogue: 0,0:02:46.58,0:02:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena, Kinoshita,
Dialogue: 0,0:02:48.16,0:02:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kaulah orang terdekatku sekarang.
Dialogue: 0,0:02:53.42,0:02:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun yang terjadi, aku ini penggemarmu.
Dialogue: 0,0:02:56.92,0:02:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Impian Tamon adalah yang terpenting.
Dialogue: 0,0:03:00.84,0:03:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun dia merasa kesepian,
Dialogue: 0,0:03:02.97,0:03:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa bilang,\N"Baik, aku mengerti,"
Dialogue: 0,0:03:04.93,0:03:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan langsung mengubah\Nperasaanku kepadanya.
Dialogue: 0,0:03:09.02,0:03:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat merepotkan.
Dialogue: 0,0:03:11.14,0:03:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri aku waktu.
Dialogue: 0,0:03:14.23,0:03:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menjelaskannya, ya?
Dialogue: 0,0:03:15.94,0:03:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga agak bingung sekarang.
Dialogue: 0,0:03:18.40,0:03:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir tak tahu apa yang kupikirkan.
Dialogue: 0,0:03:22.03,0:03:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggan asal bicara\Nsebelum menata pikiranku.
Dialogue: 0,0:03:29.58,0:03:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak sanggup lagi.
Dialogue: 0,0:03:31.71,0:03:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu aku memuja Tamon seperti dewa.
Dialogue: 0,0:03:34.92,0:03:39.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kini aku sadar bahwa akulah orang\Nyang paling dekat dengan Tamon.
Dialogue: 0,0:03:40.55,0:03:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya kedua sisi diriku\Nseperti sedang tarik-menarik.
Dialogue: 0,0:03:46.31,0:03:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:03:51.44,0:03:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu merasa kurang mengenalmu.
Dialogue: 0,0:03:56.36,0:03:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya aku ingin lebih mengenalmu.
Dialogue: 0,0:03:59.57,0:04:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi akhirnya aku memaksamu lagi.
Dialogue: 0,0:04:02.86,0:04:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali\Ntidak memikirkan perasaanmu.
Dialogue: 0,0:04:05.53,0:04:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:07.62,0:04:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunggu.
Dialogue: 0,0:04:08.74,0:04:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena jika kau tidak menyukaiku,
Dialogue: 0,0:04:10.54,0:04:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan sangat sedih.
Dialogue: 0,0:04:16.38,0:04:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian berdua berpacaran?
Dialogue: 0,0:04:19.55,0:04:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, sejak kapan kau di sini?
Dialogue: 0,0:04:22.63,0:04:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak bagian, "Kau ini selalu saja\Nkehilangan rasa percaya diri!"
Dialogue: 0,0:04:25.34,0:04:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berarti dia dengar hampir semuanya!\N- Begitu rupanya.
Dialogue: 0,0:04:27.97,0:04:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangka kau lumayan hebat.
Dialogue: 0,0:04:29.77,0:04:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah lama bersama?
Dialogue: 0,0:04:30.77,0:04:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar tiga bulan.
Dialogue: 0,0:04:32.23,0:04:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:04:33.14,0:04:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia membahas saat aku bekerja di sini\Nsebagai pembantu!
Dialogue: 0,0:04:34.98,0:04:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan memberi tahu siapa pun.
Dialogue: 0,0:04:36.36,0:04:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang bukan begitu!
Dialogue: 0,0:04:38.65,0:04:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau kemari hari ini?
Dialogue: 0,0:04:40.94,0:04:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrikku diputus,\Njadi, aku harus menumpang di kamarmu.
Dialogue: 0,0:04:43.53,0:04:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Dia tidak membayar tagihannya?
Dialogue: 0,0:04:44.95,0:04:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agensi memang membayar biaya sewa,
Dialogue: 0,0:04:46.87,0:04:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi harus membayar tagihan listrik\Ndan air sendiri itu agak…
Dialogue: 0,0:04:49.79,0:04:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:04:54.96,0:04:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bekerja?
Dialogue: 0,0:04:57.25,0:05:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nkau pasti melihat hal aneh tadi.
Dialogue: 0,0:05:00.21,0:05:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja.
Dialogue: 0,0:05:01.84,0:05:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:02.84,0:05:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal aneh?
Dialogue: 0,0:05:04.34,0:05:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ishibashi dianggap orang mencurigakan\Ndi dekat sekolah kami.
Dialogue: 0,0:05:08.10,0:05:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bagaimana bisa?
Dialogue: 0,0:05:10.18,0:05:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada keributan,\Njadi jangan khawatir.
Dialogue: 0,0:05:14.27,0:05:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu\NBu Asuka itu mantan pacar Natsuki.
Dialogue: 0,0:05:17.73,0:05:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi reaksinya sangat aneh.
Dialogue: 0,0:05:33.62,0:05:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencatatnya.
Dialogue: 0,0:05:35.12,0:05:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen langka melihatnya sedang\Nmenggubah musik.
Dialogue: 0,0:05:37.62,0:05:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga kali pertama aku melihatnya.
Dialogue: 0,0:05:40.34,0:05:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia keren sekali.
Dialogue: 0,0:05:44.88,0:05:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunlah.
Dialogue: 0,0:05:46.63,0:05:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau, aku terlalu malas.\NSangat merepotkan.
Dialogue: 0,0:05:49.47,0:05:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bagaimana dengan lagunya?
Dialogue: 0,0:05:51.14,0:05:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Bisa kuselesaikan nanti.
Dialogue: 0,0:05:53.81,0:05:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun sekarang!
Dialogue: 0,0:05:56.10,0:05:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini dan Tuan Suram memiliki\Naura suram yang berbeda.
Dialogue: 0,0:05:58.90,0:06:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bagaimana jika kau\Nyang menuliskannya untukku?
Dialogue: 0,0:06:01.44,0:06:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa menulisnya jika beralih\Nke mode bersinar, kan?
Dialogue: 0,0:06:03.57,0:06:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak bisa merobek tisu toilet\Nsesuai garis putus-putusnya.
Dialogue: 0,0:06:06.40,0:06:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa aku melakukan pekerjaan\Nsedetail menggubah musik?
Dialogue: 0,0:06:09.53,0:06:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau tertarik?
Dialogue: 0,0:06:11.37,0:06:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang begitu.
Dialogue: 0,0:06:13.16,0:06:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku suka musik.
Dialogue: 0,0:06:14.75,0:06:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggubah musik itu sangat menyenangkan.
Dialogue: 0,0:06:17.50,0:06:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak meyakinkan.
Dialogue: 0,0:06:19.54,0:06:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa kau kabur lagi?
Dialogue: 0,0:06:23.00,0:06:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu kau sedang termotivasi.
Dialogue: 0,0:06:25.67,0:06:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bilangnya, ya?
Dialogue: 0,0:06:27.01,0:06:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya penasaran,
Dialogue: 0,0:06:29.34,0:06:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa orang sepertiku\Nyang telah menghancurkan hidup seseorang,
Dialogue: 0,0:06:32.64,0:06:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhak menulis lagu penyemangat.
Dialogue: 0,0:06:37.98,0:06:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:06:39.14,0:06:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sungguh telah menghancurkan
Dialogue: 0,0:06:42.94,0:06:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hidup mantan pacarku, Asuka.
Dialogue: 0,0:06:53.33,0:06:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah.
Dialogue: 0,0:06:54.99,0:06:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini dingin sekali.
Dialogue: 0,0:06:56.54,0:06:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mati kedinginan\Njika tidur di luar begini.
Dialogue: 0,0:06:59.46,0:07:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja. Lagi pula,\Ntidak ada hal yang ingin kulakukan.
Dialogue: 0,0:07:10.18,0:07:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tip untukmu.
Dialogue: 0,0:07:13.72,0:07:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka ayam tumis pedas.
Dialogue: 0,0:07:15.01,0:07:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pilih-pilih.
Dialogue: 0,0:07:20.06,0:07:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau itu terlihat seperti anak SMP.\NSampai kapan kau mau berkeliaran?
Dialogue: 0,0:07:23.90,0:07:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\Norang tuaku tidak akan pulang.
Dialogue: 0,0:07:25.77,0:07:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kau akan tidur di mana?
Dialogue: 0,0:07:28.07,0:07:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di rumah teman atau warnet.
Dialogue: 0,0:07:30.40,0:07:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau di sekitar sini.
Dialogue: 0,0:07:31.41,0:07:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar sini?\NLalu, dari mana kau dapat uang?
Dialogue: 0,0:07:33.95,0:07:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari ini.
Dialogue: 0,0:07:35.78,0:07:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Kalau begitu,\Naku akan menyanyikan satu lagu.
Dialogue: 0,0:07:41.37,0:07:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku sama sekali\Ntidak memedulikanku.
Dialogue: 0,0:07:44.46,0:07:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun tindakanku\Ndan sekeras apa pun usahaku,
Dialogue: 0,0:07:46.46,0:07:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak pernah melihatku.
Dialogue: 0,0:07:49.76,0:07:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu alasannya
Dialogue: 0,0:07:50.97,0:07:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku perlahan kehilangan motivasi.
Dialogue: 0,0:07:53.72,0:07:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu manis sekali.
Dialogue: 0,0:07:55.55,0:07:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar. Dia cantik seperti perempuan.
Dialogue: 0,0:07:56.97,0:07:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia anak SMA, dua tahun di atasku.\N- Aku iri sekali.
Dialogue: 0,0:07:59.35,0:08:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu membawakanku takoyaki\Nsebagai tip.
Dialogue: 0,0:08:02.94,0:08:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tip untukmu.
Dialogue: 0,0:08:04.73,0:08:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau kemari setiap malam?
Dialogue: 0,0:08:06.61,0:08:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyukaiku, ya?
Dialogue: 0,0:08:07.61,0:08:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:08:08.53,0:08:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini gelap,\Nlagi pula kerjamu setengah hati.
Dialogue: 0,0:08:09.90,0:08:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kau ini tergolong tampan atau tidak,
Dialogue: 0,0:08:11.15,0:08:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku suka tipe wajah kalem sepertimu.
Dialogue: 0,0:08:13.07,0:08:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku suka nyanyianmu.
Dialogue: 0,0:08:17.49,0:08:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan kau,
Dialogue: 0,0:08:18.58,0:08:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau selalu mengeluh,\Ntapi menungguku setiap malam, kan?
Dialogue: 0,0:08:23.00,0:08:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menyukaiku?
Dialogue: 0,0:08:24.33,0:08:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:08:25.50,0:08:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau itu berisik dan suka ikut campur.
Dialogue: 0,0:08:27.59,0:08:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kembalikan takoyakiku!
Dialogue: 0,0:08:29.17,0:08:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:08:30.88,0:08:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:08:32.16,0:08:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau memang terlihat keren\Nsaat sedang bekerja keras.
Dialogue: 0,0:08:34.26,0:08:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa sepertimu.
Dialogue: 0,0:08:42.17,0:08:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat bertolak belakang.
Dialogue: 0,0:08:45.40,0:08:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, entah kenapa,\Nkami menjadi sangat dekat.
Dialogue: 0,0:08:50.19,0:08:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau ingin menjadi penyanyi?
Dialogue: 0,0:08:52.32,0:08:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, aku memang suka musik,
Dialogue: 0,0:08:54.49,0:08:57.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku melakukannya\Ncuma untuk mencari uang.
Dialogue: 0,0:08:57.28,0:08:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku menjadi penyanyi.
Dialogue: 0,0:08:59.83,0:09:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya segelintir orang yang bisa sukses.
Dialogue: 0,0:09:02.96,0:09:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan
Dialogue: 0,0:09:04.37,0:09:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah lulus SMP?
Dialogue: 0,0:09:05.67,0:09:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari kerja.
Dialogue: 0,0:09:08.67,0:09:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak bekerja di tempat kami saja?
Dialogue: 0,0:09:10.59,0:09:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah!
Dialogue: 0,0:09:11.67,0:09:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebetulan butuh karyawan baru.
Dialogue: 0,0:09:13.84,0:09:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau mau, silakan saja, Natsuki.
Dialogue: 0,0:09:18.60,0:09:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini?
Dialogue: 0,0:09:19.60,0:09:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:09:21.10,0:09:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hebat sekali.
Dialogue: 0,0:09:24.69,0:09:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menunggu.
Dialogue: 0,0:09:26.52,0:09:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau manis sekali, Nak.
Dialogue: 0,0:09:29.26,0:09:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!\NTolong buatkan sekotak takoyaki keju.
Dialogue: 0,0:09:35.20,0:09:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantingan yang bagus, Asuka!
Dialogue: 0,0:09:38.03,0:09:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa!
Dialogue: 0,0:09:40.24,0:09:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin hanya menganggapku adik,
Dialogue: 0,0:09:44.33,0:09:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tidak.
Dialogue: 0,0:09:47.96,0:09:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kau mau menjadi pacarku.
Dialogue: 0,0:10:09.44,0:10:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana hasilnya?
Dialogue: 0,0:10:10.44,0:10:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih belum berhasil.
Dialogue: 0,0:10:11.98,0:10:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu ada kesempatan lain.
Dialogue: 0,0:10:12.98,0:10:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memperlakukanku seperti anak kecil.
Dialogue: 0,0:10:14.86,0:10:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:10:17.57,0:10:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lolos babak penyisihan Kansai!
Dialogue: 0,0:10:21.28,0:10:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita rayakan!
Dialogue: 0,0:10:30.29,0:10:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yang menulis lagu ini, Natsuki?
Dialogue: 0,0:10:31.96,0:10:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja bukan. Ini cuma lagu kover.
Dialogue: 0,0:10:33.88,0:10:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei... Jika aku menang Turnamen Nasional,
Dialogue: 0,0:10:36.30,0:10:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nyanyikan lagu buatanmu sendiri untukku.
Dialogue: 0,0:10:38.09,0:10:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:39.26,0:10:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau bilang ingin coba menulis lagu?
Dialogue: 0,0:10:41.72,0:10:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kan?
Dialogue: 0,0:10:42.64,0:10:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mau dengar!\N- Aku juga!
Dialogue: 0,0:10:44.64,0:10:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kami mau dengar!
Dialogue: 0,0:10:48.64,0:10:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, boleh saja.
Dialogue: 0,0:10:55.03,0:10:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga harus berusaha\Nmelakukan yang terbaik.
Dialogue: 0,0:10:58.36,0:11:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bersama Asuka,
Dialogue: 0,0:11:00.36,0:11:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}secara alami aku jadi ingin
Dialogue: 0,0:11:02.82,0:11:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melakukan semuanya dengan baik.
Dialogue: 0,0:11:08.66,0:11:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku lolos!\N- Ya!
Dialogue: 0,0:11:10.37,0:11:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau luar biasa, Natsuki!
Dialogue: 0,0:11:14.38,0:11:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya tabunganku cukup.
Dialogue: 0,0:11:16.34,0:11:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seharusnya cukup\Nuntuk beli hadiah ulang tahun Asuka.
Dialogue: 0,0:11:18.63,0:11:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki.
Dialogue: 0,0:11:22.01,0:11:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah.
Dialogue: 0,0:11:24.14,0:11:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kabar?
Dialogue: 0,0:11:26.18,0:11:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Ayah di sini?
Dialogue: 0,0:11:30.31,0:11:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lolos audisi,\Ndan kurasa aku punya peluang.
Dialogue: 0,0:11:32.86,0:11:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekan depan adalah babak final...
Dialogue: 0,0:11:33.77,0:11:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana uangnya?
Dialogue: 0,0:11:34.86,0:11:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bekerja, kan?
Dialogue: 0,0:11:37.11,0:11:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat berikan uangmu padaku.
Dialogue: 0,0:11:40.32,0:11:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar keparat.
Dialogue: 0,0:11:41.66,0:11:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir sedang bicara dengan siapa?
Dialogue: 0,0:11:45.37,0:11:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan. Ini...
Dialogue: 0,0:11:47.83,0:11:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk hadiah Asuka.
Dialogue: 0,0:11:51.25,0:11:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak apa-apa, Natsuki?
Dialogue: 0,0:11:53.33,0:11:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asuka.
Dialogue: 0,0:11:54.92,0:11:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terluka?
Dialogue: 0,0:11:55.92,0:11:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu? Kau terluka?
Dialogue: 0,0:11:56.92,0:11:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berengsek.
Dialogue: 0,0:12:07.51,0:12:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asuka!
Dialogue: 0,0:12:11.06,0:12:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini,
Dialogue: 0,0:12:12.19,0:12:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami akan menyiarkan\NTurnamen Judo Putri SMA Nasional.
Dialogue: 0,0:12:18.73,0:12:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan memasuki babak semifinal.
Dialogue: 0,0:12:21.40,0:12:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam kompetisi ini,
Dialogue: 0,0:12:22.57,0:12:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pendatang baru yang menjanjikan\Nterpaksa mundur akibat cedera.
Dialogue: 0,0:12:24.49,0:12:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asuka.
Dialogue: 0,0:12:27.03,0:12:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, kau di sini.
Dialogue: 0,0:12:28.70,0:12:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?
Dialogue: 0,0:12:29.70,0:12:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kau lihat,\Naku sangat sehat.
Dialogue: 0,0:12:32.71,0:12:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahku.
Dialogue: 0,0:12:34.29,0:12:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan, bagaimana audisinya?
Dialogue: 0,0:12:35.79,0:12:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seleksi akhirnya kemarin, kan?
Dialogue: 0,0:12:37.46,0:12:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak meneleponku,\Njadi aku sangat penasaran.
Dialogue: 0,0:12:38.88,0:12:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pergi.
Dialogue: 0,0:12:42.63,0:12:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana aku bisa pergi\Ndi saat seperti ini?
Dialogue: 0,0:12:45.80,0:12:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:48.01,0:12:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau lakukan? Kau bodoh, ya?
Dialogue: 0,0:12:50.77,0:12:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu? Kau sungguh keterlaluan.
Dialogue: 0,0:12:53.39,0:12:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Asuka...\N- Keluar!
Dialogue: 0,0:12:55.81,0:12:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau melihat wajahmu.
Dialogue: 0,0:12:59.82,0:13:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah insiden itu,
Dialogue: 0,0:13:02.07,0:13:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku kehilangan seluruh motivasiku.
Dialogue: 0,0:13:05.49,0:13:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kerja keras Asuka pun menjadi sia-sia.
Dialogue: 0,0:13:11.83,0:13:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahku.
Dialogue: 0,0:13:16.08,0:13:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku berhenti bekerja
Dialogue: 0,0:13:17.84,0:13:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di kedai takoyaki,\Nlalu kembali mengacau.
Dialogue: 0,0:13:21.17,0:13:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bersenang-senang\Nsaat ini saja sudah cukup.
Dialogue: 0,0:13:24.13,0:13:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup seperti itu terasa lebih bebas.
Dialogue: 0,0:13:27.64,0:13:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, temanku membujukku\Nuntuk ikut audisi pencarian bakat.
Dialogue: 0,0:13:31.89,0:13:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah akhirnya aku bisa debut.
Dialogue: 0,0:13:34.31,0:13:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang bahagia,
Dialogue: 0,0:13:35.73,0:13:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sejujurnya, aku merasa aneh.
Dialogue: 0,0:13:38.69,0:13:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku selalu gelisah.
Dialogue: 0,0:13:40.65,0:13:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa bersalah\Npada para penggemarku.
Dialogue: 0,0:13:42.57,0:13:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki!
Dialogue: 0,0:13:43.57,0:13:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, aku sungguh minta maaf.
Dialogue: 0,0:13:44.99,0:13:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Natsuki, tunjukkan senyum malaikatmu!\N- Tak peduli
Dialogue: 0,0:13:46.78,0:13:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- sudah berapa lama pun,\N- aku tetap mencintaimu!
Dialogue: 0,0:13:47.78,0:13:49.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku terus berpikir,
Dialogue: 0,0:13:49.41,0:13:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku pantas berada di sini?
Dialogue: 0,0:13:57.75,0:13:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku pantas
Dialogue: 0,0:13:59.59,0:14:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berada di sini?
Dialogue: 0,0:14:00.79,0:14:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:14:02.13,0:14:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Listrikmu diputus, jadi apa boleh buat.
Dialogue: 0,0:14:04.38,0:14:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:14:06.05,0:14:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau minum terlalu banyak, Natsuki.
Dialogue: 0,0:14:07.97,0:14:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah air.
Dialogue: 0,0:14:09.47,0:14:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertidur!
Dialogue: 0,0:14:12.14,0:14:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap Natsuki memang biasanya dingin,
Dialogue: 0,0:14:14.73,0:14:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia jadi banyak bicara saat mabuk.
Dialogue: 0,0:14:16.98,0:14:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:14:18.52,0:14:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya Keito.
Dialogue: 0,0:14:19.86,0:14:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku juga sama sekali\Ntidak memahami Natsuki.
Dialogue: 0,0:14:23.44,0:14:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku bahkan tak berniat mencari tahu\Nalasan mereka menjadi idola.
Dialogue: 0,0:14:27.20,0:14:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal, mereka adalah anggota grupku.
Dialogue: 0,0:14:29.57,0:14:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini sangat menyedihkan.
Dialogue: 0,0:14:31.83,0:14:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat malu sampai rasanya ingin mati.
Dialogue: 0,0:14:33.79,0:14:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga jangan ikut-ikutan murung!
Dialogue: 0,0:14:36.41,0:14:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:14:37.71,0:14:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan Natsuki tidak termotivasi
Dialogue: 0,0:14:39.63,0:14:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti ada hubungannya dengan Bu Asuka.
Dialogue: 0,0:14:42.09,0:14:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Ntanyakan langsung saja kepadanya.
Dialogue: 0,0:14:44.25,0:14:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanya kepadanya? Bagaimana caranya?
Dialogue: 0,0:14:46.51,0:14:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asuka...
Dialogue: 0,0:14:47.97,0:14:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, Bu Asuka
Dialogue: 0,0:14:51.60,0:14:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya adalah wali kelasku.
Dialogue: 0,0:15:01.86,0:15:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mantan pacar Natsuki\Nsekaligus wali kelasku,
Dialogue: 0,0:15:05.65,0:15:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Asuka.
Dialogue: 0,0:15:07.19,0:15:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:15:09.66,0:15:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memang sudah datang jauh-jauh kemari,
Dialogue: 0,0:15:12.28,0:15:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi apa tidak apa-apa\Nkita mencampuri urusan orang lain?
Dialogue: 0,0:15:15.45,0:15:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu tidak sopan?
Dialogue: 0,0:15:17.33,0:15:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:15:18.25,0:15:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika kita ditangkap\Natas tuduhan pelecehan?
Dialogue: 0,0:15:19.67,0:15:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:15:21.33,0:15:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku sedang merasa lelah,
Dialogue: 0,0:15:23.38,0:15:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendengarmu bertanya\Napa aku baik-baik saja...
Dialogue: 0,0:15:26.21,0:15:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku merasa sangat bahagia.
Dialogue: 0,0:15:29.01,0:15:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang merasa senang\Nsaat dikhawatirkan orang lain,
Dialogue: 0,0:15:31.55,0:15:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada juga\Nyang menganggapnya menyebalkan.
Dialogue: 0,0:15:33.43,0:15:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau takkan pernah tahu\Nsebelum bertanya langsung.
Dialogue: 0,0:15:36.35,0:15:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinoshita.
Dialogue: 0,0:15:38.43,0:15:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:15:39.35,0:15:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpura-puralah jadi teman SMP-ku\Ndan ikutlah denganku.
Dialogue: 0,0:15:42.98,0:15:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman?
Dialogue: 0,0:15:46.82,0:15:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Asuka!
Dialogue: 0,0:15:49.32,0:15:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali!
Dialogue: 0,0:15:50.99,0:15:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kinoshita.
Dialogue: 0,0:15:56.74,0:15:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang mencurigakan!
Dialogue: 0,0:15:57.66,0:15:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamon!
Dialogue: 0,0:16:08.80,0:16:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tiba-tiba menerkamku.
Dialogue: 0,0:16:17.97,0:16:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembantu?
Dialogue: 0,0:16:19.73,0:16:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangka kau mengenal Tamon.
Dialogue: 0,0:16:22.90,0:16:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Naslinya Tamon tampan sekali, ya.
Dialogue: 0,0:16:25.36,0:16:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu dengan Anda.
Dialogue: 0,0:16:26.36,0:16:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia bicara!
Dialogue: 0,0:16:27.61,0:16:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utage, kau seharusnya\Nsudah terbiasa sekarang.
Dialogue: 0,0:16:29.48,0:16:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memanggil nama depanku!
Dialogue: 0,0:16:34.62,0:16:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bukankah udara di sini sangat segar?\N- Kinoshita, kau tidak apa-apa?
Dialogue: 0,0:16:36.49,0:16:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Rasanya sungguh berbeda.\N- Kinoshita.
Dialogue: 0,0:16:38.16,0:16:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengobrol\Ndengan Ibu tentang Natsuki.
Dialogue: 0,0:16:41.00,0:16:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mengkhawatirkan\Nkejadian sebelumnya.
Dialogue: 0,0:16:45.38,0:16:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki menceritakan sesuatu kepadamu?
Dialogue: 0,0:16:47.42,0:16:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang kalian pernah berpacaran.
Dialogue: 0,0:16:51.42,0:16:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu memang benar.
Dialogue: 0,0:16:55.30,0:16:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, pekerjaan Natsuki\Nsedang tidak berjalan lancar.
Dialogue: 0,0:16:58.56,0:16:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kenapa begitu?
Dialogue: 0,0:17:00.47,0:17:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang dia tak bisa menulis lagu\Nyang ingin ditulisnya.
Dialogue: 0,0:17:03.44,0:17:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia telah menghancurkan hidup Ibu,
Dialogue: 0,0:17:05.94,0:17:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya dia tak pantas menulis lagu.
Dialogue: 0,0:17:07.65,0:17:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang dia katakan.
Dialogue: 0,0:17:10.31,0:17:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang Natsuki pikirkan?
Dialogue: 0,0:17:12.69,0:17:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu aku ini lancang
Dialogue: 0,0:17:15.41,0:17:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena mencampuri urusan orang lain.
Dialogue: 0,0:17:18.41,0:17:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak bisa\Nmengabaikan Natsuki begitu saja.
Dialogue: 0,0:17:20.91,0:17:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:17:25.07,0:17:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini,
Dialogue: 0,0:17:26.75,0:17:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Asuka, sebelumnya Ibu bilang\Nkalau bias Ibu adalah Natsuki.
Dialogue: 0,0:17:29.88,0:17:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa saat itu Ibu\Nbilang tidak mengenalnya?
Dialogue: 0,0:17:33.30,0:17:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena...
Dialogue: 0,0:17:35.55,0:17:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}identitas mantan pacar seorang idola\Ntidak boleh terungkap, kan?
Dialogue: 0,0:17:39.51,0:17:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar.
Dialogue: 0,0:17:40.68,0:17:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika penggemarnya tahu\Ndia masih menemui mantan pacarnya,
Dialogue: 0,0:17:43.35,0:17:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dunia maya pasti akan gempar.
Dialogue: 0,0:17:46.10,0:17:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia malah menemuiku dengan santai.\NDasar bodoh!
Dialogue: 0,0:17:49.15,0:17:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau benar.
Dialogue: 0,0:17:50.90,0:17:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, Natsuki merasa Ibu membencinya.
Dialogue: 0,0:17:54.15,0:17:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:17:56.36,0:17:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira dialah
Dialogue: 0,0:17:57.78,0:17:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membenciku.
Dialogue: 0,0:18:01.66,0:18:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku selalu menyesalinya.
Dialogue: 0,0:18:03.54,0:18:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, saat tahu Natsuki ikut acara bakat,
Dialogue: 0,0:18:07.29,0:18:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa sangat bahagia.
Dialogue: 0,0:18:09.42,0:18:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Natsuki, kan?
Dialogue: 0,0:18:11.67,0:18:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ceria dan menawan,
Dialogue: 0,0:18:13.13,0:18:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin menjadi malaikat bagi semua orang.
Dialogue: 0,0:18:15.26,0:18:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Natsuki Ishibashi.
Dialogue: 0,0:18:16.80,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:18.76,0:18:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, hidup saja terasa merepotkan baginya.
Dialogue: 0,0:18:22.06,0:18:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun kini, dia bernyanyi dan menari.
Dialogue: 0,0:18:23.35,0:18:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga banyak tersenyum.
Dialogue: 0,0:18:27.77,0:18:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki sungguh luar biasa.
Dialogue: 0,0:18:31.06,0:18:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat sekali.
Dialogue: 0,0:18:34.48,0:18:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku membencinya?
Dialogue: 0,0:18:38.91,0:18:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku menyukai sosok Natsuki\Nyang pekerja keras.
Dialogue: 0,0:18:46.87,0:18:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisakah\NIbu memberitahunya secara langsung?
Dialogue: 0,0:18:52.04,0:18:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, aku tak bisa.
Dialogue: 0,0:18:54.51,0:18:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki adalah selebritas terkenal sekarang.
Dialogue: 0,0:18:57.09,0:18:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sukses berada di atas sana.
Dialogue: 0,0:18:58.97,0:19:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika orang biasa sepertiku menemuinya,\Nitu hanya akan menyusahkannya.
Dialogue: 0,0:19:02.68,0:19:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti perasaan Ibu, Bu Asuka.
Dialogue: 0,0:19:07.23,0:19:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Natsuki tidak merasa seperti itu.
Dialogue: 0,0:19:12.61,0:19:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki memang sangat berbakat.
Dialogue: 0,0:19:15.57,0:19:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia sering mabuk\Ndan tidak mau berhenti merokok.
Dialogue: 0,0:19:18.28,0:19:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sering kabur saat ada masalah.
Dialogue: 0,0:19:19.74,0:19:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga masih punya banyak kelemahan.
Dialogue: 0,0:19:21.32,0:19:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:19:23.41,0:19:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia luar biasa bukan\Nkarena dia seorang idola.
Dialogue: 0,0:19:25.45,0:19:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan bukan berarti orang biasa\Ntidak bisa menjadi sosok yang luar biasa.
Dialogue: 0,0:19:27.83,0:19:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggapan itu sama sekali tidak benar.
Dialogue: 0,0:19:31.25,0:19:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, itulah yang ingin kusampaikan.
Dialogue: 0,0:19:36.92,0:19:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini lembut sekali, ya.
Dialogue: 0,0:19:39.09,0:19:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku benar-benar tak menyangka.
Dialogue: 0,0:19:40.43,0:19:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, di depan kamera,
Dialogue: 0,0:19:41.51,0:19:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau selalu memancarkan aura idola.\NKukira kau bisa melakukan hal apa pun.
Dialogue: 0,0:19:46.93,0:19:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengatakannya demi pekerjaan.
Dialogue: 0,0:19:49.02,0:19:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Itu tidak benar. Begini...
Dialogue: 0,0:19:50.69,0:19:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hottiehara panik!\N- Aneh sekali. Apa yang tadi kukatakan?
Dialogue: 0,0:19:52.19,0:19:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini video sangat langka\Nyang harus diwariskan hingga ribuan tahun!
Dialogue: 0,0:19:56.32,0:19:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tetap tidak bisa\Nmenemuinya begitu saja.
Dialogue: 0,0:20:00.32,0:20:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya,
Dialogue: 0,0:20:01.70,0:20:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin menunjukkan sesuatu.
Dialogue: 0,0:20:08.16,0:20:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki, tolong lihat akun ini!
Dialogue: 0,0:20:10.37,0:20:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya jelek sekali.
Dialogue: 0,0:20:13.88,0:20:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:20:26.31,0:20:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Asuka, kan?
Dialogue: 0,0:20:28.10,0:20:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sejak kapan ini dibuat?
Dialogue: 0,0:20:30.08,0:20:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas debutmu.
Dialogue: 0,0:20:31.77,0:20:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menduduki peringkat ketiga setelah Ori.
Dialogue: 0,0:20:33.44,0:20:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menantikan hari ini.
Dialogue: 0,0:20:35.81,0:20:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus mendukungmu.
Dialogue: 0,0:20:40.03,0:20:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia adalah penggemar beratku\Nsejak acara bakat itu!
Dialogue: 0,0:20:42.70,0:20:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi? Katakan padaku!
Dialogue: 0,0:20:44.24,0:20:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau malah kabur? Itu konyol sekali!
Dialogue: 0,0:20:47.33,0:20:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unggahan baru?
Dialogue: 0,0:21:01.30,0:21:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bimbingannya juga untuk hari ini.
Dialogue: 0,0:21:11.02,0:21:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan Tuan Suram hari ini?
Dialogue: 0,0:21:13.98,0:21:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mirip anak SD yang tidak bisa diam\Nkarena terlalu semangat ikut karyawisata.
Dialogue: 0,0:21:17.44,0:21:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar ini Festival Budaya pertamanya,
Dialogue: 0,0:21:19.78,0:21:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi dia pasti sangat menantikannya.
Dialogue: 0,0:21:23.11,0:21:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi SMA Tuan Suram\Njuga mengadakan Festival Budaya.
Dialogue: 0,0:21:25.86,0:21:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, ini Festival Budaya sekolahmu.
Dialogue: 0,0:21:31.20,0:21:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,\NSMA Tachibana adalah almamater Keito.
Dialogue: 0,0:21:35.17,0:21:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, F/ACE akan mengadakan syuting\Ndi Festival Budaya sekolahmu.
Dialogue: 0,0:21:39.67,0:21:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ups, aku keceplosan.
Dialogue: 0,0:21:41.38,0:21:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, lupakan saja yang tadi.
Dialogue: 0,0:21:45.63,0:21:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demikianlah ringkasan untuk acara baru kami,
Dialogue: 0,0:21:48.64,0:21:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta rencana keamanan untuk hari ini.
Dialogue: 0,0:21:51.06,0:21:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mencegah terjadinya keributan,
Dialogue: 0,0:21:52.27,0:21:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami mohon bantuan dari para guru sekalian.
Dialogue: 0,0:21:55.52,0:21:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu saja.\N- Baik.
Dialogue: 0,0:21:58.40,0:21:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natsuki...
Dialogue: 0,0:21:59.61,0:22:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamon...
Dialogue: 0,0:22:00.65,0:22:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- akan datang ke sekolah kita?
Dialogue: 0,0:23:33.74,0:23:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menantikan Festival Budaya
Dialogue: 0,0:23:37.75,0:23:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di SMA-nya Kinoshita.
