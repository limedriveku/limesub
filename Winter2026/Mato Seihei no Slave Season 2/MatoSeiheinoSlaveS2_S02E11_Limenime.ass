Dialogue: 0,0:00:51.82,0:00:56.08,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:02:09.47,0:02:11.99,tanda,,0000,0000,0000,,EPISODE 11: SLAVE DIRGANTARA
Dialogue: 0,0:04:37.88,0:04:39.47,tanda,,0000,0000,0000,,TITIAN SURGAWI
Dialogue: 0,0:05:43.86,0:05:45.12,tanda,,0000,0000,0000,,SEJUTA HUKUMAN ILAHI
Dialogue: 0,0:09:03.77,0:09:05.73,tanda,,0000,0000,0000,,BILAH PEDANG BUDAK
Dialogue: 0,0:09:36.01,0:09:37.52,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:17:07.21,0:17:09.13,tanda,,0000,0000,0000,,PELUK ERAT
Dialogue: 0,0:17:26.48,0:17:26.90,tanda,,0000,0000,0000,,GEMETAR
Dialogue: 0,0:17:36.91,0:17:37.33,tanda,,0000,0000,0000,,KALUT
Dialogue: 0,0:19:28.48,0:19:31.23,tanda,,0000,0000,0000,,KEESOKAN HARINYA
Dialogue: 0,0:21:56.50,0:21:59.76,tanda,,0000,0000,0000,,SMA?
Dialogue: 0,0:23:26.26,0:23:30.26,tanda,,0000,0000,0000,,EPISODE 12: MAJELIS DEWA
Dialogue: 0,0:23:39.98,0:23:40.98,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA\NIKUTI AKU, ANJING KECIL
Dialogue: 0,0:00:17.23,0:00:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titian Surgawi!
Dialogue: 0,0:00:20.42,0:00:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, jadi kamu akan terus\Nmelangkah maju, ya?
Dialogue: 0,0:00:31.55,0:00:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita selesaikan!
Dialogue: 0,0:00:34.10,0:00:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira, kami akan menyelamatkanmu sekarang!
Dialogue: 0,0:02:30.92,0:02:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik pemungkas, ya?
Dialogue: 0,0:02:32.55,0:02:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik!
Dialogue: 0,0:02:37.47,0:02:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya giliran kita!
Dialogue: 0,0:02:39.22,0:02:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:02:40.14,0:02:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinju Tunggangan Budak!
Dialogue: 0,0:02:44.31,0:02:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanmu terlihat jelas.
Dialogue: 0,0:02:53.78,0:02:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma serangan rantai!
Dialogue: 0,0:03:00.08,0:03:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas, ya?
Dialogue: 0,0:03:01.91,0:03:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kena, dampaknya akan begitu, ya?
Dialogue: 0,0:03:04.29,0:03:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan rantai biasa, ya!
Dialogue: 0,0:03:24.06,0:03:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coco, Naon...
Dialogue: 0,0:03:26.99,0:03:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertangkap juga.
Dialogue: 0,0:03:29.06,0:03:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar sampah, enyah sana!
Dialogue: 0,0:03:34.03,0:03:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, bantu aku!
Dialogue: 0,0:03:36.95,0:03:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:03:43.95,0:03:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jenawi Salib Kudus!
Dialogue: 0,0:04:02.05,0:04:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil ditangkis, ya?\NTapi...
Dialogue: 0,0:04:05.60,0:04:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukuman Dewa pasti turun!
Dialogue: 0,0:04:15.49,0:04:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan sekali!\NTidak ada habisnya!
Dialogue: 0,0:04:18.86,0:04:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutarik agar lebih mendekat.
Dialogue: 0,0:04:26.04,0:04:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas nama keluarga Azuma!
Dialogue: 0,0:04:28.33,0:04:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kami pertahankan tempat ini!
Dialogue: 0,0:04:33.05,0:04:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayat Burung Kayangan.
Dialogue: 0,0:04:37.88,0:04:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titian Surgawi!
Dialogue: 0,0:04:40.76,0:04:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titian Surgawi.
Dialogue: 0,0:04:42.35,0:04:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan kujawab perasaan itu.
Dialogue: 0,0:05:14.50,0:05:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puncak gunung berawan.
Dialogue: 0,0:05:16.34,0:05:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah banyak nan runtuh.
Dialogue: 0,0:05:18.34,0:05:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunung rembulan.
Dialogue: 0,0:05:22.13,0:05:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulepas batasan otakku.
Dialogue: 0,0:05:26.89,0:05:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meningkatkan kecepatan gerakku\Ndalam waktu pendek.
Dialogue: 0,0:05:29.73,0:05:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurus yang kukembangkan\Nuntuk menghadapi Delapan Dewa Petir.
Dialogue: 0,0:05:39.19,0:05:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan juga jurus pemungkasku!
Dialogue: 0,0:05:42.03,0:05:43.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembahlah!
Dialogue: 0,0:05:45.12,0:05:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keagunganku yang indah ini!
Dialogue: 0,0:05:48.83,0:05:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengkloning tangannya saja, ya?
Dialogue: 0,0:06:24.32,0:06:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut dan gentarlah\Npada Sejuta Hukuman Dewa!
Dialogue: 0,0:06:30.41,0:06:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingatlah lagi, bayangkan saat itu!
Dialogue: 0,0:06:43.26,0:06:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menembus serangan beruntun dewa?
Dialogue: 0,0:06:45.59,0:06:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku berniat menghabisinya!
Dialogue: 0,0:06:50.06,0:06:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu dangkal, ya?
Dialogue: 0,0:06:51.60,0:06:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya akan kuserang lebih dalam lagi!
Dialogue: 0,0:06:55.19,0:06:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:06:56.98,0:07:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jaga-jaga, akan kuhabisi mereka\Nselagi terluka dengan klona!
Dialogue: 0,0:07:01.11,0:07:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh mereka!
Dialogue: 0,0:07:10.10,0:07:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:12.83,0:07:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga maju sana!
Dialogue: 0,0:07:28.97,0:07:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira?
Dialogue: 0,0:07:32.26,0:07:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klonanya lemah!
Dialogue: 0,0:07:34.98,0:07:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum menyerap Mira sepenuhnya, ya?
Dialogue: 0,0:07:44.36,0:07:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:07:47.57,0:07:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo habisi dia, Yuuki!
Dialogue: 0,0:07:49.12,0:07:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:01.59,0:08:02.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira sialan!
Dialogue: 0,0:08:03.80,0:08:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan segera kuserap sepenuhnya.
Dialogue: 0,0:08:07.84,0:08:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku dewa yang cantik memesona!
Dialogue: 0,0:08:16.27,0:08:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupersembahkan tubuhku pada Kyouka.
Dialogue: 0,0:08:26.49,0:08:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki menghilang?
Dialogue: 0,0:08:30.82,0:08:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:08:32.70,0:08:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki ada di dalam pedang itu!
Dialogue: 0,0:08:50.01,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah hukuman dewa!
Dialogue: 0,0:09:03.77,0:09:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilah Pedang Budak!
Dialogue: 0,0:09:15.58,0:09:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:09:17.70,0:09:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik diriku yang bersemayam dalam pedang.
Dialogue: 0,0:09:20.00,0:09:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulontarkan dengan tebasan kilat pemungkasku.
Dialogue: 0,0:09:23.50,0:09:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kekuatan Titian Surgawi milikku.
Dialogue: 0,0:09:25.71,0:09:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu teknik berpedangku, ini adalah...
Dialogue: 0,0:09:30.51,0:09:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jurus pemungkas gabungan kami!
Dialogue: 0,0:09:57.91,0:10:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua masih bernapas!
Dialogue: 0,0:10:12.30,0:10:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mencoba melawan\Natau memakai kekuatan menembusmu,
Dialogue: 0,0:10:17.14,0:10:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langsung kutebas!
Dialogue: 0,0:10:30.28,0:10:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini wujud aslinya?
Dialogue: 0,0:10:35.28,0:10:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya!
Dialogue: 0,0:10:36.87,0:10:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mencoba menyerapku...
Dialogue: 0,0:10:50.88,0:10:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktumu untuk tunduk.
Dialogue: 0,0:11:10.36,0:11:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titian Surgawi.
Dialogue: 0,0:11:13.07,0:11:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus sudah menguasainya.
Dialogue: 0,0:11:18.46,0:11:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:11:24.37,0:11:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:11:25.62,0:11:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak dan yang lainnya harus diapakan?
Dialogue: 0,0:11:30.34,0:11:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan yang di sini padaku.
Dialogue: 0,0:11:37.47,0:11:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak!
Dialogue: 0,0:11:38.76,0:11:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bergerak, akan kutembak!
Dialogue: 0,0:11:54.82,0:11:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabur ke bawah tanah?
Dialogue: 0,0:11:57.74,0:12:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenka, terima kasih.
Dialogue: 0,0:12:01.23,0:12:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:12:03.33,0:12:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah menumpas dewa, ya?
Dialogue: 0,0:12:07.33,0:12:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon lakukan penyembuhan\Ndan laporan penumpasan Delapan Dewa Petir.
Dialogue: 0,0:12:10.21,0:12:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengawasi sekitar untuk jaga-jaga.
Dialogue: 0,0:12:13.21,0:12:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laporan diterima.
Dialogue: 0,0:12:15.72,0:12:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan penyembuhan padaku!
Dialogue: 0,0:12:17.30,0:12:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energiku melimpah ruah!
Dialogue: 0,0:12:22.22,0:12:27.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, di sini ada Tobera,\Nsemuanya bisa segera pulih!
Dialogue: 0,0:12:33.65,0:12:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.\NSetelah merasa lega...
Dialogue: 0,0:12:37.61,0:12:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesadaranku... memu—
Dialogue: 0,0:12:58.22,0:12:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo.
Dialogue: 0,0:13:02.23,0:13:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusetsu?
Dialogue: 0,0:13:03.76,0:13:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panik.
Dialogue: 0,0:13:05.56,0:13:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan dunia nyata.
Dialogue: 0,0:13:08.77,0:13:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dunia di dalam tubuhmu.
Dialogue: 0,0:13:11.10,0:13:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semacam alam mentalmu.
Dialogue: 0,0:13:30.12,0:13:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia dalam diriku?
Dialogue: 0,0:13:33.53,0:13:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kehilangan tubuh fisik,
Dialogue: 0,0:13:36.00,0:13:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku muncul di sini,\Ntempat sisa kekuatanku berada.
Dialogue: 0,0:13:39.34,0:13:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan?
Dialogue: 0,0:13:40.30,0:13:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatmu menelan\NTetesan Dewa kental milikku, kan?
Dialogue: 0,0:13:46.81,0:13:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang itu, ya?
Dialogue: 0,0:13:49.18,0:13:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberadaan dewa itu tidak akan\Nlenyap dengan mudah.
Dialogue: 0,0:13:53.52,0:13:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tubuh fisikku telah tiada.
Dialogue: 0,0:13:56.44,0:13:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga termasuk pertarungan,
Dialogue: 0,0:13:57.98,0:14:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sama sekali tidak bisa\Nmemengaruhi dunia luar.
Dialogue: 0,0:14:06.37,0:14:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bisa kita lakukan hanyalah\Nhidup rukun di sini.
Dialogue: 0,0:14:18.13,0:14:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan terbangun, ya?
Dialogue: 0,0:14:20.21,0:14:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, mulai sekarang,\Nkita bisa bertemu kapan saja.
Dialogue: 0,0:14:23.59,0:14:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggaplah beruntung karena ada\Ndewa cantik bersemayam di hatimu.
Dialogue: 0,0:14:28.60,0:14:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini beruntung?
Dialogue: 0,0:14:40.37,0:14:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini di mana?
Dialogue: 0,0:14:43.57,0:14:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini asrama Regu Tujuh Kota Iblis, Yuuki!
Dialogue: 0,0:14:49.66,0:14:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, jadi yang barusan itu mimpi?
Dialogue: 0,0:14:55.50,0:14:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan dirimu!\NIni perintah dari atasan!
Dialogue: 0,0:14:59.21,0:15:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:15:04.26,0:15:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hilang kesadaran\Nsetelah pertarungan di Yokohama
Dialogue: 0,0:15:08.69,0:15:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tertidur selama dua hari.
Dialogue: 0,0:15:10.93,0:15:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku dibawa ke sini?
Dialogue: 0,0:15:13.81,0:15:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukamu sudah diobati.
Dialogue: 0,0:15:15.94,0:15:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya juga tidak ada\Nmasalah di tubuhmu!
Dialogue: 0,0:15:19.11,0:15:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Ketua sedang melaporkan
Dialogue: 0,0:15:20.69,0:15:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}insiden Yokohama bersama Ketua Kamiunten\Ndan yang lain di markas pusat.
Dialogue: 0,0:15:24.57,0:15:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, aku juga harus bekerja!
Dialogue: 0,0:15:29.62,0:15:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini.
Dialogue: 0,0:15:32.04,0:15:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong istirahat saja!
Dialogue: 0,0:15:37.17,0:15:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar Nei yang memasak.
Dialogue: 0,0:15:39.17,0:15:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kusiapkan pemandian juga, ya!
Dialogue: 0,0:15:41.46,0:15:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:44.72,0:15:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus terima niat baik Nei\Ndan bersantai dulu.
Dialogue: 0,0:15:51.89,0:15:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar kamu sudah siuman.
Dialogue: 0,0:15:53.77,0:15:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya tubuhku juga mulai bergerak.
Dialogue: 0,0:15:56.73,0:15:59.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku belum diberi hadiah!
Dialogue: 0,0:16:00.56,0:16:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kondisimu?
Dialogue: 0,0:16:01.61,0:16:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehat!
Dialogue: 0,0:16:02.94,0:16:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah pulih sepenuhnya!
Dialogue: 0,0:16:07.40,0:16:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu yang menyelamatkanku, ya?
Dialogue: 0,0:16:10.13,0:16:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:16:11.99,0:16:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkat kalian semua.
Dialogue: 0,0:16:14.12,0:16:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:15.72,0:16:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kemenangan\Nyang Korps Defensi Iblis raih bersama.
Dialogue: 0,0:16:20.63,0:16:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama kamu, Mira.
Dialogue: 0,0:16:22.29,0:16:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa melawan meski sudah diserap.\NTekadmu memang tangguh.
Dialogue: 0,0:16:28.55,0:16:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukerahkan tekadku sekuat-kuatnya\Nagar kekuatanku tidak diserap seluruhnya.
Dialogue: 0,0:16:34.26,0:16:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan semuanya kumpul di sini!
Dialogue: 0,0:16:36.56,0:16:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau melakukan evaluasi, bantu aku!
Dialogue: 0,0:16:41.10,0:16:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi evaluasinya besok saja.
Dialogue: 0,0:16:44.11,0:16:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kenapa?
Dialogue: 0,0:16:48.03,0:16:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesi hadiahnya mau dimulai,\Ntolong tinggalkan kami.
Dialogue: 0,0:16:54.62,0:16:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan kasih hadiah.
Dialogue: 0,0:16:56.41,0:16:57.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:57.87,0:17:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kamu bilang,\Nini kemenangan kita semua.
Dialogue: 0,0:17:03.59,0:17:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hadiahnya juga biar dikasih\Nsama siapa saja yang mau.
Dialogue: 0,0:17:07.21,0:17:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa begitu?
Dialogue: 0,0:17:10.05,0:17:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah diselamatkan olehnya.
Dialogue: 0,0:17:14.72,0:17:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Biar ikut kubantu.
Dialogue: 0,0:17:17.06,0:17:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipaksa begitu.
Dialogue: 0,0:17:19.73,0:17:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau alurnya begini,\Nkita akan mandi bareng.
Dialogue: 0,0:17:23.46,0:17:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Ma-Mandi bareng?
Dialogue: 0,0:17:26.90,0:17:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertukar buku harian saja belum,\Ntapi langsung begituan?
Dialogue: 0,0:17:32.30,0:17:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, Tenka!
Dialogue: 0,0:17:34.03,0:17:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu tidak bergerak sendiri, kan?
Dialogue: 0,0:17:37.33,0:17:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sama sekali tidak ragu?
Dialogue: 0,0:17:58.81,0:18:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking malunya, aku tidak bisa lepas baju!
Dialogue: 0,0:18:01.89,0:18:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal itu ideku sendiri!
Dialogue: 0,0:18:07.07,0:18:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau disuguhi pemandangan\Nseperti ini di depan mata...
Dialogue: 0,0:18:13.28,0:18:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking gugupnya, aku tak bisa gerak!
Dialogue: 0,0:18:15.82,0:18:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pusing, ya?
Dialogue: 0,0:18:18.08,0:18:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang malu.
Dialogue: 0,0:18:27.41,0:18:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan hal seperti ini\Ndi pemandian air panas.
Dialogue: 0,0:18:29.99,0:18:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar mesum!
Dialogue: 0,0:18:36.55,0:18:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah bekerja keras.
Dialogue: 0,0:18:44.35,0:18:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf!
Dialogue: 0,0:18:46.61,0:18:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau melaporkan sesuatu!
Dialogue: 0,0:18:48.98,0:18:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:54.45,0:18:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada dewa di dalam tubuhmu?\NKelihatannya tidak berbahaya.
Dialogue: 0,0:18:59.95,0:19:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu cuma mimpi?
Dialogue: 0,0:19:01.62,0:19:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit sekali menilainya.
Dialogue: 0,0:19:04.00,0:19:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, sekarang pun aku tidak bisa\Nberkomunikasi dengannya.
Dialogue: 0,0:19:09.00,0:19:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan mengawasimu\Ndengan saksama.
Dialogue: 0,0:19:13.09,0:19:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lihat perkembangannya.
Dialogue: 0,0:19:14.84,0:19:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laporkan terus untuk ke depannya.
Dialogue: 0,0:19:17.22,0:19:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:19:24.39,0:19:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NAku tidak bisa lepas baju!
Dialogue: 0,0:19:33.86,0:19:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka dan Mira melakukan evaluasi\Ndari pertarungan melawan Kusetsu
Dialogue: 0,0:19:38.24,0:19:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengantisipasi serangan\NDelapan Dewa Petir berikutnya.
Dialogue: 0,0:19:41.24,0:19:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama, bagian yang menyebabkan\NMira kalah dari Kusetsu.
Dialogue: 0,0:19:44.41,0:19:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengulanginya berkali-kali.
Dialogue: 0,0:19:52.75,0:19:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di akhir, sepertinya aku\Nmemang maju terlalu lurus, ya.
Dialogue: 0,0:19:55.88,0:20:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu karena pengaruh kelelahan\Nsetelah menolong warga sipil.
Dialogue: 0,0:20:00.14,0:20:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mengalahkan dewa\Nsebagai seorang Ketua.
Dialogue: 0,0:20:04.72,0:20:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil akhirnya memang bagus,\Ntapi aku tidak boleh merasa puas.
Dialogue: 0,0:20:09.40,0:20:12.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat rasional bahkan\Nuntuk ukuran orang sehebat Mira.
Dialogue: 0,0:20:13.98,0:20:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka.
Dialogue: 0,0:20:15.99,0:20:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pinjamkan bawahanmu.
Dialogue: 0,0:21:52.21,0:21:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah cerita mimpi yang dilihat Yuuki.
Dialogue: 0,0:21:56.50,0:21:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mendadak di sini?
Dialogue: 0,0:22:08.52,0:22:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:22:10.60,0:22:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melamun dari pagi.
Dialogue: 0,0:22:12.89,0:22:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:22:16.48,0:22:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Junior!
Dialogue: 0,0:22:23.41,0:22:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, pelajaran mau dimulai!
Dialogue: 0,0:22:25.95,0:22:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sana masuk ke kelas!
Dialogue: 0,0:22:27.41,0:22:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi murid!
Dialogue: 0,0:22:32.08,0:22:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini duniamu, jadi aku bisa\Nmelakukan yang seperti ini.
Dialogue: 0,0:22:36.17,0:22:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulah dewa, ya?
Dialogue: 0,0:22:38.00,0:22:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari ingatanmu yang kubaca,
Dialogue: 0,0:22:40.01,0:22:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak punya pasangan\Nsemasa sekolah, ya?
Dialogue: 0,0:22:44.84,0:22:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang jadi pasanganmu.
Dialogue: 0,0:22:53.10,0:22:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lanjut hubungan intim!
Dialogue: 0,0:22:59.57,0:23:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:23:01.65,0:23:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi tubuhku bergerak sendiri!
Dialogue: 0,0:23:05.61,0:23:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah.
Dialogue: 0,0:23:07.07,0:23:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak yang perlu kutanyakan!
Dialogue: 0,0:23:11.37,0:23:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi ini harus kubenahi!
Dialogue: 0,0:23:21.67,0:23:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia kabur!
Dialogue: 0,0:23:23.51,0:23:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, langsung mundur.
Dialogue: 0,0:23:26.26,0:23:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, episode 12, Majelis Dewa.
Dialogue: 0,0:23:30.26,0:23:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bonus buat hari ini.
Dialogue: 0,0:23:31.89,0:23:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di SMA Slave!
Dialogue: 0,0:23:34.27,0:23:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak punya pasangan?
Dialogue: 0,0:23:36.60,0:23:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:23:37.85,0:23:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang jadi pasanganmu.
