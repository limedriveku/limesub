Dialogue: 0,0:02:05.56,0:02:06.44,tanda,,0000,0000,0000,,PENERAPAN CARA MENCARI LUAS LINGKARAN
Dialogue: 0,0:02:15.36,0:02:17.08,tanda,,0000,0000,0000,,TRIP KE YOKOHAMA\NDAERAH PECINAN
Dialogue: 0,0:05:06.79,0:05:11.08,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:06:24.45,0:06:26.95,tanda,,0000,0000,0000,,EPISODE 09: TEKAD KAPTEN
Dialogue: 0,0:11:39.26,0:11:40.43,tanda,,0000,0000,0000,,ALL-KILLING
Dialogue: 0,0:13:25.95,0:13:27.45,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:23:26.55,0:23:30.35,tanda,,0000,0000,0000,,EPISODE 10: PERTEMPURAN YOKOHAMA
Dialogue: 0,0:23:39.98,0:23:41.00,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA\NIKUTI AKU, ANJING KECIL
Dialogue: 0,0:00:02.82,0:00:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus istirahat selagi bisa.
Dialogue: 0,0:00:07.49,0:00:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo!
Dialogue: 0,0:00:09.45,0:00:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penculik!
Dialogue: 0,0:00:12.58,0:00:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bergerak!
Dialogue: 0,0:00:14.12,0:00:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak bisa bersuara!
Dialogue: 0,0:00:17.50,0:00:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma, aku sudah menyegel pergerakanmu.
Dialogue: 0,0:00:20.50,0:00:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini teknik Dewa nan indah.
Dialogue: 0,0:00:23.34,0:00:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Kusetsu.
Dialogue: 0,0:00:25.13,0:00:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar Delapan Dewa Petir!
Dialogue: 0,0:00:27.38,0:00:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku kembali, penjaga sudah terbunuh\Ndan mangsaku sudah kabur!
Dialogue: 0,0:00:33.05,0:00:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencanaku gagal!
Dialogue: 0,0:00:34.89,0:00:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin rasanya aku mengamuk,
Dialogue: 0,0:00:37.14,0:00:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku dilarang Mbak Shikoku\Nuntuk bertarung!
Dialogue: 0,0:00:39.81,0:00:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat itu, aku melihatmu\Ndan memutuskan untuk mengikutimu!
Dialogue: 0,0:00:43.31,0:00:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:00:44.07,0:00:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wakura Yuuki.
Dialogue: 0,0:00:45.94,0:00:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar kalau kamu\Nkesukaannya Mbak Shikoku.
Dialogue: 0,0:00:50.03,0:00:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, aku akan menjadikanmu\Noleh-oleh dari Yokohama.
Dialogue: 0,0:00:54.81,0:00:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku bergerak sendiri!
Dialogue: 0,0:00:55.91,0:00:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga harus diverifikasi.
Dialogue: 0,0:00:58.58,0:01:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kamu lulus dengan nilai pas-pasan.
Dialogue: 0,0:01:01.04,0:01:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Verifikasi?
Dialogue: 0,0:01:03.63,0:01:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum menculik salah satu mangsaku,
Dialogue: 0,0:01:06.40,0:01:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia sedang berhubungan badan dengan pria.
Dialogue: 0,0:01:09.30,0:01:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran, apa memang benar\Nrasanya senikmat itu?
Dialogue: 0,0:01:15.56,0:01:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Li-Lidahku dan tanganku bergerak\Ndengan sendirinya!
Dialogue: 0,0:01:22.06,0:01:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini boleh juga.
Dialogue: 0,0:01:26.73,0:01:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhubungan badan dengan Dewa,\Nmanusia akan bagaimana, ya?
Dialogue: 0,0:01:32.45,0:01:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita coba.
Dialogue: 0,0:01:35.62,0:01:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoba?\NHubungan badan dengan Dewa?
Dialogue: 0,0:01:40.04,0:01:44.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Tetesan Dewa.\NTeguk semuanya.
Dialogue: 0,0:02:06.44,0:02:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu!
Dialogue: 0,0:02:09.72,0:02:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himari, terima kasih banyak!
Dialogue: 0,0:02:12.57,0:02:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal subtitusikan rasio dan rumusnya.
Dialogue: 0,0:02:17.08,0:02:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya... Yokohama.
Dialogue: 0,0:02:21.04,0:02:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten dan yang lainnya\Npergi ke sana karena ada misi.
Dialogue: 0,0:02:24.12,0:02:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bisa lihat pemandangan malam\Ndi Yokohama!
Dialogue: 0,0:02:27.50,0:02:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkannya saja sudah sangat romantis.
Dialogue: 0,0:02:37.72,0:02:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik.
Dialogue: 0,0:02:42.27,0:02:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shushu, kamu lebih cantik.
Dialogue: 0,0:02:46.56,0:02:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, auramu juga berbeda dari biasanya.
Dialogue: 0,0:02:58.95,0:03:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahan lagi.
Dialogue: 0,0:03:03.04,0:03:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam ini, kamu tidak akan kubiarkan tidur.
Dialogue: 0,0:03:10.92,0:03:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Canda! Canda!
Dialogue: 0,0:03:15.63,0:03:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu pikirkan?\NLawan kita Delapan Dewa Petir!
Dialogue: 0,0:03:19.51,0:03:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya bisa jadi lebih berbahaya\Ndari yang kita bayangkan.
Dialogue: 0,0:03:40.70,0:03:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu tegang sekali.
Dialogue: 0,0:03:45.29,0:03:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kamu hanya mati rasa.
Dialogue: 0,0:03:48.21,0:03:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan racun.
Dialogue: 0,0:03:50.21,0:03:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan khawatir dan tergodalah olehku.
Dialogue: 0,0:03:59.76,0:04:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma ini...
Dialogue: 0,0:04:04.77,0:04:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasi ini...
Dialogue: 0,0:04:09.98,0:04:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keringatmu...
Dialogue: 0,0:04:16.89,0:04:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seleraku.
Dialogue: 0,0:04:19.02,0:04:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lebih nikmati lagi.
Dialogue: 0,0:04:24.45,0:04:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatmu bisa sedikit bergerak.
Dialogue: 0,0:04:30.12,0:04:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layanilah seluruh raga Dewa ini\Ndengan lidahmu.
Dialogue: 0,0:04:38.84,0:04:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat.
Dialogue: 0,0:04:43.60,0:04:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira!
Dialogue: 0,0:04:48.98,0:04:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:06:29.25,0:06:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasi ini...
Dialogue: 0,0:06:34.46,0:06:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keringatmu...
Dialogue: 0,0:06:41.38,0:06:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seleraku banget.
Dialogue: 0,0:06:43.51,0:06:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lebih nikmati lagi.
Dialogue: 0,0:06:48.93,0:06:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatmu bisa sedikit bergerak.
Dialogue: 0,0:06:54.60,0:06:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Layanilah seluruh raga Dewa ini\Ndengan lidahmu.
Dialogue: 0,0:07:02.56,0:07:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira!
Dialogue: 0,0:07:05.91,0:07:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:07:11.24,0:07:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:07:12.29,0:07:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:07:14.54,0:07:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh kita...
Dialogue: 0,0:07:17.67,0:07:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan Dewa Petir!
Dialogue: 0,0:07:19.54,0:07:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:07:26.88,0:07:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak akan kubiarkan kabur.
Dialogue: 0,0:07:29.68,0:07:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tendang diriku
Dialogue: 0,0:07:32.93,0:07:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang cantik ini!
Dialogue: 0,0:07:36.94,0:07:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Helipad?
Dialogue: 0,0:07:42.40,0:07:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempat yang cocok untuk memulai!
Dialogue: 0,0:07:45.78,0:07:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukuman Ilahi!
Dialogue: 0,0:07:56.25,0:07:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia...
Dialogue: 0,0:07:58.71,0:08:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}All-Killing!
Dialogue: 0,0:08:06.26,0:08:08.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasih aku paham Hukuman Ilahimu!
Dialogue: 0,0:08:09.14,0:08:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan pengganda diri?
Dialogue: 0,0:08:10.85,0:08:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, dia pernah melakukannya\Ndi gudang penyimpananku.
Dialogue: 0,0:08:13.35,0:08:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:15.93,0:08:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua akan kukalahkan dengan anggun!
Dialogue: 0,0:08:31.03,0:08:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ada satu yang bertahan hidup,
Dialogue: 0,0:08:36.03,0:08:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan kira bisa menang melawanku di udara!
Dialogue: 0,0:08:38.46,0:08:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa.
Dialogue: 0,0:08:54.64,0:08:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melawanmu,
Dialogue: 0,0:08:57.31,0:09:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini akan jadi pertarungan, bukan eksekusi.
Dialogue: 0,0:09:00.44,0:09:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?\NKartu?
Dialogue: 0,0:09:03.02,0:09:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dilarang bertarung.
Dialogue: 0,0:09:05.90,0:09:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus bertarung,\Naku diperintahkan kabur.
Dialogue: 0,0:09:08.49,0:09:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyebarkan ini ke seluruh penjuru kota.
Dialogue: 0,0:09:13.28,0:09:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelepasan total!
Dialogue: 0,0:09:52.70,0:09:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bencana Kota Iblis terjadi!
Dialogue: 0,0:09:55.62,0:09:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bencana Kota Iblis terjadi!
Dialogue: 0,0:09:57.28,0:09:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurik raksasa muncul!
Dialogue: 0,0:09:58.87,0:10:02.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan tingkat kehancuran\Ndan evakuasi warga sipil secepat mungkin!
Dialogue: 0,0:10:08.09,0:10:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:10:10.88,0:10:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak yang bisa kamu selamatkan?
Dialogue: 0,0:10:13.18,0:10:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjuanglah!
Dialogue: 0,0:10:15.85,0:10:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng!
Dialogue: 0,0:10:17.93,0:10:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusetsu, aku memberimu jurik buatanku.
Dialogue: 0,0:10:22.02,0:10:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segelnya akan lepas kalau diberi aba-aba\Ndan jurik pun akan muncul.
Dialogue: 0,0:10:25.15,0:10:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyegel mereka dalam\Nkondisi tak bergerak,
Dialogue: 0,0:10:27.48,0:10:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau dilepaskan, kekuatannya\Nakan pulih dalam sepuluh detik.
Dialogue: 0,0:10:30.28,0:10:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat!
Dialogue: 0,0:10:32.32,0:10:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain jurik keroco, aku juga memasukkan\Nempat jurik yang kuat.
Dialogue: 0,0:10:36.03,0:10:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korps Defensi Iblis peringkat rendah\Ntak akan bisa mengalahkan yang ini.
Dialogue: 0,0:10:40.24,0:10:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memodifikasinya berdasarkan\Njurik yang sudah mati.
Dialogue: 0,0:10:43.46,0:10:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tambah kuat dan bisa mengeluarkan benang\Nyang mampu menyimpan mangsa hidup-hidup.
Dialogue: 0,0:10:52.17,0:10:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jurik raksasa yang kugabungkan.
Dialogue: 0,0:10:54.47,0:10:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membuatnya berotot dan sangat kuat.
Dialogue: 0,0:10:59.43,0:11:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat dan sempurna!\NAku sayang Mbak Shikoku!
Dialogue: 0,0:11:03.52,0:11:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tindakan pencegahan.
Dialogue: 0,0:11:12.19,0:11:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyebarkan jurik\Nke seluruh pelosok Yokohama!
Dialogue: 0,0:11:19.41,0:11:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan berapa banyak\Nyang bisa kuselamatkan!
Dialogue: 0,0:11:23.62,0:11:25.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Mira adalah
Dialogue: 0,0:11:25.66,0:11:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat menciptakan klona
Dialogue: 0,0:11:27.42,0:11:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia memperkuat dirinya sendiri\Ndan membuat klona
Dialogue: 0,0:11:30.38,0:11:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau berfokus pada kuantitas klona.
Dialogue: 0,0:11:35.17,0:11:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan seorang pun mati!
Dialogue: 0,0:11:37.43,0:11:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}All-Killing!
Dialogue: 0,0:11:41.43,0:11:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus pada jumlah!\NMajulah sampai batasku!
Dialogue: 0,0:11:45.31,0:11:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Markas, tolong respons!
Dialogue: 0,0:11:47.10,0:11:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak jurik yang muncul\Ndi Teluk Yokohama!
Dialogue: 0,0:11:50.44,0:11:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kirim bantuan personel!
Dialogue: 0,0:11:55.44,0:11:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Markas, pergerakan jurik raksasa\Ntak dapat dihentikan!
Dialogue: 0,0:11:59.11,0:12:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kirim bantuan Korps Defensi Iblis!
Dialogue: 0,0:12:04.20,0:12:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu...
Dialogue: 0,0:12:13.92,0:12:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini berbahaya!
Dialogue: 0,0:12:15.76,0:12:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:12:16.88,0:12:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:12:23.35,0:12:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti orang di depan Anda\Ndan evakuasi dengan cepat!
Dialogue: 0,0:12:27.43,0:12:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:12:28.27,0:12:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:29.06,0:12:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nek, sekarang sudah tidak apa-apa.
Dialogue: 0,0:12:36.24,0:12:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma, aku tidak bisa keluar.
Dialogue: 0,0:12:38.61,0:12:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyedihkan!\NBiar aku saja!
Dialogue: 0,0:13:14.23,0:13:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lebih kuat dari yang muncul\Ndi Kota Iblis!
Dialogue: 0,0:13:17.32,0:13:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takluklah!
Dialogue: 0,0:13:22.95,0:13:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka!
Dialogue: 0,0:13:33.42,0:13:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka!
Dialogue: 0,0:13:38.41,0:13:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah diobati.
Dialogue: 0,0:13:40.42,0:13:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus apa?
Dialogue: 0,0:13:43.89,0:13:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalahkan bajingan ini, pergi ke hotel,\Ndan temui bawahanmu.
Dialogue: 0,0:13:47.51,0:13:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kumpul lagi di Taman Rinko!
Dialogue: 0,0:13:49.18,0:13:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti!
Dialogue: 0,0:14:01.20,0:14:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ukurannya sebesar ini,\Ndaya tahannya pasti kuat.
Dialogue: 0,0:14:05.16,0:14:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya dia samsak berjalan.
Dialogue: 0,0:14:10.83,0:14:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira!
Dialogue: 0,0:14:11.62,0:14:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:14:27.22,0:14:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu betulan melindungi mereka, ya!
Dialogue: 0,0:14:34.65,0:14:40.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah berpikir kalau tak mungkin bisa\Nmengurus geng lokal seorang diri,
Dialogue: 0,0:14:41.49,0:14:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi berkat itu,\Naku bisa punya kemampuan klona.
Dialogue: 0,0:14:45.99,0:14:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya tinggal...
Dialogue: 0,0:14:47.74,0:14:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai nanti!
Dialogue: 0,0:14:49.20,0:14:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertemuan kita selanjutnya,\Nkamu akan merasakan Hukuman Ilahi!
Dialogue: 0,0:14:55.33,0:14:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu Dewa, tapi mau kabur?
Dialogue: 0,0:14:58.25,0:15:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak cantik sama sekali!
Dialogue: 0,0:15:03.51,0:15:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!\NHukuman Ilahimu sekarang saja!
Dialogue: 0,0:15:07.30,0:15:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga tidak boleh kubiarkan kabur!
Dialogue: 0,0:15:09.64,0:15:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru saja menggunakan\Nsebagian besar kekuatanmu
Dialogue: 0,0:15:12.89,0:15:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan harusnya tidak bisa\Nmembuat klona lagi!
Dialogue: 0,0:15:16.15,0:15:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau melawan Dewa pakai apa?
Dialogue: 0,0:15:20.11,0:15:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai teknik!
Dialogue: 0,0:15:22.44,0:15:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang tak pernah belajar.
Dialogue: 0,0:15:32.29,0:15:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipuan?
Dialogue: 0,0:15:36.71,0:15:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluru Bulu?\NBisa dia kendalikan dari jarak jauh juga?
Dialogue: 0,0:15:41.93,0:15:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutembak jatuh kamu ke neraka!
Dialogue: 0,0:15:44.76,0:15:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peras seluruh tenaga!
Dialogue: 0,0:15:46.93,0:15:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}All-Killing!
Dialogue: 0,0:15:56.35,0:16:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuhancurkan semua!
Dialogue: 0,0:16:05.19,0:16:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia bisa mengerahkan kekuatan\Ndi luar nalar berdasarkan perasaan.
Dialogue: 0,0:16:11.16,0:16:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Mbak Shikoku benar.
Dialogue: 0,0:16:16.71,0:16:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberi paham apa jadinya\Nkalau merusuh di Yokohama!
Dialogue: 0,0:16:25.59,0:16:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan lengah lagi!
Dialogue: 0,0:16:44.23,0:16:46.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan wujud ini,
Dialogue: 0,0:16:47.44,0:16:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pasti akan kuhukum!
Dialogue: 0,0:16:52.28,0:16:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jurik raksasa tengah mendekat.\NHarap evakuasi secepatnya!
Dialogue: 0,0:17:02.38,0:17:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cepat bertemu Kyouka dan Mira!
Dialogue: 0,0:17:18.09,0:17:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka!
Dialogue: 0,0:17:19.64,0:17:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki!
Dialogue: 0,0:17:23.23,0:17:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu baik-baik saja?
Dialogue: 0,0:17:25.15,0:17:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bisa bergerak bebas!
Dialogue: 0,0:17:28.03,0:17:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan bergabung dengan Mira!\NAyo pergi!
Dialogue: 0,0:17:30.40,0:17:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:34.24,0:17:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ganti bentuk sekalipun,
Dialogue: 0,0:17:36.79,0:17:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal yang harus kulakukan tetap sama!
Dialogue: 0,0:17:39.66,0:17:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klona yang menghalau jurik tadi\Nsudah kembali, ya?
Dialogue: 0,0:17:42.87,0:17:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini klona yang difokuskan pada jumlah.
Dialogue: 0,0:17:45.50,0:17:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tidak tahan lama,
Dialogue: 0,0:17:47.13,0:17:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi yang ada di dekat sini\Nbisa kupanggil balik!
Dialogue: 0,0:17:52.34,0:17:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudku yang ini...
Dialogue: 0,0:17:55.97,0:17:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya serangnya jauh berbeda!
Dialogue: 0,0:18:02.73,0:18:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipuan itu tak akan mempan\Nuntuk kedua kali...
Dialogue: 0,0:18:09.65,0:18:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:18:10.61,0:18:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih cepat dari aku mengeluarkan lendir!
Dialogue: 0,0:18:20.70,0:18:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:18:25.96,0:18:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tahannya juga meningkat!
Dialogue: 0,0:18:28.67,0:18:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasi keras yang barusan pasti tubuh asli!
Dialogue: 0,0:18:31.17,0:18:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ada urusan dengan klona!
Dialogue: 0,0:18:35.30,0:18:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukuman Ilahi!
Dialogue: 0,0:18:47.61,0:18:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga klona?
Dialogue: 0,0:18:50.78,0:18:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memeras kekuatannya\Nsampai batas terakhir!
Dialogue: 0,0:19:20.89,0:19:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau klonamu ada lebih banyak,
Dialogue: 0,0:19:26.23,0:19:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin seranganmu bisa\Nmerenggut nyawa Dewa.
Dialogue: 0,0:19:32.44,0:19:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu mengerahkan terlalu banyak\Nkekuatan untuk melindungi warga.
Dialogue: 0,0:19:38.41,0:19:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang namanya ganjaran.
Dialogue: 0,0:19:40.41,0:19:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah siap kalau ini terjadi, kan?
Dialogue: 0,0:19:45.71,0:19:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salah, wahai Dewa.
Dialogue: 0,0:19:52.09,0:19:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menolong semua orang\Ndan mengalahkanmu!
Dialogue: 0,0:19:56.43,0:19:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah tekadku!
Dialogue: 0,0:20:05.18,0:20:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusetsu.
Dialogue: 0,0:20:07.89,0:20:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kusetsu, anggota Delapan Dewa Petir.
Dialogue: 0,0:20:12.65,0:20:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kapten Skuad 2 Korps Defensi Iblis,\NKamiunten Mira!
Dialogue: 0,0:20:22.74,0:20:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ternyata cantik juga, Mira!
Dialogue: 0,0:20:26.58,0:20:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan padamu\Ntekad Korps Defensi Iblis, Kusetsu!
Dialogue: 0,0:20:34.92,0:20:38.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klona Mira sudah selesai\Nmengalahkan jurik-jurik itu.
Dialogue: 0,0:20:38.18,0:20:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang selamat.
Dialogue: 0,0:20:39.93,0:20:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira sudah menyelamatkanku tadi!
Dialogue: 0,0:20:42.35,0:20:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, giliranku menyelamatkannya!
Dialogue: 0,0:21:44.45,0:21:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyang, kenyang.
Dialogue: 0,0:21:47.41,0:21:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korps Defensi Iblis lagi?
Dialogue: 0,0:21:49.70,0:21:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku habis menyerap Mira,\Njadi masih kenyang.
Dialogue: 0,0:23:26.55,0:23:30.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, episode 10, Pertempuran Yokohama!
Dialogue: 0,0:23:30.35,0:23:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikut tambahan hari ini!
Dialogue: 0,0:23:32.10,0:23:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku jelaskan.
Dialogue: 0,0:23:33.39,0:23:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lendir yang dikeluarkan Kusetsu\Nbisa untuk menyembuhkan luka.
Dialogue: 0,0:23:36.94,0:23:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu fungsinya.
Dialogue: 0,0:23:38.86,0:23:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah paham?
