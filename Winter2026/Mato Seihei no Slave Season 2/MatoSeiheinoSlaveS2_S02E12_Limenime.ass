Dialogue: 0,0:01:31.20,0:01:33.32,tanda,,0000,0000,0000,,SLAVE: BAHANA LEDAK
Dialogue: 0,0:01:40.50,0:01:43.00,tanda,,0000,0000,0000,,EPISODE 12: MAJELIS DEWA
Dialogue: 0,0:03:18.05,0:03:19.76,tanda,,0000,0000,0000,,ASRAMA SKUAD DUA KORPS DEFENSI IBLIS
Dialogue: 0,0:04:14.94,0:04:15.86,tanda,,0000,0000,0000,,PUAH
Dialogue: 0,0:10:54.93,0:10:56.30,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:13:47.43,0:13:48.85,tanda,,0000,0000,0000,,DELAPAN DEWA PETIR - JAKU'UN
Dialogue: 0,0:14:27.89,0:14:30.43,tanda,,0000,0000,0000,,DELAPAN DEWA PETIR - NARUHIME
Dialogue: 0,0:14:52.20,0:14:56.42,tanda,,0000,0000,0000,,DELAPAN DEWA PETIR - FUKUMA
Dialogue: 0,0:15:06.18,0:15:08.14,tanda,,0000,0000,0000,,DELAPAN DEWA PETIR - TAIKYOKU
Dialogue: 0,0:17:56.01,0:17:59.02,tanda,,0000,0000,0000,,ASRAMA SKUAD TUJUH KORPS DEFENSI IBLIS
Dialogue: 0,0:21:32.94,0:21:35.19,tanda,,0000,0000,0000,,ASRAMA SKUAD TUJUH KORPS DEFENSI IBLIS
Dialogue: 0,0:23:39.94,0:23:40.94,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:00:01.94,0:00:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka, pinjamkan bawahanmu.
Dialogue: 0,0:00:06.86,0:00:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau memahami bentuk slave-ku.
Dialogue: 0,0:00:09.91,0:00:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bisa memberi hadiah, kan?
Dialogue: 0,0:00:11.99,0:00:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipaksa.
Dialogue: 0,0:00:16.32,0:00:19.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa takut!\NAku sudah membulatkan tekad!
Dialogue: 0,0:00:19.87,0:00:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menambah kartu\Nyang bisa dipakai sebanyak mungkin!
Dialogue: 0,0:00:25.21,0:00:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:00:27.76,0:00:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari tingkah dan wujud asalnya.
Dialogue: 0,0:00:31.22,0:00:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti entitas yang baru lahir\Ndi antara Delapan Dewa Petir.
Dialogue: 0,0:00:35.64,0:00:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi dewa lainnya\Npasti lebih kuat dari Kusetsu.
Dialogue: 0,0:00:39.98,0:00:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawa orang-orang akan dipertaruhkan.
Dialogue: 0,0:00:42.94,0:00:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki.
Dialogue: 0,0:00:44.82,0:00:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita perlu bertambah kuat.
Dialogue: 0,0:00:47.44,0:00:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:00:53.57,0:00:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa berperan itu berkat Kyouka!
Dialogue: 0,0:00:58.33,0:01:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengatakan itu.
Dialogue: 0,0:01:02.58,0:01:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya, aku tidak apa-apa.
Dialogue: 0,0:01:06.88,0:01:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lakukan peminjaman.
Dialogue: 0,0:01:10.01,0:01:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira.
Dialogue: 0,0:01:11.01,0:01:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:01:25.48,0:01:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perubahannya bisa jadi seperti ini?
Dialogue: 0,0:01:28.25,0:01:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya, cocok buatku.
Dialogue: 0,0:01:33.82,0:01:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya inreyen!\NAyo berangkat!
Dialogue: 0,0:01:52.26,0:01:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu tidak apa-apa?
Dialogue: 0,0:01:53.72,0:01:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:01:54.72,0:01:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecepatannya terasa enak!
Dialogue: 0,0:01:57.72,0:01:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angin Kota Iblis lumayan juga!
Dialogue: 0,0:02:00.39,0:02:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sempat mengagumi motor.
Dialogue: 0,0:02:08.52,0:02:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempat kepikiran pengin\Nmengajak kencan sambil naik motor, ya?
Dialogue: 0,0:02:16.07,0:02:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaganya mantap.
Dialogue: 0,0:02:18.24,0:02:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya, tinggal mencoba kemampuan khususnya!
Dialogue: 0,0:02:33.30,0:02:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka muncul!
Dialogue: 0,0:02:35.72,0:02:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya ini suara yang dibenci jurik.
Dialogue: 0,0:02:39.31,0:02:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisi mereka!
Dialogue: 0,0:02:46.77,0:02:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo menari!
Dialogue: 0,0:02:53.36,0:02:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tabrak habis!
Dialogue: 0,0:02:58.87,0:03:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali pukul!
Dialogue: 0,0:03:07.00,0:03:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhmu bagaimana?
Dialogue: 0,0:03:08.29,0:03:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih sanggup!
Dialogue: 0,0:03:10.63,0:03:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:03:11.84,0:03:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo patroli ke wilayah Skuad Dua!
Dialogue: 0,0:03:14.88,0:03:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:03:29.98,0:03:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus bisa tahan sampai ke asrama.
Dialogue: 0,0:03:32.69,0:03:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memancing musuh keluar pakai suara\Nkelihatannya akan berguna.
Dialogue: 0,0:03:35.95,0:03:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenaganya mantap, ditambah tangguh.
Dialogue: 0,0:03:38.49,0:03:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:03:44.87,0:03:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuklah ke dalam ke sana.
Dialogue: 0,0:03:49.75,0:03:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiahmu sepertinya akan dimulai.
Dialogue: 0,0:03:57.09,0:03:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:04:01.60,0:04:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah macam apa ini?
Dialogue: 0,0:04:04.10,0:04:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin semacam kencan di dalam mobil?
Dialogue: 0,0:04:09.27,0:04:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kencan, ya?
Dialogue: 0,0:04:15.86,0:04:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak sesulit bayanganku!
Dialogue: 0,0:04:18.36,0:04:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:04:19.57,0:04:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:04:21.49,0:04:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:04:23.95,0:04:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa aku malah menyerahkan jusku?
Dialogue: 0,0:04:32.00,0:04:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ci-Ciuman tidak langsung?
Dialogue: 0,0:04:34.80,0:04:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begini mainnya?
Dialogue: 0,0:04:37.26,0:04:39.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga minta, ya.
Dialogue: 0,0:04:56.98,0:05:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, lumayan sulit juga.
Dialogue: 0,0:05:05.03,0:05:06.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gampang!
Dialogue: 0,0:05:15.00,0:05:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya masih bakal lanjut, ya.
Dialogue: 0,0:05:18.51,0:05:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:05:19.92,0:05:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang ini gampang!
Dialogue: 0,0:05:25.76,0:05:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus sampai begini?
Dialogue: 0,0:05:28.10,0:05:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunjukkan sendiri kulitku ke pria...
Dialogue: 0,0:05:35.52,0:05:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kucium langsung dirimu.
Dialogue: 0,0:05:44.16,0:05:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai begini...
Dialogue: 0,0:05:53.67,0:05:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus sampai begini...
Dialogue: 0,0:05:59.34,0:06:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya harus tanggung jawab.
Dialogue: 0,0:06:15.27,0:06:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Mira baik-baik saja.
Dialogue: 0,0:06:19.32,0:06:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa Mbak dan yang lainnya\Nbaik-baik saja?
Dialogue: 0,0:06:26.62,0:06:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te—
Dialogue: 0,0:06:49.43,0:06:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang juga!
Dialogue: 0,0:06:52.06,0:06:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!\NKalian berdua juga!
Dialogue: 0,0:07:04.95,0:07:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi dari adik laki-lakiku\Nsedang kuisi lagi!
Dialogue: 0,0:07:08.12,0:07:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Mbak baik-baik saja.
Dialogue: 0,0:07:10.87,0:07:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan pulang pergi dari Yokohama\Njadi mudah karena ada Tenka!
Dialogue: 0,0:07:14.83,0:07:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kalau pulang pergi,\Nberarti pas datangnya juga?
Dialogue: 0,0:07:18.79,0:07:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:07:19.84,0:07:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memprediksi musuh\Nmemakai teknik bersembunyi
Dialogue: 0,0:07:22.28,0:07:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari informasi sebelumnya.
Dialogue: 0,0:07:23.80,0:07:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir ini musuh yang ada hubungannya\Ndengan teman mbakmu.
Dialogue: 0,0:07:29.18,0:07:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu ternyata prediksinya tepat!
Dialogue: 0,0:07:32.52,0:07:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehari-hari Tenka juga\Nmembantu membawakan suplai.
Dialogue: 0,0:07:37.23,0:07:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:07:39.11,0:07:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena risikonya paling kecil\Nkalau aku yang bergerak sendiri.
Dialogue: 0,0:07:43.28,0:07:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja.
Dialogue: 0,0:07:44.40,0:07:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini kamu pasti khawatir dengan\Nkeselamatan mbakmu dan teman-temannya.
Dialogue: 0,0:07:51.45,0:07:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap, Tenka!
Dialogue: 0,0:07:56.96,0:07:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:07:59.75,0:08:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sewajarnya kita saling membantu!
Dialogue: 0,0:08:06.38,0:08:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga ingin berterima kasih padamu.
Dialogue: 0,0:08:09.55,0:08:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:08:11.14,0:08:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku tidak berbuat apa-apa.
Dialogue: 0,0:08:13.22,0:08:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasihnya ke Kyouka saja.
Dialogue: 0,0:08:15.02,0:08:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan merendah!
Dialogue: 0,0:08:17.23,0:08:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dengar dari Aoba.
Dialogue: 0,0:08:19.35,0:08:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyelamatkan kami dengan anggun.
Dialogue: 0,0:08:22.40,0:08:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan anggun?
Dialogue: 0,0:08:26.15,0:08:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malu begitu!
Dialogue: 0,0:08:27.28,0:08:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serius, aku cuma membantu Kyouka.\N- Tenka, bisa bicara sebentar?
Dialogue: 0,0:08:31.49,0:08:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Korps Defensi Iblis tidak mengejarku?
Dialogue: 0,0:08:34.83,0:08:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, belum.
Dialogue: 0,0:08:37.20,0:08:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ancaman Delapan Dewa Petir dan para jurik\Nyang muncul dengan cara baru.
Dialogue: 0,0:08:42.84,0:08:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak masalah menumpuk.
Dialogue: 0,0:08:44.67,0:08:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tidak ada masalah.
Dialogue: 0,0:08:46.13,0:08:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korps Defensi Iblis juga tidak bisa\Ntetap sama seperti dulu.
Dialogue: 0,0:08:50.09,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga masih belum menemukan petunjuk
Dialogue: 0,0:08:53.47,0:08:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengembalikan kalian jadi manusia.
Dialogue: 0,0:08:55.64,0:08:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga sembari meneruskan penyelidikan\Npada Instansi Yin-Yang.
Dialogue: 0,0:09:00.85,0:09:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya masih butuh banyak waktu,
Dialogue: 0,0:09:03.56,0:09:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi mungkin sebaiknya\Nkami ganti persembunyian.
Dialogue: 0,0:09:07.57,0:09:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang Coco dan Naon bisa pulang saja\Nnilainya sudah sepuluh miliar poin!
Dialogue: 0,0:09:14.20,0:09:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tubuh kalian tidak apa-apa?
Dialogue: 0,0:09:18.41,0:09:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang terluka, tapi agak pegal.
Dialogue: 0,0:09:21.42,0:09:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu pun sudah lumayan membaik.
Dialogue: 0,0:09:26.21,0:09:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku bisa membuat kalian segar lagi.
Dialogue: 0,0:09:40.85,0:09:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu jago memijat, ya.
Dialogue: 0,0:09:50.36,0:09:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hebat!
Dialogue: 0,0:09:54.03,0:09:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titik pijat mereka...
Dialogue: 0,0:09:57.79,0:09:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Struktur tubuh mereka...
Dialogue: 0,0:10:01.66,0:10:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, aku bisa tahu betul.
Dialogue: 0,0:10:05.25,0:10:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena Kusetsu yang pernah\Nbergabung dengan mereka
Dialogue: 0,0:10:08.13,0:10:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada di dalam tubuhku?
Dialogue: 0,0:10:15.30,0:10:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku rasanya jadi segar bugar!
Dialogue: 0,0:10:17.81,0:10:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:10:20.52,0:10:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang banyak yang patut disyukuri.
Dialogue: 0,0:10:22.60,0:10:25.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sendiri punya banyak PR\Ndari pertempuran Yokohama.
Dialogue: 0,0:10:26.44,0:10:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus berjuang lebih keras lagi!
Dialogue: 0,0:10:30.69,0:10:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki, sampai jumpa lagi di rapat ketua.
Dialogue: 0,0:10:34.24,0:10:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih banyak.
Dialogue: 0,0:10:36.99,0:10:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:10:45.46,0:10:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak...
Dialogue: 0,0:11:01.60,0:11:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara muncul gerombolan jurik\Ndi kota besar,
Dialogue: 0,0:11:04.64,0:11:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}publik jadi sangat panik.
Dialogue: 0,0:11:06.69,0:11:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda kelihatannya sangat sibuk
Dialogue: 0,0:11:08.69,0:11:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}datang ke berbagai tempat\Nuntuk menenangkan keadaan.
Dialogue: 0,0:11:11.94,0:11:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja kerasnya.
Dialogue: 0,0:11:13.69,0:11:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:11:14.74,0:11:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin nanti aku akan minta\Ndimanja sama Bell.
Dialogue: 0,0:11:19.20,0:11:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan komandan itu banyak, ya?
Dialogue: 0,0:11:22.87,0:11:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jelas tidak sanggup.
Dialogue: 0,0:11:26.87,0:11:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira sudah bekerja keras\Nmelindungi warga sipil.
Dialogue: 0,0:11:29.42,0:11:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepanikan jadi bisa dihindari.
Dialogue: 0,0:11:31.93,0:11:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Instansi kepolisian juga mengirimkan\Nucapan terima kasih.
Dialogue: 0,0:11:35.93,0:11:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah tugasku sebagai\Nanggota Korps Defensi Iblis.
Dialogue: 0,0:11:38.76,0:11:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, sekarang jadi jelas kalau\Ndi medan yang melindungi banyak orang,
Dialogue: 0,0:11:42.90,0:11:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang ketua pun akan kerepotan.
Dialogue: 0,0:11:44.89,0:11:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Idealnya medan perangnya di Kota Iblis saja.
Dialogue: 0,0:11:48.19,0:11:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, aku juga bisa\Nmengerahkan seluruh tenaga.
Dialogue: 0,0:11:50.90,0:11:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan, kita harus bergerak\Ndengan lebih agresif!
Dialogue: 0,0:11:55.07,0:11:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang ancaman ke dunia nyata meningkat,
Dialogue: 0,0:11:57.40,0:12:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajar kalau kita mengubah\Narah kebijakan Korps Defensi Iblis.
Dialogue: 0,0:12:01.41,0:12:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, banyak yang tidak kita tahu,\Ndimulai dari markas musuh.
Dialogue: 0,0:12:05.96,0:12:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu harus kita selidiki.
Dialogue: 0,0:12:07.75,0:12:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Kusetsu ada di dalam tubuhku,\Nmungkin aku bisa bertanya padanya.
Dialogue: 0,0:12:12.13,0:12:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sejak saat itu,\Ndia tidak pernah muncul lagi.
Dialogue: 0,0:12:15.17,0:12:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, akan kutetapkan\NSituasi Darurat Kota Iblis.
Dialogue: 0,0:12:19.34,0:12:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa artinya itu?
Dialogue: 0,0:12:21.93,0:12:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita umumkan keberadaan\NDelapan Dewa Petir ke publik
Dialogue: 0,0:12:25.31,0:12:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Korps Defensi Iblis akan bersiap\Nmenghadapi ancaman ini sekuat tenaga.
Dialogue: 0,0:12:28.77,0:12:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga mempererat kerja sama\Ndengan dunia nyata.
Dialogue: 0,0:12:31.65,0:12:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diumumkan secara luas bahwa\Nkita akan bergerak seperti itu,
Dialogue: 0,0:12:35.69,0:12:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dunia nyata akan merasa tenang.
Dialogue: 0,0:12:37.40,0:12:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih begitu, ya?
Dialogue: 0,0:12:39.86,0:12:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi darurat, ya?
Dialogue: 0,0:12:42.66,0:12:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan Dewa Petir adalah musuh yang kuat.
Dialogue: 0,0:12:45.04,0:12:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mempersiapkan serangan\Nyang akan datang,
Dialogue: 0,0:12:48.00,0:12:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tingkatkanlah kemampuan kalian.
Dialogue: 0,0:12:49.62,0:12:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik!
Dialogue: 0,0:12:59.72,0:13:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu masuk ke dalam tubuhku?
Dialogue: 0,0:13:06.85,0:13:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya Mbak Joryu besar dan hangat!
Dialogue: 0,0:13:10.98,0:13:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya nikmat!
Dialogue: 0,0:13:23.53,0:13:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Joryu.
Dialogue: 0,0:13:25.83,0:13:27.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada panggilan.
Dialogue: 0,0:13:30.66,0:13:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan Dewa Petir diminta kumpul.
Dialogue: 0,0:13:35.59,0:13:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Shikoku, Mbak Joryu.
Dialogue: 0,0:13:38.80,0:13:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menjemput kami, Jaku'un?
Dialogue: 0,0:13:41.22,0:13:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai anak bungsu,\Nsudah sewajarnya melakukan ini.
Dialogue: 0,0:13:46.22,0:13:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua anggota telah berkumpul.
Dialogue: 0,0:13:50.27,0:13:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penelitianmu lancar?
Dialogue: 0,0:13:52.10,0:13:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, meski masih banyak\Nyang ingin kuketahui.
Dialogue: 0,0:13:56.77,0:14:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya sekarang aku masih lanjut meneliti.
Dialogue: 0,0:14:00.69,0:14:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Korps Defensi Iblis biadab,\Nmengganggu saja.
Dialogue: 0,0:14:12.92,0:14:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lama sekali.
Dialogue: 0,0:14:22.30,0:14:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menahan sergapanku!
Dialogue: 0,0:14:24.51,0:14:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya kesedihan tidak membuatmu tumpul!
Dialogue: 0,0:14:30.43,0:14:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru, kekuatanku meluap berkat amarah.
Dialogue: 0,0:14:36.86,0:14:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Petir memang harus begitu!
Dialogue: 0,0:14:39.73,0:14:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diperhatikan baik-baik,
Dialogue: 0,0:14:41.94,0:14:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Shikoku yang kelihatan\Npaling tidak semangat.
Dialogue: 0,0:14:44.45,0:14:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang menyesal.
Dialogue: 0,0:14:46.49,0:14:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya Kusetsu tidak kubiarkan\Npergi sendiri.
Dialogue: 0,0:14:52.20,0:14:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo musnahkan manusia
Dialogue: 0,0:14:54.54,0:14:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melepas kepergiannya.
Dialogue: 0,0:15:08.14,0:15:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak Taikyoku.
Dialogue: 0,0:15:10.39,0:15:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduklah di sana, Shikoku.
Dialogue: 0,0:15:15.35,0:15:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggantikan diriku yang tidak bisa\Npergi dari sisi Ibunda.
Dialogue: 0,0:15:18.56,0:15:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu bisa mengambil alih kepemimpinan.
Dialogue: 0,0:15:22.11,0:15:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa bisa sampai terbunuh\Nadalah kesalahan fatal.
Dialogue: 0,0:15:26.41,0:15:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri juga tidak bisa\Nmemaafkan kesalahanku.
Dialogue: 0,0:15:34.58,0:15:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hingga lukamu kembali pulih,\Nnikmatilah penderitaanmu sepuasnya.
Dialogue: 0,0:15:41.80,0:15:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu mulai sekarang,\Njangan terus terikat pada Kusetsu.
Dialogue: 0,0:15:45.84,0:15:49.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sebabnya kamu dijatuhi\Nhukuman seperti ini.
Dialogue: 0,0:15:50.47,0:15:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:52.31,0:15:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga jangan menyalahkan Shikoku lagi.
Dialogue: 0,0:15:55.35,0:15:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik.
Dialogue: 0,0:15:56.73,0:15:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak awal, tidak ada yang menyalahkannya.
Dialogue: 0,0:15:59.23,0:16:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah yang menyalahkan\Ncuma Mbak Taikyoku?
Dialogue: 0,0:16:05.57,0:16:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang.
Dialogue: 0,0:16:06.86,0:16:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya saat delapan pilar terkumpul,\Nkita akan melakukan serangan habis-habisan.
Dialogue: 0,0:16:12.24,0:16:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana sekarang, Shikoku?
Dialogue: 0,0:16:14.16,0:16:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Korps Defensi Iblis\Nsebagai organisasi, lebih besar dari dugaan.
Dialogue: 0,0:16:17.79,0:16:20.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu kita harus mempercepat\N"Hari Penyucian"
Dialogue: 0,0:16:20.71,0:16:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang direncanakan setelah penyerangan.
Dialogue: 0,0:16:23.59,0:16:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menyerang habis-habisan\Nsetelah Hari Penyucian.
Dialogue: 0,0:16:27.72,0:16:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya tempur kita akan meningkat drastis.
Dialogue: 0,0:16:31.01,0:16:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan makin pasti\Nuntuk mengalahkan Korps Defensi Iblis.
Dialogue: 0,0:16:34.43,0:16:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ngawur!
Dialogue: 0,0:16:35.47,0:16:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu pengecut!
Dialogue: 0,0:16:37.10,0:16:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sampai kapan kita bersiap?
Dialogue: 0,0:16:39.48,0:16:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sebut itu berhati-hati.
Dialogue: 0,0:16:41.94,0:16:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu pilar dewa sudah terbunuh!\NKita harus balas dendam!
Dialogue: 0,0:16:44.94,0:16:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sependapat dengan Rairen\Ndan Naruhime.
Dialogue: 0,0:16:49.45,0:16:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita ambil jalan tengah saja?
Dialogue: 0,0:16:52.82,0:16:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana Mbak Shikoku tetap dijalankan,
Dialogue: 0,0:16:55.33,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kita tidak akan menyerang\NKorps Defensi Iblis.
Dialogue: 0,0:17:00.50,0:17:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang akan menyerang adalah umat.
Dialogue: 0,0:17:04.21,0:17:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umat, mantan manusia\Nyang diberi kekuatan oleh dewa.
Dialogue: 0,0:17:08.88,0:17:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umat yang kinerjanya paling baik\Nakan ditarik jadi Delapan Dewa Petir.
Dialogue: 0,0:17:13.18,0:17:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, semuanya akan senang\Ndan berjuang sekuat tenaga.
Dialogue: 0,0:17:16.81,0:17:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis ini juga salah seorang\Nyang berharap menjadi dewa.
Dialogue: 0,0:17:20.06,0:17:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja!
Dialogue: 0,0:17:21.56,0:17:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar dia tunjukkan apa kekuatannya\Nsebanding dengan kita!
Dialogue: 0,0:17:24.56,0:17:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Mbak Taikyoku?
Dialogue: 0,0:17:27.03,0:17:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Shikoku tidak keberatan, aku setuju.
Dialogue: 0,0:17:31.20,0:17:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sepakat, ya.
Dialogue: 0,0:17:32.28,0:17:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku mau bicara\Ndengan Rairen dan Fukuma.
Dialogue: 0,0:17:36.12,0:17:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu seperti sedang merencanakan sesuatu.
Dialogue: 0,0:17:38.37,0:17:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau menyerang, jangan tanggung.
Dialogue: 0,0:17:41.29,0:17:42.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang harusnya begitu!
Dialogue: 0,0:17:43.17,0:17:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapan Ibunda, setidaknya 1.000 manusia\Ndibunuh setiap harinya.
Dialogue: 0,0:17:47.67,0:17:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bergerak\Nuntuk mewujudkan hari itu.
Dialogue: 0,0:17:51.26,0:17:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan mereka melihat keagungan ilahi kita!
Dialogue: 0,0:17:56.76,0:17:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Deklarasi Situasi Darurat Kota Iblis?
Dialogue: 0,0:17:59.02,0:18:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya jadi makin mencekam.
Dialogue: 0,0:18:01.48,0:18:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan Dewa Petir sudah mulai bergerak
Dialogue: 0,0:18:03.52,0:18:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai menyebabkan kerusakan di dunia nyata.
Dialogue: 0,0:18:06.40,0:18:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga butuh kekuatan\Nyang lebih kuat daripada sebelumnya.
Dialogue: 0,0:18:12.11,0:18:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang lebih kuat?
Dialogue: 0,0:18:14.28,0:18:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, mengembangkan\Nkekuatan masing-masing.
Dialogue: 0,0:18:17.24,0:18:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, memperkuat kemampuan Slave.
Dialogue: 0,0:18:20.91,0:18:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku akan secara aktif\Nmeminjamkan Yuuki.
Dialogue: 0,0:18:24.21,0:18:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik pada kalian maupun pada para Ketua.
Dialogue: 0,0:18:27.46,0:18:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skuad Tujuh akan bertambah kuat\Nbersama Yuuki.
Dialogue: 0,0:18:30.88,0:18:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut pada Delapan Dewa Petir!
Dialogue: 0,0:18:33.13,0:18:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan membuat mereka semua takluk!
Dialogue: 0,0:18:36.55,0:18:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik!
Dialogue: 0,0:18:37.55,0:18:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah diputuskan,\Nsetelah ini kita langsung latihan, Yuuki!
Dialogue: 0,0:18:41.48,0:18:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Himari kemarin sudah latihan\Nbareng Yuuki, kan?
Dialogue: 0,0:18:44.31,0:18:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya giliranku!
Dialogue: 0,0:18:46.61,0:18:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nei juga akan berjuang.
Dialogue: 0,0:18:48.23,0:18:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku akan menemanimu\Nlatihan kapan saja, Nei.
Dialogue: 0,0:18:51.82,0:18:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?\NKalau begitu, sekarang saja!
Dialogue: 0,0:18:54.91,0:18:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:18:55.66,0:18:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, curang!
Dialogue: 0,0:18:59.49,0:19:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan bergantian, ya.
Dialogue: 0,0:19:00.87,0:19:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti habis itu aku, ya!
Dialogue: 0,0:19:03.08,0:19:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tunggu, tunggu!\N- Nei juga mau latihan!
Dialogue: 0,0:19:09.04,0:19:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus sudah menemani mereka berlatih.
Dialogue: 0,0:19:11.51,0:19:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka.
Dialogue: 0,0:19:13.17,0:19:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan bersama Mira.
Dialogue: 0,0:19:14.88,0:19:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertemu lagi dengan Aoba dan yang lain.
Dialogue: 0,0:19:16.97,0:19:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rapat Ketua.
Dialogue: 0,0:19:18.80,0:19:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padat sekali yang terjadi\Nsetelah pertarungan dengan Kusetsu.
Dialogue: 0,0:19:22.18,0:19:26.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, rasanya aku sudah mau tumbang.
Dialogue: 0,0:19:26.02,0:19:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, hari ini kamu istirahat saja.
Dialogue: 0,0:19:28.69,0:19:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perintah Ketua.
Dialogue: 0,0:19:30.52,0:19:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:19:32.19,0:19:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai istirahat...
Dialogue: 0,0:19:35.24,0:19:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah selesai istirahat,\Napa kamu bisa latihan denganku?
Dialogue: 0,0:19:45.54,0:19:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:19:46.83,0:19:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bertambah kuat!
Dialogue: 0,0:19:49.08,0:19:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa melampaui Komandan Yamashiro,\Njuga untuk menjadikanmu komandan!
Dialogue: 0,0:19:55.09,0:19:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Budakku memang hebat.
Dialogue: 0,0:21:37.86,0:21:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan Yamashiro?
Dialogue: 0,0:21:40.82,0:21:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang karena mendadak\Ndapat waktu luang.
Dialogue: 0,0:21:44.45,0:21:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka mana?
Dialogue: 0,0:21:45.45,0:21:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang di Skuad Satu.
Dialogue: 0,0:21:47.20,0:21:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada perlu dengan Bu Myouga.
Dialogue: 0,0:21:49.62,0:21:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NMomennya kurang pas.
Dialogue: 0,0:21:54.54,0:21:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang masak?
Dialogue: 0,0:21:56.67,0:21:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:22:05.43,0:22:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:22:09.06,0:22:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan makan di tempat kami?
Dialogue: 0,0:22:12.10,0:22:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pemandangan yang menakjubkan.
Dialogue: 0,0:22:14.77,0:22:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dilihat-lihat,
Dialogue: 0,0:22:16.94,0:22:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara makannya pun anggun.
Dialogue: 0,0:22:21.36,0:22:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih hidangannya.
Dialogue: 0,0:22:22.61,0:22:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf hanya bisa menghidangkan ini.
Dialogue: 0,0:22:25.07,0:22:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, dia menghabiskannya tanpa sisa.
Dialogue: 0,0:22:28.41,0:22:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:22:30.20,0:22:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan tradisional yang menggambarkan musim.
Dialogue: 0,0:22:33.87,0:22:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya hadiah.
Dialogue: 0,0:22:35.71,0:22:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:36.75,0:22:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk.
Dialogue: 0,0:22:38.25,0:22:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:22:40.76,0:22:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk itu...
Dialogue: 0,0:22:43.72,0:22:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya begini!
Dialogue: 0,0:22:46.18,0:22:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elus, elus, elus!\N- Anu...
Dialogue: 0,0:22:49.85,0:22:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang
Dialogue: 0,0:22:52.81,0:22:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Anak pintar! Anak pintar!\N- sebenarnya terjadi?
Dialogue: 0,0:22:59.19,0:23:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang beda.
Dialogue: 0,0:23:01.48,0:23:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada artinya kalau dengan\NWakura Yuuki dalam mode normal.
Dialogue: 0,0:23:10.45,0:23:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mendidiknya setelah\Njadi mode slave.
Dialogue: 0,0:23:14.16,0:23:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak begitu.
Dialogue: 0,0:23:17.17,0:23:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa disebut balasan\Ndari penghinaan waktu itu.
Dialogue: 0,0:23:21.63,0:23:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti datang lagi.
Dialogue: 0,0:23:26.93,0:23:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tenang!
Dialogue: 0,0:23:28.72,0:23:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap ada bonus tambahan!
Dialogue: 0,0:23:31.01,0:23:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali giliran kalian sedikit.
Dialogue: 0,0:23:33.56,0:23:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lega karena tidak disuruh latihan.
Dialogue: 0,0:23:36.35,0:23:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan akan makin sulit.
Dialogue: 0,0:23:38.02,0:23:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikan peran dari kalian semua.
