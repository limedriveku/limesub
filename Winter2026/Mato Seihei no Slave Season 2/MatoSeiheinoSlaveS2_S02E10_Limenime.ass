Dialogue: 0,0:01:25.77,0:01:30.07,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:02:43.52,0:02:46.02,tanda,,0000,0000,0000,,EPISODE 10: PERTEMPURAN YOKOHAMA
Dialogue: 0,0:12:03.37,0:12:04.70,tanda,,0000,0000,0000,,NIRKEKAL, JARAK NOL
Dialogue: 0,0:12:52.96,0:12:54.46,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA
Dialogue: 0,0:20:39.84,0:20:41.72,tanda,,0000,0000,0000,,TITIAN SURGAWI
Dialogue: 0,0:23:26.68,0:23:30.31,tanda,,0000,0000,0000,,EPISODE 11: SLAVE DIRGANTARA
Dialogue: 0,0:23:40.02,0:23:41.04,tanda,,0000,0000,0000,,BUDAK KORPS ELITE KOTA IBLIS - MUSIM KEDUA\NIKUTI AKU, ANJING KECIL
Dialogue: 0,0:00:58.33,0:01:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyang, kenyang.
Dialogue: 0,0:01:01.71,0:01:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korps Defensi Iblis lagi?
Dialogue: 0,0:01:04.50,0:01:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku habis menyerap Mira,\Njadi masih kenyang.
Dialogue: 0,0:03:01.24,0:03:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyang, kenyang.
Dialogue: 0,0:03:04.46,0:03:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Korps Defensi Iblis lagi?
Dialogue: 0,0:03:07.06,0:03:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku habis menyerap Mira,\Njadi masih kenyang.
Dialogue: 0,0:03:27.81,0:03:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan yang indah.
Dialogue: 0,0:03:32.45,0:03:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Kapten, kekuatan Mira\Nmemang luar biasa!
Dialogue: 0,0:03:36.65,0:03:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:03:40.12,0:03:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, pujalah Kusetsu nan indah ini!
Dialogue: 0,0:04:00.47,0:04:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan Anggara Gunung Sakura!
Dialogue: 0,0:04:06.14,0:04:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang,
Dialogue: 0,0:04:08.44,0:04:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mempan!
Dialogue: 0,0:04:11.02,0:04:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan badai tebasan pun bisa dihentikan?
Dialogue: 0,0:04:23.62,0:04:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan cuma sekuat itu\Ntapi mau melawan dewa?
Dialogue: 0,0:04:27.00,0:04:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi tahu, wujud serius\NDelapan Dewa Petir lainnya lebih kuat dariku.
Dialogue: 0,0:04:36.38,0:04:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kelak aku akan melampaui mereka.
Dialogue: 0,0:04:42.64,0:04:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan kalian masih hidup
Dialogue: 0,0:04:45.10,0:04:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkat Mbak Shikoku sangat berhati-hati.
Dialogue: 0,0:04:50.02,0:04:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Wakura Yuuki, kan?
Dialogue: 0,0:04:53.44,0:04:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tadi sudah menolak ajakan indahku, ya?
Dialogue: 0,0:05:00.66,0:05:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lanjutkan dengan wujud kita sekarang.
Dialogue: 0,0:05:05.28,0:05:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:05:13.85,0:05:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kudekap dirimu.
Dialogue: 0,0:05:29.89,0:05:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita yang mendekati adikku
Dialogue: 0,0:05:33.52,0:05:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya akan kubabat habis!
Dialogue: 0,0:05:36.44,0:05:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mbak!
Dialogue: 0,0:05:38.94,0:05:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh baru?
Dialogue: 0,0:05:49.20,0:05:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan nyawa Coco dan Naon.
Dialogue: 0,0:05:56.13,0:05:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua ada di dalam tubuhnya!
Dialogue: 0,0:05:59.79,0:06:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang diserapnya masih hidup?
Dialogue: 0,0:06:02.93,0:06:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:06:05.26,0:06:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat dia memuntahkan Mira dan yang lainnya!
Dialogue: 0,0:06:07.22,0:06:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:06:08.85,0:06:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan mengalahkan Kusetsu di sini!
Dialogue: 0,0:06:12.35,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian masih bisa berkata begitu\Nsetelah melihat ini?
Dialogue: 0,0:06:24.28,0:06:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyerap Mira.
Dialogue: 0,0:06:30.04,0:06:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa menggunakan kemampuannya.
Dialogue: 0,0:06:44.26,0:06:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari hancurkan kota\Ndan sebarkan nama dewa.
Dialogue: 0,0:06:49.47,0:06:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini anak buah terbaikku!
Dialogue: 0,0:06:56.23,0:06:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti orang di depan kalian!\NTolong bergerak!
Dialogue: 0,0:06:59.86,0:07:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Unit 3 ke markas!
Dialogue: 0,0:07:01.82,0:07:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemindahan warga sipil akan segera selesai.
Dialogue: 0,0:07:06.45,0:07:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk apa itu?
Dialogue: 0,0:07:14.25,0:07:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... jurik!
Dialogue: 0,0:07:18.25,0:07:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu besar!
Dialogue: 0,0:07:24.42,0:07:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang seperti ini juga?
Dialogue: 0,0:07:26.63,0:07:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan alihkan perhatianmu, Yuuki!
Dialogue: 0,0:07:28.89,0:07:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya keputusan Mira\Nuntuk menghambatku gagal, ya!
Dialogue: 0,0:07:35.10,0:07:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira sudah benar.
Dialogue: 0,0:07:40.27,0:07:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu dibiarkan kabur,\Nnantinya akan berbahaya.
Dialogue: 0,0:07:43.65,0:07:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya,
Dialogue: 0,0:07:45.36,0:07:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia malah diserap dan jadi\Nfestival klona begini.
Dialogue: 0,0:07:52.08,0:07:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Korps Defensi Iblis!
Dialogue: 0,0:07:54.25,0:07:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan baru saja dimulai!
Dialogue: 0,0:07:59.50,0:08:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ren.
Dialogue: 0,0:08:01.79,0:08:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Administrasi bala bantuan\Nke Yokohama telah selesai!
Dialogue: 0,0:08:20.40,0:08:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan tempur khusus!
Dialogue: 0,0:08:27.82,0:08:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kukatakan sekali lagi, Kusetsu!
Dialogue: 0,0:08:30.49,0:08:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan mengalahkanmu di sini!
Dialogue: 0,0:08:33.08,0:08:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyiksa kalian\Ndengan pasukan dewa!
Dialogue: 0,0:08:45.59,0:08:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku adalah Komandan Korps Defensi Iblis!
Dialogue: 0,0:08:48.26,0:08:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah sekaligus!
Dialogue: 0,0:08:51.59,0:08:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan?
Dialogue: 0,0:08:53.35,0:08:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang paling penting?
Dialogue: 0,0:08:56.64,0:08:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia layak dikalahkan!
Dialogue: 0,0:08:58.56,0:09:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:09:01.56,0:09:02.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka terpancing.
Dialogue: 0,0:09:02.90,0:09:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pancing mereka sampai jembatan.\NJangan sampai terkejar, ya.
Dialogue: 0,0:09:06.98,0:09:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, mereka semua mudah terpancing.
Dialogue: 0,0:09:10.95,0:09:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya berkurang!\NKita harus berterima kasih pada Tobera!
Dialogue: 0,0:09:14.90,0:09:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga mulai.
Dialogue: 0,0:09:25.61,0:09:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, sudah tidak ada mobil satu pun.
Dialogue: 0,0:09:27.88,0:09:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Turun.
Dialogue: 0,0:09:28.96,0:09:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:35.14,0:09:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya banyak.
Dialogue: 0,0:09:37.64,0:09:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulur waktu untukku.
Dialogue: 0,0:09:39.59,0:09:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:43.81,0:09:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku maju!
Dialogue: 0,0:09:54.45,0:09:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Agung!
Dialogue: 0,0:10:05.63,0:10:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluru bulu.\NDahsyat sekali.
Dialogue: 0,0:10:09.26,0:10:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sekejap tangan ini\Nlangsung babak belur.
Dialogue: 0,0:10:13.76,0:10:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:10:19.97,0:10:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus menciptakan tangan\Ndan memenuhi tugasku sebagai tank!
Dialogue: 0,0:10:26.61,0:10:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar ingin lihat kamu\Nbisa bertahan sampai kapan!
Dialogue: 0,0:10:41.58,0:10:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukuman Dewa selesai, ya.
Dialogue: 0,0:11:03.81,0:11:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Tangguh juga.
Dialogue: 0,0:11:07.44,0:11:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu sudah kelelahan.
Dialogue: 0,0:11:09.94,0:11:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai penutupan, sepuluh detik lagi!
Dialogue: 0,0:11:12.15,0:11:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggaplah ini perayaan\Npenyelamatan Dewa, bagaimana?
Dialogue: 0,0:11:17.81,0:11:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:11:22.79,0:11:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, Maia.
Dialogue: 0,0:11:26.25,0:11:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bisa kuserap.
Dialogue: 0,0:11:32.88,0:11:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nirkekal!
Dialogue: 0,0:11:52.27,0:11:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:11:56.61,0:11:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merenggut daya hidupmu.
Dialogue: 0,0:12:04.70,0:12:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nirkekal, Jarak Nol!
Dialogue: 0,0:12:18.22,0:12:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, Nona Tobera.
Dialogue: 0,0:12:21.38,0:12:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hebat bisa bertahan, Maia.
Dialogue: 0,0:12:28.44,0:12:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Instingku kembali ke masa jayanya!
Dialogue: 0,0:12:33.94,0:12:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ren, kami dapat laporan\Npasukan musuh berhasil dipecah!
Dialogue: 0,0:12:40.11,0:12:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kondisi di Yokohama...
Dialogue: 0,0:12:43.20,0:12:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:12:47.37,0:12:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan turut membantu\Ndari Washington.
Dialogue: 0,0:13:10.56,0:13:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan Ren.
Dialogue: 0,0:13:12.44,0:13:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatuan alam semesta tak terhingga\Nyang meliputi segalanya.
Dialogue: 0,0:13:19.32,0:13:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan menggunakan satu kekuatan\Ndi kedua mata,
Dialogue: 0,0:13:22.20,0:13:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dayanya akan menguat.
Dialogue: 0,0:14:27.47,0:14:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin yang barusan\Ndiarahkan ke Jepang?
Dialogue: 0,0:14:32.68,0:14:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan mengenai pesawat terbang,\Njadi Anda tak perlu khawatir.
Dialogue: 0,0:14:37.44,0:14:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menggunakan kekuatan sedahsyat itu,\Ntapi tak berkeringat!
Dialogue: 0,0:14:43.53,0:14:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya saya serahkan ke anak buah saya.
Dialogue: 0,0:14:45.70,0:14:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lanjutkan rapatnya.
Dialogue: 0,0:14:48.24,0:14:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamashiro Ren.
Dialogue: 0,0:14:50.45,0:14:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar Jawaban dari Bumi.
Dialogue: 0,0:14:55.83,0:14:57.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu evakuasi darurat ada di sini!
Dialogue: 0,0:14:58.25,0:15:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong prioritaskan warga yang terluka!
Dialogue: 0,0:15:23.15,0:15:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ayo.
Dialogue: 0,0:15:25.20,0:15:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin mau terus-terusan melawanku?
Dialogue: 0,0:15:30.70,0:15:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya kekuatan yang sadis.
Dialogue: 0,0:15:38.88,0:15:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya...
Dialogue: 0,0:15:50.89,0:15:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Komandan.
Dialogue: 0,0:15:52.96,0:15:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan bantuan dari Amerika, ya.
Dialogue: 0,0:15:55.18,0:15:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking besarnya,
Dialogue: 0,0:15:56.98,0:15:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah jadi sasaran empuk.
Dialogue: 0,0:16:05.57,0:16:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal itu kesukaanku.
Dialogue: 0,0:16:09.82,0:16:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal itu kesukaanku\Nyang diberikan oleh Mbak Shikoku!
Dialogue: 0,0:16:16.58,0:16:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki!
Dialogue: 0,0:16:17.33,0:16:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:16:28.09,0:16:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hayat Burung Kayangan.
Dialogue: 0,0:16:33.60,0:16:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangkauannya luas!
Dialogue: 0,0:16:39.94,0:16:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang hebat!
Dialogue: 0,0:16:41.15,0:16:42.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenka!
Dialogue: 0,0:16:49.78,0:16:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kata saat bertempur\Nbisa menjadi perasaan yang kuat.
Dialogue: 0,0:16:55.79,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanmu tersampaikan padaku, Yuuki!
Dialogue: 0,0:17:06.21,0:17:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergerakan klonaku buruk.
Dialogue: 0,0:17:08.76,0:17:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh waktu untuk terbiasa.
Dialogue: 0,0:17:13.68,0:17:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, tubuh utamanya tidaklah lemah!
Dialogue: 0,0:17:21.94,0:17:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan pada mbakku?
Dialogue: 0,0:17:28.28,0:17:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kekuatan ini?
Dialogue: 0,0:17:34.74,0:17:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga klona?
Dialogue: 0,0:17:40.08,0:17:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini!
Dialogue: 0,0:17:45.42,0:17:49.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan menyelinap lebih cocok digunakan\Ndalam pertarungan daripada lendir.
Dialogue: 0,0:17:52.56,0:17:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan pada adikku?
Dialogue: 0,0:18:05.61,0:18:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukerahkan
Dialogue: 0,0:18:08.82,0:18:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh
Dialogue: 0,0:18:12.49,0:18:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatanku!
Dialogue: 0,0:18:48.36,0:18:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil?
Dialogue: 0,0:18:57.62,0:19:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga setingkat kapten, ya?
Dialogue: 0,0:19:27.10,0:19:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menaruh perangkap dengan\Nmenyembunyikan klona di bawah tanah?
Dialogue: 0,0:19:40.99,0:19:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bala bantuan akan kubereskan\Nsetelah mengurus kalian.
Dialogue: 0,0:19:46.29,0:19:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, aku bisa bertarung tanpa henti.
Dialogue: 0,0:19:55.38,0:19:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki.
Dialogue: 0,0:19:57.97,0:19:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lakukan Titian Surgawi!
Dialogue: 0,0:20:00.76,0:20:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu satu-satunya opsi!
Dialogue: 0,0:20:05.52,0:20:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus menguasainya!
Dialogue: 0,0:20:08.06,0:20:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:20:12.44,0:20:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jurus rahasia kalian, ya?
Dialogue: 0,0:20:16.40,0:20:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki?
Dialogue: 0,0:20:18.21,0:20:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuuki!
Dialogue: 0,0:20:41.72,0:20:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titian Surgawi!
Dialogue: 0,0:20:44.56,0:20:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mira, kami akan menyelamatkamu!
Dialogue: 0,0:22:26.41,0:22:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pancaran kekuatan yang luar biasa.
Dialogue: 0,0:22:29.12,0:22:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Wakura Yuuki?\NDia punya potensi dasar yang tinggi.
Dialogue: 0,0:22:35.13,0:22:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka.
Dialogue: 0,0:22:39.63,0:22:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Himari terlalu lama bergerak,\Nsatu keluarga Azuma harus membantunya!
Dialogue: 0,0:23:09.74,0:23:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana, mana? Biar kuajari dulu\Ncaranya mengambil inisiatif.
Dialogue: 0,0:23:14.54,0:23:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh baru telah tiba!
Dialogue: 0,0:23:17.21,0:23:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu!
Dialogue: 0,0:23:20.50,0:23:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, waktunya pertarungan terakhir!
Dialogue: 0,0:23:26.68,0:23:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, episode 11, Slave Dirgantara.
Dialogue: 0,0:23:30.31,0:23:31.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan hari ini.
Dialogue: 0,0:23:31.93,0:23:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiahnya adalah aku...
Dialogue: 0,0:23:35.73,0:23:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin mencobanya.
Dialogue: 0,0:23:37.73,0:23:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah cokelat dan diriku.
