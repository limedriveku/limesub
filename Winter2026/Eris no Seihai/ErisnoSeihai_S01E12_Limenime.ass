Dialogue: 0,0:12:58.71,0:13:01.59,tanda,,0000,0000,0000,,"PANGERAN KEDUA FARIS, RODERICK"
Dialogue: 0,0:00:03.50,0:00:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak sangat tenang.
Dialogue: 0,0:00:06.82,0:00:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:00:08.42,0:00:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih banyak waktu.
Dialogue: 0,0:00:10.99,0:00:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku akan menyerah?
Dialogue: 0,0:00:14.09,0:00:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti bertanya dan kembali bekerja!
Dialogue: 0,0:00:17.41,0:00:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar lelet.
Dialogue: 0,0:00:18.74,0:00:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:00:21.76,0:00:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun...
Dialogue: 0,0:00:25.38,0:00:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada-ada saja.
Dialogue: 0,0:00:26.63,0:00:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Apa ini?
Dialogue: 0,0:00:29.75,0:00:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini rencana perbaikan\Nbalai kota.
Dialogue: 0,0:00:34.26,0:00:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbaikan?
Dialogue: 0,0:00:36.11,0:00:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:37.26,0:00:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petir menyambar sebelum eksekusimu,\Nlalu memicu kebakaran...
Dialogue: 0,0:00:42.10,0:00:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maafkan aku.
Dialogue: 0,0:00:44.26,0:00:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa.
Dialogue: 0,0:00:46.01,0:00:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingat apa pun soal hari eksekusiku.
Dialogue: 0,0:00:49.26,0:00:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak ingat?
Dialogue: 0,0:00:51.22,0:00:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sama sekali.
Dialogue: 0,0:00:53.76,0:00:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, itu tak sepenuhnya benar.
Dialogue: 0,0:00:59.08,0:01:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum lenganku diborgol,\Nalgojo memberiku minuman buah.
Dialogue: 0,0:01:09.65,0:01:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:01:10.87,0:01:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingat apa-apa setelah meminumnya.
Dialogue: 0,0:01:13.90,0:01:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti obat penenang agar kau rileks\Nsebelum eksekusi.
Dialogue: 0,0:01:18.83,0:01:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbuat dari buah langka...
Dialogue: 0,0:01:22.05,0:01:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, orang yang memakannya\Nbisa melintasi waktu.
Dialogue: 0,0:01:28.29,0:01:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arus waktu?
Dialogue: 0,0:01:30.36,0:01:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apa ini?
Dialogue: 0,0:01:33.67,0:01:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lorong di bawah Saint Mark's Square?
Dialogue: 0,0:01:36.68,0:01:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat sempurna\Nuntuk menyembunyikan sandera.
Dialogue: 0,0:01:40.02,0:01:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:01:41.81,0:01:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor ke Keamanan Kerajaan sekarang.
Dialogue: 0,0:01:44.23,0:01:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai perintah, Nyonya!
Dialogue: 0,0:01:46.86,0:01:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat!
Dialogue: 0,0:01:51.33,0:01:52.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini...
Dialogue: 0,0:01:53.65,0:01:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan melihat dengan jelas\Nakulah yang menang pada akhirnya.
Dialogue: 0,0:03:40.40,0:03:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Datang untuk memberikan\Npukulan mematikan?
Dialogue: 0,0:03:44.31,0:03:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku benar-benar ingin membunuhmu,\Nkau sudah lama mati.
Dialogue: 0,0:03:49.10,0:03:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar...
Dialogue: 0,0:03:51.38,0:03:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bermimpi.
Dialogue: 0,0:03:53.95,0:03:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita menyelinap keluar istana
Dialogue: 0,0:03:55.91,0:03:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menonton pertunjukan jalanan di kota.
Dialogue: 0,0:04:00.37,0:04:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pulang, aku malah bertemu pencopet.
Dialogue: 0,0:04:05.63,0:04:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau langsung menangkap anak itu\Ndan mengatakan ini.
Dialogue: 0,0:04:10.69,0:04:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun alasannya, jangan jalani\Nhidup yang tak bisa kau banggakan!
Dialogue: 0,0:04:17.82,0:04:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, kau sangat jujur.
Dialogue: 0,0:04:21.10,0:04:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu semua juga cuma akting?
Dialogue: 0,0:04:24.34,0:04:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:04:26.11,0:04:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, itu kata-kata Ceci.
Dialogue: 0,0:04:29.11,0:04:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceci?
Dialogue: 0,0:04:31.21,0:04:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cece!
Dialogue: 0,0:04:36.35,0:04:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enrique.
Dialogue: 0,0:04:37.85,0:04:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kau tahu,\Naku selalu benci sifat cerobohmu.
Dialogue: 0,0:04:43.80,0:04:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi khusus hari ini...
Dialogue: 0,0:04:46.96,0:04:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupuji kecerobohanmu itu.
Dialogue: 0,0:04:50.01,0:04:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cecilia?
Dialogue: 0,0:04:57.25,0:04:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:05:03.84,0:05:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Putri Mahkota.
Dialogue: 0,0:05:06.49,0:05:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sedang ada keributan\Ndi vila kerajaan.
Dialogue: 0,0:05:09.07,0:05:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:05:10.07,0:05:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, kondisi Yang Mulia...
Dialogue: 0,0:05:13.45,0:05:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah hari eksekusi.
Dialogue: 0,0:05:15.30,0:05:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya akan rumit kalau dia mati.
Dialogue: 0,0:05:17.66,0:05:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir. Sepertinya dia hanya syok.
Dialogue: 0,0:05:22.36,0:05:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:05:33.30,0:05:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya.
Dialogue: 0,0:05:36.28,0:05:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:05:37.57,0:05:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minuman buah biasa.
Dialogue: 0,0:05:40.91,0:05:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Hamsworth.
Dialogue: 0,0:05:43.04,0:05:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gereja menyiapkannya untuk hari ini.
Dialogue: 0,0:05:46.30,0:05:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah diizinkan berada di sini.
Dialogue: 0,0:05:48.97,0:05:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Y-Ya...
Dialogue: 0,0:05:50.92,0:05:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melarangku membiarkanmu\Nmeminum sesuatu yang aneh.
Dialogue: 0,0:05:56.08,0:05:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia?
Dialogue: 0,0:06:07.53,0:06:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diperintahkan untuk membawa sandera.
Dialogue: 0,0:06:10.54,0:06:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak diberi tahu?
Dialogue: 0,0:06:12.38,0:06:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak dengar apa pun.
Dialogue: 0,0:06:14.87,0:06:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali...
Dialogue: 0,0:06:21.81,0:06:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu tumbang.
Dialogue: 0,0:06:32.04,0:06:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua tumbang.
Dialogue: 0,0:06:36.61,0:06:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Mahkota?
Dialogue: 0,0:06:48.78,0:06:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus ke kanan, dan kalian akan\Ntemukan jalan keluar di dekat alun-alun.
Dialogue: 0,0:06:55.82,0:06:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tak mendengarku?
Dialogue: 0,0:06:57.41,0:06:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat...
Dialogue: 0,0:07:00.50,0:07:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:07:10.52,0:07:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?
Dialogue: 0,0:07:15.55,0:07:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak bisa dihindari.
Dialogue: 0,0:07:17.04,0:07:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:18.09,0:07:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang ini tak bisa dihindari.
Dialogue: 0,0:07:20.14,0:07:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang bisa kita lakukan.
Dialogue: 0,0:07:21.98,0:07:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memang ditakdirkan kalah.
Dialogue: 0,0:07:24.98,0:07:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, wanita itu...
Dialogue: 0,0:07:27.83,0:07:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett Castiel\Nbenar-benar mengubah takdir.
Dialogue: 0,0:07:34.48,0:07:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Pangeran?
Dialogue: 0,0:07:38.66,0:07:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana sudi aku memberitahumu, berengsek?
Dialogue: 0,0:07:44.68,0:07:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak.
Dialogue: 0,0:07:49.84,0:07:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, semua ini bisa berakhir...
Dialogue: 0,0:07:53.79,0:07:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ceci.
Dialogue: 0,0:07:56.95,0:08:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya...\Napa aku melakukan hal yang benar?
Dialogue: 0,0:08:02.84,0:08:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:08:04.69,0:08:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara siapa yang ingin kau dengar?
Dialogue: 0,0:08:07.71,0:08:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku jadi lembek.
Dialogue: 0,0:08:13.11,0:08:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:08:15.97,0:08:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru Cece-ku!
Dialogue: 0,0:08:20.62,0:08:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceci...
Dialogue: 0,0:08:28.01,0:08:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cece.
Dialogue: 0,0:08:30.26,0:08:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:08:32.63,0:08:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku masih bisa mendengarnya.
Dialogue: 0,0:08:36.04,0:08:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara itu selalu ada,\Nseandainya aku mau mendengarkan...
Dialogue: 0,0:08:48.27,0:08:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kita?
Dialogue: 0,0:08:49.93,0:08:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihat menaranya!
Dialogue: 0,0:08:51.64,0:08:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak jauh dari Saint Mark's Square!
Dialogue: 0,0:08:56.44,0:08:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:09:01.19,0:09:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kau kenal, Uly?
Dialogue: 0,0:09:02.83,0:09:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:09:07.16,0:09:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mundur.
Dialogue: 0,0:09:08.51,0:09:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari Pangeran.
Dialogue: 0,0:09:10.90,0:09:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:09:13.23,0:09:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan May, Menteri Keuangan.
Dialogue: 0,0:09:16.08,0:09:18.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu kami di sini?
Dialogue: 0,0:09:19.15,0:09:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuntunan Dewi.
Dialogue: 0,0:09:21.74,0:09:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau babi tua itu yang muncul sih,\Ntapi biarlah.
Dialogue: 0,0:09:26.77,0:09:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kuberi kau pilihan.
Dialogue: 0,0:09:29.88,0:09:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati sekarang, atau nanti.
Dialogue: 0,0:09:33.14,0:09:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan pun itu, kau akan mati.
Dialogue: 0,0:09:43.07,0:09:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kehabisan waktu!
Dialogue: 0,0:09:44.77,0:09:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Constance...
Dialogue: 0,0:09:55.14,0:09:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti sepuluh tahun lalu...
Dialogue: 0,0:09:58.33,0:09:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pengkhianat!
Dialogue: 0,0:10:00.98,0:10:02.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak tahu malu!
Dialogue: 0,0:10:03.72,0:10:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tutup mulut kalian!
Dialogue: 0,0:10:05.99,0:10:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sumpah, kalian semua...
Dialogue: 0,0:10:08.47,0:10:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sebabnya aku muak dengan orang miskin!
Dialogue: 0,0:10:11.35,0:10:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, mulut Audrey sangat kotor.
Dialogue: 0,0:10:14.46,0:10:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miriam, kau bodoh sekali.
Dialogue: 0,0:10:16.20,0:10:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Audrey juga punya telinga yang buruk\Ndan sikap yang busuk.
Dialogue: 0,0:10:20.03,0:10:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Constance Grail tak bersalah!
Dialogue: 0,0:10:23.28,0:10:26.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mohon! Hentikan eksekusinya!
Dialogue: 0,0:10:27.32,0:10:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kate!
Dialogue: 0,0:10:29.99,0:10:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya kesaksian\Ndari mantan antek Pamela Francis!
Dialogue: 0,0:10:35.05,0:10:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, lihatlah!
Dialogue: 0,0:10:37.71,0:10:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mylene...
Dialogue: 0,0:10:48.82,0:10:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dengarkan! Aku...
Dialogue: 0,0:10:55.34,0:10:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Constance Grail!
Dialogue: 0,0:10:58.74,0:11:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas kejahatan\Npenculikan pangeran negara asing
Dialogue: 0,0:11:01.15,0:11:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merencanakan makar...
Dialogue: 0,0:11:03.62,0:11:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau dijatuhi hukuman pancung!
Dialogue: 0,0:11:19.42,0:11:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyesal...
Dialogue: 0,0:11:26.21,0:11:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali!
Dialogue: 0,0:11:35.90,0:11:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:11:45.11,0:11:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku!
Dialogue: 0,0:11:49.65,0:11:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eksekusi ini tak sah!
Dialogue: 0,0:11:51.77,0:11:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran ada di sini!
Dialogue: 0,0:11:59.88,0:12:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pangeran ketujuh Faris, Ulysses Faris.
Dialogue: 0,0:12:04.75,0:12:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diculik orang-orang\Ndari kampung halamanku, Faris!
Dialogue: 0,0:12:08.05,0:12:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu tak ada hubungannya\Ndengan penculikanku!
Dialogue: 0,0:12:12.95,0:12:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bercanda!
Dialogue: 0,0:12:14.74,0:12:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu siapa dirimu,
Dialogue: 0,0:12:16.50,0:12:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mana buktinya\Nkalau kau pangeran asli?!
Dialogue: 0,0:12:24.74,0:12:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu sudah pasti Pangeran Ulysses!
Dialogue: 0,0:12:29.96,0:12:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendall!
Dialogue: 0,0:12:31.30,0:12:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang sangat cepat.
Dialogue: 0,0:12:34.39,0:12:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tua ini memacu kudanya\Nagar tiba tepat waktu.
Dialogue: 0,0:12:38.20,0:12:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:12:39.54,0:12:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat pengakuan\Ndari sidang majelis sebelumnya.
Dialogue: 0,0:12:43.71,0:12:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau berhasil melakukannya\Ndalam waktu sesingkat ini.
Dialogue: 0,0:12:46.71,0:12:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekomendasi Pangeran Theophilis\Nmemang berperan...
Dialogue: 0,0:12:49.83,0:12:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kunjungan Raja Ernst-lah\Nyang paling menentukan.
Dialogue: 0,0:12:54.21,0:12:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undangan dari putri ketiga\Nyang kabarnya dikurung...
Dialogue: 0,0:12:58.71,0:13:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti dia sudah berhubungan
Dialogue: 0,0:13:01.59,0:13:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan Adelbide.
Dialogue: 0,0:13:02.54,0:13:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang tahu dirinya bersalah\Npasti gemetar ketakutan.
Dialogue: 0,0:13:07.51,0:13:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat berterima kasih pada Allie\Nkarena telah menggantikanku.
Dialogue: 0,0:13:11.43,0:13:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Pihak kuil juga\Nsudah memberikan persetujuan.
Dialogue: 0,0:13:16.21,0:13:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kami hanya butuh tanda tanganmu.
Dialogue: 0,0:13:20.30,0:13:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu cukup?
Dialogue: 0,0:13:21.96,0:13:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, aku senang\Nmelihat Yang Mulia selamat.
Dialogue: 0,0:13:27.11,0:13:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia?
Dialogue: 0,0:13:29.78,0:13:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:13:33.12,0:13:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Alexandra Faris.
Dialogue: 0,0:13:35.77,0:13:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pewaris sah takhta Faris...
Dialogue: 0,0:13:39.31,0:13:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, aku telah menjadi\Npermaisuri baru Faris!
Dialogue: 0,0:13:44.14,0:13:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Permaisuri baru?
Dialogue: 0,0:13:49.20,0:13:50.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak terluka?
Dialogue: 0,0:13:50.41,0:13:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak...
Dialogue: 0,0:13:54.88,0:13:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak memerah.
Dialogue: 0,0:13:56.91,0:13:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku baik-baik saja!
Dialogue: 0,0:13:58.91,0:14:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Li-Lihat? Lihat!
Dialogue: 0,0:14:02.26,0:14:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permaisuri?
Dialogue: 0,0:14:05.22,0:14:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak masuk akal!
Dialogue: 0,0:14:08.19,0:14:09.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah.
Dialogue: 0,0:14:10.87,0:14:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tahu kau punya hubungan\Ndengan Rufus May.
Dialogue: 0,0:14:14.79,0:14:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah ditangkap.
Dialogue: 0,0:14:17.30,0:14:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Riwayatmu sudah tamat.
Dialogue: 0,0:14:19.35,0:14:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alun-alun ditutup!
Dialogue: 0,0:14:21.03,0:14:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan ada eksekusi!
Dialogue: 0,0:14:23.86,0:14:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:14:25.33,0:14:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya tak begini!
Dialogue: 0,0:14:27.50,0:14:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memborgolmu.
Dialogue: 0,0:14:37.10,0:14:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan berakhir seperti ini!
Dialogue: 0,0:14:40.42,0:14:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie!
Dialogue: 0,0:14:48.79,0:14:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari!
Dialogue: 0,0:15:00.64,0:15:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie!
Dialogue: 0,0:15:07.11,0:15:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie!
Dialogue: 0,0:15:08.65,0:15:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Tolong!
Dialogue: 0,0:15:12.47,0:15:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:15:15.47,0:15:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett!
Dialogue: 0,0:15:23.59,0:15:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat ini, Constance Grail.
Dialogue: 0,0:15:28.24,0:15:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan selalu datang terlambat\Ndengan elegan.
Dialogue: 0,0:15:32.71,0:15:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett!
Dialogue: 0,0:15:34.65,0:15:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:15:35.88,0:15:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku harus repot-repot begini...
Dialogue: 0,0:15:39.85,0:15:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat bersemangat, Connie.
Dialogue: 0,0:15:47.72,0:15:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett!
Dialogue: 0,0:15:53.91,0:15:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, saat kau merasa\Ndendammu sudah terbalas...
Dialogue: 0,0:15:59.61,0:16:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan kembali pada para dewa.
Dialogue: 0,0:16:05.03,0:16:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...
Dialogue: 0,0:16:07.37,0:16:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, tidak!
Dialogue: 0,0:16:09.08,0:16:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett!
Dialogue: 0,0:16:12.96,0:16:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hapus ekspresi itu dari wajahmu,\Ndasar Connie bodoh.
Dialogue: 0,0:16:17.07,0:16:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, lihat dirimu...
Dialogue: 0,0:16:19.34,0:16:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilanmu pas-pasan,
Dialogue: 0,0:16:21.26,0:16:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau selalu gemetaran ketakutan,
Dialogue: 0,0:16:22.88,0:16:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tak bisa menyimpan rahasia,
Dialogue: 0,0:16:25.67,0:16:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau naif, bodoh,\Ndan tak pernah dengar ucapan orang.
Dialogue: 0,0:16:32.74,0:16:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa kau tahu...
Dialogue: 0,0:16:37.27,0:16:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyayangimu, Constance Grail.
Dialogue: 0,0:16:45.28,0:16:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett!
Dialogue: 0,0:16:58.63,0:16:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah.
Dialogue: 0,0:17:01.68,0:17:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi?
Dialogue: 0,0:17:04.36,0:17:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa semuanya tadi cuma mimpi?
Dialogue: 0,0:17:09.45,0:17:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nmasa depan itu takkan pernah terjadi.
Dialogue: 0,0:17:13.05,0:17:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya cuma ilusi.
Dialogue: 0,0:17:18.19,0:17:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menerimanya.
Dialogue: 0,0:17:20.99,0:17:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hari-hari itu, momen-momen itu\Ntak pernah terjadi!
Dialogue: 0,0:17:26.90,0:17:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau semuanya harus berakhir\Ndengan eksekusiku!
Dialogue: 0,0:17:31.09,0:17:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, orang yang memakannya\Nbisa melintasi arus waktu.
Dialogue: 0,0:17:37.26,0:17:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:17:39.26,0:17:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma perlu menjadikannya\Nmasa depan yang nyata.
Dialogue: 0,0:17:44.54,0:17:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk melakukannya...
Dialogue: 0,0:17:48.76,0:17:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:17:53.15,0:17:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkutuklah kau...
Dialogue: 0,0:17:55.46,0:17:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkutuklah kau.\NTerkutuklah kau, Scarlett Castiel.
Dialogue: 0,0:17:59.88,0:18:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mimpi itu ingin jadi masa depan...
Dialogue: 0,0:18:02.99,0:18:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hari-hari itu ingin jadi kenyataan...
Dialogue: 0,0:18:05.95,0:18:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang rasa malu dan kehormatanmu!
Dialogue: 0,0:18:08.03,0:18:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah roh pendendam\Ndan kembalilah ke dunia ini!
Dialogue: 0,0:18:10.81,0:18:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkutuklah kalian semua!
Dialogue: 0,0:18:17.62,0:18:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku tak tahu apa ini benar.
Dialogue: 0,0:18:21.69,0:18:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K-Kau iblis!
Dialogue: 0,0:18:23.43,0:18:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku tahu...
Dialogue: 0,0:18:25.75,0:18:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu...
Dialogue: 0,0:18:28.99,0:18:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana!
Dialogue: 0,0:18:34.74,0:18:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya baik-baik saja sekarang.
Dialogue: 0,0:18:37.17,0:18:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak takut lagi.
Dialogue: 0,0:18:39.68,0:18:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula...
Dialogue: 0,0:18:43.02,0:18:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggu di Grand Merillian.
Dialogue: 0,0:18:47.12,0:18:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau akan datang\Ndan menemukanku lagi.
Dialogue: 0,0:18:56.22,0:19:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dua bulan berlalu\Nsejak kau pergi meninggalkan kami.
Dialogue: 0,0:19:02.03,0:19:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau baik-baik saja?
Dialogue: 0,0:19:06.03,0:19:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetangga kita, Faris,\Ntelah selesaikan masalah suksesi,
Dialogue: 0,0:19:10.41,0:19:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Alexandra dinobatkan tanpa masalah.
Dialogue: 0,0:19:14.83,0:19:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, kita berhasil\Nmenghindari perang sepenuhnya.
Dialogue: 0,0:19:20.39,0:19:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari yang sama,\NPutri Mahkota Cecilia juga wafat.
Dialogue: 0,0:19:25.23,0:19:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia berkorban demi membantu\NLucia dan Pangeran Ulysses kabur.
Dialogue: 0,0:19:30.64,0:19:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang juga ditangkap.
Dialogue: 0,0:19:34.19,0:19:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang dalang, Rufus May,\Nserta para bangsawan yang terlibat.
Dialogue: 0,0:19:38.76,0:19:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesaksian Pamela terbukti palsu,
Dialogue: 0,0:19:41.60,0:19:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kudengar dia terus berusaha\Nkabur dari rumah sakit.
Dialogue: 0,0:19:46.88,0:19:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:19:48.59,0:19:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kejadian sepuluh tahun lalu\Nakhirnya terungkap juga.
Dialogue: 0,0:19:54.95,0:19:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kabar baik untukmu.
Dialogue: 0,0:19:58.11,0:20:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett, namamu akhirnya bersih.
Dialogue: 0,0:20:03.39,0:20:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, tak semua kejadian\Nsepuluh tahun lalu diketahui publik.
Dialogue: 0,0:20:10.30,0:20:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa bagian telah dibumbui,
Dialogue: 0,0:20:12.28,0:20:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan percobaan peracunan\Nyang juga dikaitkan ke Daeg Gallus.
Dialogue: 0,0:20:19.23,0:20:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mylene dan Kate\Nmenempuh jalan masing-masing.
Dialogue: 0,0:20:23.62,0:20:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucia, yang selamat\Ndan bertemu kembali dengan Nona Abigail,
Dialogue: 0,0:20:26.72,0:20:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baru-baru ini menjadi\Nsahabat pena Pangeran Ulysses.
Dialogue: 0,0:20:31.81,0:20:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan tanpa Scarlett Castiel\Nterasa tenang, damai...
Dialogue: 0,0:20:38.99,0:20:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedikit membosankan.
Dialogue: 0,0:20:41.43,0:20:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, biarkan aku mengatakan satu hal\Nsebagai penutup.
Dialogue: 0,0:20:45.95,0:20:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett bodoh...
Dialogue: 0,0:20:52.07,0:20:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Randolph.
Dialogue: 0,0:20:53.95,0:20:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:55.95,0:20:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin memanggil namamu.
Dialogue: 0,0:20:57.50,0:21:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, namaku?
Dialogue: 0,0:21:00.26,0:21:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:04.66,0:21:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie.
Dialogue: 0,0:21:05.65,0:21:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya? Ada apa?
Dialogue: 0,0:21:08.51,0:21:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin memanggil namamu.
Dialogue: 0,0:21:22.57,0:21:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, apakah itu Nona Grail?
Dialogue: 0,0:21:26.48,0:21:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Hamsworth.
Dialogue: 0,0:21:28.20,0:21:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak\Nsudah mengundang kami malam ini.
Dialogue: 0,0:21:31.42,0:21:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak masalah. Selamat datang di pameranku...
Dialogue: 0,0:21:35.60,0:21:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:21:37.64,0:21:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada anjing liar\Nmenyusup ke halaman.
Dialogue: 0,0:21:42.62,0:21:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dilakukan penjaga keamanan?
Dialogue: 0,0:21:46.05,0:21:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperiksa.
Dialogue: 0,0:21:47.74,0:21:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:49.67,0:21:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:21:51.84,0:21:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku ikut!
Dialogue: 0,0:21:55.01,0:21:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak ada di sini...
Dialogue: 0,0:22:01.09,0:22:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahmu... Ini semua salahmu...
Dialogue: 0,0:22:04.02,0:22:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}P-Pamela?
Dialogue: 0,0:22:06.07,0:22:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salahmu.
Dialogue: 0,0:22:08.44,0:22:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai kau pergi...
Dialogue: 0,0:22:10.96,0:22:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja...
Dialogue: 0,0:22:12.77,0:22:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja kau pergi!
Dialogue: 0,0:22:21.99,0:22:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:22:23.93,0:22:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun tolong aku!
Dialogue: 0,0:22:27.18,0:22:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:22:28.73,0:22:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:22:31.19,0:22:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menolongmu.
Dialogue: 0,0:22:42.10,0:22:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih saja lelet seperti biasa.
Dialogue: 0,0:22:50.66,0:22:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa?
Dialogue: 0,0:22:53.10,0:22:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Aku memikirkannya,
Dialogue: 0,0:22:55.63,0:22:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku belum membalas dendam\Npada satu orang pun!
Dialogue: 0,0:22:59.94,0:23:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:23:01.09,0:23:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memikirkannya bikin aku kesal setengah mati!
Dialogue: 0,0:23:04.28,0:23:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat cahaya putih terang,\Ntapi aku kembali demi balas dendam!
Dialogue: 0,0:23:10.11,0:23:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya itu?
Dialogue: 0,0:23:15.39,0:23:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyelamatkanmu,\Njadi aku tak terima penolakan.
Dialogue: 0,0:23:19.59,0:23:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan baik-baik, Constance Grail.
Dialogue: 0,0:23:23.05,0:23:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan menghabiskan sisa hidupmu
Dialogue: 0,0:23:26.01,0:23:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memastikan aku berhasil balas dendam.
Dialogue: 0,0:23:32.44,0:23:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
