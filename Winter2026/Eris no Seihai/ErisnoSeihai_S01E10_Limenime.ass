Dialogue: 0,0:21:43.15,0:21:45.14,tanda,,0000,0000,0000,,"PANGERAN KEDUA, JOHAN ADELBIDE"
Dialogue: 0,0:22:19.97,0:22:22.06,tanda,,0000,0000,0000,,DEMI MASA DEPAN
Dialogue: 0,0:00:01.12,0:00:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat lega.
Dialogue: 0,0:00:02.98,0:00:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kewarasanmu masih terjaga.
Dialogue: 0,0:00:05.74,0:00:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintunya hanya dikunci untuk berjaga-jaga.
Dialogue: 0,0:00:08.74,0:00:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:00:10.58,0:00:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamela Francis?
Dialogue: 0,0:00:14.07,0:00:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin membalas dendam, 'kan?
Dialogue: 0,0:00:18.74,0:00:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada Constance Grail,\Norang yang membuatmu jadi begini?
Dialogue: 0,0:00:27.00,0:00:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Constance Grail...
Dialogue: 0,0:02:04.59,0:02:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku, bagaimana keadaan Kimberly?
Dialogue: 0,0:02:07.30,0:02:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia baik-baik saja.
Dialogue: 0,0:02:08.53,0:02:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengannya terluka, tetapi dia\Nakan segera keluar dari rumah sakit.
Dialogue: 0,0:02:12.22,0:02:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:02:14.80,0:02:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan rekening rahasia itu sebagai bukti,
Dialogue: 0,0:02:16.98,0:02:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simon Darkian ditangkap\Natas pemalsuan dokumen resmi.
Dialogue: 0,0:02:21.87,0:02:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan istrinya, Deborah,
Dialogue: 0,0:02:23.14,0:02:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diduga terlibat perdagangan budak\Ndan penyelundupan Surga Jakal,
Dialogue: 0,0:02:27.58,0:02:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta akan dikirim ke Biara Rudolph.
Dialogue: 0,0:02:30.94,0:02:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, Daeg Gallus\Ntelah kehilangan pendukung terkuatnya.
Dialogue: 0,0:02:40.31,0:02:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabar kalian, Tuan dan Nona?
Dialogue: 0,0:02:42.93,0:02:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucia!
Dialogue: 0,0:02:44.27,0:02:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau keluar?
Dialogue: 0,0:02:45.66,0:02:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:47.12,0:02:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abby terlihat sangat sibuk belakangan ini,\Njadi aku ingin membelikannya kue!
Dialogue: 0,0:02:51.88,0:02:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu, ya!
Dialogue: 0,0:02:55.67,0:02:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit kupercaya Keluarga Darkian terlibat\Ndalam penyelundupan itu.
Dialogue: 0,0:03:00.30,0:03:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu Debbie tidak seperti itu.
Dialogue: 0,0:03:05.44,0:03:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apakah Simon tahu\Ndi mana Pangeran Ulysses dikurung?
Dialogue: 0,0:03:10.19,0:03:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:03:11.75,0:03:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delegasi Faris akan meninggalkan ibu kota\Ndalam beberapa hari.
Dialogue: 0,0:03:16.18,0:03:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita tak menemukan Pangeran\Nsebelum itu...
Dialogue: 0,0:03:19.06,0:03:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah akan terjadi perang?
Dialogue: 0,0:03:24.80,0:03:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah tidak ada jaringan Daeg Gallus
Dialogue: 0,0:03:26.96,0:03:28.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang punya properti di sekitar pelabuhan?
Dialogue: 0,0:03:28.98,0:03:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelabuhan?
Dialogue: 0,0:03:31.59,0:03:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penculiknya adalah pedagang dengan\Nwarna kulit yang langka di daerah ini.
Dialogue: 0,0:03:37.01,0:03:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tak ada satu pun\Nsaksi mata yang melihatnya.
Dialogue: 0,0:03:40.46,0:03:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia pasti bersembunyi
Dialogue: 0,0:03:42.83,0:03:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di tempat orang sepertinya bisa\Nkeluar-masuk tanpa dicurigai.
Dialogue: 0,0:03:47.45,0:03:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu katanya.
Dialogue: 0,0:03:49.59,0:03:52.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Chiara Grafton!
Dialogue: 0,0:03:52.95,0:03:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah keluarganya mencakup area dermaga.
Dialogue: 0,0:03:55.60,0:03:58.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia dari Daeg Gallus!
Dialogue: 0,0:03:58.58,0:04:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti punya gudang yang cocok\Nuntuk menyembunyikan orang.
Dialogue: 0,0:04:02.74,0:04:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita selidiki.
Dialogue: 0,0:04:04.66,0:04:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku ikut!
Dialogue: 0,0:04:10.67,0:04:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abby!
Dialogue: 0,0:04:12.95,0:04:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kau tak apa-apa.
Dialogue: 0,0:04:15.22,0:04:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:16.89,0:04:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru dapat kabar.
Dialogue: 0,0:04:18.54,0:04:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Deborah Darkian melarikan diri dari biara.
Dialogue: 0,0:04:26.58,0:04:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa kau marah\Nkarena aku memaksa ikut?
Dialogue: 0,0:04:31.61,0:04:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku hanya meyakinkan diriku sendiri.
Dialogue: 0,0:04:34.78,0:04:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik mengawasimu di sini daripada\Nmembiarkanmu luput dari pandanganku.
Dialogue: 0,0:04:39.96,0:04:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar juga.
Dialogue: 0,0:04:44.49,0:04:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:04:46.18,0:04:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku tak perlu memantaumu\Nlebih lama lagi.
Dialogue: 0,0:04:49.82,0:04:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:51.75,0:04:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu Pangeran Ulysses ditemukan\Ndan semuanya terungkap,
Dialogue: 0,0:04:56.12,0:04:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tujuan kalian berdua akan tercapai.
Dialogue: 0,0:04:59.79,0:05:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:05:00.73,0:05:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku tak mau mendengarnya.
Dialogue: 0,0:05:04.13,0:05:09.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, saat waktunya tiba,\Nkita harus membatalkan pertunangan kita.
Dialogue: 0,0:05:10.24,0:05:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, dengan cara\Nyang takkan menyudutkanmu.
Dialogue: 0,0:05:15.47,0:05:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan, Tuanku?
Dialogue: 0,0:05:21.66,0:05:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau takkan menikah dengan siapa pun?
Dialogue: 0,0:05:28.27,0:05:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan.
Dialogue: 0,0:05:30.11,0:05:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku tak bisa\Nmemberikan kebahagiaan pada siapa pun.
Dialogue: 0,0:05:38.69,0:05:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang bodoh.
Dialogue: 0,0:05:43.52,0:05:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Lucia, belanjaanmu banyak sekali.
Dialogue: 0,0:05:46.23,0:05:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:47.14,0:05:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abby pasti akan sangat senang.
Dialogue: 0,0:05:51.80,0:05:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:05:53.60,0:05:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuambilkan!
Dialogue: 0,0:06:06.53,0:06:08.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:06:08.66,0:06:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berteriak,\Nakan kugorok lehernya.
Dialogue: 0,0:06:11.72,0:06:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Lucia...
Dialogue: 0,0:06:15.91,0:06:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lepaskan dia, Nyonya Deborah.
Dialogue: 0,0:06:19.09,0:06:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menginginkanku, 'kan?
Dialogue: 0,0:06:27.52,0:06:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gudangnya?
Dialogue: 0,0:06:29.72,0:06:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, sepi sekali.
Dialogue: 0,0:06:32.47,0:06:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengintip ke dalam.
Dialogue: 0,0:06:36.46,0:06:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie.
Dialogue: 0,0:06:37.84,0:06:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:06:49.36,0:06:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:06:58.39,0:06:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak apa-apa?
Dialogue: 0,0:06:59.33,0:07:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:01.01,0:07:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie!
Dialogue: 0,0:07:06.53,0:07:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana mereka?
Dialogue: 0,0:07:08.02,0:07:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana!
Dialogue: 0,0:07:09.63,0:07:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya di atas atap itu!
Dialogue: 0,0:07:17.19,0:07:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyergap kita?
Dialogue: 0,0:07:19.01,0:07:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tanda-tanda\Nmereka pindah dengan terburu-buru.
Dialogue: 0,0:07:21.46,0:07:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mencurigai kita!
Dialogue: 0,0:07:24.07,0:07:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang memancing musuh.
Dialogue: 0,0:07:26.09,0:07:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manfaatkan kesempatan ini untuk lari.
Dialogue: 0,0:07:28.03,0:07:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:29.34,0:07:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett.
Dialogue: 0,0:07:31.04,0:07:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan Nona Grail padamu.
Dialogue: 0,0:07:32.40,0:07:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:07:48.94,0:07:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku!
Dialogue: 0,0:07:50.00,0:07:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang!
Dialogue: 0,0:07:52.11,0:07:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir apa yang bisa kau lakukan?!
Dialogue: 0,0:07:54.04,0:07:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia bisa...
Dialogue: 0,0:07:56.15,0:07:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kita lakukan, Scarlett?
Dialogue: 0,0:08:03.43,0:08:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya memburuk.
Dialogue: 0,0:08:06.01,0:08:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Nona Grail\Nsudah tiba di tempat aman?
Dialogue: 0,0:08:14.57,0:08:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:08:16.61,0:08:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah situasi ini,\Naku hanya memedulikan keselamatannya.
Dialogue: 0,0:08:22.47,0:08:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya pergi.
Dialogue: 0,0:08:32.53,0:08:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu Scarlett?
Dialogue: 0,0:08:36.77,0:08:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku memintanya menjaga Nona Grail.
Dialogue: 0,0:08:39.83,0:08:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, dia takkan pernah\Nmenuruti perintah orang lain.
Dialogue: 0,0:08:43.26,0:08:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutemukan dia! Di sini!
Dialogue: 0,0:08:46.74,0:08:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:57.68,0:09:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi wajahmu menyedihkan sekali.
Dialogue: 0,0:09:00.47,0:09:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlett! Apa dia baik-baik saja?!
Dialogue: 0,0:09:03.84,0:09:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:09:05.42,0:09:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku ini siapa?
Dialogue: 0,0:09:08.16,0:09:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:09:14.91,0:09:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku!
Dialogue: 0,0:09:18.40,0:09:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka?
Dialogue: 0,0:09:20.20,0:09:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah kusuruh lari.
Dialogue: 0,0:09:22.84,0:09:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bodoh, Tuanku!
Dialogue: 0,0:09:26.57,0:09:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan pernah bisa meninggalkanmu\Ndan lari begitu saja!
Dialogue: 0,0:09:29.94,0:09:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh! Ayolah!
Dialogue: 0,0:09:32.18,0:09:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu... Tuanku yang bodoh!
Dialogue: 0,0:09:34.69,0:09:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan yang bodoh?
Dialogue: 0,0:09:36.81,0:09:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:09:38.01,0:09:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku bodoh, Tuanku memang bodoh!
Dialogue: 0,0:09:40.05,0:09:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:09:46.44,0:09:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tertawa?
Dialogue: 0,0:09:50.24,0:09:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa... kau menangis?
Dialogue: 0,0:09:55.04,0:09:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:09:56.87,0:09:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku menyuruhmu lari...
Dialogue: 0,0:09:58.15,0:09:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:09:59.26,0:10:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut kau mati!
Dialogue: 0,0:10:01.90,0:10:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak menyadarinya?
Dialogue: 0,0:10:03.77,0:10:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku bodoh, kau benar-benar bodoh!
Dialogue: 0,0:10:10.86,0:10:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:10:12.71,0:10:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:10:15.74,0:10:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut kehilangan dirimu.
Dialogue: 0,0:10:22.66,0:10:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sama, Connie.
Dialogue: 0,0:10:27.00,0:10:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir kau akan kumaafkan\Nhanya dengan senyuman itu.
Dialogue: 0,0:10:38.99,0:10:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau mau...
Dialogue: 0,0:10:44.35,0:10:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau mau memaafkanku...
Dialogue: 0,0:10:47.87,0:10:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menghabiskan\Nsisa hidupku bersamamu.
Dialogue: 0,0:10:55.07,0:10:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:10:57.03,0:10:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau.
Dialogue: 0,0:10:59.62,0:11:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kumaafkan.
Dialogue: 0,0:11:02.11,0:11:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak ada seorang pun atau\Nbahkan para dewa yang memaafkanmu...
Dialogue: 0,0:11:07.87,0:11:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kumaafkan segalanya.
Dialogue: 0,0:11:10.18,0:11:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau tak perlu mengkhawatirkan\Napa pun, Tuanku.
Dialogue: 0,0:11:17.27,0:11:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada yang berani mengkritikmu...
Dialogue: 0,0:11:22.41,0:11:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutampar mereka.
Dialogue: 0,0:11:25.60,0:11:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu bisa meyakinkanku.
Dialogue: 0,0:11:27.26,0:11:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:30.18,0:11:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang perkataanmu itu\Nmembuatku takjub.
Dialogue: 0,0:11:34.13,0:11:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku akan berusaha menjadi lebih baik.
Dialogue: 0,0:11:41.43,0:11:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukanlah.
Dialogue: 0,0:11:50.18,0:11:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau menaruh dendam atas hal ini,\Ndendamlah pada Abigail.
Dialogue: 0,0:11:54.13,0:11:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abby tak melakukan kesalahan apa pun!
Dialogue: 0,0:11:57.10,0:11:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.
Dialogue: 0,0:11:58.20,0:12:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang dia lakukan benar.
Dialogue: 0,0:12:00.97,0:12:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat muak dengannya.
Dialogue: 0,0:12:03.62,0:12:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kukirimkan kepalamu padanya,\Nbagaimana ekspresi si munafik itu, ya?
Dialogue: 0,0:12:12.25,0:12:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti.
Dialogue: 0,0:12:14.54,0:12:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salvador?
Dialogue: 0,0:12:16.62,0:12:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku.
Dialogue: 0,0:12:18.55,0:12:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati,\Nakan selalu kulakukan.
Dialogue: 0,0:12:21.53,0:12:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku punya prinsip\Nuntuk tak membunuh anak-anak.
Dialogue: 0,0:12:28.63,0:12:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kembalilah ke biara...
Dialogue: 0,0:12:32.31,0:12:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, jadilah anak baik dan alihkan\Nperhatian Keamanan Kerajaan.
Dialogue: 0,0:12:36.85,0:12:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu siapa aku?
Dialogue: 0,0:12:40.20,0:12:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tapi kami tak bisa membiarkanmu\Nterlalu banyak bicara.
Dialogue: 0,0:12:44.58,0:12:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin sekali merobek lidahmu, tetapi...
Dialogue: 0,0:12:51.58,0:12:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajar saja dia\Nsampai tak bisa bicara.
Dialogue: 0,0:12:55.46,0:12:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Tidak!
Dialogue: 0,0:13:00.92,0:13:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kau boleh pergi sekarang.
Dialogue: 0,0:13:04.13,0:13:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku...
Dialogue: 0,0:13:12.47,0:13:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Instingmu tajam.
Dialogue: 0,0:13:21.00,0:13:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memberinya makanan layak.
Dialogue: 0,0:13:24.19,0:13:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Ulysses masih hidup.
Dialogue: 0,0:13:27.24,0:13:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa dia tak dibunuh?
Dialogue: 0,0:13:31.15,0:13:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama Uly diculik negara ini,\NFaris punya alasan untuk berperang.
Dialogue: 0,0:13:38.24,0:13:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika calon raja, Theophilis,\Nberada di balik semua ini,
Dialogue: 0,0:13:41.98,0:13:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uly pasti sudah disingkirkan.
Dialogue: 0,0:13:45.25,0:13:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena satu-satunya pewaris\Ndengan mata biru keunguan
Dialogue: 0,0:13:49.29,0:13:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang melambangkan darah bangsawan murni
Dialogue: 0,0:13:51.42,0:13:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanyalah Uly dan aku.
Dialogue: 0,0:13:53.89,0:13:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyatanya, Pangeran Ulysses dibiarkan hidup.
Dialogue: 0,0:13:57.79,0:14:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,\NTheophilis bukanlah dalangnya.
Dialogue: 0,0:14:01.26,0:14:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kandidat lain yang belum\Nmelepaskan hak waris takhta...
Dialogue: 0,0:14:08.54,0:14:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eularia. Mari kita temui Kendall.
Dialogue: 0,0:14:11.89,0:14:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theophilis bukan musuh kita.
Dialogue: 0,0:14:15.10,0:14:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh kita\Nadalah pangeran kedua, Roderick.
Dialogue: 0,0:14:20.78,0:14:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana perginya Lucia?
Dialogue: 0,0:14:23.78,0:14:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abigail dan yang lain sudah mencarinya,\Ntetapi belum ada petunjuk apa pun.
Dialogue: 0,0:14:29.95,0:14:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Deborah ditemukan dalam keadaan\Ntak bisa berbicara dengan jelas.
Dialogue: 0,0:14:34.44,0:14:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:14:36.96,0:14:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Constance Grail.
Dialogue: 0,0:14:42.02,0:14:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak berjumpa.
Dialogue: 0,0:14:44.25,0:14:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamela?
Dialogue: 0,0:14:45.93,0:14:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak berubah sedikit pun.
Dialogue: 0,0:14:49.81,0:14:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganku?
Dialogue: 0,0:14:51.48,0:14:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sedikit berubah, 'kan?
Dialogue: 0,0:14:55.43,0:15:00.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku melihatmu belum lama ini.
Dialogue: 0,0:15:00.45,0:15:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di gudang dekat dermaga wilayah Grafton.
Dialogue: 0,0:15:03.44,0:15:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kau salah orang.
Dialogue: 0,0:15:06.44,0:15:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:15:09.70,0:15:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, kalau begitu.
Dialogue: 0,0:15:17.05,0:15:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Ernst pergi ke Melvina?
Dialogue: 0,0:15:20.69,0:15:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Granat di gudang itu\Nmenggunakan bahan peledak
Dialogue: 0,0:15:23.78,0:15:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diselundupkan\Nsecara ilegal dari Melvina.
Dialogue: 0,0:15:28.03,0:15:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai imbalan\Nkarena menutup mata atas masalah ini,
Dialogue: 0,0:15:30.09,0:15:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia ingin membuat perjanjian perdagangan\Nsenjata dan bubuk mesiu dengan mereka,
Dialogue: 0,0:15:33.14,0:15:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}demi mengendalikan Faris.
Dialogue: 0,0:15:36.58,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan peledak dari Melvina?
Dialogue: 0,0:15:39.33,0:15:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat dari Lily juga menyinggung hal itu.
Dialogue: 0,0:15:43.18,0:15:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memintanya mengangkut bahan peledak\Nyang diselundupkan melalui Melvina.
Dialogue: 0,0:15:47.18,0:15:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Mahkota Cecilia!
Dialogue: 0,0:15:52.70,0:15:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?!
Dialogue: 0,0:15:54.99,0:15:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tak diberi tahu\Nsoal perjanjian dagang dengan Melvina!
Dialogue: 0,0:15:59.58,0:16:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:16:01.38,0:16:04.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mereka berbatasan dengan wilayah\NKeluarga Ruzé tempatmu dibesarkan.
Dialogue: 0,0:16:04.60,0:16:08.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya memungkinkan\Nperdagangan bebas dengan mereka...
Dialogue: 0,0:16:09.29,0:16:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa kau tampak begitu panik?
Dialogue: 0,0:16:13.49,0:16:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku menantikan hari ini.
Dialogue: 0,0:16:17.11,0:16:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bahan peledak selundupanmu\Ndigunakan di kerajaan ini.
Dialogue: 0,0:16:23.66,0:16:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kau mengetahuinya?
Dialogue: 0,0:16:26.25,0:16:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu alasanku menikahimu\Nmeski semua orang menentangnya?
Dialogue: 0,0:16:31.05,0:16:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, kenapa Ayah\Ndan Duke Castiel merestuinya?
Dialogue: 0,0:16:36.09,0:16:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama ini?
Dialogue: 0,0:16:39.98,0:16:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak masalah dengan ini?
Dialogue: 0,0:16:41.39,0:16:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika hal ini tersebar, kau juga bisa\Ndituduh berbuat kejahatan.
Dialogue: 0,0:16:47.03,0:16:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belum menyadarinya?
Dialogue: 0,0:16:52.46,0:16:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi polosku sudah lama mati.
Dialogue: 0,0:17:01.43,0:17:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar ceroboh.
Dialogue: 0,0:17:09.58,0:17:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang, tolong!
Dialogue: 0,0:17:11.41,0:17:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enrique diserang!
Dialogue: 0,0:17:17.61,0:17:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak membunuhnya?
Dialogue: 0,0:17:19.95,0:17:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih putra mahkota.
Dialogue: 0,0:17:21.97,0:17:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih mudah bagiku untuk bersandiwara\Nsaat dia masih hidup.
Dialogue: 0,0:17:26.01,0:17:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:17:27.95,0:17:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulysses sudah dipindahkan\Nke sel bawah tanah.
Dialogue: 0,0:17:31.11,0:17:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini persiapannya sudah matang.
Dialogue: 0,0:17:34.48,0:17:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal tak terduga yang terjadi...
Dialogue: 0,0:17:38.22,0:17:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi sekaranglah kesempatan kita.
Dialogue: 0,0:17:41.45,0:17:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tapi sebelumnya,
Dialogue: 0,0:17:46.88,0:17:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menyingkirkan\Nsiapa pun yang mungkin ikut campur.
Dialogue: 0,0:17:56.13,0:17:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu murni kebetulan.
Dialogue: 0,0:17:59.32,0:18:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berita! Berita!
Dialogue: 0,0:18:01.85,0:18:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menculik seorang pangeran?
Dialogue: 0,0:18:03.80,0:18:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya Faris siap berperang!
Dialogue: 0,0:18:07.75,0:18:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengunjungi wilayah Grafton\Natas saran dokterku.
Dialogue: 0,0:18:12.86,0:18:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana, secara kebetulan...
Dialogue: 0,0:18:14.79,0:18:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat temanku mendorong anak\Nyang menangis ke dalam kereta!
Dialogue: 0,0:18:19.62,0:18:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena penasaran, aku menghampirinya\Nuntuk menanyakan hal itu.
Dialogue: 0,0:18:24.55,0:18:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tatapan panik,\Ndia bilang bahwa aku salah orang.
Dialogue: 0,0:18:29.48,0:18:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dipikir-pikir lagi,\Nitu pasti Pangeran Ulysses.
Dialogue: 0,0:18:35.21,0:18:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah taktik mereka?
Dialogue: 0,0:18:36.81,0:18:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau Constance Grail?
Dialogue: 0,0:18:39.75,0:18:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bersekongkol dalam penculikan\NPangeran Ulysses dari Faris,
Dialogue: 0,0:18:42.90,0:18:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau kami tahan.
Dialogue: 0,0:18:47.37,0:18:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak melakukan kesalahan apa pun.
Dialogue: 0,0:18:49.87,0:18:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Randolph Ulster pelakunya?
Dialogue: 0,0:18:52.88,0:18:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:55.10,0:18:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya saksi yang melihat\NUlster menodongkan pistolnya.
Dialogue: 0,0:19:00.54,0:19:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begitu rupanya.
Dialogue: 0,0:19:02.81,0:19:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti juga\Nsedang diinterogasi sekarang.
Dialogue: 0,0:19:06.52,0:19:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini memperlambat\Npencarian Pangeran Ulysses
Dialogue: 0,0:19:09.94,0:19:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membawa kita makin dekat dengan perang.
Dialogue: 0,0:19:15.43,0:19:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie?
Dialogue: 0,0:19:16.94,0:19:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, akulah yang membantu\Npenculikan Pangeran Ulysses.
Dialogue: 0,0:19:23.28,0:19:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang membantuku.
Dialogue: 0,0:19:25.54,0:19:30.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Organisasi kejam yang rela membunuh\Ndemi mencapai tujuan mereka.
Dialogue: 0,0:19:30.04,0:19:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau!
Dialogue: 0,0:19:31.95,0:19:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama organisasinya...
Dialogue: 0,0:19:33.29,0:19:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti!
Dialogue: 0,0:19:35.49,0:19:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daeg Gallus.
Dialogue: 0,0:19:38.42,0:19:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Connie bodoh!
Dialogue: 0,0:19:40.47,0:19:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau sudah mencatatnya?
Dialogue: 0,0:19:43.56,0:19:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya informasi lain juga.
Dialogue: 0,0:19:45.50,0:19:48.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Cukup.
Dialogue: 0,0:19:48.18,0:19:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:19:50.66,0:19:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong panggil Viscount Hamsworth untukku.
Dialogue: 0,0:19:54.00,0:19:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertunanganku\Ndengan Earl Randolph Ulster...
Dialogue: 0,0:19:58.13,0:19:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membatalkannya.
Dialogue: 0,0:20:03.42,0:20:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuanku! Mereka melepaskanmu?
Dialogue: 0,0:20:07.22,0:20:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau pikirkan?!
Dialogue: 0,0:20:09.47,0:20:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tak memutuskan hubungan kita,\Nkau takkan bisa bebas.
Dialogue: 0,0:20:16.45,0:20:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan meninggalkanku?
Dialogue: 0,0:20:24.70,0:20:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kelak masalah ini berakhir\Ndan kita semua bisa tertawa kembali,
Dialogue: 0,0:20:30.05,0:20:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin memaksakan perasaanku\Npada seseorang.
Dialogue: 0,0:20:34.22,0:20:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kuat, baik hati, dan selalu adil.
Dialogue: 0,0:20:40.63,0:20:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, dia orang bodoh yang mengira
Dialogue: 0,0:20:43.10,0:20:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}takkan pernah bisa memberikan\Nkebahagiaan pada siapa pun.
Dialogue: 0,0:20:48.35,0:20:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini giliranku\Nuntuk melamarnya.
Dialogue: 0,0:20:54.99,0:20:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu akan sulit.
Dialogue: 0,0:20:57.49,0:20:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:58.99,0:21:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ada yang akan melamarmu\Nlebih dulu sebelum itu terjadi.
Dialogue: 0,0:21:03.20,0:21:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria membosankan yang tak bisa melucu
Dialogue: 0,0:21:06.11,0:21:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak tahu\Nharus kencan ke mana.
Dialogue: 0,0:21:26.75,0:21:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahiku?
Dialogue: 0,0:21:29.07,0:21:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini kita bukan tunangan...
Dialogue: 0,0:21:37.19,0:21:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Johan, Yang Mulia.
Dialogue: 0,0:21:40.37,0:21:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda sudah mengambil keputusan?
Dialogue: 0,0:21:43.15,0:21:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuatku mengulanginya.
Dialogue: 0,0:21:45.15,0:21:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanyalah pengganti raja.
Dialogue: 0,0:21:51.28,0:21:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu milik putriku!
Dialogue: 0,0:21:53.47,0:21:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut.
Dialogue: 0,0:21:55.02,0:21:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putrimu takkan terluka sedikit pun.
Dialogue: 0,0:21:59.10,0:22:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya untuk saat ini.
Dialogue: 0,0:22:02.96,0:22:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faris ingin berperang.
Dialogue: 0,0:22:06.22,0:22:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya cara\Nmeredakan kemarahan mereka
Dialogue: 0,0:22:08.90,0:22:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Anda harus bertindak tegas.
Dialogue: 0,0:22:12.16,0:22:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan mengeksekusi sang penculik\Ndi depan umum, Constance Grail.
