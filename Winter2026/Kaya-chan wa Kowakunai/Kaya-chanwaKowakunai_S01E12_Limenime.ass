Dialogue: 0,0:00:33.55,0:00:34.97,tanda,,0000,0000,0000,,TELEPON MASUK: SATOU SHIZUO
Dialogue: 0,0:01:34.99,0:01:38.75,tanda,,0000,0000,0000,,EPISODE 12: KAYA-CHAN TIDAK MENAKUTKAN
Dialogue: 0,0:05:14.75,0:05:17.67,tanda,,0000,0000,0000,,MISI OHARA-SAMA
Dialogue: 0,0:11:38.34,0:11:40.89,tanda,,0000,0000,0000,,SEMUA MALAPETAKA DIALIHKAN\NPADA EBISUMORI MUTSU
Dialogue: 0,0:15:37.21,0:15:39.71,tanda,,0000,0000,0000,,YOSHIE
Dialogue: 0,0:15:40.09,0:15:42.71,tanda,,0000,0000,0000,,HATSU, MICHIKO, YOSHIE, FUMI, AKI
Dialogue: 0,0:15:42.71,0:15:44.46,tanda,,0000,0000,0000,,EBISUMORI MIRAI
Dialogue: 0,0:20:34.38,0:20:36.38,tanda,,0000,0000,0000,,SEDANG OPERASI
Dialogue: 0,0:20:42.10,0:20:44.10,tanda,,0000,0000,0000,,SEDANG OPERASI
Dialogue: 0,0:21:40.40,0:21:43.16,tanda,,0000,0000,0000,,TK HANAMUGI
Dialogue: 0,0:22:02.18,0:22:06.26,tanda,,0000,0000,0000,,KARTU PENGUNJUNG: SATOU KAYA
Dialogue: 0,0:23:36.48,0:23:39.98,tanda,,0000,0000,0000,,TAMAT
Dialogue: 0,0:00:02.27,0:00:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:00:03.48,0:00:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah tahu tentang kematian bibinya,
Dialogue: 0,0:00:05.11,0:00:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ibu dari Nona Kaya juga menyadari
Dialogue: 0,0:00:06.99,0:00:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa dirinya makhluk yang dilahirkan\Nuntuk mengandung benda kutukan?
Dialogue: 0,0:00:10.28,0:00:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berencana menggunakan kutukan itu\Nuntuk menghancurkan keluarga Ebisumori?
Dialogue: 0,0:00:15.29,0:00:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:17.08,0:00:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar...
Dialogue: 0,0:00:18.46,0:00:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, aku tahu ada permusuhan\Nyang mendalam di antara kalian.
Dialogue: 0,0:00:21.67,0:00:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak ada cara untuk menghentikannya?
Dialogue: 0,0:00:23.59,0:00:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyuruhku untuk mengorbankan diri?
Dialogue: 0,0:00:27.09,0:00:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar juga.
Dialogue: 0,0:00:33.55,0:00:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizuo?
Dialogue: 0,0:00:36.02,0:00:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, ini Nana.
Dialogue: 0,0:00:37.06,0:00:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana.
Dialogue: 0,0:00:37.98,0:00:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai tiba-tiba\Nmenghilang dari rumah sakit!
Dialogue: 0,0:00:41.02,0:00:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kehilangan banyak darah!
Dialogue: 0,0:00:43.44,0:00:47.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perawat bilang dia mungkin panik\Ndan lari dari rumah sakit...
Dialogue: 0,0:00:47.32,0:00:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali dengan Kaya.
Dialogue: 0,0:00:49.65,0:00:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi merepotkanmu lagi.
Dialogue: 0,0:00:50.86,0:00:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tutup telepon dulu.
Dialogue: 0,0:00:53.28,0:00:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sudah mendengarnya.
Dialogue: 0,0:01:01.50,0:01:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana.
Dialogue: 0,0:01:03.38,0:01:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau langsung kembali begitu saja?
Dialogue: 0,0:01:05.71,0:01:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Mutsu meninggal karena kutukan itu...
Dialogue: 0,0:01:08.38,0:01:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:01:10.51,0:01:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku meninggal karena menerima\Nkutukan itu sebagai penggantiku,
Dialogue: 0,0:01:15.05,0:01:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekarang benda itu belum selesai.
Dialogue: 0,0:01:17.85,0:01:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama induknya masih hidup, kekuatannya\Ntidak dapat sepenuhnya terwujud.
Dialogue: 0,0:01:23.02,0:01:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai tidak boleh kehilangan nyawanya.
Dialogue: 0,0:01:27.94,0:01:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya untuk diriku sendiri,
Dialogue: 0,0:01:30.53,0:01:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga untuk Kaya.
Dialogue: 0,0:01:33.82,0:01:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:01:38.75,0:01:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan, cepat ikut aku!
Dialogue: 0,0:01:45.17,0:01:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:01:46.46,0:01:49.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya beri tahu aku\Nbagaimana menghadapinya.
Dialogue: 0,0:01:49.59,0:01:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara paling aman\Nadalah mengeluarkannya secara manual.
Dialogue: 0,0:01:54.43,0:01:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik itu miko atau Ebisu,\Nproses kelahirannya sama saja.
Dialogue: 0,0:01:57.81,0:02:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan sebelum "itu"\Nmengambil nyawa induknya,
Dialogue: 0,0:02:00.06,0:02:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melahirkan dengan normal saja sudah cukup.
Dialogue: 0,0:02:02.73,0:02:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:02:04.27,0:02:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari situasi ini,
Dialogue: 0,0:02:05.81,0:02:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mungkin merasa rumah sakit\Nakan memaksakan persalinan buatan.
Dialogue: 0,0:02:10.78,0:02:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti kasus Kaya dulu.
Dialogue: 0,0:02:14.16,0:02:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perut yang hampir melahirkan\Ndan penuh darah pasti sangat mencolok.
Dialogue: 0,0:02:19.24,0:02:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu banyak waktu\Nuntuk menemukannya.
Dialogue: 0,0:02:26.25,0:02:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa memikirkan sisanya\Nsetelah anak itu lahir.
Dialogue: 0,0:02:45.56,0:02:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak apa-apa?
Dialogue: 0,0:02:48.86,0:02:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan!
Dialogue: 0,0:02:50.11,0:02:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah!
Dialogue: 0,0:02:56.32,0:02:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia di sini?
Dialogue: 0,0:02:59.41,0:03:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berjalan kaki...
Dialogue: 0,0:03:02.04,0:03:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kondisi fisik seperti itu,\Ndia datang ke sini?
Dialogue: 0,0:03:05.67,0:03:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu jadi seperti ini?
Dialogue: 0,0:03:09.46,0:03:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai...
Dialogue: 0,0:03:13.05,0:03:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:03:13.92,0:03:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dirasuki.
Dialogue: 0,0:03:16.55,0:03:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru.
Dialogue: 0,0:03:17.84,0:03:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu sudah menyimpang terlalu jauh.
Dialogue: 0,0:03:21.43,0:03:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa hidup saja sudah beruntung.
Dialogue: 0,0:03:32.11,0:03:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:03:35.95,0:03:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan!
Dialogue: 0,0:03:39.32,0:03:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak malang.
Dialogue: 0,0:03:41.16,0:03:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:03:42.37,0:03:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang melibatkanmu dalam hal ini.
Dialogue: 0,0:03:45.71,0:03:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:03:47.79,0:03:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menemaninya sejauh ini,
Dialogue: 0,0:03:50.00,0:03:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti karena kamu peduli pada Kaya.
Dialogue: 0,0:03:55.01,0:03:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:57.43,0:03:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:03:59.09,0:04:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak perlu khawatir.
Dialogue: 0,0:04:02.05,0:04:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster keluarga Ebisumori yang menjijikkan,
Dialogue: 0,0:04:05.14,0:04:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan lenyap\Nhari ini tanpa kecuali.
Dialogue: 0,0:04:09.81,0:04:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas perawatannya.
Dialogue: 0,0:04:13.32,0:04:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kenapa jadi begini?
Dialogue: 0,0:04:16.36,0:04:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya adalah sesuatu yang berharga bagimu!
Dialogue: 0,0:04:20.66,0:04:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menamai bayi itu Kaya.
Dialogue: 0,0:04:24.04,0:04:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya?
Dialogue: 0,0:04:25.08,0:04:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama yang sangat unik.
Dialogue: 0,0:04:27.29,0:04:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak pertama selalu diberi nama yang unik.
Dialogue: 0,0:04:31.42,0:04:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tradisi keluarga kami.
Dialogue: 0,0:04:36.59,0:04:37.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:04:39.30,0:04:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau perempuan, kita beri nama Kaya.
Dialogue: 0,0:04:43.55,0:04:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:04:45.43,0:04:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau anak laki-laki?
Dialogue: 0,0:04:49.27,0:04:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti perempuan.
Dialogue: 0,0:04:52.77,0:04:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini 119, apa ada kebakaran\Natau keadaan darurat?
Dialogue: 0,0:04:55.40,0:04:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keadaan darurat!
Dialogue: 0,0:04:56.69,0:04:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istriku jatuh dari tangga!
Dialogue: 0,0:04:58.53,0:05:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang hamil!
Dialogue: 0,0:05:02.53,0:05:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Satou.
Dialogue: 0,0:05:07.41,0:05:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melahirkan anak perempuan.
Dialogue: 0,0:05:12.71,0:05:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal...
Dialogue: 0,0:05:14.75,0:05:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengikuti instruksi Bibi Yoshie.
Dialogue: 0,0:05:18.38,0:05:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada kesalahan di menit terakhir.
Dialogue: 0,0:05:21.72,0:05:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih hidup.
Dialogue: 0,0:05:23.80,0:05:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini hanya mendapatkan\Nsatu masalah kehidupan lagi.
Dialogue: 0,0:05:33.31,0:05:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:05:33.90,0:05:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suami yang biasa.
Dialogue: 0,0:05:36.40,0:05:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak perempuan yang biasa.
Dialogue: 0,0:05:38.61,0:05:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang biasa saja.
Dialogue: 0,0:05:41.24,0:05:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keseharianku sangat bahagia sehingga\Nmasa laluku jadi tidak berarti lagi.
Dialogue: 0,0:05:47.12,0:05:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini pertanda bagiku untuk melepaskan\Nsegalanya dan hidup seperti biasa.
Dialogue: 0,0:05:55.17,0:05:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:05:57.57,0:05:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi...
Dialogue: 0,0:05:58.67,0:06:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia memukul apa?\N- Dia baru saja mulai belajar berjalan.
Dialogue: 0,0:06:01.59,0:06:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mungkin hanya perasaanku.
Dialogue: 0,0:06:03.96,0:06:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Kaya itu biasa...
Dialogue: 0,0:06:07.22,0:06:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama, itu apa?
Dialogue: 0,0:06:10.60,0:06:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:11.89,0:06:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:06:14.90,0:06:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:06:16.36,0:06:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama tidak bisa melihatnya?
Dialogue: 0,0:06:22.90,0:06:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Kaya adalah hal berharga bagiku.
Dialogue: 0,0:06:26.28,0:06:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu,
Dialogue: 0,0:06:28.41,0:06:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berharap dia bisa mengakhiri hidupnya\Nsebagai "putriku yang berharga".
Dialogue: 0,0:06:33.12,0:06:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin...
Dialogue: 0,0:06:34.79,0:06:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar keterlaluan!
Dialogue: 0,0:06:37.29,0:06:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan bukan miko keluarga Ebisumori.
Dialogue: 0,0:06:40.55,0:06:41.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membencinya!
Dialogue: 0,0:06:41.92,0:06:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku tidak membenci Kaya.
Dialogue: 0,0:06:45.55,0:06:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:06:47.18,0:06:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kutukan yang akan segera lahir ini,
Dialogue: 0,0:06:48.97,0:06:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mengejar keturunan Ebisumori sampai\Ngaris keturunannya punah.
Dialogue: 0,0:06:53.68,0:06:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya juga tidak bisa lari dari kutukan ini.
Dialogue: 0,0:06:55.69,0:06:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nlebih baik aku saja yang mati, kan?
Dialogue: 0,0:06:58.46,0:06:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana.
Dialogue: 0,0:06:59.57,0:07:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu sudah meninggal.
Dialogue: 0,0:07:01.19,0:07:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan aku juga menghilang,\Nkeluarga ini akan punah.
Dialogue: 0,0:07:03.94,0:07:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ini bisa membebaskanmu\Ndari kutukan keluarga ini...
Dialogue: 0,0:07:06.95,0:07:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja pandai\Nberpura-pura jadi korban.
Dialogue: 0,0:07:10.45,0:07:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya alat untuk melahirkan benda terkutuk,\Ntapi kamu sama sekali tidak menyebutkannya.
Dialogue: 0,0:07:15.58,0:07:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kamu salah paham.
Dialogue: 0,0:07:18.71,0:07:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah paham?
Dialogue: 0,0:07:19.95,0:07:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu memang melahirkan kita\Nsesuai dengan tugasnya.
Dialogue: 0,0:07:25.17,0:07:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia selalu takut kamu\Nakan jadi Ohara-sama.
Dialogue: 0,0:07:30.60,0:07:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah Bibi Yoshie meninggal,
Dialogue: 0,0:07:32.72,0:07:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}giliranmu juga makin dekat.
Dialogue: 0,0:07:35.60,0:07:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu selalu mempersiapkan\Njalan keluar untukmu!
Dialogue: 0,0:07:40.19,0:07:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar kamu bisa meninggalkan rumah ini\Ntanpa sepengetahuanmu
Dialogue: 0,0:07:42.86,0:07:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak akan pernah berpikir\Nuntuk kembali.
Dialogue: 0,0:07:46.86,0:07:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu alasan Ibu tidak bisa\Nmemberitahukanmu kebenarannya.
Dialogue: 0,0:07:49.39,0:07:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diucapkan, Ibu takut kalau rasa curiga\Nakan menyebar di antara anak-anaknya.
Dialogue: 0,0:07:55.66,0:07:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu berharap kebencian berhenti\Npada generasi orang tua kita.
Dialogue: 0,0:08:01.25,0:08:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana.
Dialogue: 0,0:08:03.38,0:08:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah kenapa Ibu rela dibenci olehmu
Dialogue: 0,0:08:06.76,0:08:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memaksamu dikirim ke dunia luar.
Dialogue: 0,0:08:10.72,0:08:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski masa itu membuatmu menderita,
Dialogue: 0,0:08:13.56,0:08:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia juga berharap suatu hari\Nkamu bisa menjauh dari rumah ini
Dialogue: 0,0:08:20.23,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hidup bahagia di tempat lain.
Dialogue: 0,0:08:23.52,0:08:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengada-ada!
Dialogue: 0,0:08:26.65,0:08:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja menganggap dirimu\Nsebagai sosok yang rela berkorban.
Dialogue: 0,0:08:30.78,0:08:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang dihina, disiksa,\Ndan terluka adalah aku.
Dialogue: 0,0:08:36.08,0:08:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengubah seolah-olah perjuangan\Nhidupku itu berkat jasa kalian!
Dialogue: 0,0:08:44.09,0:08:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali!
Dialogue: 0,0:08:46.05,0:08:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai, kumohon kembalilah ke rumah sakit...
Dialogue: 0,0:08:51.01,0:08:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halangi aku!
Dialogue: 0,0:08:52.97,0:08:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati di sini!
Dialogue: 0,0:08:55.06,0:08:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutukan akan lahir di sini!
Dialogue: 0,0:08:57.64,0:09:01.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya akan terhapus,\Nseolah-olah tidak pernah ada.
Dialogue: 0,0:09:02.15,0:09:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga!
Dialogue: 0,0:09:03.94,0:09:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga begitu!
Dialogue: 0,0:09:06.40,0:09:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya juga sama!
Dialogue: 0,0:09:14.62,0:09:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar ceroboh, kalau ingin marah\Nperhatikan dulu sekitarmu.
Dialogue: 0,0:09:19.71,0:09:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan, kamu baik-baik saja?
Dialogue: 0,0:09:22.67,0:09:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu...
Dialogue: 0,0:09:25.08,0:09:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memalukan.
Dialogue: 0,0:09:29.30,0:09:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:09:30.13,0:09:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mob.
Dialogue: 0,0:09:31.47,0:09:35.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru bilang tempat paling aman saat ini adalah\Nruangan tempat foto mendiang Nenek Mutsu.
Dialogue: 0,0:09:38.02,0:09:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi!
Dialogue: 0,0:09:40.68,0:09:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak keluarga cabang yang diusir.
Dialogue: 0,0:09:44.31,0:09:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu mengharapkan\Nkehancuran Ebisumori?
Dialogue: 0,0:09:49.27,0:09:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tertarik sedikit pun\Npada perselisihan internal keluarga utama.
Dialogue: 0,0:09:53.41,0:09:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku berutang budi pada nenek itu.
Dialogue: 0,0:09:58.05,0:10:00.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya datang\Nuntuk melunasi utang itu saja.
Dialogue: 0,0:10:01.79,0:10:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:10:03.79,0:10:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku salah mengira.
Dialogue: 0,0:10:05.61,0:10:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, jangankan melindungi Osamu,
Dialogue: 0,0:10:08.30,0:10:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sendiri juga akan mati duluan.
Dialogue: 0,0:10:14.13,0:10:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira nenek ini\Ntidak akan mati meski dibunuh.
Dialogue: 0,0:10:19.85,0:10:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:10:22.64,0:10:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat berani melakukan\Nhal di luar kemampuanmu.
Dialogue: 0,0:10:26.76,0:10:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak keluarga cabang.
Dialogue: 0,0:10:29.03,0:10:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Mutsu.
Dialogue: 0,0:10:35.11,0:10:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak yang cerdas.
Dialogue: 0,0:10:37.74,0:10:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan mengesampingkan kebencian\Ndemi mencapai tujuanmu?
Dialogue: 0,0:10:42.25,0:10:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulurkan tanganmu.
Dialogue: 0,0:10:44.04,0:10:46.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membawanya untukmu.
Dialogue: 0,0:10:47.79,0:10:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menatapku dengan curiga seperti itu.
Dialogue: 0,0:10:50.34,0:10:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah yang tersisa dari hidupku.
Dialogue: 0,0:10:53.34,0:10:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sudah tua, kamu akan mengerti.
Dialogue: 0,0:11:01.56,0:11:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah orang yang dibuang sepertiku\Nbisa berumur panjang?
Dialogue: 0,0:11:04.89,0:11:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:11:06.35,0:11:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:11:07.52,0:11:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski kamu tinggal di Ebisumori,\Nbelum tentu berumur panjang.
Dialogue: 0,0:11:14.95,0:11:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, bisakah kamu membantuku?
Dialogue: 0,0:11:19.12,0:11:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meminta bantuanku?
Dialogue: 0,0:11:27.50,0:11:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sampaikan hal ini untukku.
Dialogue: 0,0:11:30.54,0:11:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupercayakan padamu.
Dialogue: 0,0:11:32.34,0:11:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan seenakmu begitu...
Dialogue: 0,0:11:42.35,0:11:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah pesan terakhir Ebisumori Mutsu.
Dialogue: 0,0:11:53.61,0:11:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk putri-putriku,
Dialogue: 0,0:11:56.53,0:11:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semoga kalian bisa hidup bahagia.
Dialogue: 0,0:12:06.46,0:12:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur karena sangat pendek\Ndan tidak perlu dicatat.
Dialogue: 0,0:12:11.42,0:12:12.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:12:14.71,0:12:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Osamu, kita pergi.
Dialogue: 0,0:12:16.47,0:12:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:17.88,0:12:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, bagaimana dengan Nona Kaya\Ndan yang lainnya?
Dialogue: 0,0:12:20.09,0:12:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita harus bertempur\Nsampai akhir untuk Nona Kaya?
Dialogue: 0,0:12:23.60,0:12:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang?
Dialogue: 0,0:12:24.93,0:12:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berniat mempertaruhkan nyawaku.
Dialogue: 0,0:12:27.02,0:12:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik nyawaku maupun nyawamu.
Dialogue: 0,0:12:29.81,0:12:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Utang budi sudah lunas.\N- Guru, bukankah kamu tidak punya SIM?
Dialogue: 0,0:12:31.73,0:12:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sekarang uruslah masalah kalian sendiri.\N- Guru, bukankah kamu tidak punya SIM?
Dialogue: 0,0:12:39.28,0:12:40.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat cari jalan keluar.
Dialogue: 0,0:12:40.49,0:12:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pikirkan...
Dialogue: 0,0:12:43.24,0:12:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada cara.
Dialogue: 0,0:12:44.62,0:12:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya\Nmenghentikan ibu Kaya-chan?
Dialogue: 0,0:12:47.00,0:12:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tetap di sini,\Ntidak ada yang terselesaikan.
Dialogue: 0,0:12:49.87,0:12:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau makhluk itu benar-benar lahir,
Dialogue: 0,0:12:53.00,0:12:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan bisa...
Dialogue: 0,0:12:55.80,0:12:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:12:59.34,0:13:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Kaya-chan.
Dialogue: 0,0:13:01.43,0:13:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru akan melindungimu dengan baik.
Dialogue: 0,0:13:04.89,0:13:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru ketakutan?
Dialogue: 0,0:13:06.39,0:13:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:07.54,0:13:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takut?
Dialogue: 0,0:13:09.77,0:13:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia yang menghadapinya,\Nkenapa bertanya padaku?
Dialogue: 0,0:13:16.03,0:13:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketakutan...
Dialogue: 0,0:13:19.49,0:13:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:13:21.28,0:13:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanmu terlalu mudah\Nterlihat di wajah.
Dialogue: 0,0:13:23.28,0:13:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama saat menghadapi kesulitan,\Nsangat jelas terlihat.
Dialogue: 0,0:13:25.83,0:13:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:13:26.99,0:13:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak mudah merasakan perubahan emosi.
Dialogue: 0,0:13:31.83,0:13:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:13:33.00,0:13:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat seperti ini,
Dialogue: 0,0:13:35.79,0:13:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tersenyumlah dulu.
Dialogue: 0,0:13:37.30,0:13:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:38.30,0:13:41.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hanya pura-pura,\Ntunjukkan senyuman penuh percaya diri.
Dialogue: 0,0:13:41.38,0:13:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut pada apa pun.
Dialogue: 0,0:13:44.64,0:13:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai kecemasan menular ke anak.
Dialogue: 0,0:13:47.31,0:13:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah sikap guru profesional\Nyang seharusnya.
Dialogue: 0,0:13:52.85,0:13:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:13:54.02,0:13:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hanya pura-pura,
Dialogue: 0,0:13:55.52,0:13:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetaplah penuh percaya diri.
Dialogue: 0,0:13:59.11,0:14:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:14:00.53,0:14:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya sedikit kaget\Ndan tidak merasa takut sama sekali.
Dialogue: 0,0:14:09.16,0:14:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, di sini ada Kaya-chan yang bisa\Ndengan mudah mengatasi hantu apa pun.
Dialogue: 0,0:14:14.17,0:14:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kaya pernah berjanji.
Dialogue: 0,0:14:17.99,0:14:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi bayi dengan baik.
Dialogue: 0,0:14:20.67,0:14:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya harus melindungi bayi bersama\NPapa dan Mama.
Dialogue: 0,0:14:27.16,0:14:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Kaya tidak melindungi bayi\Ndengan baik,
Dialogue: 0,0:14:30.71,0:14:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama jadi marah.
Dialogue: 0,0:14:34.44,0:14:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:36.02,0:14:38.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya bukan takut pada makhluk itu.
Dialogue: 0,0:14:38.02,0:14:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, takut melanggar janji ibu.
Dialogue: 0,0:14:42.32,0:14:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi anak-anak, perkataan orang tua
Dialogue: 0,0:14:44.53,0:14:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seringkali menjadi belenggu terkuat.
Dialogue: 0,0:14:46.78,0:14:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:14:48.91,0:14:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya bertindak dengan dendam\Ndan tekad yang begitu dalam.
Dialogue: 0,0:14:51.87,0:14:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bujukan dariku tidaklah cukup.
Dialogue: 0,0:14:54.41,0:14:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya agar ibu Kaya\Nbisa berubah pikiran?
Dialogue: 0,0:15:00.59,0:15:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:15:01.71,0:15:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pernah kuperlihatkan ke Nenek.
Dialogue: 0,0:15:04.63,0:15:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diperlihatkan ke Nenek?
Dialogue: 0,0:15:09.14,0:15:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:15:13.06,0:15:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai.
Dialogue: 0,0:15:14.85,0:15:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri-putriku?
Dialogue: 0,0:15:17.69,0:15:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:15:19.48,0:15:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan terakhir itu\Nseharusnya hanya untuk Nana.
Dialogue: 0,0:15:22.69,0:15:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dari awal tidak pernah\Ndianggap manusia.
Dialogue: 0,0:15:26.20,0:15:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bukan orang seperti itu.
Dialogue: 0,0:15:28.53,0:15:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti juga menyadarinya, kan?
Dialogue: 0,0:15:30.27,0:15:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama perempuan keluarga Ebisumori...
Dialogue: 0,0:15:34.08,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya anak sulung yang memiliki pola.
Dialogue: 0,0:15:37.21,0:15:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan setelah anak kedua
Dialogue: 0,0:15:38.13,0:15:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak menggunakan kanji.
Dialogue: 0,0:15:40.09,0:15:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang lain bisa langsung melihatnya.
Dialogue: 0,0:15:44.46,0:15:47.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, nama yang ibu berikan padamu...
Dialogue: 0,0:15:47.47,0:15:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:15:48.89,0:15:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya membicarakan hal itu sekarang?
Dialogue: 0,0:15:51.64,0:15:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mutsu sudah meninggal!
Dialogue: 0,0:15:53.47,0:15:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera menjadi Ohara-sama\Nlalu mati.
Dialogue: 0,0:15:56.35,0:15:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya juga...
Dialogue: 0,0:15:59.35,0:16:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:00.88,0:16:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya di mana...
Dialogue: 0,0:16:02.11,0:16:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya!
Dialogue: 0,0:16:06.36,0:16:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai!
Dialogue: 0,0:16:07.95,0:16:08.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:16:09.64,0:16:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya adalah putriku!
Dialogue: 0,0:16:13.12,0:16:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mendampinginya\Ndi akhir hayatnya.
Dialogue: 0,0:16:17.56,0:16:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan Kaya padaku!
Dialogue: 0,0:16:19.50,0:16:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai, jangan ke sana!
Dialogue: 0,0:16:21.75,0:16:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:22.34,0:16:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai!
Dialogue: 0,0:16:23.30,0:16:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:25.38,0:16:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit...
Dialogue: 0,0:16:31.43,0:16:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:16:32.97,0:16:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bantu mereka...
Dialogue: 0,0:16:34.97,0:16:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:37.02,0:16:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:39.19,0:16:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?
Dialogue: 0,0:16:40.56,0:16:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:42.48,0:16:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:44.73,0:16:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:16:51.70,0:16:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di mana...
Dialogue: 0,0:16:55.37,0:16:56.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang.
Dialogue: 0,0:16:56.37,0:16:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?
Dialogue: 0,0:16:57.37,0:16:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Satou!
Dialogue: 0,0:16:59.83,0:17:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satou?
Dialogue: 0,0:17:01.12,0:17:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa, ya?
Dialogue: 0,0:17:03.03,0:17:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya Satou Kaya!
Dialogue: 0,0:17:07.26,0:17:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:17:09.25,0:17:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya?
Dialogue: 0,0:17:11.05,0:17:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana dia?
Dialogue: 0,0:17:13.05,0:17:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Hasumi, wali murid anak Anda!
Dialogue: 0,0:17:15.09,0:17:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku datang untuk membahas\Nperkembangan masa depannya dengan Anda!
Dialogue: 0,0:17:18.77,0:17:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:17:21.06,0:17:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Anda, Kaya-chan.
Dialogue: 0,0:17:23.77,0:17:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya dia selalu sendirian\Nkarena tidak ada yang memahami dirinya.
Dialogue: 0,0:17:28.40,0:17:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia menunjukkan perkembangan\Nyang hebat belakangan ini.
Dialogue: 0,0:17:32.03,0:17:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anak yang sangat kami nantikan\Npertumbuhannya di masa depan.
Dialogue: 0,0:17:35.28,0:17:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih ingin terus menyaksikan\Nmasa depan Kaya-chan.
Dialogue: 0,0:17:39.45,0:17:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda juga tidak perlu menjadi\N"Ohara-sama dari Ebisumori".
Dialogue: 0,0:17:43.08,0:17:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melainkan sebagai "Ibu Kaya"!
Dialogue: 0,0:17:44.42,0:17:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali tidak mungkin!
Dialogue: 0,0:17:47.13,0:17:50.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya hanyalah anak kecil\Nyang tidak tahu apa-apa.
Dialogue: 0,0:17:51.05,0:17:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dia besar nanti, dia akan menjadi\Nmonster seperti Mutsu dan Nana.
Dialogue: 0,0:17:55.47,0:17:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya yang bisa kulakukan\Nsebelum menjadi seperti itu,
Dialogue: 0,0:17:58.39,0:18:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah pergi mati bersamanya.
Dialogue: 0,0:18:02.56,0:18:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mata Kaya,
Dialogue: 0,0:18:04.44,0:18:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang sebenarnya sudah lama mati.
Dialogue: 0,0:18:07.32,0:18:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham dari caranya memandangku.
Dialogue: 0,0:18:10.86,0:18:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang, Mama...
Dialogue: 0,0:18:14.45,0:18:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Kaya.
Dialogue: 0,0:18:16.28,0:18:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama sekarang sedikit...
Dialogue: 0,0:18:20.29,0:18:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama tidak boleh!
Dialogue: 0,0:18:21.46,0:18:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru, selamat datang.
Dialogue: 0,0:18:30.13,0:18:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk sepertiku,
Dialogue: 0,0:18:31.13,0:18:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kulit yang membungkus monster ini,
Dialogue: 0,0:18:32.67,0:18:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mungkin Kaya menganggapku\Nsebagai ibunya!
Dialogue: 0,0:18:36.01,0:18:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkan anak kecil!
Dialogue: 0,0:18:39.56,0:18:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bilang dia kecil\Ndan tidak tahu apa-apa?
Dialogue: 0,0:18:41.73,0:18:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak menganggapmu sebagai ibunya?
Dialogue: 0,0:18:44.27,0:18:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana menjelaskan ini?
Dialogue: 0,0:18:52.28,0:18:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:18:53.44,0:18:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah gambar yang sangat disayangi\NKaya-chan saat di TK.
Dialogue: 0,0:18:57.62,0:18:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan anak yang tidak mengerti apa-apa.
Dialogue: 0,0:19:00.08,0:19:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan dalam keadaan seperti ini,
Dialogue: 0,0:19:01.58,0:19:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia masih memegang janji\N"harus menjaga bayi dengan baik",
Dialogue: 0,0:19:04.16,0:19:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari ibunya yang sangat dicintainya.
Dialogue: 0,0:19:08.34,0:19:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat yakin\Ndengan gambaran masa depannya.
Dialogue: 0,0:19:15.18,0:19:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan adalah anak yang luar biasa.
Dialogue: 0,0:19:17.51,0:19:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan Anda, sebagai ibunya berharap,
Dialogue: 0,0:19:19.51,0:19:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia memiliki kekuatan untuk mewujudkan\Ngambar ini menjadi kenyataan.
Dialogue: 0,0:19:23.10,0:19:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harapan...
Dialogue: 0,0:19:31.23,0:19:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:19:37.24,0:19:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, jangan.
Dialogue: 0,0:19:38.87,0:19:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat!
Dialogue: 0,0:19:40.83,0:19:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa...
Dialogue: 0,0:19:45.04,0:19:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak boleh mendekat!
Dialogue: 0,0:19:46.62,0:19:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat Mama seperti ini...
Dialogue: 0,0:19:50.50,0:19:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:19:53.76,0:19:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:19:55.84,0:19:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya...
Dialogue: 0,0:19:58.59,0:20:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya tidak takut dengan Mama.
Dialogue: 0,0:20:04.31,0:20:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:20:06.39,0:20:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong Mama dan bayi ini, ya?
Dialogue: 0,0:20:57.57,0:20:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya!
Dialogue: 0,0:20:58.86,0:21:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini upacara penutupan,\Nbersiaplah untuk pergi.
Dialogue: 0,0:21:02.62,0:21:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah siap semuanya?
Dialogue: 0,0:21:04.16,0:21:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah siap.
Dialogue: 0,0:21:05.62,0:21:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Kaya.
Dialogue: 0,0:21:08.37,0:21:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan hadir\Ndi upacara kenaikan kelas nanti.
Dialogue: 0,0:21:12.13,0:21:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama jalannya sempoyongan.
Dialogue: 0,0:21:13.96,0:21:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:21:14.75,0:21:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengurusnya sampai malam.
Dialogue: 0,0:21:16.42,0:21:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:21:17.84,0:21:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku dirawat, semua urusan\Naku serahkan padamu.
Dialogue: 0,0:21:21.05,0:21:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku juga banyak merepotkan.
Dialogue: 0,0:21:23.93,0:21:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikirkan itu.
Dialogue: 0,0:21:26.39,0:21:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berempat selamat saja sudah cukup.
Dialogue: 0,0:21:43.66,0:21:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini upacara penutupan.
Dialogue: 0,0:21:46.16,0:21:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak TK A hari ini lulus.
Dialogue: 0,0:21:48.58,0:21:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat April tiba,\Nkalian semua akan menjadi apa?
Dialogue: 0,0:21:50.87,0:21:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak TK B.
Dialogue: 0,0:21:53.63,0:21:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kalian akan menjadi kakak tertua.
Dialogue: 0,0:21:57.17,0:21:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu bisa di sini?
Dialogue: 0,0:22:00.47,0:22:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:22:02.18,0:22:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memintaku menyuap fotografer kemarin.
Dialogue: 0,0:22:06.26,0:22:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah termasuk melanggar hukum.
Dialogue: 0,0:22:09.22,0:22:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah evakuasi, Mob segera membantu\Nmemanggil ambulans.
Dialogue: 0,0:22:13.44,0:22:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dia, Mirai dan bayi\Ndalam kandungannya selamat.
Dialogue: 0,0:22:18.94,0:22:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini tidak seberapa\Ndibanding bantuannya waktu itu.
Dialogue: 0,0:22:21.86,0:22:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, benar juga.
Dialogue: 0,0:22:23.86,0:22:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin membalas kebaikan Bu Chie.
Dialogue: 0,0:22:27.03,0:22:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:22:29.08,0:22:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berhasil menenangkan Mirai\Ndan membantu Kaya mengusir janin kutukannya.
Dialogue: 0,0:22:34.50,0:22:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil aku bisa melakukannya sendiri.
Dialogue: 0,0:22:38.50,0:22:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersyukur bisa meminta bantuanmu.
Dialogue: 0,0:22:42.11,0:22:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak melakukan apa-apa.
Dialogue: 0,0:22:44.72,0:22:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena dia tumbuh\Nsebagai anak yang jujur hingga saat ini.
Dialogue: 0,0:22:49.47,0:22:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itulah, hati ibunya bisa tersentuh.
Dialogue: 0,0:22:54.48,0:22:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini adalah hasil usaha\NKaya-chan sendiri.
Dialogue: 0,0:22:57.48,0:22:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tidak butuh imbalan apa pun.
Dialogue: 0,0:23:01.23,0:23:05.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan bisa terus menyaksikan masa depannya,\Nitu sudah sangat memuaskan.
Dialogue: 0,0:23:06.78,0:23:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak,\Nsekarang kita akan foto bersama!
Dialogue: 0,0:23:09.95,0:23:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:23:13.04,0:23:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berbaris dengan rapi, ya.
Dialogue: 0,0:23:16.46,0:23:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman Mob juga ada.
Dialogue: 0,0:23:18.21,0:23:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:23:18.96,0:23:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang lihat ke kamera, ya.
Dialogue: 0,0:23:21.76,0:23:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tersenyum.
Dialogue: 0,0:23:23.92,0:23:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, semuanya bilang "cheese"!
