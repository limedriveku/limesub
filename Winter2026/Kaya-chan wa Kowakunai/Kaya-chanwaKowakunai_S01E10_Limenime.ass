Dialogue: 0,0:01:15.05,0:01:17.68,tanda,,0000,0000,0000,,KAYA-CHAN ISN'T SCARY
Dialogue: 0,0:01:30.28,0:01:34.37,tanda,,0000,0000,0000,,EPISODE 10: PETAK UMPET TIDAK MENAKUTKAN
Dialogue: 0,0:01:55.93,0:01:59.89,tanda,,0000,0000,0000,,APA SEBENARNYA ITU?
Dialogue: 0,0:04:15.03,0:04:18.52,tanda,,0000,0000,0000,,KELAS ORIGAMI YANG MENYENANGKAN
Dialogue: 0,0:11:21.95,0:11:24.71,tanda,,0000,0000,0000,,KAMERA TIDAK MENAKUTKAN
Dialogue: 0,0:15:42.13,0:15:43.84,tanda,,0000,0000,0000,,BIBI NANA TIDAK MENAKUTKAN?
Dialogue: 0,0:16:22.25,0:16:23.39,tanda,,0000,0000,0000,,SEMUA MALAPETAKA DIALIHKAN PADA EBISUMORI NANA
Dialogue: 0,0:16:40.81,0:16:42.56,tanda,,0000,0000,0000,,RUANG KONSELING
Dialogue: 0,0:17:02.13,0:17:03.50,tanda,,0000,0000,0000,,SILSILAH KELUARGA EBISUMORI
Dialogue: 0,0:18:03.77,0:18:06.52,tanda,,0000,0000,0000,,LELUHUR KELUARGA EBISUMORI
Dialogue: 0,0:20:08.56,0:20:10.44,tanda,,0000,0000,0000,,POS PERAWAT
Dialogue: 0,0:21:01.45,0:21:03.95,tanda,,0000,0000,0000,,SATOU MIRAI
Dialogue: 0,0:22:05.43,0:22:09.93,tanda,,0000,0000,0000,,SEMUA MALAPETAKA DIALIHKAN\NPADA EBISUMORI MUTSU
Dialogue: 0,0:01:31.24,0:01:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang bernama Namu terlalu menakutkan!
Dialogue: 0,0:01:34.37,0:01:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie, apa yang terjadi dengan guruku?
Dialogue: 0,0:01:36.99,0:01:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bertanya apa yang terjadi?
Dialogue: 0,0:01:38.54,0:01:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin membunuh Kaya-chan!
Dialogue: 0,0:01:40.29,0:01:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tuduhan palsu.
Dialogue: 0,0:01:42.09,0:01:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya pengusiran setan\Nberarti menghancurkan roh jahat?
Dialogue: 0,0:01:46.79,0:01:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menyembunyikan orang ini?
Dialogue: 0,0:01:48.67,0:01:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Guru bilang ingin berbagi\Ndata investigasi Nona Kaya.
Dialogue: 0,0:01:52.55,0:01:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, apa sebenarnya rencanamu?
Dialogue: 0,0:01:55.93,0:01:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa banyak hal yang tidak beres.
Dialogue: 0,0:01:59.89,0:02:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya mengikuti\Ncara penamaan keluarga utama.
Dialogue: 0,0:02:01.81,0:02:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia anak sulung sekaligus cenayang.
Dialogue: 0,0:02:03.81,0:02:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya dia\Nmenjadi kepala keluarga berikutnya.
Dialogue: 0,0:02:06.27,0:02:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia hidup biasa di luar keluarga.
Dialogue: 0,0:02:08.97,0:02:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi bentuk aslinya\Nadalah monster semacam itu.
Dialogue: 0,0:02:12.40,0:02:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terus menyebut keluarga utama.
Dialogue: 0,0:02:15.24,0:02:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu dari keluarga Ebisumori?
Dialogue: 0,0:02:17.70,0:02:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku berasal dari cabang keluarga Ebisumori.
Dialogue: 0,0:02:20.50,0:02:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kanji-nya berbeda.
Dialogue: 0,0:02:21.83,0:02:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbeda dengan Ebisumori keluarga utama.
Dialogue: 0,0:02:24.42,0:02:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang keluarga Namu adalah garis keturunan\Nsampingan tanpa kekuatan cenayang.
Dialogue: 0,0:02:28.84,0:02:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang dari cabang keluarga
Dialogue: 0,0:02:30.51,0:02:35.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menganggap anak-anak miko keluarga utama\Nseperti dewa dan melayani mereka.
Dialogue: 0,0:02:35.59,0:02:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah.
Dialogue: 0,0:02:37.55,0:02:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah tidak yakin?
Dialogue: 0,0:02:39.10,0:02:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi...
Dialogue: 0,0:02:40.68,0:02:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diusir dari rumah\Nsekitar usia empat atau lima tahun.
Dialogue: 0,0:02:44.31,0:02:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini\Npewarisan sifat lintas generasi.
Dialogue: 0,0:02:46.52,0:02:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak lahir,\Naku bisa melihat bentuk asli para miko.
Dialogue: 0,0:02:50.32,0:02:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lama setelah aku mengatakannya,
Dialogue: 0,0:02:52.61,0:02:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dikirim ke lembaga itu.
Dialogue: 0,0:02:54.32,0:02:57.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat sesuatu\Nyang bisa merusak hidup seorang anak,
Dialogue: 0,0:02:57.95,0:03:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sesuatu\Nyang mereka tutup-tutupi mati-matian.
Dialogue: 0,0:03:00.08,0:03:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberadaan yang lebih jahat dari itu,
Dialogue: 0,0:03:03.33,0:03:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang lepas dari kendali pengawasnya,\Nmenjadi anak TK.
Dialogue: 0,0:03:07.21,0:03:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:03:08.21,0:03:11.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kamu bisa mengerti\Nkenapa aku merasa lebih baik mengusirnya?
Dialogue: 0,0:03:11.55,0:03:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu memang berniat\Nmenyingkirkan Kaya-chan, ya.
Dialogue: 0,0:03:15.09,0:03:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika perlu, aku akan melakukannya.
Dialogue: 0,0:03:17.47,0:03:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru yang mengubah makhluk itu kembali\Njadi manusia dan menyelamatkannya.
Dialogue: 0,0:03:20.89,0:03:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertanggung jawablah\Nuntuk membuatnya tetap menjadi manusia.
Dialogue: 0,0:03:24.14,0:03:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku itu juga lebih mudah.
Dialogue: 0,0:03:26.52,0:03:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sudah pasti!
Dialogue: 0,0:03:33.82,0:03:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Nanana!
Dialogue: 0,0:03:36.03,0:03:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nana, Kaya.
Dialogue: 0,0:03:37.95,0:03:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Nana, bibi Kaya-chan.
Dialogue: 0,0:03:40.95,0:03:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala keluarga utama\NEbisumori sekaligus cenayang.
Dialogue: 0,0:03:43.91,0:03:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:03:46.29,0:03:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadir.
Dialogue: 0,0:03:46.75,0:03:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya tampaknya kurang bersemangat.
Dialogue: 0,0:03:49.78,0:03:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Bu Guru tahu alasannya?
Dialogue: 0,0:03:51.79,0:03:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Soal ini...
Dialogue: 0,0:03:55.51,0:03:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:03:56.67,0:04:00.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin juga tidak menganggap\NKaya sebagai manusia.
Dialogue: 0,0:04:00.51,0:04:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin memiliki tujuan yang sama\Ndengan Namu.
Dialogue: 0,0:04:04.06,0:04:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Bu Guru tahu sesuatu...
Dialogue: 0,0:04:05.64,0:04:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:04:07.27,0:04:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Bu Guru mau bicara,\Ntolong beri tahu aku.
Dialogue: 0,0:04:12.19,0:04:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:04:15.03,0:04:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bibi Nanana juga...
Dialogue: 0,0:04:17.11,0:04:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Nana.
Dialogue: 0,0:04:18.52,0:04:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu juga bisa mengalahkan hantu?
Dialogue: 0,0:04:21.02,0:04:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, hanya keberadaan luar biasa sepertimu\Nyang bisa melakukannya, Kaya.
Dialogue: 0,0:04:28.58,0:04:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, waktu itu aku tidak berhasil.
Dialogue: 0,0:04:30.92,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa mengalahkannya.
Dialogue: 0,0:04:33.63,0:04:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku tidak akan melakukannya lagi.
Dialogue: 0,0:04:39.34,0:04:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku seusiamu,
Dialogue: 0,0:04:41.51,0:04:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makhluk aneh\Nhanya hal yang menakutkan bagiku.
Dialogue: 0,0:04:43.80,0:04:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa sembunyi di balik ibuku.
Dialogue: 0,0:04:47.48,0:04:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebenarnya bukan hal\Nyang harus dihadapi anak sepertimu.
Dialogue: 0,0:04:52.98,0:04:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memilih menghindar\Nadalah keputusan yang tepat.
Dialogue: 0,0:04:56.15,0:04:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:04:57.40,0:05:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat kamu harus\Nmenghadapinya di masa depan,
Dialogue: 0,0:05:00.28,0:05:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bawa ini.
Dialogue: 0,0:05:02.32,0:05:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jimat.
Dialogue: 0,0:05:03.82,0:05:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan melindungimu dari makhluk aneh.
Dialogue: 0,0:05:08.25,0:05:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantat.
Dialogue: 0,0:05:09.04,0:05:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hati!
Dialogue: 0,0:05:11.50,0:05:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:13.00,0:05:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana.
Dialogue: 0,0:05:15.04,0:05:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pantat?
Dialogue: 0,0:05:16.46,0:05:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hati!
Dialogue: 0,0:05:18.76,0:05:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bercanda.
Dialogue: 0,0:05:19.67,0:05:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:05:21.97,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Nanana.
Dialogue: 0,0:05:25.68,0:05:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak seharusnya\Nbilang itu pantat.
Dialogue: 0,0:05:28.72,0:05:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, cuma ada sesuatu\Nyang masuk ke mataku.
Dialogue: 0,0:05:33.27,0:05:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang mau ikut petak umpet?
Dialogue: 0,0:05:35.52,0:05:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ikut!
Dialogue: 0,0:05:36.94,0:05:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gunting, batu, kertas.
Dialogue: 0,0:05:38.94,0:05:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan jadi pencari.
Dialogue: 0,0:05:44.12,0:05:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua.
Dialogue: 0,0:05:46.33,0:05:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mau sembunyi di mana, ya?\N- Tiga.
Dialogue: 0,0:05:47.99,0:05:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat.
Dialogue: 0,0:05:49.12,0:05:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sembunyi di sini saja.\N- Lima.
Dialogue: 0,0:05:50.75,0:05:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam.
Dialogue: 0,0:05:53.17,0:05:54.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saku-chan.
Dialogue: 0,0:05:57.46,0:05:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-kun, kamu kenapa?
Dialogue: 0,0:05:59.42,0:06:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberitahumu\Ntempat persembunyian yang bagus.
Dialogue: 0,0:06:01.76,0:06:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:06:08.47,0:06:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersembunyi di sini?
Dialogue: 0,0:06:09.47,0:06:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka tempat yang gelap.
Dialogue: 0,0:06:12.18,0:06:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu ingin menang, kan?
Dialogue: 0,0:06:15.44,0:06:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bersembunyi sebentar saja.
Dialogue: 0,0:06:22.95,0:06:25.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembilan belas, dua puluh.
Dialogue: 0,0:06:29.70,0:06:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenken, ketemu.
Dialogue: 0,0:06:32.20,0:06:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzu-chan, ketemu.
Dialogue: 0,0:06:33.96,0:06:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan.
Dialogue: 0,0:06:37.75,0:06:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-kun, Saku-chan, ketemu kalian.
Dialogue: 0,0:06:47.09,0:06:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bukan Ma-kun dan Saku-chan\Nyang biasa.
Dialogue: 0,0:06:50.14,0:06:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:06:51.68,0:06:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu bicarakan?
Dialogue: 0,0:06:53.81,0:06:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu aneh sekali.
Dialogue: 0,0:06:55.27,0:06:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang aneh.
Dialogue: 0,0:07:00.19,0:07:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak aneh yang bicara aneh.
Dialogue: 0,0:07:05.82,0:07:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saku-chan tidak akan bicara seperti itu!
Dialogue: 0,0:07:11.33,0:07:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma, kamu tidak bisa melakukan apa-apa.
Dialogue: 0,0:07:15.33,0:07:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi, kamu tidak boleh\Nbergabung dengan kami.
Dialogue: 0,0:07:20.34,0:07:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita berada di tempat tinggi...
Dialogue: 0,0:07:22.00,0:07:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Kaya-chan?
Dialogue: 0,0:07:23.88,0:07:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang tidak mau bermain lagi.
Dialogue: 0,0:07:26.18,0:07:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ayo kita bermain lagi.
Dialogue: 0,0:07:33.64,0:07:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenken!
Dialogue: 0,0:07:35.27,0:07:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyerah, cepatlah keluar.
Dialogue: 0,0:07:39.27,0:07:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana dia bersembunyi?
Dialogue: 0,0:07:41.44,0:07:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:07:42.94,0:07:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti waktu pulang terlewat.
Dialogue: 0,0:07:44.94,0:07:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pulang dulu saja.
Dialogue: 0,0:07:46.15,0:07:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:07:47.53,0:07:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita bermain bersama,\Nharusnya kita menemukan orangnya.
Dialogue: 0,0:07:50.53,0:07:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenken, sudah waktunya pulang.
Dialogue: 0,0:07:56.04,0:07:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah keluar.
Dialogue: 0,0:07:59.54,0:08:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenken, ketemu.
Dialogue: 0,0:08:02.29,0:08:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat kembali ke kelas...
Dialogue: 0,0:08:06.26,0:08:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzu?
Dialogue: 0,0:08:07.43,0:08:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa menangis?
Dialogue: 0,0:08:11.30,0:08:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, kamu melihatnya?
Dialogue: 0,0:08:18.81,0:08:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak, waktunya hampir habis.
Dialogue: 0,0:08:21.81,0:08:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:28.20,0:08:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan!
Dialogue: 0,0:08:29.82,0:08:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang menjadi aneh!
Dialogue: 0,0:08:32.78,0:08:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:08:34.62,0:08:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzu-chan!
Dialogue: 0,0:08:35.87,0:08:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu takut pada hal-hal menakutkan?
Dialogue: 0,0:08:39.96,0:08:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kamu harus bersikap baik.
Dialogue: 0,0:08:42.59,0:08:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percuma, kamu tidak bisa melakukan apa-apa.
Dialogue: 0,0:08:54.38,0:08:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saat kamu harus menghadapinya\Ndi masa depan, bawa ini.
Dialogue: 0,0:08:58.85,0:09:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu tidak dapat menemukan kami?
Dialogue: 0,0:09:02.23,0:09:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kami menemukan tempat persembunyian yang bagus.\N- Tidak, aku tidak mau pergi.
Dialogue: 0,0:09:04.86,0:09:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kami menemukan tempat persembunyian yang bagus.\N- Lepaskan aku!
Dialogue: 0,0:09:10.49,0:09:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal bersembunyi di sini,
Dialogue: 0,0:09:11.99,0:09:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti, pasti tidak akan ditemukan.
Dialogue: 0,0:09:18.29,0:09:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bersembunyi bersama.
Dialogue: 0,0:09:20.75,0:09:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersembunyi terus seperti ini.
Dialogue: 0,0:09:23.29,0:09:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tidak akan ada yang menemukan kita.
Dialogue: 0,0:09:26.80,0:09:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai selamanya...
Dialogue: 0,0:09:33.76,0:09:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan!
Dialogue: 0,0:09:35.22,0:09:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah!
Dialogue: 0,0:09:42.73,0:09:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah kabur.
Dialogue: 0,0:09:44.90,0:09:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, kita mulai dari sini...
Dialogue: 0,0:09:55.12,0:09:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:58.16,0:09:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat!
Dialogue: 0,0:09:59.95,0:10:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak membutuhkanmu!
Dialogue: 0,0:10:03.21,0:10:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu teman-teman Kaya!
Dialogue: 0,0:10:16.93,0:10:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, Bodoh. Jangan tutup pintunya! Cepat buka!\N- Menyebalkan, di sini gelap dan menakutkan!
Dialogue: 0,0:10:18.51,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak bisa dibuka! Ada orang?\N- Menyebalkan, di sini gelap dan menakutkan!
Dialogue: 0,0:10:21.56,0:10:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:22.85,0:10:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu semuanya.
Dialogue: 0,0:10:25.23,0:10:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian sedang apa?
Dialogue: 0,0:10:32.44,0:10:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:33.22,0:10:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua!
Dialogue: 0,0:10:35.49,0:10:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah normal kembali, syukurlah.
Dialogue: 0,0:10:41.83,0:10:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:10:44.83,0:10:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, waktunya kembali ke kelas.
Dialogue: 0,0:10:48.64,0:10:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan.
Dialogue: 0,0:10:49.88,0:10:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengalahkan hantunya.
Dialogue: 0,0:10:52.13,0:10:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak jelas alasannya,\Ndia sepertinya sudah semangat lagi.
Dialogue: 0,0:10:56.09,0:10:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya, terima kasih.
Dialogue: 0,0:10:58.22,0:11:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini diberikan oleh Bibi Nanana padaku.
Dialogue: 0,0:11:02.85,0:11:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diberikan oleh Nana?
Dialogue: 0,0:11:04.60,0:11:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jimat pelindung.
Dialogue: 0,0:11:07.27,0:11:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar tidak terduga.
Dialogue: 0,0:11:09.48,0:11:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan.
Dialogue: 0,0:11:11.10,0:11:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku membukanya sedikit?
Dialogue: 0,0:11:13.40,0:11:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:11:17.99,0:11:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:11:24.71,0:11:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan hebat sekali!
Dialogue: 0,0:11:32.80,0:11:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya sebelumnya dia tidak bersemangat.
Dialogue: 0,0:11:36.76,0:11:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kondisinya sudah pulih, syukurlah.
Dialogue: 0,0:11:39.80,0:11:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Osamu, kamu sering melakukan hal seperti ini?
Dialogue: 0,0:11:42.77,0:11:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Guru, aku sudah merepotkanmu.
Dialogue: 0,0:11:45.89,0:11:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir,\Nini menyangkut keluarga utama.
Dialogue: 0,0:11:48.40,0:11:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sendirian,\Nentah masalah apa lagi yang akan terjadi.
Dialogue: 0,0:11:51.52,0:11:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selanjutnya...
Dialogue: 0,0:11:52.90,0:11:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu dengar tidak?
Dialogue: 0,0:11:53.89,0:11:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cekrek.
Dialogue: 0,0:11:55.95,0:11:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, kamu tidak mungkin tahu, kan?
Dialogue: 0,0:11:58.16,0:12:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin merekam fenomena supranatural,\Nkamera analog masih yang paling andal.
Dialogue: 0,0:12:02.70,0:12:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di fotonya tidak ada apa-apa?
Dialogue: 0,0:12:04.79,0:12:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah beberapa waktu,\Ngambarnya akan muncul perlahan-lahan.
Dialogue: 0,0:12:08.92,0:12:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, bisa dilihat...
Dialogue: 0,0:12:11.79,0:12:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Metode kuno seperti ini
Dialogue: 0,0:12:13.30,0:12:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terkadang bisa menemukan kebenaran\Nyang tidak bisa ditangkap oleh mata manusia.
Dialogue: 0,0:12:17.42,0:12:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau beli minum.
Dialogue: 0,0:12:27.69,0:12:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebenaran yang tidak tertangkap mata manusia.
Dialogue: 0,0:12:36.86,0:12:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak muncul fenomena aneh\Nyang disebut Bu Chie dan Guru.
Dialogue: 0,0:12:40.57,0:12:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah kemunculannya\Nmembutuhkan kondisi tertentu...
Dialogue: 0,0:12:43.36,0:12:44.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:12:49.96,0:12:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang makhluk aneh...
Dialogue: 0,0:12:53.00,0:12:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamera analog memang berbeda.
Dialogue: 0,0:12:56.17,0:12:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Nona Kaya mengabaikannya.
Dialogue: 0,0:12:59.01,0:13:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti makhluk aneh itu\Nbelum membahayakan manusia.
Dialogue: 0,0:13:04.26,0:13:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melihat ke sini...
Dialogue: 0,0:13:07.98,0:13:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan.
Dialogue: 0,0:13:12.27,0:13:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Osamu.
Dialogue: 0,0:13:14.06,0:13:16.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku kehilangan fotonya...
Dialogue: 0,0:13:16.86,0:13:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu diam saja?
Dialogue: 0,0:13:19.03,0:13:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, tolong lihat foto-foto ini.
Dialogue: 0,0:13:26.45,0:13:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali aku mengalihkan pandangan,\Ndia akan bergerak.
Dialogue: 0,0:13:29.71,0:13:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya makhluk aneh\Njenis yang akan menyerang jika tidak diawasi.
Dialogue: 0,0:13:34.46,0:13:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Guru, pasti bisa melihatnya, kan?
Dialogue: 0,0:13:36.25,0:13:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa mengusirnya?
Dialogue: 0,0:13:38.30,0:13:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berusaha tidak berkedip,\Ndan mataku sudah kering.
Dialogue: 0,0:13:41.22,0:13:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengusirnya bisa saja.
Dialogue: 0,0:13:42.72,0:13:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sama sekali\Ntidak melihat di mana makhluk anehnya.
Dialogue: 0,0:13:45.30,0:13:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:46.22,0:13:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, di dunia nyata...
Dialogue: 0,0:13:48.60,0:13:53.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, kenapa hanya dia yang bisa melihatnya,\Naku sama sekali tidak melihat apa-apa.
Dialogue: 0,0:13:54.10,0:13:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Osamu.
Dialogue: 0,0:13:55.02,0:13:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya.\N- Jangan lihat!
Dialogue: 0,0:13:56.86,0:13:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gu-Guru, jangan!
Dialogue: 0,0:13:58.65,0:14:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk aneh itu akan menyerang...
Dialogue: 0,0:14:00.53,0:14:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul juga!
Dialogue: 0,0:14:04.24,0:14:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertangkap juga!
Dialogue: 0,0:14:09.16,0:14:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lalai sehingga tidak menyadari kehadiranmu.
Dialogue: 0,0:14:12.12,0:14:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bersembunyi\Ndi dalam kamera, licik juga.
Dialogue: 0,0:14:21.13,0:14:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung mataku baik-baik saja!
Dialogue: 0,0:14:23.76,0:14:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Osamu, kamu baik-baik saja?
Dialogue: 0,0:14:25.51,0:14:26.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Guru.
Dialogue: 0,0:14:28.68,0:14:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jumlahnya bertambah.
Dialogue: 0,0:14:29.89,0:14:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:14:32.60,0:14:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.\NMakhluk ini licik juga.
Dialogue: 0,0:14:38.69,0:14:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gu-Guru.
Dialogue: 0,0:14:40.23,0:14:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku tidak bisa mengurusmu.
Dialogue: 0,0:14:41.74,0:14:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi mereka tertuju padaku,\Nkamu kabur saja dulu.
Dialogue: 0,0:14:44.32,0:14:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana boleh begitu.
Dialogue: 0,0:14:47.49,0:14:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:14:55.54,0:14:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ganggu temannya Paman Mob!
Dialogue: 0,0:15:10.10,0:15:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman Mob, kamu baik-baik saja?
Dialogue: 0,0:15:12.22,0:15:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Kaya!
Dialogue: 0,0:15:14.73,0:15:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ulangi jurus tadi sekali lagi!
Dialogue: 0,0:15:16.31,0:15:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat difoto!
Dialogue: 0,0:15:17.02,0:15:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, seharusnya merekam videonya!
Dialogue: 0,0:15:19.04,0:15:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya yang selalu\Nmelindungi Osamu adalah kamu.
Dialogue: 0,0:15:23.15,0:15:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Nanana versi laki-laki.
Dialogue: 0,0:15:25.03,0:15:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, mau ke mana?
Dialogue: 0,0:15:27.49,0:15:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:15:28.99,0:15:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak disangka akan meninggalkan\Ndampak buruk yang sedalam ini.
Dialogue: 0,0:15:31.99,0:15:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus,\Naku tidak bisa melindungi Osamu.
Dialogue: 0,0:15:35.04,0:15:36.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak terlalu rela,
Dialogue: 0,0:15:36.92,0:15:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}situasinya sudah mendesak.
Dialogue: 0,0:15:42.13,0:15:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi, Nona Ebisumori.
Dialogue: 0,0:15:43.84,0:15:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keperluan apa?
Dialogue: 0,0:15:45.63,0:15:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski terdengar konyol,
Dialogue: 0,0:15:48.24,0:15:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan sebenarnya bisa melihat hantu.
Dialogue: 0,0:15:51.04,0:15:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya itu,\Ndia bahkan bisa melenyapkan mereka.
Dialogue: 0,0:15:53.64,0:16:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pasti ada sesuatu di balik itu, kan?
Dialogue: 0,0:16:00.65,0:16:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut perkataanmu,
Dialogue: 0,0:16:02.61,0:16:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya kamu juga tahu\Ntentang miko keluarga Ebisumori.
Dialogue: 0,0:16:05.40,0:16:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang Kaya-chan, aku akan menceritakan\Nsemua yang kuketahui padamu.
Dialogue: 0,0:16:08.82,0:16:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolong ceritakan juga\Napa yang kamu ketahui.
Dialogue: 0,0:16:13.37,0:16:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu mau memercayaiku?
Dialogue: 0,0:16:17.58,0:16:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan memperlihatkannya padaku.
Dialogue: 0,0:16:20.54,0:16:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi yang tertulis di jimat.
Dialogue: 0,0:16:24.88,0:16:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kekuatanku, benda seperti itu\Nhanya berfungsi sebagai penghibur.
Dialogue: 0,0:16:28.43,0:16:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sama.
Dialogue: 0,0:16:30.72,0:16:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolong bantu aku.
Dialogue: 0,0:16:32.30,0:16:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar Kaya-chan bisa terus hidup bersama\Nkeluarganya di masa depan.
Dialogue: 0,0:16:36.60,0:16:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar dia tidak lagi disebut monster.
Dialogue: 0,0:16:42.56,0:16:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang bernama Namu berkata,\NKaya-chan adalah miko dari keluarga Ebisumori.
Dialogue: 0,0:16:47.74,0:16:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak dari keluarga cabang masih\Nbaik-baik saja, ya.
Dialogue: 0,0:16:50.96,0:16:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:54.08,0:16:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkataan Namu hanya setengah benar.
Dialogue: 0,0:16:56.50,0:16:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setengah?
Dialogue: 0,0:16:57.25,0:17:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri sulung keluarga Ebisumori\Nakan menjadi cenayang.
Dialogue: 0,0:17:00.71,0:17:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalimat ini jelas salah.
Dialogue: 0,0:17:03.50,0:17:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang disengaja agar\Nanak pertama lahir sebagai cenayang.
Dialogue: 0,0:17:07.26,0:17:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja melahirkan cenayang?
Dialogue: 0,0:17:10.08,0:17:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekilas mungkin sulit dipercaya.
Dialogue: 0,0:17:12.93,0:17:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leluhur klan Ebisumori adalah\Nmiko yang dirasuki dewa.
Dialogue: 0,0:17:15.43,0:17:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ebisumori bisa menikmati kemakmuran\Nberkat kekuatan yang luar biasa itu.
Dialogue: 0,0:17:20.27,0:17:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kekuatannya tidak diwariskan\Nke generasi berikutnya.
Dialogue: 0,0:17:25.10,0:17:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, keluarga Ebisumori\Ntidak mau melepaskan kemewahan.
Dialogue: 0,0:17:29.15,0:17:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi melahirkan kembali seorang miko,\Nmereka mencoba berbagai ilmu gaib.
Dialogue: 0,0:17:32.99,0:17:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, mereka menemukan satu cara.
Dialogue: 0,0:17:35.53,0:17:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu...
Dialogue: 0,0:17:37.95,0:17:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janin kutukan.
Dialogue: 0,0:17:39.62,0:17:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak yang lahir dengan cara ini\Npasti perempuan.
Dialogue: 0,0:17:43.63,0:17:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiring pertumbuhannya,
Dialogue: 0,0:17:45.09,0:17:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan makin menyerupai miko generasi pertama.\Nbaik penampilan maupun kemampuannya
Dialogue: 0,0:17:48.96,0:17:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ebisumori pun bisa terus makmur.
Dialogue: 0,0:17:52.09,0:17:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap miko yang lahir alami juga berharap\Nbisa melahirkan miko generasi berikutnya.
Dialogue: 0,0:17:56.39,0:18:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya, terbentuklah pola\Nanak sulung jadi cenayang.
Dialogue: 0,0:18:00.39,0:18:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tingkat kemampuannya berbeda-beda,
Dialogue: 0,0:18:02.94,0:18:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tetap tiruannya.
Dialogue: 0,0:18:06.52,0:18:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami, para Miko Ebisumori yang lahir\Nsebagai wadah kekuatan psikis,
Dialogue: 0,0:18:10.03,0:18:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memang ada benarnya juga\Ndisebut makhluk aneh oleh Namu.
Dialogue: 0,0:18:14.24,0:18:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namu bilang Kaya-chan sudah berubah sepenuhnya\Nmenjadi makhluk aneh.
Dialogue: 0,0:18:18.12,0:18:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu berarti anak yang seharusnya\Nmenjadi Satou Kaya sudah...
Dialogue: 0,0:18:21.46,0:18:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:18:23.00,0:18:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang dikatakan Namu,
Dialogue: 0,0:18:24.72,0:18:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya tampaknya mewarisi\Nkekuatan psikis miko yang sangat kuat.
Dialogue: 0,0:18:29.42,0:18:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kepribadian Kaya adalah miliknya sendiri.
Dialogue: 0,0:18:33.55,0:18:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:18:34.97,0:18:36.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:36.63,0:18:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Mirai yang melahirkan Kaya...
Dialogue: 0,0:18:42.68,0:18:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:18:44.73,0:18:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:18:46.56,0:18:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa ibu Kaya-chan melakukan ini?
Dialogue: 0,0:18:50.94,0:18:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin itu bentuk perlawanan.
Dialogue: 0,0:18:54.45,0:18:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu merasa rendah diri\Nkarena bukan cenayang.
Dialogue: 0,0:18:59.28,0:19:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kesal karena ibunya pilih kasih\Nterhadap kakaknya dalam hal punya anak.
Dialogue: 0,0:19:04.16,0:19:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mengetahui tentang janin kutukan\Nlewat suatu cara,
Dialogue: 0,0:19:07.13,0:19:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin dia ingin, dengan menjadikan\Nputrinya seorang cenayang,
Dialogue: 0,0:19:09.80,0:19:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bebas dari perasaan terbelenggu itu.
Dialogue: 0,0:19:13.22,0:19:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya, yang terdiri dari kata "kami", dewa,\Ndan "hachi", delapan,
Dialogue: 0,0:19:15.93,0:19:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memberi nama itu pada putrinya\Nmungkin juga karena alasan ini.
Dialogue: 0,0:19:20.31,0:19:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, untuk anak kedua juga...
Dialogue: 0,0:19:21.68,0:19:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Anak kedua juga?
Dialogue: 0,0:19:23.35,0:19:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:19:24.52,0:19:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata seorang paman yang aku kenal\Npunya kemampuan supranatural.
Dialogue: 0,0:19:27.19,0:19:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang ada makhluk aneh\Ndi kandungan ibu Kaya.
Dialogue: 0,0:19:31.19,0:19:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang disebut janin kutukan, kan?
Dialogue: 0,0:19:34.69,0:19:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia berharap kedua putrinya\Nbisa menjadi cenayang...
Dialogue: 0,0:19:38.57,0:19:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aneh.
Dialogue: 0,0:19:40.95,0:19:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya memang lahir sebagai seorang miko.
Dialogue: 0,0:19:44.45,0:19:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu mewarisi kekuatan sepertiku...
Dialogue: 0,0:19:47.29,0:19:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika ingin punya anak kedua...
Dialogue: 0,0:19:51.42,0:19:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana?
Dialogue: 0,0:19:54.46,0:19:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:19:55.51,0:19:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kupastikan dulu, jadi permisi.
Dialogue: 0,0:19:58.09,0:19:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:01.47,0:20:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:20:03.01,0:20:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Bu Chie.
Dialogue: 0,0:20:08.56,0:20:10.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjenguk Satou Mirai.
Dialogue: 0,0:20:10.44,0:20:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamar ada di ujung koridor sebelah kanan.
Dialogue: 0,0:20:12.27,0:20:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan tahu letaknya, kan?
Dialogue: 0,0:20:13.73,0:20:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antar Bibi ke sana, ya.
Dialogue: 0,0:20:18.95,0:20:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sana.
Dialogue: 0,0:20:24.41,0:20:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sungguh anak yang kuat, Kaya.
Dialogue: 0,0:20:26.62,0:20:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya kamu menghadapi ibumu sendirian.
Dialogue: 0,0:20:29.20,0:20:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang biar aku yang menggantikanmu.
Dialogue: 0,0:20:32.75,0:20:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera kembali.
Dialogue: 0,0:20:39.18,0:20:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya sebelum menitipkan Kaya padamu,
Dialogue: 0,0:20:42.93,0:20:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah berdiskusi dulu dengan Mirai.
Dialogue: 0,0:20:44.81,0:20:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kudengar\Nhubungan keluarga kalian agak rumit.
Dialogue: 0,0:20:48.27,0:20:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Mirai hanya tersenyum\Ndan bilang padaku,
Dialogue: 0,0:20:50.69,0:20:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Perlihatkan Kaya pada Kakak,\Nbuat dia kaget, ya."
Dialogue: 0,0:20:55.32,0:21:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ada di pikiranmu, Mirai?
Dialogue: 0,0:21:09.04,0:21:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana.
Dialogue: 0,0:21:19.51,0:21:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tadi?
Dialogue: 0,0:21:21.34,0:21:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Nanana!
Dialogue: 0,0:21:22.89,0:21:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu berdarah, kamu baik-baik saja?
Dialogue: 0,0:21:24.76,0:21:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja...
Dialogue: 0,0:21:27.06,0:21:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halusinasi? Salah.
Dialogue: 0,0:21:29.73,0:21:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar ada sesuatu.
Dialogue: 0,0:21:31.90,0:21:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memegangku...
Dialogue: 0,0:21:35.98,0:21:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku masih hidup?
Dialogue: 0,0:21:40.82,0:21:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Ebisumori.
Dialogue: 0,0:21:43.87,0:21:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:46.20,0:21:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:21:49.12,0:21:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Nana?
Dialogue: 0,0:21:50.41,0:21:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa Anda baik-baik saja?
Dialogue: 0,0:21:54.79,0:21:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu barusan?
Dialogue: 0,0:21:57.67,0:22:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ibu Anda baru saja...
Dialogue: 0,0:22:02.18,0:22:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meninggal dunia.
