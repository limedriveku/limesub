Dialogue: 0,0:00:51.36,0:00:53.95,tanda,,0000,0000,0000,,INTERKOM, PILIH, TUNGGU
Dialogue: 0,0:02:25.12,0:02:27.67,tanda,,0000,0000,0000,,KAYA-CHAN ISN'T SCARY
Dialogue: 0,0:02:40.01,0:02:43.52,tanda,,0000,0000,0000,,EPISODE 11: RUMAH IBU TIDAK MENAKUTKAN
Dialogue: 0,0:02:43.52,0:02:46.65,tanda,,0000,0000,0000,,KRAYON SD, ORIGAMI
Dialogue: 0,0:03:09.25,0:03:10.34,tanda,,0000,0000,0000,,HARI INI AKU AKAN TIDUR SEHARIAN, SHIZUO
Dialogue: 0,0:03:33.40,0:03:34.15,tanda,,0000,0000,0000,,EBISUMORI
Dialogue: 0,0:09:23.04,0:09:25.67,tanda,,0000,0000,0000,,SEMUA MALAPETAKA DIALIHKAN\NPADA EBISUMORI MUTSU
Dialogue: 0,0:09:28.59,0:09:31.13,tanda,,0000,0000,0000,,SEMUA MALAPETAKA DIALIHKAN PADA EBISUMORI NANA
Dialogue: 0,0:10:09.00,0:10:19.01,tanda,,0000,0000,0000,,KAYA-CHAN ISN'T SCARY
Dialogue: 0,0:10:19.01,0:10:22.02,tanda,,0000,0000,0000,,ADIK PEREMPUAN TIDAK MENAKUTKAN?
Dialogue: 0,0:10:34.03,0:10:35.99,tanda,,0000,0000,0000,,NANA
Dialogue: 0,0:10:35.99,0:10:37.70,tanda,,0000,0000,0000,,MIRAI
Dialogue: 0,0:14:47.87,0:14:48.95,tanda,,0000,0000,0000,,KAYA HARI INI AKAN BERMAIN\NKE RUMAH KAKAKMU
Dialogue: 0,0:14:58.54,0:15:01.20,tanda,,0000,0000,0000,,KELUARGA EBISUMORI TIDAK MENAKUTKAN?
Dialogue: 0,0:16:37.60,0:16:39.98,tanda,,0000,0000,0000,,CAMILAN
Dialogue: 0,0:17:06.76,0:17:09.26,tanda,,0000,0000,0000,,PEMAKAMAN EBISUMORI YOSHIE
Dialogue: 0,0:18:09.40,0:18:10.65,tanda,,0000,0000,0000,,KUTUKAN EBISUMORI MIRAI, TARGET: K DARI KELAS TIGA
Dialogue: 0,0:18:10.65,0:18:11.57,tanda,,0000,0000,0000,,FORMULIR PEMESANAN TOKO, PENGUSIRAN SETAN
Dialogue: 0,0:19:00.45,0:19:01.69,tanda,,0000,0000,0000,,KESEHATAN BAYI DAN BALITA
Dialogue: 0,0:19:01.69,0:19:02.95,tanda,,0000,0000,0000,,ILMU PENGASUHAN EDISI BARU
Dialogue: 0,0:19:35.03,0:19:36.49,tanda,,0000,0000,0000,,NAMA BELAKANG IBU: EBISUMORI YOSHIE
Dialogue: 0,0:19:58.05,0:20:00.04,tanda,,0000,0000,0000,,BUKU KESEHATAN IBU
Dialogue: 0,0:20:04.10,0:20:05.10,tanda,,0000,0000,0000,,SEANDAINYA DULU AKU MAKAN LEBIH BANYAK.\NINI SATU-SATUNYA PENYESALANKU
Dialogue: 0,0:20:05.10,0:20:06.14,tanda,,0000,0000,0000,,HARUS MEMBESARKAN BAYIKU DENGAN BAIK.\NIBU AKAN BERUSAHA, YA
Dialogue: 0,0:20:14.77,0:20:21.37,tanda,,0000,0000,0000,,CATATAN PROSES, MEMO PERTANYAAN
Dialogue: 0,0:21:44.60,0:21:49.54,tanda,,0000,0000,0000,,MISI OHARA-SAMA
Dialogue: 0,0:23:24.55,0:23:27.67,tanda,,0000,0000,0000,,NYONYA SATOU MIRAI
Dialogue: 0,0:00:05.76,0:00:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:00:06.99,0:00:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa!
Dialogue: 0,0:00:08.16,0:00:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:09.24,0:00:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah Kaya?
Dialogue: 0,0:00:10.74,0:00:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah hari ini Nana yang menjemput?
Dialogue: 0,0:00:12.87,0:00:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, katanya ibunya\Nmeninggal tadi malam.
Dialogue: 0,0:00:17.41,0:00:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:00:20.88,0:00:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek Kaya...
Dialogue: 0,0:00:25.96,0:00:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, ini TK Hanamugi.
Dialogue: 0,0:00:30.39,0:00:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:00:31.89,0:00:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie?
Dialogue: 0,0:00:34.35,0:00:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau ada di sini.
Dialogue: 0,0:00:35.81,0:00:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanggilnya,\Nmohon tunggu sebentar.
Dialogue: 0,0:00:38.81,0:00:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Kaya-chan ingin bicara denganmu.
Dialogue: 0,0:00:44.12,0:00:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Hasumi.
Dialogue: 0,0:00:47.13,0:00:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nana.
Dialogue: 0,0:00:48.65,0:00:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana, turut berduka cita...
Dialogue: 0,0:00:51.36,0:00:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie, ada yang ingin aku bicarakan.
Dialogue: 0,0:00:54.54,0:00:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:55.88,0:00:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya agak rumit,\Naku ingin membicarakannya langsung.
Dialogue: 0,0:01:00.96,0:01:03.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memungkinkan,\Nsilakan datang ke rumah utama Ebisumori.
Dialogue: 0,0:01:03.92,0:01:04.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:01:05.67,0:01:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:46.65,0:02:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ini.
Dialogue: 0,0:02:49.11,0:02:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang aku gambar.
Dialogue: 0,0:02:50.90,0:02:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, aku sangat suka\Ngambar yang kamu buat ini.
Dialogue: 0,0:02:55.03,0:02:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin nenekmu akan senang kalau melihatnya.
Dialogue: 0,0:02:59.58,0:03:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunjukkannya saat berdoa?
Dialogue: 0,0:03:00.95,0:03:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:02.41,0:03:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, kan, Nana?
Dialogue: 0,0:03:06.29,0:03:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:08.00,0:03:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ayah Kaya kelelahan,
Dialogue: 0,0:03:10.34,0:03:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku membawanya keluar dengan alasan\Nke pemakaman Nenek dan menjaga Kaya.
Dialogue: 0,0:03:16.68,0:03:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan?
Dialogue: 0,0:03:18.80,0:03:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berarti sebenarnya ada tujuan lain.
Dialogue: 0,0:03:30.36,0:03:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai.
Dialogue: 0,0:03:32.21,0:03:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini...
Dialogue: 0,0:03:34.15,0:03:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kediaman utama keluarga Ebisumori.
Dialogue: 0,0:03:38.20,0:03:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ebisumori.
Dialogue: 0,0:03:40.74,0:03:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah keluarga ibu Kaya.
Dialogue: 0,0:03:46.00,0:03:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:03:47.33,0:03:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa kalian juga ada di sini?
Dialogue: 0,0:03:49.79,0:03:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kasus yang berhubungan\Ndengan Nona Kaya.
Dialogue: 0,0:03:52.09,0:03:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin aku diam saja.
Dialogue: 0,0:03:55.09,0:03:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kasus yang berhubungan dengan Osamu.
Dialogue: 0,0:03:57.76,0:04:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin aku diam saja.
Dialogue: 0,0:04:01.10,0:04:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang ziarah ke tanah suci, Guru.
Dialogue: 0,0:04:05.18,0:04:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya disebut daerah terlarang.
Dialogue: 0,0:04:07.31,0:04:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang ini sebenarnya sedang apa?
Dialogue: 0,0:04:12.85,0:04:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak jadi masalah?
Dialogue: 0,0:04:15.36,0:04:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namu-san mungkin agak berbeda,
Dialogue: 0,0:04:16.82,0:04:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Mob itu orang luar, kan?
Dialogue: 0,0:04:19.32,0:04:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu juga?
Dialogue: 0,0:04:22.58,0:04:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lagi pula mereka juga punya hubungan\N- Lihat, Paman Mob.
Dialogue: 0,0:04:24.91,0:04:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang dalam dengan Kaya.\N- Gambarnya bagus sekali.
Dialogue: 0,0:04:26.62,0:04:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, benar juga.
Dialogue: 0,0:04:30.27,0:04:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu tambahan orang saja sudah bagus.
Dialogue: 0,0:04:34.80,0:04:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambahan?
Dialogue: 0,0:04:35.70,0:04:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya bagus.
Dialogue: 0,0:04:37.55,0:04:40.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kalian\Nmulai mengandalkan orang asing?
Dialogue: 0,0:04:41.51,0:04:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu ketakutan\Nmelihat kondisi ibumu yang meninggal?
Dialogue: 0,0:04:44.10,0:04:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru.
Dialogue: 0,0:04:46.56,0:04:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Mutsu...
Dialogue: 0,0:04:48.93,0:04:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dibunuh, kan?
Dialogue: 0,0:04:52.31,0:04:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, ada anak kecil di sini!
Dialogue: 0,0:04:55.53,0:04:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intuisimu masih tajam, ya.
Dialogue: 0,0:04:59.11,0:05:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena itu,
Dialogue: 0,0:05:01.56,0:05:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengajak kalian semua.
Dialogue: 0,0:05:03.64,0:05:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat menjelaskan semuanya\Ndan apa yang akan terjadi nanti.
Dialogue: 0,0:05:08.45,0:05:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lewat sini.
Dialogue: 0,0:05:10.58,0:05:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan, kamu main lompat tali di taman\Nsambil menunggu kami, ya.
Dialogue: 0,0:05:14.00,0:05:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:05:16.63,0:05:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:05:18.34,0:05:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa ada orang lain\Nyang tinggal di sini?
Dialogue: 0,0:05:22.26,0:05:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sekarang hanya tinggal aku.
Dialogue: 0,0:05:24.68,0:05:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Ibu masih mengurus,\Nbanyak sekali orang yang datang.
Dialogue: 0,0:05:28.35,0:05:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang masih percaya dengan\Npemimpin religius sekarang ini?
Dialogue: 0,0:05:31.31,0:05:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda dengan dulu, kepala keluarga\Nsekarang cuma cenayang amatir.
Dialogue: 0,0:05:36.44,0:05:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu tidak sopan!
Dialogue: 0,0:05:37.91,0:05:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:05:39.57,0:05:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya kekuatan\Nseperti Ibu atau Kaya.
Dialogue: 0,0:05:43.08,0:05:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin hanya sekadar berakting\Nuntuk menolak kesialan.
Dialogue: 0,0:05:45.87,0:05:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:05:49.75,0:05:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak jadi masalah.
Dialogue: 0,0:05:51.75,0:05:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masyarakat modern memang tidak butuh\Nhal mencurigakan seperti cenayang.
Dialogue: 0,0:05:57.92,0:06:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, meski tidak dibutuhkan,
Dialogue: 0,0:06:01.30,0:06:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mudah menghilangkannya begitu saja.
Dialogue: 0,0:06:04.12,0:06:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang tertinggal di sini,
Dialogue: 0,0:06:05.72,0:06:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- adalah sisa-sisa dari hal itu.\N- Cekrek, cekrek.
Dialogue: 0,0:06:08.72,0:06:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya sangat mendesak.
Dialogue: 0,0:06:11.23,0:06:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku akan memberitahukan sesuatu\Nyang dilarang untuk dipublikasikan,
Dialogue: 0,0:06:15.23,0:06:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu Ritual Regenerasi Miko,
Dialogue: 0,0:06:17.19,0:06:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"janin kutukan"\Ntanpa menyembunyikan apa pun.
Dialogue: 0,0:06:20.48,0:06:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janin kutukan?
Dialogue: 0,0:06:21.99,0:06:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang dia sebutkan sebelumnya,\Nitu metode melahirkan cenayang.
Dialogue: 0,0:06:27.45,0:06:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita hamil adalah subjek penting\Ndalam janin kutukan.
Dialogue: 0,0:06:32.48,0:06:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini sudah lama dilakukan\Noleh perempuan Ebisumori.
Dialogue: 0,0:06:36.50,0:06:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa ayahnya\Natau jenis kelamin janin tidak penting.
Dialogue: 0,0:06:39.71,0:06:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena apa pun asalnya,
Dialogue: 0,0:06:41.34,0:06:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya akan diubah menjadi wadah\Nbernama "miko" oleh kutukan.
Dialogue: 0,0:06:45.83,0:06:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, butuh satu "hal" lagi\Nuntuk mewujudkan perubahan ini.
Dialogue: 0,0:06:51.31,0:06:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Hal" apa itu?
Dialogue: 0,0:06:53.31,0:06:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tali pusar yang menghubungkan\Njanin ke plasenta.
Dialogue: 0,0:06:56.82,0:07:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan miko diyakini\Nbersemayam di dalam tali pusar.
Dialogue: 0,0:07:00.69,0:07:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, tali pusar\Nakan dimasukkan ke dalam tubuh.
Dialogue: 0,0:07:03.57,0:07:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan...
Dialogue: 0,0:07:04.86,0:07:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:07:06.45,0:07:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini terinspirasi dari kebiasaan\Nseperti memakan plasenta?
Dialogue: 0,0:07:11.83,0:07:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari hasilnya,\Nteori ini memang membuat ilmu hitam berhasil.
Dialogue: 0,0:07:15.37,0:07:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, janin yang bermutasi\Nmelalui janin kutukan,
Dialogue: 0,0:07:18.00,0:07:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makin lama di dalam rahim,\Nmakin hebat kekuatannya.
Dialogue: 0,0:07:24.51,0:07:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku lahir prematur,\Nwaktuku di rahim sangat singkat.
Dialogue: 0,0:07:28.51,0:07:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tingkat mutasiku sangat kecil.
Dialogue: 0,0:07:31.01,0:07:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah alasanku disebut cenayang ampas.
Dialogue: 0,0:07:36.27,0:07:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:07:38.73,0:07:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:07:39.77,0:07:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}versi buruk dari Mutsu sepertimu,
Dialogue: 0,0:07:42.23,0:07:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama sekali tidak berdaya terhadap\N"kutukan untuk Ebisumori", kan?
Dialogue: 0,0:07:47.56,0:07:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol sekali.
Dialogue: 0,0:07:48.99,0:07:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah sejak kapan kalian bermusuhan.
Dialogue: 0,0:07:51.45,0:07:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, selesaikan saja urusanmu sendiri.
Dialogue: 0,0:07:55.16,0:07:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu dengan kutukan?
Dialogue: 0,0:07:57.75,0:08:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Mutsu bukan mati\Nkarena sakit atau tua.
Dialogue: 0,0:08:03.25,0:08:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dibunuh.
Dialogue: 0,0:08:05.34,0:08:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibunuh oleh kutukan\Ndari orang yang membenci Ebisumori.
Dialogue: 0,0:08:09.51,0:08:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Atas dasar apa\Nkamu menyimpulkan hal seperti ini?
Dialogue: 0,0:08:12.18,0:08:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari itu aku mengunjunginya\Nkarena suatu urusan.
Dialogue: 0,0:08:18.44,0:08:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia tiba-tiba meninggal di hadapanku.
Dialogue: 0,0:08:23.15,0:08:25.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, itu tidak penting bagiku,
Dialogue: 0,0:08:25.07,0:08:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan membuatku merasa puas.
Dialogue: 0,0:08:27.57,0:08:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadinya ingin mencaci dia\Nsetelah kematiannya.
Dialogue: 0,0:08:31.66,0:08:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:08:32.58,0:08:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah dia meninggal,
Dialogue: 0,0:08:34.28,0:08:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jiwa Ebisumori Mutsu tidak muncul.
Dialogue: 0,0:08:37.25,0:08:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, itu sangat aneh!
Dialogue: 0,0:08:39.33,0:08:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun orang mati,\Njiwanya tidak langsung lenyap.
Dialogue: 0,0:08:44.38,0:08:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya Kyoko...
Dialogue: 0,0:08:46.84,0:08:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kematian alami tidak akan\Nmenunjukkan kondisi seperti ini.
Dialogue: 0,0:08:50.05,0:08:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada kemungkinan,
Dialogue: 0,0:08:51.72,0:08:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya tersisa kutukan buatan manusia.
Dialogue: 0,0:08:55.89,0:08:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ebisumori telah dikutuk.
Dialogue: 0,0:08:58.98,0:09:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ulah seseorang\Nyang sangat membenci kalian.
Dialogue: 0,0:09:03.31,0:09:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti tahu siapa orang itu, kan?
Dialogue: 0,0:09:08.36,0:09:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Nana.
Dialogue: 0,0:09:16.43,0:09:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat seperti yang kamu katakan.
Dialogue: 0,0:09:26.96,0:09:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:09:28.59,0:09:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama persis dengan jimat Kaya.
Dialogue: 0,0:09:31.68,0:09:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya untuk menenangkan seorang anak.
Dialogue: 0,0:09:34.72,0:09:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku adalah pemilik jimat aslinya.
Dialogue: 0,0:09:37.39,0:09:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku mati menggantikanku.
Dialogue: 0,0:09:43.52,0:09:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang sedang berencana memusnahkan\Nkeluarga kami dengan kutukan...
Dialogue: 0,0:09:53.03,0:09:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:55.45,0:09:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adik perempuanku.
Dialogue: 0,0:09:59.87,0:10:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibunya Kaya.
Dialogue: 0,0:10:04.75,0:10:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Mirai.
Dialogue: 0,0:10:22.93,0:10:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ibu Kaya-chan\Nyang membunuh Nyonya Mutsu?
Dialogue: 0,0:10:27.57,0:10:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar.
Dialogue: 0,0:10:28.77,0:10:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menerapkan kutukan yang cukup mematikan\Nbukanlah hal mudah.
Dialogue: 0,0:10:34.03,0:10:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi ibu Nona Kaya hanya orang biasa.
Dialogue: 0,0:10:37.70,0:10:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin bisa...
Dialogue: 0,0:10:38.87,0:10:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa melakukannya.
Dialogue: 0,0:10:40.83,0:10:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena...
Dialogue: 0,0:10:43.25,0:10:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi semua adik perempuan di keluarga Ebisumori,\Nmengandung benda terkutuk adalah misi mereka.
Dialogue: 0,0:10:51.38,0:10:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda terkutuk?
Dialogue: 0,0:10:52.84,0:10:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang bisa membunuh target\Ndengan mudah.
Dialogue: 0,0:10:55.63,0:10:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang bisa membawa kekayaan besar\Ndengan menjual kekuatan ini.
Dialogue: 0,0:10:59.93,0:11:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah inti dari kutukan.
Dialogue: 0,0:11:02.00,0:11:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan Ebisumori bisa berkembang\Nhingga sebesar sekarang
Dialogue: 0,0:11:04.69,0:11:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan masih bisa hidup nyaman\Ndi era industri spiritual yang sudah merosot,
Dialogue: 0,0:11:09.69,0:11:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan karena Miko,
Dialogue: 0,0:11:10.90,0:11:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi karena kekuatan benda terkutuk.
Dialogue: 0,0:11:14.57,0:11:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ibu Kaya-chan sedang mengandung...
Dialogue: 0,0:11:16.99,0:11:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia sedang mengandung\Nbenda terkutuk di rahimnya.
Dialogue: 0,0:11:25.69,0:11:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak masuk akal.
Dialogue: 0,0:11:27.25,0:11:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya keluarga Ebisumori memperlakukan\Nadikmu sebagai harta karun, kan?
Dialogue: 0,0:11:33.09,0:11:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada alasan baginya untuk mendendam.
Dialogue: 0,0:11:37.26,0:11:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjelaskan semuanya dari awal.
Dialogue: 0,0:11:43.68,0:11:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:11:50.61,0:11:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perutmu besar sekali, apa ada bayi?
Dialogue: 0,0:11:55.11,0:11:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang baru saja kukatakan,
Dialogue: 0,0:11:57.03,0:12:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ketika janin kutukan makin lama di rahim,\Nkekuatannya akan makin mengerikan.
Dialogue: 0,0:12:08.54,0:12:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak yang lahir\Nsudah tidak berbentuk manusia.
Dialogue: 0,0:12:11.89,0:12:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutukan terus dilepaskan\Ndari wadah yang rusak itu.
Dialogue: 0,0:12:17.05,0:12:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu akan menelan nyawa sang ibu\Ndan lahir dengan merobek perut.
Dialogue: 0,0:12:22.93,0:12:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda terkutuk yang terbuat dari bayi,\Nmembunuh orang yang dibenci sang ibu.
Dialogue: 0,0:12:28.02,0:12:30.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janin Kutukan Ebisu.
Dialogue: 0,0:12:45.29,0:12:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi melahirkan miko yang lebih kuat,
Dialogue: 0,0:12:49.48,0:12:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keberadaan yang muncul\Ndi ujung hasrat tersebut
Dialogue: 0,0:12:52.75,0:12:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya menentukan cara hidup\Nkeluarga Ebisumori.
Dialogue: 0,0:12:57.34,0:13:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adik-adik perempuan itu\Ndisebut "Ohara-sama".
Dialogue: 0,0:13:00.05,0:13:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka diajarkan\Nbahwa dalam keadaan darurat,
Dialogue: 0,0:13:02.55,0:13:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka harus mengorbankan nyawa\Nuntuk melahirkan benda terkutuk.
Dialogue: 0,0:13:06.77,0:13:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, orang terakhir yang menjadi\NOhara-sama adalah dia...
Dialogue: 0,0:13:11.77,0:13:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori Yoshie.
Dialogue: 0,0:13:13.69,0:13:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah adik perempuan ibuku.
Dialogue: 0,0:13:16.19,0:13:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini...
Dialogue: 0,0:13:17.40,0:13:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah menunjukkan foto ini\Npada Bu Chie.
Dialogue: 0,0:13:20.57,0:13:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita dalam foto ini.
Dialogue: 0,0:13:23.49,0:13:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Yoshie selalu sangat baik\Npada aku dan adikku.
Dialogue: 0,0:13:29.24,0:13:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang ceria dan lembut.
Dialogue: 0,0:13:31.96,0:13:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama Mirai.
Dialogue: 0,0:13:33.46,0:13:36.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Ibu jarang bersamanya,
Dialogue: 0,0:13:36.80,0:13:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia selalu menganggap Bibi\Nsebagai ibu sejati dan mengaguminya.
Dialogue: 0,0:13:42.26,0:13:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Yoshie.
Dialogue: 0,0:13:44.97,0:13:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana-chan, Mirai-chan.
Dialogue: 0,0:13:47.64,0:13:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perutmu besar sekali!
Dialogue: 0,0:13:49.81,0:13:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku menyentuhnya?
Dialogue: 0,0:13:51.31,0:13:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai, jangan!
Dialogue: 0,0:13:53.23,0:13:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:54.40,0:13:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena...
Dialogue: 0,0:13:56.71,0:14:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bilang kita tidak boleh\Nmenyentuh bayi Ohara-sama.
Dialogue: 0,0:14:01.03,0:14:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai tidak tahu hal seperti itu!
Dialogue: 0,0:14:03.28,0:14:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bilang juga padaku!
Dialogue: 0,0:14:05.99,0:14:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, jangan cemberut begitu.
Dialogue: 0,0:14:09.75,0:14:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian berdua tersenyum,\Nbayinya pasti juga akan senang.
Dialogue: 0,0:14:14.54,0:14:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyentuhnya dengan lembut,\Ntidak apa-apa.
Dialogue: 0,0:14:17.17,0:14:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:14:22.66,0:14:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai miko, aku tahu rahasia\NOhara-sama sejak awal.
Dialogue: 0,0:14:27.60,0:14:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Mirai tak tahu soal kematian Bibi Yoshie.
Dialogue: 0,0:14:33.35,0:14:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku mengira begitu.
Dialogue: 0,0:14:36.52,0:14:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai saat itu.
Dialogue: 0,0:14:38.90,0:14:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir,
Dialogue: 0,0:14:40.15,0:14:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak itu pasti sudah tahu.
Dialogue: 0,0:14:42.57,0:14:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua rahasia keluarga Ebisumori.
Dialogue: 0,0:14:54.04,0:14:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya pergi ke rumah itu?
Dialogue: 0,0:15:01.20,0:15:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana-chan, lihatlah.
Dialogue: 0,0:15:03.55,0:15:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memungutnya.\NLucu, kan?
Dialogue: 0,0:15:07.68,0:15:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu!
Dialogue: 0,0:15:20.05,0:15:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku dan kakakku bisa melihat secara alami\Nmakhluk-makhluk yang tidak bisa kulihat.
Dialogue: 0,0:15:26.16,0:15:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, tidak boleh!
Dialogue: 0,0:15:28.12,0:15:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kelinci Mirai.
Dialogue: 0,0:15:32.16,0:15:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakar saja benda yang dirasuki,\Nmasalah pun pasti beres.
Dialogue: 0,0:15:37.42,0:15:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat baik-baik, Nana.
Dialogue: 0,0:15:40.21,0:15:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:41.97,0:15:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak mengerti\Npercakapan ibuku dan kakakku.
Dialogue: 0,0:15:51.47,0:15:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai.
Dialogue: 0,0:15:54.06,0:15:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu?
Dialogue: 0,0:15:55.60,0:15:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bertengkar dengan Nana-chan?
Dialogue: 0,0:15:57.64,0:16:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau ada hubungannya dengan ibumu?
Dialogue: 0,0:16:01.82,0:16:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keduanya.
Dialogue: 0,0:16:03.28,0:16:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:16:08.32,0:16:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa boleh buat.
Dialogue: 0,0:16:11.07,0:16:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Nana dan Ibu adalah miko.
Dialogue: 0,0:16:14.77,0:16:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miko?
Dialogue: 0,0:16:16.87,0:16:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miko memiliki kekuatan yang sangat istimewa.
Dialogue: 0,0:16:19.21,0:16:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyelesaikan\Nbanyak tugas untuk keluarga.
Dialogue: 0,0:16:22.63,0:16:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa hidup tanpa kekhawatiran\Ndan tidak kekurangan apa pun,
Dialogue: 0,0:16:26.88,0:16:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua berkat para miko.
Dialogue: 0,0:16:29.34,0:16:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mereka membakar bonekaku.
Dialogue: 0,0:16:32.51,0:16:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih menyimpan dendam, ya?
Dialogue: 0,0:16:35.85,0:16:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:16:37.60,0:16:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu yang lebih enak!
Dialogue: 0,0:16:39.98,0:16:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku memakannya?
Dialogue: 0,0:16:41.44,0:16:44.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan beri tahu ibumu dan Nana-chan, ya.
Dialogue: 0,0:16:44.48,0:16:46.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Yoshie, kamu juga mau makan?
Dialogue: 0,0:16:46.74,0:16:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:47.44,0:16:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku harus menahan diri demi bayiku.
Dialogue: 0,0:16:50.95,0:16:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:16:52.45,0:16:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:16:54.73,0:16:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lebih seperti "ibu"\Ndaripada ibuku sendiri.
Dialogue: 0,0:16:59.68,0:17:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku agak iri dengan anak\Nyang akan dilahirkannya.
Dialogue: 0,0:17:10.63,0:17:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu bilang dia meninggal karena kecelakaan.
Dialogue: 0,0:17:14.68,0:17:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan bayinya?
Dialogue: 0,0:17:17.64,0:17:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak ada.
Dialogue: 0,0:17:23.40,0:17:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terima ini!\N- Roh jahat, enyahlah!
Dialogue: 0,0:17:28.40,0:17:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalian sedang apa?
Dialogue: 0,0:17:29.57,0:17:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya bisa apa lagi?\NBukannya kalian biasanya melakukan ini?
Dialogue: 0,0:17:33.43,0:17:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bim salabim!
Dialogue: 0,0:17:39.58,0:17:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah\Nmelakukan hal seperti itu!
Dialogue: 0,0:17:41.67,0:17:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!\NOrang tuaku juga bilang begitu.
Dialogue: 0,0:17:44.96,0:17:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang keluarga Ebisumori\Nbukan orang baik.
Dialogue: 0,0:17:47.09,0:17:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua penipu yang menggunakan\Nkekuatan psikis palsu untuk mencari uang.
Dialogue: 0,0:17:51.84,0:17:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pergi ke sekolah?
Dialogue: 0,0:17:54.51,0:17:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditindas lagi, ya?
Dialogue: 0,0:17:56.93,0:18:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pergi mengurusnya,\Nkamu tidak perlu khawatir.
Dialogue: 0,0:18:01.31,0:18:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nana juga tidak pergi sekolah, kan?
Dialogue: 0,0:18:04.31,0:18:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:18:06.19,0:18:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak mau pergi.
Dialogue: 0,0:18:09.40,0:18:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kami anak dari rumah yang sama?
Dialogue: 0,0:18:15.62,0:18:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai.
Dialogue: 0,0:18:17.41,0:18:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu menyusahkan Ibu.
Dialogue: 0,0:18:20.04,0:18:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini demi kebaikanmu.
Dialogue: 0,0:18:22.29,0:18:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi aku?
Dialogue: 0,0:18:24.21,0:18:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya aku yang dibuang ke luar.
Dialogue: 0,0:18:27.09,0:18:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membiarkan orang luar itu mengatakan apa saja,\Nseenaknya menindasku.
Dialogue: 0,0:18:30.76,0:18:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di rumah tidak ada satu pun orang\Nyang mau menolongku.
Dialogue: 0,0:18:33.30,0:18:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini juga disebut demi aku?
Dialogue: 0,0:18:35.55,0:18:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai...
Dialogue: 0,0:18:36.22,0:18:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:38.97,0:18:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hanya aku\Nyang diperlakukan seperti ini?
Dialogue: 0,0:18:41.02,0:18:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebenarnya perbedaan\Nantara aku dan Nana?
Dialogue: 0,0:18:43.44,0:18:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu bukan seorang miko.
Dialogue: 0,0:18:48.19,0:18:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai.
Dialogue: 0,0:18:48.94,0:18:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dikejar, Nana.
Dialogue: 0,0:18:51.19,0:18:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan dia pergi.
Dialogue: 0,0:19:00.45,0:19:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begini.
Dialogue: 0,0:19:02.95,0:19:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran nanti, kita akan bahas\NBuku Kesehatan Ibu kalian.
Dialogue: 0,0:19:07.96,0:19:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa bawa yang asli\Natau fotokopinya.
Dialogue: 0,0:19:11.21,0:19:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, orang itu adalah putri agama\Nyang selama ini dikabarkan...
Dialogue: 0,0:19:15.22,0:19:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ini berbahaya.
Dialogue: 0,0:19:16.43,0:19:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar bisa dibungkam...
Dialogue: 0,0:19:19.68,0:19:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku Kesehatan Ibu.
Dialogue: 0,0:19:22.10,0:19:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia masih menyimpan hal seperti itu?
Dialogue: 0,0:19:26.27,0:19:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya Nana mungkin masih disimpan.
Dialogue: 0,0:19:30.42,0:19:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada, mungkin ada di sini...
Dialogue: 0,0:19:33.18,0:19:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:19:35.03,0:19:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:19:37.82,0:19:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Yoshie?
Dialogue: 0,0:19:41.08,0:19:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja aku tidak melihat fotonya,\Nrupanya disimpan di sini.
Dialogue: 0,0:19:50.46,0:19:55.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kamu tiada, aku selalu sendirian.
Dialogue: 0,0:20:00.04,0:20:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ini punya Bibi Yoshie...
Dialogue: 0,0:20:06.14,0:20:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menahan diri demi bayiku.
Dialogue: 0,0:20:08.65,0:20:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:20:11.86,0:20:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Yoshie ini sungguh...
Dialogue: 0,0:20:14.77,0:20:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya akan berbeda dengan kelahiran biasa.
Dialogue: 0,0:20:16.95,0:20:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu hanya sekejap, jadi tak terasa sakit.
Dialogue: 0,0:20:21.99,0:20:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku juga banyak memikirkan\Ntentang dunia setelah kematian.
Dialogue: 0,0:20:27.12,0:20:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kakak bilang dia akan membimbingku\Nsebagai seorang miko.
Dialogue: 0,0:20:31.21,0:20:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku tidak khawatir.
Dialogue: 0,0:20:33.55,0:20:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepanjang hidupku,\Naku selalu dilindungi oleh Kakak.
Dialogue: 0,0:20:36.76,0:20:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang akhirnya giliranku untuk berbuat sesuatu\Ndemi Kakak dan keluarga Ebisumori.
Dialogue: 0,0:20:43.47,0:20:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini perutku sering bergejolak.
Dialogue: 0,0:20:47.64,0:20:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan yang cukup untuk membasmi musuh.\NAku bisa merasakan dengan kuat
Dialogue: 0,0:20:51.06,0:20:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:53.23,0:20:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa artinya ini?
Dialogue: 0,0:20:55.72,0:21:00.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sepertinya\Ntidak mengajari Mirai dengan baik.
Dialogue: 0,0:21:00.28,0:21:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa merasakan\Ndiriku ketakutan sampai pucat.
Dialogue: 0,0:21:04.16,0:21:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepertinya sama sekali tidak memahami\Nperbedaan status Miko-sama dan Ohara-sama.
Dialogue: 0,0:21:09.83,0:21:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naluri dalam diriku\Nmemberi peringatan kuat.
Dialogue: 0,0:21:12.08,0:21:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Mirai terus seperti ini,
Dialogue: 0,0:21:14.46,0:21:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di masa depan yang akan menderita\Nadalah Nana sebagai miko.
Dialogue: 0,0:21:18.80,0:21:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh terus membaca.
Dialogue: 0,0:21:20.93,0:21:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun itu adalah hidup Mirai,
Dialogue: 0,0:21:23.68,0:21:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus disiapkan akhir\Nyang bisa diterima orang.
Dialogue: 0,0:21:27.02,0:21:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak...
Dialogue: 0,0:21:28.27,0:21:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi Mirai yang akan menjadi\NOhara-sama berikutnya,
Dialogue: 0,0:21:31.65,0:21:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menulis semua yang harus\Ndia ketahui di buku pegangan ini.
Dialogue: 0,0:21:36.02,0:21:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga dia bisa menyelesaikan misinya\Ndengan baik sebagai Ohara-sama.
Dialogue: 0,0:21:41.20,0:21:42.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mirai.
Dialogue: 0,0:21:44.60,0:21:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang akan menggunakan
Dialogue: 0,0:21:46.09,0:21:47.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tali pusarku di masa depan,
Dialogue: 0,0:21:47.45,0:21:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti Mirai.
Dialogue: 0,0:21:53.04,0:21:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:21:55.34,0:21:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bibi Yoshie bukan meninggal\Nkarena kecelakaan.
Dialogue: 0,0:22:09.98,0:22:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang membuatnya berada\Ndi ambang kematian adalah...
Dialogue: 0,0:22:14.02,0:22:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miko dari keluarga Ebisumori.
Dialogue: 0,0:22:19.82,0:22:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku baru menyadarinya sekarang?
Dialogue: 0,0:22:23.53,0:22:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di keluarga ini, hanya anak perempuan sulung\Nyang diistimewakan.
Dialogue: 0,0:22:29.23,0:22:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan yang lain hanya makhluk\Nuntuk memproduksi monster.
Dialogue: 0,0:22:32.08,0:22:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rusak pun tidak jadi masalah.
Dialogue: 0,0:22:34.50,0:22:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga gila yang sama sekali tidak peduli\Ndengan nyawa kerabatnya sendiri.
Dialogue: 0,0:22:40.53,0:22:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau pergi dari sini?
Dialogue: 0,0:22:42.01,0:22:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu mendadak.
Dialogue: 0,0:22:43.30,0:22:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaralah dulu baik-baik dengan Ibu...
Dialogue: 0,0:22:45.01,0:22:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!
Dialogue: 0,0:22:46.51,0:22:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu seharusnya yang paling tahu\Nkalau orang itu tidak akan setuju.
Dialogue: 0,0:22:50.52,0:22:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di keluarga ini,
Dialogue: 0,0:22:51.73,0:22:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak pernah sesaat pun\Ndiperlakukan sebagai manusia.
Dialogue: 0,0:22:55.77,0:22:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Ebisumori,
Dialogue: 0,0:22:57.90,0:23:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah keluarga yang seharusnya\Ntidak ada di dunia ini.
Dialogue: 0,0:23:10.16,0:23:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir waktunya.
Dialogue: 0,0:23:13.48,0:23:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa tinggal di sini lagi.
Dialogue: 0,0:23:17.96,0:23:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini tidak boleh ada kesalahan.
Dialogue: 0,0:23:24.55,0:23:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Satou, aku akan membantu memasang infus.
Dialogue: 0,0:23:28.51,0:23:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bohong, kan?
Dialogue: 0,0:23:31.81,0:23:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:23:34.06,0:23:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa saja!
Dialogue: 0,0:23:35.81,0:23:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat panggil bantuan!
