Dialogue: 0,0:01:36.16,0:01:38.70,tanda,,0000,0000,0000,,KAYA-CHAN ISN'T SCARY
Dialogue: 0,0:01:51.42,0:01:52.36,tanda,,0000,0000,0000,,EPISODE 9: ORANG YANG BISA "MELIHAT"\NTIDAK MENAKUTKAN?
Dialogue: 0,0:02:33.34,0:02:36.01,tanda,,0000,0000,0000,,RUANG REFLEKSI
Dialogue: 0,0:02:39.76,0:02:41.60,tanda,,0000,0000,0000,,JANGAN KATAKAN HAL\NYANG MEMBUAT TEMANMU TIDAK SUKA
Dialogue: 0,0:02:43.73,0:02:45.19,tanda,,0000,0000,0000,,AKU SEDANG MERENUNGKAN KESALAHANKU,\NBERHARAP BISA BAIKAN SAMA TEMAN-TEMAN
Dialogue: 0,0:02:45.19,0:02:46.06,tanda,,0000,0000,0000,,SEMUA ORANG DI PANTI INI\NPUNYA MASALAHNYA MASING-MASING
Dialogue: 0,0:02:47.31,0:02:48.02,tanda,,0000,0000,0000,,MELIHAT DIRIKU SEBELUM KEMARIN,\NAKU SUNGGUH MENYESAL
Dialogue: 0,0:02:48.02,0:02:48.77,tanda,,0000,0000,0000,,AKU SADAR UCAPAN DAN TINDAKANKU\NMEMBUAT MEREKA MERASA GELISAH DAN TERGANGGU
Dialogue: 0,0:02:48.77,0:02:49.57,tanda,,0000,0000,0000,,AKU MERENUNGKANNYA DENGAN SUNGGUH-SUNGGUH,\NAKU INGIN BERUSAHA KERAS MENGUBAH DIRIKU
Dialogue: 0,0:07:27.26,0:07:29.76,tanda,,0000,0000,0000,,PEMURNIAN
Dialogue: 0,0:10:33.61,0:10:37.07,tanda,,0000,0000,0000,,BU CHIE TIDAK MENAKUTKAN
Dialogue: 0,0:14:17.04,0:14:22.05,tanda,,0000,0000,0000,,KAYA-CHAN ISN'T SCARY
Dialogue: 0,0:15:34.33,0:15:35.79,tanda,,0000,0000,0000,,DIA LUAR BIASA, SANGAT BERSEMANGAT
Dialogue: 0,0:15:35.79,0:15:38.33,tanda,,0000,0000,0000,,NONA KAYA SANGAT HEBAT
Dialogue: 0,0:23:10.74,0:23:11.45,tanda,,0000,0000,0000,,KAYA-CHAN ISN'T SCARY
Dialogue: 0,0:00:00.48,0:00:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya kamu?
Dialogue: 0,0:00:02.11,0:00:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah Namu-san.
Dialogue: 0,0:00:03.73,0:00:06.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah cenayang kuat.\NKekuatan psikisnya sangat meluap
Dialogue: 0,0:00:06.78,0:00:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga sulit menetap di satu tempat\Ndan harus berpindah-pindah.
Dialogue: 0,0:00:10.49,0:00:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melakukan hal seperti itu pada manusia biasa\Njuga tidak akan ada gunanya, kan?
Dialogue: 0,0:00:14.29,0:00:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah monster tidak akan bisa\Nhidup di tengah keramaian manusia.
Dialogue: 0,0:01:52.36,0:01:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ditinggalkan orang tuaku\Nkarena berbeda dari orang biasa.
Dialogue: 0,0:01:57.89,0:02:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini,\Ndia akan tinggal bersama kalian.
Dialogue: 0,0:02:00.39,0:02:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Namu.\NKalian harus akur, ya.
Dialogue: 0,0:02:03.94,0:02:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Namu.
Dialogue: 0,0:02:05.90,0:02:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku...
Dialogue: 0,0:02:06.44,0:02:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momoko.
Dialogue: 0,0:02:09.15,0:02:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang bergelantungan\Nmemanggilmu seperti itu.
Dialogue: 0,0:02:13.78,0:02:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menempel di sini.\NBerat sekali, kan?
Dialogue: 0,0:02:17.37,0:02:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubasmi untukmu.
Dialogue: 0,0:02:21.20,0:02:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak aneh.
Dialogue: 0,0:02:22.50,0:02:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menakutkan.
Dialogue: 0,0:02:23.36,0:02:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaranya aneh.
Dialogue: 0,0:02:24.08,0:02:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dibuang.
Dialogue: 0,0:02:33.34,0:02:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahan dengan suara-suara itu.
Dialogue: 0,0:02:36.01,0:02:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ruang refleksi yang sepi\Njustru lebih cocok untukku.
Dialogue: 0,0:02:51.48,0:02:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi mereka yang tidak tahu,
Dialogue: 0,0:02:54.49,0:02:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang lain tidak akan berbelas kasih.
Dialogue: 0,0:02:57.28,0:03:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menjalani berbagai pemeriksaan\Nserta menelan banyak obat.
Dialogue: 0,0:03:15.55,0:03:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu rumor yang dulu itu?
Dialogue: 0,0:03:17.09,0:03:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamar 313.
Dialogue: 0,0:03:19.51,0:03:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamar itu tepat di atas kita.
Dialogue: 0,0:03:20.76,0:03:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, rumor itu.
Dialogue: 0,0:03:22.18,0:03:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda pernah mendengar sesuatu?
Dialogue: 0,0:03:23.60,0:03:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya orang yang tinggal di kamar itu\Nmencoba bunuh diri.
Dialogue: 0,0:03:27.44,0:03:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:28.86,0:03:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya mereka juga akan berulang kali\Nmembenturkan kepala ke dinding.
Dialogue: 0,0:03:31.94,0:03:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.\NBisakah Anda ceritakan lebih detail...
Dialogue: 0,0:03:35.36,0:03:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei, di belakangmu!
Dialogue: 0,0:03:43.76,0:03:46.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku masih hidup?
Dialogue: 0,0:03:46.83,0:03:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah sadar.
Dialogue: 0,0:03:48.67,0:03:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kamu sangat beruntung.
Dialogue: 0,0:03:52.32,0:03:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:03:53.27,0:03:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf tidak langsung memperkenalkan diri.
Dialogue: 0,0:03:54.96,0:03:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bekerja di bidang ini...
Dialogue: 0,0:03:58.30,0:04:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cenayang?
Dialogue: 0,0:04:00.47,0:04:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:01.43,0:04:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat menyelidiki rumor tentang\Nroh jahat di kamar ini,
Dialogue: 0,0:04:05.31,0:04:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebetulan bertemu denganmu\Nyang hampir menjadi korban berikutnya.
Dialogue: 0,0:04:11.69,0:04:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini untung tidak menjadi tragedi.
Dialogue: 0,0:04:14.44,0:04:18.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, selama masih di kamar ini,\Nkejadian serupa akan terulang kembali.
Dialogue: 0,0:04:18.11,0:04:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:04:20.07,0:04:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada cenayang Mob Osamu ini.
Dialogue: 0,0:04:24.20,0:04:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan masuk\Nke kamar pasien tanpa izin.
Dialogue: 0,0:04:27.91,0:04:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluarkan dia.
Dialogue: 0,0:04:28.87,0:04:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tunggu sebentar.
Dialogue: 0,0:04:33.13,0:04:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang berada dalam bahaya\Nyang tidak diketahui!
Dialogue: 0,0:04:37.63,0:04:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini sebenarnya datang untuk apa...
Dialogue: 0,0:04:39.51,0:04:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, bukannya dia juga aneh?
Dialogue: 0,0:04:43.89,0:04:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:45.64,0:04:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mengatakan hal seperti itu,\Npasti akan dianggap gila.
Dialogue: 0,0:04:50.02,0:04:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi bilang aku ingin\Nbunuh diri karena kerasukan?
Dialogue: 0,0:04:53.40,0:04:55.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masuk akal.
Dialogue: 0,0:04:56.01,0:04:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu juga bukan kecelakaan.
Dialogue: 0,0:04:59.90,0:05:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tidak ada yang peduli\Nkalau aku mati.
Dialogue: 0,0:05:03.66,0:05:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak peduli.
Dialogue: 0,0:05:07.70,0:05:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada cenayang Mob Osamu ini.
Dialogue: 0,0:05:15.80,0:05:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak perlu ikut campur.
Dialogue: 0,0:05:20.22,0:05:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan, ini jimat pengusir setan.
Dialogue: 0,0:05:23.22,0:05:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah garam\Nyang ditempatkan di sudut tempat tidur.
Dialogue: 0,0:05:26.22,0:05:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini,\Nsetidaknya area ini akan aman.
Dialogue: 0,0:05:28.98,0:05:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan tetapi,
Dialogue: 0,0:05:29.93,0:05:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau garamnya rusak, berubah warna,\Natau terkena debu,
Dialogue: 0,0:05:34.23,0:05:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nanti bisa berdampak negatif.
Dialogue: 0,0:05:36.44,0:05:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu...
Dialogue: 0,0:05:37.40,0:05:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman...
Dialogue: 0,0:05:38.86,0:05:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadir.
Dialogue: 0,0:05:39.94,0:05:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang menganggapmu bahan tertawaan.
Dialogue: 0,0:05:42.64,0:05:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu tidak merasa malu?
Dialogue: 0,0:05:43.91,0:05:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku kira kamu mau bilang apa.
Dialogue: 0,0:05:47.37,0:05:50.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia di mata setiap orang memang berbeda.
Dialogue: 0,0:05:50.87,0:05:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin besar perbedaan "ketidaksamaan",\Ntentu akan menimbulkan kebingungan atau penolakan.
Dialogue: 0,0:05:56.38,0:05:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wajar.
Dialogue: 0,0:05:58.40,0:06:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak salah\Ndan aku juga tidak perlu malu.
Dialogue: 0,0:06:03.63,0:06:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pintar mencari alasan, ya?
Dialogue: 0,0:06:09.27,0:06:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu tidak meragukanku, kan?
Dialogue: 0,0:06:12.98,0:06:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begitu?
Dialogue: 0,0:06:14.88,0:06:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa,\Ncuma mengisi waktu saja.
Dialogue: 0,0:06:18.94,0:06:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lagi?
Dialogue: 0,0:06:20.69,0:06:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana kamu menyelinap masuk?
Dialogue: 0,0:06:22.70,0:06:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong segera pergi!
Dialogue: 0,0:06:24.07,0:06:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau aku akan memanggil polisi!
Dialogue: 0,0:06:26.24,0:06:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tegarkan hatimu!
Dialogue: 0,0:06:27.95,0:06:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku pasti akan melindungimu sampai akhir!\N- Sudahlah.
Dialogue: 0,0:06:29.41,0:06:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku pasti akan melindungimu sampai akhir!\N- Kamu mau mengoceh sampai kapan?
Dialogue: 0,0:06:34.75,0:06:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia di mata setiap orang memang berbeda.
Dialogue: 0,0:06:39.55,0:06:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum ini, aku selalu berpikir
Dialogue: 0,0:06:41.68,0:06:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya aku yang melihat dunia yang berbeda.
Dialogue: 0,0:06:48.29,0:06:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:06:49.81,0:06:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia cuma dukun palsu...
Dialogue: 0,0:06:54.38,0:06:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:06:55.31,0:06:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak mau perang berkepanjangan.
Dialogue: 0,0:06:57.31,0:07:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik menunggu mangsa datang\Ndan menyelesaikannya segera.
Dialogue: 0,0:07:01.82,0:07:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana operasinya\Nsangat sederhana dan jelas.
Dialogue: 0,0:07:10.16,0:07:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bersembunyi diam-diam di sebelah.
Dialogue: 0,0:07:12.45,0:07:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketuk temboknya kalau ada sesuatu.
Dialogue: 0,0:07:14.21,0:07:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan langsung masuk.
Dialogue: 0,0:07:16.50,0:07:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku akan menggunakan\Nsemprotan arwah ini...
Dialogue: 0,0:07:21.36,0:07:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar...
Dialogue: 0,0:07:41.32,0:07:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku ketiduran...
Dialogue: 0,0:07:44.57,0:07:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:07:48.95,0:07:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:07:50.70,0:07:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu tidak apa-apa?\N- Kok tidak sesuai ucapanmu sebelumnya?
Dialogue: 0,0:07:52.33,0:07:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, seharusnya aku langsung datang\Nsaat ada ketukan!
Dialogue: 0,0:07:56.87,0:07:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Maaf...\N- Bukan itu maksudku.
Dialogue: 0,0:07:58.50,0:08:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, kenapa kamu mengetuk tembok?
Dialogue: 0,0:08:02.09,0:08:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Bukan...
Dialogue: 0,0:08:04.55,0:08:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengetuk tembok...
Dialogue: 0,0:08:19.77,0:08:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namu-san, ini ruang berapa?
Dialogue: 0,0:08:22.90,0:08:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:25.57,0:08:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang 313.
Dialogue: 0,0:08:28.07,0:08:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu rumor sebelumnya, kan?
Dialogue: 0,0:08:30.11,0:08:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ruang 313.
Dialogue: 0,0:08:32.83,0:08:36.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya orang yang tinggal\Ndi ruangan itu mencoba bunuh diri.
Dialogue: 0,0:08:36.37,0:08:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon mereka membenturkan kepala\Nke tembok berulang kali.
Dialogue: 0,0:08:53.04,0:08:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, kamu lihat apa?
Dialogue: 0,0:08:57.35,0:08:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak apa-apa.
Dialogue: 0,0:09:00.10,0:09:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku cenayang!
Dialogue: 0,0:09:03.94,0:09:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungimu!
Dialogue: 0,0:09:09.53,0:09:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namu-san, lari!
Dialogue: 0,0:09:18.16,0:09:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman?
Dialogue: 0,0:09:27.28,0:09:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku yakin bisa mengalahkannya...
Dialogue: 0,0:09:32.84,0:09:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To-Tolong.
Dialogue: 0,0:09:35.81,0:09:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan, Namu-san!
Dialogue: 0,0:09:37.35,0:09:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruangan ini berbahaya,\Nkamu tidak boleh masuk!
Dialogue: 0,0:10:09.26,0:10:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah melindungiku.
Dialogue: 0,0:10:12.83,0:10:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah, kok.\NTidak perlu berterima kasih.
Dialogue: 0,0:10:15.30,0:10:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya Paman adalah cenayang?
Dialogue: 0,0:10:18.18,0:10:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak bisa mengatasi hantu?
Dialogue: 0,0:10:21.14,0:10:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:10:22.81,0:10:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai hari ini aku adalah gurumu\Ndan Paman adalah muridku.
Dialogue: 0,0:10:29.57,0:10:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paham, Osamu-kun?
Dialogue: 0,0:10:40.12,0:10:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muridku sendiri melompat ke lubang api.
Dialogue: 0,0:10:43.33,0:10:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai guru, mana mungkin aku diam saja.
Dialogue: 0,0:10:46.63,0:10:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan!
Dialogue: 0,0:10:47.46,0:10:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya!
Dialogue: 0,0:10:49.30,0:10:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak\Nmengawasinya sebentar saja.
Dialogue: 0,0:10:52.67,0:10:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, karena aku menghentikanmu...
Dialogue: 0,0:10:55.89,0:10:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencari ke sana.
Dialogue: 0,0:10:57.89,0:10:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cari ke sisi lain.
Dialogue: 0,0:11:10.12,0:11:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:11:16.82,0:11:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong berhenti!
Dialogue: 0,0:11:20.41,0:11:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Namu-san, kan?
Dialogue: 0,0:11:22.87,0:11:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kamu lakukan\Npada Kaya-chan?
Dialogue: 0,0:11:25.12,0:11:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukup kuat, tahu?
Dialogue: 0,0:11:27.16,0:11:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya aku penjahat?
Dialogue: 0,0:11:29.84,0:11:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu malah membuang benda ini di keramaian.
Dialogue: 0,0:11:36.09,0:11:38.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dilihat orang?
Dialogue: 0,0:11:39.60,0:11:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum pernah menemui monster\Nyang tidak bisa dikalahkannya.
Dialogue: 0,0:11:44.14,0:11:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan, tidak tahu cara\Nmenyembunyikan cakarnya.
Dialogue: 0,0:11:47.56,0:11:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mirip seperti monster saat masih bayi.
Dialogue: 0,0:11:50.41,0:11:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan.
Dialogue: 0,0:11:53.57,0:11:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Bu Guru ada di sini.
Dialogue: 0,0:11:56.99,0:12:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut, kita akan kembali ke ayahmu.
Dialogue: 0,0:12:00.57,0:12:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, sudah aman.
Dialogue: 0,0:12:05.19,0:12:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya semangat melindungi sampai mati.
Dialogue: 0,0:12:08.75,0:12:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena terpesona benda ini?
Dialogue: 0,0:12:10.69,0:12:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau,
Dialogue: 0,0:12:11.59,0:12:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kamu menjinakkannya\Ndengan cara seperti ini?
Dialogue: 0,0:12:15.59,0:12:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja dipanggil "guru".
Dialogue: 0,0:12:17.93,0:12:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:12:19.49,0:12:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang dia makhluk atau monster lagi.
Dialogue: 0,0:12:23.00,0:12:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, bukankah kamu juga cenayang?
Dialogue: 0,0:12:27.06,0:12:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu belum tentu.
Dialogue: 0,0:12:31.61,0:12:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru, apa sejak awal\Nkamu percaya kata-katanya tanpa kecuali?
Dialogue: 0,0:12:39.20,0:12:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Bu Guru sejak awal\N"tidak bisa melihat",
Dialogue: 0,0:12:42.70,0:12:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kamu memperlakukan anak itu?
Dialogue: 0,0:12:46.25,0:12:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengganggu orang lagi.
Dialogue: 0,0:12:47.91,0:12:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh\Nmengganggu orang bermain.
Dialogue: 0,0:12:50.92,0:12:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia akan menganggap\Nkeberadaan yang jauh dari akal sehat,
Dialogue: 0,0:12:54.84,0:12:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai orang sesat\Nlalu diusir dari kelompok.
Dialogue: 0,0:12:58.34,0:13:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cenayang hanya sebutan yang diperhalus.
Dialogue: 0,0:13:03.30,0:13:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abnormal itu punya banyak warna.
Dialogue: 0,0:13:05.97,0:13:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti gradasi.
Dialogue: 0,0:13:07.85,0:13:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu terlalu pekat,
Dialogue: 0,0:13:09.52,0:13:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang lain akan menganggapnya\Nseperti binatang.
Dialogue: 0,0:13:13.52,0:13:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur, bahkan aku\Nsulit menganggapnya sebagai "sejenis".
Dialogue: 0,0:13:19.24,0:13:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Osamu bahkan menyembahnya seperti dewa.
Dialogue: 0,0:13:22.11,0:13:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, orang dari keluarga seperti itu\Nmana mungkin hebat.
Dialogue: 0,0:13:26.45,0:13:29.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti "keberadaan"\Nyang lebih tidak menyenangkan.
Dialogue: 0,0:13:29.96,0:13:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa "keberadaan" yang kamu maksud?
Dialogue: 0,0:13:32.50,0:13:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kamu tahu hal seperti ini?
Dialogue: 0,0:13:35.79,0:13:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena aku
Dialogue: 0,0:13:37.84,0:13:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bernama Ebisumori Namu.
Dialogue: 0,0:13:42.38,0:13:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ebisumori?
Dialogue: 0,0:13:43.64,0:13:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bu Guru.
Dialogue: 0,0:13:45.72,0:13:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda yang sedang kamu peluk erat itu,
Dialogue: 0,0:13:48.56,0:13:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benarkah dia seperti yang kamu pikirkan?
Dialogue: 0,0:13:53.35,0:13:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang kamu lakukan?
Dialogue: 0,0:13:54.44,0:13:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat baik-baik, Bu Guru.
Dialogue: 0,0:13:57.22,0:13:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan dari keluarga Ebisumori,
Dialogue: 0,0:13:59.23,0:14:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya adalah makhluk apa?
Dialogue: 0,0:14:09.83,0:14:14.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah wujud asli Satou Kaya.
Dialogue: 0,0:14:32.45,0:14:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan, bertahanlah!
Dialogue: 0,0:14:34.35,0:14:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan...
Dialogue: 0,0:14:37.01,0:14:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan pada Kaya-chan?
Dialogue: 0,0:14:38.98,0:14:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang berbicara dengan siapa?
Dialogue: 0,0:14:41.32,0:14:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satou Kaya ada di sini.
Dialogue: 0,0:14:44.70,0:14:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kaya-chan" yang kamu sebutkan
Dialogue: 0,0:14:47.12,0:14:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanyalah makhluk aneh keluarga Ebisumori\Nyang menyamar sebagai manusia.
Dialogue: 0,0:14:51.75,0:14:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap anak sulung perempuan\Ndari Ebisumori,
Dialogue: 0,0:14:53.91,0:14:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan mewarisi kekuatan yang tidak biasa.
Dialogue: 0,0:14:57.24,0:15:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbedaan kekuatan tergantung "penggantian"\Noleh makhluk aneh dalam diri anak itu.
Dialogue: 0,0:15:04.26,0:15:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa melihatnya.
Dialogue: 0,0:15:07.45,0:15:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu,
Dialogue: 0,0:15:09.72,0:15:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di balik kulit itu sudah sepenuhnya\Ndigantikan oleh makhluk aneh.
Dialogue: 0,0:15:13.43,0:15:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada sedikit pun\N"manusia" yang tersisa.
Dialogue: 0,0:15:17.05,0:15:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap generasinya menguasai\Nkekuatan makhluk aneh,
Dialogue: 0,0:15:20.48,0:15:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu membuang segalanya yang tidak cocok.
Dialogue: 0,0:15:23.82,0:15:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, justru mereka yang berubah\Njadi makhluk aneh.
Dialogue: 0,0:15:28.66,0:15:33.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika klan mereka binasa karena bermain api,\Ntidak jadi masalah.
Dialogue: 0,0:15:33.66,0:15:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Osamu tampaknya juga seperti Bu Guru,
Dialogue: 0,0:15:35.79,0:15:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terpesona oleh makhluk aneh ini.
Dialogue: 0,0:15:38.33,0:15:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, untuk melindungi nyawa Osamu,
Dialogue: 0,0:15:40.86,0:15:43.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan mengusir makhluk aneh ini\Ndengan tanganku sendiri.
Dialogue: 0,0:15:44.03,0:15:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mengerti?
Dialogue: 0,0:15:45.38,0:15:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia bernama Satou Kaya\Nyang kamu berusaha mati-matian lindungi...
Dialogue: 0,0:15:52.43,0:15:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak pernah ada sejak awal.
Dialogue: 0,0:15:55.43,0:15:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru juga korban dari benda ini.
Dialogue: 0,0:15:58.48,0:16:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengalami banyak hal menakutkan, ya?
Dialogue: 0,0:16:02.02,0:16:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membereskan sisanya.
Dialogue: 0,0:16:04.52,0:16:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu mau kulit itu, bawa saja.
Dialogue: 0,0:16:07.03,0:16:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Bu Guru mungkin bisa menjelaskan\Nkalau dia hilang...
Dialogue: 0,0:16:20.40,0:16:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan ini?
Dialogue: 0,0:16:23.07,0:16:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikan padaku...
Dialogue: 0,0:16:26.24,0:16:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tarik kembali kata-katamu tadi!
Dialogue: 0,0:16:28.86,0:16:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang dia bukan manusia?
Dialogue: 0,0:16:31.22,0:16:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mengenalnya,\Njadi jangan bicara begitu!
Dialogue: 0,0:16:34.25,0:16:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan,
Dialogue: 0,0:16:36.31,0:16:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan, dia...
Dialogue: 0,0:16:40.21,0:16:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau ganti baju.
Dialogue: 0,0:16:42.40,0:16:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ganti baju,\Nnanti kamu tidak makan siang.
Dialogue: 0,0:16:45.47,0:16:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku tidak makan.
Dialogue: 0,0:16:46.78,0:16:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong melunaklah sedikit.
Dialogue: 0,0:16:48.40,0:16:52.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa membujuknya.
Dialogue: 0,0:16:52.12,0:16:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal akhir-akhir ini dia sangat manis.
Dialogue: 0,0:16:54.83,0:16:56.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotor sekali.
Dialogue: 0,0:16:56.58,0:16:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ribut.
Dialogue: 0,0:16:59.83,0:17:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu beri tahu alasannya pada Bu Guru, ya?
Dialogue: 0,0:17:03.25,0:17:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah dibilang...
Dialogue: 0,0:17:06.00,0:17:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah dibilang,\NBu Guru juga tidak akan mengerti!
Dialogue: 0,0:17:16.52,0:17:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan.
Dialogue: 0,0:17:19.17,0:17:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:17:20.56,0:17:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru sudah memikirkannya.
Dialogue: 0,0:17:22.69,0:17:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau ganti baju,
Dialogue: 0,0:17:24.10,0:17:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa karena kamu sangat suka baju ini?
Dialogue: 0,0:17:28.28,0:17:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:17:29.82,0:17:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau karena malu ganti baju?
Dialogue: 0,0:17:31.78,0:17:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:17:32.74,0:17:35.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu ingin kotor sepanjang hari ini.
Dialogue: 0,0:17:35.16,0:17:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali salah.
Dialogue: 0,0:17:36.66,0:17:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga salah...
Dialogue: 0,0:17:39.16,0:17:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bertanya begitu padaku?
Dialogue: 0,0:17:47.57,0:17:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Bu Guru\Ningin tahu apa yang ada di pikiranmu.
Dialogue: 0,0:17:52.51,0:17:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tebakanku sama sekali salah.
Dialogue: 0,0:17:56.47,0:17:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru.
Dialogue: 0,0:17:59.60,0:18:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru tidak benci Kaya?
Dialogue: 0,0:18:03.73,0:18:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin membencimu?
Dialogue: 0,0:18:05.94,0:18:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Guru paling suka Kaya-chan.
Dialogue: 0,0:18:16.33,0:18:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengan panjang.
Dialogue: 0,0:18:19.87,0:18:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pakai lengan panjang.
Dialogue: 0,0:18:21.71,0:18:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Kaya
Dialogue: 0,0:18:24.21,0:18:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mau jadi gelap.
Dialogue: 0,0:18:26.82,0:18:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Bu Guru sebelumnya bilang\Nkalau aku merajuk.
Dialogue: 0,0:18:31.51,0:18:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski saat itu aku tidak paham,
Dialogue: 0,0:18:33.62,0:18:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama bisa memahami\Npergumulan di dalam hatinya,
Dialogue: 0,0:18:36.26,0:18:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}arti apa pun sebenarnya tidak penting.
Dialogue: 0,0:18:39.22,0:18:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya melihat penampilan\Npasti tidak bisa mengerti.
Dialogue: 0,0:18:44.02,0:18:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski di dalamnya\Nadalah makhluk aneh, lalu apa?
Dialogue: 0,0:18:46.31,0:18:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, Kaya-chan
Dialogue: 0,0:18:48.44,0:18:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih bisa marah,\Nkhawatir, senang, dan tertawa.
Dialogue: 0,0:18:54.45,0:18:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam diri anak ini\Nbenar-benar ada hati manusia.
Dialogue: 0,0:18:59.08,0:19:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, jika kamu masih\Nmenganggapnya sebagai monster,
Dialogue: 0,0:19:02.16,0:19:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak akan membiarkan ini begitu saja.
Dialogue: 0,0:19:04.33,0:19:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Kaya-chan!
Dialogue: 0,0:19:08.09,0:19:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Bu Guru juga harus melindungimu.
Dialogue: 0,0:19:17.76,0:19:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:19:29.82,0:19:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya terlalu dekat.
Dialogue: 0,0:19:31.27,0:19:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah dipisahkan.
Dialogue: 0,0:19:34.19,0:19:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah aku melakukannya lagi?
Dialogue: 0,0:19:38.60,0:19:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:19:49.33,0:19:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Chie.
Dialogue: 0,0:19:51.71,0:19:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya-chan.
Dialogue: 0,0:19:52.84,0:19:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kamu, kan?
Dialogue: 0,0:19:56.28,0:19:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya...
Dialogue: 0,0:19:59.22,0:20:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya...
Dialogue: 0,0:20:09.48,0:20:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tersesat...
Dialogue: 0,0:20:15.16,0:20:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ketakutan, ya?
Dialogue: 0,0:20:17.03,0:20:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tidak apa-apa.
Dialogue: 0,0:20:19.61,0:20:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ikut Bu Guru kembali ke papamu.
Dialogue: 0,0:20:24.24,0:20:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa!
Dialogue: 0,0:20:25.37,0:20:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya.
Dialogue: 0,0:20:26.58,0:20:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkan kalian.\NTerima kasih banyak.
Dialogue: 0,0:20:29.12,0:20:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, syukurlah dia baik-baik saja.
Dialogue: 0,0:20:31.59,0:20:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa, Bu Chie.
Dialogue: 0,0:20:33.55,0:20:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuannya hari ini.
Dialogue: 0,0:20:35.71,0:20:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:20:38.97,0:20:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu masih berniat\Nmelakukan sesuatu padanya?
Dialogue: 0,0:20:42.12,0:20:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan.
Dialogue: 0,0:20:43.39,0:20:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, itu mustahil.
Dialogue: 0,0:20:45.85,0:20:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa mengintervensi hal-hal\Nyang berhubungan dengan arwah.
Dialogue: 0,0:20:49.39,0:20:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lepas kendali lagi dan menunjukkan\Nwujud aslinya, itu masih bisa diatasi.
Dialogue: 0,0:20:53.11,0:20:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau tetap di dalam tubuhnya,\Naku tidak bisa berbuat apa-apa.
Dialogue: 0,0:20:57.11,0:20:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kamu membuatnya kembali?
Dialogue: 0,0:20:59.04,0:21:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan\Nkamu punya bakat dalam hal ini?
Dialogue: 0,0:21:01.07,0:21:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin?
Dialogue: 0,0:21:02.70,0:21:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin anak itu benar-benar ingin kembali\Nke tubuhnya sendiri dari lubuk hatinya.
Dialogue: 0,0:21:09.00,0:21:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melindungi Kaya-chan!
Dialogue: 0,0:21:11.12,0:21:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada cenayang Mob Osamu ini.
Dialogue: 0,0:21:17.96,0:21:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia sama seperti manusia biasa?
Dialogue: 0,0:21:26.52,0:21:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya perlu ada penelitian lebih lanjut\Ntentang keberadaan itu.
Dialogue: 0,0:23:11.45,0:23:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Kaya-chan mengalahkan makhluk aneh,\Nkulitnya menjadi gelap.
Dialogue: 0,0:23:15.33,0:23:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena keberadaan di dalam tubuhnya\Nmenembus kulit dan terlihat keluar.
Dialogue: 0,0:23:21.00,0:23:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak mengerti alasannya,
Dialogue: 0,0:23:24.26,0:23:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menyadari fenomena\Nkulitnya menjadi hitam.
Dialogue: 0,0:23:28.51,0:23:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya dia memakai baju lengan panjang\Ndan celana panjang sepanjang tahun.
Dialogue: 0,0:23:31.95,0:23:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan saat berenang pun\Ndia menutupnya rapat,
Dialogue: 0,0:23:34.27,0:23:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua karena alasan ini.
