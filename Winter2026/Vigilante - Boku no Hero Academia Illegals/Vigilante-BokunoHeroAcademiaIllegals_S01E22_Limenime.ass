Dialogue: 0,0:01:06.65,0:01:09.84,tanda,,0000,0000,0000,,MY HERO ACADEMIA: VIGILANTES
Dialogue: 0,0:02:21.47,0:02:25.58,tanda,,0000,0000,0000,,KATASTROFE: PERUBAHAN BESAR DALAM\NALAM ATAU MASYARAKAT: TRANSFORMASI.
Dialogue: 0,0:02:25.61,0:02:27.11,tanda,,0000,0000,0000,,ATAU,\NAKHIR TRAGIS SEBUAH CERITA: KEHANCURAN.
Dialogue: 0,0:02:27.14,0:02:29.35,tanda,,0000,0000,0000,,EP. 22 PESTA PERPISAHAN
Dialogue: 0,0:03:00.76,0:03:02.93,tanda,,0000,0000,0000,,"MEDAN AERODINAMIS"
Dialogue: 0,0:03:52.08,0:03:54.08,tanda,,0000,0000,0000,,RUANG KONFERENSI B
Dialogue: 0,0:04:43.84,0:04:49.14,tanda,,0000,0000,0000,,NARUFES
Dialogue: 0,0:07:08.74,0:07:10.69,tanda,,0000,0000,0000,,"JADWAL CAPTAIN CELEBRITY"
Dialogue: 0,0:12:10.43,0:12:13.00,tanda,,0000,0000,0000,,"MENARA MIGHT"
Dialogue: 0,0:12:37.52,0:12:37.96,tanda,,0000,0000,0000,,DILARANG MEROKOK DI JALAN,\NKECUALI DI AREA YANG TELAH DITENTUKAN
Dialogue: 0,0:13:07.09,0:13:07.86,tanda,,0000,0000,0000,,TOKO DAUR ULANG HOPPERS
Dialogue: 0,0:13:44.40,0:13:46.88,tanda,,0000,0000,0000,,SEMINGGU YANG LALU
Dialogue: 0,0:16:01.52,0:16:03.19,tanda,,0000,0000,0000,,MOMEN LEDAKAN HEBAT:\NPENYELAMATAN DARI LANGIT
Dialogue: 0,0:16:03.19,0:16:03.75,tanda,,0000,0000,0000,,CAPTAIN CELEBRITY AKAN\NMENGAKHIRI AKTIVITAS DOMESTIKNYA
Dialogue: 0,0:19:17.05,0:19:18.60,tanda,,0000,0000,0000,,KEESOKAN HARINYA
Dialogue: 0,0:19:34.84,0:19:37.55,tanda,,0000,0000,0000,,ACARA INI AKAN DIADAKAN DI TOKYO SKY EGG!!
Dialogue: 0,0:19:40.20,0:19:43.16,tanda,,0000,0000,0000,,ACARA TERAKHIR AKAN DISELENGGARAKAN!!
Dialogue: 0,0:20:01.34,0:20:03.05,tanda,,0000,0000,0000,,"LATIHAN"
Dialogue: 0,0:00:04.52,0:00:06.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koichi, ayo cepat!
Dialogue: 0,0:00:07.56,0:00:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ngebut tanpa pelindung itu bahaya.
Dialogue: 0,0:00:10.74,0:00:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, hari ini dingin, ya.
Dialogue: 0,0:00:13.61,0:00:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, ayo cepat!
Dialogue: 0,0:00:16.26,0:00:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:00:18.08,0:00:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Makoto dan Captain.
Dialogue: 0,0:00:20.36,0:00:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rapatnya sudah mau mulai, lo.
Dialogue: 0,0:00:24.83,0:00:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku pulangnya telat...
Dialogue: 0,0:00:27.43,0:00:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja paruh waktuku juga kelewat batas.
Dialogue: 0,0:00:29.83,0:00:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:00:31.63,0:00:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mau nebeng?
Dialogue: 0,0:00:33.72,0:00:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa boleh?
Dialogue: 0,0:00:35.60,0:00:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami ikut.
Dialogue: 0,0:00:40.63,0:00:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kalau terbang memang jauh lebih cepat!
Dialogue: 0,0:00:44.14,0:00:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi... dingin! Dingin banget!
Dialogue: 0,0:02:32.83,0:02:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain!
Dialogue: 0,0:02:40.94,0:02:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin banget tadi!
Dialogue: 0,0:02:43.16,0:02:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua tidak kedinginan?
Dialogue: 0,0:02:46.10,0:02:48.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku baik-baik saja...
Dialogue: 0,0:02:48.23,0:02:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain sendiri juga pasti kedinginan\Nkalau tidak pakai jaket, 'kan?
Dialogue: 0,0:02:53.50,0:02:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak masalah.
Dialogue: 0,0:02:55.19,0:02:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasianya ada pada Quirk-ku.
Dialogue: 0,0:02:58.90,0:03:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Medan aerodinamis yang menyelimuti
Dialogue: 0,0:03:00.76,0:03:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}permukaan tubuhku
Dialogue: 0,0:03:02.96,0:03:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan cuma menjadi\Ntenaga pendorong saat terbang,
Dialogue: 0,0:03:05.66,0:03:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi juga menahan panas, dingin, benturan,\Ndan semacamnya dari luar.
Dialogue: 0,0:03:09.79,0:03:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau medannya diperluas,\Ntubuh orang lain juga bisa terlindungi.
Dialogue: 0,0:03:14.00,0:03:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma khusus cewek, ya?
Dialogue: 0,0:03:16.20,0:03:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, sih.
Dialogue: 0,0:03:18.34,0:03:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi misalnya cuma ada satu selimut di sini,
Dialogue: 0,0:03:22.30,0:03:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau mau berduaan\Ndi dalamnya dengan pria?
Dialogue: 0,0:03:25.40,0:03:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lebih baik daripada kedinginan.\NOrang ini benar-benar, deh...
Dialogue: 0,0:03:29.90,0:03:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koichi, tolong rahasiakan yang barusan, ya.
Dialogue: 0,0:03:33.02,0:03:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa merusak citra publiknya, ya?
Dialogue: 0,0:03:35.36,0:03:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu.
Dialogue: 0,0:03:37.30,0:03:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, sifat dan kelemahan Quirk\Nsebaiknya jangan diumbar ke publik.
Dialogue: 0,0:03:41.90,0:03:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:03:43.86,0:03:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan profesional harus berhati-hati, ya.
Dialogue: 0,0:03:47.13,0:03:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:03:49.91,0:03:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf terlambat!
Dialogue: 0,0:03:54.60,0:03:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian laporan untuk acara sebelumnya.
Dialogue: 0,0:03:58.60,0:04:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, kegiatan NaruFes\Nuntuk tahun ini resmi selesai!
Dialogue: 0,0:04:02.43,0:04:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sudah bekerja keras.
Dialogue: 0,0:04:05.43,0:04:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, saatnya pesta Natal!
Dialogue: 0,0:04:16.43,0:04:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau yang begini, serahkan saja padaku.
Dialogue: 0,0:04:24.57,0:04:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pizanya datang!
Dialogue: 0,0:04:27.90,0:04:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo!
Dialogue: 0,0:04:30.56,0:04:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubantu bawa.
Dialogue: 0,0:04:31.63,0:04:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah, aku saja yang bawa.
Dialogue: 0,0:04:35.50,0:04:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kelihatannya enak banget.
Dialogue: 0,0:04:38.17,0:04:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, semuanya, kerja bagus, ya.
Dialogue: 0,0:04:40.76,0:04:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Bos!
Dialogue: 0,0:04:49.14,0:04:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kita mulai, ya!
Dialogue: 0,0:04:52.31,0:04:54.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu, dua...
Dialogue: 0,0:04:55.09,0:04:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Natal!
Dialogue: 0,0:05:03.89,0:05:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:05:06.47,0:05:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbaris, ya.
Dialogue: 0,0:05:08.12,0:05:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Voucher belanja!
Dialogue: 0,0:05:14.16,0:05:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya seperti semangatku.
Dialogue: 0,0:05:16.66,0:05:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah sekali.
Dialogue: 0,0:05:25.80,0:05:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain ketiduran.
Dialogue: 0,0:05:28.18,0:05:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaannya memang sangat sibuk.
Dialogue: 0,0:05:30.90,0:05:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga ketiduran\Nsaat rapat waktu itu, 'kan?
Dialogue: 0,0:05:37.00,0:05:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pestanya sudah selesai?
Dialogue: 0,0:05:39.50,0:05:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya kerja lagi?
Dialogue: 0,0:05:41.11,0:05:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada waktu, istirahatlah selagi bisa.
Dialogue: 0,0:05:45.16,0:05:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadwal tahun ini sudah penuh\Nsampai Tahun Baru.
Dialogue: 0,0:05:49.70,0:05:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:05:51.56,0:05:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bekerja keras bagai kuda.\NTahun ini, tahun depan, dan seterusnya.
Dialogue: 0,0:05:56.08,0:05:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah hidup.
Dialogue: 0,0:05:58.50,0:05:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:59.70,0:06:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awal tahun depan masih akan sibuk\Ndengan persiapan kepulanganmu,
Dialogue: 0,0:06:03.60,0:06:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi setelah itu akan jauh lebih santai.
Dialogue: 0,0:06:05.51,0:06:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh... pulang?
Dialogue: 0,0:06:07.36,0:06:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku sedang dituntut\Ndalam berbagai kasus...
Dialogue: 0,0:06:10.09,0:06:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas luar negerimu\Nakan segera berakhir, Bos.
Dialogue: 0,0:06:13.30,0:06:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian besar persidanganmu di negara asal\Nakan selesai sebelum akhir tahun.
Dialogue: 0,0:06:17.53,0:06:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiring dengan itu, pencabutan izin usahamu\Ndi beberapa negara bagian akan dibatalkan.
Dialogue: 0,0:06:22.32,0:06:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negosiasi damai terkait perintah\Nlarangan mendekat juga sedang berjalan.
Dialogue: 0,0:06:26.90,0:06:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya.
Dialogue: 0,0:06:28.78,0:06:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kebanyakan kasus rumit itu\Nsebenarnya terjadi karena kau dijebak.
Dialogue: 0,0:06:33.98,0:06:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh... begitu?
Dialogue: 0,0:06:35.45,0:06:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kombinasi lengkap jebakan asmara,\Npaparazi, dan pemburu perkara.
Dialogue: 0,0:06:39.54,0:06:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dijadikan sasaran empuk.
Dialogue: 0,0:06:42.17,0:06:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, untuk urusan itu,\Nkami punya cara sendiri untuk menanganinya.
Dialogue: 0,0:06:49.36,0:06:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Makoto.
Dialogue: 0,0:06:51.10,0:06:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin selalu jadi teman baikmu.\NAku tidak mau menjadikanmu musuh.
Dialogue: 0,0:06:55.81,0:06:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kau bisa pulang\Nke negaramu, Captain?
Dialogue: 0,0:06:59.00,0:07:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, ya.
Dialogue: 0,0:07:00.65,0:07:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ya... memang bisa pulang ke negara asal,\Ntapi belum tentu bisa pulang ke rumah.
Dialogue: 0,0:07:05.56,0:07:08.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, hubunganku dengan istriku...
Dialogue: 0,0:07:08.74,0:07:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dijadwalkan mendampingi
Dialogue: 0,0:07:10.71,0:07:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}istrimu melahirkan bulan depan,
Dialogue: 0,0:07:12.96,0:07:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi silakan bicarakan masa depan kalian\Ndengan tenang saat itu.
Dialogue: 0,0:07:16.33,0:07:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Melahirkan?
Dialogue: 0,0:07:18.16,0:07:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamela?
Dialogue: 0,0:07:19.70,0:07:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anakku?
Dialogue: 0,0:07:21.29,0:07:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah dengar soal itu.
Dialogue: 0,0:07:23.56,0:07:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat pertama kali\Nbertemu dengannya, dia bilang,
Dialogue: 0,0:07:27.23,0:07:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Aku tahu suamiku orang yang baik,\Ntapi dia terlalu baik."
Dialogue: 0,0:07:33.03,0:07:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia takkan bisa membesarkan\Nanak dalam situasi ini."
Dialogue: 0,0:07:35.43,0:07:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Akan kubesarkan sendiri\Nanak yang lahir nanti."
Dialogue: 0,0:07:39.68,0:07:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... Pamela yang bilang begitu?
Dialogue: 0,0:07:43.46,0:07:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak. Kalau mengutip kata-kata persisnya,
Dialogue: 0,0:07:46.36,0:07:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Si bodoh itu!"
Dialogue: 0,0:07:47.43,0:07:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku percaya.
Dialogue: 0,0:07:49.20,0:07:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ringkasannya saja sudah cukup.\NTak perlu menabur garam di atas luka.
Dialogue: 0,0:07:53.28,0:07:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa istrimu berubah pikiran?
Dialogue: 0,0:07:58.16,0:08:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mendengar soal bayinya,\Naku bilang padanya...
Dialogue: 0,0:08:02.40,0:08:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau bilang?
Dialogue: 0,0:08:05.70,0:08:08.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja padaku.
Dialogue: 0,0:08:10.26,0:08:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nkau tak perlu khawatir lagi, Captain.
Dialogue: 0,0:08:13.26,0:08:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, ya!
Dialogue: 0,0:08:14.56,0:08:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau lihat bayinya!
Dialogue: 0,0:08:15.87,0:08:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:08:18.76,0:08:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.\NAku bisa pulang ke Amerika...
Dialogue: 0,0:08:24.96,0:08:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke rumahku.
Dialogue: 0,0:08:26.11,0:08:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah lagi dengan seorang bayi...
Dialogue: 0,0:08:28.70,0:08:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah Natal terbaik.
Dialogue: 0,0:08:34.74,0:08:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tunggu, tunggu!
Dialogue: 0,0:08:37.00,0:08:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku tadi bukan yang aneh-aneh!
Dialogue: 0,0:08:39.08,0:08:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga bantu aku, dong!
Dialogue: 0,0:08:41.12,0:08:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini memang sering ceroboh\Ndalam perkataan dan sikapnya.
Dialogue: 0,0:08:45.26,0:08:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, memang begitulah dia...
Dialogue: 0,0:08:48.66,0:08:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah gelap, hati-hati saat pulang,\Nya, semuanya.
Dialogue: 0,0:08:51.63,0:08:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:08:52.88,0:08:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nterima kasih atas kerja kerasnya!
Dialogue: 0,0:08:56.43,0:08:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak pulanglah naik taksi, ya.
Dialogue: 0,0:08:58.86,0:09:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:00.10,0:09:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di rapat berikutnya,\Ntolong bawa kembalian dan struknya, ya?
Dialogue: 0,0:09:04.30,0:09:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:05.69,0:09:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, ya, tadi!
Dialogue: 0,0:09:07.30,0:09:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:09:08.40,0:09:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa tahun depan, ya!
Dialogue: 0,0:09:10.50,0:09:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:11.83,0:09:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Sopir, mohon bantuannya.
Dialogue: 0,0:09:14.90,0:09:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dah!
Dialogue: 0,0:09:16.86,0:09:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak... memang menggemaskan, ya.
Dialogue: 0,0:09:19.66,0:09:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti seru kalau ada tiga anak di rumahku.
Dialogue: 0,0:09:23.36,0:09:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Makoto?
Dialogue: 0,0:09:25.37,0:09:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicarakan saja hal seperti itu\Ndengan istrimu.
Dialogue: 0,0:09:28.40,0:09:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang dengar,\Nnanti bisa menimbulkan salah paham lagi.
Dialogue: 0,0:09:31.41,0:09:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, itu gawat!
Dialogue: 0,0:09:35.55,0:09:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:09:38.22,0:09:40.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang besar terbang!
Dialogue: 0,0:09:41.14,0:09:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjahat?!
Dialogue: 0,0:09:48.60,0:09:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu taksi yang membawa anak-anak tadi!
Dialogue: 0,0:09:50.57,0:09:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Kalau dijatuhkan\Ndari ketinggian itu...
Dialogue: 0,0:09:57.11,0:09:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa!
Dialogue: 0,0:10:00.70,0:10:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengalahkan penjahat itu\Ndalam satu serangan
Dialogue: 0,0:10:03.33,0:10:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus menyelamatkan anak-anak!
Dialogue: 0,0:10:06.58,0:10:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain!
Dialogue: 0,0:10:10.47,0:10:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! Aku masih sempat...
Dialogue: 0,0:10:12.58,0:10:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayangnya, tidak semudah itu.
Dialogue: 0,0:10:21.14,0:10:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meledakkan diri?
Dialogue: 0,0:10:25.86,0:10:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos?
Dialogue: 0,0:10:30.43,0:10:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain!
Dialogue: 0,0:10:38.03,0:10:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalian baik-baik saja?\NTidak ada yang terluka?
Dialogue: 0,0:10:41.00,0:10:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Captain!
Dialogue: 0,0:10:44.87,0:10:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain, kau tidak apa-apa?
Dialogue: 0,0:10:46.83,0:10:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Kau berdarah!
Dialogue: 0,0:10:49.33,0:10:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ledakan apa itu?
Dialogue: 0,0:10:51.60,0:10:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Captain Celebrity?
Dialogue: 0,0:10:53.01,0:10:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}C.C. terluka!
Dialogue: 0,0:10:55.67,0:10:59.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi! Aku manajernya, tolong beri jalan!
Dialogue: 0,0:11:00.76,0:11:03.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Dilarang memotret!
Dialogue: 0,0:11:03.26,0:11:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memotret saat aku sedang tidak keren!
Dialogue: 0,0:11:07.68,0:11:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak.
Dialogue: 0,0:11:11.02,0:11:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru ini penampilanmu\Nyang paling keren, Bos.
Dialogue: 0,0:11:24.91,0:11:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kombinasi terbang dan ledakan\Ncukup berguna juga.
Dialogue: 0,0:11:29.40,0:11:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup kuat untuk melukai Captain Celebrity.
Dialogue: 0,0:11:33.38,0:11:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin tidak juga.
Dialogue: 0,0:11:37.21,0:11:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ledakan terjadi, dia sepenuhnya\Nmengalihkan penghalangnya ke arah anak-anak.
Dialogue: 0,0:11:44.22,0:11:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatnya tak berdaya.
Dialogue: 0,0:11:47.04,0:11:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia terlihat tak terkalahkan\Ncuma karena efek penghalang itu.
Dialogue: 0,0:11:52.66,0:11:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti tubuh aslinya kebal.
Dialogue: 0,0:11:55.85,0:11:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada peluang besar\Nmenang lewat strategi.
Dialogue: 0,0:12:00.40,0:12:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, kalau kita keluarkan\Ndua atau tiga bomber...
Dialogue: 0,0:12:06.02,0:12:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin bisa dijebak dengan mudah.
Dialogue: 0,0:12:10.43,0:12:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru.
Dialogue: 0,0:12:13.00,0:12:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sama-sama sibuk terus\Nselama liburan, ya.
Dialogue: 0,0:12:16.92,0:12:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, mohon kerja samanya lagi\Ntahun ini.
Dialogue: 0,0:12:19.36,0:12:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mohon kerja samanya.
Dialogue: 0,0:12:21.46,0:12:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf aku langsung bilang begini,
Dialogue: 0,0:12:24.00,0:12:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi mungkin untuk sementara\Naku tidak bisa datang ke sini.
Dialogue: 0,0:12:26.72,0:12:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah... aku mengerti.
Dialogue: 0,0:12:29.23,0:12:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin kau menghabiskan\Nseluruh waktumu untuk mengurusku saja.
Dialogue: 0,0:12:34.56,0:12:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, ini karena urusan mendesak.
Dialogue: 0,0:12:37.98,0:12:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mendapat informasi dari luar\Ntentang suatu kasus,
Dialogue: 0,0:12:40.90,0:12:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kami akan melakukan\Npenyelidikan intensif.
Dialogue: 0,0:12:45.32,0:12:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu soal obat terlarang\Nwaktu kau ditembak? Itu mengkhawatirkan!
Dialogue: 0,0:12:52.41,0:12:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau penyelidikannya berbahaya,\Npanggil aku.
Dialogue: 0,0:12:55.96,0:12:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bila perlu, aku akan datang diam-diam!
Dialogue: 0,0:12:59.13,0:13:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:13:01.17,0:13:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di sini secara diam-diam!
Dialogue: 0,0:13:03.74,0:13:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatmu saja sudah cukup.
Dialogue: 0,0:13:07.89,0:13:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, saat ini kami sedang menyelidiki
Dialogue: 0,0:13:10.10,0:13:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para pembeli impor dari daftar\Nyang kami dapatkan,
Dialogue: 0,0:13:12.56,0:13:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta menelusuri koneksi pribadi mereka.
Dialogue: 0,0:13:16.40,0:13:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kami masih kekurangan bukti penentu.
Dialogue: 0,0:13:20.40,0:13:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kami melacak mereka\Nsatu per satu tanpa arah,
Dialogue: 0,0:13:23.10,0:13:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa-bisa dalang dari Factory\Nmenyadarinya dan kabur lagi.
Dialogue: 0,0:13:28.16,0:13:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang tipe yang gampang kabur.
Dialogue: 0,0:13:30.91,0:13:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh sedikit lagi informasi\Nuntuk mempersempit sasaran.
Dialogue: 0,0:13:35.74,0:13:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan, Eraser?
Dialogue: 0,0:13:37.36,0:13:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsukauchi, ini.
Dialogue: 0,0:13:40.23,0:13:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini catatan aktivitas Vigilante Naruhata.
Dialogue: 0,0:13:43.26,0:13:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:51.45,0:13:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, aduh.
Dialogue: 0,0:13:53.40,0:13:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah bekerja keras, ya.
Dialogue: 0,0:13:55.43,0:13:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, anu... sebenarnya itu bukan aku.
Dialogue: 0,0:13:58.10,0:14:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia... The Crawler yang...
Dialogue: 0,0:14:02.43,0:14:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berusaha keras.
Dialogue: 0,0:14:03.82,0:14:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pura-pura tidak tahu atau mau sombong?
Dialogue: 0,0:14:06.20,0:14:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih salah satu saja.
Dialogue: 0,0:14:10.94,0:14:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tidak apa-apa.
Dialogue: 0,0:14:12.49,0:14:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian besar masih tergolong pencegahan\Nkejahatan atau penangkapan oleh warga sipil.
Dialogue: 0,0:14:17.41,0:14:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di awal-awal dulu\Ncukup banyak yang terluka...
Dialogue: 0,0:14:20.96,0:14:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu ulah paman yang tidak kami kenal.
Dialogue: 0,0:14:23.80,0:14:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, yang itu kita pisahkan\Ndari aktivitas setelah musim panas.
Dialogue: 0,0:14:27.38,0:14:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, catatannya sudah kuterima.
Dialogue: 0,0:14:31.40,0:14:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja samanya.
Dialogue: 0,0:14:33.23,0:14:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insiden penjahat di Naruhata mungkin terkait\Ndengan organisasi kriminal berskala besar.
Dialogue: 0,0:14:40.07,0:14:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin bisa menjadi\Npetunjuk penentu kasusnya.
Dialogue: 0,0:14:44.82,0:14:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga berterima kasih.
Dialogue: 0,0:14:47.20,0:14:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyimpan foto-foto seperti ini membuat kami\Nkhawatir suatu hari nanti bisa tertangkap.
Dialogue: 0,0:14:51.40,0:14:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami berkonsultasi dengan Makoto,\Ndan dia bilang...
Dialogue: 0,0:14:53.90,0:14:57.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal itu lebih baik lewat kenalan pahlawan\Ndaripada langsung ke polisi.
Dialogue: 0,0:14:57.66,0:15:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, pahlawan bisa lebih fleksibel\Nsecara pribadi,
Dialogue: 0,0:15:01.40,0:15:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tetap punya akses ke pihak resmi.
Dialogue: 0,0:15:04.13,0:15:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, kalian akan diperlakukan\Nsebagai pemberi informasi anonim.
Dialogue: 0,0:15:09.30,0:15:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sampaikan salamku\Njuga pada Manajer...
Dialogue: 0,0:15:12.70,0:15:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, pada Tuan Vigilante Misterius itu.
Dialogue: 0,0:15:17.03,0:15:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, The...
Dialogue: 0,0:15:19.06,0:15:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Crawler.
Dialogue: 0,0:15:20.76,0:15:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya adalah... The Crawler.
Dialogue: 0,0:15:26.23,0:15:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sandiwara ini melelahkan.
Dialogue: 0,0:15:28.36,0:15:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti saja alurnya.
Dialogue: 0,0:15:30.36,0:15:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto dan data teks sebagai catatan, ya.
Dialogue: 0,0:15:33.87,0:15:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya informasi lokasi\Nkejadian insiden penjahat di Naruhata.
Dialogue: 0,0:15:37.58,0:15:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk kejadian yang belum menjadi
Dialogue: 0,0:15:40.21,0:15:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kasus resmi\Ndan kondisinya sebelum polisi tiba.
Dialogue: 0,0:15:44.30,0:15:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Data ini dari mana?
Dialogue: 0,0:15:46.04,0:15:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah. Aku hanya menerimanya\Ndari Midnight, jadi tak bisa bilang apa-apa.
Dialogue: 0,0:15:51.13,0:15:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Identitas Vigilante itu pun\Nsama sekali tidak diketahui.
Dialogue: 0,0:15:58.72,0:16:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?\NTidak ada yang terluka?
Dialogue: 0,0:16:03.78,0:16:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan Amerika, Captain Celebrity,\Nyang ramai diperbincangkan akhir tahun lalu
Dialogue: 0,0:16:08.40,0:16:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkat video penyelamatan ledakan di udara,
Dialogue: 0,0:16:11.63,0:16:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengumumkan akan segera\Nmengakhiri aktivitasnya di Jepang
Dialogue: 0,0:16:14.78,0:16:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kembali ke negaranya.
Dialogue: 0,0:16:17.41,0:16:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengejutkan kalian, tapi ini\Nmemang sudah dijadwalkan sejak awal.
Dialogue: 0,0:16:22.43,0:16:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat rasanya meninggalkan Jepang,\Ntapi keluargaku menunggu di Amerika.
Dialogue: 0,0:16:26.88,0:16:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain Celebrity, yang mendominasi\Npemberitaan akhir tahun dan tahun baru
Dialogue: 0,0:16:31.01,0:16:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diharapkan dapat menggunakan\Npengalamannya di Jepang
Dialogue: 0,0:16:34.77,0:16:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencapai hal yang lebih besar.
Dialogue: 0,0:16:36.65,0:16:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa! Tayangan videonya\Nsudah tembus 100 juta!
Dialogue: 0,0:16:40.76,0:16:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tinggi dari waktu insiden raksasa!
Dialogue: 0,0:16:42.66,0:16:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya popularitasnya melonjak drastis\Ndan momentumnya mulai mendekati All Might!
Dialogue: 0,0:16:46.19,0:16:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ranking kata populer di internet\Njuga dipenuhi nama Captain!
Dialogue: 0,0:16:50.10,0:16:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celebrity, Captain, C.C. pulang kampung,\Nledakan udara, hoodie norak...
Dialogue: 0,0:16:55.24,0:16:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang heboh ingin hoodie resmi Captain\Ntapi sudah habis terjual.
Dialogue: 0,0:16:59.90,0:17:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merchandise lainnya juga ludes terjual.
Dialogue: 0,0:17:02.23,0:17:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kewalahan memenuhi permintaan.
Dialogue: 0,0:17:04.54,0:17:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali saat lagi viral\Nmalah tidak ada stok.
Dialogue: 0,0:17:09.46,0:17:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita buat viral lagi.
Dialogue: 0,0:17:13.55,0:17:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:15.08,0:17:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta perpisahan Bos\Nyang diadakan akhir Maret.
Dialogue: 0,0:17:19.26,0:17:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya direncanakan di Naruhata Civic Hall.
Dialogue: 0,0:17:22.43,0:17:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan dipindahkan ke Tokyo Sky Egg
Dialogue: 0,0:17:23.76,0:17:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}500 meter di atas tanah,\Nberkapasitas 50 ribu orang!
Dialogue: 0,0:17:27.59,0:17:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jadikan pesta besar bertema\N"Pertukaran Pahlawan Jepang-Amerika"!
Dialogue: 0,0:17:32.33,0:17:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?! Tiba-tiba sekali!
Dialogue: 0,0:17:34.46,0:17:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Makoto. Itu benar-benar tidak apa-apa?
Dialogue: 0,0:17:38.50,0:17:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupaksakan saja.\NJangan sampai peluang bisnis terlewat!
Dialogue: 0,0:17:45.00,0:17:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatan terakhir\Nmeraup keuntungan di Jepang!
Dialogue: 0,0:17:47.50,0:17:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan buatkan perpisahan\Nyang megah untukmu, Bos!
Dialogue: 0,0:17:51.21,0:17:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\NCaptain sepertinya harus siap mental.
Dialogue: 0,0:17:54.16,0:17:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya kami ingin publik menilai\Nkariermu di Jepang itu sukses besar!
Dialogue: 0,0:18:00.26,0:18:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan anggota NaruFes juga akan\Nbekerja sama sepenuhnya!
Dialogue: 0,0:18:03.18,0:18:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:18:04.35,0:18:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja sama itu...\Nmaksudnya tampil di Sky Egg?
Dialogue: 0,0:18:09.06,0:18:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami?
Dialogue: 0,0:18:10.61,0:18:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penonton NaruFes biasanya\Ncuma 100 orang, 'kan?
Dialogue: 0,0:18:13.86,0:18:17.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setengahnya juga orang dalam sendiri,\Nseperti Samazu...
Dialogue: 0,0:18:17.66,0:18:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi sebenarnya cuma 50 orang?
Dialogue: 0,0:18:19.86,0:18:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kalau Sky Egg?
Dialogue: 0,0:18:22.12,0:18:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}50 ribu orang.
Dialogue: 0,0:18:23.45,0:18:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wah, bedanya sampai tiga digit!\N- Bagaimana ini, bagaimana ini...
Dialogue: 0,0:18:26.46,0:18:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}La-Latihan!\NTidak ada jalan lain selain latihan!
Dialogue: 0,0:18:29.80,0:18:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak... tampil saja seperti biasa.
Dialogue: 0,0:18:33.82,0:18:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, penampilan kalian yang biasanya\Njustru yang paling hebat.
Dialogue: 0,0:18:38.13,0:18:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain...
Dialogue: 0,0:18:40.00,0:18:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena ini kesempatan besar,\Nkami juga ingin tampil keren.
Dialogue: 0,0:18:43.60,0:18:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:18:44.60,0:18:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga,\Nwaktu tampil kalian di panggung terbatas...
Dialogue: 0,0:18:48.20,0:18:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai dengan tarian bertema C.C.,
Dialogue: 0,0:18:50.56,0:18:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu ditutup dengan Marukane REMIX\Nseperti biasa sampai waktu habis...
Dialogue: 0,0:18:53.28,0:18:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kira-kira begitu?
Dialogue: 0,0:18:55.07,0:18:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau diskusi\Ndengan tim pemandu sorak agensi C.C.
Dialogue: 0,0:18:57.48,0:19:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pendukung lokal Naruhata.
Dialogue: 0,0:19:00.11,0:19:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perwakilan klub tari dan band\Nbisa kumpul nanti?
Dialogue: 0,0:19:04.43,0:19:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:05.16,0:19:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mari kita latihan keras\Nsampai hari H!
Dialogue: 0,0:19:08.70,0:19:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pasang wajah lesu begitu!
Dialogue: 0,0:19:10.65,0:19:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:19:11.33,0:19:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, rasanya jadi seperti dulu lagi.
Dialogue: 0,0:19:13.73,0:19:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus berusaha keras.
Dialogue: 0,0:19:15.20,0:19:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mendukung sepenuh hati.
Dialogue: 0,0:19:18.63,0:19:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, mari kita mulai latihannya!
Dialogue: 0,0:19:21.32,0:19:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:19:26.31,0:19:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat!
Dialogue: 0,0:19:27.89,0:19:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berjuang!
Dialogue: 0,0:19:47.80,0:19:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang... kuncinya tentu saja\Nbintang tamu pahlawan.
Dialogue: 0,0:19:51.56,0:19:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin formasi yang benar-benar\Nmencerminkan sosok pahlawan Jepang.
Dialogue: 0,0:19:56.10,0:19:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampil di acara itu?
Dialogue: 0,0:19:57.80,0:20:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap! Kami dengan senang hati\Nakan bekerja sama.
Dialogue: 0,0:20:01.34,0:20:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph, konyol.
Dialogue: 0,0:20:03.05,0:20:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berniat tampil di acara semacam itu.
Dialogue: 0,0:20:05.51,0:20:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja aku ikut!\NAku suka festival!
Dialogue: 0,0:20:09.39,0:20:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada, oke?
Dialogue: 0,0:20:11.00,0:20:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yeah!
Dialogue: 0,0:20:13.09,0:20:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau sempat aku datang.
Dialogue: 0,0:20:28.45,0:20:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wash!
Dialogue: 0,0:20:33.66,0:20:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyetujui\Nproposal dadakan kami.
Dialogue: 0,0:20:39.08,0:20:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan kirimkan draf kontraknya\Ndalam beberapa hari.
Dialogue: 0,0:20:42.47,0:20:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa alamat email yang Anda berikan\Nkemarin masih bisa digunakan?
Dialogue: 0,0:20:48.23,0:20:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, terima kasih.
Dialogue: 0,0:20:50.10,0:20:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:20:56.96,0:20:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susunannya sudah cukup lengkap,
Dialogue: 0,0:20:59.23,0:21:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi rasanya aku ingin\Nmenambahkannya sedikit lagi.
Dialogue: 0,0:21:01.90,0:21:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus menghubungi pahlawan lokal\Ndari luar wilayah ibu kota.
Dialogue: 0,0:21:06.20,0:21:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, yang terbaik adalah\Nkalau bisa mengundang All Might...
Dialogue: 0,0:21:12.03,0:21:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali.\NKau bekerja keras, ya.
Dialogue: 0,0:21:14.16,0:21:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kakak di rumah?\NTumben sekali.
Dialogue: 0,0:21:17.96,0:21:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma mampir ganti baju.\NSebentar lagi pergi lagi.
Dialogue: 0,0:21:21.00,0:21:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasa, sibuk sekali.
Dialogue: 0,0:21:23.20,0:21:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga, jangan terus-terusan\Nmembawa pekerjaan ke rumah.
Dialogue: 0,0:21:26.30,0:21:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu memaksakan diri.
Dialogue: 0,0:21:28.46,0:21:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini saatnya aku harus mengerahkan segalanya.
Dialogue: 0,0:21:30.51,0:21:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada melarangku, aku lebih butuh\Ndukunganmu agar aku bisa menyelesaikannya.
Dialogue: 0,0:21:35.05,0:21:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah... tentu saja aku mendukungmu.
Dialogue: 0,0:21:38.15,0:21:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kak...
Dialogue: 0,0:21:40.66,0:21:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mau minta bantuan\Nke agensi All Might
Dialogue: 0,0:21:44.24,0:21:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pakai jalur koneksimu!
Dialogue: 0,0:21:45.80,0:21:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, tidak boleh!
Dialogue: 0,0:21:47.53,0:21:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya berikan nomor ponselnya saja.
Dialogue: 0,0:21:50.36,0:21:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang tidak!
Dialogue: 0,0:21:51.79,0:21:53.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali ini saja!
Dialogue: 0,0:23:26.45,0:23:28.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di acara terakhir Captain,
Dialogue: 0,0:23:28.63,0:23:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahaya penjahat mulai mengancam.
Dialogue: 0,0:23:30.26,0:23:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi melindungi Sky Egg yang runtuh,
Dialogue: 0,0:23:32.14,0:23:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Captain menantang pertarungan\Nhidup dan mati.
Dialogue: 0,0:23:34.52,0:23:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Zero Hour".
Dialogue: 0,0:23:36.81,0:23:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh pahlawan profesional Jepang,\Nberkumpul!
