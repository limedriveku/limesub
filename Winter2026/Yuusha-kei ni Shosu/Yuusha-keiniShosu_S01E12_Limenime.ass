Dialogue: 0,0:29:24.68,0:29:31.86,tanda,,0000,0000,0000,,SENTENCED TO BE A HERO
Dialogue: 0,0:00:09.43,0:00:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teoritta, kita berhasil.
Dialogue: 0,0:00:12.50,0:00:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, ini hasil yang seharusnya.
Dialogue: 0,0:00:15.43,0:00:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuizinkan engkau\Nmengelus kepala dan memujiku.
Dialogue: 0,0:00:20.56,0:00:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapkan, "Dewi, kau memang hebat",
Dialogue: 0,0:00:22.70,0:00:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Teoritta, kau memang hebat".
Dialogue: 0,0:00:27.06,0:00:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teoritta, kau memang hebat.
Dialogue: 0,0:00:29.60,0:00:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang "Dewi" yang perkasa.
Dialogue: 0,0:00:33.20,0:00:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin semua sama.
Dialogue: 0,0:00:36.43,0:00:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun ingin dipuji setelah menyelesaikan\Nsuatu pekerjaan dengan baik.
Dialogue: 0,0:00:42.66,0:00:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan ada yang menganggap pujian itu\Nsebanding dengan nyawa mereka.
Dialogue: 0,0:01:08.43,0:01:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong...
Dialogue: 0,0:01:11.00,0:01:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku.
Dialogue: 0,0:01:12.83,0:01:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku... Ada monster...!
Dialogue: 0,0:01:16.36,0:01:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Target pengawalan kita bertambah.
Dialogue: 0,0:01:18.46,0:01:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teoritta, kau tunggu di sini...
Dialogue: 0,0:01:20.03,0:01:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai gadis kecil.
Dialogue: 0,0:01:21.94,0:01:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:01:23.20,0:01:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janganlah engkau takut.
Dialogue: 0,0:01:24.70,0:01:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewi Teoritta dan kesatriaku, Xylo Forbartz
Dialogue: 0,0:01:28.16,0:01:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan memastikan keselamatan engkau.
Dialogue: 0,0:01:30.73,0:01:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita perlu mengobati pria itu\Nsesegera mungkin.
Dialogue: 0,0:01:33.78,0:01:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namamu?
Dialogue: 0,0:01:35.90,0:01:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:01:39.00,0:01:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau baik-baik saja?
Dialogue: 0,0:01:45.62,0:01:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teoritta!
Dialogue: 0,0:01:50.36,0:01:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mati kau!
Dialogue: 0,0:01:59.23,0:02:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh!
Dialogue: 0,0:02:00.60,0:02:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menembak anak kecil? Lo?
Dialogue: 0,0:02:03.56,0:02:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang aneh.
Dialogue: 0,0:02:05.89,0:02:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsav?! Kau menembak warga sipil?
Dialogue: 0,0:02:09.07,0:02:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya, Teoritta kelihatan akan diserang.
Dialogue: 0,0:02:12.30,0:02:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:02:13.31,0:02:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah bilang, "Lo?"!
Dialogue: 0,0:02:17.60,0:02:20.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti ini...!
Dialogue: 0,0:02:26.46,0:02:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur.
Dialogue: 0,0:02:27.90,0:02:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teoritta!
Dialogue: 0,0:02:29.58,0:02:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau terluka?
Dialogue: 0,0:02:31.03,0:02:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang jangan memaksakan diri!
Dialogue: 0,0:02:33.40,0:02:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo.
Dialogue: 0,0:02:35.67,0:02:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku harus belajar\Ncara menggunakan ini.
Dialogue: 0,0:02:43.96,0:02:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menangkisnya dengan ini, ya.
Dialogue: 0,0:02:46.60,0:02:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita beli yang lebih bagus.
Dialogue: 0,0:02:49.96,0:02:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan melatihmu.
Dialogue: 0,0:02:52.44,0:02:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, faerie\Nyang menyamar menjadi manusia, ya.
Dialogue: 0,0:02:58.76,0:03:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia Spriggan.
Dialogue: 0,0:03:02.70,0:03:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau memang ancaman\Nbagi Malapetaka Raja Iblis.
Dialogue: 0,0:03:07.20,0:03:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Baguslah kalau begitu.
Dialogue: 0,0:03:15.70,0:03:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuntutan seorang "Dewi"\Nmemang selalu merepotkan.
Dialogue: 0,0:03:20.40,0:03:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pulang ke tempat\Npara sampah masyarakat berkumpul.
Dialogue: 0,0:03:24.25,0:03:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena di sanalah tempat kita kembali.
Dialogue: 0,0:03:27.81,0:03:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sebelum itu...
Dialogue: 0,0:03:30.27,0:03:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau paham maksudku, bukan?
Dialogue: 0,0:03:36.69,0:03:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau harus memuja dan puji aku
Dialogue: 0,0:03:39.63,0:03:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan seluruh jiwa dan ragamu!
Dialogue: 0,0:03:47.80,0:03:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Total pengungsi yang sampai\Nke markas sekitar 130 orang.
Dialogue: 0,0:03:51.70,0:03:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada korban jiwa.
Dialogue: 0,0:03:53.30,0:03:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orde Ke-13 Kesatria Suci memang hebat.
Dialogue: 0,0:03:56.26,0:03:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua berkat pelatihan Komandan Kivia.
Dialogue: 0,0:03:59.40,0:04:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ke mana\NKomandan dan Kapten Infanteri pergi?
Dialogue: 0,0:04:04.26,0:04:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka membiarkan kita\Nberkontribusi penuh.
Dialogue: 0,0:04:07.40,0:04:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Komandan dan Rajit\Nselalu menyikat habis semua prestasi.
Dialogue: 0,0:04:13.90,0:04:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, kalian telah bertarung dengan baik!
Dialogue: 0,0:04:16.76,0:04:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\Npihak militer dan Kuil akan bekerja sama,
Dialogue: 0,0:04:20.63,0:04:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- untuk membangun kembali kota ini!\N- Maaf membuatmu menunggu.
Dialogue: 0,0:04:22.30,0:04:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:04:23.86,0:04:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frenci.
Dialogue: 0,0:04:27.83,0:04:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dugaanmu tepat sasaran.
Dialogue: 0,0:04:52.76,0:04:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama...
Dialogue: 0,0:04:54.76,0:04:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memperbaiki kerusakan.
Dialogue: 0,0:04:58.86,0:05:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cari
Dialogue: 0,0:05:00.70,0:05:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}inang baru...
Dialogue: 0,0:05:08.16,0:05:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kau ada di sini.
Dialogue: 0,0:05:14.08,0:05:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencarimu ke mana-mana, Spriggan.
Dialogue: 0,0:05:19.50,0:05:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kau tidak tahu, ya?
Dialogue: 0,0:05:22.70,0:05:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, saat Malapetaka Raja Iblis\Nmelakukan kontaminasi ke sekitar
Dialogue: 0,0:05:26.95,0:05:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada sejenis...\NYah, bisa disebut sebagai "ombak" tersendiri.
Dialogue: 0,0:05:30.10,0:05:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk sejenis bisa mendeteksi hal itu.
Dialogue: 0,0:05:32.80,0:05:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan itulah aku mendeteksi keberadaanmu.
Dialogue: 0,0:05:35.73,0:05:36.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau...?
Dialogue: 0,0:05:36.90,0:05:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spriggan, dengarkan curhatku sebentar.
Dialogue: 0,0:05:40.26,0:05:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini aku seorang pahlawan terpidana,
Dialogue: 0,0:05:43.40,0:05:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hukumanku adalah yang paling ringan\Ndibandingkan rekan-rekanku yang lain.
Dialogue: 0,0:05:49.83,0:05:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, terlalu sederhana dan mudah dipahami.
Dialogue: 0,0:05:55.40,0:05:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa tebak?
Dialogue: 0,0:06:06.63,0:06:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabannya...
Dialogue: 0,0:06:08.97,0:06:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh sesama Raja Iblis.
Dialogue: 0,0:06:11.83,0:06:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cenderung merasakan\Nkepuasan saat lakukan itu.
Dialogue: 0,0:06:16.90,0:06:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia hebat sekali, lo.
Dialogue: 0,0:06:18.66,0:06:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi mereka,\Nhal seperti ini terlalu "lumrah",
Dialogue: 0,0:06:21.85,0:06:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan motifnya sangat "membosankan".
Dialogue: 0,0:06:24.36,0:06:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat. Jangan mendekat!
Dialogue: 0,0:06:26.43,0:06:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hebat, ya,\Nbisa bilang itu membosankan.
Dialogue: 0,0:06:28.56,0:06:31.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku sepenuhnya patuh,
Dialogue: 0,0:06:31.60,0:06:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mendengarkan semua permintaan mereka.
Dialogue: 0,0:06:34.66,0:06:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sedang belajar tentang moralitas.
Dialogue: 0,0:06:37.66,0:06:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga paham bagi kalian,\NMalapetaka Raja Iblis,
Dialogue: 0,0:06:39.76,0:06:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak lebih dari seorang pembunuh.
Dialogue: 0,0:06:44.38,0:06:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh sesama demi kesenangan pribadi.
Dialogue: 0,0:06:46.93,0:06:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuh yang klise dan membosankan.
Dialogue: 0,0:06:50.56,0:06:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bagi manusia,\Naku sama seperti pahlawan.
Dialogue: 0,0:06:54.63,0:06:59.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya? Aku belum bisa\Njelaskan konsep ini dengan baik.
Dialogue: 0,0:06:59.48,0:07:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan aku!
Dialogue: 0,0:07:01.06,0:07:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya. Jeritanmu sejak tadi...
Dialogue: 0,0:07:05.00,0:07:06.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terdengar sangat merdu, ya.
Dialogue: 0,0:07:07.30,0:07:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuatku semakin bersemangat.
Dialogue: 0,0:07:09.30,0:07:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin membunuhmu dengan perlahan.
Dialogue: 0,0:07:14.66,0:07:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, maaf lupa mengenalkan diri.
Dialogue: 0,0:07:19.41,0:07:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Malapetaka Raja Iblis, Puck Puca.
Dialogue: 0,0:07:23.46,0:07:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para manusia memanggilku\Ndengan nama pemilik asli tubuh ini,
Dialogue: 0,0:07:28.00,0:07:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alias Rhyno.
Dialogue: 0,0:07:32.20,0:07:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, selamat bermimpi indah, Spriggan.
Dialogue: 0,0:07:46.43,0:07:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melanjutkan misi.
Dialogue: 0,0:07:49.80,0:07:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku kembali mengecewakan rajaku.
Dialogue: 0,0:07:56.63,0:08:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku mengorbankan boneka darahku.
Dialogue: 0,0:08:02.43,0:08:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Suci itu terlalu berbahaya.
Dialogue: 0,0:08:06.10,0:08:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membunuh mereka,\Naku perlu lebih banyak darah manusia.
Dialogue: 0,0:08:16.36,0:08:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mendengar\Nseluruh perjuangan kalian.
Dialogue: 0,0:08:19.26,0:08:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus. Sempurna.
Dialogue: 0,0:08:22.39,0:08:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:08:24.96,0:08:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, Paman telah memimpin pasukan\Ndengan sangat baik.
Dialogue: 0,0:08:30.82,0:08:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberuntungan memihak kita.
Dialogue: 0,0:08:33.10,0:08:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti berkat dari para leluhur kita.
Dialogue: 0,0:08:36.78,0:08:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat prestasimu hari ini, Paman pasti akan\Nterpilih menjadi Kepala Pendeta tertinggi.
Dialogue: 0,0:08:42.33,0:08:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mendapatkan kehormatan seperti itu,
Dialogue: 0,0:08:45.46,0:08:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menata kembali seluruh personel.
Dialogue: 0,0:08:48.00,0:08:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menggabungkan seluruh kekuatan.
Dialogue: 0,0:08:51.26,0:08:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu terjadi, Patausche,
Dialogue: 0,0:08:53.06,0:08:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memperbaiki situasimu saat ini.
Dialogue: 0,0:09:03.26,0:09:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menata kembali personel, ya.
Dialogue: 0,0:09:06.56,0:09:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:09:08.00,0:09:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa Paman berniat mengubah
Dialogue: 0,0:09:10.25,0:09:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seluruh petinggi Kuil\Nmenjadi anggota faksi koeksistensi?
Dialogue: 0,0:09:22.56,0:09:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berhasil interogasi Lideo Sodrick?
Dialogue: 0,0:09:26.83,0:09:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Utusan faksi koeksistensi yang menemuinya...
Dialogue: 0,0:09:30.06,0:09:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahaeyzel Zelkoff.
Dialogue: 0,0:09:32.80,0:09:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendeta dan pastor akan menyebut nama beliau\Nsaat mendoakan keberuntungan.
Dialogue: 0,0:09:38.06,0:09:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan itu?
Dialogue: 0,0:09:39.66,0:09:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah tengah dan daerah lain\Nmelafalkan namanya sebagai "Zelkooff".
Dialogue: 0,0:09:44.56,0:09:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya orang wilayah utara\Nyang melafalkan "Zelkoff".
Dialogue: 0,0:09:51.03,0:09:54.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya kemampuan finansial\Nyang mampu menggerakkan Guild Petualang,
Dialogue: 0,0:09:54.50,0:09:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta orang dari wilayah utara\Nyang memiliki koneksi ke Kuil...
Dialogue: 0,0:09:58.10,0:10:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lingkup tersangkanya mudah dipersempit.
Dialogue: 0,0:10:01.83,0:10:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, kau sengaja membawa aku,
Dialogue: 0,0:10:06.86,0:10:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gadis yang tak begitu\Nmengenal dunia pergi ke luar.
Dialogue: 0,0:10:11.84,0:10:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambil jalan\Nyang berbeda dengan orang tua...
Dialogue: 0,0:10:14.80,0:10:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau telah memberikan hal yang kuperlukan
Dialogue: 0,0:10:19.30,0:10:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memulai kehidupanku sendiri.
Dialogue: 0,0:10:22.50,0:10:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang ini juga sama.
Dialogue: 0,0:10:28.63,0:10:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat membawaku pergi ke kota,
Dialogue: 0,0:10:31.50,0:10:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman selalu mengenalkan diri\Ndengan nama palsu,
Dialogue: 0,0:10:34.50,0:10:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu Zelkoff.
Dialogue: 0,0:10:37.66,0:10:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kau masih ingat.
Dialogue: 0,0:10:39.45,0:10:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak pernah lupa.
Dialogue: 0,0:10:41.80,0:10:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja,\Naku sudah memeriksa catatan kegiatanmu.
Dialogue: 0,0:10:46.10,0:10:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, dalam pertarungan tadi,
Dialogue: 0,0:10:48.10,0:10:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kompi yang menemukan faerie\Nmenyelinap ke wilayah tengah kota...
Dialogue: 0,0:10:52.90,0:10:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut Paman, mereka adalah Unit 7110.
Dialogue: 0,0:10:59.00,0:11:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi unit itu tidak pernah ada.
Dialogue: 0,0:11:05.03,0:11:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat cerdik.
Dialogue: 0,0:11:12.26,0:11:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman.
Dialogue: 0,0:11:14.06,0:11:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau membantu faksi koeksistensi?
Dialogue: 0,0:11:18.43,0:11:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya demi orang-orang yang kusayang.
Dialogue: 0,0:11:21.66,0:11:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergerak, Paman!
Dialogue: 0,0:11:25.70,0:11:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, keluargaku...
Dialogue: 0,0:11:28.43,0:11:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman!
Dialogue: 0,0:11:31.23,0:11:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, jemaah yang setia pada Kuil.
Dialogue: 0,0:11:35.50,0:11:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menyelamatkan mereka semua.
Dialogue: 0,0:11:40.63,0:11:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patausche.
Dialogue: 0,0:11:44.20,0:11:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umat manusia akan kalah.
Dialogue: 0,0:11:47.56,0:11:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, setidaknya,\Naku ingin memastikan
Dialogue: 0,0:11:51.36,0:11:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keselamatan orang-orang\Nyang menjunjung kebenaran
Dialogue: 0,0:11:53.80,0:11:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan juga keluarga yang aku cintai.
Dialogue: 0,0:11:57.46,0:11:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:11:59.83,0:12:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana dengan manusia lainnya?
Dialogue: 0,0:12:01.86,0:12:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan urusanku!
Dialogue: 0,0:12:05.03,0:12:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sama, Patausche.
Dialogue: 0,0:12:09.16,0:12:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kau ingin menjadi pahlawan\Nyang mengutamakan keselamatan orang asing
Dialogue: 0,0:12:13.20,0:12:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dibandingkan keluargamu sendiri?
Dialogue: 0,0:12:15.79,0:12:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, aku...
Dialogue: 0,0:12:18.12,0:12:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terkadang memiliki sisi kekanakan
Dialogue: 0,0:12:20.26,0:12:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tak kunjung tumbuh dewasa.
Dialogue: 0,0:12:24.60,0:12:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah dewasa, Patausche.
Dialogue: 0,0:12:27.60,0:12:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cintai keluarga dan orang-orang terdekatmu.
Dialogue: 0,0:12:32.63,0:12:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, aku ingin kau ikut\Nmengelola dunia yang akan datang
Dialogue: 0,0:12:36.76,0:12:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai anggota faksi koeksistensi.
Dialogue: 0,0:12:40.96,0:12:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...
Dialogue: 0,0:12:42.49,0:12:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia akan dikalahkan\NMalapetaka Raja Iblis.
Dialogue: 0,0:12:45.86,0:12:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita, sebagai orang-orang\Nyang bertahan hidup
Dialogue: 0,0:12:48.66,0:12:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus memihak para penguasa.
Dialogue: 0,0:12:51.86,0:12:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus membawa orang-orang\Nke jalan yang...
Dialogue: 0,0:12:55.79,0:12:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:13:01.10,0:13:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh disayangkan, Paman.
Dialogue: 0,0:13:08.16,0:13:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... sebenarnya amat sangat...
Dialogue: 0,0:13:13.76,0:13:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar menghormatimu.
Dialogue: 0,0:13:19.43,0:13:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau menangis?
Dialogue: 0,0:13:22.80,0:13:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku tak memiliki\Nhubungan dengan mereka,
Dialogue: 0,0:13:27.70,0:13:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tak mengenal wajah dan nama mereka...
Dialogue: 0,0:13:31.60,0:13:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menelantarkan mereka
Dialogue: 0,0:13:34.23,0:13:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah perbuatan yang salah.
Dialogue: 0,0:13:35.66,0:13:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patausche, itu pola pikir\Nyang egois dan tidak normal.
Dialogue: 0,0:13:42.40,0:13:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin pantas disebut\Nsifat heroik yang dibutakan oleh ego.
Dialogue: 0,0:13:46.76,0:13:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir lagi,\Nakulah yang membesarkanmu seperti itu.
Dialogue: 0,0:13:50.26,0:13:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:13:51.08,0:13:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rajit, tahan dia!
Dialogue: 0,0:13:52.77,0:13:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:13:55.86,0:13:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebus dosamu...
Dialogue: 0,0:14:06.45,0:14:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan!
Dialogue: 0,0:14:32.43,0:14:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh disayangkan, Patausche.
Dialogue: 0,0:14:36.23,0:14:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menganggapmu
Dialogue: 0,0:14:39.56,0:14:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti putriku sendiri.
Dialogue: 0,0:15:10.83,0:15:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cepat. Di sini!\N- Ada apa ini?!
Dialogue: 0,0:15:12.83,0:15:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pendeta Marlen!
Dialogue: 0,0:15:38.63,0:15:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rhyno masih belum pulang?
Dialogue: 0,0:15:40.96,0:15:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa repot kalau kita ketahuan Kivia.
Dialogue: 0,0:15:43.92,0:15:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Venetim, sudah waktunya\Nkau ikat dan rantai dia.
Dialogue: 0,0:15:48.66,0:15:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari semua orang, kenapa Jayce yang usulkan?
Dialogue: 0,0:15:52.13,0:15:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bagaimana kalau kita\Nbebaskan saja Rhyno?
Dialogue: 0,0:15:56.76,0:15:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia sedang\Nmenjarah rumah yang hancur,
Dialogue: 0,0:15:58.90,0:16:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menangkap faerie untuk disiksa.
Dialogue: 0,0:16:01.63,0:16:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah lihat dia bawa pulang faerie\Nyang masih hidup, lo.
Dialogue: 0,0:16:06.27,0:16:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan? Dotta.
Dialogue: 0,0:16:08.33,0:16:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, katanya akan dipakai untuk uji coba.
Dialogue: 0,0:16:12.76,0:16:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bang, sisakan untukku juga, dong!
Dialogue: 0,0:16:17.36,0:16:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:16:18.66,0:16:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau katakan itu\Npadahal yang paling menganggur di sini!
Dialogue: 0,0:16:22.03,0:16:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsav, kuperintahkan kau\Ndan Rhyno introspeksi diri!
Dialogue: 0,0:16:24.70,0:16:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:16:25.83,0:16:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyelamatkan Teoritta dari bahaya, lo!
Dialogue: 0,0:16:28.96,0:16:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa bodoh. Cepat pergi dari sini.
Dialogue: 0,0:16:34.00,0:16:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:16:35.43,0:16:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo!
Dialogue: 0,0:16:38.86,0:16:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Frenci.
Dialogue: 0,0:16:40.80,0:16:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh menyedihkan,\Nkenapa masih santai di sini?
Dialogue: 0,0:16:44.98,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya. Kerjaanku sudah selesai hari ini.
Dialogue: 0,0:16:48.03,0:16:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak minum, aku ambil!
Dialogue: 0,0:16:50.90,0:16:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak mau dengar cacianmu.
Dialogue: 0,0:16:53.95,0:16:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pemalas.
Dialogue: 0,0:16:55.66,0:16:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itukah sikap suami\Nkeluarga Mastibolt?
Dialogue: 0,0:16:58.30,0:17:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemur yang sedang hibernasi saja\Nlebih baik darimu.
Dialogue: 0,0:17:01.56,0:17:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, biarkan aku istirahat.
Dialogue: 0,0:17:03.20,0:17:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasku sudah selesai.
Dialogue: 0,0:17:05.09,0:17:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar, tapi...
Dialogue: 0,0:17:07.50,0:17:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan ke kota ini\Nhanya pengalih perhatian.
Dialogue: 0,0:17:13.00,0:17:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Maksudmu...?
Dialogue: 0,0:17:15.80,0:17:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malapetaka Raja Iblis, "Abaddon",
Dialogue: 0,0:17:18.30,0:17:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhasil menembus pertahanan\NOrde Ke-9 Kesatria Suci,
Dialogue: 0,0:17:21.40,0:17:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyerang Ibu Kota Kedua.
Dialogue: 0,0:17:26.09,0:17:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu kotaku...
Dialogue: 0,0:17:28.20,0:17:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diserang para faerie?
Dialogue: 0,0:17:33.44,0:17:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membaca gerakan kita di sini,
Dialogue: 0,0:17:35.63,0:17:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berhasil mengecoh kita semua.
Dialogue: 0,0:17:38.20,0:17:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:17:39.43,0:17:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:41.23,0:17:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu Kota Kedua telah mereka kuasai.
Dialogue: 0,0:17:47.26,0:17:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu Kota Kedua, Zeyllent
Dialogue: 0,0:17:49.80,0:17:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah simbol Federasi Kerajaan\Nsekaligus wilayah kunci pertahanan nasional.
Dialogue: 0,0:18:01.60,0:18:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benteng Galtuile dan Ibu Kota Pertama
Dialogue: 0,0:18:04.58,0:18:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ibarat leher sudah di ujung pisau.
Dialogue: 0,0:18:12.70,0:18:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya dia membunuh kerabat sendiri.
Dialogue: 0,0:18:14.80,0:18:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang penting di Kuil, 'kan?
Dialogue: 0,0:18:16.50,0:18:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tolong berikan jalan...
Dialogue: 0,0:18:19.11,0:18:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau membunuh Pendeta Marlen?!
Dialogue: 0,0:18:21.50,0:18:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau yang harusnya mati!\N- Buka jalan!
Dialogue: 0,0:18:23.46,0:18:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar sesat!
Dialogue: 0,0:18:24.96,0:18:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eksekusi mati dia!
Dialogue: 0,0:18:26.46,0:18:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, minggir!
Dialogue: 0,0:18:28.56,0:18:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan...
Dialogue: 0,0:18:29.76,0:18:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:18:41.30,0:18:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan Orde Ke-13 Kesatria Suci,\NPatausche Kivia.
Dialogue: 0,0:18:45.18,0:18:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau membunuh\NKepala Pendeta Marlen Kivia
Dialogue: 0,0:18:47.76,0:18:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kapten Unit Artileri, Rajit Heathrow?
Dialogue: 0,0:18:50.86,0:18:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berapa kali kau menanyakan itu?
Dialogue: 0,0:18:53.98,0:18:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman adalah anggota faksi...
Dialogue: 0,0:18:55.24,0:18:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:18:57.00,0:19:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau takut pada kekuatan\Ndan pengaruh Kepala Pendeta Marlen.
Dialogue: 0,0:19:01.56,0:19:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kau mengkhianati umat manusia\Ndan membunuh dia beserta bawahanmu.
Dialogue: 0,0:19:06.16,0:19:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bisa memberikan\Nkesaksian yang akurat mengenai itu,
Dialogue: 0,0:19:09.83,0:19:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa membebaskanmu sekarang juga.
Dialogue: 0,0:19:12.76,0:19:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau apakan bawahanku?
Dialogue: 0,0:19:18.16,0:19:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Unit Pahlawan\Ndan Xylo Forbartz?
Dialogue: 0,0:19:24.20,0:19:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak adakan sidang?!
Dialogue: 0,0:19:26.60,0:19:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku bicara di ruang sidang!
Dialogue: 0,0:19:31.86,0:19:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pikirkanlah sekali lagi.
Dialogue: 0,0:19:34.80,0:19:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya banyak waktu.
Dialogue: 0,0:19:59.56,0:20:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf.
Dialogue: 0,0:20:01.43,0:20:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata perdebatannya\Nlebih lama dari dugaanku.
Dialogue: 0,0:20:06.06,0:20:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami agak ragu karena hanya bisa
Dialogue: 0,0:20:08.96,0:20:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menerima satu orang lagi.
Dialogue: 0,0:20:20.23,0:20:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm... Patausche Kivia.
Dialogue: 0,0:20:24.00,0:20:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan komandan Orde Ke-13 Kesatria Suci.
Dialogue: 0,0:20:27.66,0:20:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat kompeten sebagai tentara,\Ntapi mentalmu cukup mengejutkanku.
Dialogue: 0,0:20:33.70,0:20:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kau bisa membunuh\Norang yang kau hormati.
Dialogue: 0,0:20:37.88,0:20:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau cukup tega untuk menghukum
Dialogue: 0,0:20:40.63,0:20:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang yang sudah mendukung\Ndan kau hormati demi orang asing.
Dialogue: 0,0:20:45.40,0:20:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas sekali ini bukan tindakan\Ndemi keuntungan pribadi.
Dialogue: 0,0:20:49.76,0:20:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya pola pikir bagai seorang pahlawan,
Dialogue: 0,0:20:52.86,0:20:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau lebih tepatnya, sebuah imajinasi liar.
Dialogue: 0,0:20:58.10,0:21:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tahu...?
Dialogue: 0,0:21:01.40,0:21:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dewi"-ku bisa memanggil buku.
Dialogue: 0,0:21:04.86,0:21:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pula disebut memanggil informasi.
Dialogue: 0,0:21:08.70,0:21:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:21:10.76,0:21:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku paham, Enfié.
Dialogue: 0,0:21:15.30,0:21:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:17.43,0:21:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:21:19.90,0:21:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang Kesatria Suci?
Dialogue: 0,0:21:24.30,0:21:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Kesatria Suci yang ke-12.
Dialogue: 0,0:21:27.76,0:21:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang, kita pernah menjadi kolega.
Dialogue: 0,0:21:34.96,0:21:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku akan memberikan pilihan.
Dialogue: 0,0:21:38.36,0:21:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihannya ada dua.
Dialogue: 0,0:21:40.36,0:21:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kau akan dieksekusi\Nsebagai anggota faksi koeksistensi.
Dialogue: 0,0:21:46.56,0:21:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua, menjadi pahlawan terpidana
Dialogue: 0,0:21:50.05,0:21:52.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terus bertarung\Nmelawan Malapetaka Raja Iblis.
Dialogue: 0,0:21:55.96,0:22:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan akan dibangkitkan kembali saat mati,\Ndan tak mengenal kebebasan.
Dialogue: 0,0:22:01.30,0:22:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehormatan pun tak punya.
Dialogue: 0,0:22:03.10,0:22:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan korbankan semuanya demi orang lain.
Dialogue: 0,0:22:07.20,0:22:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, mungkin akan menolak.
Dialogue: 0,0:22:09.76,0:22:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara pribadi,\Nkau tidak akan cocok menjadi itu.
Dialogue: 0,0:22:13.83,0:22:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan...?
Dialogue: 0,0:22:16.50,0:22:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu "Hukuman Pahlawan"?
Dialogue: 0,0:22:22.23,0:22:25.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jawab sejauh yang aku bisa.
Dialogue: 0,0:22:25.10,0:22:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin pernah dengar rumornya.
Dialogue: 0,0:22:28.46,0:22:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dewi" pertama punya kekuatan\Nuntuk memanggil pahlawan.
Dialogue: 0,0:22:34.62,0:22:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat zaman peperangan besar jauh\Ndi masa lampau,
Dialogue: 0,0:22:37.10,0:22:40.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beliau memanggil pahlawan dari dunia lain...
Dialogue: 0,0:22:40.70,0:22:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, tak semuanya sepaham dengan kita.
Dialogue: 0,0:22:47.06,0:22:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, orang-orang pada zaman itu\Nmengubah metodenya.
Dialogue: 0,0:22:51.46,0:22:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memanggil kembali
Dialogue: 0,0:22:54.36,0:22:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manusia yang mati di dunia ini\Nsebagai pahlawan.
Dialogue: 0,0:22:59.90,0:23:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanggil manusia yang mati...?
Dialogue: 0,0:23:03.66,0:23:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembangkitan kembali, ya?
Dialogue: 0,0:23:05.23,0:23:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat.
Dialogue: 0,0:23:08.10,0:23:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan berdiri di garis depan\Npeperangan melawan Malapetaka Raja Iblis,
Dialogue: 0,0:23:12.66,0:23:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak diizinkan untuk mati,\Ndan akan terus bertarung.
Dialogue: 0,0:23:18.30,0:23:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah pahlawan.
Dialogue: 0,0:23:21.96,0:23:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hukuman Pahlawan.
Dialogue: 0,0:23:24.06,0:23:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Alasan kami menyebut itu\Nsebagai hukum pidana sekarang...
Dialogue: 0,0:23:29.46,0:23:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kami punya alasan kami sendiri.
Dialogue: 0,0:23:33.26,0:23:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kekuatan "Dewi" pertama\Ntidak sempurna.
Dialogue: 0,0:23:38.16,0:23:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mungkin tahu apa yang terjadi
Dialogue: 0,0:23:40.55,0:23:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat berulang kali\Ndibangkitkan kembali, bukan?
Dialogue: 0,0:23:47.63,0:23:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagian ingatan akan menghilang,
Dialogue: 0,0:23:50.83,0:23:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mentalnya akan terkikis.
Dialogue: 0,0:23:54.63,0:23:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, manusia punya sesuatu\Nyang disebut "jiwa".
Dialogue: 0,0:23:59.40,0:24:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kualitas pemanggilan,\Natau pembangkitan kembali bergantung pada
Dialogue: 0,0:24:04.56,0:24:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seberapa akuratnya target\Nmampu "mengingat" sesuatu.
Dialogue: 0,0:24:09.55,0:24:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Catatan Enfié bisa membantu,
Dialogue: 0,0:24:14.16,0:24:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi "Dewi" pertama\Nselalu berusaha setiap hari
Dialogue: 0,0:24:18.46,0:24:22.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengingat para pahlawan\Ndan ingatan mereka.
Dialogue: 0,0:24:23.16,0:24:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Porsi mengingatnya hanya tersisa\Nuntuk satu orang lagi.
Dialogue: 0,0:24:29.63,0:24:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pahlawan begitu berharga
Dialogue: 0,0:24:33.30,0:24:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga kalian rela melakukan semua itu?
Dialogue: 0,0:24:38.50,0:24:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:24:40.96,0:24:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku inginnya seperti itu.
Dialogue: 0,0:24:45.83,0:24:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa membongkar rahasia\Nsampai di sini.
Dialogue: 0,0:24:48.83,0:24:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jelaskan segel suci pengekang\Ndan "perbaikan" di lain kesempatan.
Dialogue: 0,0:24:55.10,0:25:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa keputusanmu, Patausche Kivia?
Dialogue: 0,0:25:08.50,0:25:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku mau menjadi pahlawan,
Dialogue: 0,0:25:11.60,0:25:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau bisa mengeluarkan aku\Ndari tempat ini, 'kan?
Dialogue: 0,0:25:14.95,0:25:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa. Tapi kau perlu mati satu kali.
Dialogue: 0,0:25:19.70,0:25:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membongkar dan membawamu keluar.
Dialogue: 0,0:25:23.10,0:25:25.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak punya metode lain.
Dialogue: 0,0:25:25.87,0:25:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau akan mati\Ndengan percaya pada "Dewi" atau tidak?
Dialogue: 0,0:25:31.03,0:25:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihanmu hanya ada dua.
Dialogue: 0,0:25:37.96,0:25:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:25:39.96,0:25:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlahir di rumah pendeta,\Ndan sudah membuang rumahku.
Dialogue: 0,0:25:45.30,0:25:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, adalah satu\Ndari sedikit orang yang paham,
Dialogue: 0,0:25:49.60,0:25:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku membunuhnya dengan kedua tanganku.
Dialogue: 0,0:25:53.83,0:25:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah pikirkan berulang kali\Ndalam kegelapan ini.
Dialogue: 0,0:25:58.36,0:26:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bawahanku\Nserta Unit Pahlawan pikirkan
Dialogue: 0,0:26:00.80,0:26:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat mendengar dosa yang telah kuperbuat?
Dialogue: 0,0:26:06.20,0:26:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak apa jika mereka berpikir aku sudah gila.
Dialogue: 0,0:26:09.70,0:26:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika mereka menganggapku\Nmanusia rendahan...
Dialogue: 0,0:26:14.50,0:26:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mereka menganggap akulah\Nanggota faksi koeksistensi
Dialogue: 0,0:26:18.47,0:26:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mengkhianati umat manusia...
Dialogue: 0,0:26:24.26,0:26:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawahanku...
Dialogue: 0,0:26:27.10,0:26:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika pria itu menganggapku seperti itu...
Dialogue: 0,0:26:35.43,0:26:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan sanggup.
Dialogue: 0,0:26:43.90,0:26:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi.
Dialogue: 0,0:26:46.90,0:26:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku diizinkan bertarung sekali lagi,
Dialogue: 0,0:26:52.26,0:26:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku justru akan bersumpah untuk bertarung\Ndemi orang-orang yang tak kukenal.
Dialogue: 0,0:27:00.80,0:27:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi pahlawan.
Dialogue: 0,0:27:13.56,0:27:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:27:15.32,0:27:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa kembali lagi.
Dialogue: 0,0:27:18.06,0:27:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak merekomendasikan ini.
Dialogue: 0,0:27:20.16,0:27:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga akan diatur\Nagar tak membeberkan apa pun.
Dialogue: 0,0:27:24.50,0:27:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih menolak membuatmu\Nmenjadi seorang pahlawan.
Dialogue: 0,0:27:31.83,0:27:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan tetapi,
Dialogue: 0,0:27:34.00,0:27:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menghormati sumpah itu.
Dialogue: 0,0:27:38.17,0:27:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ambil ini.
Dialogue: 0,0:27:59.40,0:28:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyaksikan tekadmu\Nuntuk semua nyawa itu.
Dialogue: 0,0:28:07.80,0:28:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patausche Kivia.
Dialogue: 0,0:28:10.30,0:28:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dijatuhkan hukuman
Dialogue: 0,0:28:14.33,0:28:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menjadi pahlawan.
