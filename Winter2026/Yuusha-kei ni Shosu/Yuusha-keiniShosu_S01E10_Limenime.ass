Dialogue: 0,0:01:40.95,0:01:44.16,tanda,,0000,0000,0000,,SENTENCED TO BE A HERO
Dialogue: 0,0:00:03.70,0:00:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami hanya menemukan benda-benda ini.
Dialogue: 0,0:00:06.15,0:00:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya dari perapian Guild.
Dialogue: 0,0:00:08.80,0:00:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau sebagian besar sudah hangus terbakar.
Dialogue: 0,0:00:15.69,0:00:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:00:17.51,0:00:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sejenis bukti transaksi.
Dialogue: 0,0:00:23.58,0:00:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahaeyzel Zelkoff.
Dialogue: 0,0:00:27.00,0:00:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja kita bisa menangkap pria itu.
Dialogue: 0,0:00:30.46,0:00:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinannya kecil.
Dialogue: 0,0:00:32.83,0:00:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah dia sudah kabur ke luar kota, atau...
Dialogue: 0,0:00:42.06,0:00:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:00:43.50,0:00:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa memberikan izin.
Dialogue: 0,0:00:45.40,0:00:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar. Aku paham betul soal itu.
Dialogue: 0,0:00:48.96,0:00:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, situasinya sudah berubah.
Dialogue: 0,0:00:51.60,0:00:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini situasi khusus yang membuat kalian\Nharus segera melepaskannya.
Dialogue: 0,0:00:56.70,0:00:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dokumen asli?
Dialogue: 0,0:00:58.69,0:01:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:01:00.00,0:01:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel resmi Galtuile ada di sebelah sini.
Dialogue: 0,0:01:02.50,0:01:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petinggi militer\Nbenar-benar orang yang teliti.
Dialogue: 0,0:01:05.87,0:01:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kau boleh periksa sendiri jika perlu.
Dialogue: 0,0:01:09.70,0:01:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mengurung pahlawan sama seperti\Ntak memberikan hukuman, bukan?
Dialogue: 0,0:01:14.51,0:01:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian seolah mengizinkannya\Nberleha-leha di tempat yang aman.
Dialogue: 0,0:01:20.46,0:01:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:01:25.24,0:01:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu di sini, biar kupastikan dulu.
Dialogue: 0,0:01:27.76,0:01:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, silakan.
Dialogue: 0,0:03:05.53,0:03:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatriaku, aku ingin jalan-jalan ke luar!
Dialogue: 0,0:03:08.70,0:03:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau sependapat denganku, bukan?
Dialogue: 0,0:03:10.90,0:03:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu menyukai Zeff Butter.
Dialogue: 0,0:03:13.86,0:03:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larangan keluar ini sudah keterlaluan!
Dialogue: 0,0:03:16.26,0:03:17.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin pergi ke luar...
Dialogue: 0,0:03:19.23,0:03:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kau bilang seperti itu...
Dialogue: 0,0:03:20.88,0:03:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berkenan, wahai "Dewi",
Dialogue: 0,0:03:22.90,0:03:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merekomendasikan Museum Seni Dujin.
Dialogue: 0,0:03:27.23,0:03:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyimpan banyak mahakarya\Ndari periode klasik pertengahan.
Dialogue: 0,0:03:30.48,0:03:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desain bangunannya menggunakan\Nteknik arsitektur modern Nashida.
Dialogue: 0,0:03:34.96,0:03:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal yang bisa kau lihat di sana.
Dialogue: 0,0:03:37.21,0:03:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota Ioff berada di lokasi strategis\Nuntuk pengangkutan jalur laut...
Dialogue: 0,0:03:38.43,0:03:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Apa serunya pergi ke museum?
Dialogue: 0,0:03:42.36,0:03:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau jalan-jalan, ya ke laut.
Dialogue: 0,0:03:44.66,0:03:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan terbang\Ndi laut lepas sangat indah.
Dialogue: 0,0:03:47.00,0:03:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terbang ke hutan,\Nbisa sekalian berburu.
Dialogue: 0,0:03:49.56,0:03:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan jadikan terbang sebagai standarnya.
Dialogue: 0,0:03:52.46,0:03:55.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti menilai sesuatu\Ndengan standar naga.
Dialogue: 0,0:03:55.96,0:03:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Mau protes?
Dialogue: 0,0:03:58.25,0:04:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku bersedia pergi ke mana pun.
Dialogue: 0,0:04:00.40,0:04:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang, mari pergi ke kota!
Dialogue: 0,0:04:02.66,0:04:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:04:03.96,0:04:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah lupa kita diserang tempo hari?
Dialogue: 0,0:04:06.66,0:04:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinnya takkan turun lagi.
Dialogue: 0,0:04:10.08,0:04:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja...
Dialogue: 0,0:04:11.66,0:04:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:04:12.89,0:04:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa izinkan.
Dialogue: 0,0:04:14.96,0:04:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:04:16.10,0:04:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan masalah selama di sekitar Kuil.
Dialogue: 0,0:04:18.39,0:04:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat dengan fasilitas militer
Dialogue: 0,0:04:19.89,0:04:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kami bisa pastikan\Npengamanan yang sempurna.
Dialogue: 0,0:04:22.32,0:04:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kivia. Engkau terkadang\Nmenyarankan ide yang cemerlang!
Dialogue: 0,0:04:25.80,0:04:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:04:27.70,0:04:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju, tumben kau seperti ini.
Dialogue: 0,0:04:29.82,0:04:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:04:31.50,0:04:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan ini untuk\Nmenghibur Nona Teoritta.
Dialogue: 0,0:04:35.46,0:04:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ada benarnya!
Dialogue: 0,0:04:36.77,0:04:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo, engkau harus ikut menghiburku juga!
Dialogue: 0,0:04:39.48,0:04:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah dia yang suruh sendiri.
Dialogue: 0,0:04:42.24,0:04:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo.
Dialogue: 0,0:04:43.83,0:04:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong sapa Kepala Pendeta Marlen juga.
Dialogue: 0,0:04:46.70,0:04:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kumpulkan tentara kepercayaanku.
Dialogue: 0,0:04:50.02,0:04:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kau tak ikut?
Dialogue: 0,0:04:53.86,0:04:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:04:56.08,0:04:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sibuk.
Dialogue: 0,0:04:58.76,0:05:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:00.09,0:05:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang mengasuh Teoritta.
Dialogue: 0,0:05:07.35,0:05:10.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- "Dewi"!\N- Nona Teoritta sang Dewi Pedang!
Dialogue: 0,0:05:10.62,0:05:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tanda tangan bajuku!
Dialogue: 0,0:05:12.50,0:05:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas bukuku juga!
Dialogue: 0,0:05:14.60,0:05:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:05:16.23,0:05:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewi Teoritta yang perkasa\Nakan membagikan berkatnya!
Dialogue: 0,0:05:20.80,0:05:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hore!\N- Aku juga mau, Nona Teoritta.
Dialogue: 0,0:05:24.51,0:05:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, tanda tangan "Dewi"\Nmampu menghalau bencana.
Dialogue: 0,0:05:29.03,0:05:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata masih banyak yang percaya.
Dialogue: 0,0:05:31.56,0:05:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalau sudah, cepat minggir.
Dialogue: 0,0:05:34.80,0:05:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Dewi.
Dialogue: 0,0:05:36.19,0:05:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan disantap.
Dialogue: 0,0:05:38.96,0:05:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia begitu kecil seperti cucuku,
Dialogue: 0,0:05:40.96,0:05:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sudah bertarung\Nmelawan Malapetaka Raja Iblis.
Dialogue: 0,0:05:44.36,0:05:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, benar. Aku memang hebat!
Dialogue: 0,0:05:47.83,0:05:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Kesatriaku?
Dialogue: 0,0:05:49.43,0:05:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah keinginan terdalam seorang Dewi.
Dialogue: 0,0:05:52.03,0:05:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau pasti bangga.
Dialogue: 0,0:05:53.92,0:05:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku akan bagi kudapan itu denganmu.
Dialogue: 0,0:05:56.07,0:05:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:57.48,0:05:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku memang harus cicip untuk uji racun.
Dialogue: 0,0:06:00.10,0:06:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nek, maaf, ya.\NBiar aku ambil sebentar.
Dialogue: 0,0:06:03.63,0:06:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Elang Gemuruh Petir, Xylo Forbartz!
Dialogue: 0,0:06:06.33,0:06:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh minta tanda tangannya juga, tidak, ya?
Dialogue: 0,0:06:08.46,0:06:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kenal aku juga?
Dialogue: 0,0:06:10.40,0:06:12.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau lumayan populer.
Dialogue: 0,0:06:13.72,0:06:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pendeta Marlen.
Dialogue: 0,0:06:16.40,0:06:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau dikenal setelah kontribusimu
Dialogue: 0,0:06:18.50,0:06:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Benteng Mureed, dan Kerang Sodrick.
Dialogue: 0,0:06:22.96,0:06:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pahlawan terpidana, lo.
Dialogue: 0,0:06:25.40,0:06:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ah, Kepala Pendeta datang!\N- Anak-anak belum memahami makna kata itu.
Dialogue: 0,0:06:27.92,0:06:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kami permisi!
Dialogue: 0,0:06:28.94,0:06:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kesanku terhadapmu juga sudah berubah.\N- Yuk, kita pergi.
Dialogue: 0,0:06:31.92,0:06:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:06:32.60,0:06:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar macam-macam dari keponakanku...
Dialogue: 0,0:06:37.06,0:06:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patausche kerap menganggap\Nremeh nyawanya sendiri
Dialogue: 0,0:06:39.86,0:06:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena mementingkan kehormatan.
Dialogue: 0,0:06:43.90,0:06:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih pantas\Ndisebut naluri kepahlawanan.
Dialogue: 0,0:06:47.72,0:06:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidakkah kau merasa itu merepotkan?
Dialogue: 0,0:06:50.80,0:06:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:06:52.43,0:06:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak orang yang seperti dia.
Dialogue: 0,0:06:54.90,0:06:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama saat berperang\Nmelawan Malapetaka Raja Iblis.
Dialogue: 0,0:06:58.40,0:07:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti mencemaskannya sebagai paman.
Dialogue: 0,0:07:02.43,0:07:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menganggap\NPatausche seperti putriku sendiri.
Dialogue: 0,0:07:06.50,0:07:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan mengampuni orang yang berkhianat,
Dialogue: 0,0:07:10.96,0:07:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau membuatnya sedih.
Dialogue: 0,0:07:14.56,0:07:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik, Xylo Forbartz.
Dialogue: 0,0:07:16.63,0:07:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kau telah\Nmemiliki seorang tunangan.
Dialogue: 0,0:07:19.91,0:07:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:07:20.67,0:07:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunyi bel ini...
Dialogue: 0,0:07:23.76,0:07:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo, ada apa ini?
Dialogue: 0,0:07:25.60,0:07:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita diserang.
Dialogue: 0,0:07:27.34,0:07:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada musuh yang menyusup ke dalam Kota Ioff
Dialogue: 0,0:07:30.46,0:07:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memulai penyerangan.
Dialogue: 0,0:07:41.63,0:07:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kebetulan sekali.
Dialogue: 0,0:07:44.45,0:07:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau... sedang apa di sini?
Dialogue: 0,0:07:47.23,0:07:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang,\Naku menyadari kesalahan di dalam laporanku.
Dialogue: 0,0:07:51.60,0:07:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kuperbaiki sesegera mungkin.
Dialogue: 0,0:07:53.99,0:07:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini menyimpan dokumen penting\Nmengenai militer dan Kuil.
Dialogue: 0,0:07:58.56,0:08:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kalangan perwira yang boleh masuk.
Dialogue: 0,0:08:01.10,0:08:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:08:03.10,0:08:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tak tahu.
Dialogue: 0,0:08:07.49,0:08:08.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap di posisimu.
Dialogue: 0,0:08:08.93,0:08:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluar dari ruangan ini!
Dialogue: 0,0:08:10.46,0:08:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, tentu. Aku akan segera\Nmengumpulkan rekan-rekan Unit Pahlawan.
Dialogue: 0,0:08:13.78,0:08:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon rahasiakan pertemuan kita\Ndi ruangan ini.
Dialogue: 0,0:08:35.32,0:08:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya pikirkan posisiku\Nyang selalu memalsukan suatu dokumen.
Dialogue: 0,0:08:41.49,0:08:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Xylo.
Dialogue: 0,0:08:44.56,0:08:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kawanku, Xylo.
Dialogue: 0,0:08:47.10,0:08:49.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kau sehat-sehat saja.
Dialogue: 0,0:08:49.50,0:08:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau dapat banyak masalah\Nselama kepergianku.
Dialogue: 0,0:08:52.80,0:08:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku turut prihatin dari balik jeruji.
Dialogue: 0,0:08:55.76,0:08:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyuman sinismu masih belum berubah banyak.
Dialogue: 0,0:08:58.76,0:09:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diakah "Dewi" itu?
Dialogue: 0,0:09:04.02,0:09:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu, Nona Teoritta.
Dialogue: 0,0:09:06.48,0:09:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rhyno.
Dialogue: 0,0:09:08.00,0:09:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertugas sebagai artileri\Ndi Unit 9004 Pahlawan Terpidana.
Dialogue: 0,0:09:12.49,0:09:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Kawan Xylo\Nyang ada di sini adalah partner.
Dialogue: 0,0:09:16.86,0:09:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali bukan.
Dialogue: 0,0:09:18.49,0:09:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Venetim!
Dialogue: 0,0:09:20.06,0:09:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membebaskannya terlalu cepat.
Dialogue: 0,0:09:22.60,0:09:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai emosi saat melihat wajahnya.
Dialogue: 0,0:09:25.40,0:09:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo, kau yang menyuruhku\Nmengeluarkannya, lo?!
Dialogue: 0,0:09:27.79,0:09:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ampun, dah.
Dialogue: 0,0:09:28.48,0:09:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengajukan diri menjadi pahlawan\Ntapi malah dipenjara.
Dialogue: 0,0:09:31.26,0:09:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sebenarnya ingin lakukan apa?
Dialogue: 0,0:09:33.44,0:09:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin
Dialogue: 0,0:09:34.68,0:09:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendedikasikan diri bagi orang-orang\Ntak berdaya yang menjadi korban faerie.
Dialogue: 0,0:09:38.80,0:09:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya pilihan selain rencana itu.
Dialogue: 0,0:09:41.86,0:09:45.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak punya pilihan selain\Nmeledakkan rumah-rumah penduduk?
Dialogue: 0,0:09:45.80,0:09:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak jelas.
Dialogue: 0,0:09:47.40,0:09:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.
Dialogue: 0,0:09:49.03,0:09:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, mari menyatukan kekuatan\Nuntuk melewati kondisi saat ini.
Dialogue: 0,0:09:55.10,0:09:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah...
Dialogue: 0,0:09:56.46,0:09:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah pelabuhan Ioff Cheg.
Dialogue: 0,0:09:58.80,0:10:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya ada faerie\Nyang muncul di wilayah ini.
Dialogue: 0,0:10:02.06,0:10:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawanan itu bergerak menuju ke sini...
Dialogue: 0,0:10:05.63,0:10:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tui Jia, Menara Terumbu Karang\Ntelah mereka kuasai.
Dialogue: 0,0:10:09.94,0:10:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu garda utama pertahanan laut.
Dialogue: 0,0:10:15.23,0:10:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Raja Iblis di dalam kawanan itu,
Dialogue: 0,0:10:17.70,0:10:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Tui Jia perlahan mengalami\Nkontaminasi perubahan faerie.
Dialogue: 0,0:10:21.05,0:10:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jebakan.
Dialogue: 0,0:10:24.59,0:10:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan juga punya pasukan artileri, 'kan?
Dialogue: 0,0:10:26.80,0:10:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat arah dan kecepatan angin saat ini,
Dialogue: 0,0:10:28.90,0:10:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka bisa meledakkan seluruh\Nwilayah Ioff Cheg dari Tiu Jia.
Dialogue: 0,0:10:32.90,0:10:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, mereka menyandera\Nseluruh penduduk wilayah itu, ya.
Dialogue: 0,0:10:36.50,0:10:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perintah dari Galtuile?
Dialogue: 0,0:10:38.50,0:10:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada.
Dialogue: 0,0:10:39.58,0:10:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai itu...
Dialogue: 0,0:10:41.46,0:10:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orde Ke-13 Kesatria Suci\Ndan Pasukan Keamanan Kota Ioff
Dialogue: 0,0:10:44.36,0:10:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan bersiaga di bagian tengah kota.
Dialogue: 0,0:10:46.76,0:10:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawalan wilayah pelabuhan diserahkan\Npada Unit Pahlawan saja.
Dialogue: 0,0:10:50.42,0:10:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:10:52.00,0:10:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan menunggu bala bantuan datang,
Dialogue: 0,0:10:54.20,0:10:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bertahan sampai seluruh pasukan\Nbisa melawan balik...
Dialogue: 0,0:10:57.96,0:10:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menunggu bala bantuan, katamu?!
Dialogue: 0,0:10:59.66,0:11:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berniat mencampakkan\Npenduduk wilayah pelabuhan?
Dialogue: 0,0:11:01.99,0:11:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pasti karena Federasi Bangsawan ingin\Nutamakan perlindungan wilayah tengah kota.
Dialogue: 0,0:11:06.10,0:11:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena institusi penting dan harta\Npara bangsawan berada di wilayah darat!
Dialogue: 0,0:11:11.06,0:11:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:11:11.90,0:11:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aset pribadi jauh lebih penting, ya.
Dialogue: 0,0:11:14.23,0:11:15.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:11:15.56,0:11:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, tak ada artinya terluka\Natau tewas dalam pertarungan ini.
Dialogue: 0,0:11:20.26,0:11:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:20.82,0:11:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebaiknya hindari tindakan yang agresif.
Dialogue: 0,0:11:24.86,0:11:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Engkau sungguh memalukan, Venetim!
Dialogue: 0,0:11:27.20,0:11:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak peduli sesulit apa pun situasinya,
Dialogue: 0,0:11:29.00,0:11:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ini, hanya kita yang mampu\Nmenyelamatkan rakyat!
Dialogue: 0,0:11:33.10,0:11:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, perang ini layak\Ndipertaruhkan dengan nyawa kita!
Dialogue: 0,0:11:36.80,0:11:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan bilang\Nmempertaruhkan nyawa semudah...
Dialogue: 0,0:11:39.79,0:11:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dewi" memang hebat.
Dialogue: 0,0:11:41.94,0:11:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekadmu benar-benar luar biasa!
Dialogue: 0,0:11:44.50,0:11:46.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sependapat denganmu!
Dialogue: 0,0:11:46.63,0:11:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawan Xylo, inilah pertarungan kita.
Dialogue: 0,0:11:50.20,0:11:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berjuang bersama demi masa depan\Ndan harapan orang-orang!
Dialogue: 0,0:11:54.36,0:11:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik. Apa pun itu, waktunya kerja.
Dialogue: 0,0:11:57.32,0:11:59.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo, engkau pasti bisa lakukan.
Dialogue: 0,0:12:00.43,0:12:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya engkau bisa.
Dialogue: 0,0:12:03.86,0:12:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:05.16,0:12:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan semua berjalan\Nsesuai rencana para bajingan itu.
Dialogue: 0,0:12:08.98,0:12:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya mereka meremehkanku.
Dialogue: 0,0:12:14.36,0:12:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bangun benteng di sini!
Dialogue: 0,0:12:16.40,0:12:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sinilah selter untuk evakuasi penduduk!
Dialogue: 0,0:12:18.67,0:12:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangunlah pagar bersegel suci\Nsesuai desainku!
Dialogue: 0,0:12:22.46,0:12:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:23.56,0:12:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, siapkan api!
Dialogue: 0,0:12:25.74,0:12:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari peralatan masak bersegel suci\Ndan bahan makanannya!
Dialogue: 0,0:12:29.06,0:12:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:30.27,0:12:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa ada orang Guild di sini?
Dialogue: 0,0:12:33.00,0:12:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, Raja menjanjikan mereka pekerjaan.
Dialogue: 0,0:12:36.30,0:12:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengkap dengan posisi dan gaji.
Dialogue: 0,0:12:39.28,0:12:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi?
Dialogue: 0,0:12:41.07,0:12:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai dari kumpulkan bahan kayu!
Dialogue: 0,0:12:43.36,0:12:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumpulkan sebanyak mungkin!
Dialogue: 0,0:12:45.21,0:12:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:45.95,0:12:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat! Jangan bermalas-malasan!
Dialogue: 0,0:12:46.69,0:12:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, setidaknya lebih baik\Ndibandingkan hidup sebagai bandit.
Dialogue: 0,0:13:01.03,0:13:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini panas tapi lezat!
Dialogue: 0,0:13:03.00,0:13:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tatsuya.
Dialogue: 0,0:13:05.02,0:13:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga makan.
Dialogue: 0,0:13:08.92,0:13:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:13:09.86,0:13:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pakai tangan!
Dialogue: 0,0:13:11.63,0:13:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kau buru-buru saat makan.
Dialogue: 0,0:13:13.30,0:13:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga belepotan, tahu.
Dialogue: 0,0:13:18.83,0:13:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan yang hangat\Nmeningkatkan moral pasukan.
Dialogue: 0,0:13:22.60,0:13:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawan Norgalle memang luar biasa
Dialogue: 0,0:13:25.43,0:13:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena ia segera menyiapkan makanan.
Dialogue: 0,0:13:27.41,0:13:28.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:13:29.49,0:13:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Penampilan yang luar biasa.
Dialogue: 0,0:13:32.03,0:13:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rangkaian segel artileri Neven.
Dialogue: 0,0:13:34.70,0:13:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak tahu\Nkenapa dia punya zirah model lama itu.
Dialogue: 0,0:13:40.76,0:13:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sejak seluruh\Nanggota unit kita berkumpul,
Dialogue: 0,0:13:44.06,0:13:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Kawan Tsav dan Kawan Jayce\Ntak bisa maju, ya?
Dialogue: 0,0:13:48.66,0:13:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsav sedang pengobatan untuk lengannya.
Dialogue: 0,0:13:51.01,0:13:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, seperti inilah situasinya.
Dialogue: 0,0:13:53.56,0:13:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suruh dia ke sini\Nsetelah dapat penanganan minimum.
Dialogue: 0,0:13:55.86,0:13:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh.
Dialogue: 0,0:13:57.14,0:13:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Kawan Jayce?
Dialogue: 0,0:13:58.66,0:14:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak dapat izin untuk terjun ke lapangan?
Dialogue: 0,0:14:01.16,0:14:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Venetim sedang negosiasi untuk itu.
Dialogue: 0,0:14:03.76,0:14:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau berbahaya menurunkan naga\Ndi tengah kota, tapi aman, lah.
Dialogue: 0,0:14:09.00,0:14:11.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja tak bisa bergerak dari selter.
Dialogue: 0,0:14:11.46,0:14:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dotta harus memeriksa alur pertarungan\Ndi medan perang.
Dialogue: 0,0:14:14.66,0:14:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya kita berempat yang maju ke Tui Jia.
Dialogue: 0,0:14:17.30,0:14:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, intinya...
Dialogue: 0,0:14:19.56,0:14:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kekurangan orang.
Dialogue: 0,0:14:22.85,0:14:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh mengusulkan satu hal?
Dialogue: 0,0:14:27.66,0:14:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dengarkan.
Dialogue: 0,0:14:29.64,0:14:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ledakkan saja tembok ini.
Dialogue: 0,0:14:32.40,0:14:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada faerie yang masuk\Nke wilayah tengah,
Dialogue: 0,0:14:34.90,0:14:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka tentara selain kita\Nterpaksa ikut bertarung.
Dialogue: 0,0:14:37.85,0:14:40.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita takkan kekurangan orang lagi.
Dialogue: 0,0:14:40.66,0:14:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:42.30,0:14:46.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus berbagi derita dan rasa sakit.
Dialogue: 0,0:14:46.23,0:14:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia adalah makhluk hebat\Nyang bisa punya ikatan dengan cara itu.
Dialogue: 0,0:14:50.96,0:14:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatriaku, pria ini...
Dialogue: 0,0:14:53.58,0:14:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:14:55.43,0:14:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menolak.
Dialogue: 0,0:14:56.60,0:14:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membahayakan nyawa warga sipil,\Ndasar bodoh.
Dialogue: 0,0:14:59.39,0:14:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:15:00.26,0:15:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Kawan Xylo, kau punya ide?
Dialogue: 0,0:15:03.38,0:15:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rhyno.
Dialogue: 0,0:15:04.50,0:15:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menggerakkan kebanyakan\Nmanusia bukanlah ikatan,
Dialogue: 0,0:15:08.20,0:15:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi keuntungan.
Dialogue: 0,0:15:10.20,0:15:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembaklah kapal yang ada di pelabuhan.
Dialogue: 0,0:15:13.30,0:15:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa mencapai itu dari sini, 'kan?
Dialogue: 0,0:15:16.22,0:15:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Aku mengerti.
Dialogue: 0,0:15:18.26,0:15:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawan Xylo memang cerdik.
Dialogue: 0,0:15:20.56,0:15:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, jatuhkan itu.
Dialogue: 0,0:15:23.90,0:15:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita rebut kembali Tui Jia,\Ndan bunuh Raja Iblis.
Dialogue: 0,0:15:36.50,0:15:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan Kivia.\NMohon perintah untuk operasi ini.
Dialogue: 0,0:15:39.90,0:15:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik. Aku segera ke sana.
Dialogue: 0,0:15:45.76,0:15:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat berapa kali pun,\Nperintah ini sungguh tak masuk akal.
Dialogue: 0,0:15:48.26,0:15:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:15:49.83,0:15:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita butuh dukungan para bangsawan,
Dialogue: 0,0:15:52.03,0:15:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan banyak bangunan Kuil\Nberada di wilayah ini.
Dialogue: 0,0:15:56.89,0:15:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf tiba-tiba datang.
Dialogue: 0,0:15:59.85,0:16:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa?
Dialogue: 0,0:16:01.30,0:16:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Unit Pahlawan\Nsudah diperintahkan turun?
Dialogue: 0,0:16:05.01,0:16:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:05.79,0:16:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai komandan, aku bermaksud mengerahkan\Nmereka bertarung dengan gagah berani.
Dialogue: 0,0:16:11.03,0:16:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tampaknya kapal bersegel suci\Ndi pelabuhan telah diserang para faerie.
Dialogue: 0,0:16:16.49,0:16:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:16:17.70,0:16:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak boleh sampai kehilangan aset Kuil.
Dialogue: 0,0:16:22.10,0:16:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maka dari itu,\Naku meminta izin untuk mengirimkan naga.
Dialogue: 0,0:16:25.46,0:16:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin.
Dialogue: 0,0:16:26.46,0:16:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil para faerie memprioritaskan\Npenyerangan kapal bersegel suci...
Dialogue: 0,0:16:29.66,0:16:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lapor!
Dialogue: 0,0:16:31.03,0:16:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal bersegel suci besar terbakar!
Dialogue: 0,0:16:35.36,0:16:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pihak Kuil telah mengajukan\Npermintaan bantuan!
Dialogue: 0,0:16:40.40,0:16:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus. Pergilah.
Dialogue: 0,0:16:42.36,0:16:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:16:46.30,0:16:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:47.50,0:16:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bohong, 'kan?
Dialogue: 0,0:16:49.26,0:16:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:16:50.86,0:16:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak percaya\Nsaat pertama kali mendengar kabarnya.
Dialogue: 0,0:16:54.36,0:16:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar disayangkan.
Dialogue: 0,0:16:58.80,0:16:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:59.95,0:17:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuizinkan kalian memakai naga.
Dialogue: 0,0:17:02.16,0:17:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan?!
Dialogue: 0,0:17:03.10,0:17:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuil telah mengajukan permintaan, ini wajar.
Dialogue: 0,0:17:06.09,0:17:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakkan pasukan kita juga.
Dialogue: 0,0:17:08.35,0:17:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kemurahan hatimu.
Dialogue: 0,0:17:11.17,0:17:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, satu lagi.
Dialogue: 0,0:17:12.76,0:17:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku titip pesan untuk Kepala Pendeta Marlen.
Dialogue: 0,0:17:18.06,0:17:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:17:20.43,0:17:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak. Aku hanya...
Dialogue: 0,0:17:22.39,0:17:23.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan pamanku?
Dialogue: 0,0:17:23.98,0:17:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau sadari?!
Dialogue: 0,0:17:25.72,0:17:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, aku tak tahu...
Dialogue: 0,0:17:29.23,0:17:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pamanku...
Dialogue: 0,0:17:30.56,0:17:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Pendeta Marlen\Nadalah sosok yang terpuji!
Dialogue: 0,0:17:33.30,0:17:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia mengusahakan segala macam untuk Kuil,
Dialogue: 0,0:17:35.30,0:17:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan selalu mendukungku serta Kesatria Suci!
Dialogue: 0,0:17:38.24,0:17:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau... pada orang sehebat dirinya...
Dialogue: 0,0:17:41.81,0:17:42.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu!
Dialogue: 0,0:17:43.46,0:17:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya... Begini...
Dialogue: 0,0:17:45.46,0:17:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bilangnya, ya?
Dialogue: 0,0:17:47.06,0:17:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima usulan untuk mengirim pengawal\Ndi jalur air di bawah tanah.
Dialogue: 0,0:18:03.97,0:18:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:18:05.10,0:18:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sana!
Dialogue: 0,0:18:06.51,0:18:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi ke selter!
Dialogue: 0,0:18:10.00,0:18:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo. Mereka datang dari depan,\Nkawanan Bogie!
Dialogue: 0,0:18:12.73,0:18:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kanan juga. Kita terkepung!
Dialogue: 0,0:18:14.86,0:18:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:18:15.65,0:18:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dotta, kau tetap berjaga di sana.
Dialogue: 0,0:18:18.76,0:18:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka datang!
Dialogue: 0,0:18:22.41,0:18:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walah, walah.
Dialogue: 0,0:18:24.54,0:18:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bogie adalah lawan terburuk artileri.
Dialogue: 0,0:18:26.83,0:18:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawan Xylo, kuserahkan padamu.
Dialogue: 0,0:18:29.10,0:18:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:18:38.38,0:18:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mulai juga, Teoritta!
Dialogue: 0,0:18:40.66,0:18:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:18:41.86,0:18:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberkatimu!
Dialogue: 0,0:18:54.69,0:18:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyah!
Dialogue: 0,0:18:59.16,0:19:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memiliki kawan sesama\Npahlawan memang yang terbaik.
Dialogue: 0,0:19:02.56,0:19:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh beruntung.
Dialogue: 0,0:19:05.41,0:19:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita maju.
Dialogue: 0,0:19:06.60,0:19:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kita tembus langsung ke Tui Jia...\N- Tunggu!
Dialogue: 0,0:19:09.20,0:19:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada gudang di depan sana.
Dialogue: 0,0:19:11.40,0:19:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:19:12.33,0:19:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana ada segel Perusahaan Varkle.
Dialogue: 0,0:19:15.00,0:19:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga melihat api unggun.
Dialogue: 0,0:19:16.70,0:19:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada orang di dalam sana.
Dialogue: 0,0:19:18.66,0:19:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dikepung faerie.
Dialogue: 0,0:19:20.55,0:19:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jadi lokasi evakuasi, ya.
Dialogue: 0,0:19:22.56,0:19:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Ini merepotkan.
Dialogue: 0,0:19:24.26,0:19:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa keputusanmu, Kawan Xylo?
Dialogue: 0,0:19:27.20,0:19:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo, ini pertarungan penuh kehormatan.
Dialogue: 0,0:19:32.03,0:19:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:19:33.69,0:19:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:19:44.46,0:19:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rhyno, aku ingin kau terus bekerja\Nsampai mati.
Dialogue: 0,0:19:47.40,0:19:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persiapkan dirimu!
Dialogue: 0,0:19:48.53,0:19:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:19:50.90,0:19:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rela mengabdi demi\Norang-orang yang tak kukenal.
Dialogue: 0,0:19:58.16,0:19:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya mulai menyenangkan.
Dialogue: 0,0:20:19.66,0:20:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segel Penghancur kena telak.
Dialogue: 0,0:20:22.06,0:20:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa membentuk tim yang baik.
Dialogue: 0,0:20:24.98,0:20:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama "Dewi" Teoritta.
Dialogue: 0,0:20:27.43,0:20:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanmu sungguh luar biasa.
Dialogue: 0,0:20:29.44,0:20:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu.
Dialogue: 0,0:20:31.26,0:20:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku merasa kurang puas\Nkarena dipuji olehmu.
Dialogue: 0,0:20:37.46,0:20:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu sewaspada itu di dekatku.
Dialogue: 0,0:20:40.20,0:20:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua mirip.
Dialogue: 0,0:20:42.35,0:20:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak.
Dialogue: 0,0:20:44.60,0:20:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Suci akan bergerak sebentar lagi.
Dialogue: 0,0:20:46.96,0:20:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, 'kan, Venetim?
Dialogue: 0,0:20:48.72,0:20:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Ah, benar.
Dialogue: 0,0:20:50.54,0:20:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga dapat izin untuk mengirim Jayce.
Dialogue: 0,0:20:53.52,0:20:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, penutupan jalur air bawah tanah.
Dialogue: 0,0:20:55.55,0:20:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalur air?
Dialogue: 0,0:20:57.06,0:20:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang menyusup ke sana?
Dialogue: 0,0:20:58.46,0:21:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku asal bicara\Nkarena terbawa suasana.
Dialogue: 0,0:21:01.68,0:21:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal apa? Kau...
Dialogue: 0,0:21:03.83,0:21:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, menurutku itu keputusan yang bijak.
Dialogue: 0,0:21:05.96,0:21:08.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menjaga ketat wilayah kota.
Dialogue: 0,0:21:09.03,0:21:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah kota dikawal oleh orang-orang\NPenghuni Malam di bawah pimpinan Frenci.
Dialogue: 0,0:21:12.66,0:21:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka harus mengurus Spriggan.
Dialogue: 0,0:21:14.48,0:21:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Xylo!
Dialogue: 0,0:21:15.58,0:21:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh di kanan bagian depan. Di atas atap!
Dialogue: 0,0:21:18.21,0:21:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat!
Dialogue: 0,0:21:19.83,0:21:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:21.00,0:21:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang gawat?
Dialogue: 0,0:21:26.23,0:21:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, tongkat petir, ya?
Dialogue: 0,0:21:27.98,0:21:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka mereka bisa pakai segel suci.
Dialogue: 0,0:21:30.18,0:21:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:21:31.41,0:21:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini perbuatan Faksi Koeksistensi itu, ya?
Dialogue: 0,0:21:33.71,0:21:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rhyno!
Dialogue: 0,0:21:36.00,0:21:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:21:48.20,0:21:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tak ada yang rusak.
Dialogue: 0,0:21:50.42,0:21:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, aku menghabiskan sedikit sinar.
Dialogue: 0,0:21:55.90,0:21:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Kalau bisa, aku ingin kabur\Nke lorong untuk menghindari tembakan.
Dialogue: 0,0:21:58.80,0:22:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita tak punya\Nwaktu untuk memutar.
Dialogue: 0,0:22:01.06,0:22:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hentikan...!
Dialogue: 0,0:22:13.03,0:22:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ru-Rumah orang-orang...
Dialogue: 0,0:22:16.06,0:22:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Kita harus mengutamakan\Nkeselamatan penduduk.
Dialogue: 0,0:22:19.86,0:22:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu masalahnya.
Dialogue: 0,0:22:22.23,0:22:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari berangkat!
Dialogue: 0,0:22:24.10,0:22:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menuju orang-orang yang butuh bantuan kita!
Dialogue: 0,0:22:27.38,0:22:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serang!\N- Habisi semua!
Dialogue: 0,0:22:31.23,0:22:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan biarkan mereka\Nmemasuki wilayah tengah!
Dialogue: 0,0:22:33.56,0:22:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:22:37.25,0:22:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Mereka yang terakhir!
Dialogue: 0,0:22:39.63,0:22:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembak!
Dialogue: 0,0:22:42.67,0:22:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ditutup, ya.
Dialogue: 0,0:22:45.42,0:22:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berencana memasukkan faerie\Nmelalui jalur air di bawah tanah.
Dialogue: 0,0:22:50.39,0:22:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana yang benar-benar cerdik.
Dialogue: 0,0:22:53.26,0:22:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menghormatinya.
Dialogue: 0,0:22:55.96,0:22:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu? Siapa di sana?
Dialogue: 0,0:22:57.57,0:22:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faerie, ya?
Dialogue: 0,0:22:59.08,0:23:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Manusia?
Dialogue: 0,0:23:00.64,0:23:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:23:01.42,0:23:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa di sana?
Dialogue: 0,0:23:03.20,0:23:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, mohon jangan melawan balik.
Dialogue: 0,0:23:07.25,0:23:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasihan melihat kalian mati menderita.
Dialogue: 0,0:23:32.29,0:23:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman!
Dialogue: 0,0:23:33.90,0:23:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Patausche. Terima kasih sudah datang.
Dialogue: 0,0:23:36.50,0:23:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar, ada faerie yang muncul\Ndi wilayah tengah kota.
Dialogue: 0,0:23:39.39,0:23:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.\NAku sudah dapat laporan dari sekuriti.
Dialogue: 0,0:23:42.56,0:23:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka menyelinap\Ndari bawah tanah.
Dialogue: 0,0:23:55.66,0:23:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pihak militer dan Kuil bekerja sama...?
Dialogue: 0,0:23:58.46,0:24:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Paman yang mengumpulkan pasukan itu?
Dialogue: 0,0:24:01.50,0:24:04.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktu yang tepat\Nuntuk diam berpangku tangan.
Dialogue: 0,0:24:04.76,0:24:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa aku menjadi\NKepala Pendeta bila tak mampu
Dialogue: 0,0:24:07.26,0:24:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyatukan kedua pihak ini?
Dialogue: 0,0:24:09.70,0:24:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam situasi ini hubungan militer\Ndan Kuil pasti sangatlah kuat.
Dialogue: 0,0:24:14.66,0:24:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan itu pasti bisa mengantar\Numat manusia pada kemenangan.
Dialogue: 0,0:24:20.10,0:24:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman.
Dialogue: 0,0:24:23.10,0:24:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kagum pada dedikasimu.
Dialogue: 0,0:24:27.00,0:24:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengandalkanmu, Patausche.
Dialogue: 0,0:24:29.36,0:24:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lewati cobaan ini bersama.
Dialogue: 0,0:24:32.10,0:24:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:24:39.03,0:24:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga Mahaeyzel yang suci memberkatimu.
Dialogue: 0,0:24:44.92,0:24:47.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari putar keadaan.
