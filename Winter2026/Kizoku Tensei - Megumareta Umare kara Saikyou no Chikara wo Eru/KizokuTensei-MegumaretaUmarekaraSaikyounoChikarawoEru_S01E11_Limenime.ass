Dialogue: 0,0:00:02.37,0:00:03.61,Default,,0,0,0,,{\i1}Apa ini?{\i0}
Dialogue: 0,0:00:04.49,0:00:08.32,Default,,0,0,0,,{\i1}Rasanya seolah jiwaku\Nterempas ke tempat jauh.{\i0}
Dialogue: 0,0:00:13.34,0:00:17.29,Default,,0,0,0,,Sudah seribu tahun sejak\Nkami berempat berkumpul.
Dialogue: 0,0:00:18.87,0:00:20.83,Default,,0,0,0,,Kira-kira sejak Zaman Perak.
Dialogue: 0,0:00:22.89,0:00:25.13,Default,,0,0,0,,Bocah waktu itu juga sangat kuat.
Dialogue: 0,0:00:25.13,0:00:26.84,Default,,0,0,0,,Levelnya 255.
Dialogue: 0,0:00:27.09,0:00:31.34,Default,,0,0,0,,Kami ditundukkan\Ndan kekuatan kami dikembalikan.
Dialogue: 0,0:00:31.77,0:00:32.76,Default,,0,0,0,,{\i1}Kenapa?{\i0}
Dialogue: 0,0:00:32.96,0:00:34.43,Default,,0,0,0,,{\i1}Suara ini belum pernah kudengar.{\i0}
Dialogue: 0,0:00:34.62,0:00:36.14,Default,,0,0,0,,{\i1}Tapi tidak terasa asing.{\i0}
Dialogue: 0,0:00:37.09,0:00:38.20,Default,,0,0,0,,Tak lama lagi,
Dialogue: 0,0:00:38.38,0:00:40.19,Default,,0,0,0,,hari saat kita berkumpul
Dialogue: 0,0:00:40.29,0:00:43.11,Default,,0,0,0,,dan kekuatan kita kembali akan tiba.
Dialogue: 0,0:00:43.50,0:00:45.94,Default,,0,0,0,,Ini momen penuh sukacita\Nsejak dunia diciptakan.
Dialogue: 0,0:00:47.39,0:00:48.30,Default,,0,0,0,,Wah, wah.
Dialogue: 0,0:00:48.54,0:00:50.95,Default,,0,0,0,,Sepertinya kau menyukai anak ini.
Dialogue: 0,0:00:51.26,0:00:53.87,Default,,0,0,0,,Wahai Leviathan, sang Anjing Gila.
Dialogue: 0,0:01:01.50,0:01:04.09,Default,,0,0,0,,{\i1}Ini... halusinasi pendengaran?{\i0}
Dialogue: 0,0:01:04.89,0:01:06.38,Default,,0,0,0,,Suara surgawi!
Dialogue: 0,0:01:07.97,0:01:09.97,Default,,0,0,0,,- Yang barusan itu Tuhan, kan?\N- Aku juga dengar.
Dialogue: 0,0:01:09.97,0:01:12.68,Default,,0,0,0,,- Surga pun menaruh asa pada Pangeran!\N- Hebat!
Dialogue: 0,0:01:17.70,0:01:19.43,Default,,0,0,0,,Aku juga mendengarnya.
Dialogue: 0,0:01:19.83,0:01:21.31,Default,,0,0,0,,Kau hebat, Nak.
Dialogue: 0,0:01:21.57,0:01:22.98,Default,,0,0,0,,Momen penuh sukacita!
Dialogue: 0,0:01:23.31,0:01:24.77,Default,,0,0,0,,Tuan Indra juga berkata begitu?
Dialogue: 0,0:01:25.29,0:01:25.94,Default,,0,0,0,,Gigi.
Dialogue: 0,0:01:26.31,0:01:27.44,Default,,0,0,0,,Ya, Tuan!
Dialogue: 0,0:01:27.79,0:01:32.86,Default,,0,0,0,,Bagikan 5... Maksudku, 10 riin\Npada mereka yang ada di sini.
Dialogue: 0,0:01:32.97,0:01:35.40,Default,,0,0,0,,- Siap!\N- Hidup Pangeran Arif!
Dialogue: 0,0:01:35.40,0:01:36.58,Default,,0,0,0,,Terima kasih banyak!
Dialogue: 0,0:01:36.93,0:01:39.91,Default,,0,0,0,,Sosok yang diakui Tuhan\Nmemanglah hebat!
Dialogue: 0,0:01:39.91,0:01:41.12,Default,,0,0,0,,Hidup!
Dialogue: 0,0:01:42.10,0:01:45.57,Default,,0,0,0,,- Silakan.\N- {\i1}Pada momen penuh sukacita,{\i0}
Dialogue: 0,0:01:45.94,0:01:47.50,Default,,0,0,0,,{\i1}momen itu tidak dinikmati sendiri,{\i0}
Dialogue: 0,0:01:47.63,0:01:51.92,Default,,0,0,0,,{\i1}tapi juga merayakan bersama orang banyak.\NItu termasuk kewajiban bangsawan.{\i0}
Dialogue: 0,0:01:53.61,0:01:57.01,Default,,0,0,0,,{\i1}Konon, yang keberatan pada hal itu\Nadalah bangsawan kelas tiga.{\i0}
Dialogue: 0,0:01:57.60,0:02:00.98,Default,,0,0,0,,{\i1}Yang melakukannya ogah-ogahan\Nadalah bangsawan kelas dua.{\i0}
Dialogue: 0,0:02:01.28,0:02:05.31,Default,,0,0,0,,{\i1}Dan yang melakukannya secara alamiah\Nadalah bangsawan kelas satu.{\i0}
Dialogue: 0,0:02:09.53,0:02:11.78,Default,,0,0,0,,Saya memohon maaf\Npada Pangeran Arif.
Dialogue: 0,0:02:11.84,0:02:14.95,Default,,0,0,0,,Perkenankan saya\Nmenolak bantuan Pangeran.
Dialogue: 0,0:02:15.77,0:02:16.77,Default,,0,0,0,,Kenapa?
Dialogue: 0,0:02:17.43,0:02:19.79,Default,,0,0,0,,Karena saya ingin\Nmenjadi kesatria Pangeran.
Dialogue: 0,0:02:20.07,0:02:21.00,Default,,0,0,0,,Demi mewujudkannya,
Dialogue: 0,0:02:21.12,0:02:25.25,Default,,0,0,0,,saya akan mengasah kemampuan dan\Nmenjadi manusia yang layak bagi Pangeran.
Dialogue: 0,0:02:26.85,0:02:27.71,Default,,0,0,0,,Aku menolaknya.
Dialogue: 0,0:02:28.75,0:02:29.55,Default,,0,0,0,,Kenapa?
Dialogue: 0,0:02:29.86,0:02:32.38,Default,,0,0,0,,Menerima bantuan lalu malas\Nmemang dilarang,
Dialogue: 0,0:02:32.72,0:02:35.80,Default,,0,0,0,,tapi menolak sambil menahan diri\Nitu membuatmu kesatria kelas dua.
Dialogue: 0,0:02:36.13,0:02:37.51,Default,,0,0,0,,Ke-Kelas dua?
Dialogue: 0,0:02:37.71,0:02:39.47,Default,,0,0,0,,Kalau mau jadi kesatria kelas satu,
Dialogue: 0,0:02:39.47,0:02:41.68,Default,,0,0,0,,jangan anggap menerima\Nbantuan itu memalukan,
Dialogue: 0,0:02:41.68,0:02:43.64,Default,,0,0,0,,tapi kau kembalikan itu berlipat kali.
Dialogue: 0,0:02:45.50,0:02:48.77,Default,,0,0,0,,Bertindaklah seperti itu jika ingin\Njadi kesatria yang layak bagiku.
Dialogue: 0,0:02:49.77,0:02:50.90,Default,,0,0,0,,Saya mengerti.
Dialogue: 0,0:02:54.53,0:02:56.24,Default,,0,0,0,,Hebatnya.
Dialogue: 0,0:02:56.24,0:02:57.80,Default,,0,0,0,,Hanya dengan sepatah kata,
Dialogue: 0,0:02:58.40,0:03:00.87,Default,,0,0,0,,kau menumbuhkan tunas yang menarik.
Dialogue: 0,0:03:01.33,0:03:02.91,Default,,0,0,0,,Luar biasa, kan?
Dialogue: 0,0:03:06.34,0:03:08.58,Default,,0,0,0,,Oleh karena itu, aku...
Dialogue: 0,0:03:12.15,0:03:15.34,Default,,0,0,0,,ingin menjodohkannya\Ndengan cucu Pamanda.
Dialogue: 0,0:03:30.61,0:03:33.82,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:03:33.86,0:03:35.69,tanda,,0,0,0,,{\an8}BEREINKARNASI MENJADI BANGSAWAN
Dialogue: 0,0:03:34.86,0:03:38.03,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:03:35.74,0:03:38.53,tanda,,0,0,0,,{\an8}~DENGAN KEKUATAN TIADA TANDING\NSEJAK TERLAHIR~
Dialogue: 0,0:03:41.99,0:03:43.95,Default,,0,0,0,,{\i1}Orang-orang adalah harta\NTeman pun adanya{\i0}
Dialogue: 0,0:03:43.99,0:03:46.00,Default,,0,0,0,,{\i1}Permata bersinar di belakangku\NSetetes air di tengah kekacauan{\i0}
Dialogue: 0,0:03:46.08,0:03:50.67,Default,,0,0,0,,{\i1}Demi kehormatan\NKumelaju ke tingkat baru{\i0}
Dialogue: 0,0:03:50.71,0:03:52.54,Default,,0,0,0,,{\an3\i1}Dengan imaji dan naluri\NKuterkam batas level itu{\i0}
Dialogue: 0,0:03:52.54,0:03:54.51,Default,,0,0,0,,{\an3\i1}Semua di depan mataku kan tunduk{\i0}
Dialogue: 0,0:03:54.51,0:03:56.88,Default,,0,0,0,,{\i1}Nilai dari namaku bagi rakyat tak bersalah\NAdalah tolok ukur yang tak tergoyahkan{\i0}
Dialogue: 0,0:03:57.01,0:03:58.97,Default,,0,0,0,,{\i1}Itulah sumber kebenaran\NYang kehormatan pun pontang-panting{\i0}
Dialogue: 0,0:03:58.97,0:04:00.93,Default,,0,0,0,,{\i1}Lalui kemelut{\i0}
Dialogue: 0,0:04:01.18,0:04:03.93,Default,,0,0,0,,{\i1}Kuakan tegakkan keadilan{\i0}
Dialogue: 0,0:04:04.10,0:04:07.27,Default,,0,0,0,,{\i1}Di tengah ketakutan merajalela{\i0}
Dialogue: 0,0:04:07.35,0:04:11.06,Default,,0,0,0,,{\i1}Bebaskan tiap insan dari rasa takut{\i0}
Dialogue: 0,0:04:11.69,0:04:15.23,Default,,0,0,0,,{\i1}Kuakan selamatkan dunia{\i0}
Dialogue: 0,0:04:15.94,0:04:20.74,Default,,0,0,0,,{\an3\i1}Menelusuri memori\NGunakan apa yang kupunya{\i0}
Dialogue: 0,0:04:20.74,0:04:22.78,Default,,0,0,0,,{\i1}Membangun tempat untuk semua{\i0}
Dialogue: 0,0:04:22.87,0:04:24.66,Default,,0,0,0,,{\i1}Kutakkan gagal{\i0}
Dialogue: 0,0:04:24.74,0:04:28.21,Default,,0,0,0,,{\i1}Masa depan sulit 'tuk ditebak{\i0}
Dialogue: 0,0:04:28.83,0:04:32.46,Default,,0,0,0,,{\i1}Kulakukan apa yang kubisa{\i0}
Dialogue: 0,0:04:33.17,0:04:38.09,Default,,0,0,0,,{\i1}Jika hanya yakin dan menunggu{\i0}
Dialogue: 0,0:04:38.13,0:04:40.05,Default,,0,0,0,,{\i1}Tiada yang mulai{\i0}
Dialogue: 0,0:04:40.05,0:04:41.72,Default,,0,0,0,,{\i1}Aku kan meraihnya!{\i0}
Dialogue: 0,0:04:41.93,0:04:44.97,Default,,0,0,0,,{\i1}chaos chaos{\i0}
Dialogue: 0,0:04:46.27,0:04:49.52,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:04:52.82,0:04:56.65,Default,,0,0,0,,Ini di luar istana,\Njadi tak perlu terlalu formal.
Dialogue: 0,0:04:56.96,0:04:59.53,Default,,0,0,0,,Pamanda, duduklah di sampingku.
Dialogue: 0,0:04:59.53,0:05:00.32,Default,,0,0,0,,Siap.
Dialogue: 0,0:05:09.81,0:05:11.17,Default,,0,0,0,,{\i1}Saatnya panggil Leviathan.{\i0}
Dialogue: 0,0:05:11.97,0:05:13.17,Default,,0,0,0,,{\i1}Sedikit intimidasi.{\i0}
Dialogue: 0,0:05:13.29,0:05:15.97,Default,,0,0,0,,{\i1}Paling bagus cukup menanamkan\Nrasa gentar dan hormat.{\i0}
Dialogue: 0,0:05:16.47,0:05:18.96,Default,,0,0,0,,{\i1}Sip, aku tak merasakan niat jahat.{\i0}
Dialogue: 0,0:05:19.55,0:05:20.76,Default,,0,0,0,,Berlebihan.
Dialogue: 0,0:05:21.79,0:05:25.51,Default,,0,0,0,,Bisa setenang itu di usia belia\Nsangatlah mengejutkan.
Dialogue: 0,0:05:26.30,0:05:28.89,Default,,0,0,0,,Bukankah kau yang terbaik\Ndi antara para Pangeran?
Dialogue: 0,0:05:29.26,0:05:31.89,Default,,0,0,0,,Makanya aku menganugerahkan gelar "Arif".
Dialogue: 0,0:05:32.21,0:05:35.40,Default,,0,0,0,,Sama pantasnya dengan\Ngelar "Guntur" milikmu, kan?
Dialogue: 0,0:05:37.19,0:05:40.61,Default,,0,0,0,,Tapi sebentar lagi aku akan\Nmenjadi kakek-kakek petir biasa.
Dialogue: 0,0:05:40.77,0:05:42.78,Default,,0,0,0,,Kearifan Noah baru akan dimulai.
Dialogue: 0,0:05:43.25,0:05:47.58,Default,,0,0,0,,Karena dia akan menjalani\Npertempuran pertama seorang diri.
Dialogue: 0,0:05:49.69,0:05:51.04,Default,,0,0,0,,Sendirian?
Dialogue: 0,0:05:51.67,0:05:54.42,Default,,0,0,0,,Normalnya Pangeran\Nakan dikawal ketat, kan?
Dialogue: 0,0:05:54.75,0:05:57.04,Default,,0,0,0,,Tapi kalau itu beliau,\Nsaya bisa memahaminya.
Dialogue: 0,0:05:57.27,0:05:59.51,Default,,0,0,0,,{\i1}Perhatian rakyat tertuju padaku.{\i0}
Dialogue: 0,0:06:00.29,0:06:02.67,Default,,0,0,0,,{\i1}Melindungi Yang Mulia\Njadi lebih mudah.{\i0}
Dialogue: 0,0:06:03.38,0:06:04.84,Default,,0,0,0,,{\i1}Tidak, jangan-jangan...{\i0}
Dialogue: 0,0:06:07.63,0:06:08.60,Default,,0,0,0,,{\i1}Sudah kuduga.{\i0}
Dialogue: 0,0:06:08.81,0:06:10.35,Default,,0,0,0,,{\i1}Aku akan menerima kebaikannya.{\i0}
Dialogue: 0,0:06:10.58,0:06:12.81,Default,,0,0,0,,Inilah sisi hebatnya Noah.
Dialogue: 0,0:06:13.28,0:06:13.85,Default,,0,0,0,,Hah?
Dialogue: 0,0:06:14.38,0:06:17.86,Default,,0,0,0,,Aku sengaja berkata hal itu\Nsupaya tercipta situasi
Dialogue: 0,0:06:17.86,0:06:19.73,Default,,0,0,0,,yang membuatku lebih mudah dilindungi.
Dialogue: 0,0:06:19.95,0:06:22.57,Default,,0,0,0,,Noah pun langsung paham,\Ndan melakukan perannya.
Dialogue: 0,0:06:23.43,0:06:25.49,Default,,0,0,0,,Wah, seperti yang diharapkan.
Dialogue: 0,0:06:25.78,0:06:27.83,Default,,0,0,0,,Aku saja tak menyadarinya.
Dialogue: 0,0:06:28.29,0:06:31.87,Default,,0,0,0,,Pamanda memang pemberani,\Ntapi kurang peka.
Dialogue: 0,0:06:32.37,0:06:36.08,Default,,0,0,0,,Makanya kau sering\Nribut dengan istrimu.
Dialogue: 0,0:06:37.67,0:06:39.04,Default,,0,0,0,,Astaga!
Dialogue: 0,0:06:39.37,0:06:43.13,Default,,0,0,0,,Aku semakin lega menyerahkan\Ncucuku padanya.
Dialogue: 0,0:06:47.86,0:06:51.14,Default,,0,0,0,,Nah, Pamanda.\NAku ingin bicara.
Dialogue: 0,0:07:02.65,0:07:04.90,Default,,0,0,0,,Jadi, apa yang ingin dibicarakan?
Dialogue: 0,0:07:06.10,0:07:07.32,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:07:09.63,0:07:10.66,Default,,0,0,0,,{\i1}Lutiya.{\i0}
Dialogue: 0,0:07:23.66,0:07:25.97,Default,,0,0,0,,Aku berniat mencopot Putra Mahkota.
Dialogue: 0,0:07:26.86,0:07:31.13,tanda,,0,0,0,,{\an2}EPISODE 11\NPENCOPOTAN HAK WARIS
Dialogue: 0,0:07:38.77,0:07:40.98,Default,,0,0,0,,Aku kira situasinya akan membaik.
Dialogue: 0,0:07:41.46,0:07:44.90,Default,,0,0,0,,Tapi aku terpaksa memutuskan\Nbahwa dia tak layak jadi penerusku.
Dialogue: 0,0:07:45.45,0:07:46.47,Default,,0,0,0,,Apa sebabnya?
Dialogue: 0,0:07:46.75,0:07:48.41,Default,,0,0,0,,Karena kasus Gilbert.
Dialogue: 0,0:07:49.69,0:07:50.66,Default,,0,0,0,,Begitukah?
Dialogue: 0,0:07:51.70,0:07:54.91,Default,,0,0,0,,{\i1}Saat itu, aku berusaha agar\NKaisar tak membunuh anaknya sendiri.{\i0}
Dialogue: 0,0:07:55.00,0:07:59.17,Default,,0,0,0,,{\i1}Jadi kuusahakan agar Gilbert\Ndijatuhi hukuman penjara seumur hidup.{\i0}
Dialogue: 0,0:08:00.75,0:08:02.17,Default,,0,0,0,,{\i1}Namun, Sang Putra Mahkota...{\i0}
Dialogue: 0,0:08:03.67,0:08:06.01,Default,,0,0,0,,Melakukan itu memang tidak salah.
Dialogue: 0,0:08:06.48,0:08:09.93,Default,,0,0,0,,Tapi seharusnya\Nada metode yang lebih baik.
Dialogue: 0,0:08:10.22,0:08:12.26,Default,,0,0,0,,Aku juga sempat terkejut.
Dialogue: 0,0:08:12.94,0:08:17.10,Default,,0,0,0,,Kalau dia jadi Kaisar,\Npembersihan politik pasti terjadi.
Dialogue: 0,0:08:17.39,0:08:18.06,Default,,0,0,0,,Ya.
Dialogue: 0,0:08:18.59,0:08:22.44,Default,,0,0,0,,Terutama, Henry, Oscar, dan Noah,\Npasti akan disingkirkan duluan.
Dialogue: 0,0:08:23.01,0:08:25.57,Default,,0,0,0,,Pria yang picik dan kejam seperti itu...
Dialogue: 0,0:08:26.05,0:08:29.53,Default,,0,0,0,,Aku tak bisa memercayakan\Ntakhta penerusku padanya.
Dialogue: 0,0:08:30.07,0:08:32.03,Default,,0,0,0,,Aku paham, tapi bagaimana selanjutnya?
Dialogue: 0,0:08:32.26,0:08:34.66,Default,,0,0,0,,Siapa yang akan menjadi\NPutra Mahkota berikutnya?
Dialogue: 0,0:08:35.14,0:08:36.20,Default,,0,0,0,,Belum kuputuskan.
Dialogue: 0,0:08:36.86,0:08:38.21,Default,,0,0,0,,Jangan begitu.
Dialogue: 0,0:08:38.40,0:08:39.87,Default,,0,0,0,,Kau sudah tua.
Dialogue: 0,0:08:40.48,0:08:43.38,Default,,0,0,0,,Kalau kau telanjur tutup usia\Nsebelum menentukan penerus,
Dialogue: 0,0:08:43.75,0:08:45.50,Default,,0,0,0,,negeri ini akan tercerai-berai.
Dialogue: 0,0:08:48.96,0:08:51.68,Default,,0,0,0,,{\i1}Alasan Yang Mulia memilih\Nberdiskusi dengan Indra{\i0}
Dialogue: 0,0:08:51.68,0:08:54.56,Default,,0,0,0,,{\i1}pasti karena Indra berani\Nberkata secara terus terang.{\i0}
Dialogue: 0,0:08:55.93,0:08:58.06,Default,,0,0,0,,Bukan berarti aku belum menentukan.
Dialogue: 0,0:08:58.71,0:09:02.56,Default,,0,0,0,,Tapi mengumumkannya saat ini\Njustru akan menambah masalah.
Dialogue: 0,0:09:03.12,0:09:06.40,Default,,0,0,0,,Tapi, itu lebih baik dibanding\Nmengosongkan posisi Putra Mahkota.
Dialogue: 0,0:09:06.59,0:09:07.73,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:09:08.75,0:09:10.40,Default,,0,0,0,,Mohon maaf. Izinkan saya menyela.
Dialogue: 0,0:09:10.80,0:09:11.45,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:09:12.01,0:09:16.58,Default,,0,0,0,,Bagaimana kalau kita sampaikan\Nbahwa Yang Mulia sudah menulis wasiat?
Dialogue: 0,0:09:18.64,0:09:21.46,Default,,0,0,0,,Lalu nama penerusnya tertulis di sana.
Dialogue: 0,0:09:22.09,0:09:23.17,Default,,0,0,0,,Tidak bisa.
Dialogue: 0,0:09:23.54,0:09:27.05,Default,,0,0,0,,Begitu Kaisar wafat,\Napa pun bisa dipalsukan.
Dialogue: 0,0:09:27.29,0:09:27.92,Default,,0,0,0,,Benar.
Dialogue: 0,0:09:28.38,0:09:32.34,Default,,0,0,0,,Maka, wasiat itu harus disembunyikan\Ndalam tubuh Yang Mulia.
Dialogue: 0,0:09:33.98,0:09:37.22,Default,,0,0,0,,Sederhananya, seperti tulisan\Nyang diukir pada gigi palsu
Dialogue: 0,0:09:38.06,0:09:39.88,Default,,0,0,0,,atau menggunakan semacam sihir.
Dialogue: 0,0:09:40.54,0:09:41.56,Default,,0,0,0,,Rupanya begitu.
Dialogue: 0,0:09:41.64,0:09:45.86,Default,,0,0,0,,Kalau Kaisar selalu membawanya,\Nmaka tak perlu takut itu akan ditukar.
Dialogue: 0,0:09:46.03,0:09:48.07,Default,,0,0,0,,Wah, kau hebat, Noah.
Dialogue: 0,0:09:48.15,0:09:49.69,Default,,0,0,0,,Itu ide bagus!
Dialogue: 0,0:09:57.50,0:09:58.95,Default,,0,0,0,,Kau juga keluar.
Dialogue: 0,0:09:59.98,0:10:01.54,Default,,0,0,0,,Jangan biarkan siapa pun masuk.
Dialogue: 0,0:10:01.84,0:10:02.62,Default,,0,0,0,,Sesuai titah.
Dialogue: 0,0:10:03.03,0:10:04.17,Default,,0,0,0,,Bagaimana dengannya?
Dialogue: 0,0:10:04.59,0:10:05.63,Default,,0,0,0,,Jangan khawatir.
Dialogue: 0,0:10:06.27,0:10:09.30,Default,,0,0,0,,Ia adalah perantara yang digunakan\Ndalam hal seperti ini.
Dialogue: 0,0:10:09.77,0:10:13.59,Default,,0,0,0,,Dia tunarungu, tunawicara,\Nserta tunaaksara.
Dialogue: 0,0:10:15.18,0:10:16.01,Default,,0,0,0,,Oh.
Dialogue: 0,0:10:16.47,0:10:18.14,Default,,0,0,0,,Kalau begitu, saya izin pamit.
Dialogue: 0,0:10:23.37,0:10:24.90,Default,,0,0,0,,Nah, Noah.
Dialogue: 0,0:10:25.12,0:10:26.90,Default,,0,0,0,,Kau mengusulkan ide bagus.
Dialogue: 0,0:10:27.27,0:10:28.48,Default,,0,0,0,,Aku akan melakukannya.
Dialogue: 0,0:10:28.75,0:10:29.23,Default,,0,0,0,,Ya!
Dialogue: 0,0:10:29.61,0:10:31.03,Default,,0,0,0,,Lalu satu hal lagi.
Dialogue: 0,0:10:31.21,0:10:34.28,Default,,0,0,0,,Kendali seluruh pasukan\Nharus dikembalikan pada Yang Mulia.
Dialogue: 0,0:10:34.79,0:10:37.48,Default,,0,0,0,,Seperti jabatan Menteri Pertahanan\Nmilik Kanda Henry
Dialogue: 0,0:10:37.48,0:10:39.74,Default,,0,0,0,,atau jabatan\NPanglima Angkatan Pertama milikku.
Dialogue: 0,0:10:40.01,0:10:40.66,Default,,0,0,0,,Ya.
Dialogue: 0,0:10:41.09,0:10:42.08,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:10:42.08,0:10:45.62,Default,,0,0,0,,Kalau orang yang tidak terima dengan\Nwasiat masih mengendalikan pasukan,
Dialogue: 0,0:10:45.81,0:10:49.09,Default,,0,0,0,,mungkin saja dia akan menyingkirkan\Ncalon lain untuk merebut takhta.
Dialogue: 0,0:10:49.41,0:10:50.84,Default,,0,0,0,,Itu memang logis,
Dialogue: 0,0:10:51.87,0:10:55.34,Default,,0,0,0,,tapi kau tetap menyarankan hal itu\Nmeski posisimu harus dikorbankan.
Dialogue: 0,0:10:55.81,0:10:57.22,Default,,0,0,0,,Kau hebat, Nak.
Dialogue: 0,0:10:57.43,0:10:59.60,Default,,0,0,0,,Pantas untuk dipinang cucumu, kan?
Dialogue: 0,0:11:00.13,0:11:00.89,Default,,0,0,0,,Benar.
Dialogue: 0,0:11:05.87,0:11:09.27,Default,,0,0,0,,{\i1}Titah kaisar yang memuji jasaku,\Nsekaligus mencopot jabatanku.{\i0}
Dialogue: 0,0:11:14.74,0:11:16.86,Default,,0,0,0,,{\i1}Yang satunya untuk Kanda Henry, ya.{\i0}
Dialogue: 0,0:11:22.89,0:11:24.91,Default,,0,0,0,,{\i1}Titah yang sederhana.{\i0}
Dialogue: 0,0:11:25.59,0:11:29.88,Default,,0,0,0,,{\i1}Berarti dia hanya dididik untuk\Nmenjalankan titah yang sudah pasti.{\i0}
Dialogue: 0,0:11:30.69,0:11:33.92,Default,,0,0,0,,Lalu, bagaimana dengan\Npencopotan Putra Mahkota?
Dialogue: 0,0:11:38.85,0:11:41.47,Default,,0,0,0,,Dari sudut pandang saya\Nsebagai Menteri Hukum,
Dialogue: 0,0:11:41.64,0:11:43.31,Default,,0,0,0,,penerapannya bisa beragam.
Dialogue: 0,0:11:45.26,0:11:50.36,Default,,0,0,0,,Siapa pun yang akan ditunjuk maupun\Ndicopot, sepenuhnya adalah hak Yang Mulia.
Dialogue: 0,0:11:50.73,0:11:53.40,Default,,0,0,0,,Tidak ada yang berhak\Nmenentang keputusan itu.
Dialogue: 0,0:11:53.97,0:11:55.07,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:11:55.55,0:11:57.32,Default,,0,0,0,,Namun, tidak seperti Gilbert,
Dialogue: 0,0:11:57.50,0:12:01.70,Default,,0,0,0,,Kanda Albert tak melakukan\Nkejahatan spesifik.
Dialogue: 0,0:12:02.16,0:12:04.89,Default,,0,0,0,,Maka, setelah mencopotnya,\Nsebaiknya Yang Mulia
Dialogue: 0,0:12:04.89,0:12:06.46,Default,,0,0,0,,pertahankan gelar pangerannya.
Dialogue: 0,0:12:06.79,0:12:08.92,Default,,0,0,0,,Lantas, bagaimana kalau begini?
Dialogue: 0,0:12:09.13,0:12:12.38,Default,,0,0,0,,Albert tak punya niat berkhianat\Npadaku atau negeri ini,
Dialogue: 0,0:12:12.38,0:12:14.76,Default,,0,0,0,,tapi masih kurang layak\Nuntuk mengurus kekaisaran.
Dialogue: 0,0:12:14.89,0:12:18.30,Default,,0,0,0,,Maka, posisi Putra Mahkotanya dicopot,\Ndan dikembalikan menjadi Pangeran.
Dialogue: 0,0:12:18.82,0:12:20.26,Default,,0,0,0,,Saya rasa itu masuk akal.
Dialogue: 0,0:12:20.67,0:12:21.51,Default,,0,0,0,,Ya.
Dialogue: 0,0:12:21.62,0:12:23.26,Default,,0,0,0,,Lalu, Kaisar.
Dialogue: 0,0:12:23.50,0:12:26.22,Default,,0,0,0,,Apa Albert masih berpeluang\Njadi penerus lagi?
Dialogue: 0,0:12:26.60,0:12:27.31,Default,,0,0,0,,Tidak.
Dialogue: 0,0:12:30.97,0:12:31.90,Default,,0,0,0,,{\i1}Albert.{\i0}
Dialogue: 0,0:12:32.23,0:12:34.19,Default,,0,0,0,,{\i1}Rupanya dia benar-benar disingkirkan.{\i0}
Dialogue: 0,0:12:34.62,0:12:37.57,Default,,0,0,0,,Kalau begitu, kau harus\Nmemperjelas itu padanya.
Dialogue: 0,0:12:37.81,0:12:38.57,Default,,0,0,0,,Hm...
Dialogue: 0,0:12:39.10,0:12:41.11,Default,,0,0,0,,Bagaimana dengan menganugerahkan gelar?
Dialogue: 0,0:12:41.60,0:12:45.99,Default,,0,0,0,,Misalnya, Pangeran Pamungkas,\Nyang bermakna semua berakhir di situ.
Dialogue: 0,0:12:46.25,0:12:47.04,Default,,0,0,0,,Wah.
Dialogue: 0,0:12:47.65,0:12:49.50,Default,,0,0,0,,Ya, itu ide bagus.
Dialogue: 0,0:12:49.91,0:12:52.25,Default,,0,0,0,,Noah, terima kasih telah menyarankan.
Dialogue: 0,0:12:55.99,0:12:58.26,Default,,0,0,0,,Hm, ini tidak bagus.
Dialogue: 0,0:12:58.54,0:13:00.01,Default,,0,0,0,,Apa ini?
Dialogue: 0,0:13:00.26,0:13:02.05,Default,,0,0,0,,Banyak sekali salah tulisnya.
Dialogue: 0,0:13:02.51,0:13:05.31,Default,,0,0,0,,Kalimatnya pun bertele-tele\Ndan sulit dimengerti.
Dialogue: 0,0:13:05.31,0:13:06.26,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:13:06.89,0:13:09.56,Default,,0,0,0,,Aku merampas hak waris putraku sendiri.
Dialogue: 0,0:13:09.86,0:13:12.81,Default,,0,0,0,,Meski bukan merampas nyawanya,
Dialogue: 0,0:13:12.90,0:13:14.15,Default,,0,0,0,,rasanya tetap sakit.
Dialogue: 0,0:13:16.93,0:13:18.28,Default,,0,0,0,,Rupanya begitu.
Dialogue: 0,0:13:18.69,0:13:22.28,Default,,0,0,0,,Teruslah menulis ulang\Nsampai keraguanmu hilang.
Dialogue: 0,0:13:22.86,0:13:25.78,Default,,0,0,0,,Yang Mulia, izinkan saya\Nmenyampaikan sesuatu.
Dialogue: 0,0:13:26.25,0:13:30.50,Default,,0,0,0,,Bukankah lebih baik isi pesan itu\Ndibiarkan apa adanya saja?
Dialogue: 0,0:13:31.31,0:13:33.67,Default,,0,0,0,,Titah kekaisaran resmi\Nakan tercatat di arsip.
Dialogue: 0,0:13:33.97,0:13:37.84,Default,,0,0,0,,Perasaan Yang Mulia juga akan\Ntersimpan dan tersampaikan pada Kanda.
Dialogue: 0,0:13:38.93,0:13:40.60,Default,,0,0,0,,Mungkin saja Kanda dapat terima
Dialogue: 0,0:13:40.67,0:13:44.30,Default,,0,0,0,,dan terus mengabdi pada\Nkekaisaran sebagai Pangeran...
Dialogue: 0,0:13:45.10,0:13:46.97,Default,,0,0,0,,Andai saja kau terlahir lebih awal...
Dialogue: 0,0:13:51.35,0:13:52.33,Default,,0,0,0,,Akan kulakukan.
Dialogue: 0,0:13:52.82,0:13:54.56,Default,,0,0,0,,Terima kasih sudah menyampaikan.
Dialogue: 0,0:13:55.18,0:13:56.52,Default,,0,0,0,,Saya merasa sangat terhormat.
Dialogue: 0,0:14:12.87,0:14:13.33,Default,,0,0,0,,Tunggu!
Dialogue: 0,0:14:14.16,0:14:15.54,Default,,0,0,0,,Ada apa, Nak?
Dialogue: 0,0:14:15.83,0:14:19.09,Default,,0,0,0,,Perantara ini bereaksi\Nsetelah melihat titahnya.
Dialogue: 0,0:14:19.21,0:14:19.96,Default,,0,0,0,,Apa?
Dialogue: 0,0:14:20.37,0:14:21.76,Default,,0,0,0,,Lalu dia kebingungan.
Dialogue: 0,0:14:22.14,0:14:24.05,Default,,0,0,0,,Itu karena dia memahami isinya.
Dialogue: 0,0:14:26.14,0:14:26.93,Default,,0,0,0,,Takkan kubiarkan!
Dialogue: 0,0:14:31.30,0:14:31.98,Default,,0,0,0,,Cruz!
Dialogue: 0,0:14:32.74,0:14:34.23,Default,,0,0,0,,Ada apa gerangan?
Dialogue: 0,0:14:35.44,0:14:38.02,Default,,0,0,0,,Orang itu... bisa membaca!
Dialogue: 0,0:14:41.61,0:14:43.49,Default,,0,0,0,,Ini sepenuhnya kelalaian saya!
Dialogue: 0,0:14:43.61,0:14:45.86,Default,,0,0,0,,Mohon kiranya ampuni saya!
Dialogue: 0,0:14:45.86,0:14:47.70,Default,,0,0,0,,Bagaimana cara mengatasi ini, Noah?
Dialogue: 0,0:14:47.98,0:14:49.49,Default,,0,0,0,,Orang ini harus dihukum mati.
Dialogue: 0,0:14:49.53,0:14:51.49,Default,,0,0,0,,Sebaiknya dieksekusi hari ini juga.
Dialogue: 0,0:14:51.65,0:14:52.58,Default,,0,0,0,,Alasannya?
Dialogue: 0,0:14:53.02,0:14:54.92,Default,,0,0,0,,Dia pura-pura jadi tunaaksara
Dialogue: 0,0:14:54.92,0:14:57.67,Default,,0,0,0,,untuk menjabat posisi inti\Ndalam kekaisaran.
Dialogue: 0,0:14:58.21,0:15:00.96,Default,,0,0,0,,Ini sama saja dengan\Nmenodai istana Yang Mulia.
Dialogue: 0,0:15:01.61,0:15:04.80,Default,,0,0,0,,Bukankah sebaiknya kita keruk\Ninformasi darinya sebelum membunuh?
Dialogue: 0,0:15:05.39,0:15:07.68,Default,,0,0,0,,Kalau tahu dalang di baliknya,
Dialogue: 0,0:15:07.68,0:15:10.01,Default,,0,0,0,,kita bisa menghukum mereka sekaligus.
Dialogue: 0,0:15:10.89,0:15:12.52,Default,,0,0,0,,{\i1}Bagaimana kalau Albert...{\i0}
Dialogue: 0,0:15:13.37,0:15:15.64,Default,,0,0,0,,{\i1}atau salah seorang Pangeran dalangnya?{\i0}
Dialogue: 0,0:15:16.07,0:15:17.48,Default,,0,0,0,,Rupanya begitu.
Dialogue: 0,0:15:17.79,0:15:19.61,Default,,0,0,0,,Ya, mari urungkan.
Dialogue: 0,0:15:19.91,0:15:21.23,Default,,0,0,0,,Ucapanmu sangat benar.
Dialogue: 0,0:15:21.75,0:15:25.86,Default,,0,0,0,,Noah, mulai sekarang, tetaplah\Nmelayaniku sebagai Menteri Hukum.
Dialogue: 0,0:15:26.70,0:15:27.45,Default,,0,0,0,,Sesuai titah.
Dialogue: 0,0:15:27.85,0:15:29.45,Default,,0,0,0,,Lalu bagaimana dengan Cruz?
Dialogue: 0,0:15:30.39,0:15:33.20,Default,,0,0,0,,Kejahatan Cruz hanyalah\Nkelalaian pengawasan.
Dialogue: 0,0:15:34.03,0:15:36.16,Default,,0,0,0,,Pengurangan gaji\Nsetengah tahun sudah cukup.
Dialogue: 0,0:15:36.77,0:15:38.46,Default,,0,0,0,,Jadi begitu, Cruz.
Dialogue: 0,0:15:38.74,0:15:40.42,Default,,0,0,0,,Kuserahkan soal orang itu padamu.
Dialogue: 0,0:15:40.62,0:15:42.17,Default,,0,0,0,,Se-Sesuai titah!
Dialogue: 0,0:15:42.45,0:15:44.55,Default,,0,0,0,,Terima kasih banyak, Yang Mulia!
Dialogue: 0,0:15:53.07,0:15:54.18,Default,,0,0,0,,Apa sudah selesai?
Dialogue: 0,0:15:54.50,0:15:56.52,Default,,0,0,0,,Karena orang itu pejabat istana,
Dialogue: 0,0:15:56.69,0:15:59.81,Default,,0,0,0,,maka saya sendiri yang menanganinya.
Dialogue: 0,0:15:59.92,0:16:00.81,Default,,0,0,0,,Jadi bagaimana?
Dialogue: 0,0:16:01.33,0:16:02.98,Default,,0,0,0,,Tuan Noah memang hebat.
Dialogue: 0,0:16:03.45,0:16:07.40,Default,,0,0,0,,Dia seolah bisa membaca\Nhati orang lain.
Dialogue: 0,0:16:08.05,0:16:09.28,Default,,0,0,0,,Albert.
Dialogue: 0,0:16:10.02,0:16:11.41,Default,,0,0,0,,Bagaimana tentangnya?
Dialogue: 0,0:16:11.74,0:16:14.62,Default,,0,0,0,,Aku... tidak tahu harus apa.
Dialogue: 0,0:16:17.37,0:16:21.13,Default,,0,0,0,,Meski aku tak bisa menyerahkan\Nnegeri ini kepadanya,
Dialogue: 0,0:16:21.13,0:16:23.00,Default,,0,0,0,,dia tetaplah darah dagingku.
Dialogue: 0,0:16:27.28,0:16:30.64,Default,,0,0,0,,Omong-omong, apa kau tahu\Nnama Leviathan?
Dialogue: 0,0:16:30.90,0:16:31.39,Default,,0,0,0,,Ya.
Dialogue: 0,0:16:31.75,0:16:35.67,Default,,0,0,0,,Dia adalah salah satu dari Empat\NSosok Bajik yang membantu kekaisaran
Dialogue: 0,0:16:35.67,0:16:37.02,Default,,0,0,0,,pada Zaman Perak.
Dialogue: 0,0:16:37.44,0:16:42.15,Default,,0,0,0,,Sepertinya si Leviathan itu\Nmembantu Noah.
Dialogue: 0,0:16:42.38,0:16:44.07,Default,,0,0,0,,Itu luar biasa.
Dialogue: 0,0:16:44.18,0:16:48.24,Default,,0,0,0,,Tuan Noah mungkin bisa menciptakan\Nera yang melebihi Zaman Perak.
Dialogue: 0,0:16:48.59,0:16:49.53,Default,,0,0,0,,Hm.
Dialogue: 0,0:16:49.74,0:16:51.78,Default,,0,0,0,,Peluangnya memang ada.
Dialogue: 0,0:16:52.62,0:16:55.04,Default,,0,0,0,,Kira-kira sejauh apa perkembangannya?
Dialogue: 0,0:16:55.50,0:16:57.70,Default,,0,0,0,,Mari kita perhatikan dengan saksama.
Dialogue: 0,0:17:00.74,0:17:02.04,Default,,0,0,0,,Saya izin pamit.
Dialogue: 0,0:17:09.02,0:17:10.93,Default,,0,0,0,,Permisi, Pangeran.
Dialogue: 0,0:17:11.57,0:17:13.64,Default,,0,0,0,,Kita akan menuju ke mana?
Dialogue: 0,0:17:13.97,0:17:18.48,Default,,0,0,0,,Jarang-jarang kau menyela\Nomonganku seperti itu.
Dialogue: 0,0:17:18.77,0:17:20.73,Default,,0,0,0,,Ma-Maafkan kelancangan saya.
Dialogue: 0,0:17:20.99,0:17:22.98,Default,,0,0,0,,Karena Pangeran tampak\Nbanyak pikiran.
Dialogue: 0,0:17:23.33,0:17:25.94,Default,,0,0,0,,Ya, pengamatanmu benar.
Dialogue: 0,0:17:26.25,0:17:27.03,Default,,0,0,0,,Kalau begitu...
Dialogue: 0,0:17:28.12,0:17:28.99,Default,,0,0,0,,Jangan tegang.
Dialogue: 0,0:17:29.40,0:17:32.99,Default,,0,0,0,,Kita memang menuju tempat yang sulit,\Ntapi tidak mengancam nyawa.
Dialogue: 0,0:17:33.36,0:17:34.37,Default,,0,0,0,,Apa maksudnya?
Dialogue: 0,0:17:34.61,0:17:37.62,Default,,0,0,0,,Kita menuju mansion Kandaku\Nselaku Putra Mahkota.
Dialogue: 0,0:17:56.15,0:17:59.85,Default,,0,0,0,,{\i1}Di langit biru nan cerah{\i0}
Dialogue: 0,0:18:00.06,0:18:03.48,Default,,0,0,0,,{\i1}Burung putih beterbangan{\i0}
Dialogue: 0,0:18:03.81,0:18:07.57,Default,,0,0,0,,{\i1}Mengabari kota ini...{\i0}
Dialogue: 0,0:18:07.59,0:18:09.61,Default,,0,0,0,,Tamu yang jarang terlihat.
Dialogue: 0,0:18:10.09,0:18:13.74,Default,,0,0,0,,Tak kusangka Menteri Hukum\Nyang sedang naik daun akan mengunjungiku.
Dialogue: 0,0:18:14.61,0:18:17.30,Default,,0,0,0,,Saya ingin mendengar\Ndari Yang Mulia Putra Mahkota.
Dialogue: 0,0:18:17.41,0:18:19.74,Default,,0,0,0,,Mohon maaf atas\Nkunjungan mendadak saya.
Dialogue: 0,0:18:20.04,0:18:22.08,Default,,0,0,0,,Kau kaku sekali.
Dialogue: 0,0:18:22.49,0:18:25.67,Default,,0,0,0,,Mungkin itulah sebabnya\Nkau jadi Menteri Hukum.
Dialogue: 0,0:18:25.79,0:18:27.21,Default,,0,0,0,,Yang jelas, santai saja.
Dialogue: 0,0:18:27.49,0:18:29.59,Default,,0,0,0,,Mari mengobrol selayaknya saudara.
Dialogue: 0,0:18:30.00,0:18:31.46,Default,,0,0,0,,Terima kasih banyak.
Dialogue: 0,0:18:32.43,0:18:34.13,Default,,0,0,0,,Tunggulah di luar mansion.
Dialogue: 0,0:18:34.43,0:18:35.14,Default,,0,0,0,,Sesuai titah.
Dialogue: 0,0:18:35.91,0:18:39.97,Default,,0,0,0,,{\i1}Menyuruh pengawal menunggu di luar\Nadalah bukti aku percaya Putra Mahkota.{\i0}
Dialogue: 0,0:18:40.97,0:18:42.89,Default,,0,0,0,,{\i1}Shirley yang sekarang\Npasti paham itu.{\i0}
Dialogue: 0,0:18:43.39,0:18:45.60,Default,,0,0,0,,Mau di ruang tamu atau taman?
Dialogue: 0,0:18:46.10,0:18:49.98,Default,,0,0,0,,Saya dengar taman Kanda\Nmerupakan karya Maestro Trant.
Dialogue: 0,0:18:50.45,0:18:52.74,Default,,0,0,0,,Saya ingin sesekali mengunjunginya.
Dialogue: 0,0:18:52.89,0:18:55.86,Default,,0,0,0,,Oh iya, aku memang belum\Npernah memperlihatkannya.
Dialogue: 0,0:18:56.15,0:18:57.91,Default,,0,0,0,,Baiklah, ikut aku.
Dialogue: 0,0:18:59.51,0:19:00.91,Default,,0,0,0,,Luar biasa, ya.
Dialogue: 0,0:19:01.45,0:19:02.50,Default,,0,0,0,,Kau bisa memahaminya?
Dialogue: 0,0:19:03.17,0:19:03.83,Default,,0,0,0,,Ya.
Dialogue: 0,0:19:04.08,0:19:06.00,Default,,0,0,0,,Misalnya, pasangan pohon itu.
Dialogue: 0,0:19:06.25,0:19:08.46,Default,,0,0,0,,Saya belum pernah melihat\Nyang seindah itu.
Dialogue: 0,0:19:08.68,0:19:10.59,Default,,0,0,0,,Matamu memang jeli.
Dialogue: 0,0:19:10.77,0:19:13.67,Default,,0,0,0,,Itu barang persembahan\Ndari abdi yang kuminta pergi.
Dialogue: 0,0:19:13.84,0:19:15.68,Default,,0,0,0,,Kabarnya bernilai 50.000 riin.
Dialogue: 0,0:19:15.85,0:19:17.76,Default,,0,0,0,,Itu harga yang sepadan.
Dialogue: 0,0:19:18.12,0:19:20.81,Default,,0,0,0,,Nanti akan kuminta\Nitu diantarkan ke mansionmu.
Dialogue: 0,0:19:20.95,0:19:21.41,Default,,0,0,0,,Eh?
Dialogue: 0,0:19:22.37,0:19:24.48,Default,,0,0,0,,Kau memahami nilainya\Ndalam sekali lihat.
Dialogue: 0,0:19:24.52,0:19:27.98,Default,,0,0,0,,Pohon itu juga akan senang\Njika dimiliki pria yang memujinya.
Dialogue: 0,0:19:28.32,0:19:30.57,Default,,0,0,0,,Saya akan menerima\Ndengan senang hati.
Dialogue: 0,0:19:31.03,0:19:34.40,Default,,0,0,0,,Ini kedua kalinya aku\Nmemberikan sesuatu padamu, ya.
Dialogue: 0,0:19:34.83,0:19:38.16,Default,,0,0,0,,Sepertinya kau sudah\Nmenguasai pedang iblis itu.
Dialogue: 0,0:19:38.64,0:19:41.03,Default,,0,0,0,,Padahal dulu aku hanya bercanda.
Dialogue: 0,0:19:41.31,0:19:43.04,Default,,0,0,0,,Berkat itu, aku jadi belajar sesuatu.
Dialogue: 0,0:19:43.20,0:19:47.58,Default,,0,0,0,,Kekuatan dahsyat sepatutnya\Nberada di tangan yang layak.
Dialogue: 0,0:19:53.51,0:19:55.92,Default,,0,0,0,,Musim panas tahun ini kian dekat, ya.
Dialogue: 0,0:19:56.40,0:19:57.80,Default,,0,0,0,,Hm? Ya.
Dialogue: 0,0:19:58.24,0:20:00.22,Default,,0,0,0,,Saya baru saja mendengarnya.
Dialogue: 0,0:20:00.76,0:20:03.68,Default,,0,0,0,,Kabarnya Yang Mulia akan\Nmenuju utara untuk beristirahat.
Dialogue: 0,0:20:03.97,0:20:05.52,Default,,0,0,0,,Yang beda dibanding tahun lalu,
Dialogue: 0,0:20:06.36,0:20:08.69,Default,,0,0,0,,yakni Kanda harus\Nmenemani beliau tahun ini.
Dialogue: 0,0:20:10.35,0:20:11.33,Default,,0,0,0,,{\i1}Beberapa tahun ini,{\i0}
Dialogue: 0,0:20:11.61,0:20:13.69,Default,,0,0,0,,{\i1}saat Yang Mulia meninggalkan ibu kota,{\i0}
Dialogue: 0,0:20:13.94,0:20:17.24,Default,,0,0,0,,{\i1}beliau memercayakan kekosongan\Nkekuasaan pada Putra Mahkota.{\i0}
Dialogue: 0,0:20:18.92,0:20:22.49,Default,,0,0,0,,{\i1}Maka, sedikit demi sedikit urusan\Nistana diserahkan pada Putra Mahkota.{\i0}
Dialogue: 0,0:20:22.62,0:20:25.66,Default,,0,0,0,,{\i1}Ibarat latihan sebelum menjadi Kaisar.{\i0}
Dialogue: 0,0:20:26.43,0:20:28.58,Default,,0,0,0,,{\i1}Namun kalau hal itu tidak diadakan...{\i0}
Dialogue: 0,0:20:28.96,0:20:29.92,Default,,0,0,0,,Kau...
Dialogue: 0,0:20:30.93,0:20:32.54,Default,,0,0,0,,sudah tahu sejauh mana?
Dialogue: 0,0:20:33.21,0:20:35.88,Default,,0,0,0,,Yang Mulia menyampaikannya\Nsecara tersirat.
Dialogue: 0,0:20:36.32,0:20:39.43,Default,,0,0,0,,Pada musim panas ini,\NYang Mulia ingin mengajarkan
Dialogue: 0,0:20:39.43,0:20:41.89,Default,,0,0,0,,hakikat pemerintahan pada Kanda\Ndengan saksama.
Dialogue: 0,0:20:42.33,0:20:43.10,Default,,0,0,0,,Apa?
Dialogue: 0,0:20:43.89,0:20:46.18,Default,,0,0,0,,Beliaulah kaisar bijak yang langka ada.
Dialogue: 0,0:20:46.93,0:20:49.64,Default,,0,0,0,,Pasti beliau sudah\Nmenciptakan berbagai metode
Dialogue: 0,0:20:49.64,0:20:51.85,Default,,0,0,0,,yang tak terbayangkan oleh kita.
Dialogue: 0,0:20:52.68,0:20:55.90,Default,,0,0,0,,Mungkin sudah saatnya beliau\Nmewariskan hal itu pada Kanda.
Dialogue: 0,0:20:57.23,0:21:00.24,Default,,0,0,0,,{\i1}Memang benar Yang Mulia\Ningin mengajak Albert.{\i0}
Dialogue: 0,0:21:00.55,0:21:04.20,Default,,0,0,0,,{\i1}Namun itu karena beliau cemas\Nkalau Albert tidak berada di dekatnya.{\i0}
Dialogue: 0,0:21:05.88,0:21:08.87,Default,,0,0,0,,{\i1}Meski begitu, mungkin dengan\Nmenghabiskan waktu bersama,{\i0}
Dialogue: 0,0:21:08.87,0:21:12.13,Default,,0,0,0,,{\i1}perasaan Yang Mulia bisa\Ntersampaikan pada Kanda...{\i0}
Dialogue: 0,0:21:13.51,0:21:14.53,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:21:14.77,0:21:16.55,Default,,0,0,0,,Noah, kuucapkan terima kasih padamu.
Dialogue: 0,0:21:31.57,0:21:32.52,Default,,0,0,0,,Pangeran.
Dialogue: 0,0:21:32.52,0:21:33.40,Default,,0,0,0,,Alichey.
Dialogue: 0,0:21:33.99,0:21:36.52,Default,,0,0,0,,Sebentar lagi giliran saya,\Njadi saya ingin menyapa.
Dialogue: 0,0:21:36.61,0:21:37.15,Default,,0,0,0,,Ya.
Dialogue: 0,0:21:39.99,0:21:41.03,Default,,0,0,0,,Ada apa?
Dialogue: 0,0:21:41.47,0:21:44.49,Default,,0,0,0,,Tidak, sesuai saran Pangeran,
Dialogue: 0,0:21:44.70,0:21:46.83,Default,,0,0,0,,saya akan bernyanyi sekuat tenaga.
Dialogue: 0,0:21:47.84,0:21:48.33,Default,,0,0,0,,Ya.
Dialogue: 0,0:21:55.17,0:22:00.80,Default,,0,0,0,,{\i1}Ninabobo ibunda bergema lembut{\i0}
Dialogue: 0,0:22:00.84,0:22:06.43,Default,,0,0,0,,{\i1}Perapian jingga lambaikan bayang{\i0}
Dialogue: 0,0:22:06.80,0:22:11.43,Default,,0,0,0,,{\i1}Pura-pura tidur sambil merangkul erat{\i0}
Dialogue: 0,0:22:11.43,0:22:15.65,Default,,0,0,0,,{\i1}Punggung ayah{\i0}
Dialogue: 0,0:22:15.65,0:22:19.32,Default,,0,0,0,,{\i1}Jadilah kuat{\i0}
Dialogue: 0,0:22:19.32,0:22:24.41,Default,,0,0,0,,{\i1}Demi lindungi kaum yang lemah{\i0}
Dialogue: 0,0:22:24.41,0:22:31.89,Default,,0,0,0,,{\i1}Aku tahu itu\NKarena dialah yang mengajariku{\i0}
Dialogue: 0,0:22:32.08,0:22:35.83,Default,,0,0,0,,{\i1}Air mata nan bersimbah kepedihan{\i0}
Dialogue: 0,0:22:35.83,0:22:39.71,Default,,0,0,0,,{\i1}Kini menjelma arus besar{\i0}
Dialogue: 0,0:22:39.71,0:22:49.22,Default,,0,0,0,,{\an8\i1}Alirkan asa menuju hari esok{\i0}
Dialogue: 0,0:22:44.45,0:22:45.13,Default,,0,0,0,,Masuklah.
Dialogue: 0,0:22:45.67,0:22:46.97,Default,,0,0,0,,Permisi.
Dialogue: 0,0:22:49.64,0:22:51.85,Default,,0,0,0,,{\an8}Mohon maaf mengganggu Tuan\Nmalam-malam.
Dialogue: 0,0:22:52.70,0:22:56.31,Default,,0,0,0,,{\an8}Ada seorang wanita\Nyang ingin menemui Tuan.
Dialogue: 0,0:22:57.51,0:23:00.19,Default,,0,0,0,,{\an8}- Siapa namanya?\N- Namanya Olivia Coile.
Dialogue: 0,0:23:01.12,0:23:02.24,Default,,0,0,0,,{\i1}Aku tak mengenalnya.{\i0}
Dialogue: 0,0:23:02.84,0:23:06.82,Default,,0,0,0,,{\i1}Namun kalau bukan orang penting,\NZoey pasti sudah mengusirnya.{\i0}
Dialogue: 0,0:23:04.07,0:23:08.03,Default,,0,0,0,,{\an8\i1}Baik bintang, manusia,\Njarum, maupun zaman{\i0}
Dialogue: 0,0:23:07.73,0:23:08.66,Default,,0,0,0,,Izinkan dia masuk.
Dialogue: 0,0:23:08.03,0:23:12.37,Default,,0,0,0,,{\an8\i1}Semua terus berputar hingga kelak sirna{\i0}
Dialogue: 0,0:23:10.25,0:23:11.87,Default,,0,0,0,,Namamu Olivia?
Dialogue: 0,0:23:12.75,0:23:20.63,Default,,0,0,0,,{\an9\i1}Tiada satu pun\Nyang bisa kita bawa pergi{\i0}
Dialogue: 0,0:23:13.07,0:23:14.79,Default,,0,0,0,,{\an1}Ada perlu apa larut malam begini?
Dialogue: 0,0:23:15.25,0:23:16.80,Default,,0,0,0,,{\an1}Menyampaikan laporan rahasia.
Dialogue: 0,0:23:17.46,0:23:20.71,Default,,0,0,0,,Albert, Pangeran Kedua\Nsekaligus Putra Mahkota...
Dialogue: 0,0:23:21.34,0:23:24.92,Default,,0,0,0,,{\an9\i1}Bermekar megahlah{\i0}
Dialogue: 0,0:23:22.66,0:23:24.80,Default,,0,0,0,,{\an3}berencana melakukan kudeta...
Dialogue: 0,0:23:24.92,0:23:30.30,Default,,0,0,0,,{\an8\i1}Di masa depan\Nyang dulu kita impikan{\i0}
Dialogue: 0,0:23:30.30,0:23:32.01,Default,,0,0,0,,{\an8\i1}Kini aku berdiri{\i0}
Dialogue: 0,0:23:31.38,0:23:34.06,Default,,0,0,0,,dan memaksa Yang Mulia turun takhta.
Dialogue: 0,0:23:32.01,0:23:38.10,Default,,0,0,0,,{\an8\i1}Inilah kumandang nyanyian berkah{\i0}
