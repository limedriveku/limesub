Dialogue: 0,0:00:17.50,0:00:21.96,tanda,,0,0,0,,{\an6}ALBERT ARARAT\NPUTRA MAHKOTA - PANGERAN KEDUA
Dialogue: 0,0:16:07.24,0:16:08.02,tanda,,0,0,0,,GUNTUR
Dialogue: 0,0:16:23.29,0:16:28.17,tanda,,0,0,0,,{\an2}EPISODE 10\NPANGERAN GUNTUR DAN PANGERAN ARIF
Dialogue: 0,0:17:00.12,0:17:03.00,tanda,,0,0,0,,{\an9}KAISAR\N\NPAMAN\N(PANGERAN GUNTUR)\NINDRA
Dialogue: 0,0:17:03.20,0:17:06.30,tanda,,0,0,0,,{\an9}KAISAR\N\N(BAWAHAN)\NPANGERAN PERTAMA - GILBERT\NADIK - GRIME\NPAMAN (PANGERAN GUNTUR) - INDRA\NPANGERAN KEDUA DAN PUTRA MAHKOTA - ALBERT\NPANGERAN KETIGA - KYLO\NPANGERAN KEEMPAT - HENRY
Dialogue: 0,0:20:27.41,0:20:31.88,tanda,,0,0,0,,TANAH: F+F, CAHAYA: F+C\NKEGELAPAN: F
Dialogue: 0,0:00:05.11,0:00:06.15,Default,,0,0,0,,Kanda...
Dialogue: 0,0:00:06.54,0:00:07.13,Default,,0,0,0,,Tidak.
Dialogue: 0,0:00:07.49,0:00:11.87,Default,,0,0,0,,Dalam penggeledahan kediaman Gilbert,\Nditemukan dokumen berisi rencana
Dialogue: 0,0:00:11.87,0:00:14.91,Default,,0,0,0,,pembunuhan Yang Mulia\Ndari kamar tersembunyi di rubanahnya.
Dialogue: 0,0:00:15.41,0:00:19.54,Default,,0,0,0,,Begitu rupanya.\NMuncul bukti tak terbantahkan.
Dialogue: 0,0:00:19.54,0:00:21.88,Default,,0,0,0,,Dasar binatang\Nyang lebih hina dari anjing.
Dialogue: 0,0:00:22.94,0:00:25.21,Default,,0,0,0,,Lalu, bagaimana hukumannya?
Dialogue: 0,0:00:25.46,0:00:28.84,Default,,0,0,0,,Karena ini tindakan makar\Nberupa pembunuhan berencana,
Dialogue: 0,0:00:28.84,0:00:32.43,Default,,0,0,0,,maka menurut hukum kekaisaran,\Npilihan hukumannya hanya tebas badan.
Dialogue: 0,0:00:32.93,0:00:34.01,Default,,0,0,0,,Begitu.
Dialogue: 0,0:00:35.64,0:00:38.93,Default,,0,0,0,,Namun, dalam kasus ini,\Nbisa dianggap percobaan.
Dialogue: 0,0:00:39.89,0:00:41.90,Default,,0,0,0,,Bagaimana kalau percobaan?
Dialogue: 0,0:00:42.19,0:00:44.19,Default,,0,0,0,,Hukuman tebas tak dapat dihindari.
Dialogue: 0,0:00:44.57,0:00:48.07,Default,,0,0,0,,Namun, hukumannya dapat\Nditurunkan satu tingkat, serta ditunda.
Dialogue: 0,0:00:48.07,0:00:51.78,Default,,0,0,0,,Dalam hal itu, pelaksanaannya\Nsesuai keinginan Yang Mulia.
Dialogue: 0,0:00:51.78,0:00:54.53,Default,,0,0,0,,Kenapa berbuat serumit itu?
Dialogue: 0,0:00:54.53,0:00:56.62,Default,,0,0,0,,Tebas ya tebas.
Dialogue: 0,0:00:56.62,0:00:59.83,Default,,0,0,0,,Kalau ujungnya tetap hukuman mati,\Nkapan pun pelaksanaannya sama saja.
Dialogue: 0,0:01:00.04,0:01:02.12,Default,,0,0,0,,Tidak. Noah memang hebat.
Dialogue: 0,0:01:02.46,0:01:06.13,Default,,0,0,0,,"Hukum dan kemanusiaan."\NKau mempertimbangkan dua sisi.
Dialogue: 0,0:01:06.71,0:01:08.76,Default,,0,0,0,,Kau hebat bisa berpikir sejauh itu.
Dialogue: 0,0:01:10.30,0:01:12.68,Default,,0,0,0,,{\i1}Gilbert juga putra Yang Mulia.{\i0}
Dialogue: 0,0:01:12.68,0:01:16.39,Default,,0,0,0,,{\i1}Ada kemungkinan hukuman tak dapat\Ndijatuhkan karena kasih sayang.{\i0}
Dialogue: 0,0:01:16.81,0:01:21.48,Default,,0,0,0,,{\i1}Maka kuusulkan gagasan yang bisa mengubah\Nhal itu jadi hukuman seumur hidup.{\i0}
Dialogue: 0,0:01:21.85,0:01:23.65,Default,,0,0,0,,Anda tak perlu ragu.
Dialogue: 0,0:01:23.65,0:01:28.36,Default,,0,0,0,,Orang macam dia yang berusaha meracuni\NYang Mulia, harus segera dihukum mati.
Dialogue: 0,0:01:30.74,0:01:31.99,Default,,0,0,0,,Albert.
Dialogue: 0,0:01:32.49,0:01:35.37,Default,,0,0,0,,Pelaksanaannya kuserahkan padamu.\NPergilah.
Dialogue: 0,0:01:35.57,0:01:36.53,Default,,0,0,0,,Sesuai titah!
Dialogue: 0,0:01:37.74,0:01:40.54,Default,,0,0,0,,Mendambakan takhta yang mustahil diraih,
Dialogue: 0,0:01:40.70,0:01:42.16,Default,,0,0,0,,sungguh menyedihkan.
Dialogue: 0,0:01:45.33,0:01:46.38,Default,,0,0,0,,Noah.
Dialogue: 0,0:01:47.13,0:01:48.75,Default,,0,0,0,,Kau hebat bisa mengatakannya.
Dialogue: 0,0:01:49.17,0:01:53.68,Default,,0,0,0,,Di tengah situasi ini, kau hebat\Nbisa mempertimbangkan hal itu.
Dialogue: 0,0:01:53.68,0:01:57.30,Default,,0,0,0,,Hanya dengan pertimbangan itu,\Nperasaanku bisa sedikit lega.
Dialogue: 0,0:01:57.56,0:02:01.68,Default,,0,0,0,,Menurut pemikiranku,\Nwilayah Gilbert yang sudah disita,
Dialogue: 0,0:02:01.68,0:02:04.35,Default,,0,0,0,,hendak kuberikan padamu apa adanya.
Dialogue: 0,0:02:04.35,0:02:05.35,Default,,0,0,0,,Tidak bisa.
Dialogue: 0,0:02:05.52,0:02:06.44,Default,,0,0,0,,Apa?
Dialogue: 0,0:02:07.11,0:02:10.78,Default,,0,0,0,,Kasus kali ini bermula\Ndari laporan rahasia saya.
Dialogue: 0,0:02:11.44,0:02:13.53,Default,,0,0,0,,Kalau saya mendapat\Nwilayah sebagai imbalan,
Dialogue: 0,0:02:13.53,0:02:15.60,Default,,0,0,0,,pangeran lain bisa\Nmenginginkan hal serupa,
Dialogue: 0,0:02:15.66,0:02:20.20,Default,,0,0,0,,lalu saling melaporkan dan\Nmenjegal satu sama lain.
Dialogue: 0,0:02:20.54,0:02:22.08,Default,,0,0,0,,Jangan terburu-buru.
Dialogue: 0,0:02:22.08,0:02:24.67,Default,,0,0,0,,Aku bilang, "menurut pemikiranku."
Dialogue: 0,0:02:24.96,0:02:25.75,Default,,0,0,0,,Ah.
Dialogue: 0,0:02:26.00,0:02:29.15,Default,,0,0,0,,Persaingan satu sama lain boleh saja,
Dialogue: 0,0:02:29.15,0:02:31.43,Default,,0,0,0,,tapi saling menjegal\Ntak dapat kutoleransi.
Dialogue: 0,0:02:32.05,0:02:35.18,Default,,0,0,0,,Maka, dalam kasus ini,\Nhadiah tidak kuberikan.
Dialogue: 0,0:02:35.55,0:02:37.14,Default,,0,0,0,,Saya memahaminya.
Dialogue: 0,0:02:37.72,0:02:40.47,Default,,0,0,0,,Sebagai gantinya, aku akan\Nmelakukan hal sepantasnya.
Dialogue: 0,0:02:40.85,0:02:43.68,Default,,0,0,0,,Sebentar lagi kau akan\Nmemasuki wilayah kekuasaanmu.
Dialogue: 0,0:02:43.68,0:02:47.02,Default,,0,0,0,,Sudah saatnya kau memiliki istri.
Dialogue: 0,0:02:47.98,0:02:48.86,Default,,0,0,0,,Ya.
Dialogue: 0,0:02:48.86,0:02:53.61,Default,,0,0,0,,{\i1}Bagi keluarga kekaisaran, pernikahan\Ndi usia 12 tahun tidaklah dini.{\i0}
Dialogue: 0,0:02:53.90,0:02:56.66,Default,,0,0,0,,{\i1}Lalu, terkait\Npernikahan pertama pangeran.{\i0}
Dialogue: 0,0:02:56.66,0:03:00.33,Default,,0,0,0,,{\i1}Istri utamanya itu\N100% merupakan siasat politik.{\i0}
Dialogue: 0,0:03:00.33,0:03:03.75,Default,,0,0,0,,{\i1}Jadi harus seorang wanita\Nyang garis keturunannya setara.{\i0}
Dialogue: 0,0:03:04.37,0:03:09.88,Default,,0,0,0,,{\i1}Karenanya, pihak yang menjalani pernikahan\Nitu nyaris tak punya hak bersuara.{\i0}
Dialogue: 0,0:03:10.50,0:03:15.42,Default,,0,0,0,,{\i1}Namun, terkadang terjadi\N"pertemuan yang ditakdirkan".{\i0}
Dialogue: 0,0:03:16.22,0:03:19.76,Default,,0,0,0,,Bagaimana dengan cucu pamanku\Nyang merupakan Pangeran Guntur?
Dialogue: 0,0:03:20.10,0:03:21.51,Default,,0,0,0,,{\i1}Pangeran Guntur...{\i0}
Dialogue: 0,0:03:21.51,0:03:25.73,Default,,0,0,0,,{\i1}Seingatku beliau sudah lama mundur\Ndan menjauh dari politik.{\i0}
Dialogue: 0,0:03:26.44,0:03:31.44,Default,,0,0,0,,Menurut ramalan, anak yang cerdas\Nakan lahir dari kalian berdua.
Dialogue: 0,0:03:31.44,0:03:34.57,Default,,0,0,0,,Meski peluangnya hanya sekitar 1%,
Dialogue: 0,0:03:34.74,0:03:38.74,Default,,0,0,0,,katanya ada kemungkinan\Nbakatnya melampauimu.
Dialogue: 0,0:03:38.95,0:03:42.08,Default,,0,0,0,,Dapat menyambut pasangan\Nyang begitu unggul,
Dialogue: 0,0:03:42.08,0:03:43.87,Default,,0,0,0,,merupakan kebahagiaan tiada tara.
Dialogue: 0,0:03:43.87,0:03:44.95,Default,,0,0,0,,Hm.
Dialogue: 0,0:03:46.96,0:03:49.92,Default,,0,0,0,,Kalau begitu, perjodohan\Ndengan gadis itu akan kuatur.
Dialogue: 0,0:03:49.92,0:03:50.79,Default,,0,0,0,,Sesuai titah.
Dialogue: 0,0:03:58.93,0:04:02.10,Default,,0,0,0,,Yah, Tuan Noah memang hebat.
Dialogue: 0,0:04:03.35,0:04:08.39,Default,,0,0,0,,Jangankan tahu siapa gadis itu,\Nnamanya saja tidak ditanyakan.
Dialogue: 0,0:04:08.39,0:04:11.56,Default,,0,0,0,,Begitulah hakikat anggota\Nkekaisaran, khususnya pangeran.
Dialogue: 0,0:04:11.73,0:04:13.73,Default,,0,0,0,,Meski begitu, seorang pria umumnya
Dialogue: 0,0:04:13.88,0:04:16.99,Default,,0,0,0,,akan tertarik dengan wanita\Nyang akan jadi istrinya.
Dialogue: 0,0:04:17.15,0:04:19.60,Default,,0,0,0,,Di usianya, dia mampu\Nmenahan rasa penasaran itu.
Dialogue: 0,0:04:19.60,0:04:22.13,Default,,0,0,0,,Dia memang luar biasa.
Dialogue: 0,0:04:22.45,0:04:24.80,Default,,0,0,0,,"Pilihlah penerus melalui cucu."
Dialogue: 0,0:04:24.80,0:04:28.93,Default,,0,0,0,,"Cucu berkualitas menjamin\Nkemakmuran sampai tiga generasi."
Dialogue: 0,0:04:29.04,0:04:31.79,Default,,0,0,0,,Itu memang usul yang bagus.
Dialogue: 0,0:04:31.79,0:04:35.84,Default,,0,0,0,,Sejatinya bagaimana? Terkait potensi\Ncucu yang bisa melampauiku.
Dialogue: 0,0:04:36.21,0:04:40.43,Default,,0,0,0,,Untuk saat ini, peluang tersebut\Ntergantung pada Tuan Noah.
Dialogue: 0,0:04:40.68,0:04:43.93,Default,,0,0,0,,Andai kecakapan Tuan Noah\Njuga tersampaikan pada anaknya...
Dialogue: 0,0:04:44.22,0:04:45.43,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:04:46.60,0:04:48.64,Default,,0,0,0,,Tiada pilihan selain berharap.
Dialogue: 0,0:04:58.69,0:05:01.91,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:05:01.95,0:05:03.78,tanda,,0,0,0,,{\an8}BEREINKARNASI MENJADI BANGSAWAN
Dialogue: 0,0:05:03.82,0:05:06.62,tanda,,0,0,0,,{\an8}~DENGAN KEKUATAN TIADA TANDING\NSEJAK TERLAHIR~
Dialogue: 0,0:05:02.95,0:05:06.12,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:05:10.08,0:05:12.04,Default,,0,0,0,,{\i1}Orang-orang adalah harta\NTeman pun adanya{\i0}
Dialogue: 0,0:05:12.08,0:05:14.08,Default,,0,0,0,,{\i1}Permata bersinar di belakangku\NSetetes air di tengah kekacauan{\i0}
Dialogue: 0,0:05:14.17,0:05:18.76,Default,,0,0,0,,{\i1}Demi kehormatan\NKumelaju ke tingkat baru{\i0}
Dialogue: 0,0:05:18.80,0:05:20.63,Default,,0,0,0,,{\an3\i1}Dengan imaji dan naluri\NKuterkam batas level itu{\i0}
Dialogue: 0,0:05:20.63,0:05:22.59,Default,,0,0,0,,{\an3\i1}Semua di depan mataku kan tunduk{\i0}
Dialogue: 0,0:05:22.59,0:05:24.97,Default,,0,0,0,,{\i1}Nilai dari namaku bagi rakyat tak bersalah\NAdalah tolok ukur yang tak tergoyahkan{\i0}
Dialogue: 0,0:05:25.10,0:05:27.06,Default,,0,0,0,,{\i1}Itulah sumber kebenaran\NYang kehormatan pun pontang-panting{\i0}
Dialogue: 0,0:05:27.06,0:05:29.02,Default,,0,0,0,,{\i1}Lalui kemelut{\i0}
Dialogue: 0,0:05:29.27,0:05:32.02,Default,,0,0,0,,{\i1}Kuakan tegakkan keadilan{\i0}
Dialogue: 0,0:05:32.19,0:05:35.36,Default,,0,0,0,,{\i1}Di tengah ketakutan merajalela{\i0}
Dialogue: 0,0:05:35.44,0:05:39.15,Default,,0,0,0,,{\i1}Bebaskan tiap insan dari rasa takut{\i0}
Dialogue: 0,0:05:39.78,0:05:43.32,Default,,0,0,0,,{\i1}Kuakan selamatkan dunia{\i0}
Dialogue: 0,0:05:44.03,0:05:48.83,Default,,0,0,0,,{\an3\i1}Menelusuri memori\NGunakan apa yang kupunya{\i0}
Dialogue: 0,0:05:48.83,0:05:50.87,Default,,0,0,0,,{\i1}Membangun tempat untuk semua{\i0}
Dialogue: 0,0:05:50.95,0:05:52.75,Default,,0,0,0,,{\i1}Kutakkan gagal{\i0}
Dialogue: 0,0:05:52.83,0:05:56.29,Default,,0,0,0,,{\i1}Masa depan sulit 'tuk ditebak{\i0}
Dialogue: 0,0:05:56.92,0:06:00.55,Default,,0,0,0,,{\i1}Kulakukan apa yang kubisa{\i0}
Dialogue: 0,0:06:01.26,0:06:06.17,Default,,0,0,0,,{\i1}Jika hanya yakin dan menunggu{\i0}
Dialogue: 0,0:06:06.22,0:06:08.14,Default,,0,0,0,,{\i1}Tiada yang mulai{\i0}
Dialogue: 0,0:06:08.14,0:06:09.81,Default,,0,0,0,,{\i1}Aku kan meraihnya!{\i0}
Dialogue: 0,0:06:10.02,0:06:13.06,Default,,0,0,0,,{\i1}chaos chaos{\i0}
Dialogue: 0,0:06:14.35,0:06:17.61,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:06:21.61,0:06:23.28,Default,,0,0,0,,Saya sudah membulatkan tekad!
Dialogue: 0,0:06:23.86,0:06:28.03,Default,,0,0,0,,Atas dosa mengkhianati Tuan Gilbert,\Nsaya tidak akan membantah!
Dialogue: 0,0:06:28.41,0:06:30.16,Default,,0,0,0,,Mohon kiranya diakhiri...
Dialogue: 0,0:06:30.58,0:06:33.79,Default,,0,0,0,,Jangan asal menyimpulkan.\NSiapa yang bilang begitu?
Dialogue: 0,0:06:33.79,0:06:35.29,Default,,0,0,0,,Na-Namun...
Dialogue: 0,0:06:35.46,0:06:38.25,Default,,0,0,0,,Manusia adalah harta.\NTakkan kubunuh tanpa alasan.
Dialogue: 0,0:06:38.67,0:06:43.05,Default,,0,0,0,,Sejak awal, menurut hukum kekaisaran,\Npelapor tindakan makar tak dihukum.
Dialogue: 0,0:06:43.55,0:06:44.43,Default,,0,0,0,,Eh?
Dialogue: 0,0:06:44.84,0:06:47.51,Default,,0,0,0,,Ada beberapa alasan aku memanggilmu.
Dialogue: 0,0:06:48.14,0:06:50.26,Default,,0,0,0,,Pertama-tama,\NGilbert dijatuhi hukuman mati.
Dialogue: 0,0:06:50.64,0:06:52.93,Default,,0,0,0,,Maka, kekuatan faksinya pun runtuh.
Dialogue: 0,0:06:53.14,0:06:57.60,Default,,0,0,0,,Jadi, kau tak perlu lagi ganti nama\Ndan pergi dari ibu kota.
Dialogue: 0,0:06:57.60,0:06:59.40,Default,,0,0,0,,Ba-Baik.
Dialogue: 0,0:06:59.94,0:07:05.15,Default,,0,0,0,,Lalu, bagi pelapor kasus makar,\Nakan diberi hadiah 1.000 riin.
Dialogue: 0,0:07:05.45,0:07:09.07,Default,,0,0,0,,Kali ini, dengan uangku sendiri,\Nkutambahkan satu digit nol di belakangnya.
Dialogue: 0,0:07:09.53,0:07:12.91,Default,,0,0,0,,Hah? Me-Mengapa sampai sebesar itu?
Dialogue: 0,0:07:12.91,0:07:15.58,Default,,0,0,0,,Karena kau\Npenyelamat nyawa Ayahandaku.
Dialogue: 0,0:07:17.50,0:07:21.71,Default,,0,0,0,,Aku bisa saja mengembalikanmu ke\NKementerian Rumah Tangga sebagai abdiku,
Dialogue: 0,0:07:21.71,0:07:23.17,Default,,0,0,0,,tapi katakanlah kemauanmu.
Dialogue: 0,0:07:24.55,0:07:25.55,Default,,0,0,0,,Hebat.
Dialogue: 0,0:07:26.18,0:07:29.43,Default,,0,0,0,,Andalah tuan saya selamanya.
Dialogue: 0,0:07:29.89,0:07:33.06,Default,,0,0,0,,Ke mana pun Anda menuju,\Nsaya akan mengikuti Anda!
Dialogue: 0,0:07:33.43,0:07:34.52,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:07:36.98,0:07:38.73,Default,,0,0,0,,Zoey. Sudah dengar, kan?
Dialogue: 0,0:07:39.44,0:07:40.40,Default,,0,0,0,,Ya.
Dialogue: 0,0:07:40.40,0:07:43.15,Default,,0,0,0,,Ibumu tak lagi dalam bahaya.
Dialogue: 0,0:07:43.15,0:07:45.15,Default,,0,0,0,,Sampaikan padanya agar dia bertenang.
Dialogue: 0,0:07:45.15,0:07:48.99,Default,,0,0,0,,Tuan... sampai memikirkan\Nibu saya juga...
Dialogue: 0,0:07:49.36,0:07:51.07,Default,,0,0,0,,Terima kasih banyak!
Dialogue: 0,0:07:51.07,0:07:51.99,Default,,0,0,0,,Ya.
Dialogue: 0,0:07:59.00,0:08:00.65,Default,,0,0,0,,Ini negeri para pejuang.
Dialogue: 0,0:08:00.65,0:08:02.25,Default,,0,0,0,,- Di sinilah ibu kotanya.\N- Tuan.
Dialogue: 0,0:08:02.50,0:08:03.50,Default,,0,0,0,,{\an8}Namun, selama ini,
Dialogue: 0,0:08:03.50,0:08:06.67,Default,,0,0,0,,- saya belum saksikan yang seperti perang.\N- Sepertinya di sana ada hal menarik.
Dialogue: 0,0:08:10.51,0:08:13.35,Default,,0,0,0,,Nah, apakah ada\Nyang mau jadi penantang?
Dialogue: 0,0:08:13.97,0:08:16.56,Default,,0,0,0,,Syaratnya hanya bertarung\Ndan menang melawanku.
Dialogue: 0,0:08:16.56,0:08:18.48,Default,,0,0,0,,Biaya pendaftarannya tiga riin!
Dialogue: 0,0:08:18.69,0:08:20.65,Default,,0,0,0,,Kalau menang, dapat apa?
Dialogue: 0,0:08:20.65,0:08:21.98,Default,,0,0,0,,Dapat diriku.
Dialogue: 0,0:08:21.98,0:08:25.65,Default,,0,0,0,,Mau jadi istri, selir, atau pelayan,\Nkuturuti semua perintahmu.
Dialogue: 0,0:08:25.65,0:08:26.30,Default,,0,0,0,,Wah!
Dialogue: 0,0:08:26.30,0:08:29.24,Default,,0,0,0,,{\i1}Kalau budak ilegal, menurut hukum\Nkekaisaran, yang dilarang itu{\i0}
Dialogue: 0,0:08:29.24,0:08:30.61,Default,,0,0,0,,{\i1}menjual orang lain.{\i0}
Dialogue: 0,0:08:31.45,0:08:34.24,Default,,0,0,0,,{\i1}Menjual diri sendiri\Nmemang bukan pelanggaran.{\i0}
Dialogue: 0,0:08:34.49,0:08:36.54,Default,,0,0,0,,Aku cukup mengalahkanmu, kan?
Dialogue: 0,0:08:36.54,0:08:37.29,Default,,0,0,0,,Ya.
Dialogue: 0,0:08:37.29,0:08:39.16,Default,,0,0,0,,Tapi satu lawan satu.
Dialogue: 0,0:08:39.16,0:08:41.04,Default,,0,0,0,,Sejak awal, aku berniat begitu.
Dialogue: 0,0:08:41.04,0:08:44.96,Default,,0,0,0,,Kalau tidak, aku tak bisa\Nmemonopolimu saat menang.
Dialogue: 0,0:08:51.22,0:08:52.26,Default,,0,0,0,,Tiga riin.
Dialogue: 0,0:08:54.01,0:08:56.01,Default,,0,0,0,,Kau belum bayar biaya pendaftaran, kan?
Dialogue: 0,0:08:56.01,0:08:57.77,Default,,0,0,0,,Idih! Malu-maluin!
Dialogue: 0,0:08:57.77,0:09:00.23,Default,,0,0,0,,Muncul tanpa bayar,\Nterus langsung kalah?
Dialogue: 0,0:09:00.23,0:09:01.40,Default,,0,0,0,,Sialan!
Dialogue: 0,0:09:01.40,0:09:03.56,Default,,0,0,0,,Nah, siapa penantang berikutnya?
Dialogue: 0,0:09:04.02,0:09:06.23,Default,,0,0,0,,- Oke, aku mau!\N- Aku selanjutnya.
Dialogue: 0,0:09:06.23,0:09:07.61,Default,,0,0,0,,Aku setelah dia!
Dialogue: 0,0:09:13.66,0:09:16.66,Default,,0,0,0,,Hebat, sekarang sudah orang ke-15!
Dialogue: 0,0:09:18.41,0:09:19.75,Default,,0,0,0,,Nah, berikutnya?
Dialogue: 0,0:09:19.96,0:09:21.79,Default,,0,0,0,,Kau coba ikut saja.
Dialogue: 0,0:09:21.79,0:09:22.92,Default,,0,0,0,,Mana bisa.
Dialogue: 0,0:09:25.38,0:09:26.50,Default,,0,0,0,,Aku akan melawanmu.
Dialogue: 0,0:09:27.09,0:09:28.42,Default,,0,0,0,,Biaya pendaftarannya?
Dialogue: 0,0:09:28.76,0:09:30.63,Default,,0,0,0,,Enggak perlu.
Dialogue: 0,0:09:30.92,0:09:33.55,Default,,0,0,0,,Karena aku yang akan menang!
Dialogue: 0,0:09:43.44,0:09:44.98,Default,,0,0,0,,A-Apa yang terjadi?
Dialogue: 0,0:09:44.98,0:09:46.44,Default,,0,0,0,,Dia menang dengan mudah.
Dialogue: 0,0:09:47.48,0:09:49.32,Default,,0,0,0,,Dengan begini, kau milikku.
Dialogue: 0,0:09:49.57,0:09:50.53,Default,,0,0,0,,Tunggu.
Dialogue: 0,0:09:51.57,0:09:54.11,Default,,0,0,0,,Jelas-jelas itu melanggar peraturan.
Dialogue: 0,0:09:54.45,0:09:56.83,Default,,0,0,0,,Hah? Apa maksudmu, Bocah?
Dialogue: 0,0:09:56.83,0:09:58.41,Default,,0,0,0,,Jangan cari-cari kesalahan!
Dialogue: 0,0:09:58.41,0:10:00.26,Default,,0,0,0,,Itu pasti obat pelumpuh atau sejenisnya.
Dialogue: 0,0:10:00.91,0:10:03.83,Default,,0,0,0,,Kalau kau menyuruh rekanmu,\Nberarti dua lawan satu.
Dialogue: 0,0:10:05.54,0:10:08.46,Default,,0,0,0,,Kau bicara apa? Mana buktinya?
Dialogue: 0,0:10:13.93,0:10:15.14,Default,,0,0,0,,Dia, ya?
Dialogue: 0,0:10:15.14,0:10:17.35,Default,,0,0,0,,Aku tak mengenalnya!
Dialogue: 0,0:10:17.35,0:10:20.68,Default,,0,0,0,,Jangan bohong, Chad!\NDia Rob, anak buahmu.
Dialogue: 0,0:10:20.68,0:10:23.02,Default,,0,0,0,,Kemarin dia juga minum-minum di kedaiku.
Dialogue: 0,0:10:23.02,0:10:25.15,Default,,0,0,0,,Lepaskan gadis itu! Pengecut!
Dialogue: 0,0:10:27.40,0:10:31.03,Default,,0,0,0,,Dasar bocah tengik!\NSeenaknya ikut campur!
Dialogue: 0,0:10:43.21,0:10:44.87,Default,,0,0,0,,Lihatlah penampilannya.
Dialogue: 0,0:10:44.87,0:10:46.50,Default,,0,0,0,,Bocah itu hebat sekali.
Dialogue: 0,0:10:46.50,0:10:48.38,Default,,0,0,0,,Saking cepatnya, jadi tak terlihat.
Dialogue: 0,0:10:48.38,0:10:49.67,Default,,0,0,0,,Masih mau melawan?
Dialogue: 0,0:10:50.71,0:10:53.63,Default,,0,0,0,,Ca... Ca...
Dialogue: 0,0:10:53.63,0:10:55.88,Default,,0,0,0,,Camkan baik-baik!
Dialogue: 0,0:10:55.88,0:10:58.43,Default,,0,0,0,,Tunggu aku, Chad!
Dialogue: 0,0:11:03.77,0:11:05.10,Default,,0,0,0,,Kau sudah bangun?
Dialogue: 0,0:11:05.10,0:11:05.98,Default,,0,0,0,,Eh?
Dialogue: 0,0:11:07.31,0:11:08.98,Default,,0,0,0,,Siapa kau...
Dialogue: 0,0:11:09.19,0:11:12.19,Default,,0,0,0,,Sebaiknya kau berterima kasih\Npada orang ini.
Dialogue: 0,0:11:12.19,0:11:14.95,Default,,0,0,0,,Karena dia penyelamat yang menolongmu.
Dialogue: 0,0:11:15.11,0:11:16.28,Default,,0,0,0,,Menolong?
Dialogue: 0,0:11:16.28,0:11:18.16,Default,,0,0,0,,Sejauh mana yang kau ingat?
Dialogue: 0,0:11:18.32,0:11:19.28,Default,,0,0,0,,Seingatku...
Dialogue: 0,0:11:19.74,0:11:21.95,Default,,0,0,0,,Aku bertarung\Nmelawan orang menyebalkan.
Dialogue: 0,0:11:22.33,0:11:24.66,Default,,0,0,0,,Dan entah kenapa kakiku kaku.
Dialogue: 0,0:11:24.91,0:11:26.83,Default,,0,0,0,,Kau diserang rekannya.
Dialogue: 0,0:11:27.54,0:11:28.58,Default,,0,0,0,,Pengecut!
Dialogue: 0,0:11:28.58,0:11:31.67,Default,,0,0,0,,Itu memang tindakan pengecut,\Ntapi kau sendiri juga lengah.
Dialogue: 0,0:11:32.75,0:11:35.30,Default,,0,0,0,,Lagi pula, kenapa kau melakukan itu?
Dialogue: 0,0:11:35.30,0:11:36.97,Default,,0,0,0,,Ceritakan alasannya.
Dialogue: 0,0:11:38.68,0:11:41.26,Default,,0,0,0,,Aku tak memiliki ongkos pulang.
Dialogue: 0,0:11:41.81,0:11:46.73,Default,,0,0,0,,Aku datang kemari untuk mengikuti\Nseleksi kesatria, tapi tak terwujud.
Dialogue: 0,0:11:47.27,0:11:50.31,Default,,0,0,0,,Dan aku tak punya uang\Nuntuk pulang kampung.
Dialogue: 0,0:11:50.31,0:11:52.40,Default,,0,0,0,,Tunggu. Alasanmu itu aneh.
Dialogue: 0,0:11:52.57,0:11:54.36,Default,,0,0,0,,Apanya yang aneh?
Dialogue: 0,0:11:54.36,0:11:58.32,Default,,0,0,0,,Aku sudah melihat kemampuanmu.\NHarusnya kau tak tersingkir.
Dialogue: 0,0:11:58.95,0:12:01.66,Default,,0,0,0,,Aku pun tidak terima,\Njadi minta itu diselidiki.
Dialogue: 0,0:12:02.12,0:12:02.99,Default,,0,0,0,,Lalu,
Dialogue: 0,0:12:03.37,0:12:06.50,Default,,0,0,0,,aku dipanggil Yang Mulia\NPangeran Ke-10 selaku ketua penilai,
Dialogue: 0,0:12:06.50,0:12:09.17,Default,,0,0,0,,dan beliau bilang kalau\Naku bisa saja diloloskan, tapi...
Dialogue: 0,0:12:10.38,0:12:12.38,Default,,0,0,0,,Kalau aku wanita, sebagai gantinya...
Dialogue: 0,0:12:12.38,0:12:15.05,Default,,0,0,0,,Sudah cukup, aku paham intinya.
Dialogue: 0,0:12:15.84,0:12:18.72,Default,,0,0,0,,{\i1}Kandaku itu memang pria\Nyang mungkin berkata begitu.{\i0}
Dialogue: 0,0:12:19.47,0:12:21.05,Default,,0,0,0,,Kau masih mau jadi kesatria?
Dialogue: 0,0:12:21.05,0:12:25.81,Default,,0,0,0,,Tentu saja! Meski butuh waktu lama,\Nakan kubuktikan aku mampu jadi kesatria!
Dialogue: 0,0:12:26.27,0:12:28.35,Default,,0,0,0,,Kalau begitu,\Nkau tak perlu pulang kampung.
Dialogue: 0,0:12:29.27,0:12:30.35,Default,,0,0,0,,Ada 100 riin.
Dialogue: 0,0:12:30.81,0:12:33.94,Default,,0,0,0,,Rasanya cukup untuk biaya tinggalmu\Nsampai seleksi berikutnya.
Dialogue: 0,0:12:34.19,0:12:35.03,Default,,0,0,0,,Eh?
Dialogue: 0,0:12:35.86,0:12:38.74,Default,,0,0,0,,Gigi, atur tempat tinggal\Nuntuk orang ini.
Dialogue: 0,0:12:38.74,0:12:39.91,Default,,0,0,0,,Dimengerti.
Dialogue: 0,0:12:40.86,0:12:43.45,Default,,0,0,0,,Apa maksudnya?\NKenapa kau melakukan ini?
Dialogue: 0,0:12:43.62,0:12:45.49,Default,,0,0,0,,Karena aku tertarik padamu.
Dialogue: 0,0:12:46.14,0:12:49.48,Default,,0,0,0,,Enggan memanfaatkan senjata "wanita"-mu\Ndan ingin membuktikan kemampuan.
Dialogue: 0,0:12:49.75,0:12:51.42,Default,,0,0,0,,Aku suka manusia seperti itu.
Dialogue: 0,0:12:52.00,0:12:53.42,Default,,0,0,0,,Siapa gerangan kau ini?
Dialogue: 0,0:12:53.71,0:12:55.09,Default,,0,0,0,,Kau pasti bukan orang biasa.
Dialogue: 0,0:12:55.92,0:12:56.80,Default,,0,0,0,,Itu dia!
Dialogue: 0,0:12:58.42,0:12:59.22,Default,,0,0,0,,Ini bocahnya!
Dialogue: 0,0:12:59.72,0:13:02.47,Default,,0,0,0,,Berani-beraninya kau mempermalukanku!
Dialogue: 0,0:13:02.76,0:13:04.22,Default,,0,0,0,,Tolong dibantu, ya, Bang.
Dialogue: 0,0:13:04.68,0:13:05.64,Default,,0,0,0,,Kau...
Dialogue: 0,0:13:05.64,0:13:06.81,Default,,0,0,0,,Mundurlah.
Dialogue: 0,0:13:10.39,0:13:11.39,Default,,0,0,0,,{\i1}Oh.{\i0}
Dialogue: 0,0:13:11.85,0:13:13.40,Default,,0,0,0,,{\i1}Kau sendiri yang mau bertarung?{\i0}
Dialogue: 0,0:13:13.90,0:13:16.40,Default,,0,0,0,,{\i1}Oke, akan kuhubungkan\Ndengan cincin zirah.{\i0}
Dialogue: 0,0:13:18.65,0:13:19.69,Default,,0,0,0,,Sip!
Dialogue: 0,0:13:23.32,0:13:26.20,Default,,0,0,0,,A-Ada apa? Tinjunya terbakar.
Dialogue: 0,0:13:26.20,0:13:28.25,Default,,0,0,0,,Aku baru sekarang melihat itu!
Dialogue: 0,0:13:28.50,0:13:30.83,Default,,0,0,0,,Heh, jangan takut. Habisi dia!
Dialogue: 0,0:13:41.13,0:13:42.05,Default,,0,0,0,,Rob!
Dialogue: 0,0:13:57.15,0:13:59.82,Default,,0,0,0,,Hebat. Gerakannya sangat efisien.
Dialogue: 0,0:13:59.82,0:14:01.49,Default,,0,0,0,,Dia sekuat itu?
Dialogue: 0,0:14:01.49,0:14:02.78,Default,,0,0,0,,Wah!
Dialogue: 0,0:14:02.78,0:14:04.74,Default,,0,0,0,,Hm? Tak mau bertarung?
Dialogue: 0,0:14:05.03,0:14:07.03,Default,,0,0,0,,Kesatria Pangeran Ke-10!
Dialogue: 0,0:14:07.03,0:14:07.83,Default,,0,0,0,,Eh!
Dialogue: 0,0:14:07.99,0:14:10.54,Default,,0,0,0,,Oh, ternyata seperti itu.
Dialogue: 0,0:14:11.91,0:14:16.00,Default,,0,0,0,,Mo-Mohon ampuni saya,\NYang Mulia Pangeran Ke-13!
Dialogue: 0,0:14:16.71,0:14:21.72,Default,,0,0,0,,{\i1}Dia memang sudah menerima uang\Nsogokan, tapi setelah tahu aku lawannya,{\i0}
Dialogue: 0,0:14:21.72,0:14:24.63,Default,,0,0,0,,{\i1}dia pun terdiam, berharap hal ini\Nbisa selesai tanpa keributan.{\i0}
Dialogue: 0,0:14:25.09,0:14:28.05,Default,,0,0,0,,Yang Mulia Pangeran Ke-13...
Dialogue: 0,0:14:28.56,0:14:32.10,Default,,0,0,0,,Anda Pangeran Arif yang menjabat\Nsebagai Menteri Hukum?
Dialogue: 0,0:14:32.10,0:14:34.31,Default,,0,0,0,,Ya, aku Noah Ararat.
Dialogue: 0,0:14:36.31,0:14:37.27,Default,,0,0,0,,{\i1}Yang asli?{\i0}
Dialogue: 0,0:14:37.27,0:14:41.15,Default,,0,0,0,,{\i1}Kalau memang begitu, maka semua\Nyang terjadi itu masuk akal.{\i0}
Dialogue: 0,0:14:41.48,0:14:45.32,Default,,0,0,0,,{\i1}Padahal beliau pangeran sekaligus menteri,\Ntapi beliau tidak memamerkan itu...{\i0}
Dialogue: 0,0:14:45.99,0:14:48.16,Default,,0,0,0,,Hukuman mereka kuserahkan padamu.
Dialogue: 0,0:14:48.16,0:14:48.95,Default,,0,0,0,,Eh?
Dialogue: 0,0:14:49.24,0:14:51.45,Default,,0,0,0,,Memangnya kau tadi menyerangku?
Dialogue: 0,0:14:53.25,0:14:56.08,Default,,0,0,0,,Khusus kali ini, yang tadi kuabaikan.\NCepat bawa mereka.
Dialogue: 0,0:14:56.08,0:14:57.79,Default,,0,0,0,,Si-Siap!
Dialogue: 0,0:14:58.59,0:15:00.05,Default,,0,0,0,,Cepat ikut aku!
Dialogue: 0,0:15:04.55,0:15:07.14,Default,,0,0,0,,Pemuda yang mengesankan.
Dialogue: 0,0:15:07.14,0:15:09.76,Default,,0,0,0,,Tampang serta kemampuannya\Nsangat unggul.
Dialogue: 0,0:15:10.51,0:15:11.77,Default,,0,0,0,,{\i1}Siapa dia?{\i0}
Dialogue: 0,0:15:12.18,0:15:15.77,Default,,0,0,0,,Jarang kulihat pemuda sehebat ini.
Dialogue: 0,0:15:17.31,0:15:18.90,Default,,0,0,0,,{\i1}Labu emas.{\i0}
Dialogue: 0,0:15:20.11,0:15:23.15,Default,,0,0,0,,{\i1}Pemilik benda itu belakangan ini\Nkuselidiki dan kuketahui.{\i0}
Dialogue: 0,0:15:26.30,0:15:27.97,Default,,0,0,0,,Kehormatan dapat berjumpa dengan Anda.
Dialogue: 0,0:15:29.91,0:15:31.37,Default,,0,0,0,,Yang Mulia Pangeran Guntur.
Dialogue: 0,0:15:31.70,0:15:34.50,Default,,0,0,0,,Wah, kau mengenalku?
Dialogue: 0,0:15:34.70,0:15:36.83,Default,,0,0,0,,Beliau juga Pangeran?
Dialogue: 0,0:15:36.83,0:15:39.04,Default,,0,0,0,,Rasanya aku pernah mendengar namanya.
Dialogue: 0,0:15:40.54,0:15:43.05,Default,,0,0,0,,{\i1}Pangeran Guntur, Indra Ararat.{\i0}
Dialogue: 0,0:15:44.46,0:15:47.97,Default,,0,0,0,,{\i1}Beberapa dekade silam,\Nsaat Yang Mulia Kaisar naik takhta,{\i0}
Dialogue: 0,0:15:48.59,0:15:52.18,Default,,0,0,0,,{\i1}dialah pria yang berada di pusat\Nkekuasaan sebagai Pangeran Wali.{\i0}
Dialogue: 0,0:15:52.56,0:15:56.69,Default,,0,0,0,,{\i1}Pada masa itu, karena Kaisar\Nmasih belia, kekaisaran pun kacau.{\i0}
Dialogue: 0,0:15:57.52,0:16:00.27,Default,,0,0,0,,{\i1}Namun dengan tangan besinya,\Nkonon dia menumpas semuanya.{\i0}
Dialogue: 0,0:16:01.11,0:16:03.82,Default,,0,0,0,,{\i1}Lima tahun setelahnya,\Ndia memilih mundur,{\i0}
Dialogue: 0,0:16:03.82,0:16:06.36,Default,,0,0,0,,{\i1}lalu hidup tenang\Ndi wilayah kekuasaannya.{\i0}
Dialogue: 0,0:16:08.02,0:16:11.07,Default,,0,0,0,,{\i1}Atas jasanya mewujudkan\Npemerintahan langsung oleh Kaisar,{\i0}
Dialogue: 0,0:16:11.24,0:16:13.62,Default,,0,0,0,,{\i1}dia dianugerahi gelar Guntur.{\i0}
Dialogue: 0,0:16:14.87,0:16:19.17,Default,,0,0,0,,{\i1}Siapa sangka, sosok sehebat itu\Nakan muncul di ibu kota.{\i0}
Dialogue: 0,0:16:19.62,0:16:21.63,Default,,0,0,0,,Kemari dan duduklah.
Dialogue: 0,0:16:21.79,0:16:23.04,Default,,0,0,0,,Saya mohon izin.
Dialogue: 0,0:16:28.72,0:16:31.51,Default,,0,0,0,,Kalau kau tahu tentangku,
Dialogue: 0,0:16:31.76,0:16:35.77,Default,,0,0,0,,berarti Kaisar sudah membahasnya, kan?
Dialogue: 0,0:16:35.77,0:16:37.89,Default,,0,0,0,,Benar. Langsung dari Yang Mulia.
Dialogue: 0,0:16:37.89,0:16:42.56,Default,,0,0,0,,Begitu, ya. Berarti kau juga\Ntahu alasanku kemari.
Dialogue: 0,0:16:43.31,0:16:45.36,Default,,0,0,0,,Menguji kelayakan, ya?
Dialogue: 0,0:16:45.78,0:16:49.03,Default,,0,0,0,,Kaisar sudah memutuskan ini\Nkarena percaya padamu.
Dialogue: 0,0:16:49.49,0:16:52.16,Default,,0,0,0,,Sebenarnya tak perlu kupastikan,
Dialogue: 0,0:16:52.41,0:16:55.79,Default,,0,0,0,,tapi ini terkait kehidupan\Ncucu perempuanku.
Dialogue: 0,0:16:55.79,0:16:59.87,Default,,0,0,0,,{\i1}Cara bicaranya dapat memicu\Nkemarahan para inspektur kekaisaran.{\i0}
Dialogue: 0,0:17:00.42,0:17:03.17,Default,,0,0,0,,{\i1}Meski dia paman Yang Mulia Kaisar,\Ntapi dia tetap bawahan.{\i0}
Dialogue: 0,0:17:03.17,0:17:06.30,Default,,0,0,0,,{\i1}Menyebut Kaisar tanpa "Yang Mulia"\Nadalah bentuk ketidakhormatan.{\i0}
Dialogue: 0,0:17:07.55,0:17:11.76,Default,,0,0,0,,{\i1}Namun, meskipun ditegur,\Nsepertinya dia tak peduli.{\i0}
Dialogue: 0,0:17:11.76,0:17:14.01,Default,,0,0,0,,{\i1}Yang Mulia juga kurasa takkan menegur.{\i0}
Dialogue: 0,0:17:14.60,0:17:17.02,Default,,0,0,0,,{\i1}Memang begitulah tipenya.{\i0}
Dialogue: 0,0:17:18.18,0:17:21.31,Default,,0,0,0,,Jika saya dinilai tidak layak,\Napa yang akan Anda lakukan?
Dialogue: 0,0:17:22.81,0:17:25.23,Default,,0,0,0,,Aku hanya takkan merestuimu.
Dialogue: 0,0:17:25.23,0:17:27.11,Default,,0,0,0,,Perintah ini titah kekaisaran, kan?
Dialogue: 0,0:17:27.11,0:17:28.61,Default,,0,0,0,,Masa bodoh.
Dialogue: 0,0:17:28.82,0:17:32.99,Default,,0,0,0,,Kalau itu perintah Kaisar biasanya,\Nseparah apa pun akan kuturuti.
Dialogue: 0,0:17:33.24,0:17:36.58,Default,,0,0,0,,Namun, kali ini menyangkut cucuku.
Dialogue: 0,0:17:37.45,0:17:40.37,Default,,0,0,0,,Ini soal cucu perempuanku yang imut.
Dialogue: 0,0:17:40.71,0:17:44.04,Default,,0,0,0,,Artinya, ini bukan politik,\Nmelainkan urusan internal istana.
Dialogue: 0,0:17:44.04,0:17:48.71,Default,,0,0,0,,Terus, yang menitah itu keponakanku.\NBocah yang dulu main di pangkuanku.
Dialogue: 0,0:17:49.17,0:17:52.51,Default,,0,0,0,,Kalau tindakannya salah,\Nakan kuhentikan, meski harus menampar.
Dialogue: 0,0:17:53.01,0:17:55.85,Default,,0,0,0,,{\i1}Begitu, ya. Orang yang menarik.{\i0}
Dialogue: 0,0:17:56.22,0:17:58.72,Default,,0,0,0,,{\i1}Kurasa orang ini tak haus kekuasaan.{\i0}
Dialogue: 0,0:17:59.10,0:18:02.94,Default,,0,0,0,,{\i1}Makanya sikap lancang dan kurang ajarnya\Ntidak ditegur, justru disukai.{\i0}
Dialogue: 0,0:18:03.52,0:18:05.61,Default,,0,0,0,,Kalau begitu, apa saya lulus?
Dialogue: 0,0:18:06.69,0:18:09.07,Default,,0,0,0,,Baru akan kupastikan.
Dialogue: 0,0:18:10.19,0:18:14.45,Default,,0,0,0,,{\i1}Apa ini? Aku seperti ditekan sesuatu!{\i0}
Dialogue: 0,0:18:14.70,0:18:17.70,Default,,0,0,0,,{\i1}Ini sama seperti saat\Naku menggunakan Leviathan.{\i0}
Dialogue: 0,0:18:18.16,0:18:19.37,Default,,0,0,0,,{\i1}Intimidasi.{\i0}
Dialogue: 0,0:18:21.20,0:18:24.33,Default,,0,0,0,,{\i1}Kalau begitu, akan kutekan balik!{\i0}
Dialogue: 0,0:18:24.54,0:18:25.58,Default,,0,0,0,,Wah?
Dialogue: 0,0:18:26.58,0:18:28.63,Default,,0,0,0,,{\i1}Sip, dengan momentum ini, langsung...{\i0}
Dialogue: 0,0:18:29.00,0:18:30.67,Default,,0,0,0,,{\i1}Tidak, kuurungkan saja.{\i0}
Dialogue: 0,0:18:31.17,0:18:33.13,Default,,0,0,0,,{\i1}Lawan yang kuhadapi paman buyutku.{\i0}
Dialogue: 0,0:18:33.13,0:18:35.55,Default,,0,0,0,,{\i1}Pria yang mungkin\Nakan jadi kakek mertuaku.{\i0}
Dialogue: 0,0:18:35.84,0:18:38.26,Default,,0,0,0,,{\i1}Tak pantas menaklukkannya\Ndi depan umum.{\i0}
Dialogue: 0,0:18:38.56,0:18:40.64,Default,,0,0,0,,{\i1}Tak menang, tapi juga tak kalah.{\i0}
Dialogue: 0,0:18:41.22,0:18:42.93,Default,,0,0,0,,{\i1}Akan kuatur seperti itu.{\i0}
Dialogue: 0,0:18:45.40,0:18:48.86,Default,,0,0,0,,Kau hebat, Nak. Aku kalah.
Dialogue: 0,0:18:49.11,0:18:51.61,Default,,0,0,0,,Eng, saya rasa imbang.
Dialogue: 0,0:18:51.82,0:18:57.07,Default,,0,0,0,,Bodoh, kau itu membaca kekuatanku\Ndan memaksakan hasil imbang.
Dialogue: 0,0:18:57.37,0:18:59.53,Default,,0,0,0,,Pertimbangan itu membuatku kalah telak.
Dialogue: 0,0:19:00.58,0:19:04.37,Default,,0,0,0,,{\i1}Dibilang pertimbangan, padahal\Ndia sendiri yang membongkarnya.{\i0}
Dialogue: 0,0:19:04.58,0:19:06.96,Default,,0,0,0,,{\i1}Sifatnya memang sulit dibenci.{\i0}
Dialogue: 0,0:19:07.75,0:19:09.75,Default,,0,0,0,,Aku menyukaimu, Nak.
Dialogue: 0,0:19:09.75,0:19:12.34,Default,,0,0,0,,Kutitip cucu perempuanku padamu.
Dialogue: 0,0:19:12.34,0:19:13.21,Default,,0,0,0,,Baik.
Dialogue: 0,0:19:15.05,0:19:16.80,Default,,0,0,0,,Hari ini suasana hatiku sedang baik.
Dialogue: 0,0:19:16.80,0:19:17.97,Default,,0,0,0,,Hei, kau!
Dialogue: 0,0:19:17.97,0:19:18.60,Default,,0,0,0,,Hm?
Dialogue: 0,0:19:18.60,0:19:20.72,Default,,0,0,0,,Keluarkan semua arak di kedaimu.
Dialogue: 0,0:19:21.18,0:19:22.72,Default,,0,0,0,,Aku yang traktir!
Dialogue: 0,0:19:23.06,0:19:25.06,Default,,0,0,0,,Yang mau minum, minumlah!
Dialogue: 0,0:19:27.44,0:19:29.31,Default,,0,0,0,,{\i1}Foya-foya pun ada batasnya.{\i0}
Dialogue: 0,0:19:29.77,0:19:32.61,Default,,0,0,0,,{\i1}Dia memang tak seperti\Nbangsawan yang kukenal.{\i0}
Dialogue: 0,0:19:32.94,0:19:34.07,Default,,0,0,0,,Ini untukmu.
Dialogue: 0,0:19:34.49,0:19:35.82,Default,,0,0,0,,Hadiah pertunangan.
Dialogue: 0,0:19:35.82,0:19:36.78,Default,,0,0,0,,Cincin?
Dialogue: 0,0:19:37.03,0:19:38.16,Default,,0,0,0,,Dia itu...
Dialogue: 0,0:19:38.62,0:19:40.66,Default,,0,0,0,,Tunjukkanlah kekuatanmu!
Dialogue: 0,0:19:46.58,0:19:47.75,Default,,0,0,0,,Ini di mana...
Dialogue: 0,0:19:57.51,0:19:59.89,Default,,0,0,0,,Menunjukkan kekuatanku, ya?
Dialogue: 0,0:20:10.81,0:20:11.86,Default,,0,0,0,,Empaslah!
Dialogue: 0,0:20:28.83,0:20:30.08,Default,,0,0,0,,Meningkat.
Dialogue: 0,0:20:30.42,0:20:31.88,Default,,0,0,0,,Atribut cahayaku jadi +C.
Dialogue: 0,0:20:32.38,0:20:34.30,Default,,0,0,0,,Namaku Behemoth.
Dialogue: 0,0:20:35.76,0:20:37.76,Default,,0,0,0,,Aku akan tunduk padamu.
Dialogue: 0,0:20:42.55,0:20:46.64,Default,,0,0,0,,Namanya Behemoth.\NKekuatan yang berpadu denganku.
Dialogue: 0,0:20:46.64,0:20:47.81,Default,,0,0,0,,Begini, ya?
Dialogue: 0,0:20:58.07,0:21:02.57,Default,,0,0,0,,Kau seketika menaklukkan Behemoth,\Npadahal aku saja tidak bisa!
Dialogue: 0,0:21:02.57,0:21:06.20,Default,,0,0,0,,Bahkan Pangeran Guntur pun\Ntak mampu menaklukkannya?
Dialogue: 0,0:21:06.20,0:21:08.91,Default,,0,0,0,,Dia hanya memberi tahu namanya.
Dialogue: 0,0:21:09.12,0:21:11.89,Default,,0,0,0,,Sejak dulu, aku berharap\Nbisa berjumpa lagi
Dialogue: 0,0:21:11.89,0:21:14.31,Default,,0,0,0,,dengan sosok emas yang memesona itu.
Dialogue: 0,0:21:14.59,0:21:15.88,Default,,0,0,0,,Sosok?
Dialogue: 0,0:21:16.13,0:21:17.67,Default,,0,0,0,,Apa seperti ini?
Dialogue: 0,0:21:21.01,0:21:22.59,Default,,0,0,0,,Ini dia!
Dialogue: 0,0:21:22.89,0:21:26.01,Default,,0,0,0,,Kau bisa melakukan ini?\NHebat sekali, Nak.
Dialogue: 0,0:21:26.35,0:21:30.06,Default,,0,0,0,,Saya mengadu mereka\Nuntuk belajar kekuatan dan teknik.
Dialogue: 0,0:21:30.27,0:21:32.94,Default,,0,0,0,,Mengadu? Dengan apa?
Dialogue: 0,0:21:32.94,0:21:34.23,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:21:34.44,0:21:36.94,Default,,0,0,0,,Mungkin akan mudah dipahami\Njika melihat langsung.
Dialogue: 0,0:21:39.32,0:21:41.45,Default,,0,0,0,,{\i1}Pedang Iblis Air, Leviathan.{\i0}
Dialogue: 0,0:21:42.24,0:21:44.49,Default,,0,0,0,,{\i1}Cincin Api, Lutiya.{\i0}
Dialogue: 0,0:21:45.20,0:21:47.20,Default,,0,0,0,,{\i1}Lukisan Angin, Fuwawa.{\i0}
Dialogue: 0,0:21:48.16,0:21:50.33,Default,,0,0,0,,{\i1}Cincin Tanah, Behemoth.{\i0}
Dialogue: 0,0:21:50.83,0:21:53.96,Default,,0,0,0,,{\i1}Keempatnya berkumpul bersama\Nsetelah seribu tahun lamanya.{\i0}
Dialogue: 0,0:21:53.96,0:21:56.50,Default,,0,0,0,,{\i1}Sejak zaman Perak.{\i0}
Dialogue: 0,0:21:57.05,0:21:59.63,Default,,0,0,0,,{\i1}Lalu Yang Mulia Pangeran Ke-13...{\i0}
Dialogue: 0,0:22:01.42,0:22:02.21,Default,,0,0,0,,{\i1}Ya.{\i0}
Dialogue: 0,0:22:02.36,0:22:04.98,Default,,0,0,0,,{\i1}Dia mengalami peristiwa\Nyang menakjubkan,{\i0}
Dialogue: 0,0:22:05.22,0:22:08.26,Default,,0,0,0,,{\i1}yang hanya pantas disebut keajaiban.{\i0}
Dialogue: 0,0:22:17.65,0:22:21.99,Default,,0,0,0,,{\an1\i1}Mimpi singkat yang masih tak sampai{\i0}
Dialogue: 0,0:22:22.24,0:22:28.99,Default,,0,0,0,,{\i1}Kutakut akan peluh\NYang tak kunjung sembuh{\i0}
Dialogue: 0,0:22:29.58,0:22:33.83,Default,,0,0,0,,{\i1}Siluet terpantul di tepi jendela{\i0}
Dialogue: 0,0:22:34.17,0:22:39.05,Default,,0,0,0,,{\i1}Kenanganku bersamamu\Nperlahan memudar{\i0}
Dialogue: 0,0:22:41.63,0:22:46.30,Default,,0,0,0,,{\i1}Diterangi sinar rembulan{\i0}
Dialogue: 0,0:22:46.47,0:22:52.77,Default,,0,0,0,,{\i1}Kulihat dirimu bersinar\NBagai bintang nun jauh{\i0}
Dialogue: 0,0:22:53.27,0:22:59.44,Default,,0,0,0,,{\i1}Walau musim berganti, waktu berlalu{\i0}
Dialogue: 0,0:22:59.73,0:23:03.36,Default,,0,0,0,,{\i1}Rasaku padamu tidak{\i0}
Dialogue: 0,0:23:03.53,0:23:09.37,Default,,0,0,0,,{\i1}Harapku agar sajak cinta abadi ini\NKian sampai padamu{\i0}
Dialogue: 0,0:23:09.41,0:23:15.33,Default,,0,0,0,,{\i1}Walau kutahu kan terwujud\NAku tetap memimpikannya{\i0}
Dialogue: 0,0:23:15.37,0:23:16.87,Default,,0,0,0,,{\i1}Air mataku mengering{\i0}
Dialogue: 0,0:23:16.92,0:23:19.84,Default,,0,0,0,,{\an3\i1}Pemandangan mengabur\NDi seberang keabadian{\i0}
Dialogue: 0,0:23:19.84,0:23:22.88,Default,,0,0,0,,{\an3\i1}Walau aku terlepas bayang-bayangmu{\i0}
Dialogue: 0,0:23:22.96,0:23:32.43,Default,,0,0,0,,{\i1}Hatiku kan terpaut di sisimu{\i0}
