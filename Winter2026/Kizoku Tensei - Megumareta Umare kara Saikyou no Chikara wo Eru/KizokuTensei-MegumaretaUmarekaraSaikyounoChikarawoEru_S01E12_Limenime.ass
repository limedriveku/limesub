Dialogue: 0,0:00:01.56,0:00:02.94,Default,,0,0,0,,Menyampaikan laporan rahasia.
Dialogue: 0,0:00:05.36,0:00:08.57,Default,,0,0,0,,Albert, Pangeran Kedua\Nsekaligus Putra Mahkota
Dialogue: 0,0:00:10.53,0:00:12.49,Default,,0,0,0,,berencana melakukan kudeta malam ini
Dialogue: 0,0:00:13.37,0:00:16.00,Default,,0,0,0,,dan memaksa Yang Mulia turun takhta.
Dialogue: 0,0:00:24.67,0:00:27.88,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:00:27.92,0:00:29.76,tanda,,0,0,0,,{\an8}BEREINKARNASI MENJADI BANGSAWAN
Dialogue: 0,0:00:28.92,0:00:32.09,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:00:29.80,0:00:32.60,tanda,,0,0,0,,{\an8}~DENGAN KEKUATAN TIADA TANDING\NSEJAK TERLAHIR~
Dialogue: 0,0:00:36.06,0:00:38.02,Default,,0,0,0,,{\i1}Orang-orang adalah harta\NTeman pun adanya{\i0}
Dialogue: 0,0:00:38.06,0:00:40.06,Default,,0,0,0,,{\i1}Permata bersinar di belakangku\NSetetes air di tengah kekacauan{\i0}
Dialogue: 0,0:00:40.14,0:00:44.73,Default,,0,0,0,,{\i1}Demi kehormatan\NKumelaju ke tingkat baru{\i0}
Dialogue: 0,0:00:44.77,0:00:46.61,Default,,0,0,0,,{\an3\i1}Dengan imaji dan naluri\NKuterkam batas level itu{\i0}
Dialogue: 0,0:00:46.61,0:00:48.57,Default,,0,0,0,,{\an3\i1}Semua di depan mataku kan tunduk{\i0}
Dialogue: 0,0:00:48.57,0:00:50.95,Default,,0,0,0,,{\i1}Nilai dari namaku bagi rakyat tak bersalah\NAdalah tolok ukur yang tak tergoyahkan{\i0}
Dialogue: 0,0:00:51.07,0:00:53.03,Default,,0,0,0,,{\i1}Itulah sumber kebenaran\NYang kehormatan pun pontang-panting{\i0}
Dialogue: 0,0:00:53.03,0:00:54.99,Default,,0,0,0,,{\i1}Lalui kemelut{\i0}
Dialogue: 0,0:00:55.24,0:00:58.00,Default,,0,0,0,,{\i1}Kuakan tegakkan keadilan{\i0}
Dialogue: 0,0:00:58.16,0:01:01.33,Default,,0,0,0,,{\i1}Di tengah ketakutan merajalela{\i0}
Dialogue: 0,0:01:01.42,0:01:05.13,Default,,0,0,0,,{\i1}Bebaskan tiap insan dari rasa takut{\i0}
Dialogue: 0,0:01:05.75,0:01:09.30,Default,,0,0,0,,{\i1}Kuakan selamatkan dunia{\i0}
Dialogue: 0,0:01:10.01,0:01:14.80,Default,,0,0,0,,{\an3\i1}Menelusuri memori\NGunakan apa yang kupunya{\i0}
Dialogue: 0,0:01:14.80,0:01:16.85,Default,,0,0,0,,{\i1}Membangun tempat untuk semua{\i0}
Dialogue: 0,0:01:16.93,0:01:18.72,Default,,0,0,0,,{\i1}Kutakkan gagal{\i0}
Dialogue: 0,0:01:18.81,0:01:22.27,Default,,0,0,0,,{\i1}Masa depan sulit 'tuk ditebak{\i0}
Dialogue: 0,0:01:22.90,0:01:26.52,Default,,0,0,0,,{\i1}Kulakukan apa yang kubisa{\i0}
Dialogue: 0,0:01:27.23,0:01:32.15,Default,,0,0,0,,{\i1}Jika hanya yakin dan menunggu{\i0}
Dialogue: 0,0:01:32.20,0:01:34.12,Default,,0,0,0,,{\i1}Tiada yang mulai{\i0}
Dialogue: 0,0:01:34.12,0:01:35.78,Default,,0,0,0,,{\i1}Aku kan meraihnya!{\i0}
Dialogue: 0,0:01:35.99,0:01:39.04,Default,,0,0,0,,{\i1}chaos chaos{\i0}
Dialogue: 0,0:01:40.33,0:01:43.58,Default,,0,0,0,,{\i1}Break off chaos{\i0}
Dialogue: 0,0:01:46.13,0:01:50.97,tanda,,0,0,0,,{\an2}EPISODE 12\NBANGSAWAN
Dialogue: 0,0:01:53.47,0:01:54.80,Default,,0,0,0,,{\i1}Albert!{\i0}
Dialogue: 0,0:01:55.89,0:01:57.26,Default,,0,0,0,,{\i1}Tunggu dulu.{\i0}
Dialogue: 0,0:01:57.81,0:01:59.47,Default,,0,0,0,,Namamu Olivia, ya?
Dialogue: 0,0:02:00.02,0:02:02.23,Default,,0,0,0,,Kenapa kau tahu soal ini?
Dialogue: 0,0:02:02.60,0:02:06.94,Default,,0,0,0,,Saya adalah abdi Yang Mulia Gilbert,\Nmantan pangeran pertama.
Dialogue: 0,0:02:07.27,0:02:08.77,Default,,0,0,0,,Saya putrinya Coile.
Dialogue: 0,0:02:08.77,0:02:10.19,Default,,0,0,0,,Coile selaku pelayan?
Dialogue: 0,0:02:10.82,0:02:12.28,Default,,0,0,0,,Trah abdi, ya?
Dialogue: 0,0:02:12.28,0:02:13.07,Default,,0,0,0,,Benar.
Dialogue: 0,0:02:13.07,0:02:14.49,Default,,0,0,0,,{\i1}Trah abdi.{\i0}
Dialogue: 0,0:02:15.49,0:02:20.24,Default,,0,0,0,,{\i1}Secara harfiah, itu merujuk pada anak\Nyang lahir dari sesama pelayan pangeran.{\i0}
Dialogue: 0,0:02:21.12,0:02:23.66,Default,,0,0,0,,{\i1}Karena besar di lingkungan seperti itu,{\i0}
Dialogue: 0,0:02:23.66,0:02:28.00,Default,,0,0,0,,{\i1}mereka pun cenderung mudah berikrar\Nsetia pada sang Pangeran selaku tuannya.{\i0}
Dialogue: 0,0:02:29.17,0:02:31.13,Default,,0,0,0,,Saya sudah tahu terkait hal itu.
Dialogue: 0,0:02:31.46,0:02:36.72,Default,,0,0,0,,Bahwa Tuan Noah mengupayakan segala cara\Nuntuk menyelamatkan Pangeran Pertama.
Dialogue: 0,0:02:37.05,0:02:39.18,Default,,0,0,0,,Tapi, pria itu...
Dialogue: 0,0:02:39.68,0:02:40.89,Default,,0,0,0,,{\i1}Rupanya begitu.{\i0}
Dialogue: 0,0:02:41.10,0:02:43.85,Default,,0,0,0,,{\i1}Kemungkinan, pada saat itu,\NAyahandaku...{\i0}
Dialogue: 0,0:02:44.48,0:02:48.48,Default,,0,0,0,,Aku bersumpah ingin balas dendam,\Nlalu mendekati pria itu.
Dialogue: 0,0:02:48.86,0:02:52.19,Default,,0,0,0,,Dengan tubuh ini,\Nanugerah dari orang tuaku.
Dialogue: 0,0:02:52.69,0:02:55.57,Default,,0,0,0,,Lalu, aku mendengarnya.
Dialogue: 0,0:02:57.03,0:02:59.33,Default,,0,0,0,,Sebelum titah pencabutan hak waris\Ndikeluarkan resmi,
Dialogue: 0,0:03:00.20,0:03:02.87,Default,,0,0,0,,yakni pada hari ini, saat dia\Nmasih menjadi Putra Mahkota,
Dialogue: 0,0:03:03.50,0:03:07.46,Default,,0,0,0,,dia masih bisa mengerahkan\Npasukan untuk mengepung istana.
Dialogue: 0,0:03:11.34,0:03:13.92,Default,,0,0,0,,Albert ingin berbuat apa\Npada Yang Mulia?
Dialogue: 0,0:03:14.13,0:03:18.76,Default,,0,0,0,,Dia ingin memaksa Yang Mulia turun takhta,\Nlalu menjadikannya Kaisar Purnabakti.
Dialogue: 0,0:03:23.31,0:03:24.93,Default,,0,0,0,,Saya mohon dengan sangat!
Dialogue: 0,0:03:24.93,0:03:29.61,Default,,0,0,0,,Tubuh ini! Nyawa ini!\NSilakan gunakan sesuka Anda!
Dialogue: 0,0:03:29.81,0:03:33.15,Default,,0,0,0,,Saya mohon, penggallah Albert\Nselaku Putra Mahkota!
Dialogue: 0,0:03:33.15,0:03:34.36,Default,,0,0,0,,Saya mohon!
Dialogue: 0,0:03:36.74,0:03:37.82,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:03:39.49,0:03:40.45,Default,,0,0,0,,Apa tugasmu...
Dialogue: 0,0:03:40.91,0:03:43.45,Default,,0,0,0,,saat berada di mansion Gilbert?
Dialogue: 0,0:03:43.79,0:03:47.92,Default,,0,0,0,,Di bawah bimbingan Ayah,\Nsaya berlatih menjadi pelayan.
Dialogue: 0,0:03:48.50,0:03:50.67,Default,,0,0,0,,Maka, lakukanlah itu di sini.
Dialogue: 0,0:03:51.04,0:03:52.96,Default,,0,0,0,,Gajimu juga akan kubayar sama.
Dialogue: 0,0:03:53.59,0:03:56.72,Default,,0,0,0,,Mulai besok, kau tak perlu\Nmelakukan macam-macam lagi.
Dialogue: 0,0:03:57.93,0:04:00.97,Default,,0,0,0,,Mengapa Anda... memberikan\Nperlakuan seistimewa itu?
Dialogue: 0,0:04:01.89,0:04:05.81,Default,,0,0,0,,Meski kehilangan majikan, kau tetap\Nberusaha membalas musuhmu.
Dialogue: 0,0:04:06.18,0:04:08.20,Default,,0,0,0,,Setelah majikanmu wafat,\Nkau tetap setia.
Dialogue: 0,0:04:08.44,0:04:10.65,Default,,0,0,0,,Dan aku menghargai kesetiaanmu itu.
Dialogue: 0,0:04:11.31,0:04:12.90,Default,,0,0,0,,Betapa mulianya Anda...
Dialogue: 0,0:04:13.61,0:04:16.57,Default,,0,0,0,,Sudilah kiranya membimbing saya!
Dialogue: 0,0:04:19.32,0:04:21.03,tanda,,0,0,0,,{\an7}NAMA: NOAH ARARAT, PANGERAN KE-13 DARI KEKAISARAN\N JENIS KELAMIN: LAKI-LAKI\NGELAR: MENTERI HUKUM\NLEVEL: 3/∞\NAPI: F+B\NAIR: E+S\NTANAH: F+F\NCAHAYA: F+C\NKEGELAPAN: F
Dialogue: 0,0:04:21.03,0:04:22.64,tanda,,0,0,0,,{\an2}KEGELAPAN: F
Dialogue: 0,0:04:22.64,0:04:24.33,tanda,,0,0,0,,{\an2}KEGELAPAN: F+F
Dialogue: 0,0:04:34.84,0:04:36.05,Default,,0,0,0,,Tuan?
Dialogue: 0,0:04:36.84,0:04:38.30,Default,,0,0,0,,Aku mau pergi sebentar.
Dialogue: 0,0:04:38.30,0:04:41.01,Default,,0,0,0,,Ba-Baik. Kereta kuda, ya.
Dialogue: 0,0:04:41.01,0:04:42.55,Default,,0,0,0,,Tidak, aku sendirian saja.
Dialogue: 0,0:04:42.55,0:04:43.30,Default,,0,0,0,,Eh?
Dialogue: 0,0:04:48.35,0:04:50.89,Default,,0,0,0,,Ta-Tapi, ini sudah larut...
Dialogue: 0,0:04:50.89,0:04:52.36,Default,,0,0,0,,- Gigi.\N- Eh?
Dialogue: 0,0:04:58.24,0:05:01.57,Default,,0,0,0,,Kami menanti kepulangan Anda, Tuan.
Dialogue: 0,0:05:02.53,0:05:03.53,Default,,0,0,0,,Ya.
Dialogue: 0,0:05:08.62,0:05:10.83,Default,,0,0,0,,Semoga Tuan diberikan keselamatan.
Dialogue: 0,0:05:15.79,0:05:18.31,Default,,0,0,0,,{\i1}Kalau Albert\Ningin menggunakan wewenangnya,{\i0}
Dialogue: 0,0:05:18.31,0:05:20.76,Default,,0,0,0,,{\i1}hanya satu pasukan\Nyang bisa dia kerahkan.{\i0}
Dialogue: 0,0:05:29.43,0:05:31.77,Default,,0,0,0,,{\i1}Yaitu pasukan di Kementerian Pertahanan.{\i0}
Dialogue: 0,0:05:41.95,0:05:43.74,Default,,0,0,0,,{\i1}Prajurit seribu orang.{\i0}
Dialogue: 0,0:05:45.41,0:05:47.62,Default,,0,0,0,,{\i1}Karena ditugaskan selalu siaga di sana,{\i0}
Dialogue: 0,0:05:48.37,0:05:49.41,Default,,0,0,0,,{\i1}mereka...{\i0}
Dialogue: 0,0:05:50.20,0:05:52.87,Default,,0,0,0,,{\i1}...dididik untuk patuh\Nperintah secara mutlak{\i0}
Dialogue: 0,0:05:53.21,0:05:56.46,Default,,0,0,0,,{\i1}terhadap atasan yang\Nmemiliki kewenangan komando.{\i0}
Dialogue: 0,0:05:58.71,0:06:03.88,Default,,0,0,0,,Dengar! Apa kalian tahu\Nbahwa air pun bisa membusuk?
Dialogue: 0,0:06:04.93,0:06:07.10,Default,,0,0,0,,Air yang lupa untuk mengalir.
Dialogue: 0,0:06:07.10,0:06:11.56,Default,,0,0,0,,Air yang terus tertahan\Ndi satu tempat akan keruh
Dialogue: 0,0:06:11.89,0:06:14.48,Default,,0,0,0,,dan menjadi sarang bagi hama!
Dialogue: 0,0:06:14.94,0:06:17.86,Default,,0,0,0,,Pun halnya dengan negeri!
Dialogue: 0,0:06:18.40,0:06:22.90,Default,,0,0,0,,Di sisi Baginda yang telah lama\Nmelupakan cara kelola negeri ini,
Dialogue: 0,0:06:22.90,0:06:26.62,Default,,0,0,0,,hinggap para pejabat licik\Ndan pengkhianat,
Dialogue: 0,0:06:26.74,0:06:30.45,Default,,0,0,0,,yang berusaha membusukkan\Nnegeri ini dari dalam!
Dialogue: 0,0:06:30.99,0:06:32.83,Default,,0,0,0,,Keadilan berada di pihakku!
Dialogue: 0,0:06:33.33,0:06:38.46,Default,,0,0,0,,Mari rebut kembali negeri tercinta ini\Ndan kembalikan ke tangan yang seharusnya!
Dialogue: 0,0:06:38.63,0:06:47.93,Default,,0,0,0,,Ya!
Dialogue: 0,0:06:47.93,0:06:49.89,Default,,0,0,0,,Mohon tunggu sebentar, Kanda!
Dialogue: 0,0:06:49.89,0:06:50.72,Default,,0,0,0,,Hm?
Dialogue: 0,0:06:51.68,0:06:52.89,Default,,0,0,0,,Noah, ya?
Dialogue: 0,0:06:53.31,0:06:56.35,Default,,0,0,0,,Ada apa, datang selarut ini?
Dialogue: 0,0:06:56.35,0:06:58.52,Default,,0,0,0,,Hentikanlah tindakan gila ini!
Dialogue: 0,0:06:58.94,0:07:00.69,Default,,0,0,0,,Kalau sekarang, Kanda masih sempat!
Dialogue: 0,0:07:02.48,0:07:03.99,Default,,0,0,0,,Kau tahu dari siapa?
Dialogue: 0,0:07:04.32,0:07:06.61,Default,,0,0,0,,Itu hal sepele!
Dialogue: 0,0:07:06.74,0:07:11.29,Default,,0,0,0,,Kanda akan binasa\Njika melangkah lebih jauh!
Dialogue: 0,0:07:11.45,0:07:13.00,Default,,0,0,0,,Lantas kenapa?
Dialogue: 0,0:07:13.00,0:07:16.54,Default,,0,0,0,,Aku takkan diam saja\Nmenunggu kematian!
Dialogue: 0,0:07:16.87,0:07:18.25,Default,,0,0,0,,Mati?
Dialogue: 0,0:07:19.13,0:07:23.34,Default,,0,0,0,,Apa Kanda belum membaca titah\Nberisikan pencabutan hak waris itu?
Dialogue: 0,0:07:24.21,0:07:28.76,Default,,0,0,0,,Tidakkah Kanda memahami derita tersirat\NYang Mulia dari tulisan itu?
Dialogue: 0,0:07:29.93,0:07:34.31,Default,,0,0,0,,Apa pun perbuatan Kanda,\NYang Mulia tidak mengumumkannya.
Dialogue: 0,0:07:39.27,0:07:42.48,Default,,0,0,0,,Sampai saat ini, Yang Mulia masih\Ningin menolong nyawa Kanda.
Dialogue: 0,0:07:42.48,0:07:45.19,Default,,0,0,0,,Beliau berharap ada cara\Nsupaya Kanda tetap hidup...
Dialogue: 0,0:07:45.19,0:07:47.74,Default,,0,0,0,,Dia mau aku puas menjadi Pangeran?
Dialogue: 0,0:07:49.41,0:07:53.12,Default,,0,0,0,,35 tahun...\NAku sudah menunggu 35 tahun!
Dialogue: 0,0:07:53.79,0:07:57.08,Default,,0,0,0,,Hingga kelak aku akan\Nmenduduki takhta itu!
Dialogue: 0,0:07:57.62,0:08:00.42,Default,,0,0,0,,Dan aku akan memerintah negeri ini!
Dialogue: 0,0:08:01.17,0:08:03.34,Default,,0,0,0,,Lalu, inikah balasan yang kuterima?
Dialogue: 0,0:08:04.59,0:08:09.72,Default,,0,0,0,,Yang Mulia juga sudah lanjut usia.\NPastilah nyawanya terasa semakin berharga.
Dialogue: 0,0:08:09.72,0:08:13.14,Default,,0,0,0,,Jika beliau ingin mempertahankan\Ntakhta dengan cara yang hina,
Dialogue: 0,0:08:13.14,0:08:14.97,Default,,0,0,0,,maka selayaknya negeri para pejuang,
Dialogue: 0,0:08:15.18,0:08:18.35,Default,,0,0,0,,satu-satunya jalan adalah\Nmenurunkan beliau dengan senjata.
Dialogue: 0,0:08:18.85,0:08:21.61,Default,,0,0,0,,{\i1}"Puas dengan kedudukan pangeran."{\i0}
Dialogue: 0,0:08:22.58,0:08:25.52,Default,,0,0,0,,{\i1}Kedudukan pangeran itu\Ndari sudut pandang rakyat jelata...{\i0}
Dialogue: 0,0:08:25.82,0:08:29.32,Default,,0,0,0,,{\i1}bahkan dari sudut pandangku,\Nitu kedudukan yang sangat mulia.{\i0}
Dialogue: 0,0:08:30.78,0:08:32.87,Default,,0,0,0,,{\i1}Melakukan kewajiban yang seharusnya.{\i0}
Dialogue: 0,0:08:33.58,0:08:37.16,Default,,0,0,0,,{\i1}Juga bisa mengerahkan kekuatan\Nuntuk orang lain dan rakyat.{\i0}
Dialogue: 0,0:08:37.54,0:08:39.21,Default,,0,0,0,,{\i1}Kelahiran yang diberkati.{\i0}
Dialogue: 0,0:08:40.50,0:08:43.54,Default,,0,0,0,,{\i1}Namun, bagi Albert\Nyang merupakan Putra Mahkota,{\i0}
Dialogue: 0,0:08:43.54,0:08:46.42,Default,,0,0,0,,{\i1}diturunkan dari kedudukan tersebut itu...{\i0}
Dialogue: 0,0:08:46.42,0:08:47.80,Default,,0,0,0,,{\i1}...sama dengan kematian.{\i0}
Dialogue: 0,0:08:48.13,0:08:50.46,Default,,0,0,0,,Perbedaan cara pandang ini...
Dialogue: 0,0:08:52.30,0:08:54.64,Default,,0,0,0,,Kau bersikeras ingin menghentikanku?
Dialogue: 0,0:08:54.64,0:08:55.47,Default,,0,0,0,,Ya.
Dialogue: 0,0:08:56.93,0:08:58.14,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:08:58.93,0:09:02.19,Default,,0,0,0,,Kau memang adik yang seperti itu.
Dialogue: 0,0:09:06.73,0:09:08.24,Default,,0,0,0,,Tangkap Noah!
Dialogue: 0,0:09:08.53,0:09:10.28,Default,,0,0,0,,Orang itu pengkhianat!
Dialogue: 0,0:09:12.70,0:09:13.82,Default,,0,0,0,,{\i1}Lawanku seribu orang.{\i0}
Dialogue: 0,0:09:23.00,0:09:26.88,Default,,0,0,0,,{\i1}Meski lawannya Pangeran,\Nmereka tetap patuh perintah.{\i0}
Dialogue: 0,0:09:27.05,0:09:29.21,Default,,0,0,0,,{\i1}Sudah kuduga, mereka sangat terlatih.{\i0}
Dialogue: 0,0:09:29.76,0:09:32.63,Default,,0,0,0,,{\i1}Justru karena itu,\Naku tak boleh melibatkan mereka!{\i0}
Dialogue: 0,0:09:38.93,0:09:39.85,Default,,0,0,0,,Maju!
Dialogue: 0,0:09:41.89,0:09:43.27,Default,,0,0,0,,Wahai tuanku.
Dialogue: 0,0:09:44.06,0:09:45.23,Default,,0,0,0,,Sebutlah!
Dialogue: 0,0:09:45.69,0:09:50.07,Default,,0,0,0,,Sebutlah nama sejati\Ndari kekuatan yang kau damba!
Dialogue: 0,0:09:50.65,0:09:53.16,Default,,0,0,0,,{\i1}Yang kudambakan...{\i0}
Dialogue: 0,0:09:57.41,0:09:59.20,Default,,0,0,0,,Serang, Lutiya!
Dialogue: 0,0:09:59.49,0:10:00.04,Default,,0,0,0,,Tidak...
Dialogue: 0,0:10:03.08,0:10:04.33,Default,,0,0,0,,Behemoth!
Dialogue: 0,0:10:14.97,0:10:16.76,Default,,0,0,0,,Arus air...
Dialogue: 0,0:10:17.14,0:10:19.60,Default,,0,0,0,,...tidak membiarkan noda mendekat.
Dialogue: 0,0:10:21.18,0:10:22.85,Default,,0,0,0,,Embusan angin...
Dialogue: 0,0:10:23.19,0:10:26.27,Default,,0,0,0,,...menjadi mata maha melihat,\Ndan telinga maha mendengar.
Dialogue: 0,0:10:28.15,0:10:32.86,Default,,0,0,0,,Tanah berperan sebagai pijakan\Nyang menopang kaki melangkah maju.
Dialogue: 0,0:10:33.90,0:10:35.82,Default,,0,0,0,,Lalu, api...
Dialogue: 0,0:10:41.12,0:10:45.92,Default,,0,0,0,,...sebagai kekuatan penghangus segalanya,\Nakan menampakkan diri di sini!
Dialogue: 0,0:10:50.21,0:10:52.71,Default,,0,0,0,,Apa-apaan itu...
Dialogue: 0,0:11:06.52,0:11:07.65,Default,,0,0,0,,Sudah cukup.
Dialogue: 0,0:11:08.11,0:11:09.40,Default,,0,0,0,,Jangan bunuh mereka.
Dialogue: 0,0:11:29.71,0:11:31.96,Default,,0,0,0,,Tamat sudah, Kanda.
Dialogue: 0,0:11:33.26,0:11:35.01,Default,,0,0,0,,Kau akan membunuhku?
Dialogue: 0,0:11:35.01,0:11:36.97,Default,,0,0,0,,Kau... Kau?
Dialogue: 0,0:11:37.43,0:11:41.72,Default,,0,0,0,,Tidak. Saya takkan\Nmerenggut nyawa Kanda.
Dialogue: 0,0:11:42.39,0:11:44.35,Default,,0,0,0,,Kalau sesama putranya saling bunuh,
Dialogue: 0,0:11:44.98,0:11:47.52,Default,,0,0,0,,Yang Mulia pasti akan bersedih.
Dialogue: 0,0:11:48.10,0:11:49.15,Default,,0,0,0,,Maka dari itu...
Dialogue: 0,0:11:49.35,0:11:50.98,Default,,0,0,0,,Racun...?
Dialogue: 0,0:11:51.15,0:11:52.40,Default,,0,0,0,,Benar sekali.
Dialogue: 0,0:11:52.57,0:11:56.19,Default,,0,0,0,,Saya takkan menyakiti Kanda.
Dialogue: 0,0:11:56.87,0:11:59.87,Default,,0,0,0,,Tapi saya juga takkan menghentikan\NKanda yang ingin bunuh diri.
Dialogue: 0,0:12:00.99,0:12:03.62,Default,,0,0,0,,Jangan bercanda! Pikirmu kau siapa?
Dialogue: 0,0:12:04.08,0:12:05.33,Default,,0,0,0,,Dengarkan.
Dialogue: 0,0:12:06.58,0:12:09.50,Default,,0,0,0,,Kalau saya membunuh Kanda,
Dialogue: 0,0:12:09.88,0:12:11.71,Default,,0,0,0,,maka Kanda beserta keluarga\Ndan bawahan
Dialogue: 0,0:12:12.00,0:12:14.92,Default,,0,0,0,,akan kehilangan nyawa\Nsebagai pemberontak.
Dialogue: 0,0:12:15.21,0:12:19.63,Default,,0,0,0,,Namun sekarang masih dapat\Nditutup dengan narasi,
Dialogue: 0,0:12:19.63,0:12:22.60,Default,,0,0,0,,"Pemberontak yang mengerahkan pasukan,
Dialogue: 0,0:12:22.60,0:12:25.39,Default,,0,0,0,,di detik akhir urung\Ndan mengakhiri hidupnya."
Dialogue: 0,0:12:26.81,0:12:30.56,Default,,0,0,0,,Situasi ini tidak bisa dianggap\Ntak pernah terjadi.
Dialogue: 0,0:12:31.06,0:12:34.73,Default,,0,0,0,,Namun setidaknya keluarga dan\Npara bawahan Kanda tak perlu terseret,
Dialogue: 0,0:12:35.19,0:12:38.53,Default,,0,0,0,,dan putra sulung Kanda masih\Ndapat mewarisi status keluarga.
Dialogue: 0,0:12:39.24,0:12:40.36,Default,,0,0,0,,Ini semua...
Dialogue: 0,0:12:40.91,0:12:42.70,Default,,0,0,0,,tergantung keputusan Kanda.
Dialogue: 0,0:12:43.37,0:12:45.74,Default,,0,0,0,,Siapa yang sudi\Nmenuruti omong kosong itu?
Dialogue: 0,0:12:46.20,0:12:47.95,Default,,0,0,0,,Foster! Howard!
Dialogue: 0,0:12:48.50,0:12:49.75,Default,,0,0,0,,Tangkap dia!
Dialogue: 0,0:12:50.58,0:12:51.58,Default,,0,0,0,,Ya.
Dialogue: 0,0:12:56.55,0:12:57.92,Default,,0,0,0,,Masih belum.
Dialogue: 0,0:12:57.92,0:13:02.43,Default,,0,0,0,,Kalau sudah begini,\Nakan kubunuh tua bangka itu...
Dialogue: 0,0:13:05.39,0:13:07.18,Default,,0,0,0,,A-Apa yang kalian lakukan?
Dialogue: 0,0:13:07.18,0:13:10.35,Default,,0,0,0,,Kami sudah tak bisa mengikuti Anda.
Dialogue: 0,0:13:10.35,0:13:13.15,Default,,0,0,0,,Bahkan dalam situasi seperti ini pun,
Dialogue: 0,0:13:13.15,0:13:16.44,Default,,0,0,0,,Tuan Noah masih memikirkan\Nkeluarga dan bawahan Anda.
Dialogue: 0,0:13:16.86,0:13:18.53,Default,,0,0,0,,Namun Anda sendiri bagaimana?
Dialogue: 0,0:13:18.53,0:13:20.07,Default,,0,0,0,,Kau sudah sinting?
Dialogue: 0,0:13:20.07,0:13:23.03,Default,,0,0,0,,Sudah kubilang, jangan dengarkan\Nomong kosongnya itu!
Dialogue: 0,0:13:23.03,0:13:23.91,Default,,0,0,0,,Diam!
Dialogue: 0,0:13:24.62,0:13:25.66,Default,,0,0,0,,Anda...
Dialogue: 0,0:13:26.58,0:13:30.29,Default,,0,0,0,,Saat dulu kau melepaskan\Nsegelnya Leviathan.
Dialogue: 0,0:13:30.29,0:13:34.67,Default,,0,0,0,,Ingatkah kau 120 orang yang tertumbal\Nkarena paparan miasma itu?
Dialogue: 0,0:13:41.68,0:13:42.88,Default,,0,0,0,,{\i1}Yang waktu itu...{\i0}
Dialogue: 0,0:13:43.05,0:13:45.89,Default,,0,0,0,,Di antaranya, ada abangku!
Dialogue: 0,0:13:46.14,0:13:47.64,Default,,0,0,0,,Ada juga teman masa kecilku.
Dialogue: 0,0:13:48.35,0:13:50.39,Default,,0,0,0,,Ayahku juga ada di sana.
Dialogue: 0,0:13:50.56,0:13:53.19,Default,,0,0,0,,Aku tak lagi bisa mengikutimu!
Dialogue: 0,0:13:53.52,0:13:54.94,Default,,0,0,0,,Mana mungkin bisa!
Dialogue: 0,0:13:54.94,0:13:58.53,Default,,0,0,0,,Omong kosong!\NAku ini Putra Mahkota!
Dialogue: 0,0:13:58.53,0:14:00.36,Default,,0,0,0,,Nyawa kalian adalah milikku...
Dialogue: 0,0:14:01.11,0:14:02.15,Default,,0,0,0,,Tuan Noah.
Dialogue: 0,0:14:02.57,0:14:05.16,Default,,0,0,0,,Yang Mulia Putra Mahkota\Nmenyesali dosa itu
Dialogue: 0,0:14:05.16,0:14:07.24,Default,,0,0,0,,dan memilih mengakhiri hidupnya.
Dialogue: 0,0:14:07.24,0:14:08.41,Default,,0,0,0,,Apa?
Dialogue: 0,0:14:08.41,0:14:09.62,Default,,0,0,0,,Baiklah.
Dialogue: 0,0:14:10.50,0:14:11.33,Default,,0,0,0,,Olivia!
Dialogue: 0,0:14:11.91,0:14:12.83,Default,,0,0,0,,Ya.
Dialogue: 0,0:14:23.01,0:14:24.80,Default,,0,0,0,,Terima kasih banyak.
Dialogue: 0,0:14:30.81,0:14:32.85,Default,,0,0,0,,Jangan bercanda!
Dialogue: 0,0:14:33.23,0:14:36.69,Default,,0,0,0,,Kau sudah melupakan\Njasaku yang memungutmu?
Dialogue: 0,0:14:40.23,0:14:41.86,Default,,0,0,0,,Argh...
Dialogue: 0,0:14:50.29,0:14:53.20,Default,,0,0,0,,Sialan! Kalian semua...
Dialogue: 0,0:14:53.20,0:14:58.00,Default,,0,0,0,,Kalian pikir... aku ini siapa...
Dialogue: 0,0:15:05.93,0:15:07.64,Default,,0,0,0,,{\i1}35 tahun.{\i0}
Dialogue: 0,0:15:07.97,0:15:10.14,Default,,0,0,0,,{\i1}Aku sudah menunggu 35 tahun.{\i0}
Dialogue: 0,0:15:10.76,0:15:13.52,Default,,0,0,0,,{\i1}Hingga kelak aku akan\Nmenduduki takhta itu!{\i0}
Dialogue: 0,0:15:13.93,0:15:16.48,Default,,0,0,0,,{\i1}Dan aku akan memerintah negeri ini!{\i0}
Dialogue: 0,0:15:27.16,0:15:28.37,Default,,0,0,0,,Kanda...
Dialogue: 0,0:15:30.74,0:15:31.74,Default,,0,0,0,,Tuan Noah.
Dialogue: 0,0:15:35.50,0:15:37.37,Default,,0,0,0,,Sungguh sangat disayangkan.
Dialogue: 0,0:15:37.67,0:15:41.42,Default,,0,0,0,,Tuan Albert yang kami layani,\Nsudah mengakhiri hidupnya.
Dialogue: 0,0:15:41.84,0:15:44.88,Default,,0,0,0,,Beliau memang sempat mengerahkan\Npasukan karena dikuasai ambisi.
Dialogue: 0,0:15:44.88,0:15:49.05,Default,,0,0,0,,Namun saat menyadari dosa besarnya itu,\Ndia pun sangat menyesal
Dialogue: 0,0:15:49.55,0:15:52.85,Default,,0,0,0,,dan memohon belas kasih\Nuntuk keluarga yang ditinggalkannya.
Dialogue: 0,0:15:53.18,0:15:54.10,Default,,0,0,0,,Ya.
Dialogue: 0,0:15:54.39,0:15:59.65,Default,,0,0,0,,Kanda memang ingin melakukan kudeta,\Ntapi berkat laporan rahasia dari abdinya,
Dialogue: 0,0:16:00.65,0:16:03.27,Default,,0,0,0,,serta tindakan pengikutnya\Nyang bertaruh nyawa,
Dialogue: 0,0:16:03.98,0:16:06.07,Default,,0,0,0,,Kanda urung usai pasukan dikerahkan.
Dialogue: 0,0:16:06.95,0:16:11.66,Default,,0,0,0,,{\an8}Maka, menurut hukum kekaisaran,\Npelapor dan pengikut diberi imbalan.
Dialogue: 0,0:16:12.20,0:16:14.49,Default,,0,0,0,,{\an8}Para abdi lainnya\Ntak diminta pertanggungjawaban.
Dialogue: 0,0:16:15.33,0:16:17.78,Default,,0,0,0,,{\an8}Aku juga akan memohon\NYang Mulia agar putra sulungnya
Dialogue: 0,0:16:17.78,0:16:19.42,Default,,0,0,0,,{\an8}dapat mewarisinya.
Dialogue: 0,0:16:20.00,0:16:21.67,Default,,0,0,0,,{\an8}Kami sungguh berterima kasih!
Dialogue: 0,0:16:22.46,0:16:31.93,tanda,,0,0,0,,{\an7}NAMA: NOAH ARARAT, PANGERAN KE-13 DARI KEKAISARAN\N JENIS KELAMIN: LAKI-LAKI\NGELAR: MENTERI HUKUM\NLEVEL: 3/∞\NHP: E+E - API: F+A\NMP: F+E - AIR: E+S\NKEKUATAN: E+E - ANGIN: F+F\NSTAMINA: F+E - TANAH: F+F\NKECERDASAN: F+E - CAHAYA: F+C\NMENTAL: F+E - KEGELAPAN: F+F\NKECEPATAN: F+E\NKETANGKASAN: F+E\NKEBERUNTUNGAN: F+E
Dialogue: 0,0:16:23.21,0:16:25.76,Default,,0,0,0,,{\i1}Kemampuan dasarku meningkat drastis.{\i0}
Dialogue: 0,0:16:26.09,0:16:28.13,Default,,0,0,0,,{\i1}Keduanya petarung tangguh.{\i0}
Dialogue: 0,0:16:28.84,0:16:31.93,Default,,0,0,0,,{\i1}Albert sampai dicampakkan\Noleh bawahan sehebat mereka?{\i0}
Dialogue: 0,0:16:32.85,0:16:35.64,Default,,0,0,0,,Memang, manusia adalah harta.
Dialogue: 0,0:16:36.85,0:16:39.44,Default,,0,0,0,,{\i1}Selagi dia mengabaikan hal itu,{\i0}
Dialogue: 0,0:16:39.98,0:16:42.86,Default,,0,0,0,,{\i1}kudetanya takkan berhasil.{\i0}
Dialogue: 0,0:16:53.12,0:16:55.24,Default,,0,0,0,,Ternyata Yang Mulia berada di sini, ya.
Dialogue: 0,0:16:58.33,0:16:59.75,Default,,0,0,0,,Baru saja,
Dialogue: 0,0:17:00.71,0:17:02.88,Default,,0,0,0,,peti ini bereaksi.
Dialogue: 0,0:17:03.50,0:17:07.21,Default,,0,0,0,,Barangkali pedang iblis Noah\Nmulai bangkit.
Dialogue: 0,0:17:07.55,0:17:10.93,Default,,0,0,0,,Dengan bakat Tuan Noah,\Nhal itu mungkin terjadi.
Dialogue: 0,0:17:16.18,0:17:18.39,Default,,0,0,0,,Jadi, bagaimana?
Dialogue: 0,0:17:19.31,0:17:21.90,Default,,0,0,0,,Tuan Noah yang memperoleh informasi
Dialogue: 0,0:17:21.90,0:17:25.23,Default,,0,0,0,,bersamaan dengan kita,\Nsegera menuju lokasi.
Dialogue: 0,0:17:25.57,0:17:27.69,Default,,0,0,0,,Lalu Yang Mulia Putra Mahkota
Dialogue: 0,0:17:28.40,0:17:33.74,Default,,0,0,0,,dikabarkan sudah mengakhiri\Nhidupnya dengan menenggak racun.
Dialogue: 0,0:17:34.12,0:17:35.66,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:17:40.21,0:17:43.17,Default,,0,0,0,,Biarkan aku menyendiri sejenak.
Dialogue: 0,0:17:50.42,0:17:55.76,Default,,0,0,0,,Noah, di saat seperti ini pun,\Nkau tetaplah hebat.
Dialogue: 0,0:17:57.51,0:17:58.68,Default,,0,0,0,,{\i1}Dengan begitu,{\i0}
Dialogue: 0,0:17:59.43,0:18:01.14,Default,,0,0,0,,{\i1}Gilbert Ararat.{\i0}
Dialogue: 0,0:18:03.10,0:18:04.81,Default,,0,0,0,,{\i1}Albert Ararat.{\i0}
Dialogue: 0,0:18:05.44,0:18:09.98,Default,,0,0,0,,{\i1}Kedua pangeran yang berusaha membunuh\NKaisar untuk merebut takhta itu{\i0}
Dialogue: 0,0:18:09.98,0:18:12.45,Default,,0,0,0,,{\i1}telah lenyap dari dunia ini.{\i0}
Dialogue: 0,0:18:14.32,0:18:15.57,Default,,0,0,0,,{\i1}Sebagai hasilnya,{\i0}
Dialogue: 0,0:18:16.83,0:18:22.96,Default,,0,0,0,,{\i1}Kekaisaran Meeres memasuki era baru\Npemerintahan yang berbeda dari sebelumnya.{\i0}
Dialogue: 0,0:18:25.00,0:18:28.29,Default,,0,0,0,,Hebat! Sangat hebat!
Dialogue: 0,0:18:28.29,0:18:32.76,Default,,0,0,0,,Pangeran itu usianya\Nsepantaran Ayunda, kan?
Dialogue: 0,0:18:32.76,0:18:35.51,Default,,0,0,0,,Tetap saja... hebat sekali!
Dialogue: 0,0:18:36.64,0:18:39.64,Default,,0,0,0,,Kelanjutannya?\NApa yang terjadi setelahnya?
Dialogue: 0,0:18:42.98,0:18:44.60,Default,,0,0,0,,Aku masih belum tahu.
Dialogue: 0,0:18:44.81,0:18:45.44,Default,,0,0,0,,Eh?
Dialogue: 0,0:18:45.85,0:18:48.44,Default,,0,0,0,,Karena cerita ini...
Dialogue: 0,0:18:50.98,0:18:54.99,tanda,,0,0,0,,{\an2}3 TAHUN KEMUDIAN
Dialogue: 0,0:18:56.61,0:19:00.66,tanda,,0,0,0,,{\an2}NISIL, IBU KOTA ALMERIA
Dialogue: 0,0:19:05.17,0:19:06.00,Default,,0,0,0,,Ah!
Dialogue: 0,0:19:06.42,0:19:08.42,Default,,0,0,0,,Lihat ini, Kepala Pelayan!
Dialogue: 0,0:19:08.88,0:19:11.38,Default,,0,0,0,,Ini dari Evelyn!
Dialogue: 0,0:19:11.38,0:19:13.50,Default,,0,0,0,,Wah, benar.
Dialogue: 0,0:19:13.50,0:19:15.47,Default,,0,0,0,,Mari kita baca baik-baik nanti.
Dialogue: 0,0:19:15.47,0:19:17.05,Default,,0,0,0,,Kita harus cekatan
Dialogue: 0,0:19:17.05,0:19:19.10,Default,,0,0,0,,- supaya ini selesai.\N- Ini lebih menakjubkan dari biasanya.
Dialogue: 0,0:19:19.10,0:19:20.74,Default,,0,0,0,,- Masih ada lagi?\N- Soal popularitas Tuan Noah?
Dialogue: 0,0:19:20.74,0:19:23.06,Default,,0,0,0,,{\an8}- Tapi jumlahnya ini agak sulit.\N- Benar.
Dialogue: 0,0:19:21.14,0:19:23.06,Default,,0,0,0,,Ucapan selamat ulang tahun ke-15,
Dialogue: 0,0:19:23.06,0:19:27.10,Default,,0,0,0,,serta ucapan karena sudah resmi memasuki\Nwilayah Almeria sebagai penguasa
Dialogue: 0,0:19:27.10,0:19:29.06,Default,,0,0,0,,datangnya bersamaan.
Dialogue: 0,0:19:29.06,0:19:30.90,Default,,0,0,0,,Masih kurang isi dua ruangan lagi.
Dialogue: 0,0:19:30.90,0:19:34.49,Default,,0,0,0,,Wah... tiap tahun\Nmakin bertambah saja, ya.
Dialogue: 0,0:19:34.49,0:19:36.45,Default,,0,0,0,,Soalnya ini Tuan Noah.
Dialogue: 0,0:19:37.82,0:19:38.87,Default,,0,0,0,,Pasti,
Dialogue: 0,0:19:39.32,0:19:42.33,Default,,0,0,0,,ada banyak orang\Nyang terselamatkan oleh Tuan Noah,
Dialogue: 0,0:19:45.37,0:19:49.71,Default,,0,0,0,,serta ingin menjadi\Nkekuatan untuk beliau.
Dialogue: 0,0:19:52.84,0:19:56.97,Default,,0,0,0,,- Tuan kita memang hebat, ya.\N- Ya, benar sekali.
Dialogue: 0,0:19:57.51,0:19:58.59,Default,,0,0,0,,Eh?
Dialogue: 0,0:19:58.80,0:20:01.10,Default,,0,0,0,,Kalau begitu, tolong bantu sisanya.
Dialogue: 0,0:20:01.30,0:20:02.14,Default,,0,0,0,,Ya!
Dialogue: 0,0:20:14.98,0:20:17.45,Default,,0,0,0,,Anda tampak menakjubkan juga hari ini.
Dialogue: 0,0:20:17.45,0:20:18.70,Default,,0,0,0,,Audrey.
Dialogue: 0,0:20:19.11,0:20:21.28,Default,,0,0,0,,Bagaimana dengan sarapan Anda?
Dialogue: 0,0:20:21.57,0:20:22.74,Default,,0,0,0,,Aku akan makan di sini.
Dialogue: 0,0:20:23.16,0:20:24.37,Default,,0,0,0,,Dimengerti.
Dialogue: 0,0:20:24.87,0:20:25.83,Default,,0,0,0,,Zoey.
Dialogue: 0,0:20:26.20,0:20:27.50,Default,,0,0,0,,Saya mengerti.
Dialogue: 0,0:20:35.88,0:20:37.88,Default,,0,0,0,,- Silakan.\N- Ya.
Dialogue: 0,0:20:38.63,0:20:40.01,Default,,0,0,0,,Sudah saatnya, ya.
Dialogue: 0,0:20:40.43,0:20:41.34,Default,,0,0,0,,Ya.
Dialogue: 0,0:20:41.93,0:20:45.47,Default,,0,0,0,,Ulang tahun ke-15.\NHari upacara penghapusan nama.
Dialogue: 0,0:20:45.47,0:20:47.77,Default,,0,0,0,,Saya sudah menanti-nantikan hari ini.
Dialogue: 0,0:20:48.27,0:20:50.60,Default,,0,0,0,,Nama keluargamu akan hilang.
Dialogue: 0,0:20:51.10,0:20:53.11,Default,,0,0,0,,Itu membuat saya senang.
Dialogue: 0,0:20:53.27,0:20:54.52,Default,,0,0,0,,Akhirnya.
Dialogue: 0,0:20:54.52,0:20:59.07,Default,,0,0,0,,Akhirnya saya bisa menjadi\Nistri Tuan Noah secara sah.
Dialogue: 0,0:20:59.40,0:21:00.99,Default,,0,0,0,,Jangan membebani dirimu.
Dialogue: 0,0:21:01.41,0:21:05.62,Default,,0,0,0,,Karena bagiku, siapa pun yang telah\Nmelangkah masuk ambang rumahku,
Dialogue: 0,0:21:06.04,0:21:08.75,Default,,0,0,0,,takkan kuserahkan pada siapa pun.
Dialogue: 0,0:21:09.25,0:21:10.16,Default,,0,0,0,,Ya.
Dialogue: 0,0:21:11.83,0:21:14.38,Default,,0,0,0,,Kalau menurut penjelasan Kaisar,
Dialogue: 0,0:21:14.59,0:21:17.59,Default,,0,0,0,,penerusnya itu salah satu\Ndari mereka bertiga.
Dialogue: 0,0:21:19.38,0:21:22.72,Default,,0,0,0,,Pangeran Keempat, Henry.
Dialogue: 0,0:21:25.72,0:21:28.81,Default,,0,0,0,,Pangeran Kedelapan, Oscar.
Dialogue: 0,0:21:31.94,0:21:35.23,Default,,0,0,0,,Namun, kandidat terkuatnya adalah dia.
Dialogue: 0,0:21:35.82,0:21:37.28,Default,,0,0,0,,Selamat jalan.
Dialogue: 0,0:21:37.73,0:21:39.15,Default,,0,0,0,,Selamat jalan.
Dialogue: 0,0:21:39.15,0:21:40.49,Default,,0,0,0,,Selamat jalan.
Dialogue: 0,0:21:40.74,0:21:42.20,Default,,0,0,0,,Selamat jalan.
