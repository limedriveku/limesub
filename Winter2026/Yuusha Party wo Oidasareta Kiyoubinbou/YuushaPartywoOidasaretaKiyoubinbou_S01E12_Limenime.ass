Dialogue: 0,0:01:20.47,0:01:21.31,tanda,,0000,0000,0000,,SI SERBABISA TERBUANG INI AKAN BANGKIT JUA!)
Dialogue: 0,0:01:21.62,0:01:25.21,tanda,,0000,0000,0000,,SI SERBABISA TERBUANG INI AKAN BANGKIT JUA!)
Dialogue: 0,0:01:26.39,0:01:28.86,tanda,,0000,0000,0000,,SI SERBABISA TERBUANG INI AKAN BANGKIT JUA!)
Dialogue: 0,0:02:41.16,0:02:45.12,tanda,,0000,0000,0000,,EPISODE 12\NSERBABISA YANG MELINDUNGI TEMAN)
Dialogue: 0,0:00:17.26,0:00:20.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan tadi cukup besar, tapi masih\Nbutuh waktu lama untuk mengalahkannya.
Dialogue: 0,0:00:30.56,0:00:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:00:35.03,0:00:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia beregenerasi?!
Dialogue: 0,0:00:36.90,0:00:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ia bisa gunakan metode itu.
Dialogue: 0,0:00:39.47,0:00:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seperti ini...
Dialogue: 0,0:00:40.86,0:00:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong katakan ini bohong.
Dialogue: 0,0:00:43.10,0:00:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia kembali seperti semula.
Dialogue: 0,0:00:50.80,0:00:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat seperti ini...!
Dialogue: 0,0:02:58.19,0:03:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus, Sophie!
Dialogue: 0,0:03:00.42,0:03:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carol bisa menyembuhkan dirinya sendiri.
Dialogue: 0,0:03:02.39,0:03:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:03:03.48,0:03:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:04.70,0:03:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru takkan menyerah\Nwalau terjebak dalam kondisi tanpa harapan.
Dialogue: 0,0:03:09.56,0:03:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia sudah mengajarkan kita
Dialogue: 0,0:03:11.71,0:03:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa hal terpenting untuk jadi penjelajah\Nadalah pulang hidup-hidup?
Dialogue: 0,0:03:15.80,0:03:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita murid Guru!
Dialogue: 0,0:03:18.84,0:03:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar.\NKita harus pulang hidup-hidup!
Dialogue: 0,0:03:22.06,0:03:23.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vitality Up!
Dialogue: 0,0:03:23.66,0:03:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Resist Up, Magic Up!
Dialogue: 0,0:03:32.23,0:03:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thunder Arrow!
Dialogue: 0,0:03:41.03,0:03:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:03:41.99,0:03:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sophie, lari!
Dialogue: 0,0:03:43.36,0:03:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan!
Dialogue: 0,0:03:54.28,0:03:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jebakan yang diajarkan Guru.
Dialogue: 0,0:03:56.12,0:03:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya gerakanmu mudah ditebak.
Dialogue: 0,0:04:09.30,0:04:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Log!
Dialogue: 0,0:04:10.80,0:04:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok jago kau, bocah sialan.
Dialogue: 0,0:04:12.90,0:04:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bertahan hidup,\Nkau mungkin akan bertambah kuat...
Dialogue: 0,0:04:16.45,0:04:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:04:18.75,0:04:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:04:20.10,0:04:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibiarkan saja, Log bisa terbunuh.
Dialogue: 0,0:04:22.70,0:04:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus apa?
Dialogue: 0,0:04:24.70,0:04:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah
Dialogue: 0,0:04:26.03,0:04:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau ingin jadikan kami umpan?
Dialogue: 0,0:04:29.03,0:04:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu orang saja cukup.
Dialogue: 0,0:04:31.36,0:04:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dengar itu?
Dialogue: 0,0:04:33.03,0:04:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal!
Dialogue: 0,0:04:36.55,0:04:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:04:44.56,0:04:45.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:04:45.70,0:04:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku tak bisa bergerak.
Dialogue: 0,0:04:48.90,0:04:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau kenapa?
Dialogue: 0,0:05:01.16,0:05:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham sekarang.
Dialogue: 0,0:05:02.76,0:05:05.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan aneh yang selalu kurasakan...
Dialogue: 0,0:05:06.86,0:05:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kemampuan khususku!
Dialogue: 0,0:05:10.91,0:05:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi sana!
Dialogue: 0,0:05:20.75,0:05:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heal!
Dialogue: 0,0:05:23.03,0:05:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertahanlah.
Dialogue: 0,0:05:25.59,0:05:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:27.06,0:05:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang baru saja terjadi?
Dialogue: 0,0:05:29.10,0:05:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan khususku...
Dialogue: 0,0:05:33.04,0:05:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar...
Dialogue: 0,0:05:34.86,0:05:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah-bocah sialan!
Dialogue: 0,0:05:38.10,0:05:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keparat, jangan harap akan kuberi ampun.
Dialogue: 0,0:05:41.11,0:05:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, apa yang kau lakukan, Giva?
Dialogue: 0,0:05:43.96,0:05:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shion sampai jengkel, lo.\NCepat bunuh mereka.
Dialogue: 0,0:05:47.96,0:05:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak jengkel.
Dialogue: 0,0:05:50.40,0:05:53.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku memang heran\Nkenapa dia begitu kerepotan.
Dialogue: 0,0:05:55.03,0:05:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja, aku akan bunuh mereka sekarang!
Dialogue: 0,0:05:59.00,0:06:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sophie, ayo tembakkan semua sihir\Nyang kita kuasai!
Dialogue: 0,0:06:08.01,0:06:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus lakukan segala cara\Nuntuk bertahan hidup.
Dialogue: 0,0:06:11.40,0:06:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bertemu Kakak dan Kak Orhun\Nsekali lagi!
Dialogue: 0,0:06:27.53,0:06:29.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan jumlah itu?!
Dialogue: 0,0:06:29.60,0:06:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya.
Dialogue: 0,0:06:31.00,0:06:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia juga mulai serius.
Dialogue: 0,0:06:35.03,0:06:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang belum selesai,
Dialogue: 0,0:06:36.70,0:06:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekarang bukan waktunya menahan diri.
Dialogue: 0,0:06:39.46,0:06:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alteration!
Dialogue: 0,0:06:48.60,0:06:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk Pertama.
Dialogue: 0,0:06:50.63,0:06:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mont Eins!
Dialogue: 0,0:07:01.32,0:07:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Divine
Dialogue: 0,0:07:02.90,0:07:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Flash!
Dialogue: 0,0:07:06.89,0:07:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sihir baru yang Orhun sempat bahas, ya?
Dialogue: 0,0:07:10.40,0:07:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya serangnya benar-benar besar.
Dialogue: 0,0:07:15.12,0:07:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia berhasil?
Dialogue: 0,0:07:22.67,0:07:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:07:23.76,0:07:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi...?
Dialogue: 0,0:07:24.85,0:07:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, tak ada habisnya.
Dialogue: 0,0:07:28.50,0:07:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menghabisinya
Dialogue: 0,0:07:29.97,0:07:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam satu serangan\Nagar ia tak mampu lakukan regenerasi.
Dialogue: 0,0:07:35.89,0:07:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembok Sihir.\NTingkat kekokohan tertinggi!
Dialogue: 0,0:07:47.57,0:07:48.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos!
Dialogue: 0,0:07:59.20,0:08:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk Keempat.
Dialogue: 0,0:08:01.71,0:08:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mont Vier!
Dialogue: 0,0:08:12.10,0:08:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan menyia-nyiakan
Dialogue: 0,0:08:14.10,0:08:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harapan semua orang!
Dialogue: 0,0:08:29.00,0:08:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Orhun.
Dialogue: 0,0:08:33.65,0:08:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bos!\N- Selma!
Dialogue: 0,0:08:44.20,0:08:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabur, Sophie!
Dialogue: 0,0:08:46.07,0:08:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Log!
Dialogue: 0,0:08:47.16,0:08:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph, sungguh remeh.
Dialogue: 0,0:08:49.89,0:08:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin repot saja.
Dialogue: 0,0:08:52.26,0:08:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pemilik kemampuan khusus, ya?
Dialogue: 0,0:08:54.70,0:08:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus segera kuhabisi\Nsebelum jadi masalah lain.
Dialogue: 0,0:08:59.63,0:09:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa...
Dialogue: 0,0:09:00.86,0:09:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku.. tak sanggup lagi.
Dialogue: 0,0:09:04.49,0:09:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat, ya.
Dialogue: 0,0:09:07.20,0:09:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghabisi bibit yang belum\Ntumbuh adalah tugas kita.
Dialogue: 0,0:09:10.50,0:09:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu harus dibunuh.
Dialogue: 0,0:09:12.49,0:09:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat selesaikan.
Dialogue: 0,0:09:15.60,0:09:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:09:17.00,0:09:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau...
Dialogue: 0,0:09:18.23,0:09:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau mati.
Dialogue: 0,0:09:20.30,0:09:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Kak.
Dialogue: 0,0:09:25.08,0:09:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku, Kak Orhun!
Dialogue: 0,0:09:44.85,0:09:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Orhun...?
Dialogue: 0,0:09:47.30,0:09:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:09:56.16,0:09:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah bekerja keras.
Dialogue: 0,0:09:57.86,0:09:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:10:02.00,0:10:03.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Space Leap.
Dialogue: 0,0:10:08.63,0:10:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru...
Dialogue: 0,0:10:10.00,0:10:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:10:12.10,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang urus sisanya.
Dialogue: 0,0:10:18.80,0:10:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, ya.
Dialogue: 0,0:10:20.70,0:10:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuselesaikan dengan cepat.
Dialogue: 0,0:10:22.83,0:10:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang marah, ya?
Dialogue: 0,0:10:24.46,0:10:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku marah.
Dialogue: 0,0:10:26.30,0:10:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik pada kalian, dan diriku sendiri.
Dialogue: 0,0:10:30.16,0:10:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bersumpah akan lindungi mereka...
Dialogue: 0,0:10:32.76,0:10:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kesal karena begitu ceroboh\Nhingga tak bisa mencegah ini terjadi.
Dialogue: 0,0:10:36.65,0:10:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian menyakiti mereka?
Dialogue: 0,0:10:39.10,0:10:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Pembunuh Naga, ya.
Dialogue: 0,0:10:41.56,0:10:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kau memberikan kesan itu.
Dialogue: 0,0:10:43.40,0:10:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawab pertanyaanku!
Dialogue: 0,0:10:45.63,0:10:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mereka memiliki hubungan\Ndengan Pembunuh Naga.
Dialogue: 0,0:10:49.36,0:10:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir, aku bisa manfaatkan mereka\Nuntuk memancingmu muncul.
Dialogue: 0,0:10:53.00,0:10:55.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang ternyata ini\Nbenar-benar berhasil.
Dialogue: 0,0:10:56.10,0:10:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan.
Dialogue: 0,0:10:58.16,0:10:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan harap kalian bisa lolos.
Dialogue: 0,0:11:00.06,0:11:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah, akan kubuat kalian rasakan\Nsiksaan yang lebih buruk dari kematian!
Dialogue: 0,0:11:04.68,0:11:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik.
Dialogue: 0,0:11:07.06,0:11:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari penggal kepala Pembunuh Naga.
Dialogue: 0,0:11:10.20,0:11:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami, Amunzars,
Dialogue: 0,0:11:12.06,0:11:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah spesialis pertarungan\Nmelawan manusia.
Dialogue: 0,0:11:14.60,0:11:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu, tiga lawan satu.
Dialogue: 0,0:11:16.40,0:11:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil kau bisa menang.
Dialogue: 0,0:11:18.70,0:11:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin?
Dialogue: 0,0:11:23.76,0:11:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, menjauh!
Dialogue: 0,0:11:25.40,0:11:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat!
Dialogue: 0,0:11:26.09,0:11:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Weight Up!
Dialogue: 0,0:11:31.22,0:11:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhku tiba-tiba berat...
Dialogue: 0,0:11:33.16,0:11:34.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bergerak.
Dialogue: 0,0:11:35.06,0:11:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Earth Shock!
Dialogue: 0,0:11:54.10,0:11:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh mungil itu bisa menahan serangan ini?
Dialogue: 0,0:11:57.36,0:12:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di luar dugaan, kau bisa mengalahkan\Nmereka bertiga dengan mudah.
Dialogue: 0,0:12:01.80,0:12:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh sayang bila harus dibunuh.
Dialogue: 0,0:12:05.20,0:12:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blizzard?
Dialogue: 0,0:12:06.40,0:12:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mengaktifkan sihir\Ntingkat khusus secepat ini?!
Dialogue: 0,0:12:17.23,0:12:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru terdesak.
Dialogue: 0,0:12:20.30,0:12:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:12:21.88,0:12:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Orhun, berjuanglah.
Dialogue: 0,0:12:25.56,0:12:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aneh.
Dialogue: 0,0:12:26.70,0:12:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaktifannya terlalu cepat.
Dialogue: 0,0:12:28.30,0:12:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya dia bisa mengaktifkan sihir\Ntingkat khusus secara beruntun.
Dialogue: 0,0:12:31.39,0:12:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti dia mengabaikan\Nproses pengaktifannya.
Dialogue: 0,0:12:34.74,0:12:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:12:36.90,0:12:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bertahan dari seranganku\Ntanpa terluka.
Dialogue: 0,0:12:40.03,0:12:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hebat juga, Pembunuh Naga.
Dialogue: 0,0:12:43.60,0:12:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga sama.
Dialogue: 0,0:12:44.70,0:12:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanmu terlalu besar\Nuntuk ada di Amunzars.
Dialogue: 0,0:12:48.29,0:12:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga ingin orang\Nsehebat dirimu bergabung.
Dialogue: 0,0:12:53.90,0:12:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sudi membantu pembunuh.
Dialogue: 0,0:12:56.76,0:12:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu mengingatkanku pada kenalan lama.
Dialogue: 0,0:13:00.00,0:13:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mati saat kecil dulu,
Dialogue: 0,0:13:03.03,0:13:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika tumbuh dewasa,\Nmungkin dia akan menjadi orang sepertimu.
Dialogue: 0,0:13:07.86,0:13:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian membunuh penjelajah?
Dialogue: 0,0:13:10.85,0:13:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak ingin membunuh siapa pun.
Dialogue: 0,0:13:14.06,0:13:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi orisinalnya sudah dikalahkan,
Dialogue: 0,0:13:16.30,0:13:18.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan replikanya jatuh ke tangan musuh.
Dialogue: 0,0:13:19.10,0:13:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya harapan kami\Nadalah dengan mengulur waktu.
Dialogue: 0,0:13:23.86,0:13:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau?
Dialogue: 0,0:13:25.80,0:13:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil kalian paham perkataanku.
Dialogue: 0,0:13:28.70,0:13:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak berusaha untuk paham.
Dialogue: 0,0:13:30.83,0:13:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu kata-kata seorang teroris.
Dialogue: 0,0:13:34.00,0:13:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membunuh orang lain tanpa pandang bulu\Nuntuk mengulur waktu?
Dialogue: 0,0:13:37.10,0:13:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika otakmu hanya bisa memikirkan itu,\Nsebaiknya berhenti saja.
Dialogue: 0,0:13:41.43,0:13:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam kau, serangga sok tahu.
Dialogue: 0,0:13:43.26,0:13:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang seperti kalian hanya\Nmempercepat kehancuran dunia ini!
Dialogue: 0,0:13:53.60,0:13:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:14:00.11,0:14:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Explode?!
Dialogue: 0,0:14:01.50,0:14:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa mengaktifkan sihir\Nsebanyak itu dalam sekejap?!
Dialogue: 0,0:14:12.60,0:14:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang menarik, tapi akulah pemenangnya.
Dialogue: 0,0:14:16.60,0:14:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil kau bisa bertahan\Nsetelah menerima Explode sebanyak ini.
Dialogue: 0,0:14:20.50,0:14:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.\NAku lakukan ini untuk menyelamatkan dunia.
Dialogue: 0,0:14:24.46,0:14:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematianmu takkan kusia-siakan...
Dialogue: 0,0:14:32.36,0:14:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengubah pedangnya menjadi perisai?
Dialogue: 0,0:14:37.27,0:14:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:14:38.46,0:14:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentuk Nol.
Dialogue: 0,0:14:39.80,0:14:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mont Null!
Dialogue: 0,0:14:46.26,0:14:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengincar momen kau yakin sudah menang.
Dialogue: 0,0:14:53.03,0:14:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga.
Dialogue: 0,0:14:56.10,0:14:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan kabur!
Dialogue: 0,0:15:05.76,0:15:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi magis ini... Jangan-jangan...
Dialogue: 0,0:15:08.86,0:15:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orhun?
Dialogue: 0,0:15:10.46,0:15:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:15:11.83,0:15:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa gadis itu?
Dialogue: 0,0:15:16.74,0:15:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Apa maksudnya ini?
Dialogue: 0,0:15:19.67,0:15:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, seharusnya aku\Npaham betul jawabannya.
Dialogue: 0,0:15:22.56,0:15:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja ini perbuatan tetua\Ndan nenek sihir sialan itu!
Dialogue: 0,0:15:28.89,0:15:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:15:30.23,0:15:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sampai kapan kalian\Nmempermainkan orang lain?!
Dialogue: 0,0:15:36.35,0:15:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sebenarnya
Dialogue: 0,0:15:38.86,0:15:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau?
Dialogue: 0,0:15:43.50,0:15:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, Orhun.
Dialogue: 0,0:15:45.10,0:15:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak ingin bertarung lagi.
Dialogue: 0,0:15:47.83,0:15:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bertarung melawanmu, Orhun.
Dialogue: 0,0:15:50.46,0:15:52.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau bisa biarkan aku pergi?
Dialogue: 0,0:15:52.40,0:15:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bawa mereka bersamaku.
Dialogue: 0,0:15:55.06,0:15:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba...?
Dialogue: 0,0:15:56.43,0:15:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, kenapa kau tiba-tiba\Nbersikap akrab...?
Dialogue: 0,0:15:58.64,0:16:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mengenalku?
Dialogue: 0,0:16:00.46,0:16:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tak paham!
Dialogue: 0,0:16:02.66,0:16:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan paham, suatu hari nanti...
Dialogue: 0,0:16:06.83,0:16:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Energi magisku habis.
Dialogue: 0,0:16:15.30,0:16:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah pulih.
Dialogue: 0,0:16:17.30,0:16:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka sampai ikut bergabung...
Dialogue: 0,0:16:21.37,0:16:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orhun, kau baik-baik saja?
Dialogue: 0,0:16:23.06,0:16:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Sophia?!
Dialogue: 0,0:16:25.66,0:16:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya mundur.
Dialogue: 0,0:16:27.43,0:16:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan pergi\Ndari labirin besar wilayah selatan.
Dialogue: 0,0:16:30.23,0:16:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini janjiku dan Orhun.
Dialogue: 0,0:16:33.43,0:16:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Selma dan yang lain ikut bertarung,
Dialogue: 0,0:16:36.19,0:16:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami pasti menelan banyak korban.
Dialogue: 0,0:16:38.76,0:16:40.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mereka ingin mundur,
Dialogue: 0,0:16:40.46,0:16:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih baik seperti itu.
Dialogue: 0,0:16:42.56,0:16:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:44.40,0:16:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kita tak perlu saling bunuh\Nsaat bertemu sekali lagi.
Dialogue: 0,0:16:54.78,0:16:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:16:56.70,0:16:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orhun.
Dialogue: 0,0:17:06.76,0:17:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sophia!
Dialogue: 0,0:17:08.23,0:17:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:17:09.75,0:17:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, aku susah bernapas.
Dialogue: 0,0:17:18.70,0:17:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Orhun.
Dialogue: 0,0:17:20.82,0:17:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:17:22.46,0:17:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau lagi-lagi menolongku.
Dialogue: 0,0:17:24.40,0:17:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:17:25.23,0:17:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang harus minta maaf\Nkarena hampir membuat kalian celaka.
Dialogue: 0,0:17:28.15,0:17:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa kau?
Dialogue: 0,0:17:29.90,0:17:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka baik-baik saja berkatmu.
Dialogue: 0,0:17:33.26,0:17:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:17:34.26,0:17:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Guru tidak datang,\Nsenyuman mereka semua akan lenyap.
Dialogue: 0,0:17:38.10,0:17:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:39.83,0:17:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya. Guru.
Dialogue: 0,0:17:41.26,0:17:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan tadi kenalanmu?
Dialogue: 0,0:17:46.16,0:17:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:17:47.31,0:17:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak kenal.
Dialogue: 0,0:17:51.96,0:17:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih hidup! Orhun masih hidup!
Dialogue: 0,0:17:54.48,0:17:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah berapa kali aku memimpikan hari ini,\Nhanya untuk dikecewakan oleh kenyataan.
Dialogue: 0,0:17:59.03,0:18:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia menjadi seorang penjelajah.
Dialogue: 0,0:18:01.60,0:18:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu, bisa jadi musuh atau sekutu.
Dialogue: 0,0:18:04.10,0:18:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemburu dan yang diburu.
Dialogue: 0,0:18:07.26,0:18:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata itu...
Dialogue: 0,0:18:08.56,0:18:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus ditatap\Nseperti itu oleh Orhun?
Dialogue: 0,0:18:12.63,0:18:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:18:14.16,0:18:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halamannya direbut,
Dialogue: 0,0:18:15.80,0:18:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masa lalunya direbut...
Dialogue: 0,0:18:17.20,0:18:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka masih belum\Npuas juga setelah merebut
Dialogue: 0,0:18:19.80,0:18:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}waktu yang seharusnya\Nkami habiskan bersama?!
Dialogue: 0,0:18:22.86,0:18:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan mengampuni perempuan itu.
Dialogue: 0,0:18:26.03,0:18:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memojokkannya\Nsampai ke ujung neraka,
Dialogue: 0,0:18:28.26,0:18:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membuatnya menyesal\Nsudah lahir ke dunia.
Dialogue: 0,0:18:31.66,0:18:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takkan kubiarkan dia mati\Nwalau itu yang dia inginkan.
Dialogue: 0,0:18:34.70,0:18:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tenggelamkan kau dalam\Njurang keputusasaan yang belum kau ketahui!
Dialogue: 0,0:18:40.80,0:18:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang berbeda?
Dialogue: 0,0:18:42.16,0:18:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan dia...
Dialogue: 0,0:18:44.20,0:18:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia bisa sementara aku tidak?
Dialogue: 0,0:18:48.20,0:18:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?!
Dialogue: 0,0:18:50.86,0:18:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat bersemangat, Oliver.
Dialogue: 0,0:18:54.00,0:18:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Filly, ya.
Dialogue: 0,0:18:56.20,0:18:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau berlatih untuk\Nmengalahkan Naga Hitam?
Dialogue: 0,0:18:59.90,0:19:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau... untuk dia?
Dialogue: 0,0:19:02.66,0:19:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berlatih karena aku tak becus.
Dialogue: 0,0:19:05.43,0:19:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalahkan Naga Hitam seorang diri...
Dialogue: 0,0:19:07.86,0:19:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah perbuatan yang\Nbelum pernah dilakukan siapa pun.
Dialogue: 0,0:19:11.30,0:19:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang ramai membicarakan\Nkemunculannya sebagai pahlawan baru.
Dialogue: 0,0:19:16.50,0:19:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:18.43,0:19:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku baru ingat.
Dialogue: 0,0:19:19.50,0:19:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon, dekat-dekat ini\Nada turnamen bela diri.
Dialogue: 0,0:19:23.03,0:19:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kalahkan Orhun\Ndengan kedua tanganku.
Dialogue: 0,0:19:25.60,0:19:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuktikan bahwa akulah pahlawannya!
Dialogue: 0,0:19:29.23,0:19:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oliver memang hebat.
Dialogue: 0,0:19:32.10,0:19:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantikan momen itu.
Dialogue: 0,0:19:35.10,0:19:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orhun mengalahkan Naga Hitam seorang diri...
Dialogue: 0,0:19:38.30,0:19:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:19:39.46,0:19:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu tak mungkin terjadi!
Dialogue: 0,0:19:41.70,0:19:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, itulah kenyataannya.
Dialogue: 0,0:19:44.41,0:19:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, dia berhasil\Ndapatkan kekuatan yang cukup besar
Dialogue: 0,0:19:48.43,0:19:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk kalahkan Naga Hitam, entah bagaimana.
Dialogue: 0,0:19:56.50,0:19:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sinting. Sungguh sinting.
Dialogue: 0,0:19:58.23,0:19:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:20:00.30,0:20:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang takkan sudi\Nmengalahkan apa pun,
Dialogue: 0,0:20:03.46,0:20:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah berhasil membereskan bos lantai dasar
Dialogue: 0,0:20:05.43,0:20:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mampu menyelesaikan labirin besar.
Dialogue: 0,0:20:10.00,0:20:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah.
Dialogue: 0,0:20:12.83,0:20:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh ironis.
Dialogue: 0,0:20:14.86,0:20:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan bekerja untukku.
Dialogue: 0,0:20:21.96,0:20:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nbiarlah kau menjadi penyelamatku!
Dialogue: 0,0:20:25.83,0:20:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orhun Dura!
Dialogue: 0,0:20:27.86,0:20:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, aku akan menganggap seluruh
Dialogue: 0,0:20:30.94,0:20:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kesalahan yang kau perbuat padaku\Ntak pernah terjadi.
Dialogue: 0,0:20:35.90,0:20:37.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarilah, Orhun!
Dialogue: 0,0:20:37.60,0:20:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janganlah terbangun dari mimpi itu,\Nhingga akhir hayat.
Dialogue: 0,0:20:44.16,0:20:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang ini sebaiknya menari\Nhingga gila demi aku!
Dialogue: 0,0:22:23.70,0:22:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyesali kejadian tempo hari.
Dialogue: 0,0:22:26.36,0:22:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pasti tak puas\Nkarena pertarungan hari itu,
Dialogue: 0,0:22:29.70,0:22:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kembali disadarkan\Nbetapa lemahnya kalian.
Dialogue: 0,0:22:32.30,0:22:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga termasuk.
Dialogue: 0,0:22:34.15,0:22:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:22:35.43,0:22:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru datang menyelamatkan kami, 'kan?
Dialogue: 0,0:22:38.70,0:22:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Guru tidak ada, mungkin kami sudah...
Dialogue: 0,0:22:41.66,0:22:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar.
Dialogue: 0,0:22:42.80,0:22:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami masih hidup hari ini berkat Kak Orhun.
Dialogue: 0,0:22:46.76,0:22:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu hasil akhirnya.
Dialogue: 0,0:22:49.23,0:22:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita menang tipis.
Dialogue: 0,0:22:51.03,0:22:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika pertarungan itu terus berlanjut,\Nkita semua bisa mati.
Dialogue: 0,0:22:55.40,0:22:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena melibatkan Selma dan rekan lain\Nyang datang menyusul.
Dialogue: 0,0:22:58.96,0:23:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Kakak juga...?
Dialogue: 0,0:23:01.06,0:23:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekuat itulah orang-orang itu.
Dialogue: 0,0:23:04.40,0:23:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama perempuan itu...
Dialogue: 0,0:23:06.63,0:23:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kembali sadar bahwa\Ndi atas langit masih ada langit.
Dialogue: 0,0:23:10.26,0:23:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus, aku takkan bisa\Nmelindungi hal yang ingin kulindungi.
Dialogue: 0,0:23:14.03,0:23:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bertambah kuat.
Dialogue: 0,0:23:17.16,0:23:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah merasakan kekalahan.
Dialogue: 0,0:23:19.96,0:23:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita semua masih hidup.
Dialogue: 0,0:23:23.23,0:23:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau gagal,\Nkita bisa mencoba lagi dan lagi.
Dialogue: 0,0:23:27.23,0:23:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya kita tak perlu sesali apa pun lagi.
Dialogue: 0,0:23:29.62,0:23:30.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:23:32.70,0:23:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, ayo berangkat!
