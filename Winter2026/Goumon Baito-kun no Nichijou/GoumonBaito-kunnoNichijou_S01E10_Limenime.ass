Dialogue: 0,0:18:05.44,0:18:06.40,tanda,,0000,0000,0000,,PENAWARAN SPESIAL HARI INI!
Dialogue: 0,0:21:09.71,0:21:13.42,tanda,,0000,0000,0000,,KITA CIPTAKAN KANTOR BAHAGIA DAN CERIA,\NHENTIKAN PERUNDUNGAN DI TEMPAT KERJA
Dialogue: 0,0:21:41.82,0:21:43.41,tanda,,0000,0000,0000,,HARI BERIKUTNYA
Dialogue: 0,0:00:01.19,0:00:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegawai Spirytus biasanya\Nmenangani pekerjaan menyiksa.
Dialogue: 0,0:00:07.49,0:00:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi malam ini...
Dialogue: 0,0:00:13.16,0:00:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memilihku.
Dialogue: 0,0:00:16.25,0:00:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berubah menjadi pangeran.
Dialogue: 0,0:01:51.47,0:01:52.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hostes?
Dialogue: 0,0:01:54.47,0:01:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:55.64,0:01:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kelab hostes\Nyang memberiku banyak informasi.
Dialogue: 0,0:01:59.47,0:02:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, semua hostes di sana sakit.
Dialogue: 0,0:02:02.39,0:02:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ingin kita membantu mereka.
Dialogue: 0,0:02:04.65,0:02:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak punya pengalaman.
Dialogue: 0,0:02:07.01,0:02:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mereka akan mengajari kalian.\N- Hostes?
Dialogue: 0,0:02:10.11,0:02:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya NOX.
Dialogue: 0,0:02:13.95,0:02:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kelab tempatku bekerja dulu.
Dialogue: 0,0:02:16.49,0:02:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, syukurlah kalau begitu.
Dialogue: 0,0:02:25.42,0:02:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero, lama tidak bertemu!
Dialogue: 0,0:02:27.42,0:02:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:02:28.75,0:02:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga\Nkamu bekerja di Spirytus sekarang.
Dialogue: 0,0:02:31.80,0:02:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga terkejut.
Dialogue: 0,0:02:34.04,0:02:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menduga\NNOX berhubungan dengan Spirytus.
Dialogue: 0,0:02:36.60,0:02:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rahasia.
Dialogue: 0,0:02:39.26,0:02:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir...
Dialogue: 0,0:02:47.86,0:02:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa sia-sia\Njika kalian hanya jadi penyiksa.
Dialogue: 0,0:02:51.23,0:02:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manajer, air liurmu menetes.
Dialogue: 0,0:02:55.95,0:02:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dilakukan hostes?
Dialogue: 0,0:02:59.39,0:03:00.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengobrol?
Dialogue: 0,0:03:00.73,0:03:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Basa-basi sudah cukup, kan?
Dialogue: 0,0:03:04.16,0:03:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku tidak punya pilihan.
Dialogue: 0,0:03:05.87,0:03:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya,
Dialogue: 0,0:03:07.79,0:03:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus menjadi mentor kalian.
Dialogue: 0,0:03:11.46,0:03:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ser...
Dialogue: 0,0:03:12.05,0:03:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero?
Dialogue: 0,0:03:13.84,0:03:14.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:03:14.92,0:03:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Seromi.
Dialogue: 0,0:03:15.93,0:03:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya nama lain?
Dialogue: 0,0:03:18.01,0:03:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya kalian harus tahu dasar-dasarnya\Nsaat menghadapi pelanggan.
Dialogue: 0,0:03:21.47,0:03:24.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja aku wanita manis.
Dialogue: 0,0:03:24.52,0:03:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlatihlah denganku.
Dialogue: 0,0:03:26.69,0:03:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita manis?
Dialogue: 0,0:03:28.98,0:03:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melakukan ini.
Dialogue: 0,0:03:30.90,0:03:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tetap saja Sero.
Dialogue: 0,0:03:32.53,0:03:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku manis, kan?
Dialogue: 0,0:03:34.40,0:03:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak tahu malu.
Dialogue: 0,0:03:38.87,0:03:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, cepatlah.
Dialogue: 0,0:03:42.08,0:03:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:03:45.66,0:03:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Mike, senang bertemu denganmu.
Dialogue: 0,0:03:49.33,0:03:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kamu manis sekali.
Dialogue: 0,0:03:53.30,0:03:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hugh.
Dialogue: 0,0:03:55.51,0:03:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kamu manis sekali.
Dialogue: 0,0:03:57.72,0:04:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada pujian yang lain?
Dialogue: 0,0:04:01.64,0:04:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Seromi,
Dialogue: 0,0:04:02.68,0:04:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}alat penyiksaan apa yang kamu suka?
Dialogue: 0,0:04:05.56,0:04:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:04:07.27,0:04:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pendapatmu tentang Pasal Enam,\NAyat Tiga UU Penyiksaan?
Dialogue: 0,0:04:10.90,0:04:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih topik yang lebih menarik!
Dialogue: 0,0:04:16.07,0:04:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini topik yang paling menarik.
Dialogue: 0,0:04:19.27,0:04:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, orang-orang bodoh ini\Nhanya tahu soal penyiksaan!
Dialogue: 0,0:04:24.99,0:04:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicarakan penyiksaan\Nuntuk saat ini.
Dialogue: 0,0:04:27.33,0:04:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari fokus ngobrol saja.
Dialogue: 0,0:04:29.58,0:04:31.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:04:33.25,0:04:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tugas hostes itu menyajikan minuman.
Dialogue: 0,0:04:39.68,0:04:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa minuman yang kadar alkoholnya tinggi?
Dialogue: 0,0:04:41.97,0:04:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya bisa lebih cepat mabuk?
Dialogue: 0,0:04:43.93,0:04:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya membuat pelanggan mabuk?
Dialogue: 0,0:04:47.60,0:04:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga!
Dialogue: 0,0:04:48.52,0:04:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua gagal!
Dialogue: 0,0:04:50.39,0:04:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan caranya.
Dialogue: 0,0:04:52.56,0:04:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya dari awal saja.
Dialogue: 0,0:04:56.44,0:04:58.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu manis sekali, Mike.
Dialogue: 0,0:04:59.78,0:05:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengatakannya pada semua orang.
Dialogue: 0,0:05:01.82,0:05:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:04.41,0:05:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:05:05.66,0:05:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu yang paling manis.
Dialogue: 0,0:05:09.87,0:05:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:05:14.13,0:05:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugh, kudengar kamu mahasiswa?
Dialogue: 0,0:05:16.34,0:05:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku suka studi penyiksaan.
Dialogue: 0,0:05:19.19,0:05:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mempelajari hukum penyiksaan.
Dialogue: 0,0:05:21.19,0:05:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berdasarkan hukum saat ini...\N- Luar biasa.
Dialogue: 0,0:05:23.18,0:05:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena membicarakan\Nhal yang membosankan.
Dialogue: 0,0:05:25.60,0:05:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:05:27.12,0:05:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu banyak\Ntentang hal sulit,
Dialogue: 0,0:05:29.56,0:05:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku senang bisa mempelajari
Dialogue: 0,0:05:32.02,0:05:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal yang kamu suka.
Dialogue: 0,0:05:34.81,0:05:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:05:37.40,0:05:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero luar biasa.
Dialogue: 0,0:05:43.99,0:05:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh minta apinya?
Dialogue: 0,0:05:45.93,0:05:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:05:59.76,0:06:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal buruk seperti ini
Dialogue: 0,0:06:01.26,0:06:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus dilakukan dengan wanita cantik.
Dialogue: 0,0:06:06.47,0:06:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membencinya!
Dialogue: 0,0:06:07.81,0:06:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klise dikit tidak apa-apa, kan?
Dialogue: 0,0:06:12.52,0:06:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, saatnya buka!
Dialogue: 0,0:06:14.60,0:06:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik!
Dialogue: 0,0:06:17.27,0:06:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah,
Dialogue: 0,0:06:19.44,0:06:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- para pangeran tersudut.\N- Omong-omong, bukankah itu luar biasa?
Dialogue: 0,0:06:24.49,0:06:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mengandalkan kecerdasan dan keunikannya.\N- Terima kasih.
Dialogue: 0,0:06:26.87,0:06:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Entah bagaimana, mereka bisa berhasil.\N- Kamu juga sudah bekerja dengan baik.
Dialogue: 0,0:06:31.83,0:06:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menghasilkan\Ncukup banyak uang hari ini.
Dialogue: 0,0:06:37.08,0:06:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:06:38.13,0:06:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:41.21,0:06:45.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk hari ini!
Dialogue: 0,0:06:45.22,0:06:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kalian, bisnis kami lancar.
Dialogue: 0,0:06:47.55,0:06:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa menjadi hostes yang baik.
Dialogue: 0,0:06:49.56,0:06:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, keahlian kami\Nadalah mendengarkan orang.
Dialogue: 0,0:06:53.06,0:06:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bukannya lebih baik\Nbekerja sebagai hostes?
Dialogue: 0,0:06:55.65,0:06:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergabunglah dengan kami!
Dialogue: 0,0:06:57.86,0:07:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa penyiksaan lebih baik.
Dialogue: 0,0:07:01.94,0:07:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:07:03.03,0:07:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu malam yang seperti mimpi\Nbagi para pangeran.
Dialogue: 0,0:07:07.74,0:07:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hera?
Dialogue: 0,0:07:09.20,0:07:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sayang sekali\Nmengakhirinya seperti ini.
Dialogue: 0,0:07:12.20,0:07:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hostes Spirytus sepertinya ide bagus.
Dialogue: 0,0:07:15.00,0:07:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak.
Dialogue: 0,0:07:22.13,0:07:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku haus.
Dialogue: 0,0:07:25.34,0:07:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa ini?\NBaru pertama lihat!
Dialogue: 0,0:07:28.05,0:07:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.\NSudah di situ dari tadi.
Dialogue: 0,0:07:30.18,0:07:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini hadiah?
Dialogue: 0,0:07:31.81,0:07:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau.
Dialogue: 0,0:07:34.73,0:07:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya pahit dan manis.\NMinuman apa ini?
Dialogue: 0,0:07:39.56,0:07:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kertas ini...
Dialogue: 0,0:08:05.76,0:08:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata begitu.\NIni obat buatan Iz.
Dialogue: 0,0:08:10.01,0:08:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat aneh apa lagi kali ini?
Dialogue: 0,0:08:12.43,0:08:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:08:21.27,0:08:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi mengecil!
Dialogue: 0,0:08:22.82,0:08:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali!
Dialogue: 0,0:08:23.86,0:08:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum berubah sama sekali!
Dialogue: 0,0:08:26.19,0:08:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Manis sekali!\N- Tenanglah.
Dialogue: 0,0:08:29.95,0:08:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu manis sekali!
Dialogue: 0,0:08:32.58,0:08:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hentikan!
Dialogue: 0,0:08:34.24,0:08:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aslinya aku masih orang dewasa.\N- Menggemaskan sekali!
Dialogue: 0,0:08:37.25,0:08:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hanya Sero yang belum berubah?
Dialogue: 0,0:08:41.08,0:08:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena aku\Npernah mencoba prototipe ini.
Dialogue: 0,0:08:45.59,0:08:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jadi, aku kebal.\N- Iz!
Dialogue: 0,0:08:48.59,0:08:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:08:50.55,0:08:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:08:52.97,0:08:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga?
Dialogue: 0,0:08:58.39,0:09:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Naku membeli pakaian anak-anak.
Dialogue: 0,0:09:00.98,0:09:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai apa pun yang kalian suka.
Dialogue: 0,0:09:08.99,0:09:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali!
Dialogue: 0,0:09:10.74,0:09:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan pria ini?
Dialogue: 0,0:09:12.93,0:09:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero suka makhluk kecil dan manis, kan?
Dialogue: 0,0:09:21.17,0:09:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga jadi lebih manis!
Dialogue: 0,0:09:23.29,0:09:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:09:25.38,0:09:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kita akan bekerja sekarang?
Dialogue: 0,0:09:27.76,0:09:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:09:33.59,0:09:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pasti terlihat aneh, jadi tidak usah.\N- Lepaskan aku! Hentikan!
Dialogue: 0,0:09:36.64,0:09:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kamu benar.\N- Hei!
Dialogue: 0,0:09:40.48,0:09:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari bekerja seperti biasa.
Dialogue: 0,0:09:44.06,0:09:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mejanya lebih tinggi sekarang.
Dialogue: 0,0:09:47.94,0:09:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gawat.
Dialogue: 0,0:09:51.07,0:09:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Khawatirlah sedikit.
Dialogue: 0,0:09:52.78,0:09:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bisa bekerja,\Nmau pulang saja?
Dialogue: 0,0:09:55.03,0:09:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana jika kita\Nmerapikan dokumen?
Dialogue: 0,0:09:59.29,0:10:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hebat.
Dialogue: 0,0:10:01.16,0:10:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:10:02.25,0:10:04.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau tiba-tiba jadi normal saat pulang,
Dialogue: 0,0:10:04.50,0:10:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa gawat nantinya.
Dialogue: 0,0:10:06.46,0:10:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:10:11.55,0:10:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah fokus bekerja, aku jadi haus.
Dialogue: 0,0:10:15.93,0:10:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau minum apa, Mike?
Dialogue: 0,0:10:17.85,0:10:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga lapar.
Dialogue: 0,0:10:19.56,0:10:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membeli sesuatu.
Dialogue: 0,0:10:21.18,0:10:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin makan sesuatu.
Dialogue: 0,0:10:23.52,0:10:24.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:25.15,0:10:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan kalian mau makan apa.
Dialogue: 0,0:10:27.51,0:10:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan belikan semuanya.
Dialogue: 0,0:10:29.86,0:10:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu membuatku takut.
Dialogue: 0,0:10:32.53,0:10:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, anak-anak manis saat mereka bahagia.
Dialogue: 0,0:10:35.99,0:10:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:10:37.28,0:10:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh,
Dialogue: 0,0:10:38.41,0:10:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menyukai ini!
Dialogue: 0,0:10:51.67,0:10:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nakal.
Dialogue: 0,0:10:53.05,0:10:54.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat marah.
Dialogue: 0,0:10:55.68,0:10:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalan tangan anak-anak\Nsama sekali tidak sakit.
Dialogue: 0,0:10:57.97,0:10:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubalas kamu.
Dialogue: 0,0:11:04.14,0:11:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kembali normal!
Dialogue: 0,0:11:06.35,0:11:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:11:07.69,0:11:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak dengan eksperimennya.
Dialogue: 0,0:11:10.82,0:11:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang begitu,\Ntapi tetap meminumnya, kan?
Dialogue: 0,0:11:14.40,0:11:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:17.62,0:11:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya membesar.
Dialogue: 0,0:11:20.74,0:11:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang mengecil.
Dialogue: 0,0:11:25.79,0:11:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa hanya aku yang punya jeda waktu?
Dialogue: 0,0:11:28.50,0:11:33.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kebal, jadi mungkin butuh waktu\Nsampai obatnya manjur.
Dialogue: 0,0:11:33.09,0:11:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai manjur, dong!
Dialogue: 0,0:11:34.47,0:11:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliranmu yang dimanjakan.
Dialogue: 0,0:11:37.93,0:11:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong! Aku diculik!
Dialogue: 0,0:11:39.43,0:11:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:11:44.60,0:11:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya penampilanmu,
Dialogue: 0,0:11:46.85,0:11:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi berbahaya membiarkan seorang anak\Npulang sendirian.
Dialogue: 0,0:11:50.36,0:11:52.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa baik sekali!
Dialogue: 0,0:11:52.78,0:11:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero?
Dialogue: 0,0:11:53.94,0:11:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu Sero?
Dialogue: 0,0:11:55.69,0:11:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:11:57.53,0:11:59.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat makan.
Dialogue: 0,0:11:59.62,0:12:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:04.83,0:12:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa cukup menyenangkan menjadi anakmu.
Dialogue: 0,0:12:08.25,0:12:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku tinggal di sini?
Dialogue: 0,0:12:10.08,0:12:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pulang sana.
Dialogue: 0,0:12:19.93,0:12:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:12:21.26,0:12:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat Siu mengajari kita,
Dialogue: 0,0:12:24.22,0:12:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita biasanya dibagi menjadi pasangan ini.
Dialogue: 0,0:12:27.18,0:12:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana Siu biasanya mengajar?
Dialogue: 0,0:12:32.19,0:12:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat tepat dan mudah dimengerti.
Dialogue: 0,0:12:34.98,0:12:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Sero?
Dialogue: 0,0:12:36.36,0:12:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama.
Dialogue: 0,0:12:37.49,0:12:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero juga pandai mengajar.
Dialogue: 0,0:12:40.57,0:12:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:12:42.33,0:12:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak penasaran.
Dialogue: 0,0:12:44.03,0:12:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:12:48.50,0:12:49.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:12:50.17,0:12:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau kita bertukar pasangan\Ndari yang biasanya?
Dialogue: 0,0:12:53.21,0:12:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya menyenangkan.
Dialogue: 0,0:12:55.34,0:12:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak keberatan.
Dialogue: 0,0:12:59.51,0:13:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini,
Dialogue: 0,0:13:00.76,0:13:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu harus memukulnya.
Dialogue: 0,0:13:03.11,0:13:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memukul?
Dialogue: 0,0:13:05.06,0:13:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kamu harus memberikan entakan.
Dialogue: 0,0:13:07.77,0:13:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entakan?
Dialogue: 0,0:13:15.40,0:13:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu cara menghitung napas?
Dialogue: 0,0:13:18.36,0:13:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira saja.
Dialogue: 0,0:13:20.90,0:13:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Denyut jantung, ukuran pupil,
Dialogue: 0,0:13:23.70,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sudut leher itu penting.
Dialogue: 0,0:13:25.62,0:13:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat itu saat kamu mengancam mereka.
Dialogue: 0,0:13:28.50,0:13:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:34.29,0:13:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sulit dimengerti.
Dialogue: 0,0:13:37.17,0:13:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk diajari.
Dialogue: 0,0:13:50.39,0:13:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero!
Dialogue: 0,0:13:53.10,0:13:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menemukan ini saat merapikan rak.
Dialogue: 0,0:13:56.32,0:13:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jadi kangen.
Dialogue: 0,0:13:58.88,0:14:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini foto lamamu dan Siu?
Dialogue: 0,0:14:01.53,0:14:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:03.16,0:14:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaya rambutmu sekarang
Dialogue: 0,0:14:04.81,0:14:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlihat seperti gaya rambut lama Siu.
Dialogue: 0,0:14:07.24,0:14:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:14:09.04,0:14:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:10.58,0:14:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyentuh poni saat bekerja,
Dialogue: 0,0:14:13.00,0:14:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wajahku akan terkena darah.
Dialogue: 0,0:14:14.79,0:14:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu demi kenyamanan.
Dialogue: 0,0:14:16.04,0:14:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kamu menirunya karena kagum.
Dialogue: 0,0:14:19.22,0:14:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau gaya rambut yang sama?
Dialogue: 0,0:14:20.76,0:14:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:14:28.76,0:14:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada darah di wajahmu lagi.
Dialogue: 0,0:14:31.73,0:14:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku tidak menyadarinya.
Dialogue: 0,0:14:34.44,0:14:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bisa memperbaiki kebiasaan itu.
Dialogue: 0,0:14:38.19,0:14:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku akan memakai gaya rambut\Nyang sama denganmu.
Dialogue: 0,0:14:41.15,0:14:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu,\Nponiku tidak akan menghalangi.
Dialogue: 0,0:14:43.86,0:14:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:14:44.86,0:14:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejam sekali.
Dialogue: 0,0:14:51.79,0:14:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran apa alasannya.
Dialogue: 0,0:14:59.55,0:15:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pa—
Dialogue: 0,0:15:02.80,0:15:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu!
Dialogue: 0,0:15:05.05,0:15:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutmu tampak manis hari ini.
Dialogue: 0,0:15:13.18,0:15:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak nakal itu...
Dialogue: 0,0:15:14.56,0:15:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serulingmu tertinggal.
Dialogue: 0,0:15:16.27,0:15:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:17.61,0:15:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengikat rambut Papa.
Dialogue: 0,0:15:20.44,0:15:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:15:22.86,0:15:23.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:15:24.28,0:15:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat dan rapi.\NSepertinya kamu sering melakukannya.
Dialogue: 0,0:15:27.36,0:15:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menyukainya?
Dialogue: 0,0:15:29.74,0:15:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka hal seperti ini.
Dialogue: 0,0:15:31.87,0:15:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengeringkan atau mengepang rambutku.
Dialogue: 0,0:15:34.83,0:15:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:15:36.29,0:15:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wanita pasti tertarik padamu.
Dialogue: 0,0:15:38.34,0:15:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan sekali mereka.
Dialogue: 0,0:15:39.38,0:15:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, jangan membuatku\Nterdengar seperti buaya darat.
Dialogue: 0,0:15:50.14,0:15:51.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Fon.
Dialogue: 0,0:15:51.89,0:15:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyapanya.
Dialogue: 0,0:15:54.29,0:15:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fon.
Dialogue: 0,0:15:55.02,0:15:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kualitasnya benaran bagus?
Dialogue: 0,0:15:58.10,0:15:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:59.44,0:16:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan produk terbaik.
Dialogue: 0,0:16:01.69,0:16:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, belakangan ini pasar\Npenuh dengan produk berkualitas rendah.
Dialogue: 0,0:16:05.19,0:16:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku akan percaya padamu.
Dialogue: 0,0:16:08.16,0:16:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:16:13.24,0:16:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang kulihat.
Dialogue: 0,0:16:15.33,0:16:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fon benar-benar orang yang menakutkan.
Dialogue: 0,0:16:18.71,0:16:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:21.67,0:16:23.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru menyadari itu?
Dialogue: 0,0:16:30.68,0:16:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Michan! Chichan!\NAku pulang!
Dialogue: 0,0:16:35.89,0:16:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membeli makanan kucing yang enak.
Dialogue: 0,0:16:38.60,0:16:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah.
Dialogue: 0,0:16:47.24,0:16:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu.
Dialogue: 0,0:16:48.78,0:16:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita makan malam apa malam ini?
Dialogue: 0,0:16:52.20,0:16:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita makan apa?
Dialogue: 0,0:16:53.87,0:16:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero, kamu akan menginap?
Dialogue: 0,0:16:57.08,0:16:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku harus bekerja lembur.
Dialogue: 0,0:16:59.79,0:17:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, boleh kami ikut?
Dialogue: 0,0:17:04.08,0:17:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:05.21,0:17:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu semuanya.
Dialogue: 0,0:17:07.42,0:17:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam-diam, kalian berdua terkadang makan\Nkudapan tengah malam yang lezat, kan?
Dialogue: 0,0:17:14.84,0:17:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir tidak ada\Nyang menyadarinya?
Dialogue: 0,0:17:18.27,0:17:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada aroma yang tertinggal di pantri.
Dialogue: 0,0:17:21.44,0:17:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indra penciumanku tajam!
Dialogue: 0,0:17:24.06,0:17:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang aku memasak.
Dialogue: 0,0:17:26.53,0:17:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin memakannya!
Dialogue: 0,0:17:29.49,0:17:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hugh, kamu juga mau memakannya, kan?
Dialogue: 0,0:17:31.61,0:17:33.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:17:33.28,0:17:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, kami makan di luar\Natau membeli makanan.
Dialogue: 0,0:17:36.83,0:17:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencoba masakanmu hari ini.
Dialogue: 0,0:17:39.04,0:17:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, Siu?
Dialogue: 0,0:17:41.33,0:17:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ide buruk membiarkan mereka\Nmerasakan bekerja di malam hari.
Dialogue: 0,0:17:44.84,0:17:47.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, pertama,
Dialogue: 0,0:17:47.50,0:17:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita belanja bahan makanan.
Dialogue: 0,0:17:49.34,0:17:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:53.72,0:17:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau masak apa?
Dialogue: 0,0:17:55.80,0:17:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramen dan nasi goreng.
Dialogue: 0,0:17:59.52,0:18:01.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa menantikannya.
Dialogue: 0,0:18:01.23,0:18:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan Siu sangat lezat.
Dialogue: 0,0:18:06.40,0:18:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berempat hari ini.
Dialogue: 0,0:18:08.15,0:18:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ambil bahan lebih banyak.
Dialogue: 0,0:18:10.69,0:18:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:18:18.08,0:18:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bisa memasak?
Dialogue: 0,0:18:20.04,0:18:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku biasanya memesan makanan.
Dialogue: 0,0:18:22.87,0:18:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makan masakan ibuku.
Dialogue: 0,0:18:25.38,0:18:26.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu, Sero?
Dialogue: 0,0:18:26.75,0:18:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sering makan di luar,
Dialogue: 0,0:18:29.34,0:18:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terkadang memasak dari resep\Natau video masakan.
Dialogue: 0,0:18:33.72,0:18:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:18:35.30,0:18:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya,
Dialogue: 0,0:18:37.39,0:18:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku hanya memasak saat melihat sesuatu\Ndan berpikir hasilnya akan lezat
Dialogue: 0,0:18:40.43,0:18:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau saat diminta memasak.
Dialogue: 0,0:18:44.35,0:18:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ingin masakan rumahan,
Dialogue: 0,0:18:46.36,0:18:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pergi ke rumah orang tuaku.
Dialogue: 0,0:18:47.81,0:18:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ingin telur dadar dengan dashi.\N- Atau pergi ke rumah Siu.
Dialogue: 0,0:18:50.82,0:18:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu anjing liar?
Dialogue: 0,0:18:52.15,0:18:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli telurnya.
Dialogue: 0,0:18:56.03,0:18:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah memotong banyak bahan!
Dialogue: 0,0:18:58.45,0:18:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:19:01.45,0:19:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bisa melakukannya.
Dialogue: 0,0:19:03.54,0:19:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malah bersaing.
Dialogue: 0,0:19:05.96,0:19:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasak tampak sulit.
Dialogue: 0,0:19:08.88,0:19:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mudah.
Dialogue: 0,0:19:10.21,0:19:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau coba?
Dialogue: 0,0:19:11.34,0:19:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baiklah.
Dialogue: 0,0:19:20.64,0:19:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:19:24.60,0:19:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:19:26.10,0:19:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:19:28.81,0:19:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hampir selesai, jadi tunggu saja.
Dialogue: 0,0:19:32.03,0:19:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:34.15,0:19:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak berguna, kan?
Dialogue: 0,0:19:38.87,0:19:41.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, apa kamu pandai memasak
Dialogue: 0,0:19:41.08,0:19:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena Reu dan Nero?
Dialogue: 0,0:19:43.83,0:19:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:45.54,0:19:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dahulu
Dialogue: 0,0:19:46.71,0:19:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada beberapa orang yang selalu makan\Nmakanan cepat saji.
Dialogue: 0,0:19:50.54,0:19:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering memasak untuk mereka.
Dialogue: 0,0:19:54.09,0:19:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kamu membuat banyak hidangan.
Dialogue: 0,0:19:57.51,0:20:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga orang sepertimu\Nyang mengemis makanan.
Dialogue: 0,0:20:00.01,0:20:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:20:01.97,0:20:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya sedap sekali!
Dialogue: 0,0:20:04.89,0:20:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian masih di sini.
Dialogue: 0,0:20:06.02,0:20:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negosiasi untuk kasus merepotkan\Nbutuh waktu lama.
Dialogue: 0,0:20:09.44,0:20:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lapar.
Dialogue: 0,0:20:10.98,0:20:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau ikut makan?
Dialogue: 0,0:20:12.15,0:20:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah?
Dialogue: 0,0:20:13.28,0:20:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:14.36,0:20:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:20:15.78,0:20:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan merebus mi lagi.
Dialogue: 0,0:20:20.16,0:20:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan hanya berdiri di sana.\NSiapkan meja, Bodoh.
Dialogue: 0,0:20:23.54,0:20:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menyebutku bodoh?
Dialogue: 0,0:20:25.08,0:20:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang bantu menyiapkannya.
Dialogue: 0,0:20:28.62,0:20:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:20:30.13,0:20:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari makan!
Dialogue: 0,0:20:33.92,0:20:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lezat.
Dialogue: 0,0:20:35.01,0:20:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti masakan restoran.
Dialogue: 0,0:20:37.51,0:20:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rasa favoritku!
Dialogue: 0,0:20:40.55,0:20:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, ramennya enak!
Dialogue: 0,0:20:42.55,0:20:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh, ini ramen buatanku!
Dialogue: 0,0:20:45.60,0:20:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:20:46.68,0:20:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini enak sekali.
Dialogue: 0,0:20:48.06,0:20:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jujur sekali.
Dialogue: 0,0:20:50.06,0:20:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat makan!
Dialogue: 0,0:20:51.81,0:20:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lezat seperti biasanya.
Dialogue: 0,0:20:54.48,0:20:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu kita bertiga selalu makan bersama.
Dialogue: 0,0:20:56.36,0:20:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:20:57.53,0:21:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin makan ini setiap hari.
Dialogue: 0,0:21:00.53,0:21:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lezat.
Dialogue: 0,0:21:01.32,0:21:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah membayangkan\Nakan semeriah ini.
Dialogue: 0,0:21:04.74,0:21:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:21:07.45,0:21:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:21:13.42,0:21:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas makanannya.
Dialogue: 0,0:21:17.13,0:21:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenyang sekali.
Dialogue: 0,0:21:18.59,0:21:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bekerja nanti,\Njadi jangan sampai kekenyangan...
Dialogue: 0,0:21:30.27,0:21:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:21:35.73,0:21:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak ini merepotkan sekali.
Dialogue: 0,0:21:38.57,0:21:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:41.82,0:21:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kemarin aku ketiduran.
Dialogue: 0,0:21:46.12,0:21:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur kalian nyenyak sekali.
Dialogue: 0,0:21:49.00,0:21:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:21:50.33,0:21:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kami belum bisa menyerahkan\Nsif malam pada kalian.
Dialogue: 0,0:21:53.29,0:21:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus mengendalikan diri.
Dialogue: 0,0:21:55.54,0:21:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sungguh tidak berguna.
Dialogue: 0,0:21:59.51,0:22:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk bekerja di malam hari,
Dialogue: 0,0:22:01.84,0:22:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami harus berusaha lebih baik.
Dialogue: 0,0:22:04.39,0:22:07.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar kami bisa makan di Spirytus lagi!
Dialogue: 0,0:22:08.52,0:22:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu alasannya.
