Dialogue: 0,0:00:04.36,0:00:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baca apa?
Dialogue: 0,0:00:06.15,0:00:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menerima beberapa sampel
Dialogue: 0,0:00:09.11,0:00:10.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}peralatan penyiksaan.
Dialogue: 0,0:00:10.24,0:00:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran isinya.
Dialogue: 0,0:00:12.58,0:00:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertipu dengan Nona Bel.
Dialogue: 0,0:00:16.00,0:00:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sengaja mengirimkan peralatan mahal.
Dialogue: 0,0:00:19.04,0:00:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:00:21.17,0:00:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tujuan utamanya adalah...
Dialogue: 0,0:00:23.75,0:00:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:00:24.88,0:00:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, kan?
Dialogue: 0,0:00:26.59,0:00:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu merasakannya sendiri!
Dialogue: 0,0:00:31.26,0:00:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin memamerkan\Nperalatan penyiksaan favoritnya.
Dialogue: 0,0:00:36.31,0:00:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Begitu rupanya.
Dialogue: 0,0:02:14.35,0:02:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya ada di sana.
Dialogue: 0,0:02:16.03,0:02:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:02:17.95,0:02:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu boleh pergi sekarang.
Dialogue: 0,0:02:20.56,0:02:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:02:23.13,0:02:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kelinci.
Dialogue: 0,0:02:25.29,0:02:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci?
Dialogue: 0,0:02:26.46,0:02:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama yang manis.
Dialogue: 0,0:02:31.05,0:02:33.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci?
Dialogue: 0,0:02:34.51,0:02:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berduri.
Dialogue: 0,0:02:36.26,0:02:39.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara menggunakannya?
Dialogue: 0,0:02:39.22,0:02:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah roda itu ditempelkan pada kulit,
Dialogue: 0,0:02:44.87,0:02:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}putar rodanya,
Dialogue: 0,0:02:47.15,0:02:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan duri-durinya\Nperlahan mengelupas kulit.
Dialogue: 0,0:02:51.05,0:02:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja parutan.
Dialogue: 0,0:02:54.57,0:02:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagang ini berat,
Dialogue: 0,0:02:56.28,0:02:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sulit mengendalikan kekuatannya.
Dialogue: 0,0:02:58.78,0:03:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bisa membunuh orang, kan?
Dialogue: 0,0:03:01.16,0:03:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:03:02.41,0:03:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hasilnya berantakan.
Dialogue: 0,0:03:06.75,0:03:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ukurannya kecil,\Ntapi ada duri juga di sini.
Dialogue: 0,0:03:09.17,0:03:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti aksesori.
Dialogue: 0,0:03:14.84,0:03:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leher Mike kecil,\Njadi dia tidak bisa memakainya.
Dialogue: 0,0:03:17.76,0:03:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:19.64,0:03:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut sekali.
Dialogue: 0,0:03:21.35,0:03:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau besi.
Dialogue: 0,0:03:25.56,0:03:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak ada durinya.
Dialogue: 0,0:03:27.60,0:03:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kandang yang bisa digantung\Nuntuk pajangan.
Dialogue: 0,0:03:31.52,0:03:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini hanya untuk mengurung, kan?
Dialogue: 0,0:03:34.53,0:03:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan...
Dialogue: 0,0:03:35.57,0:03:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bisa duduk di dalamnya.
Dialogue: 0,0:03:37.24,0:03:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi rasanya tetap seperti disiksa.
Dialogue: 0,0:03:38.74,0:03:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini penyiksaan yang memakan waktu.
Dialogue: 0,0:03:40.20,0:03:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit bagi korban dan juga pelaku penyiksaan.
Dialogue: 0,0:03:42.41,0:03:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:03:48.17,0:03:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisnya.
Dialogue: 0,0:03:50.13,0:03:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat nyaman.
Dialogue: 0,0:03:53.54,0:03:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang kamu suka?
Dialogue: 0,0:03:55.76,0:03:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertarik dengan semuanya.
Dialogue: 0,0:03:58.47,0:04:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi semuanya besar, jadi kurang praktis.
Dialogue: 0,0:04:01.22,0:04:03.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebanyakan ukurannya besar,
Dialogue: 0,0:04:03.31,0:04:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi butuh waktu lama\Natau menyebabkan banyak kerusakan.
Dialogue: 0,0:04:07.48,0:04:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya menarik,
Dialogue: 0,0:04:08.73,0:04:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak cocok\Nuntuk penyiksaan sehari-hari.
Dialogue: 0,0:04:11.19,0:04:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:04:12.57,0:04:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tunggu sebentar!\N- Benar.
Dialogue: 0,0:04:13.52,0:04:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarkan aku!
Dialogue: 0,0:04:16.11,0:04:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu manis sekali.
Dialogue: 0,0:04:16.94,0:04:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kami menahanmu di sini?
Dialogue: 0,0:04:19.11,0:04:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang begitu dengan wajah datar!
Dialogue: 0,0:04:24.87,0:04:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kembalikan semuanya.
Dialogue: 0,0:04:27.54,0:04:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:04:29.50,0:04:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa mereka akan kembali besok.
Dialogue: 0,0:04:31.88,0:04:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tinggalkan saja semua di sini\Ndan pulang.
Dialogue: 0,0:04:35.92,0:04:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sulit digunakan,
Dialogue: 0,0:04:37.63,0:04:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi memiliki nilai kejut yang bagus.
Dialogue: 0,0:04:40.22,0:04:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini efektif menakuti orang\Ndengan tampilannya.
Dialogue: 0,0:04:43.64,0:04:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek visual lebih penting\Ndaripada kepraktisan.
Dialogue: 0,0:04:48.64,0:04:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe menakutkan seperti ini
Dialogue: 0,0:04:50.48,0:04:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin cocok untukku.
Dialogue: 0,0:04:53.31,0:04:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang mereka belajar sesuatu.
Dialogue: 0,0:04:56.35,0:04:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belta terkadang bisa membantu.
Dialogue: 0,0:05:01.81,0:05:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:05:03.95,0:05:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Bel?
Dialogue: 0,0:05:05.51,0:05:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku mau mengembalikan
Dialogue: 0,0:05:07.87,0:05:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua peralatan yang kamu kirim.
Dialogue: 0,0:05:10.67,0:05:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu tidak praktis.
Dialogue: 0,0:05:12.54,0:05:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:05:13.75,0:05:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menggunakannya\Nuntuk hal selain penyiksaan, kan?
Dialogue: 0,0:05:16.42,0:05:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu dekorasi yang bagus?
Dialogue: 0,0:05:18.51,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin, tajam, dan mencolok.
Dialogue: 0,0:05:21.05,0:05:26.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sempurna dengan latar belakang\Npenyiksaan kalian.
Dialogue: 0,0:05:29.14,0:05:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Belta
Dialogue: 0,0:05:30.31,0:05:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya tipe orang\Nyang punya peralatan penyiksaan di rumah.
Dialogue: 0,0:05:33.15,0:05:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:05:40.86,0:05:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:05:42.45,0:05:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero!
Dialogue: 0,0:05:43.82,0:05:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:45.20,0:05:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terluka?
Dialogue: 0,0:05:46.45,0:05:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kamu tidak perlu datang.
Dialogue: 0,0:05:48.54,0:05:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:05:50.20,0:05:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak parah, kok.
Dialogue: 0,0:05:52.50,0:05:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kecelakaan?
Dialogue: 0,0:05:54.71,0:05:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:05:56.13,0:05:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya...
Dialogue: 0,0:05:58.59,0:05:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diserang.
Dialogue: 0,0:05:59.92,0:06:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diserang?
Dialogue: 0,0:06:01.55,0:06:04.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginterogasi\Nanggota organisasi jahat tempo hari.
Dialogue: 0,0:06:04.89,0:06:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan-rekannya balas dendam padaku.
Dialogue: 0,0:06:07.89,0:06:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan santai begitu...
Dialogue: 0,0:06:09.56,0:06:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku terkenal di industri ini.
Dialogue: 0,0:06:16.62,0:06:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:17.61,0:06:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba aku mau kena pukul pipa besi.
Dialogue: 0,0:06:22.86,0:06:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun menghantamnya dengan kepala.
Dialogue: 0,0:06:27.33,0:06:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku menelepon polisi.
Dialogue: 0,0:06:29.77,0:06:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Liar sekali.
Dialogue: 0,0:06:33.12,0:06:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika aku diperban begini,
Dialogue: 0,0:06:35.83,0:06:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}subjek penyiksaanku\Ntidak akan menganggapku serius.
Dialogue: 0,0:06:38.47,0:06:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bekerja di meja saja hari ini.
Dialogue: 0,0:06:40.55,0:06:41.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:06:41.84,0:06:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri.
Dialogue: 0,0:06:44.01,0:06:45.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:51.14,0:06:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenggat kasus ini pekan depan.
Dialogue: 0,0:06:54.19,0:06:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:55.98,0:06:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untuk Mike.
Dialogue: 0,0:06:58.90,0:07:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satunya untuk Hugh.
Dialogue: 0,0:07:05.03,0:07:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang jadwal kerja pekan depan,
Dialogue: 0,0:07:07.53,0:07:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada yang ini dan ini.
Dialogue: 0,0:07:08.57,0:07:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana yang kamu mau?
Dialogue: 0,0:07:15.33,0:07:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia mengabaikanku?
Dialogue: 0,0:07:17.46,0:07:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:07:18.75,0:07:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu!
Dialogue: 0,0:07:19.46,0:07:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:21.67,0:07:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu.
Dialogue: 0,0:07:22.88,0:07:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka itu...
Dialogue: 0,0:07:25.68,0:07:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja?
Dialogue: 0,0:07:27.13,0:07:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:07:29.14,0:07:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah ke rumah sakit,
Dialogue: 0,0:07:30.64,0:07:32.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu diperban seperti ini.
Dialogue: 0,0:07:32.81,0:07:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini bukan apa-apa...
Dialogue: 0,0:07:36.55,0:07:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang lucu?
Dialogue: 0,0:07:38.77,0:07:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceroboh sekali.
Dialogue: 0,0:07:41.36,0:07:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasus penyiksaan yang membuatmu diserang
Dialogue: 0,0:07:43.86,0:07:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya kasusku, kan?
Dialogue: 0,0:07:46.36,0:07:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukannya untukmu.
Dialogue: 0,0:07:48.28,0:07:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu berakhir seperti ini karena aku.
Dialogue: 0,0:07:50.87,0:07:51.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah alasannya.
Dialogue: 0,0:07:52.41,0:07:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa?
Dialogue: 0,0:07:55.96,0:08:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu harus melakukan\Nsemuanya sendiri?
Dialogue: 0,0:08:02.46,0:08:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah banyak orang\Nyang harus kamu lindungi, kan?
Dialogue: 0,0:08:06.72,0:08:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu melindungiku juga.
Dialogue: 0,0:08:12.02,0:08:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi akan merepotkan\Njika sesuatu terjadi padamu,
Dialogue: 0,0:08:14.72,0:08:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik di pekerjaan maupun rekan lainnya.
Dialogue: 0,0:08:16.43,0:08:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga repot\Njika sesuatu terjadi padamu.
Dialogue: 0,0:08:21.69,0:08:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya aku yang berpikir seperti itu.
Dialogue: 0,0:08:25.23,0:08:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar-benar marah.
Dialogue: 0,0:08:28.78,0:08:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga.
Dialogue: 0,0:08:31.49,0:08:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu marah padaku?
Dialogue: 0,0:08:34.53,0:08:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cobalah memahami\Nkenapa aku sangat marah.
Dialogue: 0,0:08:40.75,0:08:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau
Dialogue: 0,0:08:42.38,0:08:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu atau orang yang kamu sukai
Dialogue: 0,0:08:48.05,0:08:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terluka.
Dialogue: 0,0:08:50.64,0:08:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan perasaan buruk itu,
Dialogue: 0,0:08:53.47,0:08:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terluka bukan masalah besar.
Dialogue: 0,0:08:59.34,0:09:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih bisa diandalkan\Ndaripada sebelumnya, kan?
Dialogue: 0,0:09:04.51,0:09:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, berbagilah denganku.
Dialogue: 0,0:09:10.57,0:09:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beban yang kamu pikul.
Dialogue: 0,0:09:17.29,0:09:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit!
Dialogue: 0,0:09:18.94,0:09:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:09:22.19,0:09:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas kalau kamu tidak memikul\Nbeban itu dengan benar.
Dialogue: 0,0:09:29.38,0:09:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menanggungnya meski harus mati.
Dialogue: 0,0:09:32.01,0:09:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus mati?
Dialogue: 0,0:09:34.09,0:09:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menggertak saja, kan?
Dialogue: 0,0:09:37.64,0:09:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kenapa?
Dialogue: 0,0:09:38.81,0:09:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius soal ini.
Dialogue: 0,0:09:40.68,0:09:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuktikan padamu.
Dialogue: 0,0:09:43.27,0:09:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah muak denganmu.
Dialogue: 0,0:09:45.44,0:09:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kamu mengatakannya sendiri, Siu.
Dialogue: 0,0:09:47.53,0:09:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lihat apa yang bisa kulakukan.
Dialogue: 0,0:09:49.69,0:09:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan sekali.
Dialogue: 0,0:10:05.00,0:10:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa! Cantik sekali!
Dialogue: 0,0:10:07.71,0:10:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua sudah bekerja keras.
Dialogue: 0,0:10:10.67,0:10:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali kita perlu istirahat, ya.
Dialogue: 0,0:10:13.33,0:10:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:10:14.26,0:10:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana Reu dan Nero?
Dialogue: 0,0:10:16.14,0:10:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak keberatan jika mereka ikut.
Dialogue: 0,0:10:18.60,0:10:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:10:19.81,0:10:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang peduli jika kamu tak keberatan?
Dialogue: 0,0:10:22.43,0:10:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya ingin bermain\Ndengan kakak dan kakak iparku.
Dialogue: 0,0:10:25.65,0:10:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa, Paman Eli bilang
Dialogue: 0,0:10:27.90,0:10:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau mengajak kami ke Lulubee Land.
Dialogue: 0,0:10:29.90,0:10:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan bermalam di sana.
Dialogue: 0,0:10:31.11,0:10:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa bisa bersantai dan pergi ke onsen.
Dialogue: 0,0:10:34.36,0:10:35.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:10:37.49,0:10:38.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalau begitu.
Dialogue: 0,0:10:38.58,0:10:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bebas sampai makan malam.
Dialogue: 0,0:10:41.29,0:10:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:44.46,0:10:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berendam di onsen dulu?
Dialogue: 0,0:10:46.88,0:10:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:10:49.03,0:10:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:10:50.13,0:10:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari pembagian kamarnya,
Dialogue: 0,0:10:51.34,0:10:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya aku yang tak bisa istirahat.
Dialogue: 0,0:10:53.17,0:10:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja kamu bisa.
Dialogue: 0,0:10:54.63,0:10:56.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku orang yang menenangkan.
Dialogue: 0,0:10:56.41,0:10:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak yakin.
Dialogue: 0,0:11:03.06,0:11:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:11:05.35,0:11:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmatnya...
Dialogue: 0,0:11:08.31,0:11:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:10.19,0:11:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini onsen yang bagus.
Dialogue: 0,0:11:12.07,0:11:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja menjadi penyiksaan\Njika dipakai dengan cara lain.
Dialogue: 0,0:11:15.53,0:11:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, seperti penyiksaan dengan air\Natau direbus?
Dialogue: 0,0:11:17.99,0:11:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:20.37,0:11:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero.
Dialogue: 0,0:11:22.87,0:11:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perusahaan kita tidak menggunakan\Nkedua metode itu.
Dialogue: 0,0:11:26.47,0:11:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit mengendalikan kekuatan\Njika korban menolak mengaku.
Dialogue: 0,0:11:29.08,0:11:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak efektif dibandingkan biayanya.
Dialogue: 0,0:11:31.59,0:11:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:11:33.51,0:11:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menggunakan banyak air\Ntidak baik untuk lingkungan.
Dialogue: 0,0:11:37.05,0:11:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spirytus adalah perusahaan penyiksaan\Nyang ramah lingkungan.
Dialogue: 0,0:11:47.02,0:11:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:11:48.27,0:11:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hera dan Noe tidak ada di sini.
Dialogue: 0,0:11:53.15,0:11:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa mereka di kamarnya.
Dialogue: 0,0:11:55.61,0:11:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang tak terlihat,\Ntapi mereka berdua itu pemalu.
Dialogue: 0,0:11:59.66,0:12:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:12:05.98,0:12:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembarangan saja.
Dialogue: 0,0:12:08.46,0:12:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan sebenarnya bukan sesuatu\Nyang bisa kukatakan begitu saja.
Dialogue: 0,0:12:12.04,0:12:14.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sesuatu yang harus dia katakan sendiri
Dialogue: 0,0:12:14.13,0:12:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan seseorang yang bisa menerimanya.
Dialogue: 0,0:12:17.55,0:12:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku selalu ada\Nuntuk mendengarkan.
Dialogue: 0,0:12:20.18,0:12:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:12:21.47,0:12:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama 24 jam sehari,\N365 hari setahun.
Dialogue: 0,0:12:25.85,0:12:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu layanan yang bagus.
Dialogue: 0,0:12:36.19,0:12:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekas lukanya tidak terlihat lagi.
Dialogue: 0,0:12:39.24,0:12:41.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:12:42.15,0:12:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung semua orang di sini,\Nkenapa kamu tidak bergabung dengan mereka?
Dialogue: 0,0:12:48.61,0:12:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-anak itu\Ntidak akan mengatakan apa pun.
Dialogue: 0,0:12:51.92,0:12:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa juga begitu.
Dialogue: 0,0:12:56.16,0:12:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku
Dialogue: 0,0:12:57.88,0:13:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya ingin bersamamu, Hera.
Dialogue: 0,0:13:01.34,0:13:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:13:02.80,0:13:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah lama kamu tak menggosok punggungku.
Dialogue: 0,0:13:05.93,0:13:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, serahkan padaku.
Dialogue: 0,0:13:12.27,0:13:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:13:15.19,0:13:17.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memikirkan sesuatu.
Dialogue: 0,0:13:18.24,0:13:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu selalu\Nmengeringkan rambutnya, Sero?
Dialogue: 0,0:13:24.07,0:13:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutnya butuh waktu lama\Nkalau dikeringkan sendirian.
Dialogue: 0,0:13:27.20,0:13:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:13:28.54,0:13:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah mengeringkan rambutnya sebentar,
Dialogue: 0,0:13:30.66,0:13:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi menyukainya.
Dialogue: 0,0:13:34.00,0:13:35.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:13:37.67,0:13:40.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku terlalu malas.
Dialogue: 0,0:13:40.09,0:13:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, nanti dia akan memarahiku.
Dialogue: 0,0:13:43.59,0:13:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cukup pandai melakukannya.
Dialogue: 0,0:13:45.89,0:13:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia memang ingin membantu,
Dialogue: 0,0:13:47.39,0:13:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan membiarkannya.
Dialogue: 0,0:13:50.10,0:13:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan sekali.
Dialogue: 0,0:13:52.48,0:13:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti berada di salon rambut.
Dialogue: 0,0:13:56.07,0:13:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Siu.
Dialogue: 0,0:13:57.57,0:13:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah kering.
Dialogue: 0,0:13:58.90,0:13:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:04.99,0:14:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas kerja keras kalian\Nseperti biasanya.
Dialogue: 0,0:14:07.79,0:14:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:14:12.66,0:14:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, biar kutuangkan minum.
Dialogue: 0,0:14:14.42,0:14:15.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:15.46,0:14:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makan tidak, Noe?
Dialogue: 0,0:14:17.80,0:14:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu mengkhawatirkanku.
Dialogue: 0,0:14:21.09,0:14:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pernah ada tamasya perusahaan\Nseperti ini?
Dialogue: 0,0:14:24.51,0:14:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pernah.
Dialogue: 0,0:14:25.59,0:14:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sero dan Noe pernah bertengkar
Dialogue: 0,0:14:28.39,0:14:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyelesaikannya dengan pingpong.
Dialogue: 0,0:14:30.22,0:14:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:14:31.73,0:14:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus menonton sampai waktunya tidur.
Dialogue: 0,0:14:35.65,0:14:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, siapa yang menang pada akhirnya?
Dialogue: 0,0:14:37.65,0:14:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa, ya?
Dialogue: 0,0:14:39.36,0:14:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu aku.
Dialogue: 0,0:14:40.40,0:14:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku menang.
Dialogue: 0,0:14:41.94,0:14:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak ingat.
Dialogue: 0,0:14:46.24,0:14:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:14:47.99,0:14:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selain kita, hanya Mike dan Hugh\Nyang bertahan begitu lama.
Dialogue: 0,0:14:53.21,0:14:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatku agak bahagia.
Dialogue: 0,0:14:55.92,0:14:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya aku menjadi penyiksa tetap saja.
Dialogue: 0,0:14:57.96,0:14:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya bercanda.
Dialogue: 0,0:14:59.17,0:15:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menjadi pekerja tetap kapan saja.
Dialogue: 0,0:15:02.46,0:15:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Hugh?
Dialogue: 0,0:15:03.59,0:15:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin kamu lakukan setelah lulus?
Dialogue: 0,0:15:06.14,0:15:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pertanyaan bagus.
Dialogue: 0,0:15:09.22,0:15:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih memikirkannya.
Dialogue: 0,0:15:12.35,0:15:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku mendukungku\Ndalam karierku sebagai penyiksa.
Dialogue: 0,0:15:17.81,0:15:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka orang tua yang sangat baik.
Dialogue: 0,0:15:22.57,0:15:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat dewasa,
Dialogue: 0,0:15:24.36,0:15:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin melakukan pekerjaan\Nyang sama dengan Papa!
Dialogue: 0,0:15:26.61,0:15:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:15:27.66,0:15:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak?
Dialogue: 0,0:15:31.37,0:15:33.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus seperti orang tua Hugh.
Dialogue: 0,0:15:33.12,0:15:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu ragu.
Dialogue: 0,0:15:34.33,0:15:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percayalah pada dirimu sendiri.
Dialogue: 0,0:15:39.79,0:15:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:15:40.63,0:15:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang memberi Noe alkohol?
Dialogue: 0,0:15:42.67,0:15:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menuangkan itu untuknya.
Dialogue: 0,0:15:44.38,0:15:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:15:45.84,0:15:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lebih parah dariku saat mabuk.
Dialogue: 0,0:15:48.39,0:15:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu tahu kamu merepotkan saat mabuk.
Dialogue: 0,0:15:52.64,0:15:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal.
Dialogue: 0,0:15:54.81,0:15:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus lebih berkontribusi\Npada perusahaan.
Dialogue: 0,0:15:56.81,0:15:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:15:58.40,0:16:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah banyak membantu!
Dialogue: 0,0:16:00.15,0:16:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:16:01.19,0:16:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak cukup baik.
Dialogue: 0,0:16:02.65,0:16:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah melakukan yang terbaik.
Dialogue: 0,0:16:04.32,0:16:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lucu sekali.
Dialogue: 0,0:16:05.36,0:16:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisnya.
Dialogue: 0,0:16:06.49,0:16:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apa yang kamu makan\Nsambil minum alkohol?
Dialogue: 0,0:16:13.29,0:16:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenyang.
Dialogue: 0,0:16:16.41,0:16:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terjatuh.
Dialogue: 0,0:16:18.96,0:16:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang akan seceroboh itu?
Dialogue: 0,0:16:23.09,0:16:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:16:26.80,0:16:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kubilang?
Dialogue: 0,0:16:28.76,0:16:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:16:32.93,0:16:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Hera.
Dialogue: 0,0:16:35.14,0:16:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:16:36.35,0:16:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Berisik sekali ke mana pun aku pergi.\N- Apa katamu?
Dialogue: 0,0:16:41.27,0:16:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:16:43.47,0:16:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak menyadarinya.
Dialogue: 0,0:16:45.32,0:16:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:16:46.69,0:16:47.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:16:47.78,0:16:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahku tembam, jadi aku baik-baik saja.
Dialogue: 0,0:16:53.41,0:16:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, kamu tidak bisa melihat\Ndengan mata kananmu?
Dialogue: 0,0:16:59.41,0:17:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bukankah sudah kuberi tahu?
Dialogue: 0,0:17:01.67,0:17:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa melihat\Ndengan mata prostetik ini.
Dialogue: 0,0:17:08.76,0:17:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu soal mata kanan Siu?
Dialogue: 0,0:17:12.05,0:17:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang, kurasa dia tidak bisa melihat.
Dialogue: 0,0:17:15.43,0:17:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak pernah menanyakannya.
Dialogue: 0,0:17:17.14,0:17:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:17:19.06,0:17:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia akan memberi tahu kita\Njika kita bertanya.
Dialogue: 0,0:17:21.47,0:17:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit untuk bertanya padanya.
Dialogue: 0,0:17:25.56,0:17:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya banyak hal\Ntelah terjadi sebelumnya.
Dialogue: 0,0:17:28.24,0:17:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Sero pasti mengetahuinya.
Dialogue: 0,0:17:32.36,0:17:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya Sero selalu berada\Ndi sisi kiri Siu.
Dialogue: 0,0:17:39.25,0:17:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta tersembunyi dalam detail kecil\Nkehidupan sehari-hari.
Dialogue: 0,0:17:44.08,0:17:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:17:47.17,0:17:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku akan menulisnya\Ndi novel suatu hari nanti.
Dialogue: 0,0:17:52.76,0:17:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sabar membacanya.
Dialogue: 0,0:17:56.93,0:17:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:18:29.92,0:18:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lihat sesuatu yang menarik?
Dialogue: 0,0:18:33.47,0:18:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku membangunkanmu?
Dialogue: 0,0:18:35.76,0:18:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:18:38.06,0:18:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu pikirkan?
Dialogue: 0,0:18:41.02,0:18:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku tampak keren saat berpikir keras?
Dialogue: 0,0:18:42.93,0:18:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan sekali.
Dialogue: 0,0:18:46.23,0:18:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya berpikir ini tempat yang bagus.
Dialogue: 0,0:18:49.52,0:18:51.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, pemandangan di sini bagus.
Dialogue: 0,0:18:51.99,0:18:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudku.
Dialogue: 0,0:18:54.49,0:18:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku Spirytus.
Dialogue: 0,0:18:59.83,0:19:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bekerja di berbagai tempat.
Dialogue: 0,0:19:04.41,0:19:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa aku bisa bertahan di sini\Nbegitu lama.
Dialogue: 0,0:19:09.32,0:19:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa lama aku harus bertahan di sini?
Dialogue: 0,0:19:14.26,0:19:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa bertahan di sini selamanya.
Dialogue: 0,0:19:16.01,0:19:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami membutuhkanmu di sini.
Dialogue: 0,0:19:19.14,0:19:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa tinggal selama yang kamu mau.
Dialogue: 0,0:19:21.89,0:19:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru,
Dialogue: 0,0:19:23.10,0:19:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bertahanlah di sini demi aku.
Dialogue: 0,0:19:30.19,0:19:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, demi perusahaan,\Nmasyarakat, dan Siu
Dialogue: 0,0:19:34.07,0:19:35.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan terus berjuang.
Dialogue: 0,0:19:35.28,0:19:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai sekali.
Dialogue: 0,0:19:37.49,0:19:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:38.91,0:19:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:19:40.37,0:19:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa kelebihanmu\Nada pada sikapmu yang santai.
Dialogue: 0,0:19:45.79,0:19:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mike bertanya tentang mataku.
Dialogue: 0,0:19:48.33,0:19:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:50.46,0:19:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bertanya lagi,
Dialogue: 0,0:19:54.55,0:19:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bukan berarti\Naku tidak bisa memberi tahu mereka.
Dialogue: 0,0:19:59.47,0:20:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu terburu-buru.
Dialogue: 0,0:20:02.18,0:20:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada banyak hal yang tidak kuketahui.
Dialogue: 0,0:20:08.02,0:20:10.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menunggu\Nsampai kamu siap memberitahuku.
Dialogue: 0,0:20:11.06,0:20:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin butuh beberapa tahun.
Dialogue: 0,0:20:15.99,0:20:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan mengandalkanmu\Nbeberapa tahun lagi.
Dialogue: 0,0:20:19.20,0:20:20.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mengandalkanmu.
Dialogue: 0,0:20:39.55,0:20:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi!
Dialogue: 0,0:20:41.51,0:20:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:20:43.60,0:20:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan pagi-pagi begini?
Dialogue: 0,0:20:46.98,0:20:49.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mempelajari Studi Penyiksaan.
Dialogue: 0,0:20:49.52,0:20:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin sehebat kalian secepat mungkin.
Dialogue: 0,0:20:51.31,0:20:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kami belajar lebih giat.
Dialogue: 0,0:20:54.57,0:20:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:20:56.74,0:20:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap yang bagus untuk belajar.
Dialogue: 0,0:21:00.20,0:21:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah membaca ini.
Dialogue: 0,0:21:02.37,0:21:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi kangen!
Dialogue: 0,0:21:04.16,0:21:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya sangat sulit.
Dialogue: 0,0:21:07.87,0:21:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:21:09.87,0:21:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:21:11.37,0:21:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu bermalas-malasan di sini?
Dialogue: 0,0:21:13.38,0:21:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu!
Dialogue: 0,0:21:14.79,0:21:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku meneleponmu tadi, kan?
Dialogue: 0,0:21:17.01,0:21:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kiriman mendesak.
Dialogue: 0,0:21:19.30,0:21:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang pria ini menyebalkan,
Dialogue: 0,0:21:21.13,0:21:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi mereka menyerahkannya pada Spirytus.
Dialogue: 0,0:21:23.76,0:21:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kalian juga ikut.
Dialogue: 0,0:21:26.72,0:21:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:30.19,0:21:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kalian siap?
Dialogue: 0,0:21:32.78,0:21:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:21:34.11,0:21:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan pun kami siap.
Dialogue: 0,0:21:39.65,0:21:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang sekali kita berempat\Nmenyiksa bersama.
Dialogue: 0,0:21:48.04,0:21:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cepatlah mengaku.
Dialogue: 0,0:21:56.92,0:21:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami Spirytus,\Nperusahaan penyedia layanan penyiksaan.
Dialogue: 0,0:22:00.09,0:22:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi masyarakat yang adil dan jujur,
Dialogue: 0,0:22:03.76,0:22:05.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami melanjutkan\Npekerjaan penyiksaan hari ini.
