Dialogue: 0,0:00:02.27,0:00:04.93,tanda,,0000,0000,0000,,INI DUNIA TEMPAT PEMBUNUHAN\NDAN PENYIKSAAN ITU LEGAL.
Dialogue: 0,0:04:42.51,0:04:43.72,tanda,,0000,0000,0000,,ELEGI DUINO
Dialogue: 0,0:04:47.23,0:04:49.94,tanda,,0000,0000,0000,,STUDIO TATO DAN TINDIK, PETA
Dialogue: 0,0:06:44.93,0:06:47.43,tanda,,0000,0000,0000,,RAMEN
Dialogue: 0,0:08:31.57,0:08:33.87,tanda,,0000,0000,0000,,TIGA TAHUN KEMUDIAN
Dialogue: 0,0:12:48.25,0:12:51.96,tanda,,0000,0000,0000,,DISEWAKAN
Dialogue: 0,0:13:04.97,0:13:08.43,tanda,,0000,0000,0000,,PERUSAHAAN KONTRAK PENYIKSAAN\NSPIRYTUS
Dialogue: 0,0:13:08.43,0:13:11.15,tanda,,0000,0000,0000,,KANTOR DIREKTUR
Dialogue: 0,0:13:50.10,0:13:53.06,tanda,,0000,0000,0000,,RUANG TUNGGU
Dialogue: 0,0:15:47.09,0:15:50.05,tanda,,0000,0000,0000,,RUANG ISTIRAHAT
Dialogue: 0,0:17:23.19,0:17:25.10,tanda,,0000,0000,0000,,TERIMA KASIH, JAGA DIRIMU
Dialogue: 0,0:21:27.02,0:21:28.23,tanda,,0000,0000,0000,,KANTOR DIREKTUR
Dialogue: 0,0:22:11.27,0:22:14.31,tanda,,0000,0000,0000,,THE DAILY LIFE OF A PART-TIME TORTURER
Dialogue: 0,0:00:15.08,0:00:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:00:17.25,0:00:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu.
Dialogue: 0,0:00:20.25,0:00:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tertarik dengan penyiksaan?
Dialogue: 0,0:00:24.92,0:00:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, darah ini?
Dialogue: 0,0:00:26.92,0:00:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan apa-apa.
Dialogue: 0,0:00:28.22,0:00:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini selalu terjadi padaku.
Dialogue: 0,0:00:31.93,0:00:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan pria yang bikin kesal ini?
Dialogue: 0,0:00:37.06,0:00:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa itu akan cocok untukmu.
Dialogue: 0,0:00:39.94,0:00:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau mencobanya?
Dialogue: 0,0:00:42.61,0:00:44.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyiksaan?
Dialogue: 0,0:00:54.41,0:00:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu murid SMA, kan?
Dialogue: 0,0:00:56.91,0:00:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penyiksa lepas.
Dialogue: 0,0:00:59.37,0:01:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu bilang aku cocok\Nuntuk menyiksa?
Dialogue: 0,0:01:04.59,0:01:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sepertinya kamu luang\Ndan pandai memukuli orang.
Dialogue: 0,0:01:07.79,0:01:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma diajak ribut pas lagi jalan-jalan.
Dialogue: 0,0:01:11.84,0:01:13.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, itu membela diri?
Dialogue: 0,0:01:13.55,0:01:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tentu saja, wajahmu.
Dialogue: 0,0:01:17.47,0:01:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kecantikan hanyalah awal dari teror."
Dialogue: 0,0:01:22.19,0:01:25.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang orang cantik\Nadalah penyiksa yang baik.
Dialogue: 0,0:01:32.57,0:01:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini untukmu.
Dialogue: 0,0:01:35.49,0:01:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum bilang mau.
Dialogue: 0,0:01:36.83,0:01:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cambuk yang biasa kupakai.
Dialogue: 0,0:01:39.90,0:01:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini cocok untuk pemula?
Dialogue: 0,0:01:47.63,0:01:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus.
Dialogue: 0,0:01:48.63,0:01:49.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok untukmu.
Dialogue: 0,0:01:50.84,0:01:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:01:52.47,0:01:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum menanyakan namamu.
Dialogue: 0,0:01:55.68,0:01:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hera.
Dialogue: 0,0:01:59.10,0:02:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu.
Dialogue: 0,0:02:08.57,0:02:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melakukannya\Ndengan sangat baik untuk pemula.
Dialogue: 0,0:02:11.78,0:02:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana perasaanmu?
Dialogue: 0,0:02:13.28,0:02:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:02:14.66,0:02:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat lelah.
Dialogue: 0,0:02:15.74,0:02:17.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komentar yang membosankan.
Dialogue: 0,0:02:17.99,0:02:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada hal lain?
Dialogue: 0,0:02:21.70,0:02:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengandalkan kekuatanku sendiri
Dialogue: 0,0:02:24.62,0:02:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyingkap jawaban\Nyang tersembunyi di hati pria itu
Dialogue: 0,0:02:27.63,0:02:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tampak cukup menarik.
Dialogue: 0,0:02:30.38,0:02:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berbakat.
Dialogue: 0,0:02:32.26,0:02:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang cocok untukmu.
Dialogue: 0,0:02:34.76,0:02:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita hubungi\Npetugas kebersihan.
Dialogue: 0,0:02:39.56,0:02:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:02:41.02,0:02:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini agak berantakan.
Dialogue: 0,0:02:43.67,0:02:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, itu anak baru.
Dialogue: 0,0:02:45.81,0:02:47.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya.
Dialogue: 0,0:02:49.77,0:02:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang aneh.
Dialogue: 0,0:02:53.24,0:02:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih kerja samanya.
Dialogue: 0,0:02:54.78,0:02:58.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa\Nada penyiksa yang rapi sepertimu.
Dialogue: 0,0:02:58.66,0:03:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:00.70,0:03:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang di belakangmu itu anak baru?
Dialogue: 0,0:03:02.33,0:03:03.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:03.12,0:03:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bekerja bersama belakangan ini.
Dialogue: 0,0:03:05.58,0:03:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:03:07.29,0:03:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat beruntung.
Dialogue: 0,0:03:08.79,0:03:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bersama penyiksa yang baik.
Dialogue: 0,0:03:11.05,0:03:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang beruntung
Dialogue: 0,0:03:13.09,0:03:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menemukan anak berbakat sepertinya.
Dialogue: 0,0:03:21.01,0:03:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:03:22.10,0:03:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:03:22.72,0:03:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya dengan "penyiksa yang rapi"?
Dialogue: 0,0:03:27.65,0:03:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Industri ini
Dialogue: 0,0:03:29.27,0:03:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penuh orang yang menyiksa\Norang tidak bersalah
Dialogue: 0,0:03:32.40,0:03:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tidak bisa menyimpan rahasia.
Dialogue: 0,0:03:35.86,0:03:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya, kan?
Dialogue: 0,0:03:39.03,0:03:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melakukan penyiksaan\Ndengan benar.
Dialogue: 0,0:03:42.03,0:03:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tidak,
Dialogue: 0,0:03:42.99,0:03:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak-anak yang akan menjadi penyiksa
Dialogue: 0,0:03:45.16,0:03:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan bisa memercayaiku.
Dialogue: 0,0:03:48.29,0:03:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:03:49.92,0:03:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu mulai melakukan pekerjaan ini?
Dialogue: 0,0:03:54.59,0:03:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebetulan bertemu penyiksa,\Njadi aku bergabung dengannya.
Dialogue: 0,0:03:59.18,0:04:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya mengikuti arus.
Dialogue: 0,0:04:06.60,0:04:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:04:08.02,0:04:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pekerjaan ini cocok untukku.
Dialogue: 0,0:04:10.48,0:04:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mendapatkan kebenaran dari mereka,
Dialogue: 0,0:04:12.95,0:04:16.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa retakan di hatiku terisi.
Dialogue: 0,0:04:16.60,0:04:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memintamu bergabung denganku,
Dialogue: 0,0:04:18.77,0:04:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terserah mau melanjutkannya
Dialogue: 0,0:04:20.76,0:04:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau tidak.
Dialogue: 0,0:04:30.79,0:04:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang salah\Ndengan hidupmu saat ini.
Dialogue: 0,0:04:34.00,0:04:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya perlu menahan kebosanan.
Dialogue: 0,0:04:37.34,0:04:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau terlibat dengannya,
Dialogue: 0,0:04:39.87,0:04:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kehidupan normalmu akan lenyap.
Dialogue: 0,0:04:44.76,0:04:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa yang harus dirindukan\Ndari kehidupan normal ini?
Dialogue: 0,0:04:58.11,0:05:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan wajahmu?
Dialogue: 0,0:05:00.82,0:05:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tato.
Dialogue: 0,0:05:02.49,0:05:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berhenti sekolah.
Dialogue: 0,0:05:04.28,0:05:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendadak sekali.
Dialogue: 0,0:05:10.62,0:05:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhenti sekolah.
Dialogue: 0,0:05:13.04,0:05:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertanggung jawab membimbing\Nanak muda dengan masa depan cerah.
Dialogue: 0,0:05:17.51,0:05:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.\NAku akan melakukan yang terbaik.
Dialogue: 0,0:05:25.64,0:05:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:05:26.85,0:05:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini saatnya kamu mengaku?
Dialogue: 0,0:05:28.35,0:05:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang gigih.
Dialogue: 0,0:05:32.06,0:05:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:05:33.31,0:05:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertahan di pekerjaanku sebelumnya.
Dialogue: 0,0:05:35.90,0:05:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlambat.
Dialogue: 0,0:05:39.57,0:05:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Fon.
Dialogue: 0,0:05:40.74,0:05:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bekerja di bidang yang sama.
Dialogue: 0,0:05:43.07,0:05:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:05:50.96,0:05:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:05:52.87,0:05:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuanmu.
Dialogue: 0,0:05:54.75,0:05:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:05:56.42,0:05:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memanggil\Npetugas kebersihan sekarang.
Dialogue: 0,0:05:59.42,0:06:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan padamu.
Dialogue: 0,0:06:02.22,0:06:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Siu, kan?
Dialogue: 0,0:06:05.34,0:06:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu berhenti sekolah.
Dialogue: 0,0:06:08.97,0:06:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:10.27,0:06:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin kamu tahu,
Dialogue: 0,0:06:12.73,0:06:14.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi profesi ini cukup tidak biasa.
Dialogue: 0,0:06:14.98,0:06:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah lebih baik\Nsegera kembali ke kehidupan normal?
Dialogue: 0,0:06:18.65,0:06:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan normal tidak terlalu buruk.
Dialogue: 0,0:06:21.69,0:06:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jika Hera menangkapmu,\Nmungkin sulit untuk kembali.
Dialogue: 0,0:06:28.62,0:06:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:06:29.62,0:06:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulutnya berbusa dan dia pingsan.
Dialogue: 0,0:06:34.91,0:06:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:06:36.75,0:06:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia belum mati.
Dialogue: 0,0:06:38.96,0:06:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Izua.
Dialogue: 0,0:06:41.01,0:06:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungi aku kapan pun\Njika ada pasien lagi.
Dialogue: 0,0:06:43.13,0:06:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat bisa diandalkan.
Dialogue: 0,0:06:49.39,0:06:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kamu lihat,
Dialogue: 0,0:06:50.89,0:06:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dokter yang selalu siap\Nkapan pun mereka butuh.
Dialogue: 0,0:06:54.10,0:06:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dokter?
Dialogue: 0,0:06:55.52,0:06:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski mereka sampah yang harus disiksa,
Dialogue: 0,0:06:57.81,0:07:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tetap butuh perawatan.
Dialogue: 0,0:07:02.09,0:07:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tidak banyak dokter\Nyang mau membantu sampah seperti itu.
Dialogue: 0,0:07:08.45,0:07:11.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau lebih tepatnya,\Nmerawat orang yang akan disiksa.
Dialogue: 0,0:07:11.08,0:07:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya
Dialogue: 0,0:07:12.33,0:07:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang sepertiku dibutuhkan.
Dialogue: 0,0:07:15.58,0:07:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku juga merawat orang biasa.
Dialogue: 0,0:07:18.38,0:07:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat memulai pekerjaan seperti ini,
Dialogue: 0,0:07:20.17,0:07:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang-orang aneh seperti ini\Nmulai berkumpul di sekitar kita.
Dialogue: 0,0:07:23.92,0:07:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tampak tidak termotivasi,
Dialogue: 0,0:07:26.05,0:07:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi meyakini pekerjaan mereka.
Dialogue: 0,0:07:29.01,0:07:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:30.76,0:07:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau orang yang tampak santai,
Dialogue: 0,0:07:32.89,0:07:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ternyata penuh perhatian.
Dialogue: 0,0:07:35.52,0:07:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, ini bukan pekerjaan mudah.
Dialogue: 0,0:07:39.69,0:07:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:07:41.59,0:07:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}polisi yang membelikan ramen\Nuntuk anak-anak lapar.
Dialogue: 0,0:07:50.06,0:07:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada berbagai macam orang.
Dialogue: 0,0:07:52.74,0:07:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:07:53.87,0:07:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan keadaanku sekarang,
Dialogue: 0,0:07:55.54,0:07:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin aku bisa membantu\Nanak-anak sepertiku.
Dialogue: 0,0:07:59.33,0:08:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu mendadak sangat sentimental?
Dialogue: 0,0:08:01.71,0:08:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin kuperiksa?
Dialogue: 0,0:08:03.13,0:08:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:08:05.67,0:08:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya agak...
Dialogue: 0,0:08:06.59,0:08:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendalikan dirimu.
Dialogue: 0,0:08:10.26,0:08:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lakukan yang terbaik juga besok!
Dialogue: 0,0:08:12.72,0:08:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya rekan yang baik!
Dialogue: 0,0:08:15.43,0:08:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:08:16.68,0:08:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berusaha keras\Nagar sesuai dengan harapanmu.
Dialogue: 0,0:08:19.40,0:08:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sungguh bisa diandalkan!
Dialogue: 0,0:08:33.87,0:08:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:08:35.53,0:08:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, terima kasih\Nkarena selalu memasak untuk kami!
Dialogue: 0,0:08:38.75,0:08:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak bosan\Nhanya makan nasi omelet, Noe?
Dialogue: 0,0:08:42.21,0:08:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena nasi omelet buatanmu lezat!
Dialogue: 0,0:08:45.76,0:08:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelak kamu akan menjadi ayah yang baik.
Dialogue: 0,0:08:48.38,0:08:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin!
Dialogue: 0,0:08:51.14,0:08:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mau mengonfirmasi\Npermintaan penyiksaan itu.
Dialogue: 0,0:08:54.39,0:08:55.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:08:56.10,0:08:57.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga dirimu.
Dialogue: 0,0:08:57.56,0:08:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati di kantor.
Dialogue: 0,0:09:05.23,0:09:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noe telah menjadi anak yang baik.
Dialogue: 0,0:09:08.49,0:09:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tiga tahun.
Dialogue: 0,0:09:10.99,0:09:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:13.35,0:09:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang menjadi keluarga\Ndengan Noe hari itu.
Dialogue: 0,0:09:18.75,0:09:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Noe dan kamu,
Dialogue: 0,0:09:20.54,0:09:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sangat bahagia setiap hari.
Dialogue: 0,0:09:22.17,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang mendengarnya.
Dialogue: 0,0:09:25.17,0:09:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap bisa tetap seperti ini selamanya.
Dialogue: 0,0:09:27.67,0:09:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:09:30.05,0:09:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fon berhenti menjadi penyiksa.
Dialogue: 0,0:09:32.59,0:09:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, orang tidak bertahan lama\Ndalam pekerjaan ini.
Dialogue: 0,0:09:40.89,0:09:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, kamu mau terus melakukannya?
Dialogue: 0,0:09:45.31,0:09:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku tidak bisa membayangkan
Dialogue: 0,0:09:48.40,0:09:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau tidak bekerja seperti ini lagi.
Dialogue: 0,0:09:51.40,0:09:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengatakannya, ya?\NPekerjaan ini...
Dialogue: 0,0:09:54.09,0:09:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa ini telah menjadi tempatku.
Dialogue: 0,0:10:00.57,0:10:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu?
Dialogue: 0,0:10:01.75,0:10:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang sudah lama kupikirkan.
Dialogue: 0,0:10:05.04,0:10:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bisa menciptakan tempat\Nbagi penyiksa resmi di dunia ini,
Dialogue: 0,0:10:09.09,0:10:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti bagus.
Dialogue: 0,0:10:11.59,0:10:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebuah tempat...
Dialogue: 0,0:10:16.89,0:10:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hera?
Dialogue: 0,0:10:28.48,0:10:29.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:10:29.57,0:10:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya macam-macam di wilayah kami.
Dialogue: 0,0:10:31.74,0:10:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berandal.
Dialogue: 0,0:10:33.15,0:10:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan kamu lolos lain kali.
Dialogue: 0,0:10:39.27,0:10:41.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengerti?
Dialogue: 0,0:10:41.29,0:10:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarlah dari industri penyiksaan.
Dialogue: 0,0:10:57.30,0:10:58.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon.
Dialogue: 0,0:10:58.87,0:11:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamatkan dia.
Dialogue: 0,0:11:08.80,0:11:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:11:11.44,0:11:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membiarkan hal ini\Nmenimpa orang yang berarti bagimu.
Dialogue: 0,0:11:16.36,0:11:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:11:31.75,0:11:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua salahku.
Dialogue: 0,0:11:33.42,0:11:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, Hera melindungiku.
Dialogue: 0,0:11:40.60,0:11:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Siu.
Dialogue: 0,0:11:44.25,0:11:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku ketiduran...
Dialogue: 0,0:11:49.36,0:11:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:11:53.98,0:11:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:11:58.74,0:12:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:12:00.74,0:12:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:12:02.24,0:12:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup.
Dialogue: 0,0:12:04.95,0:12:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang ini tanggung jawabku.
Dialogue: 0,0:12:08.21,0:12:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:12:11.29,0:12:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya aku agak senang.
Dialogue: 0,0:12:14.90,0:12:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekas luka lama di punggungku\Nsaat aku masih kecil,
Dialogue: 0,0:12:18.80,0:12:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kini ditutupi dengan luka baru.
Dialogue: 0,0:12:23.51,0:12:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukti bahwa aku\Nbisa membuat pilihan sendiri.
Dialogue: 0,0:12:29.02,0:12:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan murung begitu.
Dialogue: 0,0:12:32.36,0:12:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini bagus.
Dialogue: 0,0:12:36.99,0:12:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:12:39.74,0:12:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Siu, apa kamu ingat?
Dialogue: 0,0:12:42.57,0:12:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang aku ingin menciptakan\Nsebuah "tempat".
Dialogue: 0,0:12:48.25,0:12:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat semua orang bisa
Dialogue: 0,0:12:50.00,0:12:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyiksa dengan tenang.
Dialogue: 0,0:12:52.81,0:12:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah sebentar lagi.
Dialogue: 0,0:13:13.69,0:13:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi sangat lihai\Nsaat berdandan seperti ini.
Dialogue: 0,0:13:16.86,0:13:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:13:18.24,0:13:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga cantik hari ini.
Dialogue: 0,0:13:19.95,0:13:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang anak yang baik dan jujur.
Dialogue: 0,0:13:24.03,0:13:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Noe, aku sudah selesai hari ini.
Dialogue: 0,0:13:27.12,0:13:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu aku jika ada hal lain.
Dialogue: 0,0:13:28.75,0:13:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:31.87,0:13:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu sangat bersemangat.
Dialogue: 0,0:13:36.34,0:13:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hera, saatnya mengoleskan salep.
Dialogue: 0,0:13:40.17,0:13:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:42.51,0:13:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya.
Dialogue: 0,0:13:43.89,0:13:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:13:48.60,0:13:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon!
Dialogue: 0,0:13:50.10,0:13:53.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang ada salah paham!
Dialogue: 0,0:13:53.06,0:13:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya reporter!
Dialogue: 0,0:13:55.15,0:13:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dikira sebagai subjek penyiksaan!
Dialogue: 0,0:13:58.19,0:13:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh!
Dialogue: 0,0:13:59.82,0:14:02.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini terjadi padaku?
Dialogue: 0,0:14:02.78,0:14:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keributan apa ini?
Dialogue: 0,0:14:04.99,0:14:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bebaskan aku!
Dialogue: 0,0:14:06.70,0:14:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius!
Dialogue: 0,0:14:07.87,0:14:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang aku hanya reporter!
Dialogue: 0,0:14:12.71,0:14:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu benar-benar subjek penyiksaan?
Dialogue: 0,0:14:15.50,0:14:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang bukan!
Dialogue: 0,0:14:18.71,0:14:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku
Dialogue: 0,0:14:20.96,0:14:23.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas perlakuan buruk tadi.
Dialogue: 0,0:14:23.18,0:14:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:14:25.39,0:14:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku sudah terbiasa.
Dialogue: 0,0:14:27.68,0:14:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sering terjadi karena pekerjaanku.
Dialogue: 0,0:14:30.27,0:14:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering mengumpulkan informasi\Nyang merugikan banyak organisasi.
Dialogue: 0,0:14:34.44,0:14:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, karena itu kamu dikirim ke sini?
Dialogue: 0,0:14:37.23,0:14:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tidak bisa dimaafkan!
Dialogue: 0,0:14:40.73,0:14:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:14:41.78,0:14:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terima kasih untuk tadi.
Dialogue: 0,0:14:43.24,0:14:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu langsung melepas ikatanku.
Dialogue: 0,0:14:47.95,0:14:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai balasannya,\Nberi tahu aku kalau butuh informasi.
Dialogue: 0,0:14:50.99,0:14:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku profesional di bidang itu.
Dialogue: 0,0:14:55.29,0:14:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini informasi kontakku.
Dialogue: 0,0:14:58.46,0:15:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Sova, salam kenal!
Dialogue: 0,0:15:11.89,0:15:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:15:13.68,0:15:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita yang kita temui waktu itu.
Dialogue: 0,0:15:15.56,0:15:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa namanya...
Dialogue: 0,0:15:17.27,0:15:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sova.
Dialogue: 0,0:15:18.19,0:15:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:19.27,0:15:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memintanya\Nmenyelidiki hal yang sederhana.
Dialogue: 0,0:15:24.32,0:15:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis yang ceria.
Dialogue: 0,0:15:26.45,0:15:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:27.36,0:15:30.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua mungkin akan sangat akrab.
Dialogue: 0,0:15:32.24,0:15:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bukankah kamu terlalu banyak merokok\Nbelakangan ini?
Dialogue: 0,0:15:36.29,0:15:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu perlu bersantai sesekali
Dialogue: 0,0:15:39.29,0:15:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski semangat bekerja itu hal yang baik.
Dialogue: 0,0:15:43.21,0:15:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan sekali.
Dialogue: 0,0:15:47.09,0:15:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:15:48.43,0:15:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang lagi.
Dialogue: 0,0:15:50.93,0:15:52.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ini paket layanan.
Dialogue: 0,0:15:52.60,0:15:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang memintamu membawanya.
Dialogue: 0,0:15:55.68,0:15:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya pekan kalian berat.
Dialogue: 0,0:15:57.52,0:15:59.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengintip tanpa izin.
Dialogue: 0,0:15:59.77,0:16:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siu, warna rambutmu
Dialogue: 0,0:16:01.48,0:16:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama denganku!
Dialogue: 0,0:16:02.82,0:16:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu memanggil nama depanku?
Dialogue: 0,0:16:04.48,0:16:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku lebih tua darimu.
Dialogue: 0,0:16:07.74,0:16:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:16:12.45,0:16:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat!
Dialogue: 0,0:16:15.16,0:16:16.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indahnya!
Dialogue: 0,0:16:18.37,0:16:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang melihat hal seperti ini sesekali.
Dialogue: 0,0:16:23.80,0:16:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:26.34,0:16:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa melihatmu senang.
Dialogue: 0,0:16:33.22,0:16:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka itu...
Dialogue: 0,0:16:34.97,0:16:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sulit menyembunyikannya?
Dialogue: 0,0:16:38.48,0:16:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:40.52,0:16:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini semua salahku.
Dialogue: 0,0:16:45.69,0:16:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu menyembunyikannya dariku.
Dialogue: 0,0:16:48.74,0:16:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang luka itu.
Dialogue: 0,0:16:50.61,0:16:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga tentang dirimu.
Dialogue: 0,0:16:53.33,0:16:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu lebih banyak.
Dialogue: 0,0:16:58.62,0:17:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu, meski sendirian,
Dialogue: 0,0:17:03.04,0:17:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap ceria dengan bodohnya.
Dialogue: 0,0:17:05.55,0:17:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dengan mudah menemukan jalan\Nke hati orang-orang.
Dialogue: 0,0:17:10.01,0:17:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga sangat memahami\Nkesepian orang lain.
Dialogue: 0,0:17:13.05,0:17:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kami bersama,
Dialogue: 0,0:17:14.55,0:17:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekosongan di hatiku\Nterasa benar-benar terisi.
Dialogue: 0,0:17:19.23,0:17:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia merasakan hal yang sama.
Dialogue: 0,0:17:25.10,0:17:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi suatu hari, dia tiba-tiba menghilang.
Dialogue: 0,0:17:29.82,0:17:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bertanya-tanya\Napakah dia orang seperti itu.
Dialogue: 0,0:17:38.25,0:17:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bertemu lagi tiga tahun kemudian.
Dialogue: 0,0:17:41.12,0:17:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lihat dia di rumah sakit.
Dialogue: 0,0:17:46.04,0:17:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa begini?
Dialogue: 0,0:17:49.05,0:17:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena tiba-tiba menghubungimu.
Dialogue: 0,0:17:51.93,0:17:54.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus minta maaf\Nkarena tiba-tiba menghilang.
Dialogue: 0,0:17:54.34,0:17:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:17:56.31,0:17:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama.
Dialogue: 0,0:17:58.10,0:18:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:18:01.06,0:18:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa, ya, dia?
Dialogue: 0,0:18:04.52,0:18:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka anak-anakku?
Dialogue: 0,0:18:05.86,0:18:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa tahu?
Dialogue: 0,0:18:08.03,0:18:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka manis, kan?
Dialogue: 0,0:18:10.15,0:18:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kembar.
Dialogue: 0,0:18:12.15,0:18:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah alasanmu tiba-tiba menghilang?
Dialogue: 0,0:18:15.66,0:18:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:18:17.58,0:18:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena aku tidak bisa diandalkan?
Dialogue: 0,0:18:20.25,0:18:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:18:22.54,0:18:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melarikan diri sendirian.
Dialogue: 0,0:18:27.00,0:18:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin mereka\Nmenjadi beban bagimu.
Dialogue: 0,0:18:32.22,0:18:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memikirkannya saja membuatku takut.
Dialogue: 0,0:18:34.59,0:18:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ini kali pertama\Naku punya keluarga yang sangat berharga.
Dialogue: 0,0:18:45.73,0:18:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bodoh sekali.
Dialogue: 0,0:18:47.36,0:18:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:52.86,0:18:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku tinggal enam bulan lagi.
Dialogue: 0,0:18:59.58,0:19:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:04.87,0:19:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sova, ayo kita menikah.
Dialogue: 0,0:19:08.21,0:19:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mengasihaniku?
Dialogue: 0,0:19:14.05,0:19:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita menikah dan kamu pergi,
Dialogue: 0,0:19:17.84,0:19:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan lebih mudah bagiku\Nuntuk mengurus kedua anak ini.
Dialogue: 0,0:19:20.22,0:19:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:21.68,0:19:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu gamblang, ya?
Dialogue: 0,0:19:24.39,0:19:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:19:26.77,0:19:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka kebaikan hatimu.
Dialogue: 0,0:19:32.40,0:19:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:40.83,0:19:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian berdua.
Dialogue: 0,0:19:42.08,0:19:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan sudah siap.
Dialogue: 0,0:19:43.33,0:19:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:19:44.79,0:19:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa luar biasa!
Dialogue: 0,0:19:46.50,0:19:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Papa pandai memasak!
Dialogue: 0,0:19:47.92,0:19:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat makan.
Dialogue: 0,0:19:49.08,0:19:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Busnya segera datang.
Dialogue: 0,0:19:50.42,0:19:51.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:52.25,0:19:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak kucing itu manis sekali.
Dialogue: 0,0:19:55.05,0:19:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka nasi omelet.
Dialogue: 0,0:20:02.39,0:20:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu belum berhenti merokok?
Dialogue: 0,0:20:05.68,0:20:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang aku masih ingin merokok.
Dialogue: 0,0:20:07.94,0:20:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sejak Sova meninggal.
Dialogue: 0,0:20:10.98,0:20:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabarmu?
Dialogue: 0,0:20:13.28,0:20:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik-baik saja.
Dialogue: 0,0:20:15.53,0:20:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:21.53,0:20:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap Sova bisa lebih mengandalkanku.
Dialogue: 0,0:20:27.04,0:20:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, pada akhirnya\Ndia menghubungimu, kan?
Dialogue: 0,0:20:30.17,0:20:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memercayakan anak-anaknya\Nyang berharga padamu.
Dialogue: 0,0:20:33.73,0:20:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengandalkanmu.
Dialogue: 0,0:20:36.42,0:20:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kamu meresponsnya.
Dialogue: 0,0:20:40.01,0:20:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pilihan Sova.
Dialogue: 0,0:20:48.85,0:20:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pula dengan lukaku.
Dialogue: 0,0:20:51.48,0:20:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak tergantikan.
Dialogue: 0,0:20:54.77,0:20:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu rekan terbaik.
Dialogue: 0,0:20:58.99,0:21:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:00.41,0:21:01.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cukup tidak biasa.
Dialogue: 0,0:21:02.66,0:21:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kejadian
Dialogue: 0,0:21:04.45,0:21:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat kamu mendekatiku,
Dialogue: 0,0:21:07.37,0:21:10.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa bertahan sampai sekarang.
Dialogue: 0,0:21:10.58,0:21:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua karenamu.
Dialogue: 0,0:21:17.05,0:21:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang harus berterima kasih
Dialogue: 0,0:21:19.01,0:21:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena kamu tetap di sisiku.
Dialogue: 0,0:21:27.02,0:21:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:21:28.23,0:21:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kamu akan mempekerjakan\Nlebih banyak orang?
Dialogue: 0,0:21:30.94,0:21:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, setidaknya cuci mukamu dulu.
Dialogue: 0,0:21:35.40,0:21:38.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu berapa kasus\Nyang sudah kukerjakan sendirian?
Dialogue: 0,0:21:38.74,0:21:39.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:21:39.86,0:21:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegawai baru akan datang besok.
Dialogue: 0,0:21:42.66,0:21:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling orang yang tidak berguna lagi.
Dialogue: 0,0:21:44.57,0:21:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit menemukan orang\Nyang sanggup bertahan.
Dialogue: 0,0:21:47.29,0:21:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa pegawai baru\Nyang berhenti tahun ini?
Dialogue: 0,0:21:49.66,0:21:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada 68.
Dialogue: 0,0:21:52.37,0:21:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pegawai seperti apa yang kamu mau?
Dialogue: 0,0:21:53.92,0:21:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting.
Dialogue: 0,0:21:56.80,0:21:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan bagus jika ada anak baru\Nyang kamu sukai.
Dialogue: 0,0:22:01.47,0:22:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terlalu berharap.
