Dialogue: 0,0:23:58.58,0:24:00.08,5-normal,,0,0,0,,{\pos(957,700)\fs85\b1\bord0\c&HFCFCFC&\fad(150,0)}Pemandangan Indah
Dialogue: 0,0:00:23.63,0:00:26.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anda yakin sampai di sini saja?
Dialogue: 0,0:00:26.80,0:00:28.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:00:28.47,0:00:31.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mulai dari sini,\Naku akan pergi sendiri.
Dialogue: 0,0:00:31.64,0:00:36.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu, tempat tujuanku\Nhanya bisa dicapai dengan jalan kaki.
Dialogue: 0,0:00:37.27,0:00:38.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik, saya mengerti.
Dialogue: 0,0:00:38.56,0:00:39.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hati-hati di jalan.
Dialogue: 0,0:02:48.85,0:02:50.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Parah, sih, ini.
Dialogue: 0,0:02:51.17,0:02:54.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Desa kami diserang naga.
Dialogue: 0,0:02:54.32,0:02:57.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dataran Tinggi Kontinen Utara\Nada naganya juga?
Dialogue: 0,0:02:57.20,0:02:59.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar daerah yang berbahaya.
Dialogue: 0,0:03:00.05,0:03:01.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini masih mending.
Dialogue: 0,0:03:01.79,0:03:02.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:02.75,0:03:07.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat bertualang dengan Himmel,\Nkami pernah diserang gerombolan naga.
Dialogue: 0,0:03:08.21,0:03:10.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak terbayang\Nkalau diserang gerombolan naga.
Dialogue: 0,0:03:10.75,0:03:12.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gawat sekali.
Dialogue: 0,0:03:12.32,0:03:17.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, bicara mengenai naga,\Nbukankah memang biasa bergerombol?
Dialogue: 0,0:03:17.91,0:03:20.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Desa ini diserang gerombolan naga?
Dialogue: 0,0:03:20.37,0:03:21.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:21.63,0:03:24.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya bersarang di dekat sini,
Dialogue: 0,0:03:24.23,0:03:26.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}jadi kami ingin minta tolong\Nagar mereka dibasmi.
Dialogue: 0,0:03:27.22,0:03:29.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Patokan di Dataran Tinggi Utara seram, ih.
Dialogue: 0,0:03:29.52,0:03:31.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gawatnya di luar nalar.
Dialogue: 0,0:03:49.88,0:03:52.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Desa ini sepertinya sudah berakhir.
Dialogue: 0,0:03:53.17,0:03:54.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lebih baik pindah saja.
Dialogue: 0,0:03:56.55,0:03:57.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi.
Dialogue: 0,0:03:58.34,0:04:01.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat ini adalah kampung halaman kami.
Dialogue: 0,0:04:02.29,0:04:02.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:04:02.97,0:04:03.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aman?
Dialogue: 0,0:04:04.18,0:04:05.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kubawakan sekarang.
Dialogue: 0,0:04:07.94,0:04:10.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar itu, Nona Frieren.
Dialogue: 0,0:04:11.17,0:04:13.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anda terlalu berlebihan.
Dialogue: 0,0:04:13.05,0:04:15.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kasihan para warga desa.
Dialogue: 0,0:04:15.85,0:04:17.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lawannya gerombolan naga, lo.
Dialogue: 0,0:04:17.89,0:04:19.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian paham?
Dialogue: 0,0:04:19.55,0:04:21.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita sendiri juga tidak akan\Nselamat begitu saja.
Dialogue: 0,0:04:22.14,0:04:25.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kampung halaman itu\Nharus dilindungi, kan, Frieren?
Dialogue: 0,0:04:26.33,0:04:28.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi tergantung imbalannya.
Dialogue: 0,0:04:28.93,0:04:31.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sayangnya, desa kami begitu miskin,
Dialogue: 0,0:04:31.92,0:04:33.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}tidak ada yang bisa dijadikan imbalan.
Dialogue: 0,0:04:33.96,0:04:36.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa tidak punya kitab sihir?
Dialogue: 0,0:04:36.09,0:04:40.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Misalkan sihir untuk mengatakan\Nkalimat sulit diucap tanpa berbelit.
Dialogue: 0,0:04:40.69,0:04:43.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami hanya punya sihir\Ntidak berguna semacam itu.
Dialogue: 0,0:04:43.97,0:04:47.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya benar-benar tidak berguna.
Dialogue: 0,0:04:53.01,0:04:55.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Asal dapat sihir, apa saja boleh, nih?
Dialogue: 0,0:04:55.48,0:04:58.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian tahu dari mana\Ngerombolan naganya datang?
Dialogue: 0,0:04:58.79,0:05:01.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami cuma tahu kalau dari dalam hutan itu.
Dialogue: 0,0:05:03.23,0:05:05.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo coba lacak jejak daya sihirnya.
Dialogue: 0,0:05:06.29,0:05:07.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin bisa kita telusuri.
Dialogue: 0,0:05:32.19,0:05:34.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari sini lurus saja ke depan.
Dialogue: 0,0:05:34.90,0:05:39.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari dulu aku kepikiran,\Nsihir itu hebat, ya.
Dialogue: 0,0:05:39.49,0:05:41.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat praktis buat saat seperti ini.
Dialogue: 0,0:05:42.34,0:05:44.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boleh saja kalau mau memujiku\Nlebih tinggi lagi.
Dialogue: 0,0:05:44.53,0:05:47.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Stark, kalau beliau dipuji sembarangan,
Dialogue: 0,0:05:47.70,0:05:49.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}nanti jadi tidak mendidik buat Nona Frieren.
Dialogue: 0,0:05:49.88,0:05:52.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, itu benar juga.
Dialogue: 0,0:05:52.37,0:05:56.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian berdua menganggap aku ini apa?
Dialogue: 0,0:05:56.96,0:06:00.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pokoknya, kurang lebih kita tahu arahnya,\Nayo ke sana.
Dialogue: 0,0:06:35.50,0:06:36.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:06:36.71,0:06:38.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jumlahnya banyak sekali.
Dialogue: 0,0:06:38.50,0:06:40.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ini naga berukuran kecil.
Dialogue: 0,0:06:40.61,0:06:43.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak sekuat itu kalau\Ndibanding Naga Cermin Merah.
Dialogue: 0,0:06:44.38,0:06:48.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski begitu, naga itu cerdas,\Nakan repot kalau sampai terkepung.
Dialogue: 0,0:06:49.43,0:06:52.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita coba giring mereka ke satu tempat\Nuntuk dihabisi bersamaan.
Dialogue: 0,0:06:52.85,0:06:55.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark, tugas menahan mereka\Nkuserahkan padamu.
Dialogue: 0,0:06:56.27,0:06:58.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sudah berpengalaman\Nmelawan naga, kan?
Dialogue: 0,0:06:59.01,0:07:00.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku lagi, nih?
Dialogue: 0,0:07:00.48,0:07:02.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu ini spartan banget.
Dialogue: 0,0:07:07.29,0:07:08.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita mulai.
Dialogue: 0,0:07:08.53,0:07:10.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kali ini tembak yang benar, ya!
Dialogue: 0,0:07:14.69,0:07:17.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu kalau mereka tidak kamu habisi sendiri.
Dialogue: 0,0:08:26.40,0:08:28.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar pertempuran yang sulit.
Dialogue: 0,0:08:29.50,0:08:32.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untung saja ada gereja di desa.
Dialogue: 0,0:08:32.20,0:08:36.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di tengah pertempuran tadi,\Nkepala Tuan Stark digigit naga, kan?
Dialogue: 0,0:08:38.87,0:08:40.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa Anda bisa baik-baik saja?
Dialogue: 0,0:08:44.80,0:08:46.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Enggak tahu.
Dialogue: 0,0:08:46.70,0:08:49.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin sudah biasa untuk seorang pendekar?
Dialogue: 0,0:08:49.18,0:08:52.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eisen juga tidak terluka\Nsaat kepalanya digigit.
Dialogue: 0,0:08:52.05,0:08:55.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau itu, sudah pasti\NTuan Eisen yang tidak normal.
Dialogue: 0,0:08:55.64,0:08:57.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf sudah menunggu.
Dialogue: 0,0:08:59.51,0:09:01.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:01.44,0:09:03.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini kitab sihir imbalannya.
Dialogue: 0,0:09:13.87,0:09:16.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya, Nona Frieren ini
Dialogue: 0,0:09:16.16,0:09:20.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}hampir selalu meminta imbalan\Nsaat menolong orang.
Dialogue: 0,0:09:20.91,0:09:23.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena Himmel juga begitu.
Dialogue: 0,0:09:23.17,0:09:24.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengejutkan juga.
Dialogue: 0,0:09:24.54,0:09:29.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saya kira beliau akan menolong orang\Ntanpa pamrih atau minta imbalan.
Dialogue: 0,0:09:29.97,0:09:31.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:09:31.59,0:09:33.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kupikir juga begitu.
Dialogue: 0,0:09:34.93,0:09:37.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami benar-benar tertolong.
Dialogue: 0,0:09:37.18,0:09:41.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seharusnya kami memberikan\Nsesuatu yang lebih berharga.
Dialogue: 0,0:09:41.73,0:09:44.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi seperti kalian lihat,\Ndesa ini begitu miskin.
Dialogue: 0,0:09:44.88,0:09:48.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi hanya ini yang bisa kami sediakan.
Dialogue: 0,0:09:49.45,0:09:53.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana bisa kita menerima\Nbahan makanan dari desa ini.
Dialogue: 0,0:09:56.70,0:09:58.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu kitab sihir?
Dialogue: 0,0:10:00.16,0:10:05.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, itu buku catatan yang sudah lama\Nkami terima dari pedagang keliling.
Dialogue: 0,0:10:05.46,0:10:07.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi, tidak tahu mau dipakai untuk apa.
Dialogue: 0,0:10:17.59,0:10:19.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa tiap kali
Dialogue: 0,0:10:20.01,0:10:24.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}kamu menolong orang,\Nhampir selalu meminta imbalan, Himmel?
Dialogue: 0,0:10:25.07,0:10:29.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mendapat imbalan,\Njadinya tidak ada yang berutang, kan?
Dialogue: 0,0:10:30.19,0:10:32.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita ini grup pahlawan.
Dialogue: 0,0:10:37.45,0:10:44.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang kita inginkan adalah menolong orang,\Nbukan ucapan terima kasih mereka.
Dialogue: 0,0:10:48.34,0:10:51.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mereka sampai berutang pada kita.
Dialogue: 0,0:10:51.88,0:10:55.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita jadi tidak benar-benar\Nmenolong mereka, dong.
Dialogue: 0,0:10:57.01,0:11:02.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanya, sihir konyol seperti ini pun,\Nakan kuterima sebagai imbalan.
Dialogue: 0,0:11:03.25,0:11:04.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Frieren...
Dialogue: 0,0:11:06.49,0:11:09.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti biar kutes, ucapanku\Nbetulan jadi tidak berbelit atau tidak.
Dialogue: 0,0:11:09.61,0:11:12.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ujung-ujungnya Anda cuma\Nmenginginkan sihirnya, lo.
Dialogue: 0,0:11:12.82,0:11:17.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, minta sihir\Nbiar tidak digigit naga bisa kali.
Dialogue: 0,0:11:25.75,0:11:29.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Situasi di luar bagaimana, Frieren?
Dialogue: 0,0:11:29.90,0:11:33.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk sementara, sepertinya kita\Nbelum bisa berangkat.
Dialogue: 0,0:11:33.42,0:11:35.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, sial sekali kita.
Dialogue: 0,0:11:35.59,0:11:38.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Malah tertahan di tempat seperti ini.
Dialogue: 0,0:11:38.32,0:11:40.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hampir mati gara-gara gabut.
Dialogue: 0,0:11:40.51,0:11:42.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukannya karena kebanyakan minum?
Dialogue: 0,0:11:49.26,0:11:51.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian yang semangat, dong.
Dialogue: 0,0:11:51.57,0:11:55.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita ini sedang bertualang\Nuntuk mengalahkan Raja Iblis.
Dialogue: 0,0:11:55.15,0:11:59.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Petualangan itu sudah terhenti\Nselama beberapa hari, lo.
Dialogue: 0,0:11:59.16,0:12:03.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertualang bukan hanya soal\Nberjalan-jalan di luar.
Dialogue: 0,0:12:03.91,0:12:08.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertualang adalah rangkaian\Nhari-hari ampas seperti ini.
Dialogue: 0,0:12:08.33,0:12:11.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada yang bilang ampas, lo.
Dialogue: 0,0:12:12.67,0:12:14.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sedang apa kamu, Himmel?
Dialogue: 0,0:12:15.38,0:12:17.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:12:20.17,0:12:21.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak...
Dialogue: 0,0:12:27.66,0:12:30.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah sepekan kita di kota ini.
Dialogue: 0,0:12:30.02,0:12:32.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Badainya masih saja kencang.
Dialogue: 0,0:12:40.82,0:12:43.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini kapal penyeberangannya\Nbisa berlayar?
Dialogue: 0,0:12:43.41,0:12:45.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurutmu bisa?
Dialogue: 0,0:12:53.59,0:12:56.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kapalku itu bukan peti mati.
Dialogue: 0,0:12:58.65,0:13:00.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:02.77,0:13:07.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, tetap saja bikin kaget,\Nternyata bisa ada badai juga di danau.
Dialogue: 0,0:13:07.39,0:13:11.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Danau Korridor itu danau terbesar\Ndi Kontinen Utara.
Dialogue: 0,0:13:11.65,0:13:14.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan lebih besar daripada\Nlaut pedalaman kasar.
Dialogue: 0,0:13:15.28,0:13:18.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tepi seberangnya memang hampir\Ntidak kelihatan, sih.
Dialogue: 0,0:13:20.03,0:13:24.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pegunungan besar di timur dan baratnya\Nmembuat aliran udara jadi kacau juga.
Dialogue: 0,0:13:24.61,0:13:27.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuacanya akan sangat buruk\Ndi musim seperti sekarang.
Dialogue: 0,0:13:27.83,0:13:31.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak jarang kapal besar\Ntenggelam karena badai.
Dialogue: 0,0:13:32.33,0:13:36.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di angin kencang seperti ini,\Nmustahil menyeberang dengan sihir terbang.
Dialogue: 0,0:13:36.21,0:13:39.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyeberang saat cerah pun akan susah.
Dialogue: 0,0:13:40.15,0:13:42.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisi seberang itu lebih jauh dari bayanganmu.
Dialogue: 0,0:13:43.30,0:13:45.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mungkin masih bisa.
Dialogue: 0,0:13:45.70,0:13:47.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi daya sihir Fern tidak akan cukup.
Dialogue: 0,0:13:48.62,0:13:52.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa tidak bisa jika berjalan\Nmemutari danau?
Dialogue: 0,0:13:52.06,0:13:54.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu pasti juga sulit.
Dialogue: 0,0:13:54.81,0:13:56.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:56.94,0:13:59.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada dasarnya, penyebab cuaca buruk ini—
Dialogue: 0,0:14:01.01,0:14:02.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}adalah pegunungan di timur dan barat.
Dialogue: 0,0:14:03.25,0:14:08.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ingin melewati pegunungan tanpa jalur\Ndi tengah cuaca buruk—
Dialogue: 0,0:14:09.09,0:14:10.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}adalah tindakan bunuh diri.
Dialogue: 0,0:14:11.23,0:14:13.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Daripada ceroboh ambil jalan memutar.
Dialogue: 0,0:14:13.79,0:14:18.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada akhirnya akan lebih cepat dan aman\Nmenunggu beberapa bulan di sini.
Dialogue: 0,0:14:19.10,0:14:23.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untungnya ini adalah pusat perdagangan\Ndan kota pelabuhan yang besar.
Dialogue: 0,0:14:23.22,0:14:26.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat cocok untuk menghabiskan waktu luang.
Dialogue: 0,0:15:08.19,0:15:10.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ujung-ujungnya sampai musim dingin reda.
Dialogue: 0,0:15:11.26,0:15:12.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kapalnya bisa berlayar?
Dialogue: 0,0:15:12.72,0:15:13.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:14.49,0:15:16.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kalian punya ongkos kapalnya?
Dialogue: 0,0:15:17.26,0:15:21.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski bukan sedang badai,\Ntetap saja bukan rute kapal yang aman.
Dialogue: 0,0:15:22.25,0:15:24.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ongkosnya akan lumayan, lo.
Dialogue: 0,0:15:27.41,0:15:29.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sama sekali tidak cukup.
Dialogue: 0,0:15:29.41,0:15:33.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini gara-gara Nona Frieren\Nterlalu banyak beli kitab sihir, lo!
Dialogue: 0,0:15:33.00,0:15:35.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Habisnya aku gabut.
Dialogue: 0,0:15:35.75,0:15:38.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana kalau\Nditukar dengan permintaan?
Dialogue: 0,0:15:39.90,0:15:44.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada biara terbengkalai di pulau depan sana.
Dialogue: 0,0:15:44.26,0:15:46.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi dipasangi penghalang.
Dialogue: 0,0:15:47.05,0:15:51.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sana katanya ada buku hikayat\Npeninggalan Pahlawan Himmel.
Dialogue: 0,0:15:52.10,0:15:57.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pahlawan Himmel sudah menyelamatkan\Nkota ini di generasi kakekku.
Dialogue: 0,0:15:57.69,0:16:00.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah mengaguminya sejak kecil.
Dialogue: 0,0:16:01.42,0:16:04.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang-orang juga menginginkan hikayat itu.
Dialogue: 0,0:16:04.49,0:16:06.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin kalian menemukannya.
Dialogue: 0,0:16:07.62,0:16:09.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hikayat pribadi Himmel?
Dialogue: 0,0:16:09.99,0:16:11.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak salah.
Dialogue: 0,0:16:11.71,0:16:15.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katanya buku hikayat yang belum selesai\Ndia tulis, hilang di tengah perjalanan.
Dialogue: 0,0:16:15.95,0:16:17.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seingatku Himmel kecewa berat.
Dialogue: 0,0:16:21.95,0:16:24.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak kusangka ada di tempat seperti itu.
Dialogue: 0,0:16:25.55,0:16:26.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:16:26.85,0:16:28.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami terima permintaan itu.
Dialogue: 0,0:16:52.24,0:16:54.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu armada kapal?
Dialogue: 0,0:16:54.20,0:16:56.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Betulan kayak laut saja.
Dialogue: 0,0:16:56.12,0:16:57.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:57.25,0:17:01.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu lalang orang dan barang\Nakan ramai saat ini.
Dialogue: 0,0:17:01.96,0:17:04.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ditambah lagi, belum lama ini ada rumor
Dialogue: 0,0:17:04.54,0:17:09.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}di utara katanya ditemukan Negeri Emas,\Nkota yang segalanya terbuat dari emas.
Dialogue: 0,0:17:09.76,0:17:13.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadinya banyak orang yang menyeberang danau.
Dialogue: 0,0:17:13.26,0:17:14.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Negeri Emas?
Dialogue: 0,0:17:14.81,0:17:16.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar enggak, tuh?
Dialogue: 0,0:17:16.56,0:17:18.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana kutahu.
Dialogue: 0,0:17:18.89,0:17:22.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi aku belum pernah bertemu orang\Nyang betulan sampai ke sana.
Dialogue: 0,0:17:23.23,0:17:24.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasti cuma khayalan belaka.
Dialogue: 0,0:17:28.56,0:17:29.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu pulaunya.
Dialogue: 0,0:17:43.03,0:17:45.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan penghalang yang cukup kuat, ya.
Dialogue: 0,0:17:45.96,0:17:49.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya ini dari\Nbeberapa puluh tahun lalu.
Dialogue: 0,0:17:49.01,0:17:53.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal ini biara yang megah,\Nkenapa malah ditinggal begitu saja?
Dialogue: 0,0:17:53.97,0:17:57.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya, atap biara ini runtuh\Nkarena serangan monster.
Dialogue: 0,0:17:57.47,0:17:59.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namanya juga bangunan tua.
Dialogue: 0,0:18:00.22,0:18:01.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:18:01.68,0:18:04.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanya dipasangi penghalang darurat.
Dialogue: 0,0:18:04.81,0:18:06.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa maksudnya itu?
Dialogue: 0,0:18:06.47,0:18:11.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di kebanyakan biara, biasanya disimpan\Nbuku-buku tua yang berharga.
Dialogue: 0,0:18:14.07,0:18:18.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi penghalang ini untuk melindungi\Nbuku yang tidak sempat dibawa pergi.
Dialogue: 0,0:18:21.70,0:18:22.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kulepas.
Dialogue: 0,0:18:22.91,0:18:24.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita jelajahi.
Dialogue: 0,0:18:27.63,0:18:30.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana nasib para biarawan tempat ini?
Dialogue: 0,0:18:31.46,0:18:33.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:18:33.09,0:18:35.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namanya juga sudah lama sekali.
Dialogue: 0,0:18:35.34,0:18:40.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada yang tersisa selain\Nkisah Hikayat Pahlawan Himmel.
Dialogue: 0,0:18:50.57,0:18:52.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perpustakaannya besar sekali.
Dialogue: 0,0:18:53.40,0:18:55.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada patung Tuan Himmel.
Dialogue: 0,0:18:56.37,0:18:58.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Posenya keren juga.
Dialogue: 0,0:19:07.05,0:19:08.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:19:08.38,0:19:10.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasti ini.
Dialogue: 0,0:19:13.81,0:19:17.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, tidak salah lagi ini tulisan Himmel.
Dialogue: 0,0:20:17.47,0:20:19.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang tertulis di dalamnya?
Dialogue: 0,0:20:21.30,0:20:24.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keseharian perjalanan yang konyol.
Dialogue: 0,0:20:27.19,0:20:29.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuma keseharian biasa.
Dialogue: 0,0:20:31.17,0:20:32.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:20:32.09,0:20:33.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Imbalan permintaanmu.
Dialogue: 0,0:20:34.26,0:20:36.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan ini, ongkos kapalnya jadi impas.
Dialogue: 0,0:20:39.51,0:20:44.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku pernah dengar kalau ada\Nelf penyihir di grup pahlawan.
Dialogue: 0,0:20:44.73,0:20:46.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata kamu orangnya.
Dialogue: 0,0:20:47.35,0:20:49.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa berpikir begitu?
Dialogue: 0,0:20:49.48,0:20:53.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mukamu sesedih itu,\Nmau tidak mau aku pasti tahu.
Dialogue: 0,0:20:53.69,0:20:55.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu barang berharga untukmu, kan?
Dialogue: 0,0:20:55.98,0:20:57.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu saja yang bawa.
Dialogue: 0,0:21:00.09,0:21:04.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Toh, di sini pasti ada banyak\Nbuku lain yang berharga.
Dialogue: 0,0:21:04.16,0:21:06.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sudah lebih cukup untuk imbalannya.
Dialogue: 0,0:21:07.87,0:21:10.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang mukaku sampai begitu?
Dialogue: 0,0:21:10.62,0:21:12.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sedikit.
Dialogue: 0,0:21:12.94,0:21:16.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo, kita akan ke sisi seberang\Nsebelum matahari terbenam.
Dialogue: 0,0:21:23.06,0:21:26.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kumpulan kalimat pemungkas ini\Nrasanya tidak perlu, deh.
Dialogue: 0,0:21:26.18,0:21:27.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuma buang-buang halaman saja.
Dialogue: 0,0:21:27.97,0:21:30.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lain kali biar kucoba, ah.
Dialogue: 0,0:21:30.02,0:21:32.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maju sini, dasar monster!
Dialogue: 0,0:21:32.15,0:21:35.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar Stark si Pendekar ini yang jadi lawanmu!
Dialogue: 0,0:21:38.28,0:21:39.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:40.15,0:21:41.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu Kraken!
Dialogue: 0,0:21:42.16,0:21:44.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai ada monster lautnya juga?
Dialogue: 0,0:21:44.66,0:21:46.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gara-gara kamu tantang, sih.
Dialogue: 0,0:21:46.62,0:21:47.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gara-gara aku?
Dialogue: 0,0:21:48.37,0:21:53.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark, kalau tidak segera dihabisi,\Nkapal bakal diseret ke dasar danau—
Dialogue: 0,0:21:54.00,0:21:55.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Nona Frieren!\N- Frieren!
Dialogue: 0,0:21:58.38,0:22:00.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark, kelemahan monster ini adalah—
Dialogue: 0,0:22:00.38,0:22:02.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:22:02.51,0:22:05.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurang lebih begitu, kalian pasti bisa.\NSemangat, ya.
Dialogue: 0,0:22:06.22,0:22:12.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Frieren langsung memanfaatkan sihir\Nuntuk mengatakan kalimat sulit tanpa terbelit.
Dialogue: 0,0:22:12.52,0:22:13.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:13.77,0:22:17.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa kalian berdua bisa setenang itu?
Dialogue: 0,0:22:17.67,0:22:18.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seram, ih.
Dialogue: 0,0:23:50.08,0:23:51.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tebing curam setinggi 3000 meter.\N- Sungguh indah.
Dialogue: 0,0:23:51.45,0:23:53.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Musuh kuat sepadan dengan imbalannya.\N- Kelihatannya merespons daya sihir kita.
Dialogue: 0,0:23:53.75,0:23:57.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kita berhasil mengalahkan Raja Iblis,\Nakan datang masa ketika
Dialogue: 0,0:23:57.92,0:24:00.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}siapa saja bisa melihat pemandangan indah ini.
