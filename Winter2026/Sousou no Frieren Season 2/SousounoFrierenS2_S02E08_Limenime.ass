Dialogue: 0,0:01:29.99,0:01:32.99,6-normal,,0,0,0,,{\bord0\fs70\c&HFCFCFC&\b1\pos(1687,833)}Episode 36: Akhir yang Mulia
Dialogue: 0,0:23:58.25,0:23:59.92,5-normal,,0,0,0,,{\pos(960,393)\fs70\b1\bord0\c&HFCFCFC&\fad(150,0)}Episode 37
Dialogue: 0,0:23:58.25,0:23:59.92,5-normal,,0,0,0,,{\pos(957,700)\fs85\b1\bord0\c&HFCFCFC&\fad(150,0)}Hikayat Himme;
Dialogue: 0,0:02:15.49,0:02:18.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya, memang tidak bisa\Ndilawan dengan mudah.
Dialogue: 0,0:02:21.01,0:02:25.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seolah ada beberapa ahli pedang\Nyang bergerak serempak.
Dialogue: 0,0:02:25.85,0:02:27.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain jumlah serangannya,
Dialogue: 0,0:02:27.71,0:02:31.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}kecepatan reaksi dan staminanya\Njuga beda level dengan manusia.
Dialogue: 0,0:02:32.05,0:02:34.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark juga kewalahan.
Dialogue: 0,0:02:34.02,0:02:37.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jelas akan kalah\Nkalau berakhir adu stamina begini.
Dialogue: 0,0:02:38.87,0:02:41.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mundur dulu mengatur strategi?
Dialogue: 0,0:02:41.94,0:02:42.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:02:42.89,0:02:46.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lawan bergerak lebih cepat,\Nkami akan dikejar dan habis sudah.
Dialogue: 0,0:02:47.77,0:02:49.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini gawat.
Dialogue: 0,0:02:49.11,0:02:51.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar kata Frieren.
Dialogue: 0,0:02:51.07,0:02:53.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gerakan pedangnya seolah tidak terbaca.
Dialogue: 0,0:02:55.15,0:02:56.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:03:01.12,0:03:02.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:03:02.29,0:03:04.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kubilang jangan ditahan mentah-mentah!
Dialogue: 0,0:03:04.63,0:03:05.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Habislah kamu.
Dialogue: 0,0:03:07.88,0:03:10.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia sengaja melakukannya?
Dialogue: 0,0:03:10.43,0:03:11.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tahan banting banget.
Dialogue: 0,0:03:18.26,0:03:21.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark, kamu pendekar yang cerdik.
Dialogue: 0,0:03:21.91,0:03:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berkatmu, jadi muncul sedikit celah.
Dialogue: 0,0:03:33.86,0:03:36.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selesai sudah, Revolte.
Dialogue: 0,0:03:36.53,0:03:38.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu, aku ingat sekarang.
Dialogue: 0,0:03:40.18,0:03:44.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu pasangan penyihir kelas satu\Nyang dulu kubunuh.
Dialogue: 0,0:03:45.34,0:03:48.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Situasinya mirip dengan sekarang.
Dialogue: 0,0:03:48.21,0:03:51.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu pergi membasmi iblis lain
Dialogue: 0,0:03:51.55,0:03:54.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan pasanganmu menjaga desa.
Dialogue: 0,0:03:54.84,0:04:00.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat kembali ke desa,\Nsemuanya sudah terlambat.
Dialogue: 0,0:04:00.51,0:04:03.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu mau tahu akhir rekanmu?
Dialogue: 0,0:04:03.51,0:04:04.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:04:05.21,0:04:09.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mendapat pelajaran\Nyang sangat menarik dari pertarungan itu.
Dialogue: 0,0:04:09.60,0:04:10.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cukup.
Dialogue: 0,0:04:10.97,0:04:12.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kubuat kamu diam.
Dialogue: 0,0:04:14.07,0:04:18.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, ini saran terakhir dariku.
Dialogue: 0,0:04:18.61,0:04:22.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya pastikan jumlah korban selamat\Ndengan lebih teliti.
Dialogue: 0,0:04:24.41,0:04:25.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anak kecil?
Dialogue: 0,0:04:32.43,0:04:33.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sia-sia saja usahamu.
Dialogue: 0,0:04:46.93,0:04:48.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:04:48.35,0:04:50.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku berhasil, Tuan Revolte!
Dialogue: 0,0:04:50.73,0:04:52.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Puji a—
Dialogue: 0,0:04:57.11,0:04:59.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kerja bagus, itu sangat membantu.
Dialogue: 0,0:05:00.70,0:05:02.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pengambilan keputusanku jadi tumpul.
Dialogue: 0,0:05:03.09,0:05:06.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejenak dia terlintas di kepalaku.
Dialogue: 0,0:05:06.24,0:05:10.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin ada anak kecil\Ndi tempat seperti ini.
Dialogue: 0,0:05:12.67,0:05:15.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya dugaanku memang benar.
Dialogue: 0,0:05:15.80,0:05:19.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Manusia punya kebiasaan\Nmelindungi anak-anak.
Dialogue: 0,0:05:21.22,0:05:22.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kebiasaan, ya.
Dialogue: 0,0:05:22.97,0:05:25.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau manusia punya kebiasaan seperti itu,
Dialogue: 0,0:05:25.47,0:05:29.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}dunia pasti akan lebih damai.
Dialogue: 0,0:05:29.61,0:05:34.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejauh yang kutahu, orang bodoh yang mati\Nmelindungi anak tidak dia dikenal
Dialogue: 0,0:05:34.63,0:05:36.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya ada satu.
Dialogue: 0,0:05:39.61,0:05:43.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin anak ini sedikit terlalu baik.
Dialogue: 0,0:05:44.02,0:05:45.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di era mana pun sama.
Dialogue: 0,0:05:46.81,0:05:49.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Penyihir baik hati tidak akan hidup lama.
Dialogue: 0,0:05:50.03,0:05:52.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akhir hayat yang mulia.
Dialogue: 0,0:05:54.94,0:05:57.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata mulutmu bisa pura-pura\Nberkata manis juga.
Dialogue: 0,0:05:58.03,0:06:01.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Genau, kamu ini menyebalkan.
Dialogue: 0,0:06:01.35,0:06:03.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak punya kebaikan hati sedikit pun.
Dialogue: 0,0:06:08.28,0:06:10.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetaplah seperti itu.
Dialogue: 0,0:06:13.31,0:06:15.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sesuai perintah Anda.
Dialogue: 0,0:06:16.18,0:06:20.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menikmati pembunuhan bukanlah seleraku.
Dialogue: 0,0:06:20.63,0:06:22.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kuringankan bebanmu sekarang.
Dialogue: 0,0:06:24.28,0:06:28.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang sebaiknya jangan mengatakan\Nsesuatu yang bukan gayaku.
Dialogue: 0,0:06:37.17,0:06:38.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku terkejut.
Dialogue: 0,0:06:39.21,0:06:45.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata di dunia ini ada pendekar yang bisa\Nmenahan pedangku mentah-mentah.
Dialogue: 0,0:06:46.34,0:06:48.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi kamu masih bisa bergerak?
Dialogue: 0,0:06:48.22,0:06:51.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal lebih baik pura-pura mati.
Dialogue: 0,0:06:51.78,0:06:54.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita yang kalah kalau begitu!
Dialogue: 0,0:06:55.41,0:07:00.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang menang dalam pertarungan adalah\Nmereka yang berdiri hingga akhir!
Dialogue: 0,0:07:01.18,0:07:03.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kukira kamu ini orang baik.
Dialogue: 0,0:07:03.94,0:07:05.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata cuma bodoh.
Dialogue: 0,0:07:06.43,0:07:08.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi pemikiran itu menarik juga.
Dialogue: 0,0:07:11.27,0:07:14.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar kutemani kamu menjemput ajal, Stark.
Dialogue: 0,0:07:15.15,0:07:17.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makin kita terpojok dalam pertarungan,
Dialogue: 0,0:07:17.63,0:07:20.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}makin besar sukacita yang kita\Nrasakan saat bertahan hidup.
Dialogue: 0,0:07:20.99,0:07:23.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku jadi ingin merasakannya.
Dialogue: 0,0:07:23.24,0:07:25.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasa gemetarku sampai tidak bisa berhenti.
Dialogue: 0,0:07:39.06,0:07:40.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harus bagaimana ini?
Dialogue: 0,0:07:43.83,0:07:47.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Frieren sudah menghilang\Nentah sejak kapan.
Dialogue: 0,0:07:51.66,0:07:55.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terkadang melihat santai dari atas\Nsepertinya lumayan juga.
Dialogue: 0,0:08:09.76,0:08:12.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada gunanya menghapus\Ndaya sihir untuk sembunyi.
Dialogue: 0,0:08:14.14,0:08:17.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabut ini kubuat dengan sihir.
Dialogue: 0,0:08:17.75,0:08:21.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan bereaksi pada daya sihir meski\Nhanya sedikit dan menangkapmu.
Dialogue: 0,0:08:22.86,0:08:27.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada makhluk yang bisa menghapus\Ndaya sihir mereka sepenuhnya.
Dialogue: 0,0:08:35.70,0:08:39.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain jarak pandang yang buruk,\Nseranganku juga bisa ditahan.
Dialogue: 0,0:08:40.07,0:08:41.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lawan buruk untukku.
Dialogue: 0,0:08:57.77,0:09:01.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sensasi ini, Fern kelihatannya\Njuga sedang kesusahan.
Dialogue: 0,0:09:02.29,0:09:03.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat bisa dimengerti.
Dialogue: 0,0:09:03.73,0:09:07.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena lawannya iblis\Nyang menggunakan sihir tidak biasa.
Dialogue: 0,0:09:07.49,0:09:08.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Medrozobalt.
Dialogue: 0,0:09:13.28,0:09:15.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Melihat ke mana dirimu?
Dialogue: 0,0:09:15.16,0:09:17.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lawanmu adalah aku.
Dialogue: 0,0:09:17.04,0:09:18.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu itu.
Dialogue: 0,0:09:29.34,0:09:32.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sedangkan lawanku\Nsangat berkebalikan dari tidak biasa.
Dialogue: 0,0:09:32.72,0:09:36.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suku iblis dengan gaya bertarung\Nyang begitu padu.
Dialogue: 0,0:09:36.10,0:09:39.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selaras saat menyerang dan bertahan,\Npondasinya sangat kokoh.
Dialogue: 0,0:09:40.35,0:09:41.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar tanpa celah.
Dialogue: 0,0:09:42.52,0:09:46.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tipe musuh yang tidak boleh dilawan\Nlangsung dari depan.
Dialogue: 0,0:09:51.40,0:09:56.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurasa solusi terbaik adalah bekerja sama\Ndengan Fern untuk mengalahkannya.
Dialogue: 0,0:09:56.58,0:10:00.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, kemungkinan kabut ini juga punya\Nefek deteksi daya sihir yang kuat.
Dialogue: 0,0:10:01.37,0:10:02.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begini terus,
Dialogue: 0,0:10:02.92,0:10:06.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}keahlian bersembunyi Fern\Ntidak bisa dimanfaatkan.
Dialogue: 0,0:10:06.25,0:10:07.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu berarti.
Dialogue: 0,0:10:07.56,0:10:12.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kabut sihir ini hilang,\Nalur pertempuran akan berubah pesat.
Dialogue: 0,0:10:13.30,0:10:15.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saatnya sedikit mengacau.
Dialogue: 0,0:10:26.52,0:10:29.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Membabi buta?\NPola serangannya berubah?
Dialogue: 0,0:10:49.69,0:10:53.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gaya bertarung ini, aku mengenalnya.
Dialogue: 0,0:10:54.05,0:10:58.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mirip gaya bertarung suatu suku\Nyang memburu iblis di Dataran Tinggi Utara.
Dialogue: 0,0:10:59.74,0:11:04.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suku sinting yang mendedikasikan\Nhidup mereka untuk membunuh iblis.
Dialogue: 0,0:11:04.89,0:11:07.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini menarik.
Dialogue: 0,0:11:07.73,0:11:10.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya akan jadi pertarungan yang seru.
Dialogue: 0,0:11:11.05,0:11:13.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari selesaikan ini.
Dialogue: 0,0:11:21.45,0:11:22.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat sekali.
Dialogue: 0,0:11:22.70,0:11:24.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sihirku seolah tidak bisa kena.
Dialogue: 0,0:11:26.71,0:11:28.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari seperti ahli pedang,
Dialogue: 0,0:11:28.88,0:11:33.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}gerakannya berubah jadi bagaikan\Nhewan buas karnivor.
Dialogue: 0,0:11:38.83,0:11:42.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski sudah terluka separah ini,\Ntapi masih bisa terus bertarung.
Dialogue: 0,0:11:43.04,0:11:48.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Fisik luar biasa dan stamina tanpa batas\Nyang jauh berbeda dari manusia.
Dialogue: 0,0:11:48.02,0:11:51.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau terus begini, benar-benar akan\Ndigerus sampai habis.
Dialogue: 0,0:12:47.11,0:12:47.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Genau!
Dialogue: 0,0:12:47.87,0:12:49.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pedangnya!\NSekarang jadi rapuh!
Dialogue: 0,0:12:49.96,0:12:51.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa kita hancurkan!
Dialogue: 0,0:12:51.33,0:12:57.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Konsentrasinya juga sudah tidak cukup\Nuntuk mempertahankan daya sihir pedangnya, ya.
Dialogue: 0,0:12:58.01,0:12:59.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tinggal tiga buah!
Dialogue: 0,0:13:04.89,0:13:06.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:13:06.10,0:13:08.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Firasat aneh apa ini?
Dialogue: 0,0:13:09.10,0:13:11.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serangan babi butanya memang dahsyat.
Dialogue: 0,0:13:11.65,0:13:13.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa hawa membunuhnya\Ntidak bisa kubaca?
Dialogue: 0,0:13:14.35,0:13:17.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, memang peka sekali.
Dialogue: 0,0:13:18.15,0:13:21.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi, sepertinya sedikit terlambat\Nuntuk menyadarinya.
Dialogue: 0,0:13:21.74,0:13:24.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku baru saja selesai menganalisis kabutnya.
Dialogue: 0,0:13:27.27,0:13:29.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka yang hanya tahu bertarung
Dialogue: 0,0:13:29.50,0:13:32.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya akan mengingat sihir\Nuntuk bertarung.
Dialogue: 0,0:13:32.62,0:13:35.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika bukan berasal dari suku\Nyang sama denganku,
Dialogue: 0,0:13:35.88,0:13:38.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}tentu tidak akan bisa memecah situasi ini.
Dialogue: 0,0:13:38.76,0:13:43.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena mereka tidak tahu\Nbahwa sihir itu menyenangkan.
Dialogue: 0,0:13:47.71,0:13:49.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Erilfrachte.
Dialogue: 0,0:13:56.64,0:13:58.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabutnya menghilang?
Dialogue: 0,0:13:59.02,0:14:00.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tindakan yang sia-sia.
Dialogue: 0,0:14:01.55,0:14:04.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabut bisa kuciptakan sebanyak\Nyang kumau.
Dialogue: 0,0:14:09.05,0:14:11.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ke mana perginya anak gadis itu?
Dialogue: 0,0:14:22.72,0:14:24.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Daya sihir Hemmung sudah lenyap.
Dialogue: 0,0:14:39.11,0:14:40.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serangan?
Dialogue: 0,0:14:40.23,0:14:41.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari mana datangnya?
Dialogue: 0,0:14:55.04,0:14:56.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Zoltraak.
Dialogue: 0,0:15:00.75,0:15:02.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari sejauh itu—
Dialogue: 0,0:15:12.02,0:15:14.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agar jalurnya tidak diprediksi.
Dialogue: 0,0:15:14.18,0:15:17.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menembak dari jarak super jauh\Ndi luar area deteksi.
Dialogue: 0,0:15:17.94,0:15:19.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kerja bagus, Fern.
Dialogue: 0,0:15:19.27,0:15:20.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu hebat.
Dialogue: 0,0:15:22.86,0:15:26.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saya tidak ingin melakukan\Npertarungan sesulit ini lagi.
Dialogue: 0,0:15:36.25,0:15:37.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dua!
Dialogue: 0,0:15:40.13,0:15:41.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu!
Dialogue: 0,0:15:51.09,0:15:53.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selesai sudah, Revolte.
Dialogue: 0,0:16:01.03,0:16:03.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tangan kosong tidak bisa jadi senjata.
Dialogue: 0,0:16:03.69,0:16:05.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itulah pemikiran manusia.
Dialogue: 0,0:16:06.17,0:16:10.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Asumsi bahwa saat kehilangan senjata,\Nmaka tidak bisa bertarung lagi.
Dialogue: 0,0:16:11.19,0:16:13.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku yang menang.
Dialogue: 0,0:16:14.16,0:16:16.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Asumsi, ya.
Dialogue: 0,0:16:16.39,0:16:19.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau manusia atau iblis sepertinya sama saja.
Dialogue: 0,0:16:20.03,0:16:23.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu tidak tahu seberapa\Nkeras kepalanya manusia.
Dialogue: 0,0:16:35.91,0:16:37.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tebasan Sinar Langit!
Dialogue: 0,0:16:43.65,0:16:45.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Digardnacht.
Dialogue: 0,0:17:04.08,0:17:07.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buatku, kamu terlihat seperti orang baik.
Dialogue: 0,0:17:08.63,0:17:12.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih mencoba melindungi desa\Nyang sudah seperti ini.
Dialogue: 0,0:17:13.44,0:17:15.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu sesuatu yang tidak bisa kulakukan.
Dialogue: 0,0:17:29.70,0:17:32.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih mencoba menyelamatkanku, ya...
Dialogue: 0,0:17:37.33,0:17:39.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kuduga
Dialogue: 0,0:17:40.01,0:17:42.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}kamu ini orang baik.
Dialogue: 0,0:18:15.82,0:18:17.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Methode?
Dialogue: 0,0:18:18.29,0:18:21.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi-lagi aku gagal menemui ajalku, ya?
Dialogue: 0,0:18:21.37,0:18:23.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya begitu.
Dialogue: 0,0:18:23.62,0:18:25.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cukup, aku sudah bisa bergerak.
Dialogue: 0,0:18:30.42,0:18:31.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark bagaimana?
Dialogue: 0,0:18:31.63,0:18:35.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kondisinya memang mengkhawatirkan,\Ntapi berhasil diselamatkan.
Dialogue: 0,0:18:37.26,0:18:40.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena penyembuhan dirinya\Nlebih diprioritaskan daripada Genau.
Dialogue: 0,0:18:52.74,0:18:54.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:18:54.03,0:18:56.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anda tidak puas?
Dialogue: 0,0:18:56.03,0:18:59.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, dia sudah bekerja keras.
Dialogue: 0,0:19:00.79,0:19:05.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Frieren dan kawan-kawan kelihatannya\Nakan tinggal di desa untuk sementara waktu.
Dialogue: 0,0:19:23.93,0:19:27.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kondisiku, sudah lumayan membaik.
Dialogue: 0,0:19:27.93,0:19:29.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia malah push up.
Dialogue: 0,0:19:29.51,0:19:33.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mungkin Tuan Stark itu\Nsebenarnya adalah monster?
Dialogue: 0,0:19:33.52,0:19:35.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jahat.
Dialogue: 0,0:19:35.07,0:19:38.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, tidak ada\Npendeta di grup kalian.
Dialogue: 0,0:19:39.35,0:19:43.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah misi ini selesai,\Nsaya akan bebas tugas untuk sementara.
Dialogue: 0,0:19:43.70,0:19:45.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mau, apa perlu saya temani?
Dialogue: 0,0:19:46.83,0:19:50.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dataran Tinggi Kontinen Utara itu berbahaya\Ntanpa adanya sihir milik pendeta.
Dialogue: 0,0:19:51.29,0:19:52.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.
Dialogue: 0,0:19:52.71,0:19:56.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Walau tidak bisa pakai sihir tingkat tinggi\Nseperti sihir penyembuh,
Dialogue: 0,0:19:56.24,0:19:59.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}sedikit banyak,\Naku bisa memakai sihir pendeta.
Dialogue: 0,0:20:00.43,0:20:03.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Toh, kalau situasinya betulan bahaya,\Nkami akan lari.
Dialogue: 0,0:20:03.91,0:20:05.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selama ini kami selalu melakukannya.
Dialogue: 0,0:20:06.98,0:20:11.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlebih, aku masih ingin mengosongkan\Nposisi pendeta grup ini.
Dialogue: 0,0:20:12.65,0:20:15.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena mungkin suatu saat\Nakan bertemu lagi.
Dialogue: 0,0:20:15.86,0:20:16.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu—
Dialogue: 0,0:20:17.95,0:20:21.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau ada Methode,\Nentah kenapa suasana hati Fern jadi jelek.
Dialogue: 0,0:20:21.99,0:20:23.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, aduh.
Dialogue: 0,0:20:23.24,0:20:25.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saya dibenci, ya.
Dialogue: 0,0:20:25.00,0:20:28.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi saya juga sangat menyukai Fern, lo.
Dialogue: 0,0:20:28.75,0:20:31.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat marah pun tetap manis.
Dialogue: 0,0:20:32.04,0:20:33.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Methode.
Dialogue: 0,0:20:33.58,0:20:35.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ordo Kesatria Norm sudah tiba.
Dialogue: 0,0:20:36.08,0:20:40.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita juga akan ikut mengawal\Nsampai ke Kontinen Selatan.
Dialogue: 0,0:20:40.76,0:20:42.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:42.93,0:20:45.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami berpisah dengan kalian di sini.
Dialogue: 0,0:20:47.14,0:20:49.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark, kondisi lukamu bagaimana?
Dialogue: 0,0:20:50.98,0:20:53.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sama sekali tidak ada masalah!
Dialogue: 0,0:20:53.27,0:20:54.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:20:55.42,0:20:57.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku jadi berutang pada kalian.
Dialogue: 0,0:20:57.91,0:21:00.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelak pasti akan kubalas.
Dialogue: 0,0:21:00.03,0:21:01.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Genau.
Dialogue: 0,0:21:03.67,0:21:04.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ucapkan terima kasih.
Dialogue: 0,0:21:08.05,0:21:10.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, kami tertolong.
Dialogue: 0,0:21:11.38,0:21:14.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami juga.\NAyo sama-sama hidup panjang.
Dialogue: 0,0:21:17.17,0:21:18.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:21:18.38,0:21:19.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:21:20.21,0:21:21.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai jumpa.
Dialogue: 0,0:21:21.68,0:21:22.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:22.89,0:21:24.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai jumpa di lain tempat.
Dialogue: 0,0:21:53.75,0:21:56.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, yakin mau ditolak?
Dialogue: 0,0:21:58.46,0:22:00.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal Methode.
Dialogue: 0,0:22:01.02,0:22:03.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pendeta grup ini Sein, kan?
Dialogue: 0,0:22:03.72,0:22:05.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan itu maksudku.
Dialogue: 0,0:22:05.43,0:22:07.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wanita dewasa yang cantik, lo.
Dialogue: 0,0:22:07.39,0:22:10.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah Sein bakal protes ini itu\Nsaat gabung lagi?
Dialogue: 0,0:22:10.91,0:22:12.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak jadi masalah, kan?
Dialogue: 0,0:22:12.69,0:22:16.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagian grup ini sudah punya wanita dewasa.
Dialogue: 0,0:22:17.15,0:22:19.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga itu.
Dialogue: 0,0:23:49.99,0:23:51.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tergantung imbalannya.\N- Bukankah naga memang biasa bergerombol?
Dialogue: 0,0:23:51.53,0:23:52.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Benar-benar sial.\N- Bukankah naga memang biasa bergerombol?
Dialogue: 0,0:23:52.24,0:23:53.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Kita ini grup pahlawan.\N- Bukankah naga memang biasa bergerombol?
Dialogue: 0,0:23:53.83,0:23:54.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Kita ini grup pahlawan.\N- Gabut seakan mau mati.
Dialogue: 0,0:23:54.62,0:23:56.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Spartan banget.\N- Itu impianku sejak kecil.
Dialogue: 0,0:23:56.66,0:23:58.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Memang apa isinya?\N- Itu impianku sejak kecil.
Dialogue: 0,0:23:58.25,0:23:59.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hikayat Himmel.
