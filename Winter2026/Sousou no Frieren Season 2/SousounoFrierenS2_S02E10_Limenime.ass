Dialogue: 0,0:09:16.08,0:09:19.08,6-normal,,0,0,0,,{\bord0\fs70\c&HFCFCFC&\b1\pos(1687,833)}Episode 38: Pemandangan Indah
Dialogue: 0,0:09:19.08,0:09:22.16,6-normal,,0,0,0,,{\bord0\fs65\c&HFAFDFD&\b1\pos(1532,170)}30 tahun setelah kematian pahlawan Himmel\NPadang Salju Schmal, Dataran Tinggi Benua Utara
Dialogue: 0,0:01:33.92,0:01:36.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ngarai ini dalam sekali.
Dialogue: 0,0:01:36.33,0:01:38.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasarnya sama sekali tidak kelihatan.
Dialogue: 0,0:01:39.05,0:01:41.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini tebing curam setinggi 3000 meter.
Dialogue: 0,0:01:41.98,0:01:45.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ngarai paling dalam di kontinen ini.
Dialogue: 0,0:01:45.51,0:01:49.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buah dari betapa tingginya\NDataran Tinggi Kontinen Utara.
Dialogue: 0,0:01:49.01,0:01:52.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, bagaimana cara menyeberanginya?
Dialogue: 0,0:01:54.17,0:01:56.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anginnya kencang sekali.
Dialogue: 0,0:01:56.01,0:01:58.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini tidak bisa diseberangi\Ndengan sihir terbang.
Dialogue: 0,0:01:58.80,0:02:02.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya belum lama ini juga\Nada kejadian seperti itu.
Dialogue: 0,0:02:03.85,0:02:07.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau naik sampai ke hulu,\Nkita bisa menyeberang lewat sungai.
Dialogue: 0,0:02:07.38,0:02:10.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi harus melewati daerah\Npegunungan yang terjal,
Dialogue: 0,0:02:10.57,0:02:12.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}jadi akan lumayan memutar.
Dialogue: 0,0:02:13.23,0:02:15.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagian hilirnya bagaimana?
Dialogue: 0,0:02:15.64,0:02:19.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisi yang menghadap laut pun\Ntebing curam setinggi 3000 meter.
Dialogue: 0,0:02:20.59,0:02:23.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kudengar pemandangannya sangat indah,\Nmau coba ke sana?
Dialogue: 0,0:02:23.50,0:02:24.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak usah.
Dialogue: 0,0:02:25.28,0:02:30.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimanapun, kalau begini akan butuh\Ndua pekan untuk menyeberang.
Dialogue: 0,0:02:30.80,0:02:32.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lumayan lama juga.
Dialogue: 0,0:02:32.72,0:02:35.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, sepertinya tidak ada pilihan lain.
Dialogue: 0,0:02:37.23,0:02:39.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mungkin sekarang sudah mau jadi, ya?
Dialogue: 0,0:02:39.76,0:02:41.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maksud Anda apa?
Dialogue: 0,0:02:42.73,0:02:45.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pokoknya kita coba ke dulu pergi ke hulu.
Dialogue: 0,0:02:45.69,0:02:49.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau beruntung, mungkin di tengah jalan\Nkita bisa menyeberang.
Dialogue: 0,0:02:55.47,0:02:56.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Frieren!
Dialogue: 0,0:02:57.12,0:02:58.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kelihatan.
Dialogue: 0,0:02:58.62,0:03:00.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keren juga.
Dialogue: 0,0:03:00.08,0:03:02.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan itu jembatan, ya?
Dialogue: 0,0:03:02.87,0:03:03.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:03.69,0:03:05.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya sudah jadi.
Dialogue: 0,0:03:06.81,0:03:08.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gehen.
Dialogue: 0,0:03:08.58,0:03:10.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lama tidak jumpa, Frieren.
Dialogue: 0,0:03:10.92,0:03:13.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jembatannya sudah jadi, ya.
Dialogue: 0,0:03:13.68,0:03:14.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:03:14.91,0:03:15.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Beliau siapa?
Dialogue: 0,0:03:16.40,0:03:17.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia Gehen.
Dialogue: 0,0:03:17.89,0:03:21.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dwarf yang membangun jembatan\Ndi sini sejak 200 tahun lalu.
Dialogue: 0,0:03:21.56,0:03:22.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keren amat.
Dialogue: 0,0:03:23.40,0:03:25.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi aku kaget.
Dialogue: 0,0:03:25.20,0:03:27.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau ada jembatan sebagus ini,
Dialogue: 0,0:03:27.66,0:03:30.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}seharusnya wajar kalau jadi\Njalur lalu lintas yang penting.
Dialogue: 0,0:03:31.21,0:03:33.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi aku sama sekali tidak dengar kabarnya.
Dialogue: 0,0:03:34.03,0:03:37.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi kukira masih belum selesai.
Dialogue: 0,0:03:37.24,0:03:41.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Frieren, sebenarnya ada satu masalah.
Dialogue: 0,0:03:51.50,0:03:53.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti kalian lihat.
Dialogue: 0,0:03:53.00,0:03:56.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada monster burung raksasa\Nyang membuat angin kencang.
Dialogue: 0,0:03:56.88,0:04:01.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempo hari saja, rombongan pedagang\Nyang menuju Negeri Emas,
Dialogue: 0,0:04:01.18,0:04:03.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}terempas bersama kereta kudanya.
Dialogue: 0,0:04:03.39,0:04:07.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah begitu, monster itu terus muncul\Nsampai tak terhitung jumlahnya.
Dialogue: 0,0:04:07.53,0:04:10.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya mereka membuat\Nsarang besar di dekat sini.
Dialogue: 0,0:04:10.94,0:04:14.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itulah jembatan ini\Njadi tidak bisa dipakai.
Dialogue: 0,0:04:14.78,0:04:19.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untungnya, sarang mereka sepertinya\Nada di tepian sebelah sini.
Dialogue: 0,0:04:19.50,0:04:22.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kamu bisa berbuat sesuatu\Nuntuk mengatasinya?
Dialogue: 0,0:04:22.72,0:04:26.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini jembatan yang kubangun selama 200 tahun.
Dialogue: 0,0:04:26.12,0:04:27.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Imbalannya?
Dialogue: 0,0:04:27.50,0:04:31.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sihir membalik panekuk dengan sempurna.
Dialogue: 0,0:04:31.81,0:04:33.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bahan-bahannya juga ada.
Dialogue: 0,0:04:33.67,0:04:36.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Besok kalian bisa makan\Nsarapan yang mewah.
Dialogue: 0,0:04:37.97,0:04:39.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami terima.
Dialogue: 0,0:04:48.89,0:04:51.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurut cerita Gehen,\Nberarti sekitar sini.
Dialogue: 0,0:04:51.98,0:04:54.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya terjal sekali.
Dialogue: 0,0:04:54.62,0:04:56.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:04:56.54,0:04:58.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau jatuh, sama dengan setor nyawa, lo.
Dialogue: 0,0:05:12.40,0:05:16.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, kenapa Gehen\Nmembuat jembatan di ngarai ini?
Dialogue: 0,0:05:18.11,0:05:20.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin karena penyesalan.
Dialogue: 0,0:05:21.22,0:05:22.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:22.51,0:05:25.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jembatannya masih dibangun,\Nsayang sekali.
Dialogue: 0,0:05:26.38,0:05:28.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rencananya kapan selesai?
Dialogue: 0,0:05:28.56,0:05:31.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin selamanya tidak akan jadi.
Dialogue: 0,0:05:31.10,0:05:33.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dana pembangunan juga sudah habis.
Dialogue: 0,0:05:34.80,0:05:37.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat disayangkan.
Dialogue: 0,0:05:37.11,0:05:40.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal aku punya waktu\Nsebanyak yang kumau.
Dialogue: 0,0:05:40.99,0:05:45.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa Gehen membuat jembatan\Ndi tempat seperti ini?
Dialogue: 0,0:05:46.60,0:05:52.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu, desaku yang ada di dekat sini\Ndiserang suku iblis.
Dialogue: 0,0:05:52.57,0:05:57.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasukan paling dekat dari sini,\Nditempatkan di kota seberang tepi.
Dialogue: 0,0:06:00.06,0:06:05.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika saat itu di sini ada jembatan,\Nsemuanya pasti selamat.
Dialogue: 0,0:06:09.43,0:06:11.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gunakanlah ini.
Dialogue: 0,0:06:11.54,0:06:13.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini imbalan yang kami terima
Dialogue: 0,0:06:13.52,0:06:16.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}saat merebut pedang pusaka\Nsuatu bangsawan dari tangan iblis.
Dialogue: 0,0:06:17.86,0:06:19.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jumlahnya banyak sekali.
Dialogue: 0,0:06:20.69,0:06:21.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa kuterima.
Dialogue: 0,0:06:21.99,0:06:26.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak punya bayaran yang setimpal\Nuntuk menerima ini.
Dialogue: 0,0:06:28.49,0:06:30.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada jembatan ini.
Dialogue: 0,0:06:31.68,0:06:36.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jembatannya baru akan jadi,\Npaling cepat setelah kamu mati karena usia.
Dialogue: 0,0:06:39.23,0:06:41.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar Frieren yang menerima bayarannya.
Dialogue: 0,0:06:43.52,0:06:47.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buatlah dengan kokoh\Nhingga tahan selama seribu tahun.
Dialogue: 0,0:06:49.00,0:06:50.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:06:50.59,0:06:52.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:07:47.07,0:07:48.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketemu.
Dialogue: 0,0:07:48.78,0:07:50.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita habisi.
Dialogue: 0,0:08:08.55,0:08:09.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menunduk!
Dialogue: 0,0:08:15.40,0:08:16.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gehen.
Dialogue: 0,0:08:17.27,0:08:19.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kami bereskan.
Dialogue: 0,0:08:19.36,0:08:21.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, Frieren.
Dialogue: 0,0:08:21.52,0:08:26.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berkatmu, ngarai ini sekarang\Nbisa dilalui dengan bebas.
Dialogue: 0,0:08:26.98,0:08:29.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu mau apa setelah ini, Gehen?
Dialogue: 0,0:08:33.13,0:08:36.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan santai menikmati\Nmasa tuaku di desa.
Dialogue: 0,0:08:36.62,0:08:37.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:43.77,0:08:45.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, dia sudah pulang.
Dialogue: 0,0:08:45.76,0:08:47.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pas sekali waktunya.
Dialogue: 0,0:08:47.67,0:08:50.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baguslah, Gehen,\Nmalam ini kita ada pesta.
Dialogue: 0,0:08:52.34,0:08:54.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Frieren.
Dialogue: 0,0:08:54.81,0:08:59.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau ada 200 tahun,\Ndesa baru bisa dibangun.
Dialogue: 0,0:09:00.35,0:09:02.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:08.67,0:09:11.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya sudah, ayo berangkat.
Dialogue: 0,0:09:26.63,0:09:28.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:28.67,0:09:32.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Uang saku perjalanan kita,\Nsudah tinggal sedikit.
Dialogue: 0,0:09:32.57,0:09:33.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:33.80,0:09:36.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Entah cukup untuk hidup sepekan atau tidak.
Dialogue: 0,0:09:39.35,0:09:42.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh, ini karena Anda selalu saja\Nbeli yang tidak penting.
Dialogue: 0,0:09:43.21,0:09:48.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, kita juga tidak bisa apa-apa\Ndi tengah padang salju begini.
Dialogue: 0,0:09:49.16,0:09:51.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:09:51.20,0:09:53.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak salah sekitar sini...
Dialogue: 0,0:09:56.43,0:09:57.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita akan ganti jalur.
Dialogue: 0,0:09:57.95,0:10:00.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin bisa dapat uang.
Dialogue: 0,0:10:03.87,0:10:05.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat ini...
Dialogue: 0,0:10:05.38,0:10:07.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya bukan permukiman.
Dialogue: 0,0:10:07.96,0:10:09.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat kemah para petualang, ya?
Dialogue: 0,0:10:09.88,0:10:13.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian semua!\NAyo semangat hari ini!
Dialogue: 0,0:10:13.51,0:10:15.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Ya!
Dialogue: 0,0:10:15.23,0:10:17.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:10:17.39,0:10:22.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perkemahan para petualang yang berkumpul\Nmencari Kristal Salju Suci.
Dialogue: 0,0:10:23.28,0:10:25.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kristal Salju Suci?
Dialogue: 0,0:10:26.02,0:10:29.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mineral yang terbentuk\Ndi padang salju ini.
Dialogue: 0,0:10:29.79,0:10:32.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa dijadikan bahan baku obat sihir.
Dialogue: 0,0:10:32.15,0:10:35.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Barang langka yang hanya bisa\Ndidapatkan di daerah ini
Dialogue: 0,0:10:35.28,0:10:36.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan harganya sangat tinggi.
Dialogue: 0,0:10:36.91,0:10:38.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:38.33,0:10:42.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita bakal cari Kristal Salju Suci itu\Nuntuk dapat uang perjalanan.
Dialogue: 0,0:10:42.94,0:10:45.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark memang masih polos, ya.
Dialogue: 0,0:10:45.67,0:10:49.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kristal Salju Suci bukan sesuatu\Nyang mudah dicari.
Dialogue: 0,0:10:49.04,0:10:50.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanya mahal.
Dialogue: 0,0:10:51.09,0:10:53.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terus mau dapat uang dari mana?
Dialogue: 0,0:10:53.93,0:10:57.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo pergi ke pasar yang berjualan\Nke para petualang.
Dialogue: 0,0:10:58.25,0:11:00.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita bisa lihat sesuatu yang menarik.
Dialogue: 0,0:11:04.27,0:11:08.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatan tidak beda sama pasar biasa, tuh.
Dialogue: 0,0:11:09.01,0:11:10.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coba lihat harganya.
Dialogue: 0,0:11:11.59,0:11:14.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu roti harganya satu koin perak.
Dialogue: 0,0:11:14.55,0:11:16.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepuluh kali lebih tinggi dari harga pasaran.
Dialogue: 0,0:11:17.27,0:11:20.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena mereka jualan pada petualang kaya
Dialogue: 0,0:11:20.19,0:11:23.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}yang mencari nafkah\Ndari menambang Kristal Salju Suci.
Dialogue: 0,0:11:23.80,0:11:26.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harga barang akan naik dibanding daerah lain.
Dialogue: 0,0:11:28.13,0:11:30.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:11:30.55,0:11:34.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada dua alasan kenapa\NKristal Salju Suci bisa mahal.
Dialogue: 0,0:11:34.73,0:11:37.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu, karena kelangkaannya.
Dialogue: 0,0:11:37.01,0:11:42.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Satu lagi karena ada di daerah berbahaya\Ntempat monster buas berkeliaran.
Dialogue: 0,0:11:42.83,0:11:45.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian paham maksudku?
Dialogue: 0,0:11:45.30,0:11:47.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau harga barang-barangnya tinggi,
Dialogue: 0,0:11:47.60,0:11:51.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}imbalan permintaan penumpasan\Njuga akan naik, ya?
Dialogue: 0,0:11:51.27,0:11:53.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Fern memang pintar.
Dialogue: 0,0:11:54.33,0:11:59.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sini ada urat tambang besar\Nyang hanya diketahui warga sekitar.
Dialogue: 0,0:11:59.83,0:12:02.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin monster\Nyang bersarang di sini dibasmi.
Dialogue: 0,0:12:03.39,0:12:04.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:12:05.13,0:12:09.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah pembasmian selesai, tolong pasang\Npenghalang antimanusia di sini.
Dialogue: 0,0:12:09.46,0:12:11.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Penghalang antimanusia?
Dialogue: 0,0:12:11.09,0:12:12.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:12.13,0:12:14.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin agar tidak dimasuki orang.
Dialogue: 0,0:12:16.05,0:12:18.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, akan kami terima.
Dialogue: 0,0:12:19.54,0:12:20.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski begitu.
Dialogue: 0,0:12:20.91,0:12:25.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Permintaannya aneh sekali, sampai minta\Npasang penghalang antimanusia.
Dialogue: 0,0:12:25.01,0:12:29.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menambang juga butuh waktu\Nmengumpulkan orang dan dananya.
Dialogue: 0,0:12:29.48,0:12:34.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memasang penghalang antimanusia\Nuntuk mengamankan tempat agar tidak diserobot
Dialogue: 0,0:12:34.36,0:12:36.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukan hal yang asing.
Dialogue: 0,0:12:38.03,0:12:40.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo berangkat dulu ke lokasi pembasmian.
Dialogue: 0,0:12:56.88,0:12:58.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:12:58.89,0:13:00.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Monsternya besar sekali.
Dialogue: 0,0:13:00.63,0:13:02.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan sampai lengah.
Dialogue: 0,0:13:02.64,0:13:05.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sampai dijadikan permintaan,
Dialogue: 0,0:13:05.14,0:13:08.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}berarti petualang di perkemahan\Ntidak berkutik melawannya.
Dialogue: 0,0:13:08.39,0:13:10.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau lengah bisa mati.
Dialogue: 0,0:13:11.23,0:13:14.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Musuh kuat yang sepadan\Ndengan imbalannya, ya.
Dialogue: 0,0:13:15.69,0:13:17.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo kita kalahkan dia.
Dialogue: 0,0:13:53.34,0:13:56.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya bereaksi ke daya sihir kita.
Dialogue: 0,0:13:56.19,0:13:57.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Merepotkan sekali.
Dialogue: 0,0:14:01.40,0:14:03.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia ini cepat sekali!
Dialogue: 0,0:14:07.37,0:14:08.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Stark.
Dialogue: 0,0:14:08.58,0:14:10.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sana lari.
Dialogue: 0,0:14:10.54,0:14:12.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku punya rencana bagus.
Dialogue: 0,0:14:13.50,0:14:14.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:14:17.92,0:14:19.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lebih tinggi.
Dialogue: 0,0:15:26.99,0:15:29.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuat sekali dia ini.
Dialogue: 0,0:15:34.79,0:15:36.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Frieren?
Dialogue: 0,0:15:36.12,0:15:37.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diam dulu.
Dialogue: 0,0:15:39.50,0:15:41.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa ini?
Dialogue: 0,0:15:41.97,0:15:45.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Monster tadi sepertinya\Npenunggu sekitar sini.
Dialogue: 0,0:15:45.83,0:15:50.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mencium daya sihirnya melemah,\Nmonster lain pasti jadi berkumpul kemari.
Dialogue: 0,0:15:50.43,0:15:52.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana ini, Frieren?
Dialogue: 0,0:15:52.53,0:15:55.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih kuat kalau harus\Nmenggendong kalian lari.
Dialogue: 0,0:15:56.34,0:15:57.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah tidak sempat.
Dialogue: 0,0:15:58.63,0:16:00.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita terkepung?
Dialogue: 0,0:16:01.29,0:16:03.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yah, bagaimanapun,
Dialogue: 0,0:16:03.33,0:16:07.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}kalau tidak dikalahkan semua,\Npermintaan tidak bisa dibilang selesai.
Dialogue: 0,0:16:07.07,0:16:09.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang daya sihir kalian cukup?
Dialogue: 0,0:16:09.89,0:16:11.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saya tidak apa-apa.
Dialogue: 0,0:16:12.91,0:16:14.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harus kita lakukan.
Dialogue: 0,0:16:29.27,0:16:31.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ordo Kesatria Norm?
Dialogue: 0,0:16:33.60,0:16:37.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami mengejar monster di daerah ini\Nyang pergerakannya mencurigakan.
Dialogue: 0,0:16:38.10,0:16:40.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata ada Anda sekalian.
Dialogue: 0,0:16:40.04,0:16:42.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, kami jadi tertolong.
Dialogue: 0,0:16:43.15,0:16:45.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Justru kami yang berterima kasih.
Dialogue: 0,0:16:46.99,0:16:49.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah mendapat laporan\Ndari Tuan Norm.
Dialogue: 0,0:16:49.57,0:16:51.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya Anda sudah banyak membantu kami.
Dialogue: 0,0:16:53.08,0:16:55.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan ini utangnya impas, ya.
Dialogue: 0,0:16:59.40,0:17:00.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami permisi.
Dialogue: 0,0:17:02.98,0:17:06.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sampai ke pelosok begini,\Nhebat sekali.
Dialogue: 0,0:17:06.73,0:17:11.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katanya mereka pasukan yang berpatroli\Ndi satu wilayah kekuasaan.
Dialogue: 0,0:17:14.43,0:17:18.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya Dataran Tinggi Kontinen Utara\Nsedikit demi sedikit mulai berubah.
Dialogue: 0,0:17:19.86,0:17:22.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, sekarang sudah malam.
Dialogue: 0,0:17:22.46,0:17:24.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Malam ini kita berkemah di sini.
Dialogue: 0,0:17:32.34,0:17:36.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Frieren!\NIni sudah pagi, ayo bangun!
Dialogue: 0,0:17:38.59,0:17:40.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lima jam lagi...
Dialogue: 0,0:17:41.17,0:17:42.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti mati beku, lo.
Dialogue: 0,0:17:47.09,0:17:49.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Daripada itu, tolong lihat ini.
Dialogue: 0,0:17:50.67,0:17:54.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Urat bijih Kristal Salju Suci\Nbersinar indah kena sinar matahari.
Dialogue: 0,0:17:58.06,0:17:59.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:18:02.32,0:18:06.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang tujuan kita kali ini adalah\Nmendapat uang perjalanan.
Dialogue: 0,0:18:06.91,0:18:10.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi siapa sangka malah bertemu\Npemandangan seperti ini.
Dialogue: 0,0:18:10.03,0:18:12.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat indah.
Dialogue: 0,0:18:12.43,0:18:16.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini sangat sepadan sebagai harga\Nuntuk menumpas Raja Iblis.
Dialogue: 0,0:18:19.90,0:18:22.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kita mengalahkan Raja Iblis,
Dialogue: 0,0:18:22.32,0:18:27.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}akan tiba masa ketika semua orang\Nbisa melihat pemandangan indah ini.
Dialogue: 0,0:18:30.11,0:18:32.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin tidak sampai semua orang.
Dialogue: 0,0:18:32.93,0:18:37.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi sudah tiba masa ketika banyak orang\Nbisa melihat pemandangan ini.
Dialogue: 0,0:18:38.31,0:18:40.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasanya sungguh aneh.
Dialogue: 0,0:18:42.73,0:18:45.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar indah, ya.
Dialogue: 0,0:18:45.12,0:18:46.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:47.24,0:18:50.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi itu pun akan dihancurkan\Noleh tangan manusia.
Dialogue: 0,0:18:51.24,0:18:55.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agak sedih rasanya, tapi ini juga\Nbagaimana zaman berlalu.
Dialogue: 0,0:18:57.29,0:19:01.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya sudah, setelah kita lihat sebentar lagi,\Nayo pasang penghalang dan kembali.
Dialogue: 0,0:19:03.62,0:19:05.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, kami terbantu.
Dialogue: 0,0:19:06.29,0:19:08.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini imbalan yang dijanjikan.
Dialogue: 0,0:19:09.77,0:19:12.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan ini, urat tambang itu bisa dilindungi.
Dialogue: 0,0:19:12.68,0:19:13.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dilindungi?
Dialogue: 0,0:19:13.67,0:19:16.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi bukan penghalang untuk ditambang?
Dialogue: 0,0:19:16.61,0:19:19.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku adalah petualang asal wilayah ini.
Dialogue: 0,0:19:20.57,0:19:24.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Melihat pemandangan indah itu\Nmembuatku ingin jadi petualang.
Dialogue: 0,0:19:27.47,0:19:28.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuucapkan terima kasih.
Dialogue: 0,0:19:29.09,0:19:31.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berkat kalian, pemandangan dari\Nkampung halamanku bisa dijaga.
Dialogue: 0,0:19:33.22,0:19:34.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:19:39.73,0:19:42.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Melindungi kampung halaman seseorang\Nmemang mantap, ya.
Dialogue: 0,0:19:43.75,0:19:45.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:19:46.97,0:19:48.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau diingat lagi,
Dialogue: 0,0:19:49.35,0:19:52.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Heiter mungkin sudah\Nmelindungi kampung halamanku.
Dialogue: 0,0:19:54.63,0:19:58.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski tanah kampung halamanku\Nhilang karena perang,
Dialogue: 0,0:19:58.68,0:20:02.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}berkatnya, aku tidak sampai\Nkehilangan kenangan berhargaku.
Dialogue: 0,0:20:10.66,0:20:11.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:20:12.67,0:20:16.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat cerita soal kabur\Ndari kampung halaman.
Dialogue: 0,0:20:16.07,0:20:20.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Fern bilang itu tidak ada hubungannya\Ndan percaya padaku.
Dialogue: 0,0:20:22.79,0:20:23.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak salah.
Dialogue: 0,0:20:24.43,0:20:27.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Fern selalu memberiku dorongan, ya.
Dialogue: 0,0:20:27.33,0:20:28.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:20:35.59,0:20:38.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena Nona Frieren pasti akan melakukannya.
Dialogue: 0,0:20:58.71,0:21:03.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nona Frieren, kenapa beli alat sihir\Npadahal harganya selangit di sini?
Dialogue: 0,0:21:04.16,0:21:06.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena ini barang berharga.
Dialogue: 0,0:21:06.66,0:21:10.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya kita bakal kesulitan\Nsoal uang perjalanan lagi.
Dialogue: 0,0:21:11.37,0:21:15.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya sudah mengira itu terjadi,\Njadi separuh sudah saya sembunyikan.
Dialogue: 0,0:21:15.21,0:21:16.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang benar, nih?
Dialogue: 0,0:21:17.07,0:21:18.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Fern memang hebat.
Dialogue: 0,0:21:20.15,0:21:22.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu baru namanya muridku.
Dialogue: 0,0:21:24.13,0:21:25.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yakin boleh begitu?
Dialogue: 0,0:21:57.67,0:21:59.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya sudah, ayo berangkat.
Dialogue: 0,0:22:05.34,0:22:08.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia penyihir kelas dua bernama Edel.
Dialogue: 0,0:22:09.13,0:22:11.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Spesialis sihir mental.
Dialogue: 0,0:22:12.22,0:22:16.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengajaknya\Nuntuk memeriksa ulang tempat ini.
Dialogue: 0,0:22:16.42,0:22:21.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Informasi yang dia dapatkan,\Nkurasa akan berguna untukmu.
Dialogue: 0,0:22:22.99,0:22:25.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Denken, ulurkan tanganmu.
Dialogue: 0,0:22:25.58,0:22:27.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kuberikan ingatanku.
Dialogue: 0,0:22:30.14,0:22:31.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:22:40.71,0:22:43.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan ini serah terima sudah selesai.
Dialogue: 0,0:22:45.11,0:22:50.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Misimu adalah memelihara dan mengawasi\Npenghalang yang menyegel Negeri Emas.
Dialogue: 0,0:22:50.89,0:22:54.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebisa mungkin, jangan bertindak\Nyang tidak perlu.
Dialogue: 0,0:23:01.40,0:23:02.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Denken.
Dialogue: 0,0:23:03.99,0:23:06.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyerah saja untuk berziarah makam.
Dialogue: 0,0:23:07.49,0:23:09.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:23:13.93,0:23:16.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia sudah siap untuk mati.
Dialogue: 0,0:23:17.39,0:23:19.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sedikit iri dengannya.
Dialogue: 0,0:23:20.19,0:23:24.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena aku tidak bisa melawan\Nperintah Nona Serie.
Dialogue: 0,0:23:27.66,0:23:31.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Musuhnya adalah anggota terakhir dan terkuat\Ndari Tujuh Mahardika Kehancuran.
Dialogue: 0,0:23:32.77,0:23:35.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Macht sang Nagari Emas.
Dialogue: 0,0:23:37.23,0:23:41.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maju untuk menyelamatkan kampung halamannya\Nyang sudah diubah jadi emas.
Dialogue: 0,0:23:42.86,0:23:47.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah seperti dongeng pahlawan saja.
