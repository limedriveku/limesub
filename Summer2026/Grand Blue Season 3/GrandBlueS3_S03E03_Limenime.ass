Dialogue: 0,0:00:00.00,0:00:00.27,sign,,0000,0000,0000,,ACARA INI ADALAH KARYA FIKSI.
Dialogue: 0,0:00:00.27,0:00:00.58,sign,,0000,0000,0000,,ANAK DI BAWAH UMUR DILARANG KERAS\NMINUM ALKOHOL OLEH HUKUM.
Dialogue: 0,0:00:00.58,0:00:01.09,sign,,0000,0000,0000,,KAMI JUGA TIDAK BERMAKSUD MENGANJURKAN\NPEMAKSAAN MINUM ALKOHOL,
Dialogue: 0,0:00:01.09,0:00:01.79,sign,,0000,0000,0000,,KONSUMSI ALKOHOL BERLEBIHAN, MAUPUN TINDAKAN\NTIDAK SENONOH SAAT PESTA MINUM.
Dialogue: 0,0:00:01.79,0:00:02.40,sign,,0000,0000,0000,,MOHON ANGGAP INI SEMATA-MATA\NSEBAGAI ANIME KOMEDI.
Dialogue: 0,0:00:02.40,0:00:03.10,sign,,0000,0000,0000,,SELURUH KARAKTER YANG MENGONSUMSI\NALKOHOL DALAM KARYA INI
Dialogue: 0,0:00:03.10,0:00:03.68,sign,,0000,0000,0000,,TELAH BERUSIA 20 TAHUN ATAU LEBIH.
Dialogue: 0,0:00:03.68,0:00:04.38,sign,,0000,0000,0000,,DEMI MENYESUAIKAN DENGAN STANDAR\NKEPATUHAN TERKINI.
Dialogue: 0,0:00:04.38,0:00:04.98,sign,,0000,0000,0000,,MULAI MUSIM INI\NUKURAN SENSOR HITAM KAMI NAIK 5%.
Dialogue: 0,0:00:17.29,0:00:25.30,sign,,0000,0000,0000,,GRAND BLUE MUSIM 3
Dialogue: 0,0:01:34.99,0:01:38.45,sign,,0000,0000,0000,,PENGINAPAN KITAHARA
Dialogue: 0,0:05:31.56,0:05:32.92,sign,,0000,0000,0000,,PEMBUNUH NAGA, LAUT
Dialogue: 0,0:06:45.26,0:06:47.26,sign,,0000,0000,0000,,RUANG PINUS
Dialogue: 0,0:10:35.99,0:10:38.99,sign,,0000,0000,0000,,PENGINAPAN KITAHARA
Dialogue: 0,0:11:17.03,0:11:20.49,sign,,0000,0000,0000,,SAMPO RELAKSASI YOIMACHI KIRARA
Dialogue: 0,0:11:20.49,0:11:22.24,sign,,0000,0000,0000,,RUANG PINUS
Dialogue: 0,0:13:17.23,0:13:21.74,sign,,0000,0000,0000,,MUSIM SEMI BIRU
Dialogue: 0,0:13:21.74,0:13:24.37,sign,,0000,0000,0000,,KIRARA: KAK KOUHEI...
Dialogue: 0,0:13:24.37,0:13:27.41,sign,,0000,0000,0000,,AKU INGIN JADI ANAK TK SUNGGUHAN
Dialogue: 0,0:13:27.41,0:13:30.05,sign,,0000,0000,0000,,HILANGKAN KUTUKANNYA, CIUM DIA,
Dialogue: 0,0:13:30.05,0:13:31.75,sign,,0000,0000,0000,,AKU AKAN JADI ANAK TK CUMA BUATMU!
Dialogue: 0,0:13:59.90,0:14:02.91,sign,,0000,0000,0000,,MUSIM SEMI BIRU
Dialogue: 0,0:14:37.06,0:14:40.53,sign,,0000,0000,0000,,KHUSUS 18+, KLIK KALAU SUDAH DEWASA
Dialogue: 0,0:14:48.58,0:14:49.68,sign,,0000,0000,0000,,ACAK-ACAK DIA, MINTA DIACAK-ACAK,
Dialogue: 0,0:14:49.68,0:14:51.08,sign,,0000,0000,0000,,MINTA DIACAK-ACAK PAKAI BAJU TK
Dialogue: 0,0:17:21.23,0:17:23.73,sign,,0000,0000,0000,,PASPOR JEPANG
Dialogue: 0,0:17:39.37,0:17:41.87,sign,,0000,0000,0000,,PENGINAPAN KITAHARA
Dialogue: 0,0:18:22.91,0:18:23.66,sign,,0000,0000,0000,,RUANG PINUS
Dialogue: 0,0:20:19.66,0:20:21.41,sign,,0000,0000,0000,,RUANG PINUS
Dialogue: 0,0:21:20.84,0:21:22.30,sign,,0000,0000,0000,,PENGINAPAN KITAHARA
Dialogue: 0,0:21:22.30,0:21:24.60,sign,,0000,0000,0000,,HIDUP MESRA DI PENGINAPAN
Dialogue: 0,0:23:44.94,0:23:49.95,sign,,0000,0000,0000,,SELANJUTNYA: LAUT PALAU
Dialogue: 0,0:01:45.46,0:01:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya.
Dialogue: 0,0:01:47.07,0:01:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak, Neng Shiori.
Dialogue: 0,0:01:48.98,0:01:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:01:50.61,0:01:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski bukan aku yang masak, sih.
Dialogue: 0,0:01:53.47,0:01:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Kitahara makan beginian dari kecil?
Dialogue: 0,0:01:56.51,0:01:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mewah banget.
Dialogue: 0,0:01:57.90,0:01:59.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak saja.
Dialogue: 0,0:01:59.42,0:02:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma boleh makan sisa\Nyang hampir kedaluwarsa.
Dialogue: 0,0:02:02.48,0:02:05.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sampai jenuh makan sasyimi kering.
Dialogue: 0,0:02:05.55,0:02:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:02:07.23,0:02:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak yang menyiapkan makan\Nwaktu aku masih kecil.
Dialogue: 0,0:02:11.84,0:02:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya orang tua kami sibuk.
Dialogue: 0,0:02:14.05,0:02:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:02:15.24,0:02:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi setelah besar, itu jadi tugasnya.\N- Sepuluh, dua puluh tahun dari sekarang.
Dialogue: 0,0:02:18.48,0:02:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kakak, waktunya makan siang.\N- Sepuluh, dua puluh tahun dari sekarang.
Dialogue: 0,0:02:20.64,0:02:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketuk dulu, dong!
Dialogue: 0,0:02:22.50,0:02:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:02:25.00,0:02:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan adik perempuan, ya?
Dialogue: 0,0:02:26.99,0:02:29.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Redamlah niat membunuhmu.
Dialogue: 0,0:02:29.81,0:02:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta dibuatkan bekal saja kalau pulang.
Dialogue: 0,0:02:32.51,0:02:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang boleh, Neng Shiori?
Dialogue: 0,0:02:34.27,0:02:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, boleh saja.
Dialogue: 0,0:02:36.14,0:02:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Chisa juga mau?
Dialogue: 0,0:02:38.61,0:02:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:02:39.58,0:02:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:02:41.39,0:02:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf merepotkanmu.
Dialogue: 0,0:02:43.58,0:02:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sangat...
Dialogue: 0,0:02:45.23,0:02:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak merepotkan, kok.
Dialogue: 0,0:02:48.02,0:02:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku senang.
Dialogue: 0,0:02:50.21,0:02:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang?
Dialogue: 0,0:02:51.73,0:02:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, membayangkan kalian pulang\Ndengan gembira di kereta...
Dialogue: 0,0:02:57.53,0:03:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Chisa membawa onigiri buatanku.
Dialogue: 0,0:03:01.26,0:03:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Imamura\Nmembawa tamagoyaki buatanku.
Dialogue: 0,0:03:05.25,0:03:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggilan "kakak"-nya mana?
Dialogue: 0,0:03:06.54,0:03:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Kakak yang berseri-seri\Nmembawa paspor buatanku.
Dialogue: 0,0:03:12.00,0:03:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja sudah membuatku senang.
Dialogue: 0,0:03:15.23,0:03:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neng Shiori...
Dialogue: 0,0:03:16.48,0:03:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak yang baik.
Dialogue: 0,0:03:18.06,0:03:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasporku mau diotak-atik?
Dialogue: 0,0:03:21.81,0:03:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuperhatikan, Shiori juga pakai yukata, ya.
Dialogue: 0,0:03:24.96,0:03:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, karena kerjaan hari ini sudah selesai.
Dialogue: 0,0:03:28.24,0:03:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dikira masih bekerja\Nkalau pakai kimono.
Dialogue: 0,0:03:31.69,0:03:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:03:33.02,0:03:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga, yukata bikin kamu kayak tamu.
Dialogue: 0,0:03:35.95,0:03:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yukata juga cocok sama Neng Shiori.
Dialogue: 0,0:03:39.02,0:03:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terlihat imut.
Dialogue: 0,0:03:40.40,0:03:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:43.20,0:03:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu, Kak?
Dialogue: 0,0:03:45.60,0:03:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:03:46.71,0:03:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang cocok dan pas banget, sih.
Dialogue: 0,0:03:50.32,0:03:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurang sentuhan terakhir\Nuntuk memancing mereka.
Dialogue: 0,0:03:54.46,0:03:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya dia tidak seksi.
Dialogue: 0,0:03:57.07,0:04:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kalau Kakak pandangi terus...
Dialogue: 0,0:04:01.17,0:04:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal muntah.
Dialogue: 0,0:04:02.72,0:04:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf.
Dialogue: 0,0:04:04.78,0:04:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud aneh, kok.
Dialogue: 0,0:04:08.43,0:04:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:04:09.73,0:04:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba buka atasanmu.
Dialogue: 0,0:04:12.00,0:04:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh...
Dialogue: 0,0:04:13.22,0:04:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasih lihat belahan dadamu sedikit.
Dialogue: 0,0:04:15.40,0:04:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu adik kandungmu, Bedebah.
Dialogue: 0,0:04:19.17,0:04:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya itu normal sebagai saudara?
Dialogue: 0,0:04:23.37,0:04:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Kak.
Dialogue: 0,0:04:24.94,0:04:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:04:25.49,0:04:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:04:26.62,0:04:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau malam ini kalian berjaga di kamarku,
Dialogue: 0,0:04:31.20,0:04:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya aku tidur di mana?
Dialogue: 0,0:04:33.88,0:04:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, soal itu...
Dialogue: 0,0:04:35.36,0:04:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidur bareng Kak Kouhei, lah.
Dialogue: 0,0:04:39.14,0:04:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ogah sekamar sama kami?
Dialogue: 0,0:04:41.62,0:04:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, amit-amit...
Dialogue: 0,0:04:44.14,0:04:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma Kakak, sih, oke.
Dialogue: 0,0:04:47.64,0:04:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau di kamar Chisa?
Dialogue: 0,0:04:50.29,0:04:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, mau saja.
Dialogue: 0,0:04:52.38,0:04:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya Kak Chisa terganggu.
Dialogue: 0,0:04:54.62,0:04:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja, kok.
Dialogue: 0,0:04:56.29,0:04:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa?
Dialogue: 0,0:04:57.53,0:05:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya belakangan ini\Nada penguntit meresahkan.
Dialogue: 0,0:05:00.91,0:05:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja tadi siang ada polisi.
Dialogue: 0,0:05:03.41,0:05:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya!
Dialogue: 0,0:05:04.54,0:05:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa diampuni!
Dialogue: 0,0:05:06.93,0:05:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo tidur bersama.
Dialogue: 0,0:05:09.29,0:05:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:05:11.02,0:05:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ya.
Dialogue: 0,0:05:12.06,0:05:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya ada apa-apa.
Dialogue: 0,0:05:16.05,0:05:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastinya kami juga\Nakan berjuang melindungi Shiori.
Dialogue: 0,0:05:20.00,0:05:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi adik perempuan kesayanganku.
Dialogue: 0,0:05:22.55,0:05:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:24.45,0:05:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan adikmu, Imamura.
Dialogue: 0,0:05:27.31,0:05:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, beri aku paspornya setelah...
Dialogue: 0,0:05:29.68,0:05:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu.
Dialogue: 0,0:05:30.75,0:05:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:32.92,0:05:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal tadi siang.
Dialogue: 0,0:05:35.57,0:05:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bawakan minuman\Nuntuk meminta maaf.
Dialogue: 0,0:05:38.88,0:05:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tidak usah.
Dialogue: 0,0:05:40.24,0:05:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah terlalu dipikirkan.
Dialogue: 0,0:05:42.57,0:05:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga, silakan!
Dialogue: 0,0:05:43.94,0:05:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oke.
Dialogue: 0,0:05:45.18,0:05:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:05:46.58,0:05:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, mana dua orang itu?
Dialogue: 0,0:05:49.97,0:05:53.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, mereka kembali ke kamar duluan.
Dialogue: 0,0:05:53.08,0:05:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya mereka diam-diam\Nmelakukan sesuatu di belakangku.
Dialogue: 0,0:05:58.84,0:06:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyembunyikan\Nhasil fotonya dariku.
Dialogue: 0,0:06:01.58,0:06:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu malah bisik-bisik\Nsambil membaca peta.
Dialogue: 0,0:06:05.74,0:06:06.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:06:06.56,0:06:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas, kan?
Dialogue: 0,0:06:08.48,0:06:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:06:09.72,0:06:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamar mereka di mana?
Dialogue: 0,0:06:12.12,0:06:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ruang pinus.
Dialogue: 0,0:06:18.16,0:06:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang pinus, ya.
Dialogue: 0,0:06:19.44,0:06:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:06:20.86,0:06:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berempat sudah berteman?
Dialogue: 0,0:06:23.46,0:06:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tidak.
Dialogue: 0,0:06:25.62,0:06:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya akan terjadi hal bodoh lagi.
Dialogue: 0,0:06:28.74,0:06:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, silakan duduk.
Dialogue: 0,0:06:31.50,0:06:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:06:33.18,0:06:36.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, mumpung mereka sedang pergi.
Dialogue: 0,0:06:36.50,0:06:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, dengan senang hati!
Dialogue: 0,0:06:39.25,0:06:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin berbincang\Ntentang budaya Jepang.
Dialogue: 0,0:06:43.34,0:06:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:50.51,0:06:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:06:54.27,0:06:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:06:56.19,0:06:59.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dari pihak berwajib.
Dialogue: 0,0:07:07.28,0:07:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mah jelas banget.
Dialogue: 0,0:07:08.93,0:07:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, saking jelasnya malah janggal.
Dialogue: 0,0:07:12.37,0:07:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski pikiran kita beda,\Nkesimpulannya tetap sama.
Dialogue: 0,0:07:16.67,0:07:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kalian berdua.
Dialogue: 0,0:07:18.82,0:07:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus diisolasi di kamar ini.
Dialogue: 0,0:07:24.67,0:07:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:07:27.68,0:07:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kugel!
Dialogue: 0,0:07:28.37,0:07:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Stroh!
Dialogue: 0,0:07:29.68,0:07:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bocah yang tadi siang, kan?
Dialogue: 0,0:07:32.70,0:07:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih mau tanding lawan kami?
Dialogue: 0,0:07:35.79,0:07:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja kita lupa, Kouhei.
Dialogue: 0,0:07:38.19,0:07:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Kitahara.
Dialogue: 0,0:07:41.19,0:07:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berpikir\Nkuat minum alkohol itu hebat.
Dialogue: 0,0:07:44.94,0:07:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sayangnya kami anggota Pab.
Dialogue: 0,0:07:48.75,0:07:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana boleh diremehkan begini!
Dialogue: 0,0:07:54.58,0:07:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka belum kapok juga.
Dialogue: 0,0:07:57.04,0:08:00.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum alkohol ringan saja\Nmasih butuh air.
Dialogue: 0,0:08:00.21,0:08:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkohol yang biasa kami minum ini.
Dialogue: 0,0:08:04.51,0:08:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadarnya sekitar 35%.
Dialogue: 0,0:08:07.72,0:08:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan bagi kami, ini belum apa-apa.
Dialogue: 0,0:08:11.58,0:08:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka cuma orang Jepang\Nyang enggak kuat minum.
Dialogue: 0,0:08:14.85,0:08:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan tandingan kita\Nyang dijuluki Pemabuk Gila.
Dialogue: 0,0:08:18.35,0:08:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kasihan,\Ncampurkan air tonik saja.
Dialogue: 0,0:08:21.46,0:08:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:08:22.48,0:08:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:08:23.48,0:08:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain alkohol, bagaimana kalau\Nadu minum penawar juga?
Dialogue: 0,0:08:30.49,0:08:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tidak tahu malunya\Nmereka minta minum air?
Dialogue: 0,0:08:34.35,0:08:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa samurai cuma ada di anime, ya?
Dialogue: 0,0:08:38.00,0:08:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, oke.
Dialogue: 0,0:08:40.15,0:08:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adu minum penawar juga boleh.
Dialogue: 0,0:08:42.25,0:08:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo bersulang.
Dialogue: 0,0:08:43.75,0:08:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:08:52.14,0:08:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menyerah?
Dialogue: 0,0:08:53.90,0:08:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan satu ronde saja sudah hebat, lo.
Dialogue: 0,0:08:57.68,0:09:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penawarnya kami minum, ya!
Dialogue: 0,0:09:00.90,0:09:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai air putih pun,\Nmustahil kalian menang.
Dialogue: 0,0:09:07.15,0:09:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:09:08.45,0:09:11.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jelas-jelas bukan air.
Dialogue: 0,0:09:11.66,0:09:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penawar macam apa ini?
Dialogue: 0,0:09:14.16,0:09:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:09:16.85,0:09:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkohol manis memang kurang mantap.
Dialogue: 0,0:09:19.90,0:09:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisnya berlebihan.
Dialogue: 0,0:09:22.29,0:09:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, kenapa malah kaget?
Dialogue: 0,0:09:25.78,0:09:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian salah paham, ya?
Dialogue: 0,0:09:28.80,0:09:31.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:09:31.12,0:09:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak kuat oleh rasa manisnya,\Nbukan kadar alkoholnya.
Dialogue: 0,0:09:35.81,0:09:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkohol kami justru yang ini.
Dialogue: 0,0:09:38.56,0:09:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya kalian cuma penawar.
Dialogue: 0,0:09:44.50,0:09:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:09:45.36,0:09:48.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini Neng Shiori aman.
Dialogue: 0,0:09:48.32,0:09:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka mereka sefanatik ini.
Dialogue: 0,0:09:51.98,0:09:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antusiasmenya luar biasa.
Dialogue: 0,0:09:54.82,0:09:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai datang ke Jepang segala.
Dialogue: 0,0:09:57.98,0:10:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, cuma karena sehobi...
Dialogue: 0,0:10:01.83,0:10:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:02.96,0:10:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru sadar sesuatu.
Dialogue: 0,0:10:05.36,0:10:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:06.34,0:10:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sirkel yang hobinya sama, kan?
Dialogue: 0,0:10:10.62,0:10:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:11.84,0:10:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti si Karina itu juga sama, dong?
Dialogue: 0,0:10:18.60,0:10:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mau bahas apa?
Dialogue: 0,0:10:21.18,0:10:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujawab semampunya.
Dialogue: 0,0:10:24.43,0:10:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:10:26.36,0:10:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu aku mau bertanya
Dialogue: 0,0:10:29.86,0:10:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soal budaya hentai Jepang.
Dialogue: 0,0:10:42.50,0:10:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Budaya hentai?
Dialogue: 0,0:10:44.90,0:10:45.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:10:45.75,0:10:48.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salah paham dulu.
Dialogue: 0,0:10:48.19,0:10:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang meneliti Shunga,\Nkaryanya Hokusai.
Dialogue: 0,0:10:51.51,0:10:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maksudmu Katsushika Hokusai?
Dialogue: 0,0:10:54.56,0:10:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar karyanya terkenal\Nsampai ke luar negeri.
Dialogue: 0,0:10:57.26,0:11:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku kurang tahu, sih.
Dialogue: 0,0:11:00.88,0:11:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku juga.
Dialogue: 0,0:11:02.88,0:11:05.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:11:05.02,0:11:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin bertanya\Nsoal budaya sehari-hari.
Dialogue: 0,0:11:10.02,0:11:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang gaya hidup orang Jepang?
Dialogue: 0,0:11:12.14,0:11:14.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu kami bisa bantu.
Dialogue: 0,0:11:14.78,0:11:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, contohnya...
Dialogue: 0,0:11:17.03,0:11:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tata krama di onsen.
Dialogue: 0,0:11:23.02,0:11:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cewek itu sejenis mereka?
Dialogue: 0,0:11:25.50,0:11:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:11:28.50,0:11:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dipercaya cewek seanggun itu\Nsama anehnya.
Dialogue: 0,0:11:33.26,0:11:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi cuma itu alasan masuk akal\Ndia bisa bersama mereka.
Dialogue: 0,0:11:37.20,0:11:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, bersama dua orang ini\Nsama saja dengan penyiksaan.
Dialogue: 0,0:11:41.76,0:11:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diingat-ingat, penguntit waktu itu\Nbertubuh ramping.
Dialogue: 0,0:11:45.65,0:11:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:11:47.23,0:11:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian.
Dialogue: 0,0:11:48.51,0:11:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin tanya\Nsoal cewek bernama Karina itu.
Dialogue: 0,0:11:52.78,0:11:54.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:11:54.02,0:11:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:11:55.30,0:11:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouhei, pakai penerjemahnya.
Dialogue: 0,0:11:57.38,0:11:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:59.52,0:12:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kutanyakan.
Dialogue: 0,0:12:04.16,0:12:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu kami soal Karina.
Dialogue: 0,0:12:07.07,0:12:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat tertarik pada Karina.
Dialogue: 0,0:12:10.02,0:12:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:11.17,0:12:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang dia sukai dari Jepang?
Dialogue: 0,0:12:13.95,0:12:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bisa membuatnya\Njatuh hati ke orang Jepang?
Dialogue: 0,0:12:17.05,0:12:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:12:17.78,0:12:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asmara!
Dialogue: 0,0:12:18.98,0:12:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori dan Chisa aman, kan?
Dialogue: 0,0:12:21.65,0:12:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa akur sama keluargaku, kan?
Dialogue: 0,0:12:24.93,0:12:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:12:26.08,0:12:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikahlah!
Dialogue: 0,0:12:30.26,0:12:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang mendukung pernikahan\Ninternasional antarmahasiswa.
Dialogue: 0,0:12:34.00,0:12:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topik dari mana, tuh?
Dialogue: 0,0:12:36.69,0:12:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanyakan apa yang akan dia inginkan\Ndari Shiori dan Chisa!
Dialogue: 0,0:12:40.40,0:12:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang Karina inginkan\Ndari gadis-gadis siang itu?
Dialogue: 0,0:12:43.95,0:12:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis-gadis siang?
Dialogue: 0,0:12:45.65,0:12:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, dua gadis yang mirip Kirara?
Dialogue: 0,0:12:48.46,0:12:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pencinta Kirara\Ndari gim Musim Semi Biru.
Dialogue: 0,0:12:51.81,0:12:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ingin mewujudkan adegan gim\Nlewat Shiori dan Chisa?
Dialogue: 0,0:12:56.34,0:12:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa dia tidak tahu Musim Semi Biru?
Dialogue: 0,0:12:58.94,0:13:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi khawatir sama rumah\Ntangganya dengan Karina.
Dialogue: 0,0:13:02.85,0:13:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang apa?
Dialogue: 0,0:13:04.90,0:13:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah, suaranya tidak terekam.
Dialogue: 0,0:13:08.35,0:13:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, masa sampai sebegitunya?
Dialogue: 0,0:13:13.79,0:13:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belum paham juga?
Dialogue: 0,0:13:16.16,0:13:17.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya?
Dialogue: 0,0:13:17.23,0:13:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merealisasikan adegan gim kencan
Dialogue: 0,0:13:20.39,0:13:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah mimpi umat manusia!
Dialogue: 0,0:13:21.74,0:13:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun pasti berharap alur seperti gim
Dialogue: 0,0:13:24.37,0:13:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau bertemu orang yang semirip itu!
Dialogue: 0,0:13:27.41,0:13:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama adegan yang itu!
Dialogue: 0,0:13:36.25,0:13:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita memang sepaham, sobatku!
Dialogue: 0,0:13:38.56,0:13:39.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:13:39.44,0:13:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:13:40.72,0:13:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya semirip itu?
Dialogue: 0,0:13:42.38,0:13:45.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya aku keburu bertemu\NNeng Rarako!
Dialogue: 0,0:13:45.78,0:13:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Sihir Rarako?
Dialogue: 0,0:13:47.92,0:13:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukainya\Nsetara Musim Semi Biru, lo!
Dialogue: 0,0:13:50.46,0:13:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok urusan begini kalian bisa nyambung?
Dialogue: 0,0:13:54.15,0:13:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami benar-benar cinta gim ini!
Dialogue: 0,0:13:56.90,0:13:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim Semi Biru sudah bagaikan hidupku!
Dialogue: 0,0:13:59.90,0:14:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham! Aku paham!
Dialogue: 0,0:14:02.91,0:14:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah alasan kami
Dialogue: 0,0:14:05.16,0:14:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat ingin dia memakai ini.
Dialogue: 0,0:14:07.33,0:14:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mewujudkan hidup\Nyang kuimpikan!
Dialogue: 0,0:14:10.21,0:14:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin melihat Shiori\Nmemakai baju itu!
Dialogue: 0,0:14:15.65,0:14:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim Semi Biru, ya.
Dialogue: 0,0:14:18.05,0:14:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kita harus bersujud.
Dialogue: 0,0:14:21.03,0:14:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin bakal berhasil?
Dialogue: 0,0:14:22.91,0:14:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal sujud, serahkan padaku.
Dialogue: 0,0:14:25.71,0:14:27.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Sobat!
Dialogue: 0,0:14:27.55,0:14:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo maju!
Dialogue: 0,0:14:28.90,0:14:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke!
Dialogue: 0,0:14:29.62,0:14:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:14:30.54,0:14:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:14:32.04,0:14:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi?
Dialogue: 0,0:14:33.49,0:14:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja menelusuri gimnya.
Dialogue: 0,0:14:37.06,0:14:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gim porno, tahu!
Dialogue: 0,0:14:43.82,0:14:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa?
Dialogue: 0,0:14:45.65,0:14:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya pasang wajah begitu.
Dialogue: 0,0:14:48.58,0:14:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acak-acak, acak-acak, acak-acak!
Dialogue: 0,0:14:51.08,0:14:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim cabul apa ini!
Dialogue: 0,0:14:53.29,0:14:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana boleh diwujudkan!
Dialogue: 0,0:14:56.27,0:14:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ngomong apa, sih?
Dialogue: 0,0:14:58.26,0:15:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bedakan gim dan kenyataan.
Dialogue: 0,0:15:00.14,0:15:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan halu.
Dialogue: 0,0:15:02.09,0:15:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian Shiori mana sudi sama hal begitu.
Dialogue: 0,0:15:05.92,0:15:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja mengkhawatirkan.
Dialogue: 0,0:15:09.60,0:15:12.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah cukup dewasa.
Dialogue: 0,0:15:12.59,0:15:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percayalah pada penilaiannya.
Dialogue: 0,0:15:15.35,0:15:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan ini menguntungkan buatmu.
Dialogue: 0,0:15:18.62,0:15:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mananya?
Dialogue: 0,0:15:19.86,0:15:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi dia sibuk sama kami,\Nkamu bisa menggeledah rumah.
Dialogue: 0,0:15:25.65,0:15:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, waktunya berpencar!
Dialogue: 0,0:15:28.27,0:15:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:15:29.54,0:15:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:15:30.49,0:15:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, woi!
Dialogue: 0,0:15:32.24,0:15:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih mau menghalangi?
Dialogue: 0,0:15:34.03,0:15:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, pakai kekerasan pun...
Dialogue: 0,0:15:36.62,0:15:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belah dua!
Dialogue: 0,0:15:40.13,0:15:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa tadi?
Dialogue: 0,0:15:42.61,0:15:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada, kok.
Dialogue: 0,0:15:50.39,0:15:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai handuknya masuk air.
Dialogue: 0,0:15:53.36,0:15:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah etika di onsen.
Dialogue: 0,0:15:55.76,0:15:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:15:59.15,0:16:02.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, luar biasa.
Dialogue: 0,0:16:02.16,0:16:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:03.65,0:16:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih bagus lagi kalau turun salju.
Dialogue: 0,0:16:06.47,0:16:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan salju, ya.
Dialogue: 0,0:16:09.15,0:16:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandian terbuka bersalju\Nmemang indah.
Dialogue: 0,0:16:11.87,0:16:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku ingin melihatnya.
Dialogue: 0,0:16:13.91,0:16:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berendam di air hangat di cuaca dingin.
Dialogue: 0,0:16:17.39,0:16:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmat sekali.
Dialogue: 0,0:16:20.18,0:16:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tanpa busana,
Dialogue: 0,0:16:22.17,0:16:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka memang seakan keluar\Ndari adegan Musim Semi Biru.
Dialogue: 0,0:16:27.15,0:16:32.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi pengin mewujudkan\Nadegan selanjutnya juga.
Dialogue: 0,0:16:32.43,0:16:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba gurita muncul entah dari mana,
Dialogue: 0,0:16:35.68,0:16:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan situasinya jadi kayak Shunga!
Dialogue: 0,0:16:39.44,0:16:41.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Karina?
Dialogue: 0,0:16:41.30,0:16:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf.
Dialogue: 0,0:16:42.88,0:16:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan hiraukan aku.
Dialogue: 0,0:16:44.99,0:16:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Chisa, tatapannya tadi...
Dialogue: 0,0:16:47.95,0:16:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuek banget!
Dialogue: 0,0:16:50.32,0:16:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh? Dia tidak melihat tatapan tadi?
Dialogue: 0,0:16:54.32,0:16:55.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisa.
Dialogue: 0,0:16:55.74,0:16:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berendam,
Dialogue: 0,0:16:58.08,0:17:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo main di kamarku.
Dialogue: 0,0:17:01.09,0:17:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang kumaksud, Kak Chisa!
Dialogue: 0,0:17:04.69,0:17:06.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh.
Dialogue: 0,0:17:06.81,0:17:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:17:07.55,0:17:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok mau, sih?
Dialogue: 0,0:17:09.83,0:17:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tatapannya seseram itu.
Dialogue: 0,0:17:13.32,0:17:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seakan-akan
Dialogue: 0,0:17:14.47,0:17:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia terbiasa ditatap begitu.
Dialogue: 0,0:17:24.51,0:17:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menjatuhkan ini.
Dialogue: 0,0:17:26.31,0:17:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:28.24,0:17:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bawa paspor?
Dialogue: 0,0:17:30.62,0:17:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini punya kakakku.
Dialogue: 0,0:17:33.78,0:17:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya kakakmu?
Dialogue: 0,0:17:35.49,0:17:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok ada di kamu?
Dialogue: 0,0:17:37.81,0:17:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritanya panjang.
Dialogue: 0,0:17:41.87,0:17:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah ceritanya.
Dialogue: 0,0:17:43.68,0:17:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:17:45.13,0:17:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indahnya!
Dialogue: 0,0:17:46.22,0:17:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah?
Dialogue: 0,0:17:47.88,0:17:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya kamu cemburu, kan?
Dialogue: 0,0:17:50.45,0:17:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu marah karena ingin perhatian\Nkakak tersayangmu, kan?
Dialogue: 0,0:17:55.06,0:17:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eng...
Dialogue: 0,0:17:56.74,0:17:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali bukan.
Dialogue: 0,0:17:58.67,0:18:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma ingin menyadarkan kakakku\Nyang tidak memikirkan masa depannya.
Dialogue: 0,0:18:04.48,0:18:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menakjubkan!
Dialogue: 0,0:18:05.98,0:18:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah budaya hentai dunia nyata!
Dialogue: 0,0:18:09.68,0:18:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantap, enggak rugi aku datang ke Jepang.
Dialogue: 0,0:18:13.20,0:18:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, bukan.
Dialogue: 0,0:18:15.41,0:18:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah begitu,\Nkayaknya dia bakal asyik sendiri.
Dialogue: 0,0:18:20.29,0:18:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lanjutkan di kamar.
Dialogue: 0,0:18:23.66,0:18:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kamarnya.
Dialogue: 0,0:18:27.92,0:18:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:18:30.54,0:18:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:18:33.43,0:18:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak pingsan sambil berdiri.
Dialogue: 0,0:18:37.43,0:18:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun.
Dialogue: 0,0:18:39.08,0:18:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa kamu datang\Nke kamar Karina?
Dialogue: 0,0:18:41.97,0:18:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:18:43.78,0:18:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira Kakak akan ke kamarku\Nuntuk mencari paspor.
Dialogue: 0,0:18:49.69,0:18:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi penasaran apa yang terjadi.
Dialogue: 0,0:18:53.71,0:18:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubawakan yukata salin dan air putih.
Dialogue: 0,0:19:02.66,0:19:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:04.69,0:19:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya Kakak lakukan?
Dialogue: 0,0:19:08.96,0:19:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih mau menghalangi?
Dialogue: 0,0:19:10.98,0:19:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, pakai kekerasan pun...
Dialogue: 0,0:19:13.84,0:19:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa tadi?
Dialogue: 0,0:19:16.35,0:19:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada, kok.
Dialogue: 0,0:19:18.37,0:19:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan pergi.
Dialogue: 0,0:19:20.06,0:19:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti, dong.
Dialogue: 0,0:19:21.73,0:19:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang-buang waktu saja.
Dialogue: 0,0:19:25.06,0:19:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adegan favoritmu yang mana?
Dialogue: 0,0:19:27.12,0:19:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja pas klimaks...
Dialogue: 0,0:19:34.98,0:19:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang dua lawan satu.
Dialogue: 0,0:19:37.36,0:19:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitahara sialan.
Dialogue: 0,0:19:39.78,0:19:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:19:41.62,0:19:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dulu, dia tipe yang berusaha\Nmemenuhi ekspektasi orang.
Dialogue: 0,0:19:46.62,0:19:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kemungkinannya kecil,\Naku tetap khawatir!
Dialogue: 0,0:19:49.88,0:19:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini kakaknya!
Dialogue: 0,0:19:51.76,0:19:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dibilang,\Nadegan cabulnya tidak akan...
Dialogue: 0,0:19:54.32,0:19:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan!\NAku tidak percaya!
Dialogue: 0,0:19:59.79,0:20:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:20:06.29,0:20:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tengik.
Dialogue: 0,0:20:10.90,0:20:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia yang berniat jahat\Nbiar aku utang budi.
Dialogue: 0,0:20:16.15,0:20:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya malah sok jadi kakak.
Dialogue: 0,0:20:21.41,0:20:24.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:24.26,0:20:25.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah.
Dialogue: 0,0:20:25.66,0:20:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia bilang begitu?
Dialogue: 0,0:20:30.86,0:20:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:32.67,0:20:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menikahinya!
Dialogue: 0,0:20:37.17,0:20:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Menikah?
Dialogue: 0,0:20:39.26,0:20:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:20:40.43,0:20:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karina, kok mendadak sekali?
Dialogue: 0,0:20:43.60,0:20:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bilang, dia tertarik padaku.
Dialogue: 0,0:20:46.68,0:20:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, tidak keberatan.
Dialogue: 0,0:20:49.56,0:20:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula aku cinta Jepang.
Dialogue: 0,0:20:51.94,0:20:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia bisa memaklumi otaku.
Dialogue: 0,0:20:55.19,0:20:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:20:56.53,0:20:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktinya dia berteman sama orang ini.
Dialogue: 0,0:20:59.50,0:21:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan yang terpenting,
Dialogue: 0,0:21:01.45,0:21:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori akan jadi adikku.
Dialogue: 0,0:21:05.95,0:21:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menikah, kita bisa mencoba\Ndonburi hentai apalah itu.
Dialogue: 0,0:21:11.17,0:21:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, Karina...
Dialogue: 0,0:21:13.34,0:21:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu belum\Nmengenal dekat kakakku?
Dialogue: 0,0:21:17.78,0:21:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, itu betul.
Dialogue: 0,0:21:20.84,0:21:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kami akan mencoba tinggal serumah!
Dialogue: 0,0:21:25.23,0:21:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan di Jepang\Nselama libur musim panas.
Dialogue: 0,0:21:28.34,0:21:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tiap hari bisa merasakan\Nmomen erotis donburi apalah itu!
Dialogue: 0,0:21:32.73,0:21:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kakak tidak tinggal di sini.
Dialogue: 0,0:21:37.23,0:21:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, aku akan ikut dengannya.
Dialogue: 0,0:21:40.42,0:21:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rela ke mana saja asal di Jepang.
Dialogue: 0,0:21:43.99,0:21:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua juga ikut, kan?
Dialogue: 0,0:21:47.22,0:21:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo lakukan donburi apalah itu bersama.\N- Oh, begitu.
Dialogue: 0,0:21:49.41,0:21:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo lakukan donburi apalah itu bersama.\N- Ke mana pun asal di Jepang, ya.
Dialogue: 0,0:21:53.00,0:21:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Kalian di sini?
Dialogue: 0,0:21:55.81,0:21:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Darling.
Dialogue: 0,0:21:57.75,0:21:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:21:59.17,0:22:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
