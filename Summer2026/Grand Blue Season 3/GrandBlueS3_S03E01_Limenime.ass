Dialogue: 0,0:00:00.00,0:00:00.27,sign,,0000,0000,0000,,ACARA INI ADALAH KARYA FIKSI.
Dialogue: 0,0:00:00.27,0:00:00.58,sign,,0000,0000,0000,,ANAK DI BAWAH UMUR DILARANG KERAS\NMINUM ALKOHOL OLEH HUKUM.
Dialogue: 0,0:00:00.58,0:00:01.09,sign,,0000,0000,0000,,KAMI JUGA TIDAK BERMAKSUD MENGANJURKAN\NPEMAKSAAN MINUM ALKOHOL,
Dialogue: 0,0:00:01.09,0:00:01.79,sign,,0000,0000,0000,,KONSUMSI ALKOHOL BERLEBIHAN, MAUPUN TINDAKAN\NTIDAK SENONOH SAAT PESTA MINUM.
Dialogue: 0,0:00:01.79,0:00:02.40,sign,,0000,0000,0000,,MOHON ANGGAP INI SEMATA-MATA\NSEBAGAI ANIME KOMEDI.
Dialogue: 0,0:00:02.40,0:00:03.10,sign,,0000,0000,0000,,SELURUH KARAKTER YANG MENGONSUMSI\NALKOHOL DALAM KARYA INI
Dialogue: 0,0:00:03.10,0:00:03.68,sign,,0000,0000,0000,,TELAH BERUSIA 20 TAHUN ATAU LEBIH.
Dialogue: 0,0:00:03.68,0:00:04.38,sign,,0000,0000,0000,,DEMI MENYESUAIKAN DENGAN STANDAR\NKEPATUHAN TERKINI.
Dialogue: 0,0:00:04.38,0:00:04.98,sign,,0000,0000,0000,,MULAI MUSIM INI\NUKURAN SENSOR HITAM KAMI NAIK 5%.
Dialogue: 0,0:00:39.77,0:00:44.27,sign,,0000,0000,0000,,UNIVERSITAS IZU
Dialogue: 0,0:01:07.34,0:01:15.39,sign,,0000,0000,0000,,GRAND BLUE MUSIM 3
Dialogue: 0,0:02:29.96,0:02:31.84,sign,,0000,0000,0000,,DISKUSI KELOMPOK
Dialogue: 0,0:02:31.84,0:02:35.47,sign,,0000,0000,0000,,TEMA: MASALAH DI SEKITAR KITA DAN SOLUSINYA
Dialogue: 0,0:02:35.47,0:02:37.47,sign,,0000,0000,0000,,TEMA: PERJAKANYA YAMAMOTO SHINICHIROU
Dialogue: 0,0:03:07.50,0:03:09.50,sign,,0000,0000,0000,,APA SOLUSINYA?
Dialogue: 0,0:03:09.50,0:03:16.51,sign,,0000,0000,0000,,SOLUSI: 1. PAKAI UANG, 2. SECARA PAKSA
Dialogue: 0,0:03:16.51,0:03:23.02,sign,,0000,0000,0000,,3. CARI PACAR PAKAI BIUS ATAU HIPNOSIS
Dialogue: 0,0:04:03.56,0:04:09.56,sign,,0000,0000,0000,,BAN BOCOR
Dialogue: 0,0:04:09.56,0:04:13.07,sign,,0000,0000,0000,,TIDAK ADA SEPEDA, BERLARI PUN JADI!
Dialogue: 0,0:04:46.10,0:04:49.35,sign,,0000,0000,0000,,PUKUL 4.38, PUKUL 4.37
Dialogue: 0,0:04:49.35,0:04:50.85,sign,,0000,0000,0000,,DISKUSI KELOMPOK
Dialogue: 0,0:04:50.85,0:04:55.36,sign,,0000,0000,0000,,TEMA: MASALAH DI SEKITAR KITA DAN SOLUSINYA.
Dialogue: 0,0:05:43.03,0:05:45.53,sign,,0000,0000,0000,,TEMA: MASALAH SOSIAL BAHWA\NSEONGGOK KITAHARA SAJA PUNYA PACAR
Dialogue: 0,0:05:45.53,0:05:47.54,sign,,0000,0000,0000,,PENCETUS: YAMAMOTO SHINICHIROU
Dialogue: 0,0:05:57.42,0:05:59.55,sign,,0000,0000,0000,,JANGAN LIBATKAN AKU KE PERKARAMU!
Dialogue: 0,0:05:59.80,0:06:02.05,sign,,0000,0000,0000,,KAMU YANG MEMANCING MEREKA, TAHU!
Dialogue: 0,0:06:58.75,0:07:09.62,sign,,0000,0000,0000,,BUBUK SEMEN
Dialogue: 0,0:08:24.82,0:08:28.07,sign,,0000,0000,0000,,MASALAH PERJAKANYA KITAHARA IORI
Dialogue: 0,0:08:36.83,0:08:38.33,sign,,0000,0000,0000,,MASALAH PERJAKANYA KITAHARA IORI
Dialogue: 0,0:08:48.34,0:08:52.13,sign,,0000,0000,0000,,TEMA: MASALAH DI SEKITAR KITA DAN SOLUSINYA
Dialogue: 0,0:09:00.35,0:09:03.36,sign,,0000,0000,0000,,PEMANASAN GLOBAL
Dialogue: 0,0:09:03.36,0:09:04.86,sign,,0000,0000,0000,,MASALAH PERJAKANYA KITAHARA IORI\NSANGAT BAIK
Dialogue: 0,0:09:04.86,0:09:08.99,sign,,0000,0000,0000,,ENTAH KENAPA NILAINYA BAGUS
Dialogue: 0,0:09:08.99,0:09:10.99,sign,,0000,0000,0000,,TOKO SELAM GRAND BLUE
Dialogue: 0,0:09:42.65,0:09:43.93,sign,,0000,0000,0000,,SISA KEGIATAN MUSIM PANAS
Dialogue: 0,0:09:43.93,0:09:44.88,sign,,0000,0000,0000,,PENGIN LIHAT SEMUA PAKAI YUKATA
Dialogue: 0,0:09:44.88,0:09:45.64,sign,,0000,0000,0000,,MUSIM PANAS YANG BENAR.
Dialogue: 0,0:09:45.64,0:09:47.63,sign,,0000,0000,0000,,PENGIN PESTA MINUM YANG BERKESAN
Dialogue: 0,0:09:47.63,0:09:50.15,sign,,0000,0000,0000,,PENGIN BIKIN PESTA TAKOYAKI
Dialogue: 0,0:11:49.90,0:11:56.28,sign,,0000,0000,0000,,SISA KEGIATAN MUSIM PANAS
Dialogue: 0,0:11:59.28,0:12:02.79,sign,,0000,0000,0000,,PALING PENTING!\NSEMUANYA WAJIB PAKAI CARA PAB
Dialogue: 0,0:12:33.32,0:12:36.93,sign,,0000,0000,0000,,SEJARAH YUKATA
Dialogue: 0,0:12:36.93,0:12:38.45,sign,,0000,0000,0000,,SECARA TRADISI, TIDAK BOLEH MEMAKAI
Dialogue: 0,0:12:38.45,0:12:41.82,sign,,0000,0000,0000,,PAKAIAN DALAM SAAT MENGENAKAN YUKATA.
Dialogue: 0,0:12:39.32,0:12:41.82,sign,,0000,0000,0000,,SECARA TRADISI, TIDAK BOLEH MEMAKAI
Dialogue: 0,0:14:01.28,0:14:04.28,sign,,0000,0000,0000,,PENGIN BIKIN PESTA TAKOYAKI
Dialogue: 0,0:14:11.54,0:14:12.79,sign,,0000,0000,0000,,BAHAN-BAHAN\NTEPUNG TAKOYAKI
Dialogue: 0,0:14:12.79,0:14:14.04,sign,,0000,0000,0000,,TELUR
Dialogue: 0,0:14:14.04,0:14:17.36,sign,,0000,0000,0000,,AIR
Dialogue: 0,0:14:17.36,0:14:19.55,sign,,0000,0000,0000,,ALKOHOL
Dialogue: 0,0:14:37.06,0:14:38.70,sign,,0000,0000,0000,,BAHAN-BAHAN
Dialogue: 0,0:14:38.70,0:14:40.94,sign,,0000,0000,0000,,TEPUNG TAKOYAKI: SECUKUPNYA
Dialogue: 0,0:14:40.94,0:14:42.07,sign,,0000,0000,0000,,TELUR: SECUKUPNYA, AIR: BANYAK
Dialogue: 0,0:16:51.18,0:16:53.45,sign,,0000,0000,0000,,LOMBA MINUM AIR, LOMBA MAKAN TAKOYAKI,\NLOMBA TENGGAK BIR
Dialogue: 0,0:16:53.45,0:16:54.37,sign,,0000,0000,0000,,AIR, HIDANGAN PEMBUKA, ALKOHOL
Dialogue: 0,0:16:54.37,0:16:55.48,sign,,0000,0000,0000,,AIR (SEKITAR 96% ALKOHOL),\NTAKOYAKI (ESTIMASI 40% ALKOHOL)
Dialogue: 0,0:16:55.48,0:16:55.95,sign,,0000,0000,0000,,BIR (SEKITAR 4,5% ALKOHOL)
Dialogue: 0,0:17:05.71,0:17:06.56,sign,,0000,0000,0000,,LOMBA MINUM AIR,\NLOMBA MAKAN TAKOYAKI,
Dialogue: 0,0:17:06.56,0:17:08.22,sign,,0000,0000,0000,,LOMBA TENGGAK BIR
Dialogue: 0,0:17:20.74,0:17:21.48,sign,,0000,0000,0000,,SISA KEGIATAN MUSIM PANAS
Dialogue: 0,0:17:46.50,0:17:48.51,sign,,0000,0000,0000,,TOKO SELAM GRAND BLUE
Dialogue: 0,0:19:52.38,0:19:54.88,sign,,0000,0000,0000,,DIA SETUJU! KOUHEI AKAN IKUT BERSAMAKU!
Dialogue: 0,0:20:29.92,0:20:33.67,sign,,0000,0000,0000,,KOTEGAWA NANAKA
Dialogue: 0,0:20:55.94,0:20:57.94,sign,,0000,0000,0000,,PENGINAPAN KITAHARA
Dialogue: 0,0:20:59.95,0:21:01.45,sign,,0000,0000,0000,,IORI
Dialogue: 0,0:21:44.12,0:21:47.12,sign,,0000,0000,0000,,TOKO SELAM GRAND BLUE
Dialogue: 0,0:22:10.02,0:22:14.98,sign,,0000,0000,0000,,TUR REUNI DENGAN NENG SHIORI\N(ADIK KANDUNG ASLI)
Dialogue: 0,0:23:44.94,0:23:49.95,sign,,0000,0000,0000,,SELANJUTNYA: PULANG KAMPUNG
Dialogue: 0,0:00:47.70,0:00:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai,
Dialogue: 0,0:00:50.29,0:00:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diskusi mengenai perjakanya\NYamamoto Shinichirou.
Dialogue: 0,0:02:26.40,0:02:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah materi hari ini.
Dialogue: 0,0:02:29.96,0:02:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilihlah satu tema,
Dialogue: 0,0:02:31.84,0:02:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu diskusikan selama 20 menit.
Dialogue: 0,0:02:37.47,0:02:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masalah yang pelik.
Dialogue: 0,0:02:39.82,0:02:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita sanggup menyelesaikannya?
Dialogue: 0,0:02:43.09,0:02:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bedebah kalian!
Dialogue: 0,0:02:45.48,0:02:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau menemukan solusinya di sini...
Dialogue: 0,0:02:49.98,0:02:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa lepas!
Dialogue: 0,0:02:51.98,0:02:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari status perjaka!
Dialogue: 0,0:02:53.49,0:02:54.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glek.
Dialogue: 0,0:02:59.07,0:03:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tema sudah ditentukan.
Dialogue: 0,0:03:00.86,0:03:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya mendisuksikan solusinya.
Dialogue: 0,0:03:03.49,0:03:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:03:04.61,0:03:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara membuang keperjakaan Yamamoto, ya.
Dialogue: 0,0:03:10.37,0:03:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ada dua cara.
Dialogue: 0,0:03:12.51,0:03:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju.
Dialogue: 0,0:03:13.80,0:03:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok enggak ada solusi "cari pacar"?
Dialogue: 0,0:03:16.51,0:03:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ada tiga cara.
Dialogue: 0,0:03:19.54,0:03:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok nomor tiga ada tambahannya, sih.
Dialogue: 0,0:03:23.02,0:03:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Kitahara, kurang pantas\Nkalau pakai tindakan kriminal.
Dialogue: 0,0:03:28.03,0:03:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:03:29.23,0:03:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak bermoral.
Dialogue: 0,0:03:31.17,0:03:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kalian punya moral?
Dialogue: 0,0:03:34.03,0:03:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, anggap saja tidak ada solusinya.
Dialogue: 0,0:03:38.53,0:03:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:03:39.92,0:03:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habisnya mustahil.
Dialogue: 0,0:03:42.32,0:03:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek!
Dialogue: 0,0:03:44.54,0:03:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan cepat menyerah.
Dialogue: 0,0:03:47.29,0:03:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:03:48.59,0:03:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut metode pemecahan masalah.
Dialogue: 0,0:03:53.30,0:03:57.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat tidak bisa mengatasi\Nmasalah secara langsung,
Dialogue: 0,0:03:57.86,0:04:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita perlu mengganti cara\Nuntuk mencapai tujuan.
Dialogue: 0,0:04:03.56,0:04:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Contohnya, kalau ban sepeda bocor
Dialogue: 0,0:04:07.41,0:04:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak bisa diperbaiki,
Dialogue: 0,0:04:10.43,0:04:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah untuk berlari saja.
Dialogue: 0,0:04:13.07,0:04:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku paham maksudmu.
Dialogue: 0,0:04:16.62,0:04:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi targetnya tidak mesti manusia?
Dialogue: 0,0:04:20.62,0:04:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:04:22.33,0:04:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal setuju saja, sialan!
Dialogue: 0,0:04:25.10,0:04:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bego juga ada batasnya!
Dialogue: 0,0:04:27.52,0:04:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar dulu, Yamamoto.
Dialogue: 0,0:04:30.08,0:04:33.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku ide itu cukup\Nilmiah dan rasional.
Dialogue: 0,0:04:33.50,0:04:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Rasional apanya?
Dialogue: 0,0:04:36.09,0:04:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesama anak sains sepertimu pasti tahu.
Dialogue: 0,0:04:39.06,0:04:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istilah "galat pembacaan".
Dialogue: 0,0:04:41.59,0:04:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesalahan yang timbul saat mengukur nilai
Dialogue: 0,0:04:44.49,0:04:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di antara skala terkecil
Dialogue: 0,0:04:46.10,0:04:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada alat ukur analog, ya.
Dialogue: 0,0:04:49.35,0:04:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara umum,
Dialogue: 0,0:04:50.85,0:04:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}batas maklumnya yaitu 10% dari skala terkecil.
Dialogue: 0,0:04:54.05,0:04:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa?
Dialogue: 0,0:04:55.36,0:04:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan,
Dialogue: 0,0:04:57.01,0:05:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}genetik gorila dan manusia cuma beda 1%.
Dialogue: 0,0:05:05.41,0:05:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku harus sama gorila?
Dialogue: 0,0:05:07.50,0:05:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, apa salahnya dia perjaka?
Dialogue: 0,0:05:10.53,0:05:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga.
Dialogue: 0,0:05:11.84,0:05:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh, tujuan hubungan seksual\Nadalah berkembang biak.
Dialogue: 0,0:05:16.08,0:05:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum tahu dia pantas\Ndilestarikan apa tidak.
Dialogue: 0,0:05:19.86,0:05:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sok tahu sekali!
Dialogue: 0,0:05:23.10,0:05:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kalian pernah begituan?
Dialogue: 0,0:05:26.01,0:05:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo ganti topik.
Dialogue: 0,0:05:28.02,0:05:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imamura, cari tema lain.
Dialogue: 0,0:05:29.49,0:05:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:05:30.52,0:05:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, ada teman praktik\Nenggak kayak kalian.
Dialogue: 0,0:05:33.07,0:05:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau dibikin patah atau remuk?
Dialogue: 0,0:05:35.15,0:05:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:05:36.10,0:05:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya waktu itu gagal?
Dialogue: 0,0:05:38.53,0:05:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal ada partnernya dulu!
Dialogue: 0,0:05:47.54,0:05:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai.
Dialogue: 0,0:05:49.04,0:05:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:50.04,0:05:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Solusinya bagaimana?
Dialogue: 0,0:05:52.45,0:05:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagusnya dibikin putus, sih.
Dialogue: 0,0:05:54.90,0:05:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi enggak sudi membiarkan mereka hidup.
Dialogue: 0,0:06:02.05,0:06:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pencetus tema ini aku punya usul.
Dialogue: 0,0:06:05.14,0:06:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:06.05,0:06:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membuat batas dalam diskusi ini.
Dialogue: 0,0:06:08.70,0:06:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batas?
Dialogue: 0,0:06:09.60,0:06:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu aturan?
Dialogue: 0,0:06:12.06,0:06:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kesimpulan apa pun\Nyang kalian ambil dari diskusi ini,
Dialogue: 0,0:06:15.94,0:06:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus selalu disambung dengan,\N"Setelah *** mereka, bunuh."
Dialogue: 0,0:06:18.82,0:06:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus.
Dialogue: 0,0:06:20.18,0:06:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepakat.
Dialogue: 0,0:06:21.67,0:06:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja mau mengusulkan begitu.
Dialogue: 0,0:06:24.82,0:06:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kalian masih peduli moral, lo!
Dialogue: 0,0:06:27.07,0:06:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menurutku, sih...
Dialogue: 0,0:06:28.69,0:06:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabar.
Dialogue: 0,0:06:31.08,0:06:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada satu usul lagi.
Dialogue: 0,0:06:32.91,0:06:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat tangan dulu untuk dapat izin bicara.
Dialogue: 0,0:06:36.58,0:06:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin?
Dialogue: 0,0:06:37.79,0:06:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus sebegitunya?
Dialogue: 0,0:06:39.34,0:06:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain diskusi, ini adalah pengadilan.
Dialogue: 0,0:06:43.84,0:06:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:06:45.04,0:06:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian ini menyangkut nyawa orang.
Dialogue: 0,0:06:47.14,0:06:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanmu masuk akal.
Dialogue: 0,0:06:49.82,0:06:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kami sudah pasti dibunuh?
Dialogue: 0,0:06:52.58,0:06:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak pengadilan penyihir zaman dulu.
Dialogue: 0,0:06:54.85,0:06:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin, Ketua.
Dialogue: 0,0:06:56.13,0:06:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nojima.
Dialogue: 0,0:06:57.23,0:06:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berpendapat,
Dialogue: 0,0:06:58.75,0:07:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka boleh kubunuh?
Dialogue: 0,0:07:00.40,0:07:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:07:01.36,0:07:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enteng amat!
Dialogue: 0,0:07:02.11,0:07:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawa kami seenteng itu?
Dialogue: 0,0:07:04.22,0:07:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persetan soal orang ini!
Dialogue: 0,0:07:06.22,0:07:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya ampuni aku!
Dialogue: 0,0:07:07.94,0:07:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ampuni aku saja!
Dialogue: 0,0:07:09.62,0:07:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh hina.
Dialogue: 0,0:07:11.28,0:07:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang layak dieksekusi.
Dialogue: 0,0:07:13.62,0:07:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap minta izin sebelum bicara.
Dialogue: 0,0:07:16.62,0:07:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua!
Dialogue: 0,0:07:17.77,0:07:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain permohonan ampun, boleh bicara.
Dialogue: 0,0:07:20.07,0:07:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:07:21.88,0:07:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua memang telah jadi terpidana.
Dialogue: 0,0:07:25.68,0:07:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Ketua yakin pengkhianatnya cuma kami?
Dialogue: 0,0:07:29.89,0:07:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitahara sialan!
Dialogue: 0,0:07:31.15,0:07:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapannya penuh racun!
Dialogue: 0,0:07:33.89,0:07:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya juga, pria sepertiku memang wajar\Npunya pacar, justru aneh kalau tidak!
Dialogue: 0,0:07:39.06,0:07:41.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat rawan dicurigai!
Dialogue: 0,0:07:41.90,0:07:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mencurigai mereka.
Dialogue: 0,0:07:43.81,0:07:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Curiga, dong!
Dialogue: 0,0:07:46.15,0:07:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imamura bagaimana?
Dialogue: 0,0:07:47.91,0:07:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampangnya saja begitu!
Dialogue: 0,0:07:50.94,0:07:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan meremehkanku, Payah.
Dialogue: 0,0:07:52.66,0:07:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarku itu beda dimensi!
Dialogue: 0,0:07:55.41,0:07:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bersalah.
Dialogue: 0,0:07:56.91,0:07:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:07:58.03,0:08:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok aku merasa kalah, ya?
Dialogue: 0,0:08:00.27,0:08:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kita sedikit.
Dialogue: 0,0:08:02.42,0:08:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, mulai dari Mitarai\Nyang sudah terkonfirmasi
Dialogue: 0,0:08:05.42,0:08:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melakukan percobaan.
Dialogue: 0,0:08:07.68,0:08:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:08:13.02,0:08:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya Kitahara.
Dialogue: 0,0:08:15.60,0:08:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:08:17.10,0:08:18.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berbuat apa-apa!
Dialogue: 0,0:08:18.90,0:08:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru masalahku sama kayak Yamamoto!
Dialogue: 0,0:08:23.65,0:08:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:08:24.82,0:08:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti begini, ya?
Dialogue: 0,0:08:26.09,0:08:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah!
Dialogue: 0,0:08:28.07,0:08:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi jangan eksekusi aku...
Dialogue: 0,0:08:29.82,0:08:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya sudah habis.
Dialogue: 0,0:08:32.08,0:08:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan presentasikan diskusi kalian.
Dialogue: 0,0:08:36.21,0:08:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:38.33,0:08:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami mau ganti tema disku—
Dialogue: 0,0:08:41.83,0:08:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Presentasikan yang sekarang.
Dialogue: 0,0:08:46.86,0:08:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Presentasi kami
Dialogue: 0,0:08:48.34,0:08:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membahas tentang perjakanya Kitahara Iori.
Dialogue: 0,0:08:52.13,0:08:54.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iori masih...\N- Mereka belum begituan, toh.
Dialogue: 0,0:08:54.85,0:08:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotegawa pelit juga, ya.
Dialogue: 0,0:08:57.33,0:08:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah dia belum ternoda.
Dialogue: 0,0:08:59.22,0:09:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Bodoh itu tidak akan kuampuni!
Dialogue: 0,0:09:10.99,0:09:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat dibilang apa.
Dialogue: 0,0:09:12.66,0:09:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kok tidak ingat?\N- Ingat, dong!
Dialogue: 0,0:09:15.33,0:09:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kelas tiga sudah mau lulus.
Dialogue: 0,0:09:18.35,0:09:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya tidak ada yang ingat.
Dialogue: 0,0:09:19.98,0:09:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini musim panas terakhirku dengan mereka.\N- Masa?
Dialogue: 0,0:09:21.23,0:09:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini musim panas terakhirku dengan mereka.\N- Kalian kayak pelawak saja.
Dialogue: 0,0:09:22.94,0:09:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, Senior.
Dialogue: 0,0:09:25.25,0:09:28.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim panas ini, ada yang belum\Nsempat kalian lakukan?
Dialogue: 0,0:09:28.26,0:09:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum sempat dilakukan?
Dialogue: 0,0:09:29.87,0:09:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada, sih.
Dialogue: 0,0:09:31.74,0:09:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa memangnya?
Dialogue: 0,0:09:33.26,0:09:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lakukan, soalnya musim panas\Ntahun ini tidak akan terulang lagi!
Dialogue: 0,0:09:40.64,0:09:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iori...
Dialogue: 0,0:09:42.65,0:09:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi kita harus pesta minum
Dialogue: 0,0:09:45.64,0:09:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pesta minum dan takoyaki pakai yukata.
Dialogue: 0,0:09:47.63,0:09:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang khas musim panas, sih.
Dialogue: 0,0:09:50.15,0:09:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kumpul pakai yukata.
Dialogue: 0,0:09:53.10,0:09:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanaka ikut, kan?
Dialogue: 0,0:09:55.41,0:09:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, deh.
Dialogue: 0,0:10:04.42,0:10:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cuma perlu beli gurita\Nsama tepungnya saja, kan?
Dialogue: 0,0:10:07.65,0:10:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kurang lengkap, deh.
Dialogue: 0,0:10:09.92,0:10:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisanya beli keju, sosis, sama udang.
Dialogue: 0,0:10:13.60,0:10:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:10:14.93,0:10:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kimci dan mentaiko juga enak.
Dialogue: 0,0:10:17.70,0:10:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bikin ngiler.
Dialogue: 0,0:10:20.43,0:10:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama tepung panekuk dan cokelat, deh.
Dialogue: 0,0:10:23.54,0:10:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kita ada yang suka manis?
Dialogue: 0,0:10:26.77,0:10:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, suka.
Dialogue: 0,0:10:29.44,0:10:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Butuh alpukat, tidak, ya?
Dialogue: 0,0:10:31.69,0:10:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti lemaknya berkurang, dong.
Dialogue: 0,0:10:34.62,0:10:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:10:35.81,0:10:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, sih, suka.
Dialogue: 0,0:10:46.46,0:10:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kouhei?
Dialogue: 0,0:10:48.05,0:10:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan apa-apa.
Dialogue: 0,0:10:50.86,0:10:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:51.71,0:10:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan berakhirnya liburan musim panas...
Dialogue: 0,0:10:55.22,0:10:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersulang!
Dialogue: 0,0:11:02.85,0:11:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir dan takoyaki cocok banget!
Dialogue: 0,0:11:04.86,0:11:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin dan panasnya sangat berpadu.
Dialogue: 0,0:11:09.92,0:11:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jadi, yang ini kaldu khas Kyoto.
Dialogue: 0,0:11:12.54,0:11:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini digoreng ala Gindaco.
Dialogue: 0,0:11:15.17,0:11:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan malu-malu, ayo tambah lagi.
Dialogue: 0,0:11:18.16,0:11:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa coba.
Dialogue: 0,0:11:19.62,0:11:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nih.\N- Enak banget!
Dialogue: 0,0:11:21.36,0:11:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, para senior.
Dialogue: 0,0:11:27.12,0:11:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bawa kamera segala?
Dialogue: 0,0:11:29.44,0:11:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pinjam kamera Chisa.
Dialogue: 0,0:11:31.30,0:11:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar pesta minumnya bisa dikenang.
Dialogue: 0,0:11:34.70,0:11:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lupa konsep hari ini?
Dialogue: 0,0:11:36.68,0:11:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sempat membahasnya, kan?
Dialogue: 0,0:11:39.89,0:11:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, yang itu.
Dialogue: 0,0:11:41.72,0:11:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, bukan begini, dong.
Dialogue: 0,0:11:43.46,0:11:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:11:44.64,0:11:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, ini memang rekaman\Nbukannya kenangan, sih.
Dialogue: 0,0:11:49.90,0:11:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kok.
Dialogue: 0,0:11:50.92,0:11:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan itu maksudnya.
Dialogue: 0,0:11:53.04,0:11:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya apa?
Dialogue: 0,0:11:57.02,0:11:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada lipatan di pojoknya.
Dialogue: 0,0:12:05.04,0:12:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau melakukannya, kan?
Dialogue: 0,0:12:07.48,0:12:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Junior kita memang baik hati.
Dialogue: 0,0:12:10.52,0:12:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan bagian terakhirnya itu!
Dialogue: 0,0:12:12.24,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya kayak kontrak jebakan!
Dialogue: 0,0:12:15.59,0:12:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, ya, Chi.
Dialogue: 0,0:12:18.05,0:12:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mulai!
Dialogue: 0,0:12:19.48,0:12:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta musim panas ala Pab!
Dialogue: 0,0:12:22.30,0:12:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:12:24.06,0:12:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:12:26.84,0:12:29.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan lupa permintaanku.\N- E-Eh...
Dialogue: 0,0:12:29.33,0:12:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah kamu...
Dialogue: 0,0:12:30.86,0:12:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ingin melihat semua pakai yukata, kan?\N- A-Anu...
Dialogue: 0,0:12:33.32,0:12:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku menulis
Dialogue: 0,0:12:35.41,0:12:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"pakai yukata dengan benar" di sana, kan?
Dialogue: 0,0:12:38.45,0:12:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:12:41.82,0:12:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, Azusa...
Dialogue: 0,0:12:43.94,0:12:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berarti...
Dialogue: 0,0:12:45.56,0:12:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, berarti...
Dialogue: 0,0:12:50.74,0:12:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas dalaman kalian.
Dialogue: 0,0:12:52.58,0:12:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!
Dialogue: 0,0:12:53.84,0:12:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, begitu rupanya.
Dialogue: 0,0:12:56.50,0:12:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanaka?
Dialogue: 0,0:12:58.84,0:13:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ganti baju, Chisa.
Dialogue: 0,0:13:00.98,0:13:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:13:02.34,0:13:04.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Yah, cuma telanjang doang.\N- Tunggu, Kak!
Dialogue: 0,0:13:04.78,0:13:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah ingin kujabani.
Dialogue: 0,0:13:06.76,0:13:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:08.35,0:13:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Iori...
Dialogue: 0,0:13:09.76,0:13:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:13:10.85,0:13:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan yukata, tapi jinbei, kan?
Dialogue: 0,0:13:14.08,0:13:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin iya.
Dialogue: 0,0:13:16.36,0:13:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepas itu juga.
Dialogue: 0,0:13:23.32,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sejuk, kan, Chisa?
Dialogue: 0,0:13:27.62,0:13:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini diperkenankan?
Dialogue: 0,0:13:29.42,0:13:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:13:31.14,0:13:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya Iori cuma pinjam obi, ya?
Dialogue: 0,0:13:33.34,0:13:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada bedanya sama telanjang biasa.
Dialogue: 0,0:13:35.50,0:13:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lebih memalukan daripada telanjang!
Dialogue: 0,0:13:38.13,0:13:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kamu lepas celana dalam juga.
Dialogue: 0,0:13:41.88,0:13:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong maklumi bagian yang itu!
Dialogue: 0,0:13:44.76,0:13:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu manis banget, Chi.
Dialogue: 0,0:13:46.66,0:13:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti Azusa lagi tidak pakai, dong?
Dialogue: 0,0:13:54.27,0:13:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang dia...
Dialogue: 0,0:13:56.27,0:13:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah sejak belanja tadi?\N- Hei...
Dialogue: 0,0:13:58.52,0:14:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah melepasnya juga, Nanaka?
Dialogue: 0,0:14:01.28,0:14:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, selanjutnya takoyaki.
Dialogue: 0,0:14:04.28,0:14:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ala Pab itu apa?
Dialogue: 0,0:14:06.42,0:14:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terlalu dipikirkan.
Dialogue: 0,0:14:08.16,0:14:11.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal buat dengan bahan yang ada.
Dialogue: 0,0:14:15.29,0:14:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentar! Kayaknya itu bukan air!
Dialogue: 0,0:14:17.36,0:14:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu maksudnya ala Pab?
Dialogue: 0,0:14:19.55,0:14:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita mulai memasak.
Dialogue: 0,0:14:21.44,0:14:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti airnya keburu habis.
Dialogue: 0,0:14:25.00,0:14:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan
Dialogue: 0,0:14:25.96,0:14:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ala Pab
Dialogue: 0,0:14:27.30,0:14:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iori dan Kouhei!
Dialogue: 0,0:14:30.81,0:14:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah sekali!
Dialogue: 0,0:14:32.20,0:14:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan membuat takoyaki ala Pab.
Dialogue: 0,0:14:35.04,0:14:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya menyenangkan!
Dialogue: 0,0:14:37.06,0:14:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Caranya gampang.
Dialogue: 0,0:14:38.70,0:14:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal campur semua yang ada di sini.
Dialogue: 0,0:14:40.94,0:14:42.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:14:44.07,0:14:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chef, uap alkoholnya bikin\Nair mataku tidak berhenti.
Dialogue: 0,0:14:48.16,0:14:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja sedang iris bawang\Ndan terima nasibmu.
Dialogue: 0,0:14:52.08,0:14:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tuangkan adonan yang sudah jadi\Nke cetakan takoyaki
Dialogue: 0,0:14:55.83,0:14:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chef, adonan alkoholnya terpisah\Ndan tidak mau mengalir.
Dialogue: 0,0:14:59.66,0:15:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuncinya memasak dengan cepat\Nagar ini tidak terjadi.
Dialogue: 0,0:15:03.59,0:15:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu diperhatikan juga adonan ini\Nsangat mudah gosong.
Dialogue: 0,0:15:07.85,0:15:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada sumber api,\Nbisa langsung menyala seketika.
Dialogue: 0,0:15:11.60,0:15:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan inilah hasil jadinya!
Dialogue: 0,0:15:13.54,0:15:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:15:19.86,0:15:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ogah memakannya.
Dialogue: 0,0:15:22.04,0:15:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kering dan kayak gampang hancur.
Dialogue: 0,0:15:24.72,0:15:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya aman saja.
Dialogue: 0,0:15:26.96,0:15:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dipanaskan,\Nalkoholnya juga akan menguap.
Dialogue: 0,0:15:30.74,0:15:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, coba makan.
Dialogue: 0,0:15:32.16,0:15:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu rasanya lezat.
Dialogue: 0,0:15:34.23,0:15:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mau cicip, Chi?
Dialogue: 0,0:15:37.12,0:15:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada takoyaki.
Dialogue: 0,0:15:39.25,0:15:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:15:44.01,0:15:47.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian punya dendam padaku, ya?
Dialogue: 0,0:15:47.14,0:15:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salah paham.
Dialogue: 0,0:15:48.62,0:15:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kecelakaan.
Dialogue: 0,0:15:50.26,0:15:52.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata rasanya gila juga.
Dialogue: 0,0:15:52.22,0:15:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi harus dihabiskan.
Dialogue: 0,0:15:54.54,0:15:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:15:58.18,0:15:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisa?
Dialogue: 0,0:15:58.88,0:16:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau coba?
Dialogue: 0,0:16:00.27,0:16:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka mulutmu.
Dialogue: 0,0:16:01.82,0:16:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini!
Dialogue: 0,0:16:03.28,0:16:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu, Chisa.
Dialogue: 0,0:16:05.50,0:16:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku suapi.
Dialogue: 0,0:16:06.88,0:16:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut merepotkanmu.
Dialogue: 0,0:16:09.26,0:16:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hitungannya aku masih pacarmu.
Dialogue: 0,0:16:13.54,0:16:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bersikap layaknya seorang pacar.
Dialogue: 0,0:16:16.10,0:16:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alihkan perasaan itu buat yang lain, dong.
Dialogue: 0,0:16:19.04,0:16:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, buka mulutmu...
Dialogue: 0,0:16:20.66,0:16:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibilang tidak usah.
Dialogue: 0,0:16:23.80,0:16:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok difoto?
Dialogue: 0,0:16:26.14,0:16:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat jaga-jaga mengancammu.
Dialogue: 0,0:16:29.09,0:16:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak kasihan sama aku\Nyang akan babak belur nanti?
Dialogue: 0,0:16:32.55,0:16:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu saja yang makan!
Dialogue: 0,0:16:33.81,0:16:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu saja!
Dialogue: 0,0:16:34.79,0:16:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iori, buka mulutmu.
Dialogue: 0,0:16:36.43,0:16:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar, kalian ini.\N- Dia mau menyuapimu, tuh!
Dialogue: 0,0:16:38.43,0:16:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah dibilang jangan berantem.\N- Mumpung masih hangat!
Dialogue: 0,0:16:41.44,0:16:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia duluan!
Dialogue: 0,0:16:42.93,0:16:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iori duluan!
Dialogue: 0,0:16:43.69,0:16:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisa dan Kouhei duluan!
Dialogue: 0,0:16:45.52,0:16:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kalau sudah begini...
Dialogue: 0,0:16:47.90,0:16:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diselesaikan dengan permainan.
Dialogue: 0,0:16:56.42,0:16:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung-ujungnya tetap alkohol!
Dialogue: 0,0:17:06.56,0:17:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:17:08.22,0:17:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka\Nmereka sangat perhatian sama kita.
Dialogue: 0,0:17:11.33,0:17:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mereka ada sisi manisnya juga.
Dialogue: 0,0:17:14.27,0:17:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka selalu terlihat manis di mataku, sih.
Dialogue: 0,0:17:17.47,0:17:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa kegiatan musim panas\Nsudah selesai semua.
Dialogue: 0,0:17:20.74,0:17:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:21.48,0:17:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa fokus cari kerja.
Dialogue: 0,0:17:24.38,0:17:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:25.73,0:17:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami harus membuat draf dan laporan.
Dialogue: 0,0:17:28.50,0:17:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian masuk pascasarjana juga ada.
Dialogue: 0,0:17:30.67,0:17:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta minum yang berkesan menyenangkan.
Dialogue: 0,0:17:33.99,0:17:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bagi mereka,\Nini pesta minum
Dialogue: 0,0:17:37.18,0:17:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang meninggalkan kenangan\Ndan kerusakan di otaknya.
Dialogue: 0,0:17:40.88,0:17:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul itu.
Dialogue: 0,0:17:49.20,0:17:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Iori.
Dialogue: 0,0:17:51.44,0:17:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Nanaka.
Dialogue: 0,0:17:54.80,0:17:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta minum kemarin parah banget.
Dialogue: 0,0:17:58.13,0:17:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:17:59.02,0:18:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:00.89,0:18:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:18:02.70,0:18:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membicarakannya dengan Chisa,\Ndan Dolphin telah menghubungi kami.
Dialogue: 0,0:18:07.77,0:18:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko selam yang itu?
Dialogue: 0,0:18:10.67,0:18:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:11.65,0:18:14.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka baru buka cabang baru di Palau,
Dialogue: 0,0:18:14.47,0:18:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kekurangan orang dan butuh bantuan.
Dialogue: 0,0:18:17.16,0:18:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Palau! Aku ingin ke sana!
Dialogue: 0,0:18:19.66,0:18:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:18:20.97,0:18:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mulai minggu depan\Nsekitar dua minggu, bisa?
Dialogue: 0,0:18:24.42,0:18:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kebetulan aku pernah bilang ke Chisa\Nkalau pengin menyelam di luar negeri.
Dialogue: 0,0:18:29.70,0:18:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:18:31.20,0:18:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Kouhei?
Dialogue: 0,0:18:33.43,0:18:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia mau kerja sambilan...
Dialogue: 0,0:18:36.43,0:18:38.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau ke luar negeri.
Dialogue: 0,0:18:38.81,0:18:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana tidak bisa menonton\Nsiaran anime langsung.
Dialogue: 0,0:18:42.80,0:18:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang membujuk Kouhei.
Dialogue: 0,0:18:45.69,0:18:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kuserahkan padamu.
Dialogue: 0,0:18:48.24,0:18:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detailnya nanti lewat pesan.
Dialogue: 0,0:18:50.03,0:18:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, hati-hati di jalan.
Dialogue: 0,0:18:58.91,0:18:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai.
Dialogue: 0,0:18:59.87,0:19:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo.
Dialogue: 0,0:19:02.98,0:19:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta minum kemarin parah banget.
Dialogue: 0,0:19:05.71,0:19:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?
Dialogue: 0,0:19:08.10,0:19:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:19:09.76,0:19:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouhei.
Dialogue: 0,0:19:10.99,0:19:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:11.96,0:19:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanaka bilang cabang baru Dolphin\Nkurang orang dan butuh bantuan.
Dialogue: 0,0:19:17.84,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba kerja sambilan?\NMulai minggu depan selama dua minggu.
Dialogue: 0,0:19:21.14,0:19:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba banget.\NDua minggu, ya?
Dialogue: 0,0:19:24.82,0:19:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu butuh uang\Nbuat lisensi tingkat lanjut, kan?
Dialogue: 0,0:19:27.86,0:19:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sih.
Dialogue: 0,0:19:29.61,0:19:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana kita bisa belajar tentang menyelam,\Nbisa dapat peralatan murah juga.
Dialogue: 0,0:19:34.11,0:19:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdengar seperti penawaran yang menarik.
Dialogue: 0,0:19:37.30,0:19:40.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kamu sudah memutuskan\Nikut membantu, kan?
Dialogue: 0,0:19:40.75,0:19:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:19:42.86,0:19:45.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku tidak mau lembur tengah malam.
Dialogue: 0,0:19:45.92,0:19:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anime musim panas lagi seru-serunya.
Dialogue: 0,0:19:48.38,0:19:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bertekad selalu menonton\Nlangsung judul-judul favoritku.
Dialogue: 0,0:19:52.38,0:19:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terserah kamu saja.
Dialogue: 0,0:19:54.88,0:19:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, waktu SMA,\Nkamu studi tur ke mana?
Dialogue: 0,0:19:59.39,0:20:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Australia, memangnya kenapa?
Dialogue: 0,0:20:02.64,0:20:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu!
Dialogue: 0,0:20:04.18,0:20:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyuman apa itu?
Dialogue: 0,0:20:05.70,0:20:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:20:07.36,0:20:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kapan dan di mana?
Dialogue: 0,0:20:10.46,0:20:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senin depan jam sembilan pagi\Ndi Bandara Narita.
Dialogue: 0,0:20:13.63,0:20:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, jam sembilan di Narita.
Dialogue: 0,0:20:16.28,0:20:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:17.28,0:20:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentar!
Dialogue: 0,0:20:18.37,0:20:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada halangan?
Dialogue: 0,0:20:19.91,0:20:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cabang barunya di Bandara Narita?
Dialogue: 0,0:20:23.26,0:20:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:20:25.41,0:20:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan lupa bawa paspor.
Dialogue: 0,0:20:27.27,0:20:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mah di luar negeri, dong!
Dialogue: 0,0:20:29.92,0:20:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi aku sudah kepalang balas oke.
Dialogue: 0,0:20:33.67,0:20:34.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:34.42,0:20:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga perlu persiapan, tahu!
Dialogue: 0,0:20:37.26,0:20:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:20:38.82,0:20:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang akan menyiapkan\Nkebutuhan dasar kita,
Dialogue: 0,0:20:41.68,0:20:45.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan aku sudah memastikan\Nkamu punya paspor juga!
Dialogue: 0,0:20:45.39,0:20:47.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biadab!
Dialogue: 0,0:20:47.18,0:20:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, rekam saja anime favoritmu\Ndan ayo kerja di sana!
Dialogue: 0,0:20:50.77,0:20:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!\NSiaran langsungku yang berharga!
Dialogue: 0,0:21:01.45,0:21:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kakak?
Dialogue: 0,0:21:06.83,0:21:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, dengan kediaman Kitahara.
Dialogue: 0,0:21:09.01,0:21:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori?
Dialogue: 0,0:21:10.58,0:21:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kak?
Dialogue: 0,0:21:12.72,0:21:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan urusan penting, sih.
Dialogue: 0,0:21:14.90,0:21:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak mau minta kiriman uang?
Dialogue: 0,0:21:17.09,0:21:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan ini memang belum dikirim,\Ntapi bukan soal itu.
Dialogue: 0,0:21:21.87,0:21:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti...
Dialogue: 0,0:21:23.09,0:21:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah saatnya pulang kampung?
Dialogue: 0,0:21:25.04,0:21:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, tapi aku punya permintaan.
Dialogue: 0,0:21:28.06,0:21:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong segera kirimkan pasporku.
Dialogue: 0,0:21:30.87,0:21:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paspor?
Dialogue: 0,0:21:32.98,0:21:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa tiba-tiba?
Dialogue: 0,0:21:35.11,0:21:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang mendadak, tapi aku mau menghabiskan\Nsisa musim panasku di luar negeri.
Dialogue: 0,0:21:42.27,0:21:43.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:47.95,0:21:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang tidak mau mengirimkannya.
Dialogue: 0,0:21:50.72,0:21:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:21:51.62,0:21:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu belum setor muka\Nselama musim panas di sini.
Dialogue: 0,0:21:54.72,0:21:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah sendiri.
Dialogue: 0,0:21:56.38,0:21:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti harus ambil sendiri?
Dialogue: 0,0:22:01.09,0:22:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:22:02.63,0:22:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada masalah?
Dialogue: 0,0:22:04.51,0:22:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dan itu...
Dialogue: 0,0:22:07.09,0:22:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terasa hawa mengerikan di belakangku.
