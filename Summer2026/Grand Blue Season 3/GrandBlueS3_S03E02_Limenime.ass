Dialogue: 0,0:00:00.00,0:00:00.27,sign,,0000,0000,0000,,ACARA INI ADALAH KARYA FIKSI.
Dialogue: 0,0:00:00.27,0:00:00.58,sign,,0000,0000,0000,,ANAK DI BAWAH UMUR DILARANG KERAS\NMINUM ALKOHOL OLEH HUKUM.
Dialogue: 0,0:00:00.58,0:00:01.09,sign,,0000,0000,0000,,KAMI JUGA TIDAK BERMAKSUD MENGANJURKAN\NPEMAKSAAN MINUM ALKOHOL,
Dialogue: 0,0:00:01.09,0:00:01.79,sign,,0000,0000,0000,,KONSUMSI ALKOHOL BERLEBIHAN, MAUPUN TINDAKAN\NTIDAK SENONOH SAAT PESTA MINUM.
Dialogue: 0,0:00:01.79,0:00:02.40,sign,,0000,0000,0000,,MOHON ANGGAP INI SEMATA-MATA\NSEBAGAI ANIME KOMEDI.
Dialogue: 0,0:00:02.40,0:00:03.10,sign,,0000,0000,0000,,SELURUH KARAKTER YANG MENGONSUMSI\NALKOHOL DALAM KARYA INI
Dialogue: 0,0:00:03.10,0:00:03.68,sign,,0000,0000,0000,,TELAH BERUSIA 20 TAHUN ATAU LEBIH.
Dialogue: 0,0:00:03.68,0:00:04.38,sign,,0000,0000,0000,,DEMI MENYESUAIKAN DENGAN STANDAR\NKEPATUHAN TERKINI.
Dialogue: 0,0:00:04.38,0:00:04.98,sign,,0000,0000,0000,,MULAI MUSIM INI\NUKURAN SENSOR HITAM KAMI NAIK 5%.
Dialogue: 0,0:00:17.29,0:00:25.30,sign,,0000,0000,0000,,GRAND BLUE MUSIM 3
Dialogue: 0,0:01:37.45,0:01:39.95,sign,,0000,0000,0000,,AKULAH KAKAK KANDUNGNYA
Dialogue: 0,0:01:54.72,0:01:57.22,sign,,0000,0000,0000,,PENCINTA ADIK PEREMPUAN
Dialogue: 0,0:01:57.22,0:02:00.22,sign,,0000,0000,0000,,WAJAH MISS KONTES NO. 1, DADANYA LUMAYAN,\NPANGGUL SEKSI, SUDUT PANDANG IMAMURA
