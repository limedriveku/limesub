Dialogue: 0,0:13:48.56,0:13:50.37,sign,,0000,0000,0000,,PENCINTA ADIK PEREMPUAN
Dialogue: 0,0:15:14.39,0:15:19.15,sign,,0000,0000,0000,,TAKUT ORANG ASING
Dialogue: 0,0:15:27.78,0:15:30.14,sign,,0000,0000,0000,,PENCINTA ADIK PEREMPUAN
Dialogue: 0,0:15:32.41,0:15:34.66,sign,,0000,0000,0000,,ANAK TK, PENGELOLA PENGINAPAN,
Dialogue: 0,0:15:34.66,0:15:38.67,sign,,0000,0000,0000,,ADIK PEREMPUAN DI KEHIDUPAN SEBELUMNYA
Dialogue: 0,0:15:55.68,0:15:58.27,sign,,0000,0000,0000,,KAMAR SHIORI
Dialogue: 0,0:15:58.27,0:15:59.81,sign,,0000,0000,0000,,PENCINTA ADIK PEREMPUAN
Dialogue: 0,0:16:11.70,0:16:19.21,sign,,0000,0000,0000,,PENCINTA ADIK PEREMPUAN
Dialogue: 0,0:16:26.97,0:16:28.97,sign,,0000,0000,0000,,PENGINAPAN KITAHARA
Dialogue: 0,0:16:37.57,0:16:39.92,sign,,0000,0000,0000,,HEHEHE
Dialogue: 0,0:16:39.92,0:16:41.23,sign,,0000,0000,0000,,KAMI DATANG UNTUK BERMAIN, NONA.
Dialogue: 0,0:16:41.23,0:16:42.94,sign,,0000,0000,0000,,JANGAN MEMBERONTAK
Dialogue: 0,0:16:42.94,0:16:45.06,sign,,0000,0000,0000,,BIARKAN KAMI MEMANJAKANMU
Dialogue: 0,0:17:20.56,0:17:22.80,sign,,0000,0000,0000,,KAMI LOLICON
Dialogue: 0,0:17:22.80,0:17:25.02,sign,,0000,0000,0000,,KAMI MAU BERBUAT MESUM PADAMU
Dialogue: 0,0:18:19.70,0:18:22.71,sign,,0000,0000,0000,,PASPOR JEPANG
Dialogue: 0,0:19:54.67,0:19:57.68,sign,,0000,0000,0000,,JANGAN BERLARI DI LORONG.
Dialogue: 0,0:23:44.94,0:23:49.95,sign,,0000,0000,0000,,SELANJUTNYA:\NOPERASI MEREBUT KEMBALI PASPOR
Dialogue: 0,0:01:39.95,0:01:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan dia padamu.
Dialogue: 0,0:01:42.35,0:01:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini bicara apa?\NMana bisa aku menghentikannya.
Dialogue: 0,0:01:46.00,0:01:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:01:47.92,0:01:50.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu termasuk adik perempuan juga.
Dialogue: 0,0:01:50.85,0:01:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu aku harus memanggil\NImamura "Kakak"?
Dialogue: 0,0:01:53.59,0:01:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:02:03.18,0:02:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisa, aku tidak enak bilangnya,
Dialogue: 0,0:02:06.23,0:02:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kamu tidak lolos persyaratan.
Dialogue: 0,0:02:09.34,0:02:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu jauh lebih bikin kesal.
Dialogue: 0,0:02:18.24,0:02:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum bir di kereta\Nternyata enak juga!
Dialogue: 0,0:02:20.54,0:02:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, iya.
Dialogue: 0,0:02:21.75,0:02:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok sama makanan kereta,\Ncoba kamu juga...
Dialogue: 0,0:02:25.09,0:02:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:02:26.51,0:02:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku mulai mabuk.
Dialogue: 0,0:02:28.50,0:02:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Cuma karena bir?
Dialogue: 0,0:02:32.67,0:02:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:02:34.26,0:02:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa tidak sadar?
Dialogue: 0,0:02:36.75,0:02:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa gawat kalau pulang kampung\Nsambil mabuk.
Dialogue: 0,0:02:39.26,0:02:42.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah minum air.
Dialogue: 0,0:02:42.27,0:02:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau beli minuman dulu.
Dialogue: 0,0:02:46.50,0:02:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Kitahara.
Dialogue: 0,0:02:48.18,0:02:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:02:49.02,0:02:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak sedarah sama Chisa, kan?
Dialogue: 0,0:02:52.35,0:02:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, soal itu.
Dialogue: 0,0:02:54.21,0:02:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ayahku anak angkat.
Dialogue: 0,0:02:56.28,0:02:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:02:57.49,0:03:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cocoknya jadi gadis penyihir!
Dialogue: 0,0:03:00.16,0:03:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngawur! Cocoknya hakama!
Dialogue: 0,0:03:02.78,0:03:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lagi berantem?\N- Tidak, gadis penyihir!
Dialogue: 0,0:03:03.76,0:03:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kedengarannya bahasa asing.\N- Tidak, gadis penyihir!
Dialogue: 0,0:03:04.96,0:03:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kedengarannya bahasa asing.\N- Tidak, cocoknya hakama!
Dialogue: 0,0:03:05.79,0:03:07.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mengganggu penumpang saja.\N- Tidak, cocoknya hakama!
Dialogue: 0,0:03:07.87,0:03:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku peringati mereka dulu.
Dialogue: 0,0:03:10.04,0:03:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dia membenciku\Ngara-gara saran itu?
Dialogue: 0,0:03:12.42,0:03:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang harusnya bilang begitu!
Dialogue: 0,0:03:15.68,0:03:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo kita buktikan!
Dialogue: 0,0:03:18.30,0:03:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah?
Dialogue: 0,0:03:19.44,0:03:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be?
Dialogue: 0,0:03:20.81,0:03:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ce?
Dialogue: 0,0:03:21.92,0:03:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Kitahara?
Dialogue: 0,0:03:23.09,0:03:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sut, tidak usah dibahas lagi.
Dialogue: 0,0:03:25.73,0:03:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik jangan ikut campur.
Dialogue: 0,0:03:27.74,0:03:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa...
Dialogue: 0,0:03:28.40,0:03:30.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!\NTakutnya kita tidak bisa pulang!
Dialogue: 0,0:03:30.82,0:03:34.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga beres sendiri.
Dialogue: 0,0:03:34.08,0:03:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:03:36.99,0:03:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan?
Dialogue: 0,0:03:44.22,0:03:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:45.23,0:03:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouhei.
Dialogue: 0,0:03:47.08,0:03:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cuma pergi berdua di sini,\Ntidak ada yang lain, paham?
Dialogue: 0,0:03:50.78,0:03:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi, sih?
Dialogue: 0,0:03:53.34,0:03:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba aku sakit perut,\Njadi mau ke toilet dulu.
Dialogue: 0,0:04:02.27,0:04:04.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kekasihku.
Dialogue: 0,0:04:04.85,0:04:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kamu sudah\Nmacam-macam sama dia!
Dialogue: 0,0:04:06.86,0:04:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan perawan,\Ndia tidak bisa menggunakan sihir!
Dialogue: 0,0:04:10.08,0:04:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentar, bentar, bentar!\NBiar kami dengarkan penjelasan kalian dulu!
Dialogue: 0,0:04:14.93,0:04:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama Imamura Kouhei.
Dialogue: 0,0:04:16.72,0:04:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ngawur!
Dialogue: 0,0:04:18.06,0:04:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:04:18.89,0:04:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak kenal\Nditambah mereka orang luar negeri.
Dialogue: 0,0:04:21.41,0:04:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan komunikasiku...
Dialogue: 0,0:04:31.78,0:04:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, masalah sudah selesai.
Dialogue: 0,0:04:34.43,0:04:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus bereskan dia.
Dialogue: 0,0:04:36.72,0:04:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku juga berpikir begitu.
Dialogue: 0,0:04:39.88,0:04:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eksekusi!
Dialogue: 0,0:04:41.07,0:04:41.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:04:41.86,0:04:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sekongkol buat apa?
Dialogue: 0,0:04:43.64,0:04:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kasihan dia punya pacar sepertimu!\N- Ah, yah...
Dialogue: 0,0:04:45.84,0:04:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Benar!\N- Eng...
Dialogue: 0,0:04:46.88,0:04:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kasihan dia punya pacar sepertimu!\N- Aku tidak paham perkataannya!
Dialogue: 0,0:04:49.14,0:04:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bereaksi sama seperti Kouhei.
Dialogue: 0,0:04:51.86,0:04:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku juga berpikir begitu.
Dialogue: 0,0:04:56.37,0:04:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, baguslah.
Dialogue: 0,0:05:01.16,0:05:02.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minumlah!
Dialogue: 0,0:05:02.78,0:05:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok beda!
Dialogue: 0,0:05:04.78,0:05:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu terjemahkan, dong.
Dialogue: 0,0:05:06.58,0:05:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tidak niat bermusuhan.
Dialogue: 0,0:05:08.48,0:05:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mana bisa.
Dialogue: 0,0:05:10.35,0:05:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:05:12.17,0:05:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan aku tidak mengerti
Dialogue: 0,0:05:13.73,0:05:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang mereka bicarakan.
Dialogue: 0,0:05:15.29,0:05:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa bisa nyambung?
Dialogue: 0,0:05:17.92,0:05:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dia, meski beda bahasa,\Nkami bisa saling memahami.
Dialogue: 0,0:05:21.68,0:05:24.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:05:24.11,0:05:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei.
Dialogue: 0,0:05:29.12,0:05:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toleransi alkohol orang Jepang\Ncuma selevel ini rupanya.
Dialogue: 0,0:05:32.06,0:05:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru sebegitu saja sudah butuh air,\Npantas kabur dari tantangan.
Dialogue: 0,0:05:38.94,0:05:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:39.71,0:05:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa yang kalian bicarakan,\Ntapi kami akan meladeni.
Dialogue: 0,0:05:42.95,0:05:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami boleh saja kalah dalam hal lain,
Dialogue: 0,0:05:49.94,0:05:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau soal alkohol,\NPab tidak boleh kalah!
Dialogue: 0,0:06:00.54,0:06:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkohol ini...
Dialogue: 0,0:06:03.74,0:06:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:06:04.72,0:06:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya.
Dialogue: 0,0:06:06.22,0:06:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih belum!
Dialogue: 0,0:06:07.36,0:06:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duelnya baru dimulai sekarang!
Dialogue: 0,0:06:12.88,0:06:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?
Dialogue: 0,0:06:16.48,0:06:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:18.48,0:06:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang agak sinting.
Dialogue: 0,0:06:21.49,0:06:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat minta maaf!
Dialogue: 0,0:06:23.17,0:06:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta maaf.
Dialogue: 0,0:06:24.19,0:06:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:06:25.49,0:06:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Maaf!
Dialogue: 0,0:06:35.30,0:06:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sial!\N- Cih!
Dialogue: 0,0:06:36.32,0:06:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka itu siapa?
Dialogue: 0,0:06:39.00,0:06:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah, tiba-tiba mengajakku bicara.
Dialogue: 0,0:06:42.76,0:06:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggap saja turis gila.
Dialogue: 0,0:06:45.68,0:06:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku bisa berempati\Nsama perempuan tadi.
Dialogue: 0,0:06:50.43,0:06:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:06:51.77,0:06:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sama-sama kesulitan\Nmengatur dua orang idiot.
Dialogue: 0,0:06:56.02,0:06:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aku juga sama.
Dialogue: 0,0:06:58.15,0:06:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:07:01.74,0:07:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berpikir diri kalian normal?
Dialogue: 0,0:07:04.40,0:07:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang harusnya bilang begitu!
Dialogue: 0,0:07:06.66,0:07:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku yang bilang begitu!
Dialogue: 0,0:07:16.48,0:07:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah hampir sampai.
Dialogue: 0,0:07:20.29,0:07:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal cari cara menyembunyikan ini.
Dialogue: 0,0:07:24.64,0:07:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kukembalikan sampai dia\Nmau meneruskan bisnis keluarga.
Dialogue: 0,0:07:29.42,0:07:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak tengik.
Dialogue: 0,0:07:34.31,0:07:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:07:35.71,0:07:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Penginapan Kitahara.
Dialogue: 0,0:07:37.81,0:07:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu, Paman, Bibi.
Dialogue: 0,0:07:40.86,0:07:42.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chisa, lama tidak bertemu.
Dialogue: 0,0:07:42.96,0:07:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah besar, ya.
Dialogue: 0,0:07:44.82,0:07:47.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia temannya Iori?
Dialogue: 0,0:07:47.36,0:07:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, namaku Imamura Kouhei.
Dialogue: 0,0:07:50.45,0:07:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kandungnya Shiori!
Dialogue: 0,0:07:53.70,0:07:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu!
Dialogue: 0,0:07:55.45,0:07:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bawa perselisihan ke keluargaku!
Dialogue: 0,0:07:57.52,0:07:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud begitu.
Dialogue: 0,0:07:59.65,0:08:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru itu lebih parah!
Dialogue: 0,0:08:02.14,0:08:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang.
Dialogue: 0,0:08:03.58,0:08:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, aku tidak akan mengakuinya.
Dialogue: 0,0:08:05.52,0:08:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah! Jangan bikin arahnya jadi ke sana!
Dialogue: 0,0:08:09.01,0:08:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya bagaimana?
Dialogue: 0,0:08:11.26,0:08:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya teman kami.
Dialogue: 0,0:08:14.72,0:08:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, masalahnya bukan di situ.
Dialogue: 0,0:08:18.54,0:08:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu, pasporku ada di mana?
Dialogue: 0,0:08:20.73,0:08:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku tidak lihat.
Dialogue: 0,0:08:23.76,0:08:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Shiori yang menyimpannya.
Dialogue: 0,0:08:27.11,0:08:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori, bisa minta tolong ambilkan?
Dialogue: 0,0:08:30.11,0:08:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan pernah kuberikan.
Dialogue: 0,0:08:32.87,0:08:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggu depan aku mau ke Palau.
Dialogue: 0,0:08:36.14,0:08:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu berangkat.
Dialogue: 0,0:08:37.87,0:08:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu akan tinggal di sini.
Dialogue: 0,0:08:40.64,0:08:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang dan selamanya.
Dialogue: 0,0:08:42.13,0:08:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang kamu seram banget.
Dialogue: 0,0:08:45.50,0:08:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya biar dikembalikan?
Dialogue: 0,0:08:47.74,0:08:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu introspeksi diri,\Nrajin belajar,
Dialogue: 0,0:08:52.08,0:08:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melakukan kewajibanmu,\Nsuatu hari pasti dikembalikan.
Dialogue: 0,0:08:55.01,0:08:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu abstrak!
Dialogue: 0,0:08:57.73,0:09:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, kupersembahkan dia!
Dialogue: 0,0:09:00.05,0:09:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neng Shiori, ini kakakmu Kouhei.
Dialogue: 0,0:09:02.52,0:09:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Chisa, apa kamu mau\Nke onsen duluan?
Dialogue: 0,0:09:06.27,0:09:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, kebetulan aku sedang berkeringat.
Dialogue: 0,0:09:09.40,0:09:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori, ada yang kamu inginkan tidak?
Dialogue: 0,0:09:12.16,0:09:13.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:09:13.44,0:09:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamera SLR.
Dialogue: 0,0:09:14.60,0:09:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra yang berbakti.
Dialogue: 0,0:09:16.20,0:09:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tanya kalian!
Dialogue: 0,0:09:17.91,0:09:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Chisa, handuknya sudah kusiapkan di sana.
Dialogue: 0,0:09:22.42,0:09:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat menikmati.
Dialogue: 0,0:09:23.87,0:09:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Shiori!
Dialogue: 0,0:09:27.62,0:09:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal waktu kita mepet!
Dialogue: 0,0:09:30.30,0:09:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya begini, sih.
Dialogue: 0,0:09:31.78,0:09:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya adik keras kepala\Nmenyenangkan juga.
Dialogue: 0,0:09:34.68,0:09:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana supaya dikembalikan, ya?
Dialogue: 0,0:09:38.18,0:09:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memohon dengan tulus?
Dialogue: 0,0:09:40.51,0:09:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berbuat baik supaya kamu\Ndipercaya olehnya.
Dialogue: 0,0:09:42.69,0:09:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya harus mengambil hatinya.
Dialogue: 0,0:09:45.12,0:09:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buruan sana, waktu kita mepet.
Dialogue: 0,0:09:48.54,0:09:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa harus sejauh itu?
Dialogue: 0,0:09:51.09,0:09:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:51.84,0:09:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitahara?
Dialogue: 0,0:09:52.95,0:09:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuma merajuk dan bersikap egois.
Dialogue: 0,0:09:56.21,0:09:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi pikirkanlah perasaan Shiori juga.
Dialogue: 0,0:09:58.75,0:10:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak peduli!
Dialogue: 0,0:10:00.70,0:10:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya urusan sendiri!
Dialogue: 0,0:10:03.07,0:10:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuceramahi dia sebagai kakak!
Dialogue: 0,0:10:13.72,0:10:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup, Shiori!
Dialogue: 0,0:10:16.72,0:10:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai rela menjilat sepatumu!
Dialogue: 0,0:10:24.35,0:10:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuceramahi dia keras-keras.
Dialogue: 0,0:10:26.99,0:10:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah kalau kamu maunya begitu.
Dialogue: 0,0:10:29.86,0:10:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana paspornya?
Dialogue: 0,0:10:31.58,0:10:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara mental, aku sudah mendapatkannya.
Dialogue: 0,0:10:34.86,0:10:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, paspor itu benda fisik.
Dialogue: 0,0:10:37.76,0:10:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:10:39.39,0:10:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang tinggal mencuri fisiknya\Ndi kamar Shiori.
Dialogue: 0,0:10:43.42,0:10:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulus banget cara mengajak orang
Dialogue: 0,0:10:45.11,0:10:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kriminalnya!
Dialogue: 0,0:10:46.13,0:10:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rute yang tidak terlihat mata...
Dialogue: 0,0:10:50.02,0:10:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kamu disebut kakak palsu.
Dialogue: 0,0:10:52.94,0:10:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:10:53.63,0:10:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:10:54.82,0:10:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak kandung
Dialogue: 0,0:10:56.26,0:10:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti bisa mengambil hati\Nadiknya dengan mudah.
Dialogue: 0,0:10:59.28,0:11:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya kamu bisa?
Dialogue: 0,0:11:01.89,0:11:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas.
Dialogue: 0,0:11:03.30,0:11:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci mengambil hati adalah\N"pengamatan saksama".
Dialogue: 0,0:11:07.46,0:11:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:11:08.40,0:11:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, menyamarlah
Dialogue: 0,0:11:11.53,0:11:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar tidak ketahuan,
Dialogue: 0,0:11:13.40,0:11:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu catat seluruh kesehariannya\Ndari jarak dekat.
Dialogue: 0,0:11:17.33,0:11:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:11:18.32,0:11:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Analisis catatan itu\Nuntuk mencari tahu hobi dan seleranya.
Dialogue: 0,0:11:22.41,0:11:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu, sekarang bisa bantu aku?
Dialogue: 0,0:11:30.92,0:11:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:11:32.10,0:11:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Kitahara, ada penguntit\Nyang mengincar Neng Shiori!
Dialogue: 0,0:11:36.67,0:11:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, memang ada.
Dialogue: 0,0:11:39.53,0:11:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu mau menyerahkan diri?
Dialogue: 0,0:11:41.68,0:11:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku!
Dialogue: 0,0:11:43.68,0:11:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di penginapan kami.
Dialogue: 0,0:11:46.21,0:11:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mengawasinya\Ndari lensa kamera...
Dialogue: 0,0:11:50.02,0:11:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu melihat cermin?
Dialogue: 0,0:11:51.23,0:11:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang bukan aku!
Dialogue: 0,0:12:02.75,0:12:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang mesum di sana.
Dialogue: 0,0:12:04.58,0:12:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi orang mesumnya ada dua.
Dialogue: 0,0:12:06.32,0:12:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bertambah satu?
Dialogue: 0,0:12:08.00,0:12:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sudah melaporkannya,\Nsudah tidak ada masalah, kan?
Dialogue: 0,0:12:11.07,0:12:12.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak segampang itu!
Dialogue: 0,0:12:13.26,0:12:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru tahap mengamati,\Nfase eksekusinya beda lagi.
Dialogue: 0,0:12:16.62,0:12:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu paham banget\Nsama trik kriminal, ya.
Dialogue: 0,0:12:19.97,0:12:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda!\NIni bukan saatnya memujiku!
Dialogue: 0,0:12:23.62,0:12:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan memanfaatkan\Ninformasi itu untuk mendekat.
Dialogue: 0,0:12:27.23,0:12:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu terjadi,\Nkita harus membasmi para mesum itu.
Dialogue: 0,0:12:30.48,0:12:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana cara kita tahu\Nsiapa yang mesum itu?
Dialogue: 0,0:12:33.57,0:12:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu, aku serahkan padamu.
Dialogue: 0,0:12:35.54,0:12:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:12:37.71,0:12:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kalian sejenis.
Dialogue: 0,0:12:40.02,0:12:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:12:41.99,0:12:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa menemukannya\Nsegampang itu...
Dialogue: 0,0:12:50.86,0:12:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sini tidak ada yang janggal.
Dialogue: 0,0:12:52.94,0:12:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa?
Dialogue: 0,0:12:54.56,0:12:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak terlihat janggal di matamu?
Dialogue: 0,0:12:57.28,0:12:58.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa, sih?
Dialogue: 0,0:12:58.54,0:12:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:12:59.51,0:13:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Onsennya nyaman sekali, terima kasih.
Dialogue: 0,0:13:02.24,0:13:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:13:06.02,0:13:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu imut!
Dialogue: 0,0:13:07.01,0:13:08.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju!
Dialogue: 0,0:13:10.02,0:13:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan!
Dialogue: 0,0:13:17.28,0:13:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan kenakan ini,Nona.
Dialogue: 0,0:13:19.19,0:13:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecantikanmu pasti bersinar\Nlebih terang lagi!
Dialogue: 0,0:13:22.30,0:13:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kita tolong mereka.
Dialogue: 0,0:13:24.64,0:13:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:27.02,0:13:28.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:28.54,0:13:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:13:30.43,0:13:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, sih?
Dialogue: 0,0:13:31.36,0:13:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menolongnya, tapi...
Dialogue: 0,0:13:36.50,0:13:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwaku malah mendukung turis itu!
Dialogue: 0,0:13:42.50,0:13:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin lihat mereka berpakaian itu?
Dialogue: 0,0:13:45.41,0:13:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saja kalau mau\Ndibenci sama Shiori.
Dialogue: 0,0:13:50.37,0:13:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak macam apa yang tidak bisa\Nmelindungi adiknya...
Dialogue: 0,0:13:53.70,0:13:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian kamu bukan siapa-siapa dia.
Dialogue: 0,0:13:55.81,0:13:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kalian.
Dialogue: 0,0:13:58.78,0:14:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sampai di situ.
Dialogue: 0,0:14:00.43,0:14:02.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para gadis itu jadi terganggu.
Dialogue: 0,0:14:08.10,0:14:09.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo! Bocah-Bocah!
Dialogue: 0,0:14:09.66,0:14:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berduel lagi?
Dialogue: 0,0:14:11.83,0:14:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum! Minum!
Dialogue: 0,0:14:14.00,0:14:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka ini...
Dialogue: 0,0:14:15.47,0:14:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengil banget.
Dialogue: 0,0:14:18.21,0:14:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, di sana ada polisi!
Dialogue: 0,0:14:20.84,0:14:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sial!\N- Ada polisi!
Dialogue: 0,0:14:22.22,0:14:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:14:23.38,0:14:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:14:25.38,0:14:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Shiori?
Dialogue: 0,0:14:26.98,0:14:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terima kasih sudah menolongku.
Dialogue: 0,0:14:32.13,0:14:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma hal sepele.
Dialogue: 0,0:14:34.25,0:14:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak ada aku, bisa gawat ini.
Dialogue: 0,0:14:37.22,0:14:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:38.29,0:14:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru sadar kakak beradik itu\Nharus saling menolong.
Dialogue: 0,0:14:42.29,0:14:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:44.11,0:14:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pasporku...
Dialogue: 0,0:14:45.61,0:14:46.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh.
Dialogue: 0,0:14:49.37,0:14:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak boleh?\NPadahal aku sudah menolongnya!
Dialogue: 0,0:14:52.61,0:14:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisi keras kepalanya pun mengagumkan.
Dialogue: 0,0:14:55.63,0:14:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak mengagumkan!
Dialogue: 0,0:14:57.73,0:14:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada cara lain...
Dialogue: 0,0:14:58.63,0:14:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:14:59.63,0:15:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:15:00.58,0:15:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu...
Dialogue: 0,0:15:02.63,0:15:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temannya mereka?
Dialogue: 0,0:15:04.37,0:15:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, namaku Kalina, teman mereka.
Dialogue: 0,0:15:08.61,0:15:11.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka sudah merepotkan kalian.
Dialogue: 0,0:15:11.14,0:15:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kami tidak apa-apa, kok.
Dialogue: 0,0:15:14.39,0:15:17.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengganggu Neng Shiori!
Dialogue: 0,0:15:17.22,0:15:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf!
Dialogue: 0,0:15:19.15,0:15:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengagumi wanita Jepang.
Dialogue: 0,0:15:22.62,0:15:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama Shiori dan Chisa, sih.\NMemang kelihatan tertarik banget
Dialogue: 0,0:15:26.16,0:15:27.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama
Dialogue: 0,0:15:27.78,0:15:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka menyukai Yoimachi Kirara.
Dialogue: 0,0:15:30.14,0:15:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kirara? Apa itu?
Dialogue: 0,0:15:32.41,0:15:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karakter adik perempuan dari Musim Semi Biru.
Dialogue: 0,0:15:34.66,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa Neng Shiori mirip sama dia!
Dialogue: 0,0:15:38.67,0:15:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada mereka.\NAku akan memberi teguran keras
Dialogue: 0,0:15:41.79,0:15:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lakukan, takutnya mereka\Nsampai menyusup ke kamarnya.
Dialogue: 0,0:15:45.54,0:15:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:15:47.74,0:15:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami permisi dulu.
Dialogue: 0,0:15:51.28,0:15:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kita ke kamarnya Shiori.
Dialogue: 0,0:15:53.84,0:15:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:15:55.68,0:15:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menjatuhkan peta rumahnya.
Dialogue: 0,0:15:58.27,0:15:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:15:59.81,0:16:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adikku bisa dalam bahaya!\NKalau mereka yang memungutnya,
Dialogue: 0,0:16:03.95,0:16:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan adikmu.
Dialogue: 0,0:16:07.52,0:16:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Kitahara!
Dialogue: 0,0:16:09.20,0:16:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bergegas—
Dialogue: 0,0:16:10.69,0:16:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:16:11.70,0:16:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa menghentikanku?
Dialogue: 0,0:16:13.18,0:16:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shiori sedang terdesak, kan?
Dialogue: 0,0:16:15.23,0:16:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku sudah bilang begitu!
Dialogue: 0,0:16:17.73,0:16:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:16:20.03,0:16:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan\Nuntuk membuatnya berutang budi!
Dialogue: 0,0:16:24.53,0:16:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar iblis.
Dialogue: 0,0:16:36.48,0:16:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa?
Dialogue: 0,0:16:37.57,0:16:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, namaku Tanaka.
Dialogue: 0,0:16:39.92,0:16:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ken.
Dialogue: 0,0:16:41.23,0:16:42.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dari Kanada?
Dialogue: 0,0:16:42.94,0:16:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, aku dari Amerika.
Dialogue: 0,0:16:45.06,0:16:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Orang mesum!
Dialogue: 0,0:16:46.74,0:16:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun!
Dialogue: 0,0:16:47.76,0:16:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:16:51.49,0:16:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan kalian\Nmenyakiti Shiori.
Dialogue: 0,0:16:54.18,0:16:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak?
Dialogue: 0,0:16:59.87,0:17:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa, Shiori?
Dialogue: 0,0:17:01.57,0:17:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kak.
Dialogue: 0,0:17:03.95,0:17:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak memang hebat!\NIdamanku!
Dialogue: 0,0:17:07.46,0:17:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:17:09.26,0:17:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembalikan paspormu.
Dialogue: 0,0:17:12.76,0:17:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah yang kuincar.
Dialogue: 0,0:17:15.01,0:17:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mah mustahil.
Dialogue: 0,0:17:16.64,0:17:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku bakal begini.
Dialogue: 0,0:17:20.56,0:17:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ichiro bermain tenis.
Dialogue: 0,0:17:22.80,0:17:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanako suka sepak bola.
Dialogue: 0,0:17:25.66,0:17:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:17:28.22,0:17:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan melindungi adikku!
Dialogue: 0,0:17:30.78,0:17:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira begitu.
Dialogue: 0,0:17:32.46,0:17:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, kenapa kamu bisa\Nada di kamarnya Shiori?
Dialogue: 0,0:17:35.94,0:17:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelanjutannya...
Dialogue: 0,0:17:37.54,0:17:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak, Kak Kouhei!
Dialogue: 0,0:17:40.51,0:17:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah dipikirkan.
Dialogue: 0,0:17:43.04,0:17:44.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai bentuk terima kasih,
Dialogue: 0,0:17:44.79,0:17:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong acak-acak diriku!
Dialogue: 0,0:17:47.52,0:17:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neng Shiori!
Dialogue: 0,0:17:50.05,0:17:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:17:51.38,0:17:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kamu bilang begitu\Ndi depan kakak kandungnya.
Dialogue: 0,0:17:54.32,0:17:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, jadi malu.
Dialogue: 0,0:17:56.05,0:17:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mending bantu aku\Nmerebut kembali pasporku!
Dialogue: 0,0:17:58.99,0:18:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubunganku dengan Neng Shiori\Nlebih penting!
Dialogue: 0,0:18:03.97,0:18:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kita ambil jalan tengah.
Dialogue: 0,0:18:06.82,0:18:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:18:08.07,0:18:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita buat kompromi.
Dialogue: 0,0:18:10.46,0:18:12.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kompromi, ya?
Dialogue: 0,0:18:12.07,0:18:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, kalian berdua!
Dialogue: 0,0:18:14.61,0:18:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah.
Dialogue: 0,0:18:15.47,0:18:17.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah dipikirkan.
Dialogue: 0,0:18:17.46,0:18:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nsebagai tanda terima kasih,
Dialogue: 0,0:18:19.70,0:18:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong acak-acak paspor ini!
Dialogue: 0,0:18:22.71,0:18:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak keberatan,\Nboleh saja.
Dialogue: 0,0:18:24.90,0:18:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Otakmu mendidih\Nkarena kepanasan, ya, bodoh?
Dialogue: 0,0:18:28.21,0:18:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya mereka benaran\Nke sana atau tidak.
Dialogue: 0,0:18:30.62,0:18:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menjamin itu.
Dialogue: 0,0:18:32.72,0:18:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka menyukai Yoimachi Kirara,\Nmustahil tidak tertarik Neng Shiori.
Dialogue: 0,0:18:36.94,0:18:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya mereka semirip itu, ya?
Dialogue: 0,0:18:40.72,0:18:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, bisa dibilang Kirara di dunia nyata...
Dialogue: 0,0:18:45.92,0:18:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotegawa juga mirip, tapi umurnya...
Dialogue: 0,0:18:48.24,0:18:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, ada yang salah\Ndengan baju gantiku.
Dialogue: 0,0:18:51.49,0:18:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana pakaianmu sebelumnya?
Dialogue: 0,0:18:53.34,0:18:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak melihatnya.
Dialogue: 0,0:18:55.24,0:18:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti cuma bisa memakai itu.
Dialogue: 0,0:18:57.31,0:18:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku mau!
Dialogue: 0,0:18:59.36,0:19:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian siapa yang menaruh ini di sini?
Dialogue: 0,0:19:04.25,0:19:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu di situ, ayahku.
Dialogue: 0,0:19:06.15,0:19:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, anakku?\NPakailah itu lalu beranjak dari sini.
Dialogue: 0,0:19:09.63,0:19:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang aneh dengan baju gantiku!
Dialogue: 0,0:19:11.86,0:19:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kembalikan bajuku!
Dialogue: 0,0:19:13.78,0:19:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak suka baju ini?
Dialogue: 0,0:19:15.33,0:19:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas-jelas tidak suka!
Dialogue: 0,0:19:17.39,0:19:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:18.82,0:19:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku juga akan berpakaian sama.
Dialogue: 0,0:19:21.57,0:19:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Otakmu juga mendidih\Nkarena kepanasan, ya?
Dialogue: 0,0:19:24.39,0:19:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba bawa kostum\NYoimachi Kirara?
Dialogue: 0,0:19:28.40,0:19:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamu yang ada di lobi tadi...
Dialogue: 0,0:19:30.92,0:19:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melakukannya, Tuan.
Dialogue: 0,0:19:33.36,0:19:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:19:34.10,0:19:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, para tamu ini memaksa...
Dialogue: 0,0:19:37.09,0:19:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku ingin menolak\N- Kenakan ini!
Dialogue: 0,0:19:38.96,0:19:40.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tapi tidak bisa mengabaikannya.\N- Kenakan ini!
Dialogue: 0,0:19:41.89,0:19:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, serahkan padaku.
Dialogue: 0,0:19:45.46,0:19:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku memilih Iori yang genetiknya sama.
Dialogue: 0,0:19:48.35,0:19:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu.
Dialogue: 0,0:19:49.42,0:19:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal lihat jenis kelaminnya dulu!
Dialogue: 0,0:19:52.17,0:19:54.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu, Neng Shiori dalam bahaya!
Dialogue: 0,0:19:54.67,0:19:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak pernah introspeksi diri!
Dialogue: 0,0:19:57.68,0:19:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Neng Shiori!
Dialogue: 0,0:19:58.96,0:20:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:20:00.05,0:20:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua!
Dialogue: 0,0:20:03.76,0:20:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:04.68,0:20:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka tidur?
Dialogue: 0,0:20:06.91,0:20:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kurang tahu.
Dialogue: 0,0:20:09.10,0:20:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kamu baik-baik saja.
Dialogue: 0,0:20:10.74,0:20:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami khawatir.
Dialogue: 0,0:20:12.19,0:20:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah mengkhawatirkanku.
Dialogue: 0,0:20:14.66,0:20:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sebegitunya mengkhawatirkanku,\Nkenapa tidak tinggal di rumah saja?
Dialogue: 0,0:20:18.70,0:20:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak mungkin!\NAku menolak.
Dialogue: 0,0:20:21.84,0:20:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakmu Kouhei siap tinggal\Nbersamamu kapan saja.
Dialogue: 0,0:20:24.95,0:20:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Kouhei cocoknya tinggal di kota.
Dialogue: 0,0:20:28.16,0:20:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, lagian tidak banyak\Nsiaran anime di pedesaan.
Dialogue: 0,0:20:31.55,0:20:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:20:32.46,0:20:34.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tinggal streaming saja.
Dialogue: 0,0:20:34.64,0:20:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:20:37.07,0:20:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saputangan yang direndam dalam...
Dialogue: 0,0:20:40.97,0:20:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat?
Dialogue: 0,0:20:43.47,0:20:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:44.97,0:20:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah juga tidur?
Dialogue: 0,0:20:46.56,0:20:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan?
Dialogue: 0,0:20:47.89,0:20:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena kelelahan menjalani hari.
Dialogue: 0,0:20:50.98,0:20:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya kita selamat kali ini.
Dialogue: 0,0:20:53.70,0:20:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamu seperti mereka memang berbahaya.
Dialogue: 0,0:20:56.69,0:20:57.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:57.49,0:21:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tenang saja, malam ini\Nbiar kakakmu ini yang melindungimu.
Dialogue: 0,0:21:01.78,0:21:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, kamu akan selalu\Nada di sisiku, kan?
Dialogue: 0,0:21:05.62,0:21:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, soalnya aku masih ada kuliah.
Dialogue: 0,0:21:07.89,0:21:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lagian kamu tidak cocok belajar.
Dialogue: 0,0:21:11.50,0:21:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih!
Dialogue: 0,0:21:12.50,0:21:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kouhei, tolong alihkan pembicaraan\Nke arah yang benar!
Dialogue: 0,0:21:16.19,0:21:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:21:17.26,0:21:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ternyata begitu!
Dialogue: 0,0:21:19.63,0:21:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kouhei?
Dialogue: 0,0:21:21.26,0:21:25.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti lagi pura-pura tidur\Nsupaya bisa menyelinap nanti malam!
Dialogue: 0,0:21:25.86,0:21:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:21:28.02,0:21:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!\NAku tahu Shiori memang seimut itu!
Dialogue: 0,0:21:30.70,0:21:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus begini,\NNeng Shiori bisa dalam bahaya!
Dialogue: 0,0:21:35.77,0:21:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intip.
Dialogue: 0,0:21:37.28,0:21:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus aku harus bagaimana?
Dialogue: 0,0:21:39.38,0:21:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia butuh orang yang kuat, pintar,\Ndan bisa diandalkan!
Dialogue: 0,0:21:44.53,0:21:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intip.
Dialogue: 0,0:21:46.03,0:21:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti datang\Nke kamarnya Shiori malam ini!
Dialogue: 0,0:21:49.15,0:21:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi!
Dialogue: 0,0:21:50.79,0:21:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya mereka punya peta bikinan Kitahara\Nuntuk menyusup ke kamarnya!
Dialogue: 0,0:21:55.04,0:21:56.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:21:56.29,0:21:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:21:58.58,0:22:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, malam ini kamu dalam bahaya!
Dialogue: 0,0:22:01.60,0:22:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:22:03.58,0:22:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana, Kak?
Dialogue: 0,0:22:06.53,0:22:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, kena dia!\NSemua sesuai dengan rencana!
Dialogue: 0,0:22:11.07,0:22:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, aku bisa mendapatkan\Npasporku kembali!
