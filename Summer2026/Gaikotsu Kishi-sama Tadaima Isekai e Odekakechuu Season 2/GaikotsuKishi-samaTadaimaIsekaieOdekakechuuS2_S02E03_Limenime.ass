Dialogue: 0,0:01:55.47,0:01:59.02,sign,,0000,0000,0000,,KESATRIA TENGKORAK BERKELANA DI DUNIA LAIN\NMUSIM KEDUA
Dialogue: 0,0:06:04.59,0:06:06.80,sign,,0000,0000,0000,,KALKUN PEMABUK
Dialogue: 0,0:11:25.96,0:11:30.96,sign,,0000,0000,0000,,EPISODE 3: TARIAN KEHANCURAN PARA PENJAHAT\NDAN IKATAN KAKAK-BERADIK
Dialogue: 0,0:12:28.10,0:12:29.52,sign,,0000,0000,0000,,PEMULIHAN
Dialogue: 0,0:15:23.32,0:15:25.36,sign,,0000,0000,0000,,PEMULIHAN
Dialogue: 0,0:23:39.94,0:23:44.94,sign,,0000,0000,0000,,SELANJUTNYA:\NROH SANTO YANG BERKELIARAN DI DESA TERKUTUK
Dialogue: 0,0:23:44.94,0:23:51.45,sign,,0000,0000,0000,,ANAK YANG BAIK TIDAK BOLEH MEMANJAT DINDING, YA!\N#PONTASAATINIJUGASEDANGBERKELANA
Dialogue: 0,0:01:03.67,0:01:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shia, pemandangan dari sini\Nselalu yang terbaik!
Dialogue: 0,0:01:07.46,0:01:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!\NTidak sopan pada penonton!
Dialogue: 0,0:01:10.80,0:01:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sapa dulu mereka!
Dialogue: 0,0:01:16.43,0:01:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah sukses memanjat\Ntembok menara jam!
Dialogue: 0,0:01:27.11,0:01:29.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tontonan yang bagus.\N- Hebat.
Dialogue: 0,0:01:29.49,0:01:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, anak manis.
Dialogue: 0,0:01:31.07,0:01:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:01:34.87,0:01:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jago juga, ya.
Dialogue: 0,0:01:36.03,0:01:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tak mau anakku memanjat begitu.
Dialogue: 0,0:02:19.49,0:02:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan beralkohol hibrida yang membuat\Nmabuk hanya dengan memakannya?
Dialogue: 0,0:02:25.29,0:02:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, Ponta!
Dialogue: 0,0:03:16.47,0:03:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Arc.
Dialogue: 0,0:03:18.82,0:03:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama kota yang ramai ini adalah Hoban.
Dialogue: 0,0:03:21.60,0:03:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami datang ke tempat ini\Natas permintaan Tuan Danka.
Dialogue: 0,0:03:25.98,0:03:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di wilayah Hoban, Kerajaan Rhoden,
Dialogue: 0,0:03:28.02,0:03:33.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada sekelompok orang yang menculik kaum elf,\Nmanusia hewan, bahkan manusia.
Dialogue: 0,0:03:33.03,0:03:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah ke sana.
Dialogue: 0,0:03:34.49,0:03:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wilayah Hoban merupakan tempat strategis\Ndalam jalur perdagangan,
Dialogue: 0,0:03:38.32,0:03:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghubungkan Limbult dan Olav,\NKerajaan Rhoden,
Dialogue: 0,0:03:40.53,0:03:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu-satunya negara\Nyang berdagang dengan kaum elf.
Dialogue: 0,0:04:07.14,0:04:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:04:08.56,0:04:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini kaum elf benar-benar berjalan\Ndengan santai di kota manusia, ya.
Dialogue: 0,0:04:13.40,0:04:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan yang luar biasa.
Dialogue: 0,0:04:17.70,0:04:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Putri Yuriarna,
Dialogue: 0,0:04:19.52,0:04:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kaum elf kini jadi lebih leluasa muncul\Ndi tempat umum, ya.
Dialogue: 0,0:04:22.80,0:04:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang begitulah seharusnya.
Dialogue: 0,0:04:25.37,0:04:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja ini menjadi sesuatu yang wajar.
Dialogue: 0,0:04:28.76,0:04:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, banyak sekali orang\Ndan kereta barang yang lewat, ya.
Dialogue: 0,0:04:32.21,0:04:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara mereka ada yang menculik\Nkaum elf, manusia hewan,
Dialogue: 0,0:04:35.71,0:04:38.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan manusia tanpa pandang bulu.
Dialogue: 0,0:04:38.17,0:04:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:39.26,0:04:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hari ini, kita istirahat dulu saja\Nsetelah perjalanan panjang.
Dialogue: 0,0:04:42.80,0:04:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, di kota yang semakmur ini,
Dialogue: 0,0:04:45.68,0:04:48.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti ada banyak makanan enak.
Dialogue: 0,0:04:48.56,0:04:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kan, Ponta?
Dialogue: 0,0:05:01.99,0:05:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali!
Dialogue: 0,0:05:08.96,0:05:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau orangnya seramai ini,
Dialogue: 0,0:05:11.42,0:05:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bakal susah mencari informasi.
Dialogue: 0,0:05:19.30,0:05:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti juga beres.
Dialogue: 0,0:05:21.26,0:05:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejahatan itu biasanya datang\Ndengan sendirinya.
Dialogue: 0,0:05:26.76,0:05:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini.
Dialogue: 0,0:05:28.02,0:05:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara bilang begitu,\Nkita jadi sering terlibat masalah.
Dialogue: 0,0:05:33.85,0:05:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlepas itu,\Nkita belum punya informasi apa pun.
Dialogue: 0,0:05:36.77,0:05:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok kita mulai cari.
Dialogue: 0,0:05:38.28,0:05:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap, dimengerti.
Dialogue: 0,0:05:44.70,0:05:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget.
Dialogue: 0,0:05:47.74,0:05:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingamu... jangan-jangan!
Dialogue: 0,0:05:50.29,0:05:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar!
Dialogue: 0,0:05:52.58,0:05:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging ini rasanya unik banget.
Dialogue: 0,0:05:55.63,0:05:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin ketagihan.
Dialogue: 0,0:05:57.55,0:05:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tidak mungkin.
Dialogue: 0,0:05:59.46,0:06:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya yang aku pesan itu...
Dialogue: 0,0:06:01.30,0:06:03.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah kalkun tubruk.
Dialogue: 0,0:06:04.59,0:06:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kalkun pemabuk?
Dialogue: 0,0:06:13.31,0:06:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, Ponta!
Dialogue: 0,0:06:15.48,0:06:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan beralkohol hibrida yang membuat\Nmabuk hanya dengan memakannya?
Dialogue: 0,0:06:20.19,0:06:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Favorit para pelanggan yang sibuk?
Dialogue: 0,0:06:32.58,0:06:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ce-Celaka!\NKalau sudah begini...
Dialogue: 0,0:06:35.75,0:06:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:36.96,0:06:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya masalah denganku?
Dialogue: 0,0:06:40.34,0:06:42.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mabuk!
Dialogue: 0,0:06:42.21,0:06:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, kamu juga makan lagi yang banyak!
Dialogue: 0,0:06:45.26,0:06:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging ini enak banget!
Dialogue: 0,0:06:48.22,0:06:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:06:49.39,0:06:52.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nona Ariane makin mabuk,\Nsituasinya bisa jadi kacau!
Dialogue: 0,0:06:53.48,0:06:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:06:56.98,0:06:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo habiskan!
Dialogue: 0,0:06:58.15,0:07:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habiskan!
Dialogue: 0,0:07:01.48,0:07:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Habiskan!\N- Kenapa malah jadi makin heboh?
Dialogue: 0,0:07:04.95,0:07:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan dimakan semuanya sendirian!
Dialogue: 0,0:07:08.58,0:07:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suapi aku juga!
Dialogue: 0,0:07:12.87,0:07:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!
Dialogue: 0,0:07:13.66,0:07:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kalkun ini akan kuhabiskan sendiri!
Dialogue: 0,0:07:16.17,0:07:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bilang?
Dialogue: 0,0:07:17.67,0:07:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kalkunku!
Dialogue: 0,0:07:19.84,0:07:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan!
Dialogue: 0,0:07:21.17,0:07:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh!\NPokoknya tidak boleh!
Dialogue: 0,0:07:23.30,0:07:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, sih?
Dialogue: 0,0:07:24.76,0:07:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berniat memakannya sendiri?
Dialogue: 0,0:07:27.09,0:07:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan!
Dialogue: 0,0:07:28.72,0:07:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh, Nona Ariane!
Dialogue: 0,0:07:30.60,0:07:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baiklah kalau begitu.
Dialogue: 0,0:07:32.89,0:07:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Wahai batu yang diselimuti api,\N- Nona Ariane, mantra itu...
Dialogue: 0,0:07:36.73,0:07:38.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serang dan binasakan musuh!
Dialogue: 0,0:08:17.14,0:08:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak dapat apa-apa.
Dialogue: 0,0:08:18.98,0:08:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku juga tidak dapat petunjuk apa pun.
Dialogue: 0,0:08:22.33,0:08:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh.
Dialogue: 0,0:08:23.77,0:08:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kepalaku terasa sakit?
Dialogue: 0,0:08:25.78,0:08:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak minum sake.
Dialogue: 0,0:08:27.36,0:08:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kamu memang tidak minum.
Dialogue: 0,0:08:29.24,0:08:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi memakannya!
Dialogue: 0,0:08:30.36,0:08:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:08:31.66,0:08:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sama sekali tidak ingat\Nkejadian semalam.
Dialogue: 0,0:08:35.87,0:08:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponta juga sama apesnya, ya.
Dialogue: 0,0:08:39.25,0:08:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, saksikanlah!
Dialogue: 0,0:08:41.33,0:08:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, dengan tangan kosong\Ndan bertelanjang kaki,
Dialogue: 0,0:08:44.25,0:08:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kutunjukkan bahwa aku bisa memanjat\Nmenara jam ini sampai ke atas.
Dialogue: 0,0:08:47.97,0:08:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gagal, tubuhku bisa remuk.
Dialogue: 0,0:08:49.80,0:08:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil, berikan tepuk tangan.
Dialogue: 0,0:08:51.80,0:08:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa juga sawerannya.
Dialogue: 0,0:08:53.68,0:08:56.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, silakan saksikan!
Dialogue: 0,0:08:56.02,0:08:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, atraksi, ya?
Dialogue: 0,0:08:57.89,0:09:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini dia sendirian?
Dialogue: 0,0:09:00.02,0:09:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu...
Dialogue: 0,0:09:01.40,0:09:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah, adiknya meniup seruling.
Dialogue: 0,0:09:04.27,0:09:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal suaranya menyejukkan.
Dialogue: 0,0:09:08.57,0:09:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!\NTinggal setengah jalan lagi!
Dialogue: 0,0:09:10.86,0:09:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah aku akan berhasil?
Dialogue: 0,0:09:14.16,0:09:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, lihai juga dia.
Dialogue: 0,0:09:17.04,0:09:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita lihat lebih dekat lagi.
Dialogue: 0,0:09:41.44,0:09:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku?
Dialogue: 0,0:09:53.53,0:09:55.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dark elf?
Dialogue: 0,0:10:04.83,0:10:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ribut.
Dialogue: 0,0:10:06.17,0:10:09.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikutlah bersama kami sekarang juga.
Dialogue: 0,0:10:09.26,0:10:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi seperti ini modusnya.
Dialogue: 0,0:10:11.50,0:10:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:14.51,0:10:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ariane!
Dialogue: 0,0:10:15.72,0:10:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Kita mundur!
Dialogue: 0,0:10:17.41,0:10:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka itu penculik!
Dialogue: 0,0:10:19.35,0:10:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:10:23.14,0:10:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkap anak laki-laki itu.
Dialogue: 0,0:10:24.85,0:10:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu yang memberi kode ke mereka.
Dialogue: 0,0:10:27.69,0:10:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengejar mereka.
Dialogue: 0,0:10:29.11,0:10:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti!
Dialogue: 0,0:10:35.45,0:10:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:44.54,0:10:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, mereka berhasil kabur.
Dialogue: 0,0:10:46.38,0:10:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Tuan Kesatria di sini?
Dialogue: 0,0:10:48.04,0:10:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kamu anak yang tahu sopan santun, ya?
Dialogue: 0,0:10:51.76,0:10:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, bodoh!
Dialogue: 0,0:10:57.18,0:10:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tidak juga.
Dialogue: 0,0:11:00.10,0:11:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar aku kalau bisa!\NDasar payah!
Dialogue: 0,0:11:20.10,0:11:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena.
Dialogue: 0,0:11:32.09,0:11:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licik banget.
Dialogue: 0,0:11:33.71,0:11:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa pakai trik seperti itu?
Dialogue: 0,0:11:36.05,0:11:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan trik.\NIni yang namanya sihir.
Dialogue: 0,0:11:39.33,0:11:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sombong amat, Tuan Kesatria.
Dialogue: 0,0:11:42.10,0:11:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu komplotannya mereka, kan?
Dialogue: 0,0:11:45.77,0:11:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa anak kecil sepertimu\Nmembantu orang-orang itu?
Dialogue: 0,0:11:51.77,0:11:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungkam, ya.
Dialogue: 0,0:11:53.25,0:11:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak yang kalian culik\Ndengan cara seperti itu?
Dialogue: 0,0:11:58.95,0:12:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya kaum elf,
Dialogue: 0,0:12:00.78,0:12:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manusia dan manusia hewan\Njuga kalian culik, kan?
Dialogue: 0,0:12:06.37,0:12:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana kalian bawa orang-orang\Nyang diculik itu?
Dialogue: 0,0:12:09.31,0:12:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu kami\Nkalau memang masih di kota ini!
Dialogue: 0,0:12:14.59,0:12:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ariane!
Dialogue: 0,0:12:15.88,0:12:20.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu apa yang akan dilakukan\Npada mereka yang diculik itu?
Dialogue: 0,0:12:21.55,0:12:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.
Dialogue: 0,0:12:22.81,0:12:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini terluka.
Dialogue: 0,0:12:25.02,0:12:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita sembuhkan dulu.
Dialogue: 0,0:12:27.14,0:12:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heal.
Dialogue: 0,0:12:33.40,0:12:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini juga yang namanya sihir?
Dialogue: 0,0:12:35.71,0:12:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:12:37.43,0:12:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa patah tulang serius\Nbisa disembuhkan pakai sihir itu?
Dialogue: 0,0:12:44.20,0:12:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada alasannya.
Dialogue: 0,0:12:45.87,0:12:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kamu ceritakan?
Dialogue: 0,0:12:51.29,0:12:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, saksikanlah!
Dialogue: 0,0:12:53.17,0:12:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku akan memanjat lebih tinggi lagi!
Dialogue: 0,0:12:55.84,0:12:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, jangan memaksakan!
Dialogue: 0,0:12:58.22,0:12:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:12:59.63,0:13:01.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah aku, Shia.
Dialogue: 0,0:13:29.90,0:13:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shia!
Dialogue: 0,0:13:32.33,0:13:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke alun-alun sendirian\Ndemi menyembuhkan kaki Shia.
Dialogue: 0,0:13:35.96,0:13:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mempertontonkan atraksi dan melakukan\Nhal yang lebih berbahaya.
Dialogue: 0,0:13:40.13,0:13:41.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tetap tidak cukup.
Dialogue: 0,0:13:42.25,0:13:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh banyak uang\Nuntuk membawa Shia ke dokter.
Dialogue: 0,0:13:45.65,0:13:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu saat itu, dia datang.
Dialogue: 0,0:13:48.93,0:13:50.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Mashla.
Dialogue: 0,0:13:50.64,0:13:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin menyelamatkan adikmu, kan?
Dialogue: 0,0:13:53.00,0:13:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membantumu.
Dialogue: 0,0:13:56.23,0:13:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah aku mulai membantu mereka.
Dialogue: 0,0:13:59.90,0:14:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:14:01.11,0:14:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu melihat anak-anak\Nseumuran Shia ditangkap...
Dialogue: 0,0:14:08.91,0:14:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda.
Dialogue: 0,0:14:10.66,0:14:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antarkan kami ke tempat adikmu.
Dialogue: 0,0:14:30.97,0:14:33.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ketahuan sama orang-orang aneh itu.
Dialogue: 0,0:14:33.31,0:14:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan kita di kota ini harus disudahi.
Dialogue: 0,0:14:36.86,0:14:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih ingin cari elf dan manusia hewan\Nuntuk dijual mahal.
Dialogue: 0,0:14:40.73,0:14:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mau bagaimana lagi.
Dialogue: 0,0:14:42.76,0:14:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pergi dari sini.
Dialogue: 0,0:14:45.28,0:14:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya,
Dialogue: 0,0:14:47.66,0:14:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke mana si bocah Shil itu?
Dialogue: 0,0:14:50.91,0:14:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adiknya itu, meski kakinya tak bisa dipakai,
Dialogue: 0,0:14:54.54,0:14:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih bisa dipakai untuk hal lain.
Dialogue: 0,0:15:05.38,0:15:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shia, aku pulang.
Dialogue: 0,0:15:07.09,0:15:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:15:08.10,0:15:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:15:10.26,0:15:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa?
Dialogue: 0,0:15:11.35,0:15:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Shia.
Dialogue: 0,0:15:13.23,0:15:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kesatria ini akan menyembuhkan kakimu.
Dialogue: 0,0:15:17.15,0:15:18.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini parah sekali.
Dialogue: 0,0:15:18.86,0:15:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya pasti sangat sakit.
Dialogue: 0,0:15:21.32,0:15:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:15:22.36,0:15:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heal.
Dialogue: 0,0:15:32.37,0:15:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, hebat!
Dialogue: 0,0:15:34.00,0:15:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak sakit!
Dialogue: 0,0:15:35.62,0:15:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:15:44.46,0:15:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, aku bisa sendiri.
Dialogue: 0,0:15:48.14,0:15:51.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu lama tidak digerakkan,\Nototmu nanti jadi kaku.
Dialogue: 0,0:15:53.35,0:15:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasih sayang kakak dan adik\Nmemang indah, ya.
Dialogue: 0,0:15:56.55,0:15:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:02.94,0:16:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ingat dulu.
Dialogue: 0,0:16:04.57,0:16:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nona Ariane?
Dialogue: 0,0:16:07.40,0:16:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:16:08.78,0:16:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya teringat Kak Evin.
Dialogue: 0,0:16:11.76,0:16:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, kamu punya kakak perempuan.
Dialogue: 0,0:16:16.06,0:16:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakimu masih kaku, jadi jangan dipaksakan.
Dialogue: 0,0:16:19.33,0:16:20.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak sendiri?
Dialogue: 0,0:16:21.29,0:16:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada yang harus kulakukan.
Dialogue: 0,0:16:23.55,0:16:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melakukan hal berbahaya.
Dialogue: 0,0:16:25.46,0:16:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tahu.
Dialogue: 0,0:16:27.34,0:16:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah.
Dialogue: 0,0:16:29.89,0:16:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kesatria, akan kuantar kalian\Nke markas mereka.
Dialogue: 0,0:16:32.64,0:16:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:35.14,0:16:37.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah itu mengkhianati kita.
Dialogue: 0,0:16:37.98,0:16:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja.\NLagi pula, markas kita sudah kosong.
Dialogue: 0,0:16:41.23,0:16:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu...
Dialogue: 0,0:16:46.49,0:16:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:17:02.33,0:17:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:17:07.80,0:17:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepi sekali.
Dialogue: 0,0:17:09.08,0:17:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:10.48,0:17:12.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan sana belok kanan.
Dialogue: 0,0:17:25.85,0:17:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya mereka sudah kabur.
Dialogue: 0,0:17:27.65,0:17:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:17:28.74,0:17:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenapa?
Dialogue: 0,0:17:30.32,0:17:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu masuk tadi juga dipasangi rantai.
Dialogue: 0,0:17:33.21,0:17:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada pintu masuk lain?
Dialogue: 0,0:17:34.99,0:17:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sini.
Dialogue: 0,0:17:44.33,0:17:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta kudanya tidak ada.
Dialogue: 0,0:17:52.30,0:17:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka tidak bilang pergi ke mana?
Dialogue: 0,0:17:55.01,0:17:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah ke Olav.
Dialogue: 0,0:17:56.85,0:17:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang barat.
Dialogue: 0,0:17:58.10,0:17:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:16.20,0:18:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak muda, kamu tahu ke mana\Nkereta kuda mereka pergi?
Dialogue: 0,0:18:18.99,0:18:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih.\NAsalkan bisa lihat wajahnya.
Dialogue: 0,0:18:24.88,0:18:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kereta kuda ke arah Olav itu\Npasti akan lewat bawah sini.
Dialogue: 0,0:18:30.80,0:18:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah?
Dialogue: 0,0:18:31.84,0:18:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:18:36.30,0:18:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan juga.
Dialogue: 0,0:18:38.89,0:18:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:18:48.57,0:18:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini... suara serulingnya Shia.
Dialogue: 0,0:18:51.49,0:18:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa?
Dialogue: 0,0:18:52.57,0:18:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya dari kereta kuda itu.
Dialogue: 0,0:18:55.33,0:18:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!\NItu dia!
Dialogue: 0,0:18:57.07,0:19:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya adik anak ini\Ntelah diculik oleh mereka.
Dialogue: 0,0:19:05.17,0:19:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bertindak seenaknya!
Dialogue: 0,0:19:13.67,0:19:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon, Tuan Kesatria,\Nselamatkanlah Shia!
Dialogue: 0,0:19:16.55,0:19:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:18.93,0:19:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimension Move.
Dialogue: 0,0:19:37.28,0:19:39.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dark elf yang waktu itu!
Dialogue: 0,0:19:39.88,0:19:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan.
Dialogue: 0,0:19:41.12,0:19:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita tangkap dan jual dia.
Dialogue: 0,0:19:43.53,0:19:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu kami lengah.
Dialogue: 0,0:19:45.25,0:19:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang akan kami balas dua kali lipat.
Dialogue: 0,0:19:47.50,0:19:50.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kalian sanggup?
Dialogue: 0,0:20:09.94,0:20:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanfaatkan kasih sayang kakak dan adik\Nuntuk melakukan perbuatan jahat
Dialogue: 0,0:20:15.31,0:20:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah tindakan yang tak bisa dibiarkan.
Dialogue: 0,0:20:18.16,0:20:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:20:19.20,0:20:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?\NSiapa sebenarnya dia?
Dialogue: 0,0:20:22.28,0:20:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang giliran kalian yang dikurung\Ndalam jeruji neraka!
Dialogue: 0,0:20:27.29,0:20:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern Slash!
Dialogue: 0,0:20:40.49,0:20:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shia, kamu di dalam?
Dialogue: 0,0:20:41.97,0:20:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak!
Dialogue: 0,0:20:43.22,0:20:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shia.
Dialogue: 0,0:20:45.02,0:20:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah aman.
Dialogue: 0,0:20:50.10,0:20:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penonton sekalian, sebentar lagi\Nakan sampai di menara jam.
Dialogue: 0,0:20:53.27,0:20:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil, berikan tepuk tangan.
Dialogue: 0,0:20:57.28,0:20:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:20:59.01,0:21:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa bersama lagi di alun-alun.
Dialogue: 0,0:21:01.41,0:21:02.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:02.53,0:21:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang rasanya melihat mereka bersama.
Dialogue: 0,0:21:05.29,0:21:09.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Berhasil dengan gemilang!
Dialogue: 0,0:21:09.54,0:21:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak keren!
Dialogue: 0,0:21:11.92,0:21:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shia!
Dialogue: 0,0:21:16.05,0:21:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya, komplotan itu\Nsudah sering menculik
Dialogue: 0,0:21:19.34,0:21:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjualnya ke luar negeri.
Dialogue: 0,0:21:22.03,0:21:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti kasus anak bengal itu, ya.
Dialogue: 0,0:21:24.72,0:21:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, burung pembisik.
Dialogue: 0,0:21:31.02,0:21:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Danka lagi, ya?
Dialogue: 0,0:21:32.98,0:21:34.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Arin!
Dialogue: 0,0:21:34.56,0:21:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah temui Kakak sekarang juga!
Dialogue: 0,0:21:38.86,0:21:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Evin?
Dialogue: 0,0:21:58.25,0:22:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersyukurlah.
Dialogue: 0,0:22:00.57,0:22:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena setelah mati pun,\Nkalian masih bisa mengabdi pada Tuhan.
