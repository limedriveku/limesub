Dialogue: 0,0:01:40.04,0:01:44.00,sign,,0000,0000,0000,,KESATRIA TENGKORAK BERKELANA DI DUNIA LAIN\NMUSIM KEDUA
Dialogue: 0,0:08:39.25,0:08:41.25,sign,,0000,0000,0000,,TIGA HARI KEMUDIAN
Dialogue: 0,0:12:39.03,0:12:44.03,sign,,0000,0000,0000,,EPISODE 2: TARING RACUN PEMBUNUH\NYANG MENGINTAI PENGANTIN ELF
Dialogue: 0,0:15:31.32,0:15:31.79,sign,,0000,0000,0000,,LARIAT ZIRAH!
Dialogue: 0,0:16:42.36,0:16:44.11,sign,,0000,0000,0000,,PEDANG PENGHAKIMAN
Dialogue: 0,0:23:40.02,0:23:45.03,sign,,0000,0000,0000,,SELANJUTNYA: TARIAN KEHANCURAN PARA PENJAHAT\NDAN IKATAN KAKAK-BERADIK
Dialogue: 0,0:23:45.03,0:23:51.43,sign,,0000,0000,0000,,#PONTASAATINIJUGASEDANGBERKELANA\NDI SINI JUGA ADA BURUNG YANG MENCURIGAKAN!
Dialogue: 0,0:00:15.20,0:00:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Arc.
Dialogue: 0,0:00:17.44,0:00:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya tiba di wilayah Landbalt.
Dialogue: 0,0:00:20.00,0:00:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditanya kenapa kami di sini...
Dialogue: 0,0:00:23.09,0:00:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami utusan elf dari Lalatoya,\NHutan Besar Kanada.
Dialogue: 0,0:00:28.41,0:00:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami datang untuk mengucapkan\Nselamat atas pernikahan penguasa.
Dialogue: 0,0:00:33.93,0:00:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel yang cukup megah, ya.
Dialogue: 0,0:00:36.47,0:00:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi pembangunannya membebani rakyat.
Dialogue: 0,0:00:40.01,0:00:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:00:41.23,0:00:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau penguasanya menikahi elf,
Dialogue: 0,0:00:44.32,0:00:47.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku rasa dia memiliki pemikiran yang terbuka.
Dialogue: 0,0:00:47.83,0:00:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga saja begitu.
Dialogue: 0,0:00:49.49,0:00:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya mungkin akan terjalin\Nhubungan baru antara dua ras ini.
Dialogue: 0,0:00:55.03,0:00:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman telah berubah, ya.
Dialogue: 0,0:00:58.50,0:01:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tak tahu zaman sebelumnya.
Dialogue: 0,0:01:00.25,0:01:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimana kalau elf itu\Ndipaksa untuk menikah?
Dialogue: 0,0:01:04.36,0:01:06.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus memastikannya.
Dialogue: 0,0:01:06.55,0:01:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang Nona Ariane banget.
Dialogue: 0,0:01:08.73,0:01:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, bagaimana penguasanya?
Dialogue: 0,0:01:11.26,0:01:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang disembunyikan,
Dialogue: 0,0:01:13.30,0:01:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka pasti menolak pertemuan ini.
Dialogue: 0,0:01:21.56,0:01:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya kita disambut meriah sekali.
Dialogue: 0,0:02:04.56,0:02:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, coba lihat.
Dialogue: 0,0:02:06.40,0:02:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata yang bulat, kulit merah muda pucat,
Dialogue: 0,0:02:08.65,0:02:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dirimu bagaikan anak babi...
Dialogue: 0,0:02:10.78,0:02:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:02:57.95,0:02:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, utusan elf.
Dialogue: 0,0:02:59.99,0:03:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Petros, penguasa wilayah Landbalt.
Dialogue: 0,0:03:03.25,0:03:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dia istriku, Toreasa.
Dialogue: 0,0:03:05.00,0:03:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:03:07.50,0:03:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas pernikahan kalian.
Dialogue: 0,0:03:10.50,0:03:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:11.83,0:03:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan panjang pasti melelahkan.
Dialogue: 0,0:03:13.79,0:03:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyiapkan hidangan.
Dialogue: 0,0:03:15.88,0:03:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak seberapa,\Nsilakan dinikmati tanpa sungkan.
Dialogue: 0,0:03:19.89,0:03:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat paham bagaimana\Nporsi makan kaum elf.
Dialogue: 0,0:03:23.10,0:03:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, Sayang ini.
Dialogue: 0,0:03:24.35,0:03:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesannya aku jadi seperti\Norang yang rakus, tahu.
Dialogue: 0,0:03:27.40,0:03:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat melihatmu makan dengan lahap,
Dialogue: 0,0:03:29.98,0:03:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hatiku dipenuhi\Ndengan kebahagiaan tiada tara.
Dialogue: 0,0:03:33.73,0:03:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang lebih bahagia
Dialogue: 0,0:03:35.93,0:03:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari mengenyangkan orang yang aku cintai.
Dialogue: 0,0:03:39.03,0:03:40.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang.
Dialogue: 0,0:03:40.95,0:03:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toreasa.
Dialogue: 0,0:03:46.71,0:03:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak terlihat mencurigakan, ya.
Dialogue: 0,0:03:49.17,0:03:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:03:50.59,0:03:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, mungkin agak kurang sopan bertanya.
Dialogue: 0,0:03:56.01,0:04:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dengar penguasa di sini\Nsudah menjabat selama 20 tahun.
Dialogue: 0,0:04:01.21,0:04:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Tuan Petros usianya terlalu muda.
Dialogue: 0,0:04:04.04,0:04:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:04:05.39,0:04:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ariane sedang mencurigaiku, ya?
Dialogue: 0,0:04:08.67,0:04:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan bermaksud begitu.
Dialogue: 0,0:04:10.85,0:04:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku benar-benar penguasa kedua\NWilayah Landbalt.
Dialogue: 0,0:04:15.19,0:04:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua?
Dialogue: 0,0:04:16.94,0:04:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, satu bulan lalu,
Dialogue: 0,0:04:18.70,0:04:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayahku yang merupakan penguasa sebelumnya,
Dialogue: 0,0:04:20.99,0:04:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diketahui diam-diam telah menindas kaum elf.
Dialogue: 0,0:04:24.95,0:04:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendesaknya agar mengubah perilakunya,
Dialogue: 0,0:04:29.24,0:04:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sayangnya beliau tidak mendengarkan.
Dialogue: 0,0:04:32.43,0:04:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku minta beliau melepas jabatan,\Ndan aku mengambil alih posisinya.
Dialogue: 0,0:04:36.96,0:04:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, di mana beliau sekarang?
Dialogue: 0,0:04:40.34,0:04:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski telah berbuat jahat,\Nbeliau tetaplah ayah kandungku.
Dialogue: 0,0:04:45.26,0:04:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, beliau tinggal\Ndi kamar kecil lantai paling atas kastel.
Dialogue: 0,0:04:50.35,0:04:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang aku selamatkan waktu itu\Nadalah Toreasa.
Dialogue: 0,0:04:53.53,0:04:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jatuh cinta padanya\Npada pandangan pertama.
Dialogue: 0,0:04:57.61,0:04:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keputusan yang sangat berani!
Dialogue: 0,0:04:59.99,0:05:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi masa hidup manusia\Ndan elf itu berbeda jauh.
Dialogue: 0,0:05:02.87,0:05:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu hal bagus?
Dialogue: 0,0:05:05.87,0:05:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski nanti aku menua,\Ndia akan tetap cantik selamanya.
Dialogue: 0,0:05:10.00,0:05:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah kebahagiaan tiada tara.
Dialogue: 0,0:05:12.38,0:05:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lega melihat kalian berdua bahagia.
Dialogue: 0,0:05:16.09,0:05:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kami pamit dulu.
Dialogue: 0,0:05:18.05,0:05:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, hidangannya mau kami bungkus.
Dialogue: 0,0:05:20.01,0:05:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:05:22.13,0:05:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, ada hal yang ingin\Naku bicarakan pada kalian.
Dialogue: 0,0:05:28.60,0:05:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lewat sini.
Dialogue: 0,0:05:32.81,0:05:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin dia bicarakan?
Dialogue: 0,0:05:34.80,0:05:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pamer kemesraan,\Nsebaiknya kita pulang saja.
Dialogue: 0,0:05:37.82,0:05:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat kalian petarung yang tangguh,\Naku ingin minta bantuan pada kalian.
Dialogue: 0,0:05:43.00,0:05:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin...
Dialogue: 0,0:05:44.07,0:05:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kalian melindungi Toreasa.
Dialogue: 0,0:05:47.24,0:05:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:05:48.62,0:05:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelaskan pada kami.
Dialogue: 0,0:05:50.71,0:05:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:05:52.01,0:05:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, beberapa hari ini,
Dialogue: 0,0:05:53.79,0:05:58.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah terjadi serangkaian\Npercobaan pembunuhan pada Toreasa.
Dialogue: 0,0:05:59.01,0:06:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembunuhan?
Dialogue: 0,0:06:00.05,0:06:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak bisa dibiarkan.
Dialogue: 0,0:06:02.37,0:06:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu minggu lalu, di tempat tidur Toreasa.
Dialogue: 0,0:06:07.76,0:06:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu dua hari setelahnya...
Dialogue: 0,0:06:10.98,0:06:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanannya diracun.
Dialogue: 0,0:06:14.15,0:06:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya tidak terjadi apa-apa\Nkarena ada petugas pencicip.
Dialogue: 0,0:06:18.99,0:06:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu petugas pencicipnya?
Dialogue: 0,0:06:20.57,0:06:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurnya masih selamat,
Dialogue: 0,0:06:22.86,0:06:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedang memulihkan diri di rumahnya.
Dialogue: 0,0:06:26.16,0:06:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, permintaan kalian itu...
Dialogue: 0,0:06:29.66,0:06:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin kalian menangkap pelakunya.
Dialogue: 0,0:06:32.79,0:06:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Nona Ariane?
Dialogue: 0,0:06:35.29,0:06:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita terima.
Dialogue: 0,0:06:36.77,0:06:39.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sesama kaum elf,\Naku tak bisa berdiam diri.
Dialogue: 0,0:06:42.21,0:06:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:06:43.92,0:06:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mengingat perangkapnya\Nsampai ke tempat tidur dan makanan,
Dialogue: 0,0:06:48.30,0:06:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}besar kemungkinan pelakunya orang dalam.
Dialogue: 0,0:06:51.60,0:06:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Petros, apa ada yang kamu curigai?
Dialogue: 0,0:06:53.89,0:06:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ada banyak.
Dialogue: 0,0:06:57.15,0:06:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang melayani di kastel ini
Dialogue: 0,0:06:59.40,0:07:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah orang yang bekerja sejak masa ayah.
Dialogue: 0,0:07:01.79,0:07:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang dendam pada kami\Nkarena telah menjatuhkan ayah.
Dialogue: 0,0:07:06.28,0:07:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebaiknya mereka\Ndiselidiki dan diusir?
Dialogue: 0,0:07:10.45,0:07:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak bersalah.
Dialogue: 0,0:07:12.79,0:07:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku memecat mereka,
Dialogue: 0,0:07:14.87,0:07:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluarga mereka akan kehilangan penghidupan.
Dialogue: 0,0:07:17.83,0:07:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus berbelas kasih seperti itu,\Nberapa pun nyawamu tak akan pernah cukup.
Dialogue: 0,0:07:21.96,0:07:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah siap dengan risikonya.
Dialogue: 0,0:07:24.13,0:07:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara orang-orang,
Dialogue: 0,0:07:25.59,0:07:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada banyak yang tidak suka\Ndengan pernikahan kami.
Dialogue: 0,0:07:29.93,0:07:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, itu tidak bisa dihindari.
Dialogue: 0,0:07:32.77,0:07:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia tidak bisa berubah begitu saja.
Dialogue: 0,0:07:34.96,0:07:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk berubah, butuh waktu\Nyang panjang dan tenang.
Dialogue: 0,0:07:38.52,0:07:41.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, kami mengerti situasinya.
Dialogue: 0,0:07:41.04,0:07:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita susun rencana.
Dialogue: 0,0:07:58.17,0:08:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara kota pelabuhan,\Ntentu saja makanan lautnya!
Dialogue: 0,0:08:00.71,0:08:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku lihat lobster semantap ini.
Dialogue: 0,0:08:03.55,0:08:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hm! Dagingnya juga kenyal-kenyal!\N- Kamu ini terlalu santai.
Dialogue: 0,0:08:07.43,0:08:10.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya khawatirkan sedikit soal mereka.
Dialogue: 0,0:08:10.55,0:08:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf, maaf.
Dialogue: 0,0:08:12.47,0:08:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski penampilannya begitu,\Nternyata mereka mantap...
Dialogue: 0,0:08:16.64,0:08:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maksudku bisa diandalkan.
Dialogue: 0,0:08:18.64,0:08:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:19.77,0:08:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan tekad mereka yang ingin\Nmengubah pandangan dunia dengan pernikahan.
Dialogue: 0,0:08:24.32,0:08:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin membantu mereka.
Dialogue: 0,0:08:26.65,0:08:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:08:28.20,0:08:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa rencana kita?
Dialogue: 0,0:08:30.66,0:08:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, kumpulkan informasi dulu.
Dialogue: 0,0:08:32.80,0:08:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan mengawasi mereka,
Dialogue: 0,0:08:35.12,0:08:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu selidiki mereka yang mencurigakan.
Dialogue: 0,0:08:37.25,0:08:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap.
Dialogue: 0,0:08:45.88,0:08:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santai sekali kamu ini.
Dialogue: 0,0:08:48.36,0:08:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lakukan penyelidikan?
Dialogue: 0,0:08:49.84,0:08:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, tak ada yang terlewat.
Dialogue: 0,0:08:51.80,0:08:52.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu?
Dialogue: 0,0:08:52.89,0:08:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mengenai penjaga kamarnya...
Dialogue: 0,0:09:00.27,0:09:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya dari awal di sini ada zirah?
Dialogue: 0,0:09:03.19,0:09:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudahlah.
Dialogue: 0,0:09:04.94,0:09:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerak-geriknya seperti\Nmenyelidiki sesuatu di kastel.
Dialogue: 0,0:09:07.86,0:09:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, penjaga itu pelakunya?
Dialogue: 0,0:09:10.23,0:09:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu...
Dialogue: 0,0:09:16.33,0:09:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa zirahnya bergerak?
Dialogue: 0,0:09:17.83,0:09:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlihat mencurigakan!\NApa yang kamu lakukan?
Dialogue: 0,0:09:20.77,0:09:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak melakukan apa pun!
Dialogue: 0,0:09:22.58,0:09:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Catatan inilah buktinya!
Dialogue: 0,0:09:24.71,0:09:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi itu...
Dialogue: 0,0:09:26.38,0:09:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, coba lihat.
Dialogue: 0,0:09:28.13,0:09:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata yang bulat, kulit merah muda pucat,
Dialogue: 0,0:09:30.47,0:09:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dirimu bagaikan anak babi...
Dialogue: 0,0:09:33.05,0:09:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:09:33.76,0:09:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini! Membaca surat cinta\Ntanpa izin itu keterlaluan!
Dialogue: 0,0:09:38.64,0:09:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Surat cinta?\NIni?
Dialogue: 0,0:09:40.43,0:09:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat Tuan Petros dan Nyonya Toreasa menikah\Nmembuatku ingin menyatakan cinta,
Dialogue: 0,0:09:44.73,0:09:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya aku buat surat cinta!
Dialogue: 0,0:09:47.85,0:09:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itulah.
Dialogue: 0,0:09:50.36,0:09:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kalau bagian dapur?
Dialogue: 0,0:09:53.99,0:09:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:55.37,0:09:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada penjaga yang terlihat\Nseperti memikirkan sesuatu.
Dialogue: 0,0:09:58.62,0:10:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu pekerjaannya selesai,\Ndia langsung menyelinap pergi,
Dialogue: 0,0:10:01.46,0:10:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku membuntutinya.
Dialogue: 0,0:10:04.00,0:10:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata, pria itu masuk ke toko obat.
Dialogue: 0,0:10:08.75,0:10:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko obat?
Dialogue: 0,0:10:10.03,0:10:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan soal racun itu.
Dialogue: 0,0:10:12.05,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat mencurigakan.
Dialogue: 0,0:10:13.76,0:10:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku juga berpikir begitu.
Dialogue: 0,0:10:20.93,0:10:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pak Pemilik.
Dialogue: 0,0:10:24.40,0:10:25.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tanya sesuatu.
Dialogue: 0,0:10:25.90,0:10:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tadi datang untuk apa?
Dialogue: 0,0:10:28.94,0:10:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, orang yang tadi ingin tahu soal racun.
Dialogue: 0,0:10:32.65,0:10:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Racun?
Dialogue: 0,0:10:34.03,0:10:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tanya di mana bisa\Nmenemukan tumbuhan beracun,
Dialogue: 0,0:10:36.99,0:10:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku jawab di hutan pinggiran utara kota.
Dialogue: 0,0:10:40.54,0:10:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!
Dialogue: 0,0:10:49.09,0:10:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh!
Dialogue: 0,0:10:50.25,0:10:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan kamu ini?
Dialogue: 0,0:10:51.67,0:10:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ditangkap atas dugaan percobaan\Npembunuhan terhadap Nyonya Toreasa.
Dialogue: 0,0:10:56.09,0:10:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak melakukan hal seperti itu!
Dialogue: 0,0:10:57.76,0:11:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memetik tanaman beracun\Nadalah bukti tak terbantahkan!
Dialogue: 0,0:11:00.76,0:11:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampaikan pembelaanmu nanti di kastel.
Dialogue: 0,0:11:03.27,0:11:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Racun ini dipakai untuk membuat penawar!
Dialogue: 0,0:11:06.02,0:11:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nyonya Toreasa diracun lagi,
Dialogue: 0,0:11:08.44,0:11:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa menanganinya dengan cepat\Nkalau ada penawarnya, kan?
Dialogue: 0,0:11:12.61,0:11:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:14.70,0:11:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, seperti itulah.
Dialogue: 0,0:11:17.77,0:11:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, waktu pulang dari sana,\NPonta menemukan burung aneh.
Dialogue: 0,0:11:23.62,0:11:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung aneh?
Dialogue: 0,0:11:29.84,0:11:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Ponta?
Dialogue: 0,0:11:31.05,0:11:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perutmu sakit?
Dialogue: 0,0:11:38.34,0:11:40.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik! Baik!
Dialogue: 0,0:11:40.76,0:11:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat ke sini, bodoh!
Dialogue: 0,0:11:46.44,0:11:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma burung beo\Nyang sedang bersenandung.
Dialogue: 0,0:11:49.77,0:11:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung beo yang bersenandung?
Dialogue: 0,0:11:52.53,0:11:54.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, di halaman dalam...
Dialogue: 0,0:11:57.49,0:11:59.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu apa?
Dialogue: 0,0:11:59.41,0:12:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangkar burung.
Dialogue: 0,0:12:00.99,0:12:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku dulu memelihara burung beo,
Dialogue: 0,0:12:03.28,0:12:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi entah kapan dia kabur.
Dialogue: 0,0:12:06.75,0:12:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi itu burung yang dimaksud.
Dialogue: 0,0:12:09.85,0:12:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang jelas, semua yang mencurigakan\Nsudah diselidiki
Dialogue: 0,0:12:13.30,0:12:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hasilnya nihil.
Dialogue: 0,0:12:15.05,0:12:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:12:16.66,0:12:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada satu yang paling dicurigai.
Dialogue: 0,0:12:20.14,0:12:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahnya Tuan Petros, ya?
Dialogue: 0,0:12:23.09,0:12:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, orangnya sedang dikurung.
Dialogue: 0,0:12:25.72,0:12:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya dia bisa merencanakan sesuatu?
Dialogue: 0,0:12:28.02,0:12:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diselidiki pun, dia pasti tak akan\Nberbuat aneh-aneh kalau tahu diawasi.
Dialogue: 0,0:12:31.90,0:12:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya ide yang bagus.
Dialogue: 0,0:12:36.03,0:12:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku tidak enak.
Dialogue: 0,0:12:47.12,0:12:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petros sialan,\Nberani-beraninya mengurungku di sini.
Dialogue: 0,0:12:52.67,0:12:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, yang salah bukanlah anakku.
Dialogue: 0,0:12:55.25,0:12:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini gara-gara elf itu!
Dialogue: 0,0:12:57.59,0:13:02.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia berhasil memikat Petros dengan licik,\Nbahkan merebut posisiku!
Dialogue: 0,0:13:04.18,0:13:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:13:07.52,0:13:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:13:09.31,0:13:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tak ada tempat lagi,\Nsaya diminta menaruhnya di sini.
Dialogue: 0,0:13:13.11,0:13:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini bukan gudang!\NBawa pergi lagi!
Dialogue: 0,0:13:15.98,0:13:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini sudah perintah.
Dialogue: 0,0:13:17.91,0:13:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya permisi.
Dialogue: 0,0:13:19.11,0:13:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu dulu!
Dialogue: 0,0:13:22.24,0:13:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:13:23.45,0:13:26.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah memasukkan barang yang tidak berguna.
Dialogue: 0,0:13:28.75,0:13:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini?
Dialogue: 0,0:13:32.25,0:13:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa di dalam ada orangnya?
Dialogue: 0,0:13:39.05,0:13:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak ada.
Dialogue: 0,0:13:41.43,0:13:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, betul ada.
Dialogue: 0,0:13:45.89,0:13:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhancurkan lalu kubuang lewat jendela.
Dialogue: 0,0:13:48.68,0:13:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau kubakar saja jadi abu?
Dialogue: 0,0:13:53.15,0:13:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudahlah.
Dialogue: 0,0:13:54.10,0:13:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya perlu bersabar sebentar lagi.
Dialogue: 0,0:14:07.87,0:14:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung beo itu...
Dialogue: 0,0:14:10.33,0:14:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, besok adalah hari kematian istriku.
Dialogue: 0,0:14:13.21,0:14:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petros dan Toreasa pasti\Nakan pergi berziarah.
Dialogue: 0,0:14:16.67,0:14:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Incar mereka saat itu terjadi.
Dialogue: 0,0:14:18.34,0:14:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik! Baik!
Dialogue: 0,0:14:25.01,0:14:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dalangnya memang dia.
Dialogue: 0,0:14:27.52,0:14:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, burung beo itu...
Dialogue: 0,0:14:39.90,0:14:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana perginya tengkorak itu?
Dialogue: 0,0:14:49.03,0:14:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakanlah pembalasanku, elf sialan!
Dialogue: 0,0:14:55.29,0:14:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,\Nberduaan di tempat sempit seperti ini
Dialogue: 0,0:14:59.04,0:15:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku merasa sedikit bersalah.
Dialogue: 0,0:15:02.05,0:15:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tidak.
Dialogue: 0,0:15:03.22,0:15:05.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang bukan waktunya\Nmemikirkan yang tidak perlu.
Dialogue: 0,0:15:05.97,0:15:10.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masa depan manusia dan elf\Nbergantung dari apa yang akan kami lakukan.
Dialogue: 0,0:15:16.52,0:15:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:15:17.65,0:15:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serang!
Dialogue: 0,0:15:18.73,0:15:19.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:15:28.62,0:15:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lariat Zirah!
Dialogue: 0,0:15:33.75,0:15:36.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana kalian sudah terbaca semua!
Dialogue: 0,0:15:36.58,0:15:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si-Siapa dia?
Dialogue: 0,0:15:38.52,0:15:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan saja!\NIncar pengantin elf itu!
Dialogue: 0,0:15:41.96,0:15:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, sebaiknya jangan pergi ke sana.
Dialogue: 0,0:15:46.47,0:15:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai Api.
Dialogue: 0,0:15:47.93,0:15:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membaralah dan menari dengan pedangku!
Dialogue: 0,0:15:59.77,0:16:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan Toreasa!
Dialogue: 0,0:16:01.02,0:16:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun yang ingin mati,
Dialogue: 0,0:16:03.44,0:16:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}majulah ke sini!
Dialogue: 0,0:16:13.37,0:16:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Nyonya Toreasa.
Dialogue: 0,0:16:17.17,0:16:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Loveris, bagaimana keadaanmu?
Dialogue: 0,0:16:19.67,0:16:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sudah lebih baik.
Dialogue: 0,0:16:21.38,0:16:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan karena kamu,
Dialogue: 0,0:16:22.92,0:16:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang aku mungkin sudah kehilangan nyawa.
Dialogue: 0,0:16:25.96,0:16:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah ingin sekali datang menjengukmu.
Dialogue: 0,0:16:29.13,0:16:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu kehormatan Nyonya Toreasa\Nberkenan datang
Dialogue: 0,0:16:32.51,0:16:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga ke rumah saya.
Dialogue: 0,0:16:34.72,0:16:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah ini tak punya apa-apa,\Ntapi silakan bersantai.
Dialogue: 0,0:16:38.89,0:16:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik Kesatria Suci: Judgement!
Dialogue: 0,0:16:50.03,0:16:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah beres semua.
Dialogue: 0,0:16:52.43,0:16:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:53.44,0:16:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua bertarung dengan luar biasa!
Dialogue: 0,0:16:56.44,0:16:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita bisa menjemput Toreasa.
Dialogue: 0,0:16:59.54,0:17:01.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Toreasa sekarang di mana?
Dialogue: 0,0:17:02.04,0:17:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang menjenguk petugas pencicip\Ndi pinggiran utara kota.
Dialogue: 0,0:17:07.08,0:17:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petugas pencicip dan tanaman beracun\Ndi pinggiran utara kota?
Dialogue: 0,0:17:10.48,0:17:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Burung beo penguasa sebelumnya\Nyang terlihat di sana...
Dialogue: 0,0:17:13.84,0:17:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:17:15.06,0:17:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arc, terbanglah ke hutan di utara!
Dialogue: 0,0:17:17.43,0:17:19.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Untuk apa?
Dialogue: 0,0:17:19.31,0:17:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:17:20.19,0:17:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:17:41.87,0:17:43.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:17:43.21,0:17:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah itu...
Dialogue: 0,0:17:48.71,0:17:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma yang harum.
Dialogue: 0,0:17:55.97,0:17:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:18:00.43,0:18:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Arc, Nona Ariane?
Dialogue: 0,0:18:02.14,0:18:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:18:03.40,0:18:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, soal itu...
Dialogue: 0,0:18:06.73,0:18:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi sebentar.
Dialogue: 0,0:18:16.74,0:18:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:18.08,0:18:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:18:19.20,0:18:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?
Dialogue: 0,0:18:22.66,0:18:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Toreasa,\Npelaku yang mengincar nyawamu
Dialogue: 0,0:18:26.44,0:18:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah dia.
Dialogue: 0,0:18:29.29,0:18:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia telah menerima perintah\Ndari penguasa sebelumnya,
Dialogue: 0,0:18:33.22,0:18:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu apa hubungannya?
Dialogue: 0,0:18:36.39,0:18:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di daerah sini,\Ntanaman beracun tumbuh subur, ya?
Dialogue: 0,0:18:42.10,0:18:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dengar insiden itu,\Naku sudah merasa ada yang janggal.
Dialogue: 0,0:18:45.94,0:18:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih hidup setelah minum racun\Nbukanlah hal yang biasa.
Dialogue: 0,0:18:48.82,0:18:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa maksudnya?
Dialogue: 0,0:18:50.86,0:18:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percobaan pembunuhan dengan racun,
Dialogue: 0,0:18:53.03,0:18:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanyalah sandiwara yang dia buat.
Dialogue: 0,0:18:55.36,0:18:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sandiwara?
Dialogue: 0,0:18:57.20,0:19:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah gagal membunuh Nyonya Toreasa\Ndengan ular berbisa,
Dialogue: 0,0:19:01.54,0:19:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar tidak dicurigai,
Dialogue: 0,0:19:03.66,0:19:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu membuat kehebohan\Ndengan pura-pura diracuni.
Dialogue: 0,0:19:07.25,0:19:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tujuanmu yang sebenarnya
Dialogue: 0,0:19:09.84,0:19:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah rencana yang jauh lebih mengerikan.
Dialogue: 0,0:19:12.05,0:19:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rencana yang mengerikan?
Dialogue: 0,0:19:13.76,0:19:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu bahwa Nyonya Toreasa\Nyang berhati baik pasti akan datang menjenguk.
Dialogue: 0,0:19:19.00,0:19:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pun berpikir itulah kesempatan\Nyang paling bagus
Dialogue: 0,0:19:22.39,0:19:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk membunuhnya.
Dialogue: 0,0:19:23.64,0:19:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin.
Dialogue: 0,0:19:27.69,0:19:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur!
Dialogue: 0,0:19:35.57,0:19:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sampai di situ!
Dialogue: 0,0:19:36.91,0:19:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah!
Dialogue: 0,0:19:41.79,0:19:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu melakukan ini?
Dialogue: 0,0:19:43.58,0:19:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sudi dengan pernikahan\Nantara manusia dan elf.
Dialogue: 0,0:19:47.96,0:19:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf tidak boleh menduduki\Nposisi di atas manusia!
Dialogue: 0,0:19:50.84,0:19:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zaman sudah mulai berubah.
Dialogue: 0,0:19:53.23,0:19:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan tindakan bodohmu.
Dialogue: 0,0:19:54.88,0:19:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tak berpikir\Nuntuk lari dari dosaku.
Dialogue: 0,0:19:58.66,0:20:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada hidup menanggung malu...
Dialogue: 0,0:20:10.69,0:20:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu menolongku?
Dialogue: 0,0:20:12.15,0:20:16.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku ingin orang sepertimu\Nterus hidup di zaman yang akan datang.
Dialogue: 0,0:20:16.93,0:20:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, aku ingin kamu berubah.
Dialogue: 0,0:20:23.41,0:20:25.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, para kesatria pemberani.
Dialogue: 0,0:20:25.91,0:20:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat kalian, nyawa Toreasa\Nberhasil diselamatkan.
Dialogue: 0,0:20:29.92,0:20:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikhianati orang\Nyang dipercaya itu menyakitkan.
Dialogue: 0,0:20:33.80,0:20:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja?
Dialogue: 0,0:20:35.42,0:20:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kejadian ini,
Dialogue: 0,0:20:37.09,0:20:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami berpikir harus menjadi lebih kuat lagi.
Dialogue: 0,0:20:41.43,0:20:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:42.55,0:20:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:20:44.31,0:20:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:20:46.14,0:20:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingin terus percaya pada potensi\Nyang dibangun manusia dan kaum elf.
Dialogue: 0,0:20:50.56,0:20:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toreasa.
Dialogue: 0,0:20:53.27,0:20:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku akan melindungimu.
Dialogue: 0,0:20:56.32,0:20:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang.
Dialogue: 0,0:20:58.11,0:20:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toreasa.
Dialogue: 0,0:21:04.37,0:21:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang.
Dialogue: 0,0:21:05.24,0:21:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toreasa!
Dialogue: 0,0:21:06.08,0:21:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang!
Dialogue: 0,0:21:07.16,0:21:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Toreasa!\N- Sayang.
Dialogue: 0,0:21:09.54,0:21:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:21:11.33,0:21:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau bukan pemikiran hebat\NDetektif Nona Ariane,
Dialogue: 0,0:21:14.17,0:21:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Toreasa pasti sudah terbunuh.
Dialogue: 0,0:21:16.63,0:21:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detektif?
Dialogue: 0,0:21:18.26,0:21:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lupakan saja.
Dialogue: 0,0:21:20.43,0:21:23.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Tuan Petros pasti kesulitan.
Dialogue: 0,0:21:23.49,0:21:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia harus menjatuhkan hukuman\Npada ayahnya sendiri.
Dialogue: 0,0:21:27.10,0:21:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tidak perlu sampai begitu.
Dialogue: 0,0:21:29.85,0:21:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar burung itu!
Dialogue: 0,0:21:31.27,0:21:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa komplotannya pasti bersembunyi\Ndi arah tujuannya!
Dialogue: 0,0:21:34.36,0:21:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tak ada lagi\Nyang memihak mantan penguasa.
Dialogue: 0,0:21:37.33,0:21:41.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua mungkin suatu saat nanti\Nakan mengubah dunia.
Dialogue: 0,0:21:41.32,0:21:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:44.57,0:21:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu burung pembisik?
Dialogue: 0,0:21:49.96,0:21:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ariane, Arc.
Dialogue: 0,0:21:52.04,0:21:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini... Danka?
Dialogue: 0,0:21:53.92,0:21:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Orang itu, ya.
Dialogue: 0,0:21:56.59,0:21:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, dia tidak kelihatan.
Dialogue: 0,0:21:58.92,0:22:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di wilayah Hoban, Kerajaan Rhoden,
Dialogue: 0,0:22:00.84,0:22:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada sekelompok orang yang menculik kaum elf,\Nmanusia hewan, bahkan manusia.
Dialogue: 0,0:22:06.01,0:22:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah ke sana.
