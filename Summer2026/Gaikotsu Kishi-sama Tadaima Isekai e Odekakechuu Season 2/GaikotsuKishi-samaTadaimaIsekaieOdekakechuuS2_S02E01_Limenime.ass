Dialogue: 0,0:00:49.40,0:00:51.16,sign,,0000,0000,0000,,LARIAT ZIRAH
Dialogue: 0,0:01:34.37,0:01:37.04,sign,,0000,0000,0000,,BADAI HUJAN PETIR
Dialogue: 0,0:01:54.26,0:01:55.51,sign,,0000,0000,0000,,PELINDUNG PETIR
Dialogue: 0,0:02:26.04,0:02:30.00,sign,,0000,0000,0000,,KESATRIA TENGKORAK BERKELANA DI DUNIA LAIN\NMUSIM KEDUA
Dialogue: 0,0:09:30.80,0:09:31.97,sign,,0000,0000,0000,,PEMULIHAN
Dialogue: 0,0:13:44.97,0:13:49.98,sign,,0000,0000,0000,,EPISODE 1: PERTARUNGAN MAUT?\NKESATRIA PERAK MELAWAN KESATRIA PERAK!
Dialogue: 0,0:13:49.98,0:13:53.98,sign,,0000,0000,0000,,KADIPATEN AGUNG LIMBULT
Dialogue: 0,0:16:36.60,0:16:40.27,sign,,0000,0000,0000,,TEBASAN NAGA
Dialogue: 0,0:19:33.94,0:19:35.65,sign,,0000,0000,0000,,TARING BATU TAJAM
Dialogue: 0,0:20:02.06,0:20:04.31,sign,,0000,0000,0000,,PERLINDUNGAN CAHAYA SUCI
Dialogue: 0,0:23:39.94,0:23:44.94,sign,,0000,0000,0000,,SELANJUTNYA: TARING RACUN PEMBUNUH\NYANG MENGINTAI PENGANTIN ELF
Dialogue: 0,0:00:08.07,0:00:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun, tolong!
Dialogue: 0,0:00:09.61,0:00:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:00:11.66,0:00:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong kami!
Dialogue: 0,0:00:13.35,0:00:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, kerja bagus.
Dialogue: 0,0:00:18.54,0:00:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:00:20.25,0:00:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para Orc ini adalah anak buahku.
Dialogue: 0,0:00:23.73,0:00:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang yang bisa\Nmenyelamatkan kalian.
Dialogue: 0,0:00:28.63,0:00:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada gadis cantik di sini.
Dialogue: 0,0:00:31.45,0:00:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini biar aku coba dulu sebelum dijual.
Dialogue: 0,0:00:36.98,0:00:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku Arc.
Dialogue: 0,0:00:42.81,0:00:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang ke dunia lain
Dialogue: 0,0:00:44.40,0:00:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk bertualang dengan tenang\Ntanpa mencolok.
Dialogue: 0,0:00:47.57,0:00:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kamu?
Dialogue: 0,0:00:49.40,0:00:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lariat Zirah!
Dialogue: 0,0:00:52.16,0:00:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, tidak berjalan lancar.
Dialogue: 0,0:00:55.16,0:00:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, masalah beres!
Dialogue: 0,0:01:03.38,0:01:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan, Arc?
Dialogue: 0,0:01:08.84,0:01:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya ketemu, Tuan Arc.
Dialogue: 0,0:01:12.09,0:01:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Nona Ariane, Nona Chiyome, dan Ponta.
Dialogue: 0,0:01:15.10,0:01:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai, Api.
Dialogue: 0,0:01:16.35,0:01:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membaralah dan menari dengan pedangku!
Dialogue: 0,0:01:20.64,0:01:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir air, Taring Serigala Tirta!
Dialogue: 0,0:01:24.31,0:01:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang hebat.
Dialogue: 0,0:01:25.94,0:01:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku juga.
Dialogue: 0,0:01:28.32,0:01:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir area elemen petir!
Dialogue: 0,0:01:31.11,0:01:33.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lightning Downpour!
Dialogue: 0,0:01:39.33,0:01:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu, Arc!
Dialogue: 0,0:02:00.18,0:02:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, masalah beres!
Dialogue: 0,0:02:05.10,0:02:07.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres apanya?
Dialogue: 0,0:02:07.02,0:02:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara melakukan ini,\Nkita jadi mencolok!
Dialogue: 0,0:02:50.02,0:02:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kegelapan Perak?
Dialogue: 0,0:02:52.19,0:02:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dark Elf yang kejam?
Dialogue: 0,0:02:54.28,0:02:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:02:56.36,0:02:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segarnya sampai ke tulang, ya?
Dialogue: 0,0:03:43.37,0:03:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejahatan kalian berakhir di sini!
Dialogue: 0,0:03:45.85,0:03:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang senjata dan menyerahlah!
Dialogue: 0,0:03:48.67,0:03:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak bisa kabur!
Dialogue: 0,0:03:49.96,0:03:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahlah!
Dialogue: 0,0:04:09.85,0:04:13.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyelamatkan\Nanak gadis kami.
Dialogue: 0,0:04:13.52,0:04:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sedikit tanda terima kasih kami.
Dialogue: 0,0:04:16.14,0:04:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, tidak perlu sungkan.
Dialogue: 0,0:04:18.36,0:04:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dinikmati saja.
Dialogue: 0,0:04:19.86,0:04:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Maaf merepotkan.
Dialogue: 0,0:04:22.16,0:04:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku ambil saja.
Dialogue: 0,0:04:23.70,0:04:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Arc!
Dialogue: 0,0:04:25.04,0:04:26.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:04:26.41,0:04:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi di sini, kita terima saja.
Dialogue: 0,0:04:28.62,0:04:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Terlihat enak!
Dialogue: 0,0:04:31.38,0:04:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan khas kota persinggahan ini,
Dialogue: 0,0:04:33.38,0:04:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepiting Gunung Berzirah goreng.
Dialogue: 0,0:04:35.63,0:04:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:04:37.72,0:04:39.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makan di depan mereka?
Dialogue: 0,0:04:39.84,0:04:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Celaka!
Dialogue: 0,0:04:41.14,0:04:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelepasan gara-gara lihat hidangan mewah!
Dialogue: 0,0:04:43.64,0:04:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kota persinggahan kami juga\Nada tempat pemandian.
Dialogue: 0,0:04:46.97,0:04:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan berendam jika berkenan.
Dialogue: 0,0:04:49.02,0:04:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:04:50.02,0:04:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada pemandian air panas, ya.
Dialogue: 0,0:04:52.15,0:04:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:52.94,0:04:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat pemandian yang dipakai\Nseluruh penginapan di kota ini.
Dialogue: 0,0:04:56.65,0:05:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekitar sini, hanya kota kami\Nyang ada tempat pemandiannya.
Dialogue: 0,0:05:00.40,0:05:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebanggaan kota kami.
Dialogue: 0,0:05:01.66,0:05:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:03.03,0:05:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan pergi berendam dulu.
Dialogue: 0,0:05:05.91,0:05:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong antarkan makanannya ke kamar saja.
Dialogue: 0,0:05:08.16,0:05:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kesatria,\Nmaukah saya gosok punggung Anda?
Dialogue: 0,0:05:11.17,0:05:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih.
Dialogue: 0,0:05:13.08,0:05:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ada yang masuk ke pemandian\Nsampai aku selesai.
Dialogue: 0,0:05:16.42,0:05:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya jangan.
Dialogue: 0,0:05:18.17,0:05:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pemandiannya di mana?
Dialogue: 0,0:05:20.26,0:05:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saya antar.
Dialogue: 0,0:05:23.47,0:05:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan Tuan Kesatria?
Dialogue: 0,0:05:26.64,0:05:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kesatria itu pemalu.
Dialogue: 0,0:05:29.10,0:05:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:30.31,0:05:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga enak.
Dialogue: 0,0:05:32.52,0:05:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, dicoba.
Dialogue: 0,0:05:34.63,0:05:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:35.86,0:05:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dimakan.
Dialogue: 0,0:05:40.70,0:05:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kalian tidak terpikirkan apa pun\Ntentang kami?
Dialogue: 0,0:05:45.70,0:05:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:46.74,0:05:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini memang jarang terlihat elf\Nmaupun manusia hewan.
Dialogue: 0,0:05:50.93,0:05:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami menganggapnya langka.
Dialogue: 0,0:05:53.00,0:05:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:05:54.92,0:05:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalian tidak ada bedanya\Ndengan kami.
Dialogue: 0,0:05:59.17,0:06:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia juga bermacam-macam, ya.
Dialogue: 0,0:06:21.28,0:06:25.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segarnya sampai ke tulang, Ponta.
Dialogue: 0,0:06:26.28,0:06:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Arc masih di dalam.
Dialogue: 0,0:06:28.70,0:06:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia suka sekali berendam.
Dialogue: 0,0:06:30.70,0:06:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga mau mandi, ya.
Dialogue: 0,0:06:33.23,0:06:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nona Ariane.
Dialogue: 0,0:06:35.58,0:06:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan, sih, teriak-teriak?
Dialogue: 0,0:06:43.42,0:06:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:06:45.43,0:06:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!
Dialogue: 0,0:06:50.18,0:06:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kamu ini.
Dialogue: 0,0:06:51.93,0:06:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa membedakan\Npemandian pria dan wanita.
Dialogue: 0,0:06:54.44,0:06:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar banget.
Dialogue: 0,0:06:56.10,0:06:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sungguh memalukan.
Dialogue: 0,0:06:58.44,0:07:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Arc,
Dialogue: 0,0:07:00.27,0:07:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah kamu mau ke mata air peluluh kutukan\Nagar kembali ke wujud manusia?
Dialogue: 0,0:07:04.00,0:07:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin bisa bersantai seperti ini?
Dialogue: 0,0:07:06.66,0:07:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita malah pergi ke arah berlawanan\Ndari Pegunungan Naga Angin.
Dialogue: 0,0:07:10.95,0:07:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara Arc mampir ke sana-sini, sih.
Dialogue: 0,0:07:13.95,0:07:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi?
Dialogue: 0,0:07:16.08,0:07:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa membiarkan orang\Nyang kesulitan, kan?
Dialogue: 0,0:07:18.83,0:07:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengantar seorang nenek\Nke kampung halamannya.
Dialogue: 0,0:07:22.84,0:07:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membasmi sindikat perampok\Nyang mencuri permata.
Dialogue: 0,0:07:26.84,0:07:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai menyelamatkan anak-anak\Ndari perdagangan manusia.
Dialogue: 0,0:07:30.85,0:07:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu-tahu sekarang sudah sampai di sini.
Dialogue: 0,0:07:33.72,0:07:37.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, justru itulah sisi bagusnya Tuan Arc.
Dialogue: 0,0:07:37.92,0:07:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, kamu juga sampai ikut-ikutan.
Dialogue: 0,0:07:41.23,0:07:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, katanya di dekat mata air itu
Dialogue: 0,0:07:43.61,0:07:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada tempat tersembunyi milik Klan Jinshin\Nyang telah lama hilang.
Dialogue: 0,0:07:47.74,0:07:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:48.66,0:07:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat legendaris Klan Jinshin
Dialogue: 0,0:07:50.41,0:07:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang konon menjadi kediaman Hanzo,\Npemimpin pertama Klan Jinshin.
Dialogue: 0,0:07:54.12,0:07:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari tempat itu juga tugasmu, ya?
Dialogue: 0,0:07:58.58,0:08:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus melenceng dari rencana,\Nkita akan merepotkan Chiyome.
Dialogue: 0,0:08:02.42,0:08:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:08:04.13,0:08:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:08:05.09,0:08:07.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Nona Ariane,
Dialogue: 0,0:08:07.26,0:08:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kakimu panjang dan cantik, ya.
Dialogue: 0,0:08:10.51,0:08:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitmu juga halus.
Dialogue: 0,0:08:12.30,0:08:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu kenapa memegang di bagian itu?
Dialogue: 0,0:08:15.98,0:08:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, aku balas, nih!
Dialogue: 0,0:08:18.81,0:08:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kakimu juga indah.\N- Baiklah, mulai sekarang kita jalan lurus
Dialogue: 0,0:08:22.06,0:08:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hentikan! Rasanya geli!\N- tanpa mampir lagi.
Dialogue: 0,0:08:23.35,0:08:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hentikan! Rasanya geli!\N- Setuju, Ponta?
Dialogue: 0,0:08:37.08,0:08:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:08:38.03,0:08:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, kita jadi tak kesulitan\Nmengalirkan air ke ladang.
Dialogue: 0,0:08:56.64,0:08:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kenapa, ya?
Dialogue: 0,0:08:58.43,0:09:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, sejak masuk ke desa ini,\Ntingkah mereka terasa aneh.
Dialogue: 0,0:09:02.65,0:09:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:03.48,0:09:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya mereka seperti menghindari kita.
Dialogue: 0,0:09:12.41,0:09:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lari ke sini!
Dialogue: 0,0:09:16.29,0:09:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada apa?
Dialogue: 0,0:09:17.62,0:09:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa, Nak?
Dialogue: 0,0:09:20.62,0:09:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong biarkan anak ini pergi!
Dialogue: 0,0:09:22.67,0:09:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa sebenarnya ini?
Dialogue: 0,0:09:26.17,0:09:28.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waduh, kakimu berdarah.
Dialogue: 0,0:09:29.07,0:09:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:09:30.80,0:09:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heal!
Dialogue: 0,0:09:33.76,0:09:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah aman.
Dialogue: 0,0:09:37.26,0:09:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak sakit!
Dialogue: 0,0:09:38.43,0:09:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:09:39.60,0:09:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, tidak perlu berterima kasih.
Dialogue: 0,0:09:42.39,0:09:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, bukankah kalian
Dialogue: 0,0:09:44.90,0:09:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kegelapan Perak\Ndan Dark Elf yang kejam?
Dialogue: 0,0:09:49.03,0:09:51.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kegelapan Perak?
Dialogue: 0,0:09:51.45,0:09:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dark Elf yang kejam?
Dialogue: 0,0:09:58.04,0:09:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:09:59.99,0:10:01.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria dan elf ini,
Dialogue: 0,0:10:01.41,0:10:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kabarnya sering menculik banyak orang\Ndi sekitar sini.
Dialogue: 0,0:10:04.92,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah mereka peniru\NTuan Arc dan Nona Ariane?
Dialogue: 0,0:10:08.21,0:10:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peniru, ya?
Dialogue: 0,0:10:11.19,0:10:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku tidak ingin mencolok,
Dialogue: 0,0:10:13.45,0:10:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya aku sudah menjadi\Norang terkenal, ya.
Dialogue: 0,0:10:16.64,0:10:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktunya bicara santai begitu!
Dialogue: 0,0:10:19.39,0:10:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak memaafkan siapa pun\Nyang meniruku!
Dialogue: 0,0:10:21.68,0:10:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Niatnya mau langsung ke mata air,
Dialogue: 0,0:10:24.02,0:10:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya tidak berjalan lancar, Ponta.
Dialogue: 0,0:10:27.94,0:10:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:10:29.44,0:10:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana biasanya mereka muncul?
Dialogue: 0,0:10:43.87,0:10:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Putri Yuriarna,\Nsemuanya bisa dibebaskan, Kak Ariane.
Dialogue: 0,0:10:49.21,0:10:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memasang wajah menakutkan begitu,\Nnanti musuh malah jadi waspada.
Dialogue: 0,0:10:53.59,0:10:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah bersikap natural.
Dialogue: 0,0:10:56.30,0:10:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya juga.
Dialogue: 0,0:10:58.55,0:11:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:11:00.14,0:11:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Putri Yuriarna dari Kerajaan Rhoden
Dialogue: 0,0:11:02.56,0:11:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memutuskan untuk menyelamatkan\Ndan melindungi para elf,
Dialogue: 0,0:11:05.85,0:11:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami yang dulu pernah ditangkap
Dialogue: 0,0:11:07.77,0:11:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya bisa bebas.
Dialogue: 0,0:11:10.23,0:11:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dialognya terlalu banyak penjelasan,\Npanjang, dan datar.
Dialogue: 0,0:11:14.49,0:11:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bagaimana lagi?
Dialogue: 0,0:11:15.99,0:11:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah berakting.
Dialogue: 0,0:11:19.33,0:11:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pura-pura tidak tahu saja.
Dialogue: 0,0:11:21.03,0:11:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia hewan\Nbisa kabur memanfaatkan situasi yang kacau.
Dialogue: 0,0:11:24.83,0:11:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kampung halamanku\Nsangat jauh dari sini.
Dialogue: 0,0:11:28.79,0:11:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caranya kami bisa pulang?
Dialogue: 0,0:11:40.14,0:11:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyome, bukankah kita mau\Nmenyerang mereka?
Dialogue: 0,0:11:43.02,0:11:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang-orang lain yang ditangkap.
Dialogue: 0,0:11:45.28,0:11:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan mereka bawa kita ke markasnya.
Dialogue: 0,0:11:47.69,0:11:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong! Tolong!
Dialogue: 0,0:12:00.07,0:12:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, lumayan juga.
Dialogue: 0,0:12:02.45,0:12:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak sehebat yang asli.
Dialogue: 0,0:12:05.41,0:12:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ampuni kami!
Dialogue: 0,0:12:07.33,0:12:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong biarkan kami hidup!
Dialogue: 0,0:12:10.12,0:12:13.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyome, aktingmu jago banget.
Dialogue: 0,0:12:13.21,0:12:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku Shinobi.
Dialogue: 0,0:12:14.55,0:12:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Nona Ariane juga.
Dialogue: 0,0:12:17.09,0:12:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bunuh kami!
Dialogue: 0,0:12:22.39,0:12:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf dan manusia hewan?
Dialogue: 0,0:12:25.02,0:12:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita dapat tangkapan berkualitas.
Dialogue: 0,0:12:26.64,0:12:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ada mereka berdua?
Dialogue: 0,0:12:29.44,0:12:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah bikin keributan besar di sini.
Dialogue: 0,0:12:32.15,0:12:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang jadi mulai waspada.
Dialogue: 0,0:12:35.90,0:12:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, bos sudah menunggu.
Dialogue: 0,0:12:49.04,0:12:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat dada elf ini.
Dialogue: 0,0:12:51.29,0:12:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggoda banget.
Dialogue: 0,0:12:54.34,0:12:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaiannya vulgar pula.
Dialogue: 0,0:12:56.38,0:12:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sengaja, ya?
Dialogue: 0,0:12:58.05,0:12:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan.
Dialogue: 0,0:13:00.51,0:13:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, aromanya menggoda banget.
Dialogue: 0,0:13:05.10,0:13:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau macam-macam,\Nkamu bisa kena marah bos, lo.
Dialogue: 0,0:13:08.31,0:13:09.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan.
Dialogue: 0,0:13:11.40,0:13:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian ini rasanya sesak banget.
Dialogue: 0,0:13:17.19,0:13:19.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan perlihatkan wajahmu.
Dialogue: 0,0:13:19.49,0:13:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kakinya kayak cewek sungguhan.
Dialogue: 0,0:13:23.28,0:13:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak punya bulu kaki, lo.
Dialogue: 0,0:13:25.62,0:13:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku mungkin lebih cantik\Ndari orang aslinya.
Dialogue: 0,0:13:29.16,0:13:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tahan!
Dialogue: 0,0:13:55.98,0:13:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuriarna.
Dialogue: 0,0:13:57.48,0:14:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin mau menemui Sekt?
Dialogue: 0,0:14:01.36,0:14:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Ayunda Seriarna.
Dialogue: 0,0:14:03.74,0:14:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir.
Dialogue: 0,0:14:05.37,0:14:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah hal itu berbahaya?
Dialogue: 0,0:14:07.01,0:14:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah memiliki dukungan,
Dialogue: 0,0:14:09.24,0:14:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Tuan Fangas, sang Tetua Agung kaum elf.
Dialogue: 0,0:14:12.87,0:14:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu juga seharusnya\Ntidak bisa asal ikut campur.
Dialogue: 0,0:14:17.54,0:14:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sendiri yang akan mendatanginya.
Dialogue: 0,0:14:27.60,0:14:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duduk!
Dialogue: 0,0:14:29.93,0:14:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mereka tangkapan kita hari ini?
Dialogue: 0,0:14:32.31,0:14:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:14:33.85,0:14:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi dia akan datang.
Dialogue: 0,0:14:36.02,0:14:39.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dagangan sebanyak ini harusnya sudah cukup.
Dialogue: 0,0:14:39.27,0:14:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangkapan hari ini sangat berkualitas.
Dialogue: 0,0:14:41.69,0:14:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia hewan dan elf.
Dialogue: 0,0:14:43.45,0:14:44.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh?
Dialogue: 0,0:14:45.53,0:14:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia hewan dan elf, ya?
Dialogue: 0,0:14:56.75,0:14:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:14:58.09,0:15:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak bengal yang mesum itu!
Dialogue: 0,0:15:05.63,0:15:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalian!
Dialogue: 0,0:15:08.51,0:15:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Perak dan elf wanita!
Dialogue: 0,0:15:11.01,0:15:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Mustahil!\N- Mereka yang asli?
Dialogue: 0,0:15:12.77,0:15:13.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Ariane!
Dialogue: 0,0:15:13.77,0:15:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama banget!
Dialogue: 0,0:15:16.52,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:15:17.81,0:15:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah berhasil menyusup\Nke dalam markas penculik.
Dialogue: 0,0:15:23.90,0:15:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia adalah orang yang meniruku?
Dialogue: 0,0:15:27.11,0:15:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponta, apakah dia mirip denganku?
Dialogue: 0,0:15:31.03,0:15:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, mana penirunya Nona Ariane?
Dialogue: 0,0:15:34.29,0:15:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya!
Dialogue: 0,0:15:36.04,0:15:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang kalian lakukan?
Dialogue: 0,0:15:37.79,0:15:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajar mereka!
Dialogue: 0,0:15:39.21,0:15:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:41.30,0:15:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Chiyome, Nona Ariane.
Dialogue: 0,0:15:43.13,0:15:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:15:43.80,0:15:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hukum mereka sepantasnya!
Dialogue: 0,0:15:51.85,0:15:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita sialan!
Dialogue: 0,0:15:55.68,0:15:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.
Dialogue: 0,0:15:57.48,0:16:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mau kuperlakukan\Ndengan baik kalau patuh.
Dialogue: 0,0:16:03.23,0:16:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:04.82,0:16:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai, Api.
Dialogue: 0,0:16:05.74,0:16:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selimuti pedangku, terjang dan meledaklah!
Dialogue: 0,0:16:11.66,0:16:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaki siapa tadi yang kamu bilang lebih cantik?
Dialogue: 0,0:16:23.25,0:16:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata lumayan juga.
Dialogue: 0,0:16:25.36,0:16:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, menurutku tetap tidak mirip.
Dialogue: 0,0:16:31.80,0:16:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku perlihatkan
Dialogue: 0,0:16:34.01,0:16:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kekuatan yang asli!
Dialogue: 0,0:16:36.60,0:16:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wyvern Slash!
Dialogue: 0,0:16:58.71,0:16:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:16:59.85,0:17:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyome, tolong jaga mereka.
Dialogue: 0,0:17:01.67,0:17:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:17:02.83,0:17:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arc, kita kejar.
Dialogue: 0,0:17:04.38,0:17:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:17:07.55,0:17:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah aman.
Dialogue: 0,0:17:11.89,0:17:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kabur dari sini.
Dialogue: 0,0:17:23.23,0:17:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:17:26.06,0:17:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar anak bengal\Nyang tidak pernah kapok.
Dialogue: 0,0:17:28.55,0:17:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak bengal?
Dialogue: 0,0:17:29.99,0:17:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:17:31.07,0:17:33.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang waktu itu, ya?
Dialogue: 0,0:17:38.62,0:17:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pikir aku masih seperti dulu.
Dialogue: 0,0:17:41.21,0:17:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sengaja pancing ke sini\Nagar bisa mengalahkan kalian!
Dialogue: 0,0:17:45.00,0:17:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:48.55,0:17:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Ponta?
Dialogue: 0,0:17:51.47,0:17:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datanglah, pasukan monster!
Dialogue: 0,0:18:00.89,0:18:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, itu...
Dialogue: 0,0:18:02.75,0:18:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goblin.
Dialogue: 0,0:18:03.94,0:18:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh! Ternyata memang goblin!
Dialogue: 0,0:18:09.15,0:18:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada Goblin Lord juga.
Dialogue: 0,0:18:12.78,0:18:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia dunia fantasi!
Dialogue: 0,0:18:15.16,0:18:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Goblin, hidup berkelompok di hutan atau gua.
Dialogue: 0,0:18:18.45,0:18:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reproduksinya sangat kuat.
Dialogue: 0,0:18:19.91,0:18:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan menculik perempuan manusia\Nuntuk melahirkan anak.
Dialogue: 0,0:18:23.36,0:18:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Secara individu tidaklah kuat, namun ganas.
Dialogue: 0,0:18:26.29,0:18:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan yang sangat merepotkan\Nketika berkawanan.
Dialogue: 0,0:18:30.17,0:18:32.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu paham sekali tentang hal itu.
Dialogue: 0,0:18:32.92,0:18:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubalaskan dendam papa sekarang!
Dialogue: 0,0:18:36.01,0:18:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunuh mereka berdua!
Dialogue: 0,0:18:40.43,0:18:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang bukan waktunya merasa senang.
Dialogue: 0,0:18:47.61,0:18:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali!
Dialogue: 0,0:18:49.02,0:18:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa anak bengal itu\Nbisa mengendalikan goblin?
Dialogue: 0,0:18:53.40,0:18:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang, aku tidak seperti dulu lagi.
Dialogue: 0,0:18:56.28,0:18:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku telah mendapatkan kekuatan.
Dialogue: 0,0:19:01.75,0:19:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan!
Dialogue: 0,0:19:06.29,0:19:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:19:14.13,0:19:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada habisnya.
Dialogue: 0,0:19:20.64,0:19:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti pemimpin kawanannya.
Dialogue: 0,0:19:28.94,0:19:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah,
Dialogue: 0,0:19:30.07,0:19:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sihir area tingkat menengah.
Dialogue: 0,0:19:32.68,0:19:33.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rock Fang!
Dialogue: 0,0:19:35.65,0:19:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu!
Dialogue: 0,0:19:37.16,0:19:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai sihir manipulasi medan di sini...
Dialogue: 0,0:19:48.75,0:19:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:06.35,0:20:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita selamat.
Dialogue: 0,0:20:09.06,0:20:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, masalah beres!
Dialogue: 0,0:20:13.35,0:20:15.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beres apanya?
Dialogue: 0,0:20:22.33,0:20:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat, jalan!
Dialogue: 0,0:20:26.33,0:20:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari yang mereka katakan,
Dialogue: 0,0:20:27.91,0:20:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik manusia, elf, maupun manusia hewan,
Dialogue: 0,0:20:30.46,0:20:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dijual dengan harga tinggi\Nke pedagang luar negeri.
Dialogue: 0,0:20:34.96,0:20:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, negara yang mana?
Dialogue: 0,0:20:38.19,0:20:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orangnya pun tidak tahu.
Dialogue: 0,0:20:40.68,0:20:44.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa dia bisa mengendalikan goblin?
Dialogue: 0,0:20:44.22,0:20:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menundukkan monster itu bukanlah sesuatu\Nyang bisa dilakukan orang biasa.
Dialogue: 0,0:20:48.44,0:20:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, goblin-goblin itu
Dialogue: 0,0:20:50.15,0:20:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipinjamkan oleh pedagang\Ndari luar negeri tersebut.
Dialogue: 0,0:20:53.59,0:20:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan anak bengal itu\Nyang menguasai sihirnya,
Dialogue: 0,0:20:56.82,0:20:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sejak awal memang\Nsudah menuruti perintah.
Dialogue: 0,0:21:00.57,0:21:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya,
Dialogue: 0,0:21:02.10,0:21:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pria yang menyerang gadis-gadis\Ndi kota persinggahan
Dialogue: 0,0:21:04.83,0:21:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dulu juga mengendalikan Orc.
Dialogue: 0,0:21:07.50,0:21:10.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja ada hubungannya.
Dialogue: 0,0:21:21.51,0:21:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, pergilah.
Dialogue: 0,0:21:24.39,0:21:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekerjalah demi Tuhan.
Dialogue: 0,0:21:35.40,0:21:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan kembali ke desa dulu
Dialogue: 0,0:21:37.55,0:21:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mencari tahu\Nada informasi lain atau tidak.
Dialogue: 0,0:21:39.95,0:21:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong ya, Chiyome.
Dialogue: 0,0:21:43.78,0:21:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi kita melipir dari jalan.
Dialogue: 0,0:21:46.89,0:21:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah waktunya kita menuju tujuan utama,
Dialogue: 0,0:21:49.91,0:21:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu mata air peluluh kutukan\Ndi Pegunungan Naga Angin.
Dialogue: 0,0:21:54.46,0:21:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Arc.
Dialogue: 0,0:21:56.67,0:21:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:21:58.30,0:22:00.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah sejauh ini,
Dialogue: 0,0:22:00.43,0:22:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada tempat yang ingin aku kunjungi sebentar.
Dialogue: 0,0:22:05.18,0:22:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat yang ingin kamu kunjungi?
