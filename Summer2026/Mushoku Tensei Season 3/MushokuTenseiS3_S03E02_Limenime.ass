Dialogue: 0,0:22:02.05,0:22:05.05,sign,,0000,0000,0000,,EPISODE 2: MENGGONGGONGLAH! ANJING GILA
Dialogue: 0,0:23:35.06,0:23:40.06,sign,,0000,0000,0000,,SELANJUTNYA: KESEHARIAN YANG KEMBALI
Dialogue: 0,0:00:02.80,0:00:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, hei, katanya dia sudah jadian\Ndengan cowok yang dekat dengannya.
Dialogue: 0,0:00:07.70,0:00:09.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh...
Dialogue: 0,0:00:09.77,0:00:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cowoknya keren, sih, bikin iri.
Dialogue: 0,0:00:12.02,0:00:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:13.48,0:00:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nina tertarik sama seseorang, tidak?
Dialogue: 0,0:00:15.50,0:00:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?!
Dialogue: 0,0:00:15.92,0:00:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, kamu sendiri sama Jino bagaimana?
Dialogue: 0,0:00:18.15,0:00:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jino?!
Dialogue: 0,0:00:18.91,0:00:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus dia tiba-tiba panik.
Dialogue: 0,0:00:22.27,0:00:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku enggak pernah lihat mukanya begitu.\N- Hu-Hubunganku sama Jino bukan begitu!
Dialogue: 0,0:00:25.79,0:00:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu aku mau hidup\Ncukup sama pedang saja!
Dialogue: 0,0:00:28.51,0:00:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saingan si Anjing Gila memang beda.
Dialogue: 0,0:00:31.53,0:00:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nina mana sempat mikirin asmara.
Dialogue: 0,0:00:44.90,0:00:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Anjing Gila masih seperti biasa.
Dialogue: 0,0:00:47.09,0:00:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa habis berlatih sama Gusti Dewa Pedang?
Dialogue: 0,0:00:51.86,0:00:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh, paling kamu enggak bakal\Nbisa punya cowok!
Dialogue: 0,0:00:56.51,0:00:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habiskan saja hidupmu sama pedang\Ndan tetap jadi perawan!
Dialogue: 0,0:01:03.79,0:01:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa, sih?!
Dialogue: 0,0:01:06.00,0:01:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja, tapi aku bukan gadis perawan!
Dialogue: 0,0:01:11.68,0:01:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?! Sama siapa?!
Dialogue: 0,0:01:14.17,0:01:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang dari kecil dibesarkan bersamaku.
Dialogue: 0,0:01:17.01,0:01:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus itu sangat hebat!
Dialogue: 0,0:01:19.11,0:01:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami jadi petualang dan berjalan dari\Nbenua iblis sampai kampung halaman.
Dialogue: 0,0:01:22.61,0:01:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga bisa membalas serangan Orsted!
Dialogue: 0,0:01:25.28,0:01:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong!
Dialogue: 0,0:01:26.45,0:01:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura tempur Dewa Naga itu hebat!
Dialogue: 0,0:01:28.18,0:01:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata Ayah, serangan biasa tidak akan bisa\Nmelukainya sedikit pun!
Dialogue: 0,0:01:31.81,0:01:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bohong,\NRudeus itu bukan orang biasa.
Dialogue: 0,0:01:37.73,0:01:40.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku yang sekarang\Ntidak sebanding dengan Rudeus.
Dialogue: 0,0:01:41.34,0:01:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus jadi lebih kuat.
Dialogue: 0,0:01:52.34,0:01:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mushoku Tensei:\NJobless Reincarnation Season 3
Dialogue: 0,0:01:52.74,0:01:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus pasti cuma imajinasi Eris.
Dialogue: 0,0:02:02.06,0:02:03.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus?
Dialogue: 0,0:02:03.23,0:02:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya! Kalian pasti tidak pernah dengar\Nada petualang dengan nama itu, kan?!
Dialogue: 0,0:02:08.36,0:02:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, kalau Rudeus si Ahli Rawa,\Ndia terkenal di antara para petualang.
Dialogue: 0,0:02:12.94,0:02:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:13.61,0:02:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya berulang kali diajak gabung\Nsama Stepped Leader yang itu.
Dialogue: 0,0:02:17.18,0:02:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari katanya dia mengalahkan\NNaga Merah liar seorang diri.
Dialogue: 0,0:02:20.53,0:02:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jago banget, ya?
Dialogue: 0,0:02:21.83,0:02:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalahkan Naga Merah sendirian?!
Dialogue: 0,0:02:23.46,0:02:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat amat.
Dialogue: 0,0:02:25.87,0:02:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi soal petualang\Nbernama Rudeus yang kuminta?
Dialogue: 0,0:02:29.19,0:02:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, langsung terkumpul soalnya terkenal.
Dialogue: 0,0:02:32.45,0:02:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, yang benar?!
Dialogue: 0,0:02:33.72,0:02:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus Greyrat, jadi penyihir tingkat Dewa Air\Ndi usia lima tahun.
Dialogue: 0,0:02:38.24,0:02:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di usia tujuh tahun jadi guru privat\NEris Boreas Greyrat di Wilayah Fittoa.
Dialogue: 0,0:02:43.35,0:02:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelahnya dia memang menghilang,
Dialogue: 0,0:02:45.19,0:02:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi belakangan mulai tenar jadi petualang\Ndengan nama Rudeus si Ahli Rawa.
Dialogue: 0,0:02:49.36,0:02:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini diundang akademi sihir\Nsebagai siswa khusus
Dialogue: 0,0:02:52.70,0:02:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tinggal di Kota Sihir, Sharia...
Dialogue: 0,0:02:57.35,0:03:01.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Rudeus bukan cuma pangeran\Ndari imajinasi Eris?
Dialogue: 0,0:03:03.36,0:03:08.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, prestasinya memang hebat,\Ntapi dia cuma seorang petualang.
Dialogue: 0,0:03:08.35,0:03:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalahkan Naga Merah sendirian\Nterdengar cuma omong kosong.
Dialogue: 0,0:03:11.47,0:03:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julukannya norak kayak "Ahli Rawa",\Nbisa jadi aslinya tidak sehebat itu?
Dialogue: 0,0:03:17.06,0:03:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:03:20.26,0:03:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu saja, Eris!
Dialogue: 0,0:03:22.09,0:03:26.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukalahkan Rudeus dan kuseret dia\Nsebagai budakku ke hadapanmu!
Dialogue: 0,0:03:36.05,0:03:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir ternyata banyak juga yang kekar.
Dialogue: 0,0:03:39.91,0:03:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi Rudeus ada di sana?!
Dialogue: 0,0:03:42.33,0:03:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:03:43.58,0:03:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus?
Dialogue: 0,0:03:49.04,0:03:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga mau berduel dengan Rudeus?
Dialogue: 0,0:03:51.09,0:03:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:03:57.03,0:03:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda yang bernama Rudeus si Ahli Rawa?
Dialogue: 0,0:03:59.57,0:04:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon terima duel lamaran dari saya.
Dialogue: 0,0:04:07.43,0:04:11.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, anu, apa maksud Anda itu\Nlamaran dengan berduel?
Dialogue: 0,0:04:11.44,0:04:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- yang sedang ramai akhir-akhir ini?\N- Jadi ini Rudeus?
Dialogue: 0,0:04:13.30,0:04:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:13.69,0:04:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badannya kelihatan cukup terlatih,
Dialogue: 0,0:04:16.36,0:04:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak terasa ada ambisi atau semacamnya.
Dialogue: 0,0:04:18.89,0:04:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukanya oke, lah.
Dialogue: 0,0:04:20.94,0:04:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kisanak tidak berhak menolak!\N- Tapi, tidak ada daya tarik seorang pria.
Dialogue: 0,0:04:23.52,0:04:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cocok sekali sama Eris.
Dialogue: 0,0:04:25.95,0:04:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, biar kuhajar habis dia...
Dialogue: 0,0:04:30.03,0:04:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bertarung dengan adil!
Dialogue: 0,0:04:34.91,0:04:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, saya yang menang, ya.
Dialogue: 0,0:04:39.04,0:04:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir bisa mengalahkan pendekar\Ndi jarak sedekat itu?
Dialogue: 0,0:04:42.42,0:04:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kebetulan saja orang dari\Nsuku binatang tadi yang lemah.
Dialogue: 0,0:04:47.13,0:04:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang di situ, aku sedang mencari\Npenyihir bernama Rudeus.
Dialogue: 0,0:04:50.95,0:04:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Kau juga mau\Nmengajaknya berduel, ya?
Dialogue: 0,0:04:54.25,0:04:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Iya.
Dialogue: 0,0:04:57.11,0:04:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti antre di ujung belakang sana.
Dialogue: 0,0:05:05.95,0:05:09.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antrean apa ini?!\NApa sedang ada festival?!
Dialogue: 0,0:05:09.79,0:05:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini antrean untuk mengajukan\Nduel pada Rudeus Greyrat!
Dialogue: 0,0:05:13.53,0:05:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebanyak ini?
Dialogue: 0,0:05:14.89,0:05:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada caranya tidak biar aku boleh\Ndiizinkan untuk duluan?
Dialogue: 0,0:05:18.35,0:05:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti kalahkan dulu semua\Nyang sudah mengantre!
Dialogue: 0,0:05:21.93,0:05:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh itu!\NAku suka!
Dialogue: 0,0:05:24.35,0:05:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua seranglah aku sekarang!
Dialogue: 0,0:05:27.72,0:05:31.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Badigadi si Raja Iblis Abadi.
Dialogue: 0,0:05:31.25,0:05:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberikan gelar pahlawan\Nbila berhasil mengalahkanku!
Dialogue: 0,0:05:35.49,0:05:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bercanda, woi!
Dialogue: 0,0:05:37.06,0:05:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuhajar sini!
Dialogue: 0,0:05:38.94,0:05:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh?
Dialogue: 0,0:05:39.74,0:05:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sombong dulu, hei!
Dialogue: 0,0:05:54.47,0:05:56.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, duh.
Dialogue: 0,0:05:59.71,0:06:01.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, akan kumulai.
Dialogue: 0,0:06:01.63,0:06:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, maju sini!
Dialogue: 0,0:06:17.65,0:06:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja iblis itu tumbang sekali serang?
Dialogue: 0,0:06:20.65,0:06:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris ingin jadi sebanding dengan orang itu?
Dialogue: 0,0:07:24.26,0:07:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang\Ndari jauh-jauh sampai sini.
Dialogue: 0,0:07:27.41,0:07:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan jauh pasti berat untuk lansia.
Dialogue: 0,0:07:29.97,0:07:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Air.
Dialogue: 0,0:07:31.35,0:07:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:07:33.27,0:07:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau sampai mau\Nmenundukkan kepala padaku.
Dialogue: 0,0:07:36.79,0:07:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking mengejutkannya,\Naku jadi datang kemari.
Dialogue: 0,0:07:40.08,0:07:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, siapa dan apa yang harus kuajari?
Dialogue: 0,0:07:45.95,0:07:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nina, izin untuk masuk.
Dialogue: 0,0:07:55.79,0:07:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenangkan dirimu.
Dialogue: 0,0:08:08.59,0:08:09.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuperkenalkan.
Dialogue: 0,0:08:10.25,0:08:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nenek ini adalah Reida Lia,\Npemimpin aliran Dewa Air.
Dialogue: 0,0:08:14.81,0:08:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bersua, Nyonya Dewa Air.
Dialogue: 0,0:08:17.52,0:08:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Nina, ya.\NKamu sudah besar.
Dialogue: 0,0:08:21.53,0:08:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah jadi Ratu Pedang?
Dialogue: 0,0:08:23.89,0:08:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, belum, masih jauh untuk saya.
Dialogue: 0,0:08:26.84,0:08:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya yakin bisa jadi yang tercepat,
Dialogue: 0,0:08:29.28,0:08:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalau yang terkuat itu bukan saya.
Dialogue: 0,0:08:31.99,0:08:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu ini!\NAyo duduk, tidak sopan!
Dialogue: 0,0:08:35.62,0:08:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris, nenek ini mulai sekarang akan\Nmengajarimu tetek bengek Aliran Dewa Air.
Dialogue: 0,0:08:43.07,0:08:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dibantu.
Dialogue: 0,0:08:45.08,0:08:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti binatang liar saja.
Dialogue: 0,0:08:47.71,0:08:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf saja, Nak Gal.
Dialogue: 0,0:08:50.17,0:08:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aliran Dewa Air tidak cocok\Nuntuk anak gadis ini.
Dialogue: 0,0:08:53.47,0:08:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu itu.
Dialogue: 0,0:08:55.84,0:08:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus apa yang harus kuajarkan?
Dialogue: 0,0:08:58.39,0:09:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah kau ajari apa-apa,\Ncukup jadi lawannya.
Dialogue: 0,0:09:02.50,0:09:04.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:09:05.10,0:09:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini? Kau ingin menyuruh\Nbinatang ini membunuhku, ya?
Dialogue: 0,0:09:09.95,0:09:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:09:11.59,0:09:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa membunuh nenek-nenek\Nyang nanti juga mati sendiri.
Dialogue: 0,0:09:15.59,0:09:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, ayo beri tahu,\Nkau ingin dia melawan siapa?
Dialogue: 0,0:09:22.24,0:09:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris yang di situ katanya ingin\Nmengalahkan Dewa Naga Orsted.
Dialogue: 0,0:09:28.59,0:09:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Dewa Naga?
Dialogue: 0,0:09:33.68,0:09:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali targetnya.
Dialogue: 0,0:09:36.49,0:09:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kau pikir dia bisa?
Dialogue: 0,0:09:38.69,0:09:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku bisa.
Dialogue: 0,0:09:41.17,0:09:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Eris yang melawan.
Dialogue: 0,0:09:43.21,0:09:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru menarik.
Dialogue: 0,0:09:45.17,0:09:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, maaf saja, aku tidak akan mau\Nmenghadapi orang tak berbakat.
Dialogue: 0,0:09:50.65,0:09:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawan dulu muridku, kalau sudah bisa\Nmenang telak, baru melawanku.
Dialogue: 0,0:09:58.19,0:10:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kudengar ceritanya.
Dialogue: 0,0:10:01.31,0:10:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkenalkan aku Isolde Cluel,\Ntingkat Raja Air.
Dialogue: 0,0:10:04.68,0:10:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon ingat aku untuk ke depannya.
Dialogue: 0,0:10:07.17,0:10:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nina Farion, tingkat Pedang Suci.
Dialogue: 0,0:10:10.61,0:10:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Eris Greyrat.
Dialogue: 0,0:10:14.53,0:10:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menolak melawannya\Nkarena disuruh Guru.
Dialogue: 0,0:10:18.50,0:10:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jangan pikir setingkat Pedang Suci\Nbisa mengalahkanku.
Dialogue: 0,0:10:26.06,0:10:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, tolong jarang terlalu keras.
Dialogue: 0,0:11:15.53,0:11:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah kapan pun.
Dialogue: 0,0:11:30.71,0:11:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menang.
Dialogue: 0,0:11:35.97,0:11:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hasil yang menarik.
Dialogue: 0,0:11:38.61,0:11:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada menariknya sama sekali.
Dialogue: 0,0:11:41.53,0:11:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, tapi mungkin hasilnya cukup bagus.
Dialogue: 0,0:11:45.37,0:11:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bagaimana?
Dialogue: 0,0:11:46.99,0:11:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mau belajar teknik Dewa Air padaku?
Dialogue: 0,0:11:50.15,0:11:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sepertinya saya ingin\Nmemperdalam aliran Dewa Pedang.
Dialogue: 0,0:11:54.19,0:11:57.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya, ya, bagus itu.
Dialogue: 0,0:11:57.51,0:12:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau mereka biar latihan bertiga\Nuntuk saling mengasah diri dulu?
Dialogue: 0,0:12:04.71,0:12:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:12:06.83,0:12:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, pagi ini belajar\Nseperti biasa dengan guru,
Dialogue: 0,0:12:10.45,0:12:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah matahari mulai turun,\Nkalian berlatihlah bertiga.
Dialogue: 0,0:12:13.09,0:12:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:14.03,0:12:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, baik.
Dialogue: 0,0:12:35.09,0:12:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi yang menang.
Dialogue: 0,0:12:37.72,0:12:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isolde menang dari Eris.
Dialogue: 0,0:12:39.85,0:12:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menang melawan Isolde.
Dialogue: 0,0:12:41.65,0:12:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan Eris menang melawanku.
Dialogue: 0,0:12:43.48,0:12:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada habisnya, ya.
Dialogue: 0,0:12:46.83,0:12:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita adakan evaluasi?
Dialogue: 0,0:12:49.29,0:12:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang apa gunanya?
Dialogue: 0,0:12:51.12,0:12:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aliran Dewa Air akan saling memberi saran\Nuntuk mengasah diri satu sama lain.
Dialogue: 0,0:12:57.04,0:12:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak masalah, sih.
Dialogue: 0,0:13:01.17,0:13:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, ayo kita lakukan.
Dialogue: 0,0:13:04.51,0:13:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sepakat, ya, kalau begitu...
Dialogue: 0,0:13:07.68,0:13:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kencangkan lagi suaramu!
Dialogue: 0,0:13:09.25,0:13:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tempat yang lebih tenang tidak?
Dialogue: 0,0:13:12.32,0:13:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:13:18.73,0:13:21.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan langsung kusampaikan.
Dialogue: 0,0:13:21.07,0:13:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris terlalu banyak\Nmengeluarkan hawa membunuh.
Dialogue: 0,0:13:24.20,0:13:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aliran Dewa Air seperti kami\Npeka pada hawa membunuh.
Dialogue: 0,0:13:27.49,0:13:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tahu akan diserang,\Nbisa diantisipasi.
Dialogue: 0,0:13:30.98,0:13:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dikasih tahu kayak begitu pun\Naku tidak tahu harus bagaimana.
Dialogue: 0,0:13:34.77,0:13:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, juga.
Dialogue: 0,0:13:37.03,0:13:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nina hampir tidak mengeluarkan\Nhawa membunuh, bagaimana caranya?
Dialogue: 0,0:13:41.17,0:13:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditanya bagaimana...
Dialogue: 0,0:13:43.33,0:13:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan menang kalau bisa\Nmengayun pedang secepat mungkin.
Dialogue: 0,0:13:46.19,0:13:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu mengeluarkan\Nhawa membunuh, kan?
Dialogue: 0,0:13:49.62,0:13:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham.
Dialogue: 0,0:13:52.34,0:13:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku tidak bisa menang\Ndari orang seperti ini, sih?
Dialogue: 0,0:13:55.19,0:13:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin hilang pede saja.
Dialogue: 0,0:13:57.69,0:14:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku membuatmu bergerak belakangan.
Dialogue: 0,0:14:01.55,0:14:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:02.89,0:14:05.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diajari Ruijerd.
Dialogue: 0,0:14:05.10,0:14:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arah pandangan bisa dipakai membuat musuh\Ngerak lebih dulu atau belakangan dariku.
Dialogue: 0,0:14:11.16,0:14:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rui... jerd, itu siapa?
Dialogue: 0,0:14:13.66,0:14:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia guruku.
Dialogue: 0,0:14:15.80,0:14:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, Eris sengaja memancing\Npergerakan musuh, begitu?
Dialogue: 0,0:14:21.45,0:14:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, begitu.
Dialogue: 0,0:14:24.57,0:14:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu, itu juga kau lakukan padaku?
Dialogue: 0,0:14:27.14,0:14:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kulakukan, tapi kau tidak bergerak.
Dialogue: 0,0:14:30.05,0:14:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memang menerima latihan seperti itu.
Dialogue: 0,0:14:33.94,0:14:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali bagaimana kalau tidak usah begitu\Ndan menahan hawa membunuhmu?
Dialogue: 0,0:14:38.98,0:14:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kucoba.
Dialogue: 0,0:14:41.39,0:14:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kalau aku menurutmu harus bagaimana?
Dialogue: 0,0:14:43.86,0:14:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:45.97,0:14:49.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau coba tanya ke gurumu?
Dialogue: 0,0:14:49.44,0:14:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau akan semudah itu memberi tahu,\Nkita tidak akan susah-susah latihan bertiga.
Dialogue: 0,0:14:59.03,0:15:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bikin evaluasi ternyata tidak ada artinya.
Dialogue: 0,0:15:05.18,0:15:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:15:05.96,0:15:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:06.91,0:15:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau punya baju\Nyang sama dengan Ghislaine?
Dialogue: 0,0:15:09.95,0:15:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Oh...
Dialogue: 0,0:15:12.36,0:15:15.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dibuatkan saat kami jadi Pedang Suci.
Dialogue: 0,0:15:15.24,0:15:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bukan gayaku, jadi jarang kupakai.
Dialogue: 0,0:15:18.02,0:15:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya.
Dialogue: 0,0:15:19.77,0:15:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pengin, buru saja sendiri sana.
Dialogue: 0,0:15:21.98,0:15:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau paling juga bisa.
Dialogue: 0,0:15:25.45,0:15:26.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya buru sendiri?
Dialogue: 0,0:15:26.91,0:15:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujian Pedang Suci itu disuruh\Nuntuk memburu monster.
Dialogue: 0,0:15:30.73,0:15:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulit monster hasil buruan sendiri\Ndijadikan jaket sebagai tanda Pedang Suci.
Dialogue: 0,0:15:35.71,0:15:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster itu ada di mana memangnya?
Dialogue: 0,0:15:38.09,0:15:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke hutan yang ada air terjunnya\Nke arah barat dari sini, tidak sejauh itu, kok.
Dialogue: 0,0:15:42.22,0:15:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antar aku ke sana!
Dialogue: 0,0:15:46.13,0:15:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:15:47.80,0:15:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku juga boleh ikut?
Dialogue: 0,0:16:07.89,0:16:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kalian akan baik-baik saja.
Dialogue: 0,0:16:10.63,0:16:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jumlahnya lumayan banyak\Ndan gesit, jadi hati-hati, lo.
Dialogue: 0,0:16:14.23,0:16:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jarang bertarung dengan monster,\Njadi gugup rasanya.
Dialogue: 0,0:16:18.83,0:16:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih lebih mudah dibanding\Nmenjinakkan binatang itu.
Dialogue: 0,0:16:21.42,0:16:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, monsternya ada di mana?
Dialogue: 0,0:16:23.68,0:16:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan datang kalau menyalakan api.
Dialogue: 0,0:16:25.61,0:16:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggulah sebentar.
Dialogue: 0,0:16:34.76,0:16:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:16:36.40,0:16:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naungan bara agung akan selalu datang\Nbagi mereka yang membutuhkan.
Dialogue: 0,0:16:40.02,0:16:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datangkanlah panasnya cahaya\Nnan gagah berani di sini.
Dialogue: 0,0:16:43.19,0:16:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fireball.
Dialogue: 0,0:16:48.24,0:16:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini, bisa pakai sihir?!
Dialogue: 0,0:16:50.70,0:16:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar dari Rudeus.
Dialogue: 0,0:16:52.61,0:16:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga diajari caranya baca tulis.
Dialogue: 0,0:16:54.84,0:16:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengajarimu sihir dan baca tulis?!
Dialogue: 0,0:16:57.12,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghislaine juga diajari.
Dialogue: 0,0:16:58.83,0:17:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga diajari bahasa iblis\Nsaat melewati benua iblis.
Dialogue: 0,0:17:02.61,0:17:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat di hutan rimba, dia bisa\Nbicara dengan suku binatang.
Dialogue: 0,0:17:06.13,0:17:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus itu hebat pokoknya.
Dialogue: 0,0:17:12.54,0:17:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini...
Dialogue: 0,0:17:21.56,0:17:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu monster yang kumaksud.
Dialogue: 0,0:17:35.08,0:17:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, banyak sekali yang dibiarkan lolos.
Dialogue: 0,0:18:15.31,0:18:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat menyenangkan.
Dialogue: 0,0:18:17.89,0:18:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlatih dan mengevaluasi bersama anak\Ndengan ilmu pedang yang kurang lebih setara
Dialogue: 0,0:18:23.31,0:18:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memburu monster seperti ini\Nadalah pertama kalinya buatku.
Dialogue: 0,0:18:26.56,0:18:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ya.\NAku juga sama.
Dialogue: 0,0:18:33.38,0:18:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku permisi di sini.
Dialogue: 0,0:18:35.57,0:18:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih untuk hari ini.
Dialogue: 0,0:18:37.85,0:18:40.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung sekali kita mengadakan evaluasi.
Dialogue: 0,0:18:40.35,0:18:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa perlahan-lahan\Njadi makin kuat.
Dialogue: 0,0:18:50.03,0:18:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih juga untuk Eris.
Dialogue: 0,0:18:53.17,0:18:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu seranganku pasti\Nbisa mengenaimu nanti.
Dialogue: 0,0:18:55.96,0:18:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunggu dengan senang hati.
Dialogue: 0,0:18:57.96,0:19:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, selamat istirahat.
Dialogue: 0,0:19:09.50,0:19:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:10.61,0:19:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin tahu cara agar tidak\Nmengeluarkan hawa membunuh, kan?
Dialogue: 0,0:19:14.79,0:19:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa?
Dialogue: 0,0:19:16.50,0:19:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, cobalah tiap hari mandi,\Ncucilah badanmu, makan yang benar,
Dialogue: 0,0:19:21.45,0:19:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu tidur nyenyak di kasur hangat sambil\Nmemikirkan cowok yang kamu suka, bagaimana?
Dialogue: 0,0:19:26.85,0:19:30.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya itu?\NRudeus tidak ada hubungannya, kan?
Dialogue: 0,0:19:32.01,0:19:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hawa membunuhmu ini hilang\Nsaat bercerita soal dia.
Dialogue: 0,0:19:35.97,0:19:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba saja, sana.
Dialogue: 0,0:19:41.15,0:19:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalau terlalu jorok\Nnanti malah bisa dibenci.
Dialogue: 0,0:19:52.59,0:19:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Rudeus memang teliti soal mencuci.
Dialogue: 0,0:20:19.42,0:20:20.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:21:12.08,0:21:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya mereka bertiga\Nsekarang jadi setara.
Dialogue: 0,0:21:16.15,0:21:19.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski setara, hubungan kekuatannya\Ntetap tidak berubah.
Dialogue: 0,0:21:19.77,0:21:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:21:20.84,0:21:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap sebuah kemajuan, mereka bisa\Nsaling menang sekali dari tiga pertandingan.
Dialogue: 0,0:21:25.01,0:21:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mereka semakin berkembang.
Dialogue: 0,0:21:27.84,0:21:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini yang Guru incar, ya.
Dialogue: 0,0:21:32.45,0:21:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Akhirnya berhasil.\N- Yah,
Dialogue: 0,0:21:34.19,0:21:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kukira aku akan mati.\N- memang benar dia jadi makin kuat.
Dialogue: 0,0:21:36.04,0:21:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengatur tenaganya itu susah.
Dialogue: 0,0:21:38.26,0:21:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya aku lawan Nina, kan?!
Dialogue: 0,0:21:40.11,0:21:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sampai sini saja.
Dialogue: 0,0:21:41.65,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:21:42.87,0:21:46.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah pertandingan tadi selesai,\Nrencananya mau mengadakan evaluasi.
Dialogue: 0,0:21:46.86,0:21:48.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:21:49.70,0:21:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa mandi sebelum mulai evaluasi!
Dialogue: 0,0:21:57.19,0:21:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tahu!
