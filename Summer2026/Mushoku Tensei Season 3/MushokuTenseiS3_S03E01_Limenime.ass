Dialogue: 0,0:22:01.97,0:22:04.97,sign,,0000,0000,0000,,EPISODE 1: MEMBARALAH! ANJING GILA
Dialogue: 0,0:23:34.98,0:23:39.98,sign,,0000,0000,0000,,SELANJUTNYA: MENGGONGGONGLAH! ANJING GILA
Dialogue: 0,0:00:29.20,0:00:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima Rudeus sebagai\Nhadiah ulang tahun kelima belasku.
Dialogue: 0,0:00:34.70,0:00:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sedikit beda dengan janjinya,\Ntapi aku sudah terikat dengan Rudeus.
Dialogue: 0,0:00:41.59,0:00:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecil sekali.
Dialogue: 0,0:00:46.32,0:00:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku selalu saja ia tolong.
Dialogue: 0,0:00:51.70,0:00:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pantas untuk Rudeus.
Dialogue: 0,0:01:09.31,0:01:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris...
Dialogue: 0,0:02:26.71,0:02:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ha, itu siapa?\N- Bukannya itu?
Dialogue: 0,0:02:29.09,0:02:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu, Nona Ghislaine?
Dialogue: 0,0:02:32.89,0:02:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti latihan!
Dialogue: 0,0:02:34.39,0:02:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua masuk ke aula tunggu!
Dialogue: 0,0:02:44.14,0:02:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mushoku Tensei:\NJobless Reincarnation Season 3
Dialogue: 0,0:03:07.51,0:03:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ghislaine, kau masih hidup rupanya.
Dialogue: 0,0:03:10.97,0:03:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bersua, Guru.
Dialogue: 0,0:03:13.67,0:03:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira sudah mati telantar di suatu tempat,\Nternyata kau lebih sehat dari yang kuduga.
Dialogue: 0,0:03:18.95,0:03:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang di sampingmu itu?
Dialogue: 0,0:03:20.89,0:03:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Eris, muridku.
Dialogue: 0,0:03:23.15,0:03:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kubawa kemari agar dididik oleh Guru.
Dialogue: 0,0:03:26.56,0:03:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, mendidik dia?
Dialogue: 0,0:03:31.47,0:03:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya urusan\Nsama keroco sepertimu!
Dialogue: 0,0:03:36.95,0:03:39.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berengsek, jaga bicaramu pada Guru!
Dialogue: 0,0:03:39.17,0:03:40.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berlutut!
Dialogue: 0,0:03:40.25,0:03:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di depanmu itu\NTuan Gal Farion sang Dewa Pedang!
Dialogue: 0,0:03:43.20,0:03:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget kenapa tiba-tiba kembali,\Napa yang sudah Nona Ghislaine ajari?!
Dialogue: 0,0:03:47.21,0:03:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak kau ajari disiplin, ya!\N- Urus sendiri muridmu sana.
Dialogue: 0,0:03:50.35,0:03:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi!
Dialogue: 0,0:03:51.49,0:03:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:03:53.50,0:03:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya mata yang bagus.
Dialogue: 0,0:03:55.97,0:03:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang ingin kau tebas?
Dialogue: 0,0:03:58.30,0:03:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Naga.
Dialogue: 0,0:03:59.80,0:04:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Naga Orsted.
Dialogue: 0,0:04:02.43,0:04:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dewa Naga?!\N- Dewa Naga katanya?!
Dialogue: 0,0:04:03.83,0:04:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dari Tujuh Kekuatan Agung itu?!\N- Orsted itu apa?
Dialogue: 0,0:04:05.89,0:04:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Memang ada yang bisa melawannya?\N- Tidak banyak yang tahu nama Dewa Naga.
Dialogue: 0,0:04:09.90,0:04:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:04:11.27,0:04:14.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kalau dibanding Orsted,\Naku adalah keroco.
Dialogue: 0,0:04:14.65,0:04:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu, ya,\Njadi kau ingin menebas dia?
Dialogue: 0,0:04:18.70,0:04:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi selain diriku, ada lagi orang\Nyang ingin menebasnya.
Dialogue: 0,0:04:27.46,0:04:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mudah kalau cuma diucap di mulut.
Dialogue: 0,0:04:31.68,0:04:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kau bisa?
Dialogue: 0,0:04:33.17,0:04:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan!
Dialogue: 0,0:04:41.68,0:04:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, biar kulihat pedangmu.
Dialogue: 0,0:04:43.40,0:04:45.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jino, jadilah lawannya.
Dialogue: 0,0:04:45.58,0:04:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ba-baik!
Dialogue: 0,0:04:47.60,0:04:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia yang termuda di sini.
Dialogue: 0,0:04:49.84,0:04:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang masih payah, tapi sudah lumayan.
Dialogue: 0,0:04:58.82,0:05:00.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian maju ke tengah...
Dialogue: 0,0:05:17.20,0:05:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, masih payah, kan?
Dialogue: 0,0:05:19.90,0:05:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:05:22.49,0:05:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, selanjutnya kau, Nina.
Dialogue: 0,0:05:25.67,0:05:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:05:26.89,0:05:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini mulailah setelah saling berhadapan.
Dialogue: 0,0:05:29.27,0:05:30.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan kejutan itu boleh saja,
Dialogue: 0,0:05:30.77,0:05:33.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tunjukkan juga pedangmu\Nsaat diberi aba-aba.
Dialogue: 0,0:05:48.95,0:05:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh.
Dialogue: 0,0:05:51.74,0:05:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:06:16.71,0:06:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cu-Cukup!
Dialogue: 0,0:06:18.45,0:06:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:06:38.45,0:06:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini isinya orang payah semua, ya?!
Dialogue: 0,0:06:40.96,0:06:42.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berengsek!
Dialogue: 0,0:06:42.43,0:06:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mempermalukan kami, ha?!
Dialogue: 0,0:06:43.97,0:06:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tahu diri, dong!\N- Apanya yang teknik pedang itu?!
Dialogue: 0,0:06:45.77,0:06:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf, aku sedikit salah menilai.
Dialogue: 0,0:06:51.25,0:06:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang melawanmu.
Dialogue: 0,0:06:53.23,0:06:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru tidak perlu sampai maju.
Dialogue: 0,0:06:55.45,0:06:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar saya saja.
Dialogue: 0,0:07:02.28,0:07:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan panik dulu,\Naku tetap akan menahan diri.
Dialogue: 0,0:07:06.21,0:07:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, pedangmu bagus juga.
Dialogue: 0,0:07:08.80,0:07:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu buatan perajin terkenal Yulian, kan?
Dialogue: 0,0:07:11.10,0:07:12.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:07:12.29,0:07:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuterima dari suku Migurdia.
Dialogue: 0,0:07:14.52,0:07:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:07:22.66,0:07:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini juga buatan Yulian, lo.
Dialogue: 0,0:07:37.56,0:07:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku maju.
Dialogue: 0,0:07:59.08,0:08:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hebat sekali!
Dialogue: 0,0:08:00.35,0:08:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris!
Dialogue: 0,0:08:04.25,0:08:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris.
Dialogue: 0,0:08:17.79,0:08:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghislaine, obatilah Eris.
Dialogue: 0,0:08:22.40,0:08:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini dia Pedang Suci.
Dialogue: 0,0:08:24.78,0:08:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai besok aku yang akan\Nmengajarinya berpedang.
Dialogue: 0,0:08:27.37,0:08:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh, yang benar?\N- Orang seperti dia?
Dialogue: 0,0:08:29.85,0:08:31.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru!
Dialogue: 0,0:08:31.41,0:08:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedang Suci adalah titel khusus pada mereka\Nyang sudah menguasai Pedang Panjang Cahaya.
Dialogue: 0,0:08:36.28,0:08:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah tidak jelas asal-usulnya seperti dia...
Dialogue: 0,0:08:39.78,0:08:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah mengalahkan dua bocah\Nyang menguasai Pedang Panjang Cahaya.
Dialogue: 0,0:08:43.61,0:08:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu cukup?
Dialogue: 0,0:08:45.03,0:08:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi...
Dialogue: 0,0:08:46.27,0:08:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi Dewa Pedang itu bukan cuma\Ndengan menguasai sesuatu.
Dialogue: 0,0:08:51.55,0:08:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku yang spesial saja\Ntidak diperlakukan spesial.
Dialogue: 0,0:08:55.23,0:08:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sekadar Pedang Suci\Nharus diperlakukan spesial begitu?
Dialogue: 0,0:09:00.94,0:09:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mohon maaf.
Dialogue: 0,0:09:28.84,0:09:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa cuma begini?!
Dialogue: 0,0:09:42.17,0:09:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, hei, kau masih punya waktu\Nmemikirkan hal lain saat beradu begini?
Dialogue: 0,0:09:54.07,0:09:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayunkan pedang tanpa berpikir apa-apa.
Dialogue: 0,0:09:56.57,0:10:01.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayunkan pedang tanpa banyak pikir,\Nsaat lelah duduklah lalu baru dipikir.
Dialogue: 0,0:10:01.07,0:10:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah capek berpikir,\Nberdirilah dan ayunkan pedang lagi.
Dialogue: 0,0:10:11.18,0:10:14.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Ghislaine betulan bisa menulis?
Dialogue: 0,0:10:14.94,0:10:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya iya.
Dialogue: 0,0:10:16.38,0:10:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tidak ada yang bisa membacanya,\Njadi tidak bisa dibuktikan.
Dialogue: 0,0:10:19.64,0:10:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kukira itu bohong.
Dialogue: 0,0:10:22.05,0:10:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Ayah mengakui orang seperti dia?
Dialogue: 0,0:10:26.19,0:10:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu, daripada berpedang,\Nsepertinya lebih berbakat buat main pukul!
Dialogue: 0,0:10:30.94,0:10:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haha, benar juga.
Dialogue: 0,0:10:34.69,0:10:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jino juga bilang sesuatu, dong!
Dialogue: 0,0:10:36.85,0:10:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:39.61,0:10:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris tidak mau coba sekali-kali\Nikut latihan bersama kami?
Dialogue: 0,0:10:44.00,0:10:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?! Bilang apa kamu ini?!
Dialogue: 0,0:10:46.04,0:10:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang seperti dia\Njadi murid langsung Ayah, lo!
Dialogue: 0,0:10:49.29,0:10:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jino tidak sebal?!
Dialogue: 0,0:10:51.21,0:10:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku memang sudah kalah.
Dialogue: 0,0:10:53.74,0:10:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu kalah dengan cara\Nyang tidak pantas untuk Aliran Dewa Pedang?!
Dialogue: 0,0:10:57.16,0:10:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kalah kalau\Ndi pertandingan serius!
Dialogue: 0,0:10:59.61,0:11:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa iya?
Dialogue: 0,0:11:18.17,0:11:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengayun pedang ternyata sulit.
Dialogue: 0,0:11:28.86,0:11:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghislaine itu lebih cepat!
Dialogue: 0,0:11:30.92,0:11:33.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruijerd juga lebih cepat!
Dialogue: 0,0:11:33.45,0:11:35.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Pedang juga lebih cepat!
Dialogue: 0,0:11:35.98,0:11:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Orsted juga jauh lebih cepat lagi!
Dialogue: 0,0:11:40.74,0:11:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus lebih cepat lagi.
Dialogue: 0,0:11:57.95,0:12:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara gerak Dewa Pedang itu bagaimana?
Dialogue: 0,0:12:08.22,0:12:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujung jari.
Dialogue: 0,0:12:10.72,0:12:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pundak.
Dialogue: 0,0:12:16.60,0:12:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak berhasil, ya.
Dialogue: 0,0:12:39.79,0:12:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus.
Dialogue: 0,0:13:41.34,0:13:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih jauh, ya.
Dialogue: 0,0:13:56.03,0:13:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:13:57.69,0:14:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang, tidak?!
Dialogue: 0,0:14:00.07,0:14:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:14:03.07,0:14:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah ada orang.
Dialogue: 0,0:14:06.78,0:14:08.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku Kaisar Utara, Auber...
Dialogue: 0,0:14:08.66,0:14:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir.
Dialogue: 0,0:14:11.33,0:14:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia ini?
Dialogue: 0,0:14:13.34,0:14:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau menghalangi.
Dialogue: 0,0:14:15.66,0:14:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Auber si Pedang Merak.
Dialogue: 0,0:14:18.69,0:14:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dirimu murid Aliran Dewa Pedang.
Dialogue: 0,0:14:21.31,0:14:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong sampaikan pada Dewa Pedang...
Dialogue: 0,0:14:23.77,0:14:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang minggir.
Dialogue: 0,0:15:30.66,0:15:32.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup sampai situ.
Dialogue: 0,0:15:32.63,0:15:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, lama tidak berjumpa, Gusti Dewa Pedang.
Dialogue: 0,0:15:43.79,0:15:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau datang, Kaisar Utara.
Dialogue: 0,0:15:46.23,0:15:49.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku sudah membaca surat\Ndari Anda, Gusti Dewa Pedang.
Dialogue: 0,0:15:49.46,0:15:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu saat bertanya di dojo, ada anak itu.
Dialogue: 0,0:15:52.92,0:15:56.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya diriku melihat\Nahli pedang segarang ini.
Dialogue: 0,0:15:56.19,0:15:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah seperti binatang saja, ah...
Dialogue: 0,0:15:59.45,0:16:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi anak yang disebut Anjing Gila itu, ya?
Dialogue: 0,0:16:02.25,0:16:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:16:25.91,0:16:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Eris.
Dialogue: 0,0:16:49.95,0:16:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Guru tidak mengajari Eris apa pun?!
Dialogue: 0,0:16:53.16,0:16:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sudah kuajari?
Dialogue: 0,0:16:54.69,0:16:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara mengayun pedang?!
Dialogue: 0,0:16:56.75,0:16:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, tapi caranya berlatih.
Dialogue: 0,0:16:59.92,0:17:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah Guru selalu bilang,\Nlakukan segalanya secara logis?
Dialogue: 0,0:17:04.19,0:17:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:17:05.27,0:17:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, latihan buat Eris itu apa?!
Dialogue: 0,0:17:07.17,0:17:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengayun seperti orang bodoh\Nyang cuma tahu satu hal.
Dialogue: 0,0:17:10.20,0:17:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mananya yang logis?!
Dialogue: 0,0:17:11.84,0:17:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:17:12.64,0:17:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum bisa pakai Pedang Panjang Cahaya\Npadahal sudah beberapa tahun.
Dialogue: 0,0:17:16.06,0:17:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Guru tidak mengajarinya?
Dialogue: 0,0:17:18.43,0:17:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini sejak kapan jadi bisa\Nbilang sesuatu yang bikin repot begitu?
Dialogue: 0,0:17:23.06,0:17:25.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak sebelum kembali ke sini!
Dialogue: 0,0:17:27.90,0:17:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu sudah tidak akan\Nmendengar kata gurumu lagi, ya?
Dialogue: 0,0:17:31.99,0:17:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...!
Dialogue: 0,0:17:33.82,0:17:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghislaine, aku ini sedikit menyesal\Ndalam mendidikmu.
Dialogue: 0,0:17:40.37,0:17:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghislaine yang dulu seperti harimau\Nkelaparan, sekarang jadi anak kucing ompong.
Dialogue: 0,0:17:46.59,0:17:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tetap seperti dulu,\Nsekarang kau pasti sudah jadi Kaisar Pedang.
Dialogue: 0,0:17:56.45,0:17:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak akan melepas taringku lagi.
Dialogue: 0,0:18:01.02,0:18:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham.
Dialogue: 0,0:18:02.65,0:18:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dia tidak dididik?
Dialogue: 0,0:18:04.73,0:18:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kasihan Eris kalau begitu?!
Dialogue: 0,0:18:09.22,0:18:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Ghislaine.
Dialogue: 0,0:18:10.79,0:18:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin melampauiku,
Dialogue: 0,0:18:12.32,0:18:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}asal dicekoki logika\Nkelak juga bisa dilampaui.
Dialogue: 0,0:18:15.49,0:18:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang ingin dia capai\Nadalah Dewa Naga Orsted.
Dialogue: 0,0:18:20.45,0:18:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu berada di luar logika.
Dialogue: 0,0:18:24.37,0:18:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan bisa menang melawannya\Nkalau hanya dengan ajaranku.
Dialogue: 0,0:18:33.00,0:18:37.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, Ghislaine,\Nberlatih itu bukan cuma dididik.
Dialogue: 0,0:18:37.17,0:18:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi kalau punya tujuan,
Dialogue: 0,0:18:38.93,0:18:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma mengangguk mendengar kata orang\Nitu tidak ada artinya, kan?
Dialogue: 0,0:18:43.05,0:18:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru selalu saja mengatakan hal rumit.
Dialogue: 0,0:18:46.17,0:18:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mana paham.
Dialogue: 0,0:18:49.07,0:18:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, intinya tidak akan cukup\Nkalau cuma kuajari.
Dialogue: 0,0:18:54.57,0:18:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan dia sebagai awalannya.
Dialogue: 0,0:18:56.95,0:19:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Auber Corvette si Kaisar Utara.
Dialogue: 0,0:19:00.48,0:19:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang sekitar memanggilku Pedang Merak.
Dialogue: 0,0:19:04.14,0:19:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aliran Dewa Utara punya urusan apa?
Dialogue: 0,0:19:06.12,0:19:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku diminta Sang Dewa Pedang\Nuntuk mendidik seorang muridnya.
Dialogue: 0,0:19:12.12,0:19:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus Aliran Dewa Utara?
Dialogue: 0,0:19:13.97,0:19:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eris seharusnya tidak cocok\Ndengan trik licik seperti mereka.
Dialogue: 0,0:19:17.91,0:19:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Dewa Naga menggunakannya.
Dialogue: 0,0:19:21.67,0:19:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Naga itu sebenarnya seperti apa?
Dialogue: 0,0:19:24.25,0:19:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana kutahu.
Dialogue: 0,0:19:25.88,0:19:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, baik itu Aliran Dewa Pedang\Natau Aliran Dewa Utara,
Dialogue: 0,0:19:30.39,0:19:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menguasai semua aliran\Nstandar seperti itu.
Dialogue: 0,0:19:34.62,0:19:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipakai, tentu bisa dia atasi,\Ndan dia juga bisa menggunakannya.
Dialogue: 0,0:19:38.85,0:19:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu, kalau kita tidak menguasainya juga,\Ntidak akan sebanding melawan dia.
Dialogue: 0,0:19:43.45,0:19:44.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:19:44.97,0:19:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, nanti juga akan\Nmemanggil Aliran Dewa Air?
Dialogue: 0,0:19:48.01,0:19:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sudah kukirimi surat.
Dialogue: 0,0:19:50.71,0:19:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:54.77,0:19:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Tuan Kaisar Utara,\Nsilakan nikmati waktu Anda di sini.
Dialogue: 0,0:19:58.71,0:20:00.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Nona Ratu Pedang.
Dialogue: 0,0:20:00.74,0:20:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku akan merepotkan kalian.
Dialogue: 0,0:20:05.93,0:20:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambutan garang yang kemarin,\Nbenar-benar mengguncang hatiku.
Dialogue: 0,0:20:10.69,0:20:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan diriku memastikan sekali lagi\Nkemampuan dari Anjing Gila.
Dialogue: 0,0:20:17.89,0:20:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai!
Dialogue: 0,0:20:45.03,0:20:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih kuat lagi,\Naku harus jadi lebih kuat lagi.
Dialogue: 0,0:20:48.67,0:20:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai dianggap bisa bersanding\Ndengan Rudeus.
Dialogue: 0,0:20:51.90,0:20:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus?
Dialogue: 0,0:20:53.90,0:20:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ahli pedangnya,\Ndan Rudeus yang jadi penyihirnya.
Dialogue: 0,0:21:01.27,0:21:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rudeus itu...
Dialogue: 0,0:21:06.70,0:21:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat hebat!
Dialogue: 0,0:21:29.23,0:21:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu tadi?!
Dialogue: 0,0:21:31.09,0:21:32.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang Pedang Panjang Cahaya!
Dialogue: 0,0:21:32.85,0:21:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecepatan, serta dayanya sangat sempurna.
Dialogue: 0,0:21:36.36,0:21:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:21:44.91,0:21:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, sungguh sebuah serangan\Nyang memukau.
Dialogue: 0,0:21:49.62,0:21:53.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah minta tanding sekali lagi?
Dialogue: 0,0:21:55.70,0:21:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
