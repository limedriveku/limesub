Dialogue: 0,0:22:01.92,0:22:04.93,5-normal,,0,0,0,,{\pos(960,759)\fs100\b1\bord0\3c&H181D2F&\4c&H181D2F&\c&HFFFFFF&}Penyihir Tingkat Raja Air
Dialogue: 0,0:23:34.93,0:23:39.94,5-normal,,0,0,0,,{\bord0\fs65\b0\pos(960,338)\c&H000A49&}Selanjutnya
Dialogue: 0,0:23:34.93,0:23:39.94,5-normal,,0,0,0,,{\fad(1500,0)\bord0\fs100\b1\c&H000A49&\pos(960,652)}Perayaan
Dialogue: 0,0:00:06.99,0:00:10.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa juga yang menyangka\Nkau bisa mati begini.
Dialogue: 0,0:00:10.74,0:00:13.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang saja masih sulit dipercaya.
Dialogue: 0,0:00:13.33,0:00:16.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia pasti bahagia bisa mati\Nmelindungi putranya.
Dialogue: 0,0:00:16.85,0:00:18.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Enggak salah lagi.
Dialogue: 0,0:00:18.21,0:00:21.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, Zenith malah jadi seperti itu.
Dialogue: 0,0:00:21.71,0:00:23.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lebih mending daripada mati, kan?
Dialogue: 0,0:00:23.65,0:00:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:24.52,0:00:28.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Zenith pasti juga bahagia\Nbisa dikelilingi keluarganya.
Dialogue: 0,0:00:28.39,0:00:31.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Toh ada putranya yang bisa diandalkan.
Dialogue: 0,0:00:31.91,0:00:33.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baru juga dibahas.
Dialogue: 0,0:00:33.58,0:00:35.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yo, kalian berdua!
Dialogue: 0,0:00:35.32,0:00:37.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selamat pagi, semuanya.
Dialogue: 0,0:00:39.43,0:00:41.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan berangkat hari ini, ya.
Dialogue: 0,0:00:41.50,0:00:44.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa coba, Senior kesepian, ya?
Dialogue: 0,0:00:44.02,0:00:46.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:00:46.22,0:00:50.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rumah Senior juga kelihatan mulai tenang,\Njadi ini saatnya berpisah.
Dialogue: 0,0:00:50.74,0:00:54.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah agak terlalu lama kalau sekadar\Nberkabung untuk dia.
Dialogue: 0,0:00:54.94,0:00:58.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Vierra dan Shierra juga sudah\Npergi dari lama.
Dialogue: 0,0:00:58.08,0:01:01.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti tidak akan hadir di upacaraku.
Dialogue: 0,0:01:01.31,0:01:04.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buat apa juga ke upacara elf binal.
Dialogue: 0,0:01:04.01,0:01:05.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa katamu?!
Dialogue: 0,0:01:05.23,0:01:06.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ha?!
Dialogue: 0,0:01:06.17,0:01:10.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian berdua, berhenti berkelahi\Ndi saat seperti ini.
Dialogue: 0,0:01:10.47,0:01:12.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetap saja tidak berubah.
Dialogue: 0,0:01:12.52,0:01:14.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh iya, Senior.
Dialogue: 0,0:01:14.47,0:01:16.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hampir saja kelupaan.
Dialogue: 0,0:01:18.39,0:01:19.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini?!
Dialogue: 0,0:01:19.89,0:01:23.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Harta dari Labirin Teleportasi,\Nitu jatah untuk Senior.
Dialogue: 0,0:01:23.31,0:01:24.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terlalu banyak!
Dialogue: 0,0:01:26.61,0:01:28.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada jatah Paul juga.
Dialogue: 0,0:01:29.82,0:01:33.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Juga, sedikit hadiah dari kami.
Dialogue: 0,0:01:33.66,0:01:34.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Geese.
Dialogue: 0,0:01:34.99,0:01:37.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Alah, panggil "Anak Baru" saja.
Dialogue: 0,0:01:37.85,0:01:41.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasti banyak kebutuhan\Nsetelah keluargamu bertambah, kan?
Dialogue: 0,0:01:41.29,0:01:43.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan sungkan, terima saja.
Dialogue: 0,0:01:44.29,0:01:46.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jagalah baik-baik keluargamu.
Dialogue: 0,0:01:48.02,0:01:48.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:02:30.79,0:02:33.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pak Greyrat, terima kasih untuk tempo hari.
Dialogue: 0,0:02:33.99,0:02:36.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong sampaikan salam ke Dik Aisha.
Dialogue: 0,0:02:36.57,0:02:38.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik, akan saya sampaikan.
Dialogue: 0,0:03:10.09,0:03:15.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mushoku Tensei:\NJobless Reincarnation Season 3
Dialogue: 0,0:03:19.29,0:03:20.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, Kakak!
Dialogue: 0,0:03:20.89,0:03:22.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:03:22.15,0:03:23.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:03:23.18,0:03:24.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sylphy sudah berangkat?
Dialogue: 0,0:03:24.99,0:03:28.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Langsung berangkat kerja\Ntepat setelah Kakak pergi.
Dialogue: 0,0:03:28.00,0:03:29.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:03:29.36,0:03:33.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, sekarang ini\Naku tidak punya penghasilan.
Dialogue: 0,0:03:33.79,0:03:37.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana ceritanya istri kerja,\Ntapi suami pengangguran?
Dialogue: 0,0:03:39.21,0:03:41.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aisha, sejak kapan Ibu bisa melakukan itu?
Dialogue: 0,0:03:41.70,0:03:42.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:03:43.35,0:03:45.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, sudah lumayan lama.
Dialogue: 0,0:03:45.58,0:03:47.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Awalnya Ibu melarang.
Dialogue: 0,0:03:47.84,0:03:50.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, Nyonya tetap membantu\Nsaat aku mengurus halaman.
Dialogue: 0,0:03:50.67,0:03:53.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nyonya Zenith lebih hebat dari aku, lo.
Dialogue: 0,0:03:54.88,0:03:57.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Roxy, kenapa malah bikin berantakan?!
Dialogue: 0,0:03:57.80,0:04:02.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Zenith sangat menyayangi tumbuhan\Ndi halaman rumah kami di Desa Buena.
Dialogue: 0,0:04:02.29,0:04:05.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa itu berhubungan dengan tindakannya ini?
Dialogue: 0,0:04:06.20,0:04:11.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau bisa memicu agar ingatannya kembali,\Nrasanya tidak perlu kuhentikan.
Dialogue: 0,0:04:12.92,0:04:14.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, Aisha...
Dialogue: 0,0:04:15.26,0:04:18.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu juga boleh memanggil\Ndengan sebutan "Ibu", kok.
Dialogue: 0,0:04:18.61,0:04:23.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, Ibu menyuruhku\Nmemanggil dengan "Nyonya Zenith".
Dialogue: 0,0:04:23.57,0:04:25.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lilia yang bilang?
Dialogue: 0,0:04:25.13,0:04:26.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ketat sekali ajarannya.
Dialogue: 0,0:04:27.08,0:04:28.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:04:28.57,0:04:32.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nama panggilan itu\Nhal sepele untuk keluarga.
Dialogue: 0,0:04:32.25,0:04:36.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu, kalau dilihat begini,\Nmereka seperti ibu dan anak.
Dialogue: 0,0:04:37.02,0:04:40.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, hari ini Kakak libur, kan?
Dialogue: 0,0:04:40.25,0:04:40.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:40.97,0:04:42.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:04:42.43,0:04:44.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti ke kamarku, ya!
Dialogue: 0,0:04:46.18,0:04:50.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lucy sayang, ini Papa, lo...
Dialogue: 0,0:04:55.95,0:04:58.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sulit sekali dia dibuat tertawa.
Dialogue: 0,0:04:58.53,0:05:01.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi teringat Tuan Rudeus saat kecil.
Dialogue: 0,0:05:02.59,0:05:04.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuanku juga sering melakukan itu.
Dialogue: 0,0:05:04.89,0:05:08.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuanku kesulitan membuat Tuan Rudeus tertawa.
Dialogue: 0,0:05:08.80,0:05:10.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:10.09,0:05:12.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu memang pernah begitu, ya.
Dialogue: 0,0:05:19.09,0:05:20.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu apa, ya?
Dialogue: 0,0:05:20.79,0:05:23.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar kuperiksa dulu.
Dialogue: 0,0:05:34.86,0:05:37.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di kamar Aisha juga tidak ada yang aneh.
Dialogue: 0,0:05:38.74,0:05:39.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa itu?!
Dialogue: 0,0:05:57.25,0:05:58.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Treant?
Dialogue: 0,0:06:02.42,0:06:04.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa selama ini kamu diam saja?
Dialogue: 0,0:06:04.55,0:06:06.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah mau bilang!
Dialogue: 0,0:06:06.56,0:06:09.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, Kakak kelihatan sibuk sekali,\Njadi kupikir nanti saja.
Dialogue: 0,0:06:09.97,0:06:13.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terus malah Kakak temukan duluan!
Dialogue: 0,0:06:14.19,0:06:17.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Treant adalah monster\Npaling umum di dunia ini.
Dialogue: 0,0:06:17.78,0:06:22.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau mau diumpamakan, makhluk ini\Nsudah seperti slime di gim RPG pasaran.
Dialogue: 0,0:06:22.06,0:06:23.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetapi...
Dialogue: 0,0:06:23.07,0:06:25.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejak awal dia sudah bisa bergerak?
Dialogue: 0,0:06:25.84,0:06:28.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Enggak, awalnya dia tidak gerak.
Dialogue: 0,0:06:28.49,0:06:32.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berarti, ada sesuatu yang\Nmengubahnya jadi monster.
Dialogue: 0,0:06:32.60,0:06:34.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa ada hal aneh yang kamu lakukan?
Dialogue: 0,0:06:34.76,0:06:38.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hm, padahal rasanya tidak ada.
Dialogue: 0,0:06:39.23,0:06:40.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, tapi...
Dialogue: 0,0:06:40.78,0:06:44.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa karena terkadang kuberi\Nair panas bekas pemandian?
Dialogue: 0,0:06:44.88,0:06:48.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Air bekas mandi yang sudah larut\Ndengan keringat Sylphy dan Aisha?!
Dialogue: 0,0:06:48.05,0:06:52.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya?!\NPantas saja tumbuh sulur yang tidak senonoh!
Dialogue: 0,0:06:52.31,0:06:54.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin itu!
Dialogue: 0,0:06:55.76,0:07:00.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa pun penyebabnya, kurasa lebih baik\Ndisingkirkan dengan dibakar atau semacamnya.
Dialogue: 0,0:07:00.05,0:07:02.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, padahal sudah kurawat begini?!
Dialogue: 0,0:07:02.19,0:07:04.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak harus dibakar juga, kan?!
Dialogue: 0,0:07:04.51,0:07:07.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aisha, dia ini Treant.\NSeekor monster.
Dialogue: 0,0:07:07.87,0:07:10.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, dia sekecil dan semanis ini, lo!
Dialogue: 0,0:07:10.44,0:07:13.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa saja dia menyerang orang\Nkalau sudah besar, jadi bahaya.
Dialogue: 0,0:07:13.53,0:07:16.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti kuajari biar tidak menyerang orang!
Dialogue: 0,0:07:17.88,0:07:20.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayolah, Kak.\NBoleh kupelihara, ya.
Dialogue: 0,0:07:20.85,0:07:22.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berlagak imut pun, pokoknya tidak.
Dialogue: 0,0:07:22.37,0:07:25.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, dia tidak berbuat nakal\Nsama sekali, lo.
Dialogue: 0,0:07:25.05,0:07:27.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau mendengar perintahku juga, kok.
Dialogue: 0,0:07:27.43,0:07:28.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Coba lihat!
Dialogue: 0,0:07:29.16,0:07:30.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tangan.
Dialogue: 0,0:07:31.43,0:07:32.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuh, kan!
Dialogue: 0,0:07:34.97,0:07:37.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetap enggak boleh?
Dialogue: 0,0:07:41.24,0:07:42.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tetap tidak!
Dialogue: 0,0:07:43.22,0:07:44.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:07:44.35,0:07:48.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tetap tidak boleh,\Naku juga punya caraku sendiri.
Dialogue: 0,0:07:48.53,0:07:52.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kuberi tahu soal "itu"\Nke Kak Sylphy dan Kak Roxy.
Dialogue: 0,0:07:52.05,0:07:53.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal "itu"?
Dialogue: 0,0:07:53.42,0:07:55.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Soal kamar tersembunyi di rubanah!
Dialogue: 0,0:07:56.41,0:07:58.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:07:58.25,0:08:01.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan bilang maksudnya kamar tersembunyi,\Nitu soal altarku?!
Dialogue: 0,0:08:02.16,0:08:04.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}A-Aisha, aku seperti ini demi dirimu...
Dialogue: 0,0:08:04.99,0:08:08.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah tidak terganggu\Nmau seberapa cabul Kakak.
Dialogue: 0,0:08:08.45,0:08:11.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, kira-kira bagaimana dengan\NKak Sylphy dan Kak Roxy?
Dialogue: 0,0:08:11.64,0:08:16.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terutama Kak Roxy, kira-kira akan bagaimana\Nkalau tahu celana dalam lamanya
Dialogue: 0,0:08:16.18,0:08:18.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}dipajang seperti itu?
Dialogue: 0,0:08:19.94,0:08:21.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengerikan sekali dia!
Dialogue: 0,0:08:21.83,0:08:24.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berbalik mengancam saat orang\Nmerasa sudah tenang!
Dialogue: 0,0:08:24.94,0:08:26.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, sial!
Dialogue: 0,0:08:26.13,0:08:28.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana ini?!\NSebaiknya harus bagaimana?!
Dialogue: 0,0:08:28.45,0:08:30.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wahai Dewiku!
Dialogue: 0,0:08:30.49,0:08:31.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:08:31.92,0:08:34.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku dengar namaku disebut-sebut.
Dialogue: 0,0:08:34.20,0:08:37.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ke-Kenapa Roxy bisa di sini?!\NSekolah bagaimana?!
Dialogue: 0,0:08:37.50,0:08:39.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada yang ketinggalan.
Dialogue: 0,0:08:41.01,0:08:44.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini, Kak Roxy, Kakak menyimpan ce...
Dialogue: 0,0:08:55.48,0:08:56.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini Treant, ya.
Dialogue: 0,0:08:56.82,0:08:58.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nah, iya, Roxy!
Dialogue: 0,0:08:58.90,0:09:01.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aisha bilang ingin merawatnya...
Dialogue: 0,0:09:01.69,0:09:03.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ini monster, kan?\NJadi, bahaya.
Dialogue: 0,0:09:03.82,0:09:06.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa tidak Roxy ikut beri tahu\Nkalau tidak boleh?
Dialogue: 0,0:09:07.73,0:09:09.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah tidak masalah?
Dialogue: 0,0:09:10.40,0:09:14.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dirawat dengan baik,\NTreant bisa jinak dengan manusia.
Dialogue: 0,0:09:14.03,0:09:16.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sebesar ini rasanya\Ntidak akan berbahaya.
Dialogue: 0,0:09:16.70,0:09:19.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:09:19.01,0:09:19.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:19.75,0:09:23.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Suku Migurdia sering membiakkannya\Nsebagai pengusir hama kebun.
Dialogue: 0,0:09:24.11,0:09:26.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh iya, seingatku memang ada.
Dialogue: 0,0:09:29.86,0:09:31.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aisha.
Dialogue: 0,0:09:31.22,0:09:33.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kakak yang salah.
Dialogue: 0,0:09:33.67,0:09:38.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, Kakak sudah memikirkanku, ya.
Dialogue: 0,0:09:38.49,0:09:40.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, jelas itu.
Dialogue: 0,0:09:42.21,0:09:45.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan diam soal "itu".
Dialogue: 0,0:09:47.15,0:09:49.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku cinta sama Kak Roxy!
Dialogue: 0,0:09:52.77,0:09:54.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:09:55.55,0:09:59.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan ini, bertambahlah sebuah Treant\Nsebagai peliharaan di rumahku.
Dialogue: 0,0:10:00.12,0:10:01.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namanya Beat.
Dialogue: 0,0:10:02.05,0:10:04.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak kusangka dia menemukan altar itu,
Dialogue: 0,0:10:04.83,0:10:07.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}pelayan memang tidak bisa dianggap remeh.
Dialogue: 0,0:10:09.67,0:10:13.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan hanya sihir biasa, tapi bisa\Nmembatalkan sihir penghalang juga, ya.
Dialogue: 0,0:10:14.22,0:10:16.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pantas saja disebut batu sihir ajaib.
Dialogue: 0,0:10:16.78,0:10:19.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, ayo kita pelajari lebih detail lagi.
Dialogue: 0,0:10:19.71,0:10:20.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:21.60,0:10:27.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisik hydra yang tempo hari diberikan Geese,\Nnama resminya adalah Batu Penyerap Sihir.
Dialogue: 0,0:10:28.13,0:10:30.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hasil percobaan menunjukkan kalau
Dialogue: 0,0:10:30.82,0:10:36.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}punya efek menguraikan dalam sekejap\Nsegala sesuatu yang dibuat dari daya sihir.
Dialogue: 0,0:10:36.57,0:10:39.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar kemampuan dan musuh\Nyang sulit dilawan.
Dialogue: 0,0:10:43.96,0:10:46.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Segini saja untuk hari ini.
Dialogue: 0,0:10:46.22,0:10:48.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa tidak diteruskan lagi sebentar?
Dialogue: 0,0:10:48.13,0:10:49.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sebenarnya tidak masalah.
Dialogue: 0,0:10:49.72,0:10:51.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, apa harus buru-buru begitu?
Dialogue: 0,0:10:51.87,0:10:56.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bu-Bukan begitu juga sebenarnya, tapi...
Dialogue: 0,0:10:56.66,0:11:01.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa jadi kelak akan ada lagi\Nbahaya yang mengancam keluargaku.
Dialogue: 0,0:11:01.19,0:11:06.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk itu, aku merasa harus\Nmelakukan segala sesuatu yang ada.
Dialogue: 0,0:11:06.17,0:11:09.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah tidak ingin\Nkehilangan siapa pun lagi.
Dialogue: 0,0:11:10.13,0:11:11.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rudeus...
Dialogue: 0,0:11:12.52,0:11:15.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Guru, maaf terlambat.
Dialogue: 0,0:11:15.18,0:11:18.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Zanoba Shirone telah tiba.
Dialogue: 0,0:11:18.36,0:11:19.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Telah tiba!
Dialogue: 0,0:11:19.41,0:11:21.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu lama sekali!
Dialogue: 0,0:11:21.38,0:11:24.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kubilang hari ini\Nmau menguji Batu Penyerap Sihir.
Dialogue: 0,0:11:24.49,0:11:29.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, tanpa sadar aku terlalu fokus\Npada penelitian sampai lupa waktu.
Dialogue: 0,0:11:29.33,0:11:31.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meneliti patung automaton yang itu?
Dialogue: 0,0:11:31.89,0:11:33.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana hasilnya?
Dialogue: 0,0:11:33.17,0:11:34.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu dia!
Dialogue: 0,0:11:34.84,0:11:39.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat membongkar bagian dalam patung itu,\Nkutemukan batu sihir besar di tengahnya!
Dialogue: 0,0:11:40.24,0:11:43.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Besar, aku berhasil membuat ini.
Dialogue: 0,0:11:43.05,0:11:44.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:11:44.43,0:11:46.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, setelah diamati, ternyata tersusun\Ndari beberapa batu sihir kecil,
Dialogue: 0,0:11:46.35,0:11:48.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}yang permukaannya diukir lingkaran sihir!
Dialogue: 0,0:11:48.96,0:11:52.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini penemuan besar yang bisa\Nmematahkan logika saat ini!
Dialogue: 0,0:11:52.77,0:11:55.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana hasil latihan Julie ini?!
Dialogue: 0,0:11:55.78,0:11:57.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin penilaianku bias,
Dialogue: 0,0:11:57.65,0:12:01.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi kurasa hasilnya tidak kalah\Ndari buatan Guru!
Dialogue: 0,0:12:01.14,0:12:02.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, hasilnya bagus.
Dialogue: 0,0:12:02.77,0:12:04.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata Guru pun menilai begitu!
Dialogue: 0,0:12:04.95,0:12:06.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuanku!
Dialogue: 0,0:12:06.78,0:12:08.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Syukur banget, ya, Julie.
Dialogue: 0,0:12:08.38,0:12:11.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Latihanmu sedikit demi sedikit\Ntiap hari tidak sia-sia.
Dialogue: 0,0:12:11.58,0:12:13.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Apa hasilnya sebagus itu?\N- Benar.
Dialogue: 0,0:12:13.33,0:12:15.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu buru-buru.
Dialogue: 0,0:12:15.20,0:12:19.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lakukan saja secara perlahan, satu per satu,\Napa yang ada di depan mata.
Dialogue: 0,0:12:19.84,0:12:21.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersama semuanya.
Dialogue: 0,0:12:22.17,0:12:24.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo makan malam di rumahku habis ini.
Dialogue: 0,0:12:24.31,0:12:26.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah, apa tidak masalah?!
Dialogue: 0,0:12:26.88,0:12:30.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, aku juga ingin mengenalkan Lucy\Nke kalian semua.
Dialogue: 0,0:12:30.03,0:12:33.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu ceritanya,\Nizinkan aku menerima tawaran itu.
Dialogue: 0,0:12:33.58,0:12:36.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak, Tuan Besar.
Dialogue: 0,0:12:36.32,0:12:39.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Julie, jangan sampai bikin masalah, ya.
Dialogue: 0,0:12:39.20,0:12:40.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik, Tuanku.
Dialogue: 0,0:12:41.37,0:12:43.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Penelitiannya bagaimana?
Dialogue: 0,0:12:43.00,0:12:45.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, untuk hari ini tidak apa-apa.
Dialogue: 0,0:12:45.76,0:12:49.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boleh tidak besok aku minta tolong\Nuntuk dibantu lagi?
Dialogue: 0,0:12:50.59,0:12:52.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boleh, serahkan padaku.
Dialogue: 0,0:12:54.61,0:12:56.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:12:58.13,0:13:01.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oke, penelitian batu sihir
Dialogue: 0,0:13:01.09,0:13:04.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan rencana memulihkan\Nnama baik suku Superdia sudah berjalan.
Dialogue: 0,0:13:05.56,0:13:08.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hubungan dengan keluarga juga harmonis.
Dialogue: 0,0:13:08.56,0:13:10.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya berjalan lancar.
Dialogue: 0,0:13:14.08,0:13:15.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sisanya...
Dialogue: 0,0:13:15.68,0:13:19.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin sudah saatnya untuk lanjut\Nke tahap selanjutnya.
Dialogue: 0,0:13:22.70,0:13:26.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tidak masalah, kan?! Kumohon!\N- Tidak bisa!
Dialogue: 0,0:13:26.16,0:13:28.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekali saja!\NSekali saja tidak apa-apa!
Dialogue: 0,0:13:28.73,0:13:29.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:13:29.41,0:13:33.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong dipikirkan baik-baik!\NIni tidak buruk untuk kita berdua!
Dialogue: 0,0:13:33.77,0:13:36.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang mungkin memang kurang enak.
Dialogue: 0,0:13:36.96,0:13:41.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, kalau dilihat jangka panjang,\Npasti akan jadi nilai plus untuk kita.
Dialogue: 0,0:13:41.43,0:13:43.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tidak masalah, kan?! Tolong diusahakan...\N- Tetapi...
Dialogue: 0,0:13:43.90,0:13:44.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami dari OSIS!
Dialogue: 0,0:13:44.93,0:13:46.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Wah, ada Tuan Luke!\N- Itu Fitz si Hening!
Dialogue: 0,0:13:46.58,0:13:49.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Kak Fitz belakangan ini makin manis, ya?\N- Tuan Luke hari ini keren sekali!
Dialogue: 0,0:13:49.39,0:13:54.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami dapat laporan kalau Rudeus\Nmenyerang seorang siswi.
Dialogue: 0,0:13:57.82,0:14:00.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Fitz, sisanya kuserahkan padamu.
Dialogue: 0,0:14:00.27,0:14:01.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:01.66,0:14:04.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bubar!\NBubar semuanya!
Dialogue: 0,0:14:06.70,0:14:09.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, dianggap seorang siswi, ya...
Dialogue: 0,0:14:09.57,0:14:11.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:14:11.22,0:14:14.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelihatannya masih sedikit yang sadar\Nkalau Roxy adalah pengajar.
Dialogue: 0,0:14:14.93,0:14:19.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begini, Rudy, meski sudah menikah,\Nmain paksa itu tidak baik, lo.
Dialogue: 0,0:14:19.59,0:14:22.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada kalanya gadis tidak mau berbuat.
Dialogue: 0,0:14:22.39,0:14:25.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, iya, tentu saja aku tahu.
Dialogue: 0,0:14:26.11,0:14:29.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Roxy mungkin memang lebih mahir.
Dialogue: 0,0:14:29.69,0:14:31.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ada aku juga, lo.
Dialogue: 0,0:14:34.58,0:14:36.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:14:40.15,0:14:43.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh, Sylphy sedang cemburu, ya?!
Dialogue: 0,0:14:43.62,0:14:45.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ti-Tidak sampai cemburu juga...
Dialogue: 0,0:14:45.89,0:14:47.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan khawatir, Sylphy.
Dialogue: 0,0:14:47.71,0:14:51.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentunya aku tidak bermaksud\Nuntuk tidak mengajakmu, Sylphy.
Dialogue: 0,0:14:51.23,0:14:54.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, yang benar?!\NBerarti mau bertiga?!
Dialogue: 0,0:14:54.53,0:14:59.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja!\NAyo kita berdua minta diajari Roxy.
Dialogue: 0,0:14:59.18,0:15:00.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:00.25,0:15:02.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku masih belum bilang setuju!
Dialogue: 0,0:15:02.67,0:15:04.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak usah bilang begitu.
Dialogue: 0,0:15:04.67,0:15:06.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sylphy juga ingin belajar, kan?
Dialogue: 0,0:15:07.11,0:15:11.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, maaf, Rudy.\NKalian sedang bahas apa memangnya?
Dialogue: 0,0:15:11.60,0:15:16.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sedang minta untuk diajari\Nsihir tingkat Raja Air oleh Roxy.
Dialogue: 0,0:15:21.15,0:15:23.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Matsukaze memang kuda yang baik, ya.
Dialogue: 0,0:15:23.49,0:15:27.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurut sama perintah, tidak nakal,\Nkekuatannya juga mumpuni.
Dialogue: 0,0:15:27.75,0:15:31.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, benar.\NJarang ada kuda sebagus ini.
Dialogue: 0,0:15:31.58,0:15:33.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sylphy tahu banyak soal kuda?
Dialogue: 0,0:15:33.91,0:15:36.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, tidak juga, kok.
Dialogue: 0,0:15:36.85,0:15:41.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, aku beberapa kali lihat kuda yang\Ndisebut kelas tertinggi di Istana Asura.
Dialogue: 0,0:15:41.97,0:15:44.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang ditunggangi\Nkapten ordo kesatria misalnya.
Dialogue: 0,0:15:44.20,0:15:46.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pasti sangat gagah.
Dialogue: 0,0:15:47.47,0:15:51.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, maaf, kamu juga gagah, kok.
Dialogue: 0,0:15:51.14,0:15:53.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apalagi kudanya keluarga Greyrat.
Dialogue: 0,0:15:55.02,0:15:57.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Master masih ingat dengan Carabacchio?
Dialogue: 0,0:15:57.92,0:16:01.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masih, kudanya Paul, kan?\NItu sudah lama sekali.
Dialogue: 0,0:16:01.55,0:16:04.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat itu kita juga menunggang kuda\Nseperti ini, ya.
Dialogue: 0,0:16:04.19,0:16:06.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, kalian bahas apa?
Dialogue: 0,0:16:06.25,0:16:09.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cerita saat aku masih jadi guru privat Rudy.
Dialogue: 0,0:16:09.68,0:16:13.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak salah saat itu\Nmasih belum bertemu Sylphy.
Dialogue: 0,0:16:13.39,0:16:15.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oalah.
Dialogue: 0,0:16:15.33,0:16:19.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong, suasana sekitar sini\Nagak mirip sama Desa Buena.
Dialogue: 0,0:16:20.11,0:16:21.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dipikir benar juga.
Dialogue: 0,0:16:21.75,0:16:23.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya iya.
Dialogue: 0,0:16:35.17,0:16:37.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah cukup lama\Nwaktu berlalu sejak saat itu.
Dialogue: 0,0:16:45.75,0:16:49.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena kuputuskan untuk mengajari,\Njadi akan kuajari dengan serius.
Dialogue: 0,0:16:49.42,0:16:50.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu sudah siap?
Dialogue: 0,0:16:51.23,0:16:52.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:52.01,0:16:53.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak masalah.
Dialogue: 0,0:16:54.87,0:16:59.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan menembakkan Lightning,\Nsihir tingkat Raja Air ke pohon itu.
Dialogue: 0,0:16:59.86,0:17:01.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihatlah baik-baik.
Dialogue: 0,0:17:01.51,0:17:02.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Baik!
Dialogue: 0,0:17:09.29,0:17:11.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kumulai sekarang.
Dialogue: 0,0:17:12.64,0:17:17.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wahai roh tirta nan agung,\Npangeran guntur penguasa dirga.
Dialogue: 0,0:17:17.69,0:17:21.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabulkan pinta hamba,\Nturunkan karunia anggara.
Dialogue: 0,0:17:21.63,0:17:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perlihatkan kuasamu kepada kami para jelata!
Dialogue: 0,0:17:25.97,0:17:29.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunjukkan daulat agung\Ndengan halilintar martil batara.
Dialogue: 0,0:17:29.15,0:17:31.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Banjiri bumi dengan tirta!
Dialogue: 0,0:17:32.94,0:17:38.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Wahai hujan, basuh semesta dan hancurkan segalanya!\N- Lo, bukankah ini Cumulonimbus?
Dialogue: 0,0:17:39.16,0:17:44.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wahai roh cahaya nan agung,\Nkaisar guntur penguasa dirga!
Dialogue: 0,0:17:45.13,0:17:46.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, bukan.
Dialogue: 0,0:17:46.50,0:17:48.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dapatkah engkau lihat yang menjulang murka?
Dialogue: 0,0:17:48.51,0:17:50.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dialah ahli jemawa, musuh Paduka!
Dialogue: 0,0:17:51.39,0:17:56.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hambalah yang akan mengalahkannya\Ndalam satu terjangan pedang dewata!
Dialogue: 0,0:17:56.31,0:18:00.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan kuasa sinar kirana,\Ntunjukkan wibawa sang adiraja!
Dialogue: 0,0:18:00.77,0:18:02.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lightning!
Dialogue: 0,0:18:14.91,0:18:16.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Awas.
Dialogue: 0,0:18:16.07,0:18:17.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:18:17.57,0:18:19.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untung saja berhasil.
Dialogue: 0,0:18:19.75,0:18:24.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski pakai tongkat, daya sihirku\Nhanya mampu memakainya sekali.
Dialogue: 0,0:18:24.19,0:18:26.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang penting, apa sudah kamu perhatikan?
Dialogue: 0,0:18:26.19,0:18:27.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, Master.
Dialogue: 0,0:18:28.01,0:18:29.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa kamu pakai?
Dialogue: 0,0:18:29.98,0:18:31.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan kucoba?
Dialogue: 0,0:18:45.19,0:18:49.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wahai roh tirta nan agung,\Npangeran guntur penguasa dirga.
Dialogue: 0,0:18:49.82,0:18:53.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kabulkan pinta hamba,\Nturunkan karunia anggara.
Dialogue: 0,0:18:53.36,0:18:56.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perlihatkan kuasamu kepada kami para jelata!
Dialogue: 0,0:18:59.58,0:19:00.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Hebat...\N- Tunjukkan daulat agung
Dialogue: 0,0:19:00.88,0:19:03.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}dengan halilintar martil batara.
Dialogue: 0,0:19:03.00,0:19:04.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Banjiri bumi dengan tirta!
Dialogue: 0,0:19:04.91,0:19:10.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wahai hujan, basuh semesta\Ndan hancurkan segalanya!
Dialogue: 0,0:19:14.38,0:19:18.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wahai roh cahaya nan agung,\Nkaisar guntur penguasa dirga!
Dialogue: 0,0:19:18.89,0:19:21.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dapatkah engkau lihat yang menjulang murka?
Dialogue: 0,0:19:21.14,0:19:23.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dialah ahli jemawa, musuh Paduka!
Dialogue: 0,0:19:23.94,0:19:28.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hambalah yang akan mengalahkannya\Ndalam satu terjangan pedang dewata!
Dialogue: 0,0:19:28.90,0:19:33.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan kuasa kirana,\Ntunjukkan wibawa sang adiraja!
Dialogue: 0,0:19:33.65,0:19:35.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lightning!
Dialogue: 0,0:20:03.98,0:20:06.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan ini Rudy sudah jadi\Npenyihir tingkat Raja Air.
Dialogue: 0,0:20:06.95,0:20:11.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agak sebal rasanya.\NPada akhirnya cuma aku yang tidak bisa.
Dialogue: 0,0:20:11.44,0:20:14.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sendiri paling tidak akan gagal\Nsekali dalam lima percobaan.
Dialogue: 0,0:20:14.77,0:20:17.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, Rudy bisa berhasil sekali coba.
Dialogue: 0,0:20:17.13,0:20:18.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia memang hebat.
Dialogue: 0,0:20:18.53,0:20:19.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:20:19.97,0:20:22.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kuduga akan begitu.
Dialogue: 0,0:20:22.41,0:20:26.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, kalau berhasil semudah itu,\Nagak sedih rasanya.
Dialogue: 0,0:20:30.93,0:20:32.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cantiknya.
Dialogue: 0,0:20:32.38,0:20:34.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya, cantik sekali.
Dialogue: 0,0:20:35.38,0:20:40.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belakangan ini, ada kalanya aku merasa\Nkalau sedang bermimpi.
Dialogue: 0,0:20:40.14,0:20:41.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bermimpi?
Dialogue: 0,0:20:41.28,0:20:42.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:20:42.76,0:20:49.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mungkin aku masih di labirin itu\Ndan sedang bermimpi indah di ujung ajal?
Dialogue: 0,0:20:49.77,0:20:53.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dalam setengah tahun ini,\Naku jadi sangat bahagia.
Dialogue: 0,0:20:54.23,0:20:57.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah bisa menikah,\Naku pun sudah jadi pengajar.
Dialogue: 0,0:20:57.96,0:21:01.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin bagi Sylphy aku hanya pengganggu.
Dialogue: 0,0:21:02.35,0:21:07.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, aku merasa senang kita bertiga\Nbisa menunggangi kuda seperti ini.
Dialogue: 0,0:21:07.59,0:21:10.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kamu bukan pengganggu, kok.
Dialogue: 0,0:21:10.87,0:21:14.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sendiri juga senang\Nbisa akur dengan Roxy.
Dialogue: 0,0:21:14.95,0:21:19.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau harus rebutan Rudy,\Nkurasa aku akan kalah.
Dialogue: 0,0:21:22.14,0:21:24.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ini hanya mujur.
Dialogue: 0,0:21:24.81,0:21:30.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa ketemu lagi dengan Rudy\Ndan membantunya saat kesusahan.
Dialogue: 0,0:21:30.55,0:21:34.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau tidak begitu, mana mungkin\NRudy mau melirikku.
Dialogue: 0,0:21:34.75,0:21:37.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kurasa tidak juga, kok.
Dialogue: 0,0:21:37.28,0:21:39.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang mujur justru diriku.
Dialogue: 0,0:21:39.57,0:21:43.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku berani keluar karena ditarik Roxy.
Dialogue: 0,0:21:43.17,0:21:47.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keadaan bahagia ini bisa terwujud\Nberkat izin Sylphy.
Dialogue: 0,0:21:47.81,0:21:51.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku yang seperti ini kalaupun bilang\Nmenyayangi mereka berdua,
Dialogue: 0,0:21:51.53,0:21:54.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya akan terdengar seperti basa-basi.
Dialogue: 0,0:21:54.31,0:21:57.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena itu, akan kubuktikan dengan tindakan.
Dialogue: 0,0:21:57.63,0:22:01.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Demi mereka berdua,\Ndemi melindungi keluargaku.
