Dialogue: 0,0:00:00.00,0:00:01.98,sign,,0000,0000,0000,,SEPULUH TAHUN YANG LALU
Dialogue: 0,0:01:15.31,0:01:22.98,sign,,0000,0000,0000,,VICTORIA OF MANY FACES
Dialogue: 0,0:02:37.01,0:02:37.91,sign,,0000,0000,0000,,EPISODE 3:
Dialogue: 0,0:02:37.91,0:02:39.76,sign,,0000,0000,0000,,GAGAL MENJADI ORANG YANG BISA DIANDALKAN
Dialogue: 0,0:17:03.99,0:17:06.00,sign,,0000,0000,0000,,SEPULUH TAHUN YANG LALU
Dialogue: 0,0:20:45.10,0:20:47.73,sign,,0000,0000,0000,,BEBERAPA JAM SEBELUMNYA
Dialogue: 0,0:00:09.64,0:00:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeff.
Dialogue: 0,0:00:11.60,0:00:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:12.91,0:00:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini akan ekspedisi, kan?
Dialogue: 0,0:00:14.29,0:00:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:00:15.39,0:00:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum berangkat,\Naku ingin bertemu denganmu dulu.
Dialogue: 0,0:00:18.82,0:00:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali dengan selamat, ya.
Dialogue: 0,0:00:21.80,0:00:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas.
Dialogue: 0,0:00:23.19,0:00:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersama kakakmu yang bisa diandalkan.
Dialogue: 0,0:00:30.29,0:00:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaiser.
Dialogue: 0,0:00:35.72,0:00:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeff, terima kasih.
Dialogue: 0,0:00:37.45,0:00:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke depannya juga, tolong jaga adikku.
Dialogue: 0,0:00:42.38,0:00:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:00:45.55,0:00:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku pernah bertunangan\Ndengan seorang wanita.
Dialogue: 0,0:00:50.33,0:00:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak menyadari
Dialogue: 0,0:00:54.56,0:00:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penderitaan yang dia alami.
Dialogue: 0,0:01:01.44,0:01:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal menjadi orang\Nyang bisa dia andalkan.
Dialogue: 0,0:02:37.91,0:02:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, ini sudah selesai.
Dialogue: 0,0:02:43.88,0:02:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky, penampilanmu seperti tuan putri.
Dialogue: 0,0:02:46.77,0:02:48.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Nonna.
Dialogue: 0,0:02:49.26,0:02:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana persiapan jamuan malamnya?
Dialogue: 0,0:02:51.40,0:02:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah siap, Nyonya.
Dialogue: 0,0:02:53.51,0:02:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pacaran dengan Kapten Kesatria, kan?
Dialogue: 0,0:02:57.14,0:03:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kami pacaran atau tidak.
Dialogue: 0,0:03:00.24,0:03:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya minta aku pura-pura\Njadi pasangannya
Dialogue: 0,0:03:02.45,0:03:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berharap bisa membantunya.
Dialogue: 0,0:03:03.90,0:03:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kikuk, ya.
Dialogue: 0,0:03:05.60,0:03:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu buat alasan seperti itu,
Dialogue: 0,0:03:07.29,0:03:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia harusnya langsung mengundangmu saja.
Dialogue: 0,0:03:11.32,0:03:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bertiga sudah pergi piknik bersama.
Dialogue: 0,0:03:13.34,0:03:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya?
Dialogue: 0,0:03:15.68,0:03:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus.
Dialogue: 0,0:03:17.25,0:03:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, kamu dan Kapten Kesatria\Nmasih lajang.
Dialogue: 0,0:03:20.13,0:03:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di masyarakat sekarang, pasti ada solusi\Nuntuk perbedaan status seperti ini.
Dialogue: 0,0:03:23.50,0:03:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kami tak punya hubungan seperti itu.
Dialogue: 0,0:03:25.84,0:03:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:03:27.15,0:03:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan memang perlu sedikit bumbu cinta.
Dialogue: 0,0:03:29.65,0:03:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih muda.
Dialogue: 0,0:03:33.78,0:03:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena peranku pura-pura\Nmenjadi pasangannya,
Dialogue: 0,0:03:36.33,0:03:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan dianggap sebagai kekasihnya.
Dialogue: 0,0:03:39.93,0:03:42.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehadiranku mungkin akan\Nmembuat sedikit drama.
Dialogue: 0,0:03:42.08,0:03:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mentalku sudah siap.
Dialogue: 0,0:03:44.65,0:03:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menghindari janji\Nyang tak bisa ditepati.
Dialogue: 0,0:03:47.03,0:03:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang sudah dijanjikan\Njuga harus ditepati.
Dialogue: 0,0:03:50.00,0:03:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu prinsipku.
Dialogue: 0,0:03:52.71,0:03:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah datang menjemputmu.
Dialogue: 0,0:04:00.76,0:04:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memilih gaun ini\Nkarena warnanya cocok denganmu.
Dialogue: 0,0:04:04.77,0:04:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya malam ini\Nakan ada banyak orang yang iri padaku.
Dialogue: 0,0:04:07.83,0:04:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:04:09.52,0:04:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak pun pujiannya,\Naku akan terima semuanya.
Dialogue: 0,0:04:14.44,0:04:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku langsung pulang.
Dialogue: 0,0:04:16.20,0:04:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati di jalan, Vicky.
Dialogue: 0,0:04:19.68,0:04:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menjaganya sampai pagi,
Dialogue: 0,0:04:21.64,0:04:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malam ini tak pulang pun\Ntidak apa-apa.
Dialogue: 0,0:04:24.55,0:04:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Yolana, sebenarnya Anda ingin aku\Nbertindak sampai sejauh mana?
Dialogue: 0,0:04:30.69,0:04:33.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pergi dan nikmati acaranya!
Dialogue: 0,0:05:06.83,0:05:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, saatnya menjalankan misi.
Dialogue: 0,0:05:09.90,0:05:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sangat populer, ya, Kapten.
Dialogue: 0,0:05:12.82,0:05:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah sepuluh tahun\Ntak hadir dengan pasangan.
Dialogue: 0,0:05:15.61,0:05:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti kaget.
Dialogue: 0,0:05:16.95,0:05:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Asher, lama tidak bertemu.
Dialogue: 0,0:05:20.01,0:05:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget melihatmu membawa pasangan.
Dialogue: 0,0:05:22.39,0:05:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu, Count Wald.
Dialogue: 0,0:05:24.97,0:05:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, boleh tahu siapa namamu?
Dialogue: 0,0:05:28.67,0:05:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Victoria Sellers.
Dialogue: 0,0:05:31.31,0:05:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berasal dari Kerajaan Randall.
Dialogue: 0,0:05:33.19,0:05:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja aku belum pernah melihatmu,
Dialogue: 0,0:05:35.56,0:05:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata dari negara tetangga, ya?
Dialogue: 0,0:05:40.55,0:05:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Nona Gilmore.
Dialogue: 0,0:05:43.76,0:05:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini giliranku berperan\Nsebagai pasangan pura-puranya.
Dialogue: 0,0:05:46.70,0:05:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Asher.
Dialogue: 0,0:05:48.20,0:05:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang berkali-kali,\Ntolong panggil aku Florence.
Dialogue: 0,0:05:52.21,0:05:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, malam ini kamu bersama seseorang, ya?
Dialogue: 0,0:05:56.29,0:05:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Victoria Sellers.
Dialogue: 0,0:05:58.19,0:06:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri viscount dari Kerajaan Randall.
Dialogue: 0,0:06:00.87,0:06:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu?
Dialogue: 0,0:06:02.11,0:06:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount, ya.
Dialogue: 0,0:06:03.72,0:06:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ketus begitu\Ndi depan orang yang kamu sukai.
Dialogue: 0,0:06:08.39,0:06:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Victoria Sellers.
Dialogue: 0,0:06:10.52,0:06:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona-nona Kerajaan Ashbury
Dialogue: 0,0:06:13.06,0:06:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya anggun dan ramah.
Dialogue: 0,0:06:15.57,0:06:17.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang sudah disambut hangat.
Dialogue: 0,0:06:19.97,0:06:21.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang penting bagiku,
Dialogue: 0,0:06:21.99,0:06:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semoga kalian bisa akur.
Dialogue: 0,0:06:24.95,0:06:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:27.02,0:06:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, dasar Jeffrey.
Dialogue: 0,0:06:31.31,0:06:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kita pura-pura,\Nsenyum manismu terlalu serius.
Dialogue: 0,0:06:36.07,0:06:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami permisi dulu.
Dialogue: 0,0:06:42.92,0:06:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, itu Putra Mahkota!
Dialogue: 0,0:06:51.33,0:06:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilan dia sangat menawan!
Dialogue: 0,0:06:53.02,0:06:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua indah seperti lukisan.
Dialogue: 0,0:07:30.29,0:07:31.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita juga menari.
Dialogue: 0,0:07:31.95,0:07:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:34.75,0:08:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan mahir berdansa?
Dialogue: 0,0:08:37.20,0:08:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku juga pernah pura-pura\Nmenjadi kekasih orang lain.
Dialogue: 0,0:08:41.65,0:08:42.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:08:42.97,0:08:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu bisa membuatku terkejut.
Dialogue: 0,0:08:45.69,0:08:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:08:47.33,0:08:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, siapa atasanmu yang kamu bilang\Nselalu ingin menjodohkanmu?
Dialogue: 0,0:08:53.87,0:08:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Putra Mahkota Conrad\Nyang berdansa tadi.
Dialogue: 0,0:08:59.71,0:09:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu dekat dengan Putra Mahkota?
Dialogue: 0,0:09:09.82,0:09:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten.
Dialogue: 0,0:09:11.60,0:09:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:12.28,0:09:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan di dekat Putra Mahkota itu
Dialogue: 0,0:09:15.45,0:09:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak tadi tidak bekerja dengan serius.
Dialogue: 0,0:09:18.31,0:09:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan dia ingin\Nmencuri permata para nona di sini?
Dialogue: 0,0:09:22.28,0:09:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat seperti sedang mencari seseorang.
Dialogue: 0,0:09:24.29,0:09:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku pergi melihatnya dulu.
Dialogue: 0,0:09:26.25,0:09:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, silakan.
Dialogue: 0,0:09:50.57,0:09:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!\NDia kabur ke sana!
Dialogue: 0,0:09:52.36,0:09:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejar! Cepat!
Dialogue: 0,0:09:53.45,0:09:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat disayangkan.
Dialogue: 0,0:09:54.62,0:09:56.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten membiarkannya kabur.
Dialogue: 0,0:09:58.27,0:10:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin akan
Dialogue: 0,0:10:01.83,0:10:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengganti seragam yang mencolok itu.
Dialogue: 0,0:10:04.42,0:10:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang!
Dialogue: 0,0:10:17.22,0:10:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia di sana!
Dialogue: 0,0:10:42.58,0:10:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten.
Dialogue: 0,0:10:43.73,0:10:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, kamu di sini, ya?
Dialogue: 0,0:10:45.88,0:10:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh.\N- Aku akan pulang naik kereta kuda saja.
Dialogue: 0,0:10:48.43,0:10:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:10:49.84,0:10:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, naik kereta kudaku saja.
Dialogue: 0,0:10:51.99,0:10:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sekarang aku tidak bisa\Nmengantarmu pulang.
Dialogue: 0,0:10:54.59,0:10:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa nanti.
Dialogue: 0,0:10:55.77,0:10:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:10:59.92,0:11:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelakunya tertangkap,
Dialogue: 0,0:11:02.19,0:11:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi syukurlah penjagaan\Ndi sini cukup longgar.
Dialogue: 0,0:11:05.84,0:11:07.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam aula sepertinya ada keributan.
Dialogue: 0,0:11:07.81,0:11:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu?
Dialogue: 0,0:11:09.32,0:11:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sedikit masalah.
Dialogue: 0,0:11:10.27,0:11:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sudah teratasi.
Dialogue: 0,0:11:12.09,0:11:13.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengganti gaun dulu.
Dialogue: 0,0:11:13.95,0:11:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong antar aku ke sebuah toko\Ndi Distrik Selatan dulu.
Dialogue: 0,0:11:16.85,0:11:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:21.85,0:11:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak banyak bertanya.
Dialogue: 0,0:11:24.37,0:11:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelayan keluarga Count memang hebat.
Dialogue: 0,0:11:27.90,0:11:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tak melakukan\Nhal seperti itu,
Dialogue: 0,0:11:30.78,0:11:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang aku sedikit\Ntidak ingin bertemu Nonna.
Dialogue: 0,0:11:33.51,0:11:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu sangat sensitif\Nterhadap situasi seperti ini.
Dialogue: 0,0:11:37.76,0:11:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum pulang, cari tempat dulu.
Dialogue: 0,0:11:45.54,0:11:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:11:46.96,0:11:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong berikan arak suling\Nyang direkomendasi.
Dialogue: 0,0:11:51.34,0:11:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:55.49,0:11:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama aku tak merasakan\Nmomen seperti ini.
Dialogue: 0,0:11:59.37,0:12:02.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepuasan membaca gerakan lawan\Ndan menekannya.
Dialogue: 0,0:12:02.85,0:12:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketegangan dan kegembiraan yang membuat\Nwaktu di sekitar seolah berhenti.
Dialogue: 0,0:12:08.12,0:12:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:12:11.36,0:12:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati.
Dialogue: 0,0:12:17.97,0:12:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku mengira aku bekerja\Ndemi keluarga dan Lancome.
Dialogue: 0,0:12:22.12,0:12:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sepertinya, aku suka pekerjaan itu.
Dialogue: 0,0:12:25.92,0:12:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:12:27.01,0:12:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud\Nkembali menjadi agen rahasia.
Dialogue: 0,0:12:30.80,0:12:31.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena...
Dialogue: 0,0:12:33.12,0:12:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mau pulang?
Dialogue: 0,0:12:35.26,0:12:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:35.97,0:12:39.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada anak imut yang menungguku pulang.
Dialogue: 0,0:12:39.60,0:12:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau demi menjaga kebahagiaan ini...
Dialogue: 0,0:12:43.41,0:12:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan datang lagi.
Dialogue: 0,0:12:48.33,0:12:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu menyesali jurus-jurus itu.
Dialogue: 0,0:12:52.94,0:12:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Markis McKenna,
Dialogue: 0,0:12:54.56,0:12:56.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda tahu kenapa Anda diincar?
Dialogue: 0,0:12:56.92,0:12:59.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak tahu.
Dialogue: 0,0:12:59.91,0:13:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pria itu direkrut seseorang?
Dialogue: 0,0:13:02.65,0:13:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingat punya dendam\Ndengan siapa pun.
Dialogue: 0,0:13:04.93,0:13:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Jeffrey tidak menghentikannya,
Dialogue: 0,0:13:07.18,0:13:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda mungkin sudah tewas.
Dialogue: 0,0:13:09.50,0:13:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisau di tangan pria itu dilumuri racun.
Dialogue: 0,0:13:13.90,0:13:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeffrey.
Dialogue: 0,0:13:14.99,0:13:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kamu mulai menyadari pria itu?
Dialogue: 0,0:13:16.97,0:13:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan aku yang menyadarinya.
Dialogue: 0,0:13:18.99,0:13:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasanganku yang menyadarinya.
Dialogue: 0,0:13:20.56,0:13:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat semuanya sedang menari,
Dialogue: 0,0:13:21.79,0:13:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia melihat pria itu\Ntidak bekerja dengan serius.
Dialogue: 0,0:13:24.68,0:13:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:13:26.04,0:13:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ditemukan oleh pasanganmu.
Dialogue: 0,0:13:27.89,0:13:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, prajurit pertama\Nyang berlari ke halaman
Dialogue: 0,0:13:31.04,0:13:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memiliki penglihatan malam\Nyang sangat baik.
Dialogue: 0,0:13:35.99,0:13:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang saat menemukan pria itu,
Dialogue: 0,0:13:38.24,0:13:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlihat sekilas siluet seorang wanita\Nyang menghilang dalam kegelapan.
Dialogue: 0,0:13:42.99,0:13:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita?
Dialogue: 0,0:13:44.13,0:13:46.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang menjatuhkan pria itu\Nseorang wanita?
Dialogue: 0,0:13:46.89,0:13:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:13:47.80,0:13:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak melihat momen wanita itu\Nmenjatuhkan pria itu.
Dialogue: 0,0:13:50.43,0:13:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kehilangan pria itu sampai ditemukan\Njatuh di halaman hanya beberapa detik.
Dialogue: 0,0:13:54.48,0:13:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menjatuhkannya\Ndalam waktu sesingkat itu,
Dialogue: 0,0:13:57.23,0:13:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan prajurit pun sulit melakukannya.
Dialogue: 0,0:13:59.49,0:14:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, wanita itu mungkin\Nhanya kebetulan ada di sana.
Dialogue: 0,0:14:02.80,0:14:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya terkejut, lalu kabur.
Dialogue: 0,0:14:06.10,0:14:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak, apa ada ciri-ciri wanita itu?
Dialogue: 0,0:14:09.09,0:14:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya,
Dialogue: 0,0:14:10.35,0:14:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya terlihat dia mengenakan gaun.
Dialogue: 0,0:14:16.99,0:14:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudahi dulu diskusi ini.
Dialogue: 0,0:14:20.09,0:14:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Markis McKenna,
Dialogue: 0,0:14:21.51,0:14:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku boleh bertanya beberapa hal lagi?
Dialogue: 0,0:14:23.95,0:14:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:14:33.32,0:14:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bilang ini di depan semuanya,
Dialogue: 0,0:14:35.40,0:14:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi prajurit kami yang lapor\Nmelihat warna gaun wanita itu.
Dialogue: 0,0:14:39.67,0:14:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Warnanya ungu muda atau biru muda.
Dialogue: 0,0:14:43.74,0:14:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeffrey, aku merasa wanita itu
Dialogue: 0,0:14:47.20,0:14:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah pasanganmu yang kamu bawa.
Dialogue: 0,0:14:50.79,0:14:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi, dia sejak awal menyadari\Ngerak-gerik mencurigakan pria itu.
Dialogue: 0,0:14:54.65,0:14:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh tanya siapa sebenarnya nona itu?
Dialogue: 0,0:14:59.76,0:15:02.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru mengenal wanita itu\Nbelakangan ini,
Dialogue: 0,0:15:02.40,0:15:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}namanya Victoria Sellers.
Dialogue: 0,0:15:05.52,0:15:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa ceritakan bagaimana\Nkamu bisa mengenalnya?
Dialogue: 0,0:15:09.16,0:15:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:13.67,0:15:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria di jamuan malam tadi,
Dialogue: 0,0:15:15.19,0:15:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gerakannya masih terlihat amatir.
Dialogue: 0,0:15:17.77,0:15:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan mengambil risiko untuk membunuh
Dialogue: 0,0:15:20.94,0:15:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin karena dendam pribadi.
Dialogue: 0,0:15:24.03,0:15:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski membunuh orang yang kamu benci,
Dialogue: 0,0:15:26.45,0:15:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ingatan masa lalu tak akan hilang.
Dialogue: 0,0:15:29.28,0:15:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu bangsawan\Nyang diserang itu orang baik atau jahat.
Dialogue: 0,0:15:33.28,0:15:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak ingin membunuh orang\Nkarena alasan itu.
Dialogue: 0,0:15:37.69,0:15:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:15:39.90,0:15:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak membiarkan pria itu kabur\Njuga demi diriku sendiri.
Dialogue: 0,0:15:43.80,0:15:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pria itu berhasil kabur,
Dialogue: 0,0:15:45.55,0:15:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang di jamuan malam akan diselidiki.
Dialogue: 0,0:15:50.30,0:15:54.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang asing yang baru pertama kali hadir\Npasti akan dicurigai dulu.
Dialogue: 0,0:15:54.83,0:15:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menghindari situasi itu terjadi.
Dialogue: 0,0:15:59.07,0:16:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam, Nonna.
Dialogue: 0,0:16:04.59,0:16:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak,
Dialogue: 0,0:16:05.65,0:16:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga ingin bertemu wanita itu.
Dialogue: 0,0:16:08.95,0:16:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau wanita itu bisa menjatuhkan pria itu,
Dialogue: 0,0:16:11.84,0:16:14.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ilmu bela dirinya pasti sangat hebat.
Dialogue: 0,0:16:14.91,0:16:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah bertemu dia, lalu bagaimana?
Dialogue: 0,0:16:16.79,0:16:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga tak punya hubungan denganmu, kan?
Dialogue: 0,0:16:18.71,0:16:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin bertemu orang\Nyang ahli bela diri.
Dialogue: 0,0:16:21.59,0:16:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cedric.
Dialogue: 0,0:16:25.11,0:16:28.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa membiarkan wanita itu\Nbergerak bebas pilihan tepat?
Dialogue: 0,0:16:29.16,0:16:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:30.61,0:16:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatannya bukan orang jahat,
Dialogue: 0,0:16:32.68,0:16:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku harus mengawasinya\Ndemi kebaikan Jeffrey.
Dialogue: 0,0:16:37.50,0:16:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan Jeffrey berhenti melangkah\Nselama sepuluh tahun ini,
Dialogue: 0,0:16:40.17,0:16:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga karena aku.
Dialogue: 0,0:16:43.52,0:16:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya tanggung jawab\Nuntuk menjadi orang yang dibenci itu.
Dialogue: 0,0:17:01.07,0:17:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, kuperintahkan\NPasukan Kesatria Pertama
Dialogue: 0,0:17:03.99,0:17:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk berperang.
Dialogue: 0,0:17:08.56,0:17:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Conrad,
Dialogue: 0,0:17:09.68,0:17:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kuserahkan tugas komando padamu.
Dialogue: 0,0:17:11.41,0:17:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertempuran pertamamu.
Dialogue: 0,0:17:13.31,0:17:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Ayah!
Dialogue: 0,0:17:17.81,0:17:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menyerang malam hari\Nsebelum musuh bangkit lagi!
Dialogue: 0,0:17:20.68,0:17:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam hari terlalu berbahaya,
Dialogue: 0,0:17:22.31,0:17:24.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya kita menunggu sampai pagi.
Dialogue: 0,0:17:24.15,0:17:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menunggu semalaman,\Npasukan bantuan mereka akan tiba!
Dialogue: 0,0:17:26.67,0:17:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:17:27.90,0:17:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota, mohon berikan perintah!
Dialogue: 0,0:17:37.17,0:17:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertindaklah sebelum\Npasukan bantuan musuh tiba.
Dialogue: 0,0:17:39.45,0:17:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tunggu, Putra Mahkota!
Dialogue: 0,0:17:41.82,0:17:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh memiliki keunggulan medan!
Dialogue: 0,0:17:43.84,0:17:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau musuh tahu kita menyerang malam ini,
Dialogue: 0,0:17:45.84,0:17:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa rugi besar!
Dialogue: 0,0:17:48.34,0:17:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon pertimbangkan kembali keputusanmu.
Dialogue: 0,0:18:14.78,0:18:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota!
Dialogue: 0,0:18:17.31,0:18:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota, bahaya!
Dialogue: 0,0:18:27.65,0:18:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuserahkan sisanya padamu,
Dialogue: 0,0:18:30.41,0:18:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota.
Dialogue: 0,0:18:34.24,0:18:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaiser!
Dialogue: 0,0:18:42.64,0:18:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua orang tuanya baru saja meninggal,
Dialogue: 0,0:18:45.05,0:18:46.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang kakak kembarnya juga.
Dialogue: 0,0:18:46.81,0:18:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan sekali.
Dialogue: 0,0:18:47.69,0:18:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan tidak menangis sedikit pun!
Dialogue: 0,0:18:49.78,0:18:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar tegar.
Dialogue: 0,0:18:50.82,0:18:54.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri keluarga kesatria memang hebat.
Dialogue: 0,0:18:54.24,0:18:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar Pangeran sangat ingin menang
Dialogue: 0,0:18:56.49,0:18:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memaksakan serangan malam.
Dialogue: 0,0:18:58.78,0:19:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Kaiser dari awal menentangnya, kan?
Dialogue: 0,0:19:01.50,0:19:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tewas demi melindungi Pangeran,\Nbenar-benar malang.
Dialogue: 0,0:19:06.03,0:19:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyesal
Dialogue: 0,0:19:07.58,0:19:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas meninggalnya Kaiser.
Dialogue: 0,0:19:10.07,0:19:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota.
Dialogue: 0,0:19:12.19,0:19:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak gugur demi melindungi Putra Mahkota,\Nitu suatu kehormatan.
Dialogue: 0,0:19:18.07,0:19:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong angkat kepala Anda.
Dialogue: 0,0:19:22.04,0:19:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katherine, menyentuh\NPutra Mahkota itu tidak sopan.
Dialogue: 0,0:19:32.68,0:19:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka...
Dialogue: 0,0:19:33.40,0:19:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kakak...\N- Katherine.
Dialogue: 0,0:19:38.20,0:19:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:20:07.42,0:20:09.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau keluar\Ndari Pasukan Kesatria Pertama?
Dialogue: 0,0:20:10.03,0:20:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:12.55,0:20:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menerimanya.
Dialogue: 0,0:20:14.15,0:20:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pindah ke Pasukan Kesatria Kedua saja.
Dialogue: 0,0:20:15.82,0:20:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong pertimbangkan lagi, Jeffrey.
Dialogue: 0,0:20:32.49,0:20:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hari yang panjang.
Dialogue: 0,0:20:35.24,0:20:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Victoria pulang dengan selamat?
Dialogue: 0,0:20:39.45,0:20:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Mahkota memang hebat.
Dialogue: 0,0:20:45.10,0:20:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu awal kamu mengenalnya?
Dialogue: 0,0:20:47.10,0:20:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:48.67,0:20:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:20:49.60,0:20:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertemuan kalian terdengar seperti kebetulan.
Dialogue: 0,0:20:52.76,0:20:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang punya inisiatif itu kamu.
Dialogue: 0,0:20:55.03,0:20:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia tak punya motif\Nsengaja mendekatimu.
Dialogue: 0,0:20:57.97,0:20:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ada inisiatif begitu.
Dialogue: 0,0:20:59.74,0:21:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun penjelasannmu,\Nkamu terlihat suka padanya.
Dialogue: 0,0:21:02.79,0:21:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben.
Dialogue: 0,0:21:04.31,0:21:05.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:07.40,0:21:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak menatapku dengan tatapan\Nyang membuatku tidak nyaman.
Dialogue: 0,0:21:10.61,0:21:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuatku tenang.
Dialogue: 0,0:21:12.40,0:21:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih pentingnya lagi,
Dialogue: 0,0:21:13.60,0:21:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai seorang wanita,
Dialogue: 0,0:21:15.36,0:21:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia hidup tanpa bergantung\Npada orang lain,
Dialogue: 0,0:21:18.26,0:21:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan memiliki semangat untuk merawat\Nanak yatim dari negara lain.
Dialogue: 0,0:21:22.60,0:21:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jatuh cinta padanya?
Dialogue: 0,0:21:27.42,0:21:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:33.15,0:21:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Victoria Sellers.
Dialogue: 0,0:21:35.80,0:21:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari, kamu muncul di dalam hidupku.
Dialogue: 0,0:21:40.26,0:21:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muncul di hadapanku yang tidak bisa\Nmenjadi tempat bersandar orang lain.
Dialogue: 0,0:21:45.85,0:21:47.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang tak bergantung pada siapa pun
Dialogue: 0,0:21:47.64,0:21:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}muncul di hadapanku.
Dialogue: 0,0:21:59.11,0:22:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang bisa kubantu?
Dialogue: 0,0:22:01.68,0:22:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh orang di Kerajaan Randall
Dialogue: 0,0:22:04.15,0:22:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selidiki orang bernama Victoria Sellers.
