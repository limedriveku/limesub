Dialogue: 0,0:00:11.28,0:00:16.00,sign,,0000,0000,0000,,VICTORIA OF MANY FACES
Dialogue: 0,0:01:29.99,0:01:34.99,sign,,0000,0000,0000,,EPISODE 2: AKU TAK BUTUH DIKASIHANI
Dialogue: 0,0:04:08.31,0:04:09.49,sign,,0000,0000,0000,,DUA MINGGU LALU
Dialogue: 0,0:05:19.38,0:05:21.39,sign,,0000,0000,0000,,KEESOKAN HARINYA
Dialogue: 0,0:01:40.81,0:01:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah pulang?
Dialogue: 0,0:01:42.13,0:01:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:01:43.29,0:01:46.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku pulang untuk mengunjungi Ibu.
Dialogue: 0,0:01:48.61,0:01:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, Jeffrey,
Dialogue: 0,0:01:50.51,0:01:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kudengar kamu tampil rapi saat keluar.
Dialogue: 0,0:01:54.55,0:01:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pergi kencan dengan wanita, kan?
Dialogue: 0,0:01:57.83,0:02:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang menemuiku\Nhanya untuk membahas hal ini?
Dialogue: 0,0:02:01.60,0:02:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dingin begitu.
Dialogue: 0,0:02:03.91,0:02:05.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah senang mendengarnya.
Dialogue: 0,0:02:05.99,0:02:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu bisa mengajak wanita kencan.
Dialogue: 0,0:02:09.44,0:02:11.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan terakhir kali kamu melakukannya?
Dialogue: 0,0:02:11.24,0:02:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak,
Dialogue: 0,0:02:12.91,0:02:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah bilang\Njangan terus mengasihaniku, kan?
Dialogue: 0,0:02:18.33,0:02:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:02:20.08,0:02:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan mengungkitnya lagi.
Dialogue: 0,0:02:22.73,0:02:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kencannya seru?
Dialogue: 0,0:02:26.96,0:02:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru.
Dialogue: 0,0:02:29.65,0:02:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku makan malam bersama wanita asing\Nyang baru tiba di negeri ini
Dialogue: 0,0:02:32.76,0:02:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gadis kecil berusia enam tahun\Nyang diadopsinya,
Dialogue: 0,0:02:36.35,0:02:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kami sangat menikmatinya.
Dialogue: 0,0:02:40.25,0:02:42.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak juga sudah punya penerus,
Dialogue: 0,0:02:42.85,0:02:45.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu hanya perlu\Nmengkhawatirkan urusan dia saja.
Dialogue: 0,0:02:45.45,0:02:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu mengkhawatirkanku.
Dialogue: 0,0:02:49.32,0:02:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sampai jumpa\Ndi pesta ulang tahun Paman.
Dialogue: 0,0:02:55.80,0:02:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara tentang Paman,
Dialogue: 0,0:02:56.95,0:03:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kudengar dia merekrut\Nseorang asisten yang cekatan.
Dialogue: 0,0:03:00.45,0:03:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eva bahkan sangat kagum.
Dialogue: 0,0:03:02.75,0:03:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya mahir bahasa asing,\Ndia juga mahir pekerjaan rumah tangga.
Dialogue: 0,0:03:07.03,0:03:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:03:08.79,0:03:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa membuat Paman yang angkuh\Ndan sulit bergaul itu puas,
Dialogue: 0,0:03:12.01,0:03:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya dia orang yang hebat, ya?
Dialogue: 0,0:03:15.88,0:03:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Edward, Jeffrey, kalian sudah datang, ya?
Dialogue: 0,0:03:18.68,0:03:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman.
Dialogue: 0,0:03:20.39,0:03:22.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah Paman masih sehat.
Dialogue: 0,0:03:22.20,0:03:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, lama tidak jumpa.
Dialogue: 0,0:03:25.61,0:03:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman terlihat jauh lebih ceria\Ndari sebelumnya.
Dialogue: 0,0:03:29.33,0:03:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, rumahnya juga sangat rapi.
Dialogue: 0,0:03:33.48,0:03:36.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kembali ke masa\Nsaat Bibi masih hidup.
Dialogue: 0,0:03:36.00,0:03:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berkat asisten baru itu.
Dialogue: 0,0:03:40.87,0:03:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu.
Dialogue: 0,0:03:42.74,0:03:45.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanannya sudah siap.
Dialogue: 0,0:03:45.81,0:03:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:03:47.37,0:03:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:03:48.96,0:03:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian, kamu juga ikut makan bersama kami.
Dialogue: 0,0:03:51.32,0:03:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berjasa besar membuat\Nhidup Paman kembali normal.
Dialogue: 0,0:03:55.17,0:03:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon.
Dialogue: 0,0:03:56.72,0:03:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak enak.
Dialogue: 0,0:03:59.66,0:04:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sellers?
Dialogue: 0,0:04:01.13,0:04:03.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Kapten.
Dialogue: 0,0:04:05.24,0:04:07.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak jumpa.
Dialogue: 0,0:04:09.49,0:04:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah memanggilmu kemari.
Dialogue: 0,0:04:12.76,0:04:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membalas budi atas bantuanmu\Nmenangkap perampok tempo hari.
Dialogue: 0,0:04:16.32,0:04:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, justru aku yang harus berterima kasih.
Dialogue: 0,0:04:23.33,0:04:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap gerakannya anggun dan indah.
Dialogue: 0,0:04:25.70,0:04:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengaku berasal dari Kerajaan Randall,
Dialogue: 0,0:04:28.59,0:04:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia sepertinya\Npernah hidup layak di sana.
Dialogue: 0,0:04:33.53,0:04:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, apa rencanamu selanjutnya?
Dialogue: 0,0:04:36.13,0:04:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus tinggal di hotel juga\Nbukan solusi, kan?
Dialogue: 0,0:04:38.40,0:04:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dapat pekerjaan,
Dialogue: 0,0:04:40.19,0:04:41.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rencananya ingin menyewa rumah.
Dialogue: 0,0:04:42.54,0:04:43.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:04:47.84,0:04:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau rencanamu menyewa rumah,\Nbagaimana kalau di rumahku?
Dialogue: 0,0:04:51.55,0:04:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada rumah yang terpisah dari rumah utama.
Dialogue: 0,0:04:53.48,0:04:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada dapur dan kamar mandinya.
Dialogue: 0,0:04:57.39,0:04:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sebagai tanda terima kasihku.
Dialogue: 0,0:04:58.99,0:05:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:05:01.68,0:05:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai warga Kerajaan Ashbury,
Dialogue: 0,0:05:04.51,0:05:08.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin berterima kasih karena\Nkamu sudah mengadopsi dan merawat anak ini.
Dialogue: 0,0:05:10.69,0:05:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah aku langsung membuat\Nkontrak sewanya?
Dialogue: 0,0:05:15.90,0:05:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:05:21.39,0:05:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontraknya sangat detail.
Dialogue: 0,0:05:23.84,0:05:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kontrak yang sempurna.
Dialogue: 0,0:05:26.66,0:05:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menyukaimu!
Dialogue: 0,0:05:36.13,0:05:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harga sewanya setengah harga?
Dialogue: 0,0:05:37.90,0:05:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan.
Dialogue: 0,0:05:39.80,0:05:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendapat penyewa yang menarik.
Dialogue: 0,0:05:42.45,0:05:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tempat kerjamu di dekat sini?
Dialogue: 0,0:05:44.24,0:05:46.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bekerja di tempat sejarawan Bernard
Dialogue: 0,0:05:46.73,0:05:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai asisten sekaligus pelayan.
Dialogue: 0,0:05:50.23,0:05:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?\NDengan orang itu?
Dialogue: 0,0:05:57.57,0:06:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dibelikan almarhum suamiku,
Dialogue: 0,0:06:00.92,0:06:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}topi yang penuh kenangan.
Dialogue: 0,0:06:03.66,0:06:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa boleh buat.
Dialogue: 0,0:06:22.95,0:06:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku gadis periang.
Dialogue: 0,0:06:25.52,0:06:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kamu ini
Dialogue: 0,0:06:27.28,0:06:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih bisa melakukan hal apa lagi?
Dialogue: 0,0:06:34.41,0:06:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya beruntung bisa menyewakan rumah\Nterpisah pada orang sehebat dia.
Dialogue: 0,0:06:38.33,0:06:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:06:39.86,0:06:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya, kalau nanti\Naku sudah akrab dengan Nonna,
Dialogue: 0,0:06:42.61,0:06:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku boleh mengajak dia\Nmenginap di kamarku?
Dialogue: 0,0:06:45.13,0:06:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begitu, Nona Victoria juga\Nbisa keluar di malam hari.
Dialogue: 0,0:06:48.76,0:06:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai keinginanmu saja.
Dialogue: 0,0:06:52.50,0:06:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia wanita yang sangat berpendidikan.
Dialogue: 0,0:06:56.44,0:07:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja bisa jadi asisten sarjana\Nyang sulit dihadapi itu.
Dialogue: 0,0:07:08.52,0:07:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Bernard,
Dialogue: 0,0:07:09.88,0:07:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dokumen yang Anda berikan kemarin\Nsudah selesai saya terjemahkan.
Dialogue: 0,0:07:15.21,0:07:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selesai hanya dalam semalam?
Dialogue: 0,0:07:16.81,0:07:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:07:17.67,0:07:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon periksa apakah masih ada yang salah.
Dialogue: 0,0:07:21.25,0:07:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi Anda memeriksa,\Naku akan melakukan tugas rumah.
Dialogue: 0,0:07:28.20,0:07:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sempurna.
Dialogue: 0,0:07:30.83,0:07:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepenuhnya memahami isi dokumennya.
Dialogue: 0,0:07:46.95,0:07:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka makan apa?
Dialogue: 0,0:07:51.03,0:07:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan yang kusuka?
Dialogue: 0,0:07:54.56,0:07:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky...
Dialogue: 0,0:07:56.25,0:07:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan yang dimasak Vicky...
Dialogue: 0,0:07:59.44,0:08:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging domba muda panggang!
Dialogue: 0,0:08:03.65,0:08:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:08:05.78,0:08:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau malam ini senggang, bagaimana kalau kita\Npanggang daging domba muda di rumah?
Dialogue: 0,0:08:10.15,0:08:12.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga bisa ikut makan bersama.
Dialogue: 0,0:08:12.77,0:08:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, senang mendengarnya.
Dialogue: 0,0:08:14.69,0:08:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati akan saya masakan.
Dialogue: 0,0:08:16.27,0:08:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk biaya bahan makanan dan upahnya,\Nakan kubayar sekalian.
Dialogue: 0,0:08:21.45,0:08:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:08:23.15,0:08:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pengalaman langka karena\Nbisa makan bersama orang selain Nonna,
Dialogue: 0,0:08:27.15,0:08:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tidak perlu diberi upah lembur.
Dialogue: 0,0:08:29.37,0:08:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:30.53,0:08:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya tidak butuh.
Dialogue: 0,0:08:32.03,0:08:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:32.74,0:08:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:08:33.65,0:08:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu...
Dialogue: 0,0:08:34.33,0:08:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas niat baiknya.
Dialogue: 0,0:08:36.55,0:08:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cukup keras kepala, ya.
Dialogue: 0,0:08:38.83,0:08:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak yang bilang begitu.
Dialogue: 0,0:08:43.03,0:08:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak.
Dialogue: 0,0:08:45.40,0:08:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:08:46.42,0:08:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna, jangan bicara saat sedang makan.
Dialogue: 0,0:08:53.60,0:08:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:59.99,0:09:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku tak yakin, bagaimana bisa\Ndia bekerja sambil membawa anak?
Dialogue: 0,0:09:03.94,0:09:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku suka anak yang berpendidikan.
Dialogue: 0,0:09:09.23,0:09:12.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalaman makan\Nyang sangat menyenangkan tadi,
Dialogue: 0,0:09:12.16,0:09:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baru pertama kali kurasakan lagi\Nsetelah kepergianmu.
Dialogue: 0,0:09:19.79,0:09:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaji tiga kali lipat?
Dialogue: 0,0:09:21.37,0:09:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu tidak terlalu banyak?
Dialogue: 0,0:09:26.45,0:09:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:27.34,0:09:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kamu menguasai empat bahasa,\Ndan mahir mengurus pekerjaan juga!
Dialogue: 0,0:09:31.76,0:09:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:09:32.76,0:09:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa mengubah ruang kerja Paman\Nyang tadinya seperti kapal pecah
Dialogue: 0,0:09:36.01,0:09:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi ruang kerja sarjana yang seharusnya!
Dialogue: 0,0:09:40.52,0:09:42.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu berlebihan, Eva.
Dialogue: 0,0:09:42.52,0:09:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:43.65,0:09:45.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melakukan pekerjaan setara tiga orang.
Dialogue: 0,0:09:45.71,0:09:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan menemani Paman mengobrol juga.
Dialogue: 0,0:09:47.65,0:09:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya upah dia empat kali lipat!
Dialogue: 0,0:09:49.53,0:09:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah diputuskan, ya!
Dialogue: 0,0:09:58.77,0:10:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kami juga ingin\Nmempekerjakan orang sepertimu.
Dialogue: 0,0:10:04.63,0:10:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:10:05.71,0:10:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Victoria, bisa bantu aku?
Dialogue: 0,0:10:08.46,0:10:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu apa?
Dialogue: 0,0:10:09.64,0:10:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan mengadakan\Npesta ulang tahun Paman yang ke-65.
Dialogue: 0,0:10:12.55,0:10:14.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para kerabat Paman akan datang.
Dialogue: 0,0:10:14.43,0:10:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu upah tambahan,
Dialogue: 0,0:10:16.64,0:10:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa membantu menyiapkannya pestanya?
Dialogue: 0,0:10:19.14,0:10:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu terlalu meriah.
Dialogue: 0,0:10:21.19,0:10:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik,
Dialogue: 0,0:10:22.54,0:10:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Nona tidak keberatan.
Dialogue: 0,0:10:25.94,0:10:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu ceritanya.
Dialogue: 0,0:10:28.20,0:10:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:29.34,0:10:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru ingat ini sudah waktunya\Nmengirim laporan padamu.
Dialogue: 0,0:10:34.64,0:10:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Victoria, masakan ini berbeda\Ndengan yang sebelumnya.
Dialogue: 0,0:10:37.16,0:10:40.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa hubunganmu dengannya?\N- Iya, aku menambahkan kacang.
Dialogue: 0,0:10:40.04,0:10:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau itu...\N- Ini sangat enak.
Dialogue: 0,0:10:42.79,0:10:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu menendang perampok\Nsambil menggendong anak?
Dialogue: 0,0:10:45.88,0:10:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendengarnya,\Nsepertinya kamu tak punya rasa takut.
Dialogue: 0,0:10:49.13,0:10:51.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diingat lagi,\Nitu tindakan yang gegabah, ya.
Dialogue: 0,0:10:51.63,0:10:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, berkat kejadian itu,
Dialogue: 0,0:10:53.01,0:10:56.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wanita yang dirampok itu menyewakan\Nrumah terpisahnya padaku.
Dialogue: 0,0:10:56.80,0:10:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk Distrik Timur,\Nbiaya sewanya sangat murah.
Dialogue: 0,0:10:59.64,0:11:02.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kamu bertemu dengan Jeff\Njuga karena kejadian itu, ya?
Dialogue: 0,0:11:02.39,0:11:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:11:03.85,0:11:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia orang yang kamu ajak\N"makan malam yang seru" itu?
Dialogue: 0,0:11:06.52,0:11:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:07.19,0:11:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kakak.
Dialogue: 0,0:11:08.52,0:11:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahas soal Distrik Timur,\Nitu rumah milik siapa?
Dialogue: 0,0:11:11.72,0:11:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah Nyonya Yolana Haynes.
Dialogue: 0,0:11:14.25,0:11:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah Nyonya Count Haynes\Ngenerasi sebelumnya, ya?
Dialogue: 0,0:11:17.41,0:11:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi-lagi hal yang mengejutkan.
Dialogue: 0,0:11:18.84,0:11:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang sulit bergaul, kan?
Dialogue: 0,0:11:20.77,0:11:21.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak,
Dialogue: 0,0:11:21.70,0:11:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pemilik rumah yang baik dan ramah.
Dialogue: 0,0:11:24.29,0:11:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan, Nonna?
Dialogue: 0,0:11:26.58,0:11:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Yolana sangat baik.
Dialogue: 0,0:11:29.75,0:11:33.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu bisa menangani Paman,\Njadi itu wajar.
Dialogue: 0,0:11:33.84,0:11:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar tidak sopan.
Dialogue: 0,0:11:35.34,0:11:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Bernard juga sangat baik.
Dialogue: 0,0:11:37.65,0:11:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:11:47.00,0:11:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Bernard minum cukup banyak.
Dialogue: 0,0:11:50.20,0:11:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sangat menikmatinya.
Dialogue: 0,0:11:51.90,0:11:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya berkat kamu.
Dialogue: 0,0:11:53.53,0:11:54.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:11:55.03,0:11:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami permisi dulu.
Dialogue: 0,0:11:57.08,0:11:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak,
Dialogue: 0,0:11:58.13,0:12:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin mengobrol sebentar\Ndengannya sebelum pulang.
Dialogue: 0,0:12:01.12,0:12:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:12:02.68,0:12:04.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku pulang duluan.
Dialogue: 0,0:12:13.11,0:12:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ingin kamu bicarakan?
Dialogue: 0,0:12:17.38,0:12:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan malam bersama kalian waktu itu\Nmembuatku sangat senang.
Dialogue: 0,0:12:21.05,0:12:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku ingin mengajak kalian makan lagi.
Dialogue: 0,0:12:24.72,0:12:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:12:26.54,0:12:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi ini...
Dialogue: 0,0:12:28.46,0:12:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengingatkanku saat menjadi agen rahasia,
Dialogue: 0,0:12:30.49,0:12:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan memanfaatkan percintaan\Ndemi mendapatkan informasi.
Dialogue: 0,0:12:34.98,0:12:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu akan merepotkanmu?
Dialogue: 0,0:12:37.33,0:12:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, sama sekali tidak merepotkan.
Dialogue: 0,0:12:39.77,0:12:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja,
Dialogue: 0,0:12:41.03,0:12:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}posisiku tidak cocok untuk terlalu akrab\Ndengan bangsawan.
Dialogue: 0,0:12:46.35,0:12:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya putra kedua,
Dialogue: 0,0:12:48.29,0:12:50.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan mewarisi usaha keluarga.
Dialogue: 0,0:12:50.42,0:12:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu khawatir soal status.
Dialogue: 0,0:12:53.71,0:12:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:13:07.12,0:13:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, prioritas utamaku\Nmembesarkan Nonna.
Dialogue: 0,0:13:12.50,0:13:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:13:13.56,0:13:16.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana kalau kita\Npergi piknik bertiga?
Dialogue: 0,0:13:17.44,0:13:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:18.80,0:13:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piknik itu apa?
Dialogue: 0,0:13:20.59,0:13:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:13:21.95,0:13:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bilang begitu,\NNonna pasti akan menantikannya...
Dialogue: 0,0:13:30.61,0:13:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:13:32.71,0:13:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:34.01,0:13:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyiapkan bekal.
Dialogue: 0,0:13:35.79,0:13:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan piknik.
Dialogue: 0,0:13:38.01,0:13:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piknik!
Dialogue: 0,0:13:47.54,0:13:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berlari terlalu jauh.
Dialogue: 0,0:13:49.85,0:13:51.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:56.09,0:13:59.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah berpura-pura\Npiknik sendirian demi pekerjaan,
Dialogue: 0,0:13:59.72,0:14:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ini pertama kalinya\Naku membawa anak kecil.
Dialogue: 0,0:14:03.57,0:14:05.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir...
Dialogue: 0,0:14:06.49,0:14:08.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga belum pernah piknik waktu kecil.
Dialogue: 0,0:14:14.37,0:14:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna, kamu hebat!
Dialogue: 0,0:14:16.39,0:14:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya kena.
Dialogue: 0,0:14:18.88,0:14:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky lebih hebat.
Dialogue: 0,0:14:22.55,0:14:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:14:24.30,0:14:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Victoria, tolong perlihatkan pada kami.
Dialogue: 0,0:14:28.14,0:14:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, ya?
Dialogue: 0,0:14:30.02,0:14:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:14:30.97,0:14:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus buat lemparan yang payah?
Dialogue: 0,0:14:32.69,0:14:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin lihat Kapten\Nyang mencontohkan duluan.
Dialogue: 0,0:14:35.56,0:14:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:14:42.12,0:14:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua dilempar ke tempat yang sama.
Dialogue: 0,0:14:43.79,0:14:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Giliranmu.
Dialogue: 0,0:14:57.25,0:14:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, meleset.
Dialogue: 0,0:14:59.40,0:15:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:00.50,0:15:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna dan Victoria sama-sama hebat.
Dialogue: 0,0:15:02.51,0:15:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku gadis periang.
Dialogue: 0,0:15:05.01,0:15:06.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis periang!
Dialogue: 0,0:15:09.89,0:15:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sekarang memanjat pohon?
Dialogue: 0,0:15:13.07,0:15:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai jatuh.
Dialogue: 0,0:15:14.18,0:15:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky lebih hebat.
Dialogue: 0,0:15:17.80,0:15:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku gadis periang\Nyang tumbuh di desa.
Dialogue: 0,0:15:22.07,0:15:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi, sekarang aku tidak bisa memanjat,
Dialogue: 0,0:15:24.53,0:15:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soalnya pakai rok.
Dialogue: 0,0:15:27.39,0:15:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:15:34.66,0:15:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya.
Dialogue: 0,0:15:37.67,0:15:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini kamu juga yang mengajarkannya?
Dialogue: 0,0:15:41.09,0:15:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengajarkan semua hal yang kutahu.
Dialogue: 0,0:15:44.97,0:15:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku menjauhkannya\Ndari semua bahaya,
Dialogue: 0,0:15:48.43,0:15:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan menjadi wanita\Nyang hanya bisa dilindungi orang lain.
Dialogue: 0,0:15:55.77,0:15:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah bicara arogan.
Dialogue: 0,0:15:58.34,0:15:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:15:59.15,0:16:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku bertemu\Nwanita yang bilang begitu.
Dialogue: 0,0:16:01.69,0:16:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya terkejut.
Dialogue: 0,0:16:15.31,0:16:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan sebelumnya enak,\Ntapi roti lapis ini juga enak.
Dialogue: 0,0:16:19.08,0:16:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:16:22.24,0:16:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dulu kamu seorang juru masak?
Dialogue: 0,0:16:24.56,0:16:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mantan akademisi?
Dialogue: 0,0:16:26.13,0:16:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah bekerja sebagai juru masak,
Dialogue: 0,0:16:29.05,0:16:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedangkan belajar bahasa itu hobiku.
Dialogue: 0,0:16:32.15,0:16:33.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:16:33.58,0:16:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaum bangsawan juga biasanya\Nbelajar beberapa bahasa sejak kecil, kan?
Dialogue: 0,0:16:39.14,0:16:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, itu benar.
Dialogue: 0,0:16:41.48,0:16:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu rakyat biasa, kan?
Dialogue: 0,0:16:42.98,0:16:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku lahir di keluarga miskin,
Dialogue: 0,0:16:45.73,0:16:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi harus bisa melakukan apa pun.
Dialogue: 0,0:16:50.70,0:16:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:16:54.94,0:16:57.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pekerjaanku dulu\Nmengharuskanku begitu.
Dialogue: 0,0:17:04.35,0:17:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru, ya?
Dialogue: 0,0:17:07.05,0:17:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sangat akrab denganmu.
Dialogue: 0,0:17:09.08,0:17:10.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:10.26,0:17:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat imut.
Dialogue: 0,0:17:12.23,0:17:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku tidak tahu\Nbahwa anak kecil seimut ini.
Dialogue: 0,0:17:15.45,0:17:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang rasanya bisa mengajaknya piknik.
Dialogue: 0,0:17:21.00,0:17:22.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky, kamu juga senang?
Dialogue: 0,0:17:24.67,0:17:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, senang.
Dialogue: 0,0:17:27.99,0:17:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat senang.
Dialogue: 0,0:17:32.60,0:17:35.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya kupikir akan lebih baik\Nkalau hanya kita bertiga,
Dialogue: 0,0:17:35.95,0:17:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata dugaanku salah.
Dialogue: 0,0:17:38.31,0:17:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lelah, biar aku yang mengemudi.
Dialogue: 0,0:17:42.03,0:17:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku hanya berpikir kalau ada kusir,\Nkita bisa mengobrol selama perjalanan.
Dialogue: 0,0:17:46.69,0:17:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kamu juga bisa mengemudi?
Dialogue: 0,0:17:50.53,0:17:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pepatah\Nminimal harus bisa semua hal dasar.
Dialogue: 0,0:17:58.14,0:18:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pepatah itu tidak cocok\Nuntuk menggambarkan dirimu.
Dialogue: 0,0:18:11.22,0:18:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau hanya pekerjaan,
Dialogue: 0,0:18:12.84,0:18:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa melaluinya sambil tersenyum.
Dialogue: 0,0:18:16.18,0:18:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ekspresi apa yang kutunjukkan tadi?
Dialogue: 0,0:18:19.94,0:18:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tergantung siapa yang melakukannya,\Ntindakan itu bisa terasa menakutkan,
Dialogue: 0,0:18:24.03,0:18:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi yang jelas,\Nini tidak terasa mengganggu.
Dialogue: 0,0:18:28.84,0:18:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku punya\Nbanyak pengalaman kerja,
Dialogue: 0,0:18:32.28,0:18:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku belum pernah jatuh cinta\Npada siapa pun.
Dialogue: 0,0:18:35.63,0:18:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu\Napa itu piknik yang sesungguhnya.
Dialogue: 0,0:18:39.08,0:18:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa di dalam diriku,
Dialogue: 0,0:18:40.89,0:18:43.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti ada banyak hal yang kurang.
Dialogue: 0,0:18:45.75,0:18:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tidak perlu merasa cemas.
Dialogue: 0,0:18:49.41,0:18:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian yang kurang itu,
Dialogue: 0,0:18:51.23,0:18:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku menantikan untuk mengisinya\Ndi masa depan.
Dialogue: 0,0:18:54.30,0:18:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar teknik baru juga menyenangkan.
Dialogue: 0,0:19:09.68,0:19:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamuan malam yang diadakan\Nkeluarga kerajaan?
Dialogue: 0,0:19:11.76,0:19:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, benar.
Dialogue: 0,0:19:14.62,0:19:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa hadir.
Dialogue: 0,0:19:16.47,0:19:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menyiapkan gaun dan perhiasan.
Dialogue: 0,0:19:19.28,0:19:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya perlu menemaniku\Ndan bersikap akrab denganku.
Dialogue: 0,0:19:24.05,0:19:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengusir\Nserangga yang mengganggumu, ya?
Dialogue: 0,0:19:27.97,0:19:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang begitu.
Dialogue: 0,0:19:29.65,0:19:32.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin atasanku berhenti menjodohkanku.
Dialogue: 0,0:19:32.82,0:19:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa kamu bisa berperan\Nsebagai putri bangsawan dengan baik.
Dialogue: 0,0:19:38.52,0:19:40.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:19:40.33,0:19:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat menolaknya...
Dialogue: 0,0:19:41.95,0:19:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak mau menemaninya pergi?
Dialogue: 0,0:19:44.08,0:19:46.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap hari harus meladeni Paman\Nyang sulit dihadapi.
Dialogue: 0,0:19:46.36,0:19:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupanmu hanya soal pekerjaan,\Norang tua, dan anak kecil.
Dialogue: 0,0:19:48.96,0:19:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendengarnya saja membuatku sedih.
Dialogue: 0,0:19:50.96,0:19:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tapi aku...
Dialogue: 0,0:19:52.29,0:19:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menjaga Nonna.
Dialogue: 0,0:19:54.21,0:19:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja padaku.
Dialogue: 0,0:19:55.26,0:19:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantu Jeffrey yang malang itu.
Dialogue: 0,0:19:58.19,0:19:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna,
Dialogue: 0,0:19:59.51,0:20:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpisah satu malam dengan Victoria\Ntidak apa-apa, kan?
Dialogue: 0,0:20:03.67,0:20:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:20:05.42,0:20:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky,
Dialogue: 0,0:20:06.84,0:20:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergilah bersama Kapten.
Dialogue: 0,0:20:10.46,0:20:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mulai besok\Nkita harus belajar tata krama dengan baik.
Dialogue: 0,0:20:23.54,0:20:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah tidur?
Dialogue: 0,0:20:28.01,0:20:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang tidak mau jaga rumah, kan?
Dialogue: 0,0:20:30.17,0:20:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa menjaga rumah.
Dialogue: 0,0:20:34.78,0:20:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku, Nonna.
Dialogue: 0,0:20:35.80,0:20:37.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa!
Dialogue: 0,0:20:41.04,0:20:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau\Nkamu dikasihani orang lain.
Dialogue: 0,0:20:46.31,0:20:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna.
Dialogue: 0,0:20:54.83,0:20:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bahagia hidup bersamamu.
Dialogue: 0,0:20:57.83,0:21:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak ada yang perlu dikasihani.
Dialogue: 0,0:21:00.89,0:21:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Eva tidak bermaksud begitu.
Dialogue: 0,0:21:03.81,0:21:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu dipikirkan.
Dialogue: 0,0:21:07.04,0:21:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky,
Dialogue: 0,0:21:09.65,0:21:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu akan memakai gaun?
Dialogue: 0,0:21:11.63,0:21:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:13.04,0:21:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhiasan juga?
Dialogue: 0,0:21:14.29,0:21:15.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin.
Dialogue: 0,0:21:19.09,0:21:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:19.97,0:21:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu pikirkan?
Dialogue: 0,0:21:21.01,0:21:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vicky akan menjadi tuan putri.
Dialogue: 0,0:21:25.93,0:21:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihatnya.
Dialogue: 0,0:21:27.81,0:21:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:29.92,0:21:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:21:38.94,0:21:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiah untuk misi pertamamu.
Dialogue: 0,0:21:46.10,0:21:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayatnya tidak ditemukan.
Dialogue: 0,0:21:48.79,0:21:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada laporan dia terjatuh saat berusaha\Nmengambil topi yang tertiup angin.
Dialogue: 0,0:21:53.15,0:21:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga laporan dia depresi berat\Nsampai batin dan fisiknya tertekan.
Dialogue: 0,0:21:58.59,0:22:00.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pun alasannya, sama saja.
Dialogue: 0,0:22:02.45,0:22:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chloe, apa kamu
Dialogue: 0,0:22:05.79,0:22:07.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih hidup?
