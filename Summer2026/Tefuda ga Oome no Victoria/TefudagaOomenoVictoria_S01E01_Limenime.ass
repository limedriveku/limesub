Dialogue: 0,0:01:17.62,0:01:19.68,sign,,0000,0000,0000,,PASUKAN KHUSUS KERAJAAN HAGL
Dialogue: 0,0:01:19.68,0:01:21.23,sign,,0000,0000,0000,,RUANG MANAJEMEN PUSAT
Dialogue: 0,0:02:32.60,0:02:33.33,sign,,0000,0000,0000,,PERBATASAN KERAJAAN RANDALL
Dialogue: 0,0:03:04.06,0:03:05.86,sign,,0000,0000,0000,,KERAJAAN HAGL
Dialogue: 0,0:03:05.86,0:03:08.56,sign,,0000,0000,0000,,KERAJAAN RANDALL
Dialogue: 0,0:03:08.56,0:03:10.09,sign,,0000,0000,0000,,KERAJAAN ASHBURY
Dialogue: 0,0:03:11.71,0:03:14.49,sign,,0000,0000,0000,,PERBATASAN KERAJAAN ASHBURY
Dialogue: 0,0:03:25.23,0:03:30.77,sign,,0000,0000,0000,,IBU KOTA KERAJAAN ASHBURY
Dialogue: 0,0:03:54.71,0:04:02.97,sign,,0000,0000,0000,,VICTORIA OF MANY FACES
Dialogue: 0,0:04:14.32,0:04:18.99,sign,,0000,0000,0000,,VICTORIA OF MANY FACES
Dialogue: 0,0:05:32.98,0:05:34.01,sign,,0000,0000,0000,,EPISODE 1:\NBEBAS DAN TAK TERIKAT SIAPA PUN
Dialogue: 0,0:21:24.10,0:21:25.50,sign,,0000,0000,0000,,DUA MINGGU KEMUDIAN
Dialogue: 0,0:00:01.91,0:00:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira
Dialogue: 0,0:00:03.61,0:00:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal itu tak akan pernah bisa kugapai.
Dialogue: 0,0:00:06.71,0:00:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti menggapai cahaya matahari.
Dialogue: 0,0:00:10.21,0:00:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya,
Dialogue: 0,0:00:11.32,0:00:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak berniat mencoba menggapainya.
Dialogue: 0,0:00:14.45,0:00:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidup bahagia yang sederhana.
Dialogue: 0,0:00:18.12,0:00:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tak membutuhkannya.
Dialogue: 0,0:00:21.40,0:00:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku yakin akan terus berjalan\Ndi jalan yang sudah kupilih sendiri.
Dialogue: 0,0:00:27.16,0:00:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, pikiran bisa berubah.
Dialogue: 0,0:00:29.23,0:00:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, aku membuka\Npintu ini seperti biasa,
Dialogue: 0,0:00:32.50,0:00:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pergi dari rumahku.
Dialogue: 0,0:00:35.06,0:00:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencari sinar matahari musim semi.
Dialogue: 0,0:00:39.73,0:00:42.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, cuaca hari ini cerah, ya.
Dialogue: 0,0:00:42.69,0:00:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah sebelum hari mulai gelap.
Dialogue: 0,0:00:50.82,0:00:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pamit pada tebing\Nyang kucintai ini
Dialogue: 0,0:00:52.95,0:00:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan juga pada kehidupan\Nyang kujalani ini.
Dialogue: 0,0:01:10.47,0:01:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan kembali ke organisasi lagi.
Dialogue: 0,0:01:16.37,0:01:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Lancome.
Dialogue: 0,0:01:17.62,0:01:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada laporan bahwa Chloe
Dialogue: 0,0:01:19.68,0:01:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terlihat di Tebing Matool siang tadi.
Dialogue: 0,0:01:22.48,0:01:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi ke sana dan periksa.
Dialogue: 0,0:01:23.76,0:01:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah pagi tiba,\Nperiksa juga bawah tebingnya.
Dialogue: 0,0:01:25.98,0:01:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Periksa seluruh area sekitar dengan teliti.
Dialogue: 0,0:01:28.23,0:01:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:01:30.39,0:01:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lancome.
Dialogue: 0,0:01:31.49,0:01:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kecil Chloe sudah sering\Npergi ke tebing itu, kan?
Dialogue: 0,0:01:34.17,0:01:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:01:35.48,0:01:39.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memperingatinya berkali-kali,\Ndi sana tak ada pagar dan berbahaya.
Dialogue: 0,0:01:40.15,0:01:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa terjadi sesuatu pada Chloe?
Dialogue: 0,0:01:42.37,0:01:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sepertinya sangat syok\Nkarena pernikahan kita dan menjadi kurus.
Dialogue: 0,0:01:47.09,0:01:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:01:48.25,0:01:50.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum tahu situasi dia.
Dialogue: 0,0:01:50.99,0:01:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:01:52.05,0:01:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cemas.
Dialogue: 0,0:01:52.99,0:01:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini cuma salah paham.
Dialogue: 0,0:01:56.10,0:01:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chloe orang yang kuat.
Dialogue: 0,0:02:00.52,0:02:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak usia delapan tahun,\Naku terpisah dari keluargaku
Dialogue: 0,0:02:03.57,0:02:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diadopsi oleh Lancome saat muda.
Dialogue: 0,0:02:07.01,0:02:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum usia 27 tahun,
Dialogue: 0,0:02:09.47,0:02:12.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu menjadi\Nagen rahasia Kerajaan Hagl.
Dialogue: 0,0:02:18.60,0:02:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu arak?
Dialogue: 0,0:02:20.20,0:02:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:02:21.02,0:02:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalananku masih panjang.
Dialogue: 0,0:02:22.16,0:02:24.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian mau coba juga?
Dialogue: 0,0:02:26.90,0:02:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini,
Dialogue: 0,0:02:27.79,0:02:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka hanya akan ingat riasan, tahi lalat,
Dialogue: 0,0:02:30.30,0:02:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan rambut merahku saja.
Dialogue: 0,0:02:33.33,0:02:35.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, mungkin dadaku juga.
Dialogue: 0,0:02:37.91,0:02:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bekerja demi menghidupi keluargaku.
Dialogue: 0,0:02:40.93,0:02:43.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu aku mengagumi Lancome\Nseperti kakak sendiri,
Dialogue: 0,0:02:43.06,0:02:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menghormatinya sebagai atasan,
Dialogue: 0,0:02:46.02,0:02:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai aku tahu pengkhianatannya.
Dialogue: 0,0:02:50.53,0:02:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:02:52.01,0:02:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku meninggalkan kehidupanku\Nsebagai agen rahasia.
Dialogue: 0,0:03:04.06,0:03:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Victoria Sellers.
Dialogue: 0,0:03:05.86,0:03:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tokoh yang betulan ada di Kerajaan Randall.
Dialogue: 0,0:03:08.56,0:03:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, dia menghilang.
Dialogue: 0,0:03:10.61,0:03:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usianya sebaya denganku.
Dialogue: 0,0:03:11.71,0:03:14.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parasnya mirip denganku dan tak mencolok.
Dialogue: 0,0:03:14.49,0:03:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menghilang selama beberapa tahun,
Dialogue: 0,0:03:16.78,0:03:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak punya kerabat.
Dialogue: 0,0:03:18.47,0:03:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu melewati dua perbatasan negara,
Dialogue: 0,0:03:20.85,0:03:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan ada yang bisa melacakku.
Dialogue: 0,0:03:39.24,0:03:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku akan hidup sendirian\Nsebagai Victoria Sellers.
Dialogue: 0,0:03:44.75,0:03:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bebas dan tak terikat siapa pun.
Dialogue: 0,0:03:48.46,0:03:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu cemas.
Dialogue: 0,0:03:49.92,0:03:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku
Dialogue: 0,0:03:52.45,0:03:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih punya banyak cara.
Dialogue: 0,0:05:34.01,0:05:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga harimu menyenangkan.
Dialogue: 0,0:05:40.69,0:05:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak buru-buru,\Nkita akan kehabisan.
Dialogue: 0,0:06:03.65,0:06:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:06:05.30,0:06:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu masih situ...
Dialogue: 0,0:06:07.93,0:06:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dia diculik orang jahat?
Dialogue: 0,0:06:11.46,0:06:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:06:13.71,0:06:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tersesat?
Dialogue: 0,0:06:15.27,0:06:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:06:17.63,0:06:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tersesat.
Dialogue: 0,0:06:19.32,0:06:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namamu?
Dialogue: 0,0:06:21.01,0:06:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna.
Dialogue: 0,0:06:22.03,0:06:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna, keluargamu di mana?
Dialogue: 0,0:06:25.25,0:06:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu menyuruhku menunggu di sini.
Dialogue: 0,0:06:28.03,0:06:31.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingat menunggunya dari jam berapa?
Dialogue: 0,0:06:31.29,0:06:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum lonceng berbunyi sepuluh kali.
Dialogue: 0,0:06:34.04,0:06:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lewat empat jam.
Dialogue: 0,0:06:37.44,0:06:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lapar?
Dialogue: 0,0:06:38.92,0:06:41.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau makan bersamaku
Dialogue: 0,0:06:41.20,0:06:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil menunggu ibumu kembali?
Dialogue: 0,0:06:46.53,0:06:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:47.95,0:06:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunyah pelan-pelan, ya.
Dialogue: 0,0:06:49.93,0:06:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:06:55.81,0:06:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna, berapa umurmu?
Dialogue: 0,0:06:57.44,0:06:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam tahun.
Dialogue: 0,0:07:03.30,0:07:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terus menunggu sendirian di sini.
Dialogue: 0,0:07:05.93,0:07:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasihan.
Dialogue: 0,0:07:10.23,0:07:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini pasti ditinggalkan.
Dialogue: 0,0:07:12.53,0:07:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya ada tempat penitipan anak.
Dialogue: 0,0:07:21.55,0:07:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:07:22.88,0:07:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya.
Dialogue: 0,0:07:23.55,0:07:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus menghindar.
Dialogue: 0,0:07:26.05,0:07:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir!
Dialogue: 0,0:07:34.14,0:07:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:07:34.60,0:07:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:07:38.67,0:07:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melawan!
Dialogue: 0,0:07:49.81,0:07:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, apa kamu terluka?
Dialogue: 0,0:07:51.49,0:07:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:52.59,0:07:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuanmya.
Dialogue: 0,0:07:56.08,0:07:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun.
Dialogue: 0,0:07:57.16,0:08:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu akan membawanya\Nke pasukan penjaga?
Dialogue: 0,0:08:01.17,0:08:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau iya, apa aku juga boleh ikut?
Dialogue: 0,0:08:05.36,0:08:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ke sana?
Dialogue: 0,0:08:09.04,0:08:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menangkap perampok\Ndan membawanya ke sini.
Dialogue: 0,0:08:12.46,0:08:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kapten.
Dialogue: 0,0:08:13.89,0:08:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapten?
Dialogue: 0,0:08:16.54,0:08:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa wanita di sana?
Dialogue: 0,0:08:18.45,0:08:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang menjaga anak yang terlantar.
Dialogue: 0,0:08:20.68,0:08:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya kuserahkan padamu.
Dialogue: 0,0:08:24.73,0:08:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:08:28.68,0:08:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan anak itu malam ini?
Dialogue: 0,0:08:31.43,0:08:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan menginap dulu di sini.
Dialogue: 0,0:08:34.01,0:08:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah menghubungi panti asuhan,
Dialogue: 0,0:08:36.10,0:08:39.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi walinya paling cepat\Nbaru bisa datang besok.
Dialogue: 0,0:08:39.98,0:08:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok...
Dialogue: 0,0:08:45.88,0:08:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, apa untuk malam ini saja
Dialogue: 0,0:08:48.38,0:08:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku boleh membawanya\Nke hotel tempatku menginap?
Dialogue: 0,0:08:52.16,0:08:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tiba di negeri ini
Dialogue: 0,0:08:54.72,0:08:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak ada yang bisa\Nmenjadi penjaminku.
Dialogue: 0,0:08:56.84,0:08:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menemani anak ini\Nselama beberapa jam.
Dialogue: 0,0:08:59.08,0:09:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tak tega meninggalkannya begitu saja.
Dialogue: 0,0:09:01.96,0:09:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ada penjamin?
Dialogue: 0,0:09:06.12,0:09:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya tidak ada yang menjamin kamu\Nmenginap di hotel atau bukan.
Dialogue: 0,0:09:10.49,0:09:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa pastikan apakah dia\Nbetulan menginap di hotel.
Dialogue: 0,0:09:16.04,0:09:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat anak ini gelisah dan ada\Ndi tempat penitipan yang kotor
Dialogue: 0,0:09:20.97,0:09:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku tak tega juga.
Dialogue: 0,0:09:26.21,0:09:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:09:28.01,0:09:31.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyangka akan merepotkan\NKapten Pasukan Kesatria Kedua.
Dialogue: 0,0:09:32.35,0:09:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:09:33.49,0:09:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berterima kasih karena sudah\Nmembantuku menangkap perampok.
Dialogue: 0,0:09:37.16,0:09:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, asalmu dari mana?
Dialogue: 0,0:09:39.18,0:09:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalku dari Kerajaan Randall di sebelah.
Dialogue: 0,0:09:41.67,0:09:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berapa lama di sini?
Dialogue: 0,0:09:45.13,0:09:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua keluargaku meninggal karena kebakaran.
Dialogue: 0,0:09:49.15,0:09:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang ke negeri ini\Nuntuk menenangkan pikiran.
Dialogue: 0,0:09:52.89,0:09:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jawaban yang sudah kusiapkan.
Dialogue: 0,0:09:54.88,0:09:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebisa mungkin jangan berbohong.
Dialogue: 0,0:09:57.00,0:09:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawaban ini bisa kuingat\Ndan kemungkinan tak akan ketahuan.
Dialogue: 0,0:10:00.04,0:10:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:10:01.98,0:10:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu fasih berbahasa negara ini.
Dialogue: 0,0:10:03.80,0:10:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujiannya.
Dialogue: 0,0:10:09.67,0:10:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dikonfirmasi\Nbahwa kamu menginap di sini.
Dialogue: 0,0:10:12.01,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membantu
Dialogue: 0,0:10:13.76,0:10:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menangkap perampok
Dialogue: 0,0:10:14.97,0:10:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjaga anak itu.
Dialogue: 0,0:10:18.46,0:10:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, selamat malam.
Dialogue: 0,0:10:20.43,0:10:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:10:30.73,0:10:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari pertama hidup sebagai Victoria Sellers,
Dialogue: 0,0:10:33.24,0:10:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}langsung mengalami banyak hal.
Dialogue: 0,0:10:36.81,0:10:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur, Nonna.
Dialogue: 0,0:10:45.57,0:10:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi, Kakak.
Dialogue: 0,0:10:50.20,0:10:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekalian beli itu saat pulang kemarin.
Dialogue: 0,0:10:52.59,0:10:54.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatan cocok, ya.
Dialogue: 0,0:10:56.20,0:10:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku di mana?
Dialogue: 0,0:10:58.20,0:11:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya belum datang.
Dialogue: 0,0:11:00.96,0:11:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, silakan makan.
Dialogue: 0,0:11:04.75,0:11:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pekerjaan ibumu?
Dialogue: 0,0:11:07.52,0:11:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:11:09.34,0:11:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kegiatanmu saat sendirian?
Dialogue: 0,0:11:11.41,0:11:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya diam saja.
Dialogue: 0,0:11:13.33,0:11:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:11:14.76,0:11:18.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini sepertinya tidak banyak\Nmenunjukkan ekspresi.
Dialogue: 0,0:11:19.81,0:11:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kegiatanmu saat bersama ibumu?
Dialogue: 0,0:11:21.55,0:11:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya diam saja.
Dialogue: 0,0:11:23.53,0:11:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ibumu menyuruhmu diam?
Dialogue: 0,0:11:26.17,0:11:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:27.88,0:11:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar ibunya tak akan kembali.
Dialogue: 0,0:11:31.03,0:11:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalaupun kembali,
Dialogue: 0,0:11:32.64,0:11:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekali menelantarkan anaknya,
Dialogue: 0,0:11:34.59,0:11:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak akan bisa merawatnya dengan benar.
Dialogue: 0,0:11:38.71,0:11:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak boleh terus terlibat masalahnya.
Dialogue: 0,0:11:41.25,0:11:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa merawat anak kecil.
Dialogue: 0,0:11:51.88,0:11:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:11:55.93,0:11:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pita biru ini sangat cocok\Ndengan rambut pirangmu yang cantik.
Dialogue: 0,0:12:02.85,0:12:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ini yang bisa kubantu untuknya.
Dialogue: 0,0:12:06.44,0:12:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya datang.
Dialogue: 0,0:12:08.42,0:12:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kepala Panti Asuhan Distrik Selatan.
Dialogue: 0,0:12:11.17,0:12:14.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merawat anak ini tadi malam.\NTerima kasih sudah membantu
Dialogue: 0,0:12:14.46,0:12:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama.
Dialogue: 0,0:12:17.03,0:12:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita pergi.
Dialogue: 0,0:12:31.67,0:12:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak.
Dialogue: 0,0:12:33.62,0:12:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:12:44.08,0:12:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:12:45.33,0:12:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tunggu sebentar!
Dialogue: 0,0:12:49.33,0:12:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:12:50.68,0:12:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku...
Dialogue: 0,0:12:53.00,0:12:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku boleh mengadopsi gadis ini?
Dialogue: 0,0:13:04.60,0:13:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:13:06.36,0:13:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah mengganggu pekerjaanmu
Dialogue: 0,0:13:08.60,0:13:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bahkan menjadi penjaminku.
Dialogue: 0,0:13:10.98,0:13:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:13:12.41,0:13:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu juga warga penting\NKerajaan Ashbury.
Dialogue: 0,0:13:16.30,0:13:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kenapa kamu ingin mengadopsinya?
Dialogue: 0,0:13:19.14,0:13:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatapannya seperti meminta pertolongan.
Dialogue: 0,0:13:22.89,0:13:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu sekali,
Dialogue: 0,0:13:24.20,0:13:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada gadis dengan tatapan yang sama.
Dialogue: 0,0:13:26.65,0:13:28.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat memikirkan situasi mereka yang mirip,
Dialogue: 0,0:13:29.15,0:13:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tanpa sadar ingin menolongnya.
Dialogue: 0,0:13:32.44,0:13:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, tadi malam
Dialogue: 0,0:13:33.85,0:13:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah pulang, aku juga merenung.
Dialogue: 0,0:13:37.56,0:13:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi malam kalian pasti\Nbelum makan malam, kan?
Dialogue: 0,0:13:40.55,0:13:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:42.66,0:13:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku yakin kamu tak akan\Nmeninggalkan anak itu dan makan sendiri.
Dialogue: 0,0:13:46.76,0:13:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan-jangan kamu tidur\Ndengan perut kosong?
Dialogue: 0,0:13:50.39,0:13:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setidaknya harus\Nmengirimkan makanan enak ke sana.
Dialogue: 0,0:13:55.21,0:13:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua tebakanmu benar.
Dialogue: 0,0:13:57.67,0:14:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kapten tidak perlu merenungkan itu.
Dialogue: 0,0:14:00.89,0:14:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, untuk menghilangkan\Nrasa bersalahku,
Dialogue: 0,0:14:04.00,0:14:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bolehkah malam ini aku mentraktirmu makan?
Dialogue: 0,0:14:09.67,0:14:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut kalau Nonna diajak.
Dialogue: 0,0:14:14.42,0:14:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna.
Dialogue: 0,0:14:15.48,0:14:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, ayo cari rumah\Nuntuk kita tinggali bersama.
Dialogue: 0,0:14:18.86,0:14:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa menyewa rumah\Nyang ada dapurnya,
Dialogue: 0,0:14:21.22,0:14:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa memasak untukmu.
Dialogue: 0,0:14:23.74,0:14:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasak?
Dialogue: 0,0:14:24.84,0:14:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:14:26.03,0:14:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna, kamu suka makan apa?
Dialogue: 0,0:14:28.96,0:14:29.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Roti.
Dialogue: 0,0:14:30.69,0:14:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:14:32.24,0:14:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kita tambah makanan enak\Nyang kamu suka.
Dialogue: 0,0:14:35.46,0:14:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap hari makan banyak masakan enak.
Dialogue: 0,0:14:38.88,0:14:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membuatkannya untukmu.
Dialogue: 0,0:14:41.37,0:14:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Kakak.
Dialogue: 0,0:14:49.52,0:14:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, mulai hari ini,\Nkita berdua adalah keluarga.
Dialogue: 0,0:14:54.29,0:14:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, panggil aku Victoria.
Dialogue: 0,0:14:56.87,0:14:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panggil Vicky juga boleh.
Dialogue: 0,0:15:02.20,0:15:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bantuannya, Nonna.
Dialogue: 0,0:15:04.51,0:15:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita pergi mencari rumah bersama.
Dialogue: 0,0:15:12.64,0:15:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka hanya karena membawa anak,\Ntidak ada yang mau menyewakan.
Dialogue: 0,0:15:17.17,0:15:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu semua orang juga anak-anak.
Dialogue: 0,0:15:20.15,0:15:25.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudoakan pemilik rumah itu\Nmenginjak kotoran anjing saat keluar.
Dialogue: 0,0:15:26.26,0:15:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna.
Dialogue: 0,0:15:27.16,0:15:28.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini sudah malam.
Dialogue: 0,0:15:28.62,0:15:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku saja yang pergi mencari rumah.
Dialogue: 0,0:15:31.00,0:15:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kalau kamu sudah bangun,
Dialogue: 0,0:15:32.74,0:15:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan mencemaskan aku di luar, ya.
Dialogue: 0,0:15:36.44,0:15:37.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ikut.
Dialogue: 0,0:15:38.07,0:15:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencarinya akan sampai malam,
Dialogue: 0,0:15:39.82,0:15:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membawa anak kecil bisa berbahaya.
Dialogue: 0,0:15:45.41,0:15:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau ditinggal sendirian.
Dialogue: 0,0:15:52.04,0:15:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Nonna,
Dialogue: 0,0:15:53.27,0:15:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu harus janji padaku.
Dialogue: 0,0:15:56.10,0:15:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku memintamu jangan bersuara,
Dialogue: 0,0:15:58.15,0:16:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa pun yang terjadi, jangan bersuara.
Dialogue: 0,0:16:00.23,0:16:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:16:01.36,0:16:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kusuruh lari,
Dialogue: 0,0:16:02.44,0:16:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lari sekuat tenaga\Ndan cari tempat sembunyi.
Dialogue: 0,0:16:04.57,0:16:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan lari!
Dialogue: 0,0:16:05.44,0:16:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kusuruh berteriak,
Dialogue: 0,0:16:06.70,0:16:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}teriak dengan lantang.
Dialogue: 0,0:16:07.78,0:16:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berteriak!
Dialogue: 0,0:16:08.61,0:16:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kusuruh jangan bergerak,
Dialogue: 0,0:16:10.16,0:16:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan bergerak sedikit pun.
Dialogue: 0,0:16:11.81,0:16:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan bergerak!
Dialogue: 0,0:16:14.52,0:16:16.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini penurut.
Dialogue: 0,0:16:16.69,0:16:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapnya yang tak seperti anak-anak,\Nmungkin karena lingkungannya?
Dialogue: 0,0:16:21.90,0:16:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti aku akan mengajarimu\Nbeberapa ilmu bela diri.
Dialogue: 0,0:16:25.45,0:16:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilmu bela diri?
Dialogue: 0,0:16:26.88,0:16:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:27.95,0:16:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik untuk melindungi diri sendiri.
Dialogue: 0,0:16:30.11,0:16:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat mengalami hal menakutkan,
Dialogue: 0,0:16:31.68,0:16:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan hanya menangis dan diam,
Dialogue: 0,0:16:34.89,0:16:37.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus bisa melindungi dirimu sendiri.
Dialogue: 0,0:16:37.54,0:16:38.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:16:39.21,0:16:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, siap-siap untuk pergi.
Dialogue: 0,0:16:41.94,0:16:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ganti baju.
Dialogue: 0,0:16:44.43,0:16:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak, kamu cantik sekali.
Dialogue: 0,0:16:46.52,0:16:47.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:48.10,0:16:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna juga cantik.
Dialogue: 0,0:16:57.40,0:16:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau pakai pita itu?
Dialogue: 0,0:16:59.00,0:17:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:00.17,0:17:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya\Nada yang membelikanku pita.
Dialogue: 0,0:17:07.66,0:17:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, siapa?
Dialogue: 0,0:17:09.43,0:17:12.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku, Jeffrey Asher.
Dialogue: 0,0:17:12.10,0:17:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuka pintunya.
Dialogue: 0,0:17:14.91,0:17:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam, Kapten.
Dialogue: 0,0:17:18.79,0:17:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kalian berdua cantik sekali.
Dialogue: 0,0:17:22.84,0:17:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini restoran yang sering kukunjungi.
Dialogue: 0,0:17:25.69,0:17:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kujamin rasanya enak.
Dialogue: 0,0:17:26.94,0:17:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar.
Dialogue: 0,0:17:31.11,0:17:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membawa kami tidak akan ada masalah, kan?
Dialogue: 0,0:17:34.51,0:17:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan ada masalah.
Dialogue: 0,0:17:36.15,0:17:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bujangan yang bebas.
Dialogue: 0,0:17:38.20,0:17:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:17:39.66,0:17:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin dimusuhi\Norang-orang yang menyukaimu.
Dialogue: 0,0:17:44.79,0:17:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang seperti itu.
Dialogue: 0,0:17:46.75,0:17:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pasti ada.
Dialogue: 0,0:17:48.63,0:17:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengagumnya pasti sangat banyak.
Dialogue: 0,0:17:51.01,0:17:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini daging apa?
Dialogue: 0,0:17:52.41,0:17:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini daging kambing panggang herbal.
Dialogue: 0,0:17:58.60,0:17:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak?
Dialogue: 0,0:17:59.52,0:18:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:00.71,0:18:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf harus menyesuaikan\Ndengan jam pulang kerjaku.
Dialogue: 0,0:18:03.53,0:18:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nonna mengantuk?
Dialogue: 0,0:18:05.56,0:18:07.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa,\Nsetelah ini kami akan mencari rumah.
Dialogue: 0,0:18:08.88,0:18:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menyewa rumah?
Dialogue: 0,0:18:10.35,0:18:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membawa anak kecil malam-malam itu bahaya.
Dialogue: 0,0:18:12.20,0:18:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar.
Dialogue: 0,0:18:13.81,0:18:17.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau langsung setuju menyewa\Ntanpa melihat situasi malamnya,
Dialogue: 0,0:18:17.16,0:18:19.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemungkinan akan dapat rumah\Nyang kurang bagus.
Dialogue: 0,0:18:19.37,0:18:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan ikut menemani.
Dialogue: 0,0:18:21.65,0:18:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini merepotkan,
Dialogue: 0,0:18:22.86,0:18:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebagai penjamin,\Naku tak bisa diam saja.
Dialogue: 0,0:18:25.99,0:18:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia ikut, aku akan kesulitan\Nmenyelidiki area sekitar rumah.
Dialogue: 0,0:18:30.09,0:18:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak merepotkan.
Dialogue: 0,0:18:31.81,0:18:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami justru senang.
Dialogue: 0,0:18:34.53,0:18:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan santainya memberi tahu\Ntempat tinggal pada orang lain.
Dialogue: 0,0:18:38.60,0:18:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa waspadanya seorang wanita biasa\Nuntuk melindungi dirinya?
Dialogue: 0,0:18:43.89,0:18:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia agen rahasia,\Nhal seperti ini tak akan terjadi.
Dialogue: 0,0:18:46.48,0:18:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil Asher akan mendobrak masuk
Dialogue: 0,0:18:48.75,0:18:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mencelakai kami, kan?
Dialogue: 0,0:18:53.26,0:18:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:18:54.51,0:18:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah merepotkanmu\Nmenemani kami mencari rumah.
Dialogue: 0,0:18:57.93,0:18:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:18:58.96,0:19:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru tiba di negeri ini.
Dialogue: 0,0:19:01.20,0:19:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu situasi di Randall,
Dialogue: 0,0:19:03.73,0:19:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi di negeri ini,
Dialogue: 0,0:19:04.90,0:19:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}wanita keluar di malam hari\Nsambil membawa anak kecil
Dialogue: 0,0:19:07.58,0:19:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa dibilang aman.
Dialogue: 0,0:19:09.19,0:19:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:19:12.86,0:19:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:19:14.34,0:19:16.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahasa Ashbury-mu sangat fasih, ya.
Dialogue: 0,0:19:17.11,0:19:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pekerjaanmu saat di Randall?
Dialogue: 0,0:19:23.21,0:19:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Macam-macam.
Dialogue: 0,0:19:25.00,0:19:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada kesempatan bertemu lagi,
Dialogue: 0,0:19:27.27,0:19:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa membahasnya.
Dialogue: 0,0:19:31.84,0:19:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku menantikan\Nhari kita bertemu lagi.
Dialogue: 0,0:19:36.72,0:19:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malam ini sangat berkesan, Kapten.
Dialogue: 0,0:19:39.49,0:19:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa begitu.\NSelamat malam.
Dialogue: 0,0:19:42.22,0:19:43.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:19:50.61,0:19:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada jejak kaki.
Dialogue: 0,0:19:55.38,0:19:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada bekas dibuka.
Dialogue: 0,0:19:58.37,0:20:00.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas tidak ada.
Dialogue: 0,0:20:12.17,0:20:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.\NAku membuatmu terbangun?
Dialogue: 0,0:20:15.39,0:20:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging kambing panggangnya enak sekali.
Dialogue: 0,0:20:18.35,0:20:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, lain kali akan kumasakan untukmu.
Dialogue: 0,0:20:20.95,0:20:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:20:22.68,0:20:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:20:24.64,0:20:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin memasak.
Dialogue: 0,0:20:28.32,0:20:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:20:29.32,0:20:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti akan kuajarkan.
Dialogue: 0,0:20:31.40,0:20:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan akan mengajarkan\Nsemua hal yang kutahu.
Dialogue: 0,0:20:38.37,0:20:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:20:41.71,0:20:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Vicky.
Dialogue: 0,0:20:50.46,0:20:51.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonna.
Dialogue: 0,0:20:51.51,0:20:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan kita sepertinya akan penuh tawa.
Dialogue: 0,0:20:54.76,0:20:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penuh tawa?
Dialogue: 0,0:20:56.53,0:21:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!\NSeperti ini!
Dialogue: 0,0:21:01.53,0:21:05.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geli, Vicky!
Dialogue: 0,0:21:08.11,0:21:12.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuajarkan semua\Nyang kuketahui pada anak ini.
Dialogue: 0,0:21:14.59,0:21:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski masih anak kecil,
Dialogue: 0,0:21:17.09,0:21:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa banyak hal itu harus.
Dialogue: 0,0:21:25.50,0:21:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Nona Victoria masih menginap di sini?
Dialogue: 0,0:21:28.60,0:21:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:21:29.85,0:21:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia meninggalkan surat untukmu.
Dialogue: 0,0:21:35.07,0:21:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeffrey Asher,\NKapten Pasukan Kesatria Kedua.
Dialogue: 0,0:21:38.39,0:21:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuanmu\Nbeberapa waktu lalu.
Dialogue: 0,0:21:40.87,0:21:42.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah dapat pekerjaan
Dialogue: 0,0:21:42.64,0:21:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berhasil menyewa rumah.
Dialogue: 0,0:21:45.07,0:21:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diharuskan melaporkan kondisi\Nterkiniku pada penjamin setiap bulan.
Dialogue: 0,0:21:50.79,0:21:52.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulan depan,
Dialogue: 0,0:21:52.08,0:21:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan menyerahkan laporan\Npada Pasukan Kesatria.
Dialogue: 0,0:21:55.01,0:21:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hormat, Victoria Sellers.
Dialogue: 0,0:21:57.24,0:21:59.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya sangat formal, ya.
Dialogue: 0,0:22:00.99,0:22:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, apa boleh buat.
Dialogue: 0,0:22:02.37,0:22:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jodoh,
Dialogue: 0,0:22:03.84,0:22:05.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan ketemu lagi.
