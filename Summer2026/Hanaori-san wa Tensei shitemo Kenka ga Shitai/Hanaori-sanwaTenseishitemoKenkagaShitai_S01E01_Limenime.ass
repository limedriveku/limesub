Dialogue: 0,0:00:09.70,0:00:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kosong.
Dialogue: 0,0:00:12.28,0:00:15.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Narukami Ryusei,\Nseorang NEET.
Dialogue: 0,0:00:15.95,0:00:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang sudah patah semangat\Ntanpa tujuan hidup.
Dialogue: 0,0:00:19.69,0:00:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemberontak yang melawan arus,\Ndan kamar ini adalah bentengku.
Dialogue: 0,0:00:23.33,0:00:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak Sampah, ada tamu!
Dialogue: 0,0:00:27.23,0:00:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini,\Nadikku pun jadi kasar padaku.
Dialogue: 0,0:00:30.30,0:00:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu?\NMemangnya aku punya kenalan?
Dialogue: 0,0:00:42.23,0:00:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya ketemu, Raja Iblis Scarlet Eyes!
Dialogue: 0,0:00:47.44,0:00:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangka kamu juga\Nbereinkarnasi ke dunia ini.
Dialogue: 0,0:00:51.53,0:00:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kamu sudah melupakanku!
Dialogue: 0,0:00:54.87,0:00:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, kamu siapa?
Dialogue: 0,0:00:56.87,0:00:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:00:58.33,0:01:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanaori Meteor.
Dialogue: 0,0:01:00.50,0:01:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaya, cantik, dan populer.
Dialogue: 0,0:01:05.17,0:01:07.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aku datang untuk membunuhmu!
Dialogue: 0,0:01:07.55,0:01:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram!
Dialogue: 0,0:01:08.51,0:01:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu, telepon polisi!
Dialogue: 0,0:01:10.05,0:01:11.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:02:44.85,0:02:50.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, aku, Narukami Ryusei,\Ndulunya Raja Iblis dari dunia lain.
Dialogue: 0,0:02:50.94,0:02:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis ini adalah pahlawan\Nyang mengalahkanku!
Dialogue: 0,0:02:54.82,0:02:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia bereinkarnasi juga.
Dialogue: 0,0:02:56.95,0:03:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NTerlalu takut untuk berbicara?
Dialogue: 0,0:03:00.66,0:03:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sedang hidup di zaman damai,\Nkamu lagi melantur, ya?
Dialogue: 0,0:03:04.62,0:03:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang membuatnya senang?
Dialogue: 0,0:03:07.17,0:03:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku sekarang seorang NEET?
Dialogue: 0,0:03:11.59,0:03:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku menjelaskan gaya hidup\NNEET bernama Narukami Ryusei.
Dialogue: 0,0:03:16.47,0:03:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bangun langsung buka internet.
Dialogue: 0,0:03:18.47,0:03:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bermain gim sampai malam.
Dialogue: 0,0:03:20.47,0:03:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang-kadang aku menonton film,\Nacara TV, dan anime.
Dialogue: 0,0:03:22.97,0:03:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak sanggup jadi bahan gosip,
Dialogue: 0,0:03:25.85,0:03:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengunci diri di kamarku.
Dialogue: 0,0:03:28.56,0:03:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan adikku yang tadinya imut...
Dialogue: 0,0:03:32.02,0:03:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari kerja sana, Sampah.
Dialogue: 0,0:03:34.86,0:03:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:03:37.07,0:03:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu berat.
Dialogue: 0,0:03:38.75,0:03:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini yang namanya kehidupan?
Dialogue: 0,0:03:41.53,0:03:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya lebih mirip mayat hidup.
Dialogue: 0,0:03:46.25,0:03:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku cukup pandai dalam gim video.
Dialogue: 0,0:03:48.92,0:03:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih ke hanya bisa itu.
Dialogue: 0,0:03:50.99,0:03:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Main gim sepuluh jam sehari\Nbenar-benar bikin pegal.
Dialogue: 0,0:03:55.51,0:03:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membenamkan diri dalam gim PVP
Dialogue: 0,0:03:57.34,0:04:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku melupakan rasa bersalahku.
Dialogue: 0,0:04:00.93,0:04:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi pemain profesional.
Dialogue: 0,0:04:02.56,0:04:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu satu-satunya tujuan hidupku.
Dialogue: 0,0:04:06.35,0:04:08.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang siap bertarung?
Dialogue: 0,0:04:14.19,0:04:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, di mata masyarakat,\Naku tidak berbahaya.
Dialogue: 0,0:04:18.91,0:04:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu bicarakan?
Dialogue: 0,0:04:20.62,0:04:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, aku tidak bisa\Nmengabaikan Raja Iblis.
Dialogue: 0,0:04:24.32,0:04:27.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memberimu pelajaran.
Dialogue: 0,0:04:27.08,0:04:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merepotkan sekali dia ini.
Dialogue: 0,0:04:29.75,0:04:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh mengejutkan.
Dialogue: 0,0:04:31.04,0:04:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mengikuti jejak sihirmu,
Dialogue: 0,0:04:33.44,0:04:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata Raja Iblis-nya\Nlagi mengurung diri.
Dialogue: 0,0:04:36.76,0:04:38.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh sebuah kejatuhan!
Dialogue: 0,0:04:39.24,0:04:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang sedang bersenang-senang.
Dialogue: 0,0:04:41.59,0:04:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara mengatasi situasi ini, ya?
Dialogue: 0,0:04:43.76,0:04:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya ada perlu apa?
Dialogue: 0,0:04:47.52,0:04:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!\NJangan berpura-pura, dong!
Dialogue: 0,0:04:50.19,0:04:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang berpura-pura?
Dialogue: 0,0:04:51.52,0:04:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:04:52.86,0:04:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak mengakui\Nsemua yang kukatakan,
Dialogue: 0,0:04:56.11,0:04:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan terdengar\Nseperti orang gila!
Dialogue: 0,0:04:59.95,0:05:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terdengar seperti orang gila?
Dialogue: 0,0:05:03.37,0:05:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya memang gila?
Dialogue: 0,0:05:04.62,0:05:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:05:06.33,0:05:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sacred Knuckle!
Dialogue: 0,0:05:07.70,0:05:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aduh, aduh, aduh!\N- Rasakan Justice Fist dan matilah!
Dialogue: 0,0:05:14.25,0:05:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anggap saja rumah sendiri.
Dialogue: 0,0:05:19.97,0:05:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikmu imut.
Dialogue: 0,0:05:22.30,0:05:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:05:27.31,0:05:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat cerobohmu itu masih sama\Nseperti sebelum reinkarnasi.
Dialogue: 0,0:05:32.65,0:05:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu, musuh bebuyutanku.
Dialogue: 0,0:05:41.53,0:05:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu baik-baik saja?
Dialogue: 0,0:05:44.32,0:05:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan Gadis Bokong.
Dialogue: 0,0:05:46.03,0:05:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar Pahlawan Meteor!
Dialogue: 0,0:05:48.41,0:05:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat pakaian minim dan rok pendekmu?
Dialogue: 0,0:05:51.08,0:05:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti! Jangan ingatkan aku!
Dialogue: 0,0:05:53.00,0:05:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cara berpakaianmu sendiri.
Dialogue: 0,0:05:54.46,0:05:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pelecehan seksual!
Dialogue: 0,0:05:56.88,0:06:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menyerap energi roh\Nlangsung melalui kulitku!
Dialogue: 0,0:06:00.55,0:06:02.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya zirahku minimalis
Dialogue: 0,0:06:02.43,0:06:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk memperkuat diriku\Ndengan energi roh!
Dialogue: 0,0:06:05.18,0:06:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:06:06.76,0:06:08.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah!
Dialogue: 0,0:06:08.22,0:06:09.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kosakatamu jelek.
Dialogue: 0,0:06:09.93,0:06:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah pernah membunuhku, kan?
Dialogue: 0,0:06:11.64,0:06:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mati lagi!
Dialogue: 0,0:06:13.27,0:06:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahmu sendiri meninggalkan jejak sihir!
Dialogue: 0,0:06:16.81,0:06:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, mana mungkin\Naku akan melacakmu!
Dialogue: 0,0:06:19.32,0:06:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti sedang merencanakan hal jahat!
Dialogue: 0,0:06:21.78,0:06:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, ungkapkan rahasiamu!
Dialogue: 0,0:06:24.57,0:06:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya menggunakan sihir\Nuntuk mencari seseorang.
Dialogue: 0,0:06:26.82,0:06:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya kamu sempat mencariku?\NKamu rindu musuh bebuyutanmu?
Dialogue: 0,0:06:30.87,0:06:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan kamu.
Dialogue: 0,0:06:32.25,0:06:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.\NJangan bilang mau balas dendam?
Dialogue: 0,0:06:34.25,0:06:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku dulu.
Dialogue: 0,0:06:37.04,0:06:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih saja menyebalkan.
Dialogue: 0,0:06:38.92,0:06:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sebut aku begitu!
Dialogue: 0,0:06:40.80,0:06:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya pengurung diri,\Nbukan Raja Iblis lagi.
Dialogue: 0,0:06:43.05,0:06:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah itu lebih baik.
Dialogue: 0,0:06:44.59,0:06:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan Raja Iblis introver yang mengurung diri,\Npasti akan jahat lagi!
Dialogue: 0,0:06:48.89,0:06:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meteor juga bilang begitu.
Dialogue: 0,0:06:50.60,0:06:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kamu siapa?
Dialogue: 0,0:06:52.48,0:06:54.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Introver adalah dark side.
Dialogue: 0,0:06:54.64,0:06:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasa Inggris?
Dialogue: 0,0:06:55.77,0:06:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa berbicara bahasa Inggris!
Dialogue: 0,0:06:58.02,0:06:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bodoh, ya?
Dialogue: 0,0:06:59.44,0:07:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah bereinkarnasi, memangnya\Nsegampang itu berhenti jadi Raja Iblis?
Dialogue: 0,0:07:04.03,0:07:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya perlu penyucian diri dulu?
Dialogue: 0,0:07:06.03,0:07:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya berkontribusi pada masyarakat.
Dialogue: 0,0:07:08.12,0:07:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:07:09.41,0:07:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minimal memulung sampah\Natau jadi sukarelawan.
Dialogue: 0,0:07:12.08,0:07:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ogah.
Dialogue: 0,0:07:14.75,0:07:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lakukan kejahatan
Dialogue: 0,0:07:16.54,0:07:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu dikalahkan olehku lagi.
Dialogue: 0,0:07:18.17,0:07:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu tujuan aslimu!
Dialogue: 0,0:07:19.79,0:07:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin menghabiskan hidup\Ntanpa mengganggu siapa pun.
Dialogue: 0,0:07:23.96,0:07:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku akan percaya?
Dialogue: 0,0:07:27.72,0:07:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah kisah balas dendam\NRaja Iblis Kematian.
Dialogue: 0,0:07:31.31,0:07:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir istana\Nyang kerajaannya dihancurkan
Dialogue: 0,0:07:34.35,0:07:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi sosok abadi melalui kekuatan terlarang\Ndemi membalas dendam.
Dialogue: 0,0:07:39.40,0:07:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menciptakan pasukan mayat hidup,
Dialogue: 0,0:07:42.15,0:07:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meluluhlantakkan semua negeri musuhnya,
Dialogue: 0,0:07:45.36,0:07:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengubah benua ini menjadi\Nneraka berisi lautan darah
Dialogue: 0,0:07:49.12,0:07:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan gunungan mayat.
Dialogue: 0,0:07:51.70,0:07:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penguasa negeri orang mati, musuh bagi\Nseluruh makhluk hidup di benua ini.
Dialogue: 0,0:07:57.37,0:08:00.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis bermata merah darah\Nyang berlumur maut dan api.
Dialogue: 0,0:08:00.76,0:08:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir sosok seperti itu\Nakan hidup tenang
Dialogue: 0,0:08:03.08,0:08:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya karena bereinkarnasi?
Dialogue: 0,0:08:05.16,0:08:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin membalaskan\Ndendam Tuan Putri.
Dialogue: 0,0:08:07.97,0:08:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian dikalahkan olehmu.
Dialogue: 0,0:08:10.62,0:08:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis itu sudah tidak ada lagi.
Dialogue: 0,0:08:13.43,0:08:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, orang yang kamu cari itu...
Dialogue: 0,0:08:17.50,0:08:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, jiwa Tuan Putri.
Dialogue: 0,0:08:22.06,0:08:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinannya ada,\Njadi aku sangat ingin mencarinya.
Dialogue: 0,0:08:27.39,0:08:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jejak jiwanya sama sekali\Ntidak ketemu di dunia ini.
Dialogue: 0,0:08:32.28,0:08:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sampai membuang kemanusiaanmu\Nuntuk membalaskan dendamnya.
Dialogue: 0,0:08:36.40,0:08:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sangat berarti bagimu.
Dialogue: 0,0:08:40.71,0:08:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bwahahaha!
Dialogue: 0,0:08:42.50,0:08:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar cengeng!
Dialogue: 0,0:08:46.42,0:08:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu alasanmu mengurung diri?\NPayah banget!
Dialogue: 0,0:08:52.76,0:08:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal tadi.
Dialogue: 0,0:08:54.61,0:08:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:08:56.43,0:08:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis malah berlagak manusia.
Dialogue: 0,0:08:59.64,0:09:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak menyimak, ya?\NAwalnya aku manusia juga.
Dialogue: 0,0:09:01.85,0:09:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sepertimu.
Dialogue: 0,0:09:04.32,0:09:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah pahlawan.
Dialogue: 0,0:09:06.40,0:09:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata yang dibuat\Nuntuk menghancurkan Raja Iblis.
Dialogue: 0,0:09:10.49,0:09:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi...
Dialogue: 0,0:09:11.99,0:09:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus tanggung jawab!
Dialogue: 0,0:09:14.28,0:09:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:15.74,0:09:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan terlahir\Nkalau bukan karenamu.
Dialogue: 0,0:09:19.79,0:09:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus bertanggung jawab.
Dialogue: 0,0:09:21.67,0:09:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah seperti gadis posesif!
Dialogue: 0,0:09:24.75,0:09:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak bermaksud aneh-aneh!
Dialogue: 0,0:09:27.63,0:09:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan begitu!
Dialogue: 0,0:09:29.38,0:09:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu.
Dialogue: 0,0:09:30.22,0:09:33.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada yang harus kamu katakan padaku!
Dialogue: 0,0:09:35.93,0:09:36.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:09:36.85,0:09:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon maaf yang sebesar-besarnya.
Dialogue: 0,0:09:38.60,0:09:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu!
Dialogue: 0,0:09:39.56,0:09:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matilah! Aura Knuckle!
Dialogue: 0,0:09:42.35,0:09:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:09:47.27,0:09:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesum.
Dialogue: 0,0:09:51.03,0:09:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menghilang.
Dialogue: 0,0:09:52.32,0:09:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dipikirkan.
Dialogue: 0,0:09:54.16,0:09:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang.
Dialogue: 0,0:09:55.24,0:09:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:09:57.60,0:10:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya, kamu harus berubah.
Dialogue: 0,0:10:00.96,0:10:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa memaafkanmu,\Ntapi Meteor tidak!
Dialogue: 0,0:10:03.79,0:10:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu siapa?
Dialogue: 0,0:10:07.88,0:10:12.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin melihatnya lagi.\NAku mau cari kerja saja, deh.
Dialogue: 0,0:10:14.13,0:10:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dapat pekerjaan?
Dialogue: 0,0:10:16.22,0:10:18.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kiamat sudah dekat!
Dialogue: 0,0:10:18.18,0:10:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hari pertamaku.
Dialogue: 0,0:10:20.44,0:10:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai guru di sekolah putri.\NAku beruntung mendapatkan pekerjaan
Dialogue: 0,0:10:23.37,0:10:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa motivasimu?
Dialogue: 0,0:10:25.60,0:10:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin\Nterus merepotkanmu dan Ibu.
Dialogue: 0,0:10:29.15,0:10:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena gadis itu, kan?
Dialogue: 0,0:10:30.86,0:10:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Glek!\NAku tidak bisa membantah...
Dialogue: 0,0:10:39.73,0:10:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mungkin tidak bisa melepas\Nmasa lalunya sebagai pahlawan.
Dialogue: 0,0:10:43.87,0:10:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku juga sama seperti dia.
Dialogue: 0,0:10:49.17,0:10:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia masih membutuhkan\NRaja Iblis dalam hidupnya.
Dialogue: 0,0:10:53.97,0:10:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan Raja Iblis?
Dialogue: 0,0:10:56.59,0:10:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cerita dari dunia yang sangat jauh.
Dialogue: 0,0:10:59.68,0:11:04.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kita hidup di dunia yang damai\Ntanpa pedang dan sihir.
Dialogue: 0,0:11:05.56,0:11:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja,\Nada satu masalah tidak terduga...
Dialogue: 0,0:11:09.73,0:11:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:11:11.69,0:11:13.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut kabedon.
Dialogue: 0,0:11:16.99,0:11:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengajar di kelas si pahlawan!
Dialogue: 0,0:11:34.67,0:11:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu tentang guru baru?
Dialogue: 0,0:11:36.97,0:11:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampan, kan?
Dialogue: 0,0:11:38.22,0:11:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:11:39.47,0:11:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang membicarakan guru baru.
Dialogue: 0,0:11:42.26,0:11:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa pendapatmu tentang Narukami-sensei?
Dialogue: 0,0:11:45.02,0:11:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak peduli.
Dialogue: 0,0:11:47.31,0:11:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahmu begitu?
Dialogue: 0,0:11:49.10,0:11:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan kembali ke Zaman Kegelapan.
Dialogue: 0,0:11:52.36,0:11:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:11:54.11,0:11:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan guru baru?\NKamu sebegitu penasarannya
Dialogue: 0,0:11:57.70,0:11:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:11:58.95,0:12:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kelas lain pun membicarakannya.
Dialogue: 0,0:12:01.95,0:12:04.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seperti\Nseluruh sekolah menyukainya.
Dialogue: 0,0:12:04.54,0:12:06.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dih...
Dialogue: 0,0:12:06.83,0:12:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang mereka lihat darinya?
Dialogue: 0,0:12:09.25,0:12:11.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada aura gelap dan misterius padanya.
Dialogue: 0,0:12:11.75,0:12:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya dia Raja Iblis.
Dialogue: 0,0:12:13.38,0:12:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, dia tenang dan dewasa.
Dialogue: 0,0:12:15.59,0:12:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya introver.
Dialogue: 0,0:12:17.47,0:12:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, dia itu iblis yang menyamar.
Dialogue: 0,0:12:22.51,0:12:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meteor mengatakan hal yang sama.
Dialogue: 0,0:12:24.01,0:12:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kamu jadi ibuku?
Dialogue: 0,0:12:29.06,0:12:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini disebut kabedon.
Dialogue: 0,0:12:30.31,0:12:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:31.81,0:12:35.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan di sekolah?\NSebagai guru pula.
Dialogue: 0,0:12:35.78,0:12:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu yang menyuruhku bekerja?
Dialogue: 0,0:12:38.24,0:12:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti aku memintamu\Njadi wali kelasku!
Dialogue: 0,0:12:42.12,0:12:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang mau mengambil alih sekolah?
Dialogue: 0,0:12:45.20,0:12:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus repot-repot\Nmelakukan itu?
Dialogue: 0,0:12:48.12,0:12:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para gadis yang memujamu\Npasti membuatmu besar kepala.
Dialogue: 0,0:12:51.33,0:12:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti yang kamu bicarakan.
Dialogue: 0,0:12:54.00,0:12:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan, kehidupan sekolahku\Nsudah berakhir di sini.
Dialogue: 0,0:12:57.97,0:13:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah kamu saja, tapi bisa berhenti\Nmemojokkanku ke dinding?
Dialogue: 0,0:13:01.97,0:13:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:02.85,0:13:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingin membicarakan sesuatu, kan?
Dialogue: 0,0:13:06.06,0:13:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hampir lupa!\NAku akan...
Dialogue: 0,0:13:10.19,0:13:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita lanjutkan nanti.
Dialogue: 0,0:13:11.77,0:13:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa, sih?
Dialogue: 0,0:13:16.94,0:13:18.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melelahkan...
Dialogue: 0,0:13:18.69,0:13:22.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka aku akan menjadi\Ngurunya pahlawan itu.
Dialogue: 0,0:13:22.82,0:13:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Narukami-sensei?
Dialogue: 0,0:13:25.20,0:13:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatan lelah.
Dialogue: 0,0:13:26.83,0:13:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku menganggur cukup lama,\Njadi susah berbaur dengan murid.
Dialogue: 0,0:13:32.67,0:13:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:13:33.96,0:13:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi ini sekolah putri.
Dialogue: 0,0:13:36.09,0:13:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru laki-laki\Npasti menarik perhatian para siswi.
Dialogue: 0,0:13:39.92,0:13:41.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu terburu-buru membiasakan diri.
Dialogue: 0,0:13:41.93,0:13:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku akan berusaha.
Dialogue: 0,0:13:49.81,0:13:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis Scarlet Eyes,
Dialogue: 0,0:13:52.19,0:13:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi guru kikuk.
Dialogue: 0,0:13:54.31,0:13:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti menyesal datang ke sini.
Dialogue: 0,0:13:58.61,0:14:01.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengungkap semua rencana jahatmu.
Dialogue: 0,0:14:01.53,0:14:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Brave Aura!
Dialogue: 0,0:14:03.91,0:14:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura kepahlawananku
Dialogue: 0,0:14:05.91,0:14:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti membuatmu sangat kerepotan!
Dialogue: 0,0:14:10.20,0:14:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa?
Dialogue: 0,0:14:13.83,0:14:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia malah menarik perhatiannya\Ndengan tatapan menggoda.
Dialogue: 0,0:14:18.13,0:14:19.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suram...
Dialogue: 0,0:14:20.92,0:14:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kamu aneh.
Dialogue: 0,0:14:22.97,0:14:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Hanaori-kun?
Dialogue: 0,0:14:24.68,0:14:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada masalah?
Dialogue: 0,0:14:26.60,0:14:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Matsurika... Bukan apa-apa.
Dialogue: 0,0:14:29.60,0:14:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, deh, Meteor bertingkah aneh\Nsejak guru baru kita tiba.
Dialogue: 0,0:14:33.73,0:14:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:14:34.39,0:14:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!
Dialogue: 0,0:14:35.65,0:14:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana pendapatmu tentang\NNarukami-sensei?
Dialogue: 0,0:14:42.28,0:14:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa dia tidak suka laki-laki.
Dialogue: 0,0:14:44.78,0:14:46.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menggemaskan sekali.
Dialogue: 0,0:14:47.78,0:14:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Meteor, mau saran?
Dialogue: 0,0:14:50.54,0:14:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:51.70,0:14:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan melihat guru kita dengan\Ntatapan menggoda.
Dialogue: 0,0:14:55.25,0:14:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tebakanku benar, ya?
Dialogue: 0,0:15:01.67,0:15:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa memahami\Napa yang kamu katakan.
Dialogue: 0,0:15:04.38,0:15:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah paham!
Dialogue: 0,0:15:07.68,0:15:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ih, jorok!
Dialogue: 0,0:15:11.81,0:15:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagi?
Dialogue: 0,0:15:13.35,0:15:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Supaya jelas, kita adalah musuh.
Dialogue: 0,0:15:16.44,0:15:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu guru dan murid.
Dialogue: 0,0:15:17.81,0:15:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada yang bisa kupelajari\Ndari Raja Iblis!
Dialogue: 0,0:15:21.57,0:15:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan temanku sampai salah paham!
Dialogue: 0,0:15:23.90,0:15:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bukan teman, hubungan kita\Ncuma soal bunuh atau dibunuh!
Dialogue: 0,0:15:27.49,0:15:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicara apa dia di dunia sedamai ini?
Dialogue: 0,0:15:30.83,0:15:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar baik-baik!\NHubungan ini hanya rahasia kita berdua!
Dialogue: 0,0:15:35.87,0:15:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun!
Dialogue: 0,0:15:38.17,0:15:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejoli muda!
Dialogue: 0,0:15:40.13,0:15:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tapi jadi rahasia kita bertiga!
Dialogue: 0,0:15:47.76,0:15:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kuucapkan tadi?
Dialogue: 0,0:15:50.76,0:15:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Hubungan kita cuma soal\Nbunuh atau dibunuh."
Dialogue: 0,0:15:55.93,0:15:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja,\NRokudo-sensei pasti sudah terbiasa,
Dialogue: 0,0:15:59.65,0:16:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tahu ini hanya salah paham.
Dialogue: 0,0:16:01.77,0:16:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:16:03.94,0:16:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nitu jadi rahasia kita berempat.
Dialogue: 0,0:16:06.82,0:16:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, jadi lima orang.
Dialogue: 0,0:16:09.53,0:16:12.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lima orang tambah seekor kucing!
Dialogue: 0,0:16:17.46,0:16:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Narukami Ryusei.
Dialogue: 0,0:16:20.08,0:16:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Iblis dari dunia lain\Nyang bereinkarnasi ke Jepang modern.
Dialogue: 0,0:16:23.67,0:16:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini aku mengajar di sekolah putri.
Dialogue: 0,0:16:26.88,0:16:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup damai di dunia
Dialogue: 0,0:16:29.89,0:16:31.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa pedang dan sihir.
Dialogue: 0,0:16:31.76,0:16:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya begitu.
Dialogue: 0,0:16:33.85,0:16:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seandainya tidak ada mantan pahlawan ini.
Dialogue: 0,0:16:37.31,0:16:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanaori-san, kamu memahami bagian ini?
Dialogue: 0,0:16:41.81,0:16:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengabaikanku!
Dialogue: 0,0:16:43.32,0:16:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tatapannya tajam banget! Seram!
Dialogue: 0,0:16:47.32,0:16:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengabaikan gurumu di kelas.
Dialogue: 0,0:16:49.86,0:16:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:16:51.03,0:16:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku pahlawan.
Dialogue: 0,0:16:52.82,0:16:55.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi hanya bisa membasmi\Norang-orang jahat.
Dialogue: 0,0:16:55.41,0:16:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini bicara apa?
Dialogue: 0,0:16:57.29,0:17:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kurasa tidak ada bangsawan korup
Dialogue: 0,0:17:00.87,0:17:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau petualang sombong\Nuntuk kamu hajar di sini.
Dialogue: 0,0:17:04.11,0:17:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak punya cara mengisi\Nenergi kepahlawananmu.
Dialogue: 0,0:17:06.46,0:17:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bentar, kamu pikir pahlawan itu apa?
Dialogue: 0,0:17:09.63,0:17:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu...
Dialogue: 0,0:17:11.43,0:17:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menantangmu, Raja Iblis!
Dialogue: 0,0:17:16.31,0:17:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu hanya ingin melampiaskannya, kan?
Dialogue: 0,0:17:18.59,0:17:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:17:20.31,0:17:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatanku ada\Nsemata-mata untuk mengalahkanmu.
Dialogue: 0,0:17:26.26,0:17:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:17:27.48,0:17:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba dapatkan nilai bagus.
Dialogue: 0,0:17:31.11,0:17:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah... Itu...\NAku harus pergi.
Dialogue: 0,0:17:34.12,0:17:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:17:40.08,0:17:41.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang siswi menatapku!
Dialogue: 0,0:17:41.96,0:17:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku namanya Nagamori Matsurika.
Dialogue: 0,0:17:43.88,0:17:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat menonjol sebagai ketua kelas!
Dialogue: 0,0:17:47.24,0:17:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyangka akan dipelototi
Dialogue: 0,0:17:48.63,0:17:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}oleh siswi selain Meteor.
Dialogue: 0,0:17:51.05,0:17:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Sensei, ada apa?
Dialogue: 0,0:17:53.59,0:17:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali, Satsuki.
Dialogue: 0,0:17:55.89,0:17:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku berbuat salah?
Dialogue: 0,0:17:58.39,0:17:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tentang Meteor?
Dialogue: 0,0:17:59.60,0:18:01.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, tapi Nagamori-kun.
Dialogue: 0,0:18:01.69,0:18:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, dia.
Dialogue: 0,0:18:02.56,0:18:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Matsurika tidak suka\Ndengan laki-laki.
Dialogue: 0,0:18:09.23,0:18:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah.
Dialogue: 0,0:18:10.78,0:18:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bersyukur?
Dialogue: 0,0:18:11.99,0:18:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencoba melambai padanya.
Dialogue: 0,0:18:13.74,0:18:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo!
Dialogue: 0,0:18:15.37,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti menyapa kucing.
Dialogue: 0,0:18:17.65,0:18:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mendengarnya!
Dialogue: 0,0:18:19.62,0:18:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah muncul gadis merepotkan.
Dialogue: 0,0:18:22.41,0:18:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku memenangkan yang ini!
Dialogue: 0,0:18:24.71,0:18:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya lagi bersaing soal apa?
Dialogue: 0,0:18:32.05,0:18:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka takut kekuatan Raja Iblisku.
Dialogue: 0,0:18:34.38,0:18:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedih.
Dialogue: 0,0:18:43.23,0:18:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hai, Sensei!
Dialogue: 0,0:18:45.06,0:18:47.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia baik!
Dialogue: 0,0:18:51.23,0:18:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akrab sekali dengan dia...\NMaksudku guru kita.
Dialogue: 0,0:18:56.20,0:18:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, begitulah.
Dialogue: 0,0:18:57.91,0:18:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengobrol lebih banyak.
Dialogue: 0,0:18:59.74,0:19:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku harus\Nmeminta pelajaran tambahan?
Dialogue: 0,0:19:01.91,0:19:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah sedekat itu?
Dialogue: 0,0:19:04.79,0:19:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya jangan dilanjutkan,\Ndia pasti pria berbahaya!
Dialogue: 0,0:19:08.38,0:19:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meteor mengatakan hal yang sama!
Dialogue: 0,0:19:10.30,0:19:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu katamu sendiri.
Dialogue: 0,0:19:11.59,0:19:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang cemburu, nih!
Dialogue: 0,0:19:14.76,0:19:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:19:15.76,0:19:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jelas cemburu.
Dialogue: 0,0:19:18.47,0:19:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:19:19.39,0:19:20.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu ikutan juga!
Dialogue: 0,0:19:20.43,0:19:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang cemburu!\NCemburu!
Dialogue: 0,0:19:23.23,0:19:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hentikan!\N- Cemburu!
Dialogue: 0,0:19:27.85,0:19:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra— Maksudku, Sensei!
Dialogue: 0,0:19:30.40,0:19:32.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanaori-kun...
Dialogue: 0,0:19:37.20,0:19:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izin duduk di sini.
Dialogue: 0,0:19:39.24,0:19:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:19:41.83,0:19:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau lihat siapa yang bisa\Nmakan lebih banyak?
Dialogue: 0,0:19:43.83,0:19:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, terima kasih.
Dialogue: 0,0:19:44.83,0:19:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makan apa?
Dialogue: 0,0:19:46.42,0:19:47.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Set makan siang Jepang.
Dialogue: 0,0:19:47.67,0:19:48.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membosankan.
Dialogue: 0,0:19:48.29,0:19:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu?
Dialogue: 0,0:19:49.75,0:19:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spageti bolognese.
Dialogue: 0,0:19:50.75,0:19:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai mengotori seragammu, ya.
Dialogue: 0,0:19:54.84,0:19:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir itu bisa mencegah noda saus, lo.
Dialogue: 0,0:19:57.97,0:20:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu semangat banget kalau soal makanan.
Dialogue: 0,0:20:01.30,0:20:03.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rokudo Sakura.
Dialogue: 0,0:20:03.52,0:20:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wali kelas 2-2.
Dialogue: 0,0:20:05.60,0:20:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang melihat guru laki-laki\Ndigoda oleh para gadis!
Dialogue: 0,0:20:10.27,0:20:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak kelelahan.
Dialogue: 0,0:20:11.86,0:20:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:12.73,0:20:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada masalah cinta!
Dialogue: 0,0:20:14.53,0:20:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tentang siswi yang satu itu?
Dialogue: 0,0:20:16.70,0:20:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, semuanya tentang diriku sendiri.
Dialogue: 0,0:20:20.91,0:20:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena cinta, kan?
Dialogue: 0,0:20:22.45,0:20:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak begitu mengerti,\Ntapi aku berasumsi begitu!
Dialogue: 0,0:20:25.91,0:20:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menderita dalam diam.\NBicarakan saja.
Dialogue: 0,0:20:30.42,0:20:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengungkapkan perasaan\Nadalah hal yang penting.
Dialogue: 0,0:20:32.59,0:20:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka komedi romantis!
Dialogue: 0,0:22:06.64,0:22:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf memanggilmu sepulang sekolah.
Dialogue: 0,0:22:08.89,0:22:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu inginkan?
Dialogue: 0,0:22:10.93,0:22:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bertingkah aneh.
Dialogue: 0,0:22:13.35,0:22:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimusuhi Matsurika membuatmu tertekan?
Dialogue: 0,0:22:16.34,0:22:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah merasakan kekuatanku\Ndi area sekolah?
Dialogue: 0,0:22:20.32,0:22:21.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, memangnya kenapa?
Dialogue: 0,0:22:21.90,0:22:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:22:24.03,0:22:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut itu berdampak pada para murid.
Dialogue: 0,0:22:28.79,0:22:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, tentang ilmu hitam\Nberdampak negatif terhadap kehidupan?
Dialogue: 0,0:22:34.01,0:22:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya propaganda Gereja Besar.
Dialogue: 0,0:22:37.79,0:22:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengkhawatirkan hal itu?
Dialogue: 0,0:22:42.34,0:22:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah seberapa besar kekuatan asli\NMeteor yang masih tersisa.
Dialogue: 0,0:22:47.01,0:22:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti terlalu membebani\Nbagi kehidupan warga sipil.
Dialogue: 0,0:22:50.47,0:22:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti ketakutan.
Dialogue: 0,0:22:52.10,0:22:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah menatap\Nsebelum aku membunuhmu.
Dialogue: 0,0:22:54.52,0:22:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram!
Dialogue: 0,0:22:55.56,0:22:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gunakan kekuatanmu\Ntanpa alasan yang jelas.
Dialogue: 0,0:22:58.19,0:23:00.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memerintahku.
Dialogue: 0,0:23:00.04,0:23:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya ada yang melacakmu\Nseperti kamu melacakku.
Dialogue: 0,0:23:05.16,0:23:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu...
Dialogue: 0,0:23:09.33,0:23:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa teman atau musuh...
Dialogue: 0,0:23:12.79,0:23:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku\Nmemperkenalkan siswi baru kita.
Dialogue: 0,0:23:17.00,0:23:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri salam kepada Kuraishi Mana-san\Ndan Takigawa Minto-san.
Dialogue: 0,0:23:23.72,0:23:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita musuh.
Dialogue: 0,0:23:26.74,0:23:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami siswi cantik baru misterius,\NTakigawa Minto...
Dialogue: 0,0:23:29.93,0:23:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kuraishi Mana.
Dialogue: 0,0:23:31.64,0:23:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasakan sesuatu yang manis.
Dialogue: 0,0:23:33.56,0:23:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku perlu tahu apa itu!
Dialogue: 0,0:23:36.02,0:23:38.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuma rakus.
Dialogue: 0,0:23:38.27,0:23:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetot! Kamu salah!
