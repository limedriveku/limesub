Dialogue: 0,0:00:52.74,0:00:56.16,sign,,0000,0000,0000,,HANAORI METEOR\NREINKARNASI PAHLAWAN
Dialogue: 0,0:01:53.93,0:02:00.98,sign,,0000,0000,0000,,HANAORI-SAN STILL WANTS\NTO FIGHT IN THE NEXT LIFE
Dialogue: 0,0:02:07.82,0:02:10.99,sign,,0000,0000,0000,,EPISODE 2: PENYIHIR OZ
Dialogue: 0,0:02:10.99,0:02:14.95,sign,,0000,0000,0000,,MURID BARU MISTERIUS
Dialogue: 0,0:02:14.95,0:02:18.83,sign,,0000,0000,0000,,KURAISHI MANA
Dialogue: 0,0:02:26.67,0:02:30.17,sign,,0000,0000,0000,,TAKIGAWA MINTO
Dialogue: 0,0:02:55.94,0:03:01.04,sign,,0000,0000,0000,,SEDANG MEMPERKENALKAN SMA PUTRI MITSURUGI
Dialogue: 0,0:03:40.03,0:03:41.41,sign,,0000,0000,0000,,AROMA MANIS SEPERTI SIHIR
Dialogue: 0,0:04:18.45,0:04:21.54,sign,,0000,0000,0000,,LALU, SEPULANG SEKOLAH
Dialogue: 0,0:04:31.58,0:04:39.05,sign,,0000,0000,0000,,WAA!
Dialogue: 0,0:04:39.05,0:04:40.00,sign,,0000,0000,0000,,TATAPAN SERIUS!
Dialogue: 0,0:05:10.21,0:05:13.13,sign,,0000,0000,0000,,SEMPIT
Dialogue: 0,0:05:13.13,0:05:25.60,sign,,0000,0000,0000,,MOMEN KLASIK TERJEBAK DI LOKER
Dialogue: 0,0:05:46.20,0:05:48.41,sign,,0000,0000,0000,,PWEH
Dialogue: 0,0:05:48.41,0:05:51.12,sign,,0000,0000,0000,,GELISAH
Dialogue: 0,0:06:21.69,0:06:22.83,sign,,0000,0000,0000,,JRENG!
Dialogue: 0,0:06:27.03,0:06:29.70,sign,,0000,0000,0000,,TERTANGKAP BASAH
Dialogue: 0,0:06:43.55,0:06:44.42,sign,,0000,0000,0000,,IDENTITAS ASLI MEREKA ADALAH...
Dialogue: 0,0:06:46.47,0:06:47.95,sign,,0000,0000,0000,,SRET!
Dialogue: 0,0:07:11.41,0:07:15.62,sign,,0000,0000,0000,,KESAL!
Dialogue: 0,0:07:15.62,0:07:16.42,sign,,0000,0000,0000,,BUU
Dialogue: 0,0:07:23.30,0:07:26.00,sign,,0000,0000,0000,,PWEH
Dialogue: 0,0:07:30.97,0:07:35.94,sign,,0000,0000,0000,,MASALAHNYA BERES?
Dialogue: 0,0:07:35.94,0:07:41.15,sign,,0000,0000,0000,,JALAN HIDUP SANG PAHLAWAN
Dialogue: 0,0:07:47.61,0:07:48.48,sign,,0000,0000,0000,,ANGGUN
Dialogue: 0,0:08:26.19,0:08:29.16,sign,,0000,0000,0000,,BAWA BARANG-BARANG
Dialogue: 0,0:08:51.26,0:08:53.92,sign,,0000,0000,0000,,KISAH PUTRI PAHLAWAN CAHAYA
Dialogue: 0,0:08:53.92,0:08:56.64,sign,,0000,0000,0000,,DAN PANGERAN KEGELAPAN
Dialogue: 0,0:09:50.95,0:09:53.99,sign,,0000,0000,0000,,KISAH PUTRI SUCI ELF
Dialogue: 0,0:09:53.99,0:09:55.71,sign,,0000,0000,0000,,DAN SEKTE NAGA JAHAT
Dialogue: 0,0:10:40.12,0:10:43.02,sign,,0000,0000,0000,,SEGERA HADIR!
Dialogue: 0,0:10:43.84,0:10:45.87,sign,,0000,0000,0000,,SETELAH DIINGAT LAGI, TERNYATA SURAM
Dialogue: 0,0:10:49.01,0:10:50.59,sign,,0000,0000,0000,,BABU
Dialogue: 0,0:10:52.11,0:10:56.01,sign,,0000,0000,0000,,SAATNYA MELIHAT IKAN PAUS
Dialogue: 0,0:11:18.28,0:11:21.55,sign,,0000,0000,0000,,MEMORI PERTEMPURAN MELAWAN RAJA IBLIS
Dialogue: 0,0:12:37.70,0:12:39.66,sign,,0000,0000,0000,,SIAPA ORANG YANG INGIN KAMU TEMUI?
Dialogue: 0,0:13:06.27,0:13:08.19,sign,,0000,0000,0000,,PWEH
Dialogue: 0,0:13:10.35,0:13:12.31,sign,,0000,0000,0000,,APA HAL TERSULIT SETELAH MENJADI PAHLAWAN?
Dialogue: 0,0:13:21.24,0:13:23.20,sign,,0000,0000,0000,,APA YANG PALING DIBUTUHKAN\NSEORANG PAHLAWAN?
Dialogue: 0,0:13:32.25,0:13:34.21,sign,,0000,0000,0000,,APA HAL PALING BERHARGA BAGIMU?
Dialogue: 0,0:13:42.34,0:13:44.30,sign,,0000,0000,0000,,APA ARTI PAHLAWAN BAGIMU?
Dialogue: 0,0:13:53.77,0:13:55.95,sign,,0000,0000,0000,,PROFESIONAL\NJALAN HIDUP SANG PAHLAWAN, TAMAT
Dialogue: 0,0:14:00.49,0:14:01.99,sign,,0000,0000,0000,,HANAORI-SAN STILL WANTS\NTO FIGHT IN THE NEXT LIFE
Dialogue: 0,0:14:04.49,0:14:05.99,sign,,0000,0000,0000,,HANAORI-SAN STILL WANTS\NTO FIGHT IN THE NEXT LIFE
Dialogue: 0,0:14:09.29,0:14:13.37,sign,,0000,0000,0000,,MANTAN PAHLAWAN
Dialogue: 0,0:14:13.37,0:14:16.94,sign,,0000,0000,0000,,AWAL MULA
Dialogue: 0,0:14:47.49,0:14:48.95,sign,,0000,0000,0000,,BERSINAR
Dialogue: 0,0:15:00.21,0:15:02.27,sign,,0000,0000,0000,,KESAL
Dialogue: 0,0:15:05.18,0:15:09.14,sign,,0000,0000,0000,,HANTU? MONSTER? MAKHLUK LAINNYA?
Dialogue: 0,0:15:44.42,0:15:46.80,sign,,0000,0000,0000,,MELOTOT
Dialogue: 0,0:15:54.22,0:15:55.12,sign,,0000,0000,0000,,MELEDEK
Dialogue: 0,0:16:09.31,0:16:11.58,sign,,0000,0000,0000,,TAMAN BERHANTU
Dialogue: 0,0:16:27.61,0:16:28.84,sign,,0000,0000,0000,,NYENGIR
Dialogue: 0,0:16:33.89,0:16:36.10,sign,,0000,0000,0000,,MOMEN HOROR KLASIK
Dialogue: 0,0:17:01.75,0:17:07.76,sign,,0000,0000,0000,,AH, HIDUP TAK LEPAS DARI KOMEDI ROMANTIS
Dialogue: 0,0:17:22.23,0:17:24.44,sign,,0000,0000,0000,,MUSUH PERTAMA
Dialogue: 0,0:17:30.91,0:17:32.11,sign,,0000,0000,0000,,LOGIKA YANG BODOH
Dialogue: 0,0:17:56.67,0:18:00.64,sign,,0000,0000,0000,,SUDAH WAKTUNYA
Dialogue: 0,0:18:04.86,0:18:07.57,sign,,0000,0000,0000,,LANGSUNG BOHONG
Dialogue: 0,0:19:36.03,0:19:36.94,sign,,0000,0000,0000,,PARA PEJUANG
Dialogue: 0,0:22:07.01,0:22:09.10,sign,,0000,0000,0000,,MENGULAS KEMBALI YANG TERJADI
Dialogue: 0,0:22:57.48,0:23:00.19,sign,,0000,0000,0000,,HMPH
Dialogue: 0,0:23:14.62,0:23:15.55,sign,,0000,0000,0000,,PWEH
Dialogue: 0,0:23:16.58,0:23:20.61,sign,,0000,0000,0000,,KESAL!
Dialogue: 0,0:23:22.80,0:23:25.01,sign,,0000,0000,0000,,SEKIAN!
Dialogue: 0,0:23:25.01,0:23:25.65,sign,,0000,0000,0000,,EPISODE SELANJUTNYA
Dialogue: 0,0:23:37.31,0:23:40.02,sign,,0000,0000,0000,,EPISODE 3: LARI TENGAH MALAM
Dialogue: 0,0:23:40.02,0:23:43.72,sign,,0000,0000,0000,,HANAORI-SAN: LOVE IS WAR\NBAHKAN SEBAGAI IDOLA DI KEHIDUPAN SELANJUTNYA
Dialogue: 0,0:23:43.72,0:23:48.01,sign,,0000,0000,0000,,KARENA HIKAWA HEKIRU-SENSEI BAIK HATI,\NBIKIN APA PUN BUAT KARTU PENUTUP PASTI DIMAAFKAN
Dialogue: 0,0:23:48.01,0:23:50.03,sign,,0000,0000,0000,,ILUSTRASI: AKASAKA AKA
Dialogue: 0,0:00:04.66,0:00:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Narukami-sensei?
Dialogue: 0,0:00:06.40,0:00:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:00:07.06,0:00:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak keberatan...
Dialogue: 0,0:00:08.53,0:00:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong pandu murid baru\Ndi kelasku keliling sekolah?
Dialogue: 0,0:00:12.66,0:00:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada urusan mendadak.
Dialogue: 0,0:00:14.83,0:00:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:00:16.80,0:00:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kuraishi, mohon bimbingannya.
Dialogue: 0,0:00:19.92,0:00:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Takigawa, mohon bimbingannya.
Dialogue: 0,0:00:22.72,0:00:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Narukami, wali kelas 2-1.
Dialogue: 0,0:00:25.12,0:00:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya, ya.
Dialogue: 0,0:00:26.71,0:00:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Narukami-sensei juga baru mengajar di sini,
Dialogue: 0,0:00:29.86,0:00:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian bebas merepotkan beliau.
Dialogue: 0,0:00:32.83,0:00:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokudo-sensei!
Dialogue: 0,0:00:34.68,0:00:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah pasti ini harem, kan?\NParah!
Dialogue: 0,0:00:36.42,0:00:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang harem.\NDasar buaya.
Dialogue: 0,0:00:38.45,0:00:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salah paham!\NHentikan!
Dialogue: 0,0:02:14.95,0:02:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuraishi Mana.
Dialogue: 0,0:02:16.86,0:02:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis jangkung yang santai.
Dialogue: 0,0:02:18.83,0:02:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaranya lembut, baik hati, ramah,\Ndan tipe yang disukai banyak orang.
Dialogue: 0,0:02:23.39,0:02:26.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kadang cepat menyimpulkan sesuatu\Ndan agak ceroboh.
Dialogue: 0,0:02:26.67,0:02:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takigawa Minto.
Dialogue: 0,0:02:28.85,0:02:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendek dan pemarah.
Dialogue: 0,0:02:30.17,0:02:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tipe orang yang blakblakan tanpa basa-basi.
Dialogue: 0,0:02:33.57,0:02:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak canggung, cepat berbaur\Nsejak hari pertama pindah sekolah.
Dialogue: 0,0:02:37.64,0:02:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua sebenarnya teman lama,
Dialogue: 0,0:02:40.08,0:02:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kebetulan pindah sekolah\Ndi waktu yang sama!
Dialogue: 0,0:02:43.28,0:02:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:02:44.64,0:02:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma takdir sial.
Dialogue: 0,0:02:47.25,0:02:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang pindah bersamaan, tepat saat mantan\NRaja Iblis dan Pahlawan datang ke sekolah ini.
Dialogue: 0,0:02:53.01,0:02:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa curigaku terlalu berlebihan?
Dialogue: 0,0:02:55.94,0:02:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}SMA Putri Mitsurugi ini sekolah bergengsi
Dialogue: 0,0:02:58.40,0:03:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan moto unggul dalam akademik dan olahraga.
Dialogue: 0,0:03:01.54,0:03:04.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suasana di sini cukup bebas\Ndan banyak pilihan ekskulnya.
Dialogue: 0,0:03:04.72,0:03:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya sekolah ini sangat menghargai\Ninisiatif para murid.
Dialogue: 0,0:03:08.27,0:03:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekolahnya modis dan keren, ya!
Dialogue: 0,0:03:10.69,0:03:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konon arsitekturnya meniru\Nnuansa kota di Italia.
Dialogue: 0,0:03:13.25,0:03:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekolah putri seperti ini\Nbiasanya muridnya munafik.
Dialogue: 0,0:03:16.38,0:03:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minto!
Dialogue: 0,0:03:17.72,0:03:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah sana gor olahraga luar ruangan.
Dialogue: 0,0:03:19.80,0:03:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang di sini lapangan utama.
Dialogue: 0,0:03:21.34,0:03:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ujung sana juga ada\Nlapangan tenis dan kolam renang.
Dialogue: 0,0:03:24.85,0:03:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan gedung ini di dalamnya\Nada koperasi sekolah dan kantin.
Dialogue: 0,0:03:28.40,0:03:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu setelah memutari seluruh area,\Ndi sinilah gedung utamanya.
Dialogue: 0,0:03:33.69,0:03:37.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meteor, kamu juga penasaran\Nsampai datang ke sini, ya?
Dialogue: 0,0:03:41.90,0:03:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tercium aroma yang harum, ya?
Dialogue: 0,0:03:46.04,0:03:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar?\NMungkin cuma perasaanmu saja.
Dialogue: 0,0:03:48.50,0:03:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aromanya terasa.
Dialogue: 0,0:03:51.65,0:03:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromanya manis seperti sihir.
Dialogue: 0,0:03:56.96,0:04:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa tahu hal-hal yang manis\Nkarena kekuatan misteriusku!
Dialogue: 0,0:04:01.65,0:04:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya...
Dialogue: 0,0:04:03.10,0:04:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia terlarang yang cuma\Ndiketahui kalian berdua?
Dialogue: 0,0:04:06.72,0:04:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda!
Dialogue: 0,0:04:08.02,0:04:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aromaku seperti apa?
Dialogue: 0,0:04:09.90,0:04:10.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gioza.
Dialogue: 0,0:04:10.74,0:04:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:19.23,0:04:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang kelas kosong.
Dialogue: 0,0:04:21.54,0:04:24.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau di sini, tak akan ada\Nyang bisa dengar obrolan kita.
Dialogue: 0,0:04:24.54,0:04:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis tadi, dia bilang\Ntahu rahasia kita berdua, ya?
Dialogue: 0,0:04:28.37,0:04:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ucapannya jelas untuk kita berdua.
Dialogue: 0,0:04:31.58,0:04:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bisa ketahuan?
Dialogue: 0,0:04:33.25,0:04:34.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia punya tujuan khusus?
Dialogue: 0,0:04:34.85,0:04:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena sihir barier saus dagingmu itu?
Dialogue: 0,0:04:37.90,0:04:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:04:40.00,0:04:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti karena kita berdua bersama.
Dialogue: 0,0:04:43.14,0:04:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir kita berdua saling merespons.
Dialogue: 0,0:04:45.77,0:04:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti merasa barusan itu\Nkedengarannya keren.
Dialogue: 0,0:04:49.10,0:04:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sebenarnya tak paham,\Ntapi barusan itu keren!
Dialogue: 0,0:04:52.61,0:04:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mereka ke sini karena\Nmerasakan sihir kita,
Dialogue: 0,0:04:57.73,0:05:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya kita pancing mereka\Nke ruang kelas kosong ini.
Dialogue: 0,0:05:02.10,0:05:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau sembunyi di dalam loker\Nuntuk memantau mereka, kamu—
Dialogue: 0,0:05:05.74,0:05:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!\NAku juga ikut!
Dialogue: 0,0:05:13.13,0:05:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu ikut masuk juga?
Dialogue: 0,0:05:15.73,0:05:18.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan marah, jadi gerah!
Dialogue: 0,0:05:18.34,0:05:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga penasaran, jadi apa boleh buat!
Dialogue: 0,0:05:21.33,0:05:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meteor juga bilang begitu!
Dialogue: 0,0:05:23.06,0:05:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meteor kan kamu sendiri!
Dialogue: 0,0:05:29.47,0:05:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini panas.
Dialogue: 0,0:05:31.10,0:05:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini gara-gara kamu!
Dialogue: 0,0:05:32.90,0:05:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu begini aku harusnya\Npakai baju olahraga.
Dialogue: 0,0:05:35.41,0:05:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu tak usah ikut.
Dialogue: 0,0:05:36.77,0:05:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bilang?
Dialogue: 0,0:05:37.84,0:05:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Emosimu sangat labil.
Dialogue: 0,0:05:40.24,0:05:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Tunggu, situasi ini mulai gawat.
Dialogue: 0,0:05:43.44,0:05:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NApanya yang gawat?
Dialogue: 0,0:05:46.20,0:05:48.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau ke toilet.
Dialogue: 0,0:05:48.41,0:05:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, tunggu! Tahan!
Dialogue: 0,0:05:49.86,0:05:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:05:51.12,0:05:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai ngompol di sini,\Nsebaiknya aku mati saja.
Dialogue: 0,0:05:54.38,0:05:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ikut mati!\NMalah aku duluan yang bakal mati!
Dialogue: 0,0:05:57.84,0:06:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Raja Iblis bisa mati\Nkalau disiram air pipis pahlawan?
Dialogue: 0,0:06:01.22,0:06:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesannya malah jijik!
Dialogue: 0,0:06:02.68,0:06:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan begitu!
Dialogue: 0,0:06:04.26,0:06:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah seperti Air Suci?\NTernyata aku menyeramkan!
Dialogue: 0,0:06:07.09,0:06:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu bodoh?
Dialogue: 0,0:06:08.10,0:06:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba?
Dialogue: 0,0:06:09.41,0:06:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sadar?\NKamu juga bisa mati.
Dialogue: 0,0:06:12.06,0:06:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, pergilah ke toilet.
Dialogue: 0,0:06:14.05,0:06:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada sibuk memikirkan ingin mengalahkanku,\Nselamatkan dulu harga dirimu!
Dialogue: 0,0:06:18.15,0:06:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar, itu prioritasku sekarang!
Dialogue: 0,0:06:20.99,0:06:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu!
Dialogue: 0,0:06:22.83,0:06:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ini momen tertangkap basah!
Dialogue: 0,0:06:25.14,0:06:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua sepertinya sedang asyik, ya.
Dialogue: 0,0:06:31.00,0:06:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian hebat bisa menebaknya!
Dialogue: 0,0:06:32.45,0:06:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mentalmu kuat, ya!
Dialogue: 0,0:06:35.12,0:06:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua sebenarnya siapa?
Dialogue: 0,0:06:38.00,0:06:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa kalian mencari kami?
Dialogue: 0,0:06:40.59,0:06:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertanyaan yang bagus!
Dialogue: 0,0:06:44.42,0:06:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah
Dialogue: 0,0:06:46.47,0:06:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi Komedi Romantis!
Dialogue: 0,0:06:47.95,0:06:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kamu saja.
Dialogue: 0,0:06:49.25,0:06:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi Komedi Romantis?
Dialogue: 0,0:06:51.62,0:06:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tidak sudi
Dialogue: 0,0:06:53.95,0:06:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat guru pria dan siswi bermesraan\Ndi sekolah putri yang indah ini!
Dialogue: 0,0:06:58.02,0:06:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma kamu saja.
Dialogue: 0,0:06:59.30,0:07:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolah putri,\Ncinta sesama itu yang paling cocok!
Dialogue: 0,0:07:03.07,0:07:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak paham kamu bicara apa!
Dialogue: 0,0:07:05.15,0:07:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya, kalian berdua harus putus!
Dialogue: 0,0:07:10.08,0:07:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah paham!
Dialogue: 0,0:07:11.41,0:07:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami berdua tak punya hubungan seperti itu!
Dialogue: 0,0:07:13.70,0:07:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, kami berdua itu bermusuhan!
Dialogue: 0,0:07:15.62,0:07:16.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah!
Dialogue: 0,0:07:16.42,0:07:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}namanya komedi romantis.\NJustru hal yang seperti itu
Dialogue: 0,0:07:19.34,0:07:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga merasa begitu, kan?
Dialogue: 0,0:07:20.83,0:07:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai temannya, nasihati dia!
Dialogue: 0,0:07:23.30,0:07:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik! Dada kalian berdua besar.
Dialogue: 0,0:07:26.00,0:07:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi setengah.
Dialogue: 0,0:07:30.97,0:07:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi sedikit.
Dialogue: 0,0:07:32.54,0:07:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kukuh, ya.
Dialogue: 0,0:07:38.35,0:07:41.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi!
Dialogue: 0,0:07:41.15,0:07:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saling sapa pagi begini ada manfaatnya?
Dialogue: 0,0:07:44.42,0:07:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantang dan semangat di pagi hari\Nitu bagus buat kesehatan, kan?
Dialogue: 0,0:07:48.48,0:07:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, selamat pagi!
Dialogue: 0,0:07:50.83,0:07:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanaori, pagi!
Dialogue: 0,0:07:52.30,0:07:54.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanaori, selamat pagi!
Dialogue: 0,0:07:54.10,0:07:55.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi!
Dialogue: 0,0:07:56.18,0:07:58.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kenapa?
Dialogue: 0,0:07:58.62,0:08:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatnya hebat, ya.
Dialogue: 0,0:08:00.62,0:08:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan itu?\NDia populer?
Dialogue: 0,0:08:03.98,0:08:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia dikagumi semua murid\Ntanpa memandang tingkatan kelas.
Dialogue: 0,0:08:07.10,0:08:10.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya ekskul olahraga\Nbanyak minta tolong padanya.
Dialogue: 0,0:08:10.29,0:08:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terlalu sering diandalkan,\Nkesannya bisa apa pun.
Dialogue: 0,0:08:13.01,0:08:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesannya malah mirip pahlawan, ya?
Dialogue: 0,0:08:16.22,0:08:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, mirip pahlawan.
Dialogue: 0,0:08:18.35,0:08:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku mirip seperti Wanita Suci, ya?
Dialogue: 0,0:08:22.52,0:08:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu Kesatria Suci.
Dialogue: 0,0:08:30.87,0:08:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Ryusei?
Dialogue: 0,0:08:34.17,0:08:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti repot diminta bantu-bantu terus.
Dialogue: 0,0:08:36.55,0:08:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga seperti ini?\NApa saat menjadi pahlawan dulu
Dialogue: 0,0:08:39.03,0:08:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tertarik?
Dialogue: 0,0:08:40.29,0:08:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehebatan pahlawan itu cuma bisa\Nkudengar lewat kabar angin.
Dialogue: 0,0:08:45.65,0:08:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu penasaran aku sudah melalui\Npetualangan seperti apa?
Dialogue: 0,0:08:49.55,0:08:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawel!
Dialogue: 0,0:08:51.26,0:08:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kisah saat aku terlibat pertempuran
Dialogue: 0,0:08:53.92,0:08:56.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}antara Putri Pahlawan dan Dewa Iblis.
Dialogue: 0,0:08:56.64,0:09:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Pahlawan dari Kerajaan Exelia.\NKarena suatu kejadian, aku bertemu Nia,
Dialogue: 0,0:09:01.26,0:09:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membantunya\Ndan berakhir menjadi sahabat.
Dialogue: 0,0:09:04.32,0:09:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tujuan dia mengalahkan Dewa Iblis\Nyang mengincar kerajaan.
Dialogue: 0,0:09:08.24,0:09:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga menyelamatkan pangeran tunangannya\Nyang ditawan pengaruh jahat.
Dialogue: 0,0:09:12.74,0:09:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membantu membersihkan monster di gua\Nuntuk upacara kebangkitan menjadi pahlawan
Dialogue: 0,0:09:17.01,0:09:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai mencari pedang sucinya.
Dialogue: 0,0:09:19.18,0:09:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu babu...
Dialogue: 0,0:09:20.45,0:09:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku lanjutkan.
Dialogue: 0,0:09:21.71,0:09:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga menghabisi banyak\Npasukan Dewa Iblis yang mengincarnya.
Dialogue: 0,0:09:25.68,0:09:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Delapan Jenderal Besar Dewa Iblis!\NEmpat Raja Langit Pasukan Iblis!
Dialogue: 0,0:09:28.78,0:09:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali!
Dialogue: 0,0:09:29.92,0:09:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membebaskannya dari pengaruh jahat.\NLalu, aku mengalahkan pangeran yang ditawan,
Dialogue: 0,0:09:33.57,0:09:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu akhirnya aku menghancurkan\NDewa Iblis itu!
Dialogue: 0,0:09:35.99,0:09:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah kamu semua yang melakukannya.
Dialogue: 0,0:09:37.85,0:09:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, serangan terakhir Dewa Iblis\Nmengincar Putri Pahlawan!
Dialogue: 0,0:09:42.05,0:09:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran yang sudah sadar langsung\Nmelindunginya dan mati tragis!
Dialogue: 0,0:09:45.56,0:09:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai sahabatnya, aku terpaksa menontonnya\Nseperti skenario yang tak bisa dihindari.
Dialogue: 0,0:09:49.24,0:09:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan kamu bilang skenario?
Dialogue: 0,0:09:50.95,0:09:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, berkelana di Wilayah Ardent,
Dialogue: 0,0:09:53.99,0:09:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagian barat benua.
Dialogue: 0,0:09:55.71,0:09:58.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlibat dalam konflik\Nantara pemuja Naga, Ordo Veda
Dialogue: 0,0:09:58.32,0:10:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sekte sesat yang berencana\Nmembangkitkan Naga Jahat.
Dialogue: 0,0:10:02.38,0:10:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas permintaan Elthea,\NWanita Suci dari Ordo itu,
Dialogue: 0,0:10:05.86,0:10:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyegel enam menara!\Naku memulai petualanganku
Dialogue: 0,0:10:08.59,0:10:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pengikut sekte sesat terus berdatangan,\Ntapi aku terus maju bertarung!
Dialogue: 0,0:10:11.85,0:10:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enam Naga Jahat yang menjaga menara!\NDua Belas Jenderal Sekte Sesat!
Dialogue: 0,0:10:14.99,0:10:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah makin absurd!
Dialogue: 0,0:10:16.39,0:10:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena berjuang demi menyelamatkan dunia\Ndari Naga Jahat,
Dialogue: 0,0:10:19.05,0:10:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang memanggilku juru selamat.
Dialogue: 0,0:10:20.68,0:10:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus julukan pahlawanmu?
Dialogue: 0,0:10:21.77,0:10:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berhasil menyudutkan sekte sesat itu,
Dialogue: 0,0:10:23.97,0:10:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak disangka, Abal,\Nsang pemimpin ordo,
Dialogue: 0,0:10:26.34,0:10:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah dalang di balik rencana\Nkebangkitan Raja Naga Jahat!
Dialogue: 0,0:10:28.85,0:10:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elthea yang menganggap Abal\Norang tuanya sendiri.
Dialogue: 0,0:10:31.44,0:10:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abal berniat membangkitkan Raja Naga Jahat\Ndengan menggunakan tubuh Elthea!
Dialogue: 0,0:10:35.86,0:10:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana nasib mereka berdua selanjutnya?
Dialogue: 0,0:10:37.74,0:10:40.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu jadi pihak luar, ya.
Dialogue: 0,0:10:40.12,0:10:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera hadir!
Dialogue: 0,0:10:41.26,0:10:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu cuma cuplikan?
Dialogue: 0,0:10:43.84,0:10:45.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Lalu cerita pahlawannya...
Dialogue: 0,0:10:46.53,0:10:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kamu baik-baik saja?
Dialogue: 0,0:10:49.01,0:10:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi babu?
Dialogue: 0,0:10:52.11,0:10:55.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saatnya melihat ikan paus.
Dialogue: 0,0:10:55.28,0:10:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi!
Dialogue: 0,0:10:56.01,0:10:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja?\NMalah bengong.
Dialogue: 0,0:10:58.27,0:10:59.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:59.30,0:11:03.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa arti petualangan pahlawanku selama ini?\NAku cuma alat bagi para penguasa?
Dialogue: 0,0:11:03.76,0:11:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arti pahlawan memang itu, kan?
Dialogue: 0,0:11:05.76,0:11:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelamatkan orang dan membuat tersenyum.
Dialogue: 0,0:11:07.73,0:11:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu!\NApa tidak ada hal yang seru?
Dialogue: 0,0:11:11.39,0:11:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal seru?
Dialogue: 0,0:11:14.58,0:11:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scarlet Eyes, kali ini aku pasti\Nakan mengalahkanmu!
Dialogue: 0,0:11:18.28,0:11:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu pahlawan baru itu, ya?
Dialogue: 0,0:11:23.70,0:11:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuatku kecewa.
Dialogue: 0,0:11:27.42,0:11:29.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini kamu belum bisa mengalahkanku!
Dialogue: 0,0:11:29.96,0:11:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulanglah dan latihan lagi!
Dialogue: 0,0:11:32.05,0:11:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu pertarungan yang bagus,\Ntapi sepertinya ada pengganggu.
Dialogue: 0,0:11:35.50,0:11:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duelnya kita simpan untuk nanti saja.
Dialogue: 0,0:11:39.23,0:11:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh bebuyutanku memang hebat!\NAku menantikan bisa bertarung denganmu!
Dialogue: 0,0:11:48.60,0:11:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NKamu sudah tidak kuat?
Dialogue: 0,0:11:50.61,0:11:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan!
Dialogue: 0,0:11:51.86,0:11:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan melawan\NRaja Iblis itu sangat sulit!
Dialogue: 0,0:11:54.56,0:11:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:11:55.19,0:11:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eksploitasi! Itu eksploitasi\Nmemberi semangat! Dasar licik!
Dialogue: 0,0:11:58.91,0:12:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjalanan pahlawan itu\Npenuh penderitaan dan sengsara!
Dialogue: 0,0:12:08.59,0:12:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu pahlawan hebat.
Dialogue: 0,0:12:10.91,0:12:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya bangga.
Dialogue: 0,0:12:13.39,0:12:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah jelas.
Dialogue: 0,0:12:16.14,0:12:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, aku malah teringat\Nmomen terkena Iron Claw.
Dialogue: 0,0:12:21.37,0:12:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan Iron Claw, tapi Energy Drain\Nuntuk membuat otakmu kopong.
Dialogue: 0,0:12:30.27,0:12:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kabar semuanya, ya?
Dialogue: 0,0:12:32.35,0:12:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti mereka banyak bepergian, kan?
Dialogue: 0,0:12:34.35,0:12:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bertemu berbagai macam orang, kan?
Dialogue: 0,0:12:36.38,0:12:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:12:39.66,0:12:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayah dan Ibu di penginapan desa awal,
Dialogue: 0,0:12:43.63,0:12:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mizuna dan teman-teman\Ndi Serikat Petualang.
Dialogue: 0,0:12:47.10,0:12:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu Gantz si Pandai Besi yang selalu\Nmemperbaiki perlengkapanku...
Dialogue: 0,0:12:50.88,0:12:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muridnya, Lutz. Philip.
Dialogue: 0,0:12:53.36,0:12:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantan istrinya Philip.
Dialogue: 0,0:12:55.59,0:13:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Albert dari Kesatria Emas. Nayuta.\NIceman. Tom Hiddleston.
Dialogue: 0,0:13:01.58,0:13:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tom Hiddleston itu aktor, kan?
Dialogue: 0,0:13:03.80,0:13:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma bisa ketemu satu orang,\Ningin ketemu siapa?
Dialogue: 0,0:13:06.27,0:13:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, Tom Hiddleston!
Dialogue: 0,0:13:08.19,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu fans beratnya, ya?
Dialogue: 0,0:13:12.31,0:13:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa menyelamatkan semua orang.
Dialogue: 0,0:13:14.90,0:13:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah melakukan yang terbaik,\Ntetap ada yang membenciku.
Dialogue: 0,0:13:18.51,0:13:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu mengutuk ketidakberdayaanku.
Dialogue: 0,0:13:23.20,0:13:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena aku punya hati\Nyang pantang menyerah dan terus bangkit!
Dialogue: 0,0:13:27.41,0:13:32.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang pahlawan, pada akhirnya harus\Nterus menjadi pahlawan sampai akhir.
Dialogue: 0,0:13:34.21,0:13:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, orang-orang\Nyang percaya dan mendukungku.
Dialogue: 0,0:13:38.51,0:13:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan merekalah yang membuatku jadi kuat!
Dialogue: 0,0:13:44.30,0:13:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terluka, mengalami kegagalan,\Nlalu terasah sampai bersinar.
Dialogue: 0,0:13:47.90,0:13:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berlian milikku...
Dialogue: 0,0:13:50.53,0:13:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah pahlawan.\NMungkin.
Dialogue: 0,0:13:55.95,0:13:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apaan ini?
Dialogue: 0,0:14:05.99,0:14:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusei!
Dialogue: 0,0:14:07.66,0:14:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!\NAda apa?
Dialogue: 0,0:14:09.29,0:14:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diusir dari grup pahlawan!
Dialogue: 0,0:14:12.03,0:14:13.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu?
Dialogue: 0,0:14:13.37,0:14:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang dulu.
Dialogue: 0,0:14:15.10,0:14:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba jelaskan apa yang terjadi.
Dialogue: 0,0:14:16.94,0:14:20.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, waktu itu saat jam istirahat.
Dialogue: 0,0:14:20.96,0:14:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:21.92,0:14:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dua murid baru dari kelas 2-2?\NMako dan Matsurika.
Dialogue: 0,0:14:26.06,0:14:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciao, ada apa?
Dialogue: 0,0:14:27.66,0:14:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melihat kombinasi langka, ya.
Dialogue: 0,0:14:29.52,0:14:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada cerita Taman Nishiguchi berhantu.
Dialogue: 0,0:14:33.39,0:14:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu.
Dialogue: 0,0:14:34.60,0:14:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini di MooTube ramai dibahas.
Dialogue: 0,0:14:37.06,0:14:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat sedang membahasnya, mereka berdua\Nikut bergabung dan langsung akrab.
Dialogue: 0,0:14:41.76,0:14:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami rencananya akan ke sana sore nanti.
Dialogue: 0,0:14:44.53,0:14:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak takut hantu, ya, Meteor?\NKamu kelihatannya
Dialogue: 0,0:14:47.49,0:14:48.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, itu bukan masalah!
Dialogue: 0,0:14:48.95,0:14:52.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah aku lebih cemas kamu buat kacau
Dialogue: 0,0:14:52.10,0:14:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menghancurkan sesuatu.
Dialogue: 0,0:14:53.60,0:14:54.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:14:55.28,0:14:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, Nona Gelisah,\Ngrup ini sudah pas berempat.
Dialogue: 0,0:15:00.21,0:15:02.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ceritanya!
Dialogue: 0,0:15:02.27,0:15:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian memang selalu begini?
Dialogue: 0,0:15:05.18,0:15:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini memang banyak laporan penampakan.
Dialogue: 0,0:15:09.14,0:15:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, itu monster dari dunia kita?
Dialogue: 0,0:15:17.15,0:15:19.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa saja itu ada hubungannya
Dialogue: 0,0:15:19.06,0:15:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}antara dunia kita dan dunia ini.
Dialogue: 0,0:15:22.48,0:15:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau memang ada monster di sini,\Nkenapa tidak masuk berita?
Dialogue: 0,0:15:27.30,0:15:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Polisi atau Militer Jepang tidak dikerahkan?
Dialogue: 0,0:15:30.46,0:15:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, cerita urban seperti itu\Ntak akan dianggap serius.
Dialogue: 0,0:15:33.75,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menutupinya dari publik.\NTidak, bisa aja ada yang sengaja
Dialogue: 0,0:15:38.67,0:15:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agen pemerintah... Dark web...\NOrganisasi rahasia...
Dialogue: 0,0:15:42.84,0:15:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah bahas konspirasi?
Dialogue: 0,0:15:44.42,0:15:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan konspirasi! Agar seru saja!
Dialogue: 0,0:15:46.80,0:15:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:15:48.53,0:15:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi cemas.
Dialogue: 0,0:15:50.39,0:15:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus pergi memeriksanya!
Dialogue: 0,0:15:52.70,0:15:54.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus ikut?
Dialogue: 0,0:15:55.12,0:15:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?\NKamu takut hantu?
Dialogue: 0,0:15:59.41,0:16:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit.
Dialogue: 0,0:16:00.82,0:16:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta maaf pada pasukan mayat hidupmu.
Dialogue: 0,0:16:06.61,0:16:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini Taman Nishiguchi, ya.
Dialogue: 0,0:16:09.31,0:16:11.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya agak seram, ya.
Dialogue: 0,0:16:11.58,0:16:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamannya luas, pepohonannya juga\Nmengurangi jarak pandang.
Dialogue: 0,0:16:15.44,0:16:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati jalannya, ya.
Dialogue: 0,0:16:17.54,0:16:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira kita akan disambut arwah apa?
Dialogue: 0,0:16:19.97,0:16:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hantu, bukan arwah.
Dialogue: 0,0:16:22.21,0:16:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satsuki, yakin tidak apa-apa\Ntak mengajak Hanaori-kun?
Dialogue: 0,0:16:25.92,0:16:27.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:16:27.61,0:16:28.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin dia pasti
Dialogue: 0,0:16:28.84,0:16:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menyeret guru untuk mengejar kita.
Dialogue: 0,0:16:31.51,0:16:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi komedi romantis!
Dialogue: 0,0:16:35.12,0:16:36.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:16:36.10,0:16:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, susah lihat karena jalannya gelap.
Dialogue: 0,0:16:39.04,0:16:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, terus pegangan padaku.
Dialogue: 0,0:16:42.44,0:16:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menempel berduaan di tempat angker!\NIni dia!
Dialogue: 0,0:16:49.20,0:16:51.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak bikin merinding, ya.
Dialogue: 0,0:16:54.12,0:16:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih.
Dialogue: 0,0:16:56.35,0:16:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:16:58.29,0:17:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Radar komedi romantisku menyala kuat!
Dialogue: 0,0:17:02.40,0:17:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu baik-baik saja?
Dialogue: 0,0:17:04.26,0:17:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:17:05.71,0:17:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada hal bagus terjadi?
Dialogue: 0,0:17:07.76,0:17:08.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada.
Dialogue: 0,0:17:08.72,0:17:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid di sini saling akrab.
Dialogue: 0,0:17:11.59,0:17:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura mereka sampai terasa ke sini.
Dialogue: 0,0:17:15.46,0:17:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi tak sabar melihat\Nperkembangan hubungan mereka!
Dialogue: 0,0:17:18.27,0:17:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu betulan baik-baik saja?
Dialogue: 0,0:17:20.24,0:17:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:17:23.78,0:17:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh.
Dialogue: 0,0:17:24.44,0:17:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, sebenarnya hantu itu apa?
Dialogue: 0,0:17:27.15,0:17:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sejenis goblin, kan?
Dialogue: 0,0:17:29.18,0:17:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh pertama biasanya itu.
Dialogue: 0,0:17:32.11,0:17:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang monster dari dunia kita,
Dialogue: 0,0:17:35.01,0:17:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada yang bisa melawannya di sini.
Dialogue: 0,0:17:36.94,0:17:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan abaikan aku.
Dialogue: 0,0:17:38.37,0:17:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma goblin, aku bisa\Nmengalahkannya dengan mudah.
Dialogue: 0,0:17:41.23,0:17:42.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengandalkan otot saja?
Dialogue: 0,0:17:42.42,0:17:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit membayangkan mantan NEET\Nsepertimu punya tenaga.
Dialogue: 0,0:17:45.25,0:17:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, staminaku payah, lari pun tak bisa.\NKena pukul, tulangku bisa patah.
Dialogue: 0,0:17:49.26,0:17:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak cocok lawan jarak dekat.
Dialogue: 0,0:17:50.51,0:17:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kulindungi?
Dialogue: 0,0:17:53.84,0:17:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia!
Dialogue: 0,0:17:56.67,0:17:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mulai gelap, ya.
Dialogue: 0,0:17:58.64,0:18:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, tidak ada yang muncul.
Dialogue: 0,0:18:00.64,0:18:04.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Hanaori-san\Ndan wali kelasnya itu pacaran?
Dialogue: 0,0:18:04.86,0:18:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:18:05.42,0:18:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:06.16,0:18:07.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali jawabnya.
Dialogue: 0,0:18:07.57,0:18:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, mereka kelihatan\Nseperti teman masa kecil.
Dialogue: 0,0:18:11.25,0:18:12.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:18:12.82,0:18:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat Meteor\Nbersikap seperti itu.
Dialogue: 0,0:18:15.86,0:18:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku berharap bisa melihat\Nlebih banyak sisi dirinya yang lain.
Dialogue: 0,0:18:21.94,0:18:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini sekolah putri!
Dialogue: 0,0:18:23.63,0:18:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuraishi-san, kamu baik-baik saja?
Dialogue: 0,0:18:25.28,0:18:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan saja.
Dialogue: 0,0:18:28.14,0:18:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu Meteor, kan?
Dialogue: 0,0:18:30.71,0:18:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga kamu akan segera muncul.
Dialogue: 0,0:18:45.65,0:18:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan.
Dialogue: 0,0:18:48.57,0:18:52.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah membuat kalian dalam bahaya.\NAku akan melindungi kalian.
Dialogue: 0,0:18:55.07,0:18:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mundur!
Dialogue: 0,0:18:57.12,0:19:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai petir, empaskan semua\Nyang menghalangi jalanku!
Dialogue: 0,0:19:01.16,0:19:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarilah, Api yang Agung!\NPui pui pun!
Dialogue: 0,0:19:04.62,0:19:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lightning Bolt!
Dialogue: 0,0:19:06.58,0:19:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fireball!
Dialogue: 0,0:19:18.82,0:19:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memakai sihir?
Dialogue: 0,0:19:21.81,0:19:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sedang menjalankan tugas.
Dialogue: 0,0:19:23.57,0:19:27.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti anggota ekskul sihir\Nyang sering ada di manga!
Dialogue: 0,0:19:27.15,0:19:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti sedang mengikuti\Nyang ada di cerita klise.
Dialogue: 0,0:19:29.90,0:19:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, jangan begitu, kamu tidak sopan.
Dialogue: 0,0:19:31.57,0:19:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau mereka dengar?
Dialogue: 0,0:19:33.55,0:19:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dengar.
Dialogue: 0,0:19:36.94,0:19:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya staf yang membereskan\Nkalau ada kekacauan?
Dialogue: 0,0:19:39.24,0:19:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa mereka sebenarnya?
Dialogue: 0,0:19:40.51,0:19:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya satu misteri sudah terpecahkan.
Dialogue: 0,0:19:42.45,0:19:47.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja, Satsuki-san dan Nagamori-san\Nsudah kami antar pulang.
Dialogue: 0,0:19:47.39,0:19:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melupakan kejadian ini.\NKami menggunakan sihir agar mereka
Dialogue: 0,0:19:50.50,0:19:52.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu makhluk apa?
Dialogue: 0,0:19:52.14,0:19:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu siapa kalian sebenarnya?
Dialogue: 0,0:19:53.63,0:19:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu makhluk hidup dari luar angkasa.
Dialogue: 0,0:19:57.63,0:20:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menyebut mereka Eater.
Dialogue: 0,0:20:00.05,0:20:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memangsa manusia.
Dialogue: 0,0:20:01.51,0:20:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jauh lebih parah dari yang kubayangkan!
Dialogue: 0,0:20:03.60,0:20:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami adalah Oz.
Dialogue: 0,0:20:05.81,0:20:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami organisasi penyihir yang diam-diam\Nmenangani ancaman tak biasa seperti ini.
Dialogue: 0,0:20:10.21,0:20:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Damai.
Dialogue: 0,0:20:11.98,0:20:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Mereka penyihir?
Dialogue: 0,0:20:15.03,0:20:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami butuh bantuan seseorang\Ndari dalam sekolah.
Dialogue: 0,0:20:19.36,0:20:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:20:20.53,0:20:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian berdua mau\Nbekerja sama dengan kami?
Dialogue: 0,0:20:23.89,0:20:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama kehadiran guru\Nakan sangat membantu.
Dialogue: 0,0:20:28.16,0:20:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa minta bantuan pada kami?
Dialogue: 0,0:20:30.67,0:20:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada alasan khusus.
Dialogue: 0,0:20:32.79,0:20:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sang Pahlawan dan Raja Iblis pun\Nbekerja sama tanpa alasan khusus.
Dialogue: 0,0:22:07.89,0:22:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya...
Dialogue: 0,0:22:09.10,0:22:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya selesai tanpa keterlibatan kita.
Dialogue: 0,0:22:11.56,0:22:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan dan Raja Iblis\Nsama sekali tidak ikut berperan.
Dialogue: 0,0:22:14.56,0:22:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kan bukan grup pahlawan.
Dialogue: 0,0:22:17.28,0:22:18.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:22:18.28,0:22:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster misterius dan para penyihir, ya?
Dialogue: 0,0:22:22.00,0:22:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu banyak yang terjadi dan aku lelah.
Dialogue: 0,0:22:24.45,0:22:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan saja para gadis itu\Nyang menyelamatkan dunia.
Dialogue: 0,0:22:26.88,0:22:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:27.74,0:22:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan yang diasingkan ini\Nakan menjalani hidup damai.
Dialogue: 0,0:22:32.05,0:22:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ternyata pendendam, ya?
Dialogue: 0,0:22:33.83,0:22:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ryusei, seberapa banyak\Nkekuatanmu yang masih tersisa?
Dialogue: 0,0:22:38.53,0:22:40.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kehilangan ilmu terlarang
Dialogue: 0,0:22:40.48,0:22:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sangat kuat milik Raja Iblis.
Dialogue: 0,0:22:43.55,0:22:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku hanya manusia biasa.
Dialogue: 0,0:22:45.91,0:22:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, kamu sudah tidak bisa\Nmenghancurkan negara lagi?
Dialogue: 0,0:22:49.15,0:22:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian tidak mau.
Dialogue: 0,0:22:50.22,0:22:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemah.
Dialogue: 0,0:22:51.14,0:22:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oi, kamu bilang apa?
Dialogue: 0,0:22:53.63,0:22:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu sendiri?
Dialogue: 0,0:22:54.77,0:22:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kamu akan menggunakan kekuatanmu?
Dialogue: 0,0:22:57.48,0:22:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menjalani hidup damai.
Dialogue: 0,0:22:58.64,0:23:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang pendendam.
Dialogue: 0,0:23:01.49,0:23:07.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menggunakannya untuk melindungi\Norang-orang lemah seperti dulu.
Dialogue: 0,0:23:09.16,0:23:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga termasuk,\Nsekarang kamu sudah lemah dan payah.
Dialogue: 0,0:23:14.62,0:23:15.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu.
Dialogue: 0,0:23:15.55,0:23:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh!
Dialogue: 0,0:23:16.58,0:23:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini harusnya jadi momen haru!
Dialogue: 0,0:23:18.89,0:23:20.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya peka!
Dialogue: 0,0:23:20.61,0:23:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haru dari mananya?
Dialogue: 0,0:23:25.65,0:23:29.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Hasegawa, wali kelas 2-3.\NKatanya lonceng di sekolah
Dialogue: 0,0:23:29.48,0:23:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terinspirasi dari Big Ben di London.
Dialogue: 0,0:23:32.68,0:23:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaranya bagus, bukan?
Dialogue: 0,0:23:33.64,0:23:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku betulan praktisi Aikido.
Dialogue: 0,0:23:36.19,0:23:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saksikan episode berikutnya.
Dialogue: 0,0:23:37.31,0:23:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat malam.
Dialogue: 0,0:23:38.21,0:23:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru teladan.
