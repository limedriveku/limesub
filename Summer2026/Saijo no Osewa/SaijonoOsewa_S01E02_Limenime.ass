Dialogue: 0,0:03:52.92,0:03:54.58,sign,,0000,0000,0000,,EPISODE 2: HARI PERTAMA SEBAGAI PENGURUS
Dialogue: 0,0:09:43.89,0:09:45.76,sign,,0000,0000,0000,,"SHIZUNE"
Dialogue: 0,0:16:12.00,0:16:13.37,sign,,0000,0000,0000,,KERIPIK KENTANG RASA KALDU
Dialogue: 0,0:00:06.98,0:00:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengantuk.
Dialogue: 0,0:00:09.62,0:00:11.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau pulang.
Dialogue: 0,0:00:11.06,0:00:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menurutinya kalau Anda\Nminta lagi delapan jam dari sekarang.
Dialogue: 0,0:00:15.46,0:00:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itsuki.
Dialogue: 0,0:00:17.08,0:00:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan jadi teman sekolah Nona\Nmulai hari ini,
Dialogue: 0,0:00:20.25,0:00:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku akan memanggilmu\NTuan Itsuki di depan umum.
Dialogue: 0,0:00:23.54,0:00:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:00:24.98,0:00:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menurunkan kalian\Nagak jauh dari akademi.
Dialogue: 0,0:00:27.97,0:00:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Statusmu sebagai pengurusnya\Ndan fakta bahwa kalian tinggal seatap
Dialogue: 0,0:00:32.58,0:00:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus dijaga kerahasiaannya.
Dialogue: 0,0:00:34.75,0:00:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:00:36.32,0:00:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:00:38.68,0:00:40.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ada yang bisa dibantu?
Dialogue: 0,0:00:40.63,0:00:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaralah seperti biasa.
Dialogue: 0,0:00:42.14,0:00:43.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:00:43.42,0:00:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune.
Dialogue: 0,0:00:44.80,0:00:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh Itsuki bicara seperti sebelumnya.
Dialogue: 0,0:00:47.81,0:00:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu akan jadi contoh buruk\Nbagi pelayan lain.
Dialogue: 0,0:00:50.62,0:00:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, bagaimana jika saat kita\Nberdua saja, atau ada Shizune?
Dialogue: 0,0:00:56.53,0:00:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah Anda saja.
Dialogue: 0,0:00:58.51,0:01:00.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau senang, 'kan, Itsuki?
Dialogue: 0,0:01:00.38,0:01:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bicara santai denganku.
Dialogue: 0,0:01:02.50,0:01:04.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus senang?
Dialogue: 0,0:01:07.58,0:01:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita hampir sampai akademi.
Dialogue: 0,0:01:11.28,0:01:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:01:12.74,0:01:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi sekarang?
Dialogue: 0,0:01:13.83,0:01:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluk.
Dialogue: 0,0:01:16.83,0:01:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat.
Dialogue: 0,0:01:18.54,0:01:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, rasanya tak pantas\Nwanita baik-baik seperti Anda melakukan ini.
Dialogue: 0,0:01:23.27,0:01:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuh Itsuki wangi, lo.
Dialogue: 0,0:01:26.42,0:01:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:01:28.64,0:01:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itsuki, boleh aku cium baumu\Nsebagai referensi?
Dialogue: 0,0:01:31.78,0:01:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan!
Dialogue: 0,0:01:33.01,0:01:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Endus, endus.
Dialogue: 0,0:01:36.98,0:01:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Itsuki, ambil ini.
Dialogue: 0,0:01:39.06,0:01:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu. Apa ini?
Dialogue: 0,0:01:41.92,0:01:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Nona mulai sulit diatur,\Nsilakan gunakan ini.
Dialogue: 0,0:01:47.86,0:01:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, semoga harimu menyenangkan.
Dialogue: 0,0:01:50.96,0:01:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pulang.
Dialogue: 0,0:01:52.92,0:01:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau harus berakting?
Dialogue: 0,0:01:54.92,0:01:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum ada yang memperhatikan kita.
Dialogue: 0,0:01:57.74,0:02:01.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia punya sensor tatapan orang lain?
Dialogue: 0,0:02:01.91,0:02:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini demi upah 20.000 yen sehari.
Dialogue: 0,0:02:04.02,0:02:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus menjaga reputasi Hinako\Nsebagai nona besar,
Dialogue: 0,0:02:07.65,0:02:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil berpura-pura jadi\Nteman sekolahnya di sekolah elite ini!
Dialogue: 0,0:02:12.87,0:02:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali...
Dialogue: 0,0:03:34.57,0:03:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rich Girl Caretaker:
Dialogue: 0,0:03:37.09,0:03:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I'm Secretly the Caregiver of the\NMost Popular Girl in This Rich Kid School
Dialogue: 0,0:03:46.42,0:03:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sambutlah murid pindahan baru kita.
Dialogue: 0,0:03:49.27,0:03:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Tomonari Itsuki.
Dialogue: 0,0:03:51.06,0:03:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:03:54.58,0:03:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tomonari, silakan duduk\Ndi kursi kosong di belakang.
Dialogue: 0,0:03:58.07,0:03:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:04:00.38,0:04:04.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang tepuk tangan atau bicara,\Ntapi suasananya tak menegangkan.
Dialogue: 0,0:04:04.77,0:04:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang tampak bersahabat.
Dialogue: 0,0:04:07.08,0:04:10.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat berbeda dari sekolah lamaku.
Dialogue: 0,0:04:10.14,0:04:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita mulai\Npelajaran Matematika hari ini.
Dialogue: 0,0:04:14.26,0:04:18.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan mulai mempelajari\Nintegral substitusi.
Dialogue: 0,0:04:19.30,0:04:23.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu materi akhir kelas tiga?
Dialogue: 0,0:04:23.95,0:04:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mempelajarinya di musim semi\Npadahal baru kelas dua?
Dialogue: 0,0:04:28.54,0:04:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lelah\Nsetelah jam pelajaran pertama.
Dialogue: 0,0:04:31.75,0:04:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, bagaimana keadaan Hinako?
Dialogue: 0,0:04:33.94,0:04:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konohana, ada beberapa materi tadi\Nyang tidak kumengerti.
Dialogue: 0,0:04:38.05,0:04:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dengan senang hati mengajarimu.
Dialogue: 0,0:04:41.02,0:04:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak sempurna saat ada orang lain.
Dialogue: 0,0:04:43.05,0:04:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Murid Baru.
Dialogue: 0,0:04:45.89,0:04:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau mengabaikanku, Murid Baru.
Dialogue: 0,0:04:49.66,0:04:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, serahkan uangmu.
Dialogue: 0,0:04:52.04,0:04:53.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:53.72,0:04:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:04:54.32,0:04:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:04:55.02,0:04:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membuatnya takut.
Dialogue: 0,0:04:58.05,0:04:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, cuma bercanda.
Dialogue: 0,0:05:00.18,0:05:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Taisho Katsuya.
Dialogue: 0,0:05:01.90,0:05:03.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Asahi Karen.
Dialogue: 0,0:05:03.73,0:05:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:05:06.06,0:05:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Tomonari Itsuki, 'kan?
Dialogue: 0,0:05:08.20,0:05:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran tadi susah diikuti, ya?
Dialogue: 0,0:05:11.20,0:05:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian memperhatikanku?
Dialogue: 0,0:05:12.90,0:05:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murid pindahan biasanya memang kesulitan.
Dialogue: 0,0:05:15.67,0:05:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa murid berasal\Ndari sekolah unggulan,
Dialogue: 0,0:05:20.14,0:05:23.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi banyak yang masuk sini\Nkarena urusan keluarga.
Dialogue: 0,0:05:23.25,0:05:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, untuk meneruskan bisnis keluarga.
Dialogue: 0,0:05:25.12,0:05:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang seperti itu\Ndianggap "rakyat biasa".
Dialogue: 0,0:05:28.34,0:05:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau termasuk\Ndalam golongan itu, 'kan, Tomonari?
Dialogue: 0,0:05:30.04,0:05:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:32.05,0:05:36.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolah, tolong bicara\Ndengan bahasa yang formal.
Dialogue: 0,0:05:36.35,0:05:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena status pura-puramu itu rendah.
Dialogue: 0,0:05:38.51,0:05:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pewaris perusahaan dianggap rakyat biasa?
Dialogue: 0,0:05:42.29,0:05:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:05:43.68,0:05:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku menjalankan perusahaan IT\Nkecil-kecilan.
Dialogue: 0,0:05:47.12,0:05:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:05:48.86,0:05:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pindah dari sekolah biasa\Nke kurikulum sini memang sulit.
Dialogue: 0,0:05:53.30,0:05:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya murid\Ndengan latar belakang serupa
Dialogue: 0,0:05:56.05,0:05:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biasanya berkumpul untuk saling membantu.
Dialogue: 0,0:05:57.83,0:05:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:05:59.20,0:06:03.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Asahi juga rakyat biasa,\Njadi kami bisa membantumu.
Dialogue: 0,0:06:04.95,0:06:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka baik sekali.
Dialogue: 0,0:06:06.88,0:06:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu akan sangat membantu.
Dialogue: 0,0:06:08.01,0:06:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan sangat berterima kasih!
Dialogue: 0,0:06:10.30,0:06:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak usah terlalu kaku begitu.
Dialogue: 0,0:06:11.95,0:06:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita 'kan teman sekelas.
Dialogue: 0,0:06:13.36,0:06:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aturan keluargaku...
Dialogue: 0,0:06:15.72,0:06:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, mau bagaimana lagi.
Dialogue: 0,0:06:18.24,0:06:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nada yang ingin kutanyakan padamu.
Dialogue: 0,0:06:22.73,0:06:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa
Dialogue: 0,0:06:24.01,0:06:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hubunganmu dengan Konohana?
Dialogue: 0,0:06:27.67,0:06:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berangkat ke sekolah\Nbareng pagi ini, 'kan?
Dialogue: 0,0:06:32.63,0:06:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tua kami saling kenal,\Ndan kami pernah mengobrol,
Dialogue: 0,0:06:36.54,0:06:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku memintanya\Nmenunjukkan jalan ke sekolah.
Dialogue: 0,0:06:39.02,0:06:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma itu?
Dialogue: 0,0:06:40.97,0:06:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak bertunangan atau semacamnya?
Dialogue: 0,0:06:43.86,0:06:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bertunangan?\NSama sekali tidak!
Dialogue: 0,0:06:47.55,0:06:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jangan bikin kami kaget!
Dialogue: 0,0:06:50.94,0:06:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konohana itu sangat populer, lo.
Dialogue: 0,0:06:56.74,0:07:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang dia adalah\Nsiswi paling terkenal di akademi ini.
Dialogue: 0,0:07:01.91,0:07:05.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilainya sempurna, penampilannya juga.
Dialogue: 0,0:07:05.59,0:07:08.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja,\Ndia putri dari Keluarga Konohana.
Dialogue: 0,0:07:08.57,0:07:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar saat jam istirahat,
Dialogue: 0,0:07:10.12,0:07:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia ikut rapat jarak jauh\Nuntuk bisnis keluarganya.
Dialogue: 0,0:07:18.20,0:07:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:07:19.70,0:07:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:07:21.37,0:07:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaralah seperti biasa.
Dialogue: 0,0:07:24.28,0:07:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selalu makan di sini?
Dialogue: 0,0:07:26.09,0:07:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini sepi.
Dialogue: 0,0:07:28.45,0:07:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udara segarnya juga enak.
Dialogue: 0,0:07:30.48,0:07:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Ayo makan.
Dialogue: 0,0:07:32.58,0:07:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:07:34.07,0:07:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:07:35.80,0:07:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini kulihat bekal semewah ini.
Dialogue: 0,0:07:38.77,0:07:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan kantin jauh lebih mewah.
Dialogue: 0,0:07:41.07,0:07:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bekal ini\Ncuma berisi makanan kesukaanku.
Dialogue: 0,0:07:43.82,0:07:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ada makanan yang tak kau suka?
Dialogue: 0,0:07:47.20,0:07:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wortel, paprika, jamur shiitake,\Nacar plum, tomat, labu...
Dialogue: 0,0:07:51.90,0:07:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu banyak!\NBilang saja kau benci sayur!
Dialogue: 0,0:07:54.60,0:07:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan.
Dialogue: 0,0:07:56.46,0:07:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makananmu berantakan.
Dialogue: 0,0:07:58.05,0:07:59.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:07:59.02,0:08:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu.
Dialogue: 0,0:08:00.93,0:08:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suapi aku.
Dialogue: 0,0:08:10.22,0:08:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada penolakan.
Dialogue: 0,0:08:12.97,0:08:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai ucapan terima kasih, buka mulutmu.
Dialogue: 0,0:08:22.95,0:08:24.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak banget! Apa-apaan?
Dialogue: 0,0:08:25.04,0:08:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini omelet terenak yang pernah kumakan!
Dialogue: 0,0:08:27.35,0:08:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:08:29.32,0:08:32.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku majikanmu, jadi tugasku memberimu makan.
Dialogue: 0,0:08:32.90,0:08:34.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberiku makan?
Dialogue: 0,0:08:34.64,0:08:37.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau kau\Nkehabisan kesabaran menghadapiku...
Dialogue: 0,0:08:38.30,0:08:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa pengurusmu\Nyang sebelumnya berhenti?
Dialogue: 0,0:08:42.03,0:08:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah.
Dialogue: 0,0:08:43.00,0:08:45.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah? Berapa lama dia bertahan?
Dialogue: 0,0:08:45.42,0:08:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar dua minggu.
Dialogue: 0,0:08:47.62,0:08:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:08:48.38,0:08:50.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, yang sebelumnya tiga minggu.
Dialogue: 0,0:08:50.94,0:08:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paling lama cuma sebulan.
Dialogue: 0,0:08:53.12,0:08:54.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa mereka cepat sekali berhenti?
Dialogue: 0,0:08:55.18,0:08:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang ada pekerjaan\Ndengan syarat semenguntungkan ini.
Dialogue: 0,0:08:59.40,0:09:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat menguntungkan?
Dialogue: 0,0:09:00.90,0:09:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:02.01,0:09:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat tempat tinggal\Ndengan makan tiga kali sehari
Dialogue: 0,0:09:04.57,0:09:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta upah 20.000 yen sehari!
Dialogue: 0,0:09:06.29,0:09:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga membayari uang sekolahku.
Dialogue: 0,0:09:08.46,0:09:11.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kita harus belajar keras...
Dialogue: 0,0:09:11.10,0:09:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, bagaimana denganku?
Dialogue: 0,0:09:12.41,0:09:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:13.20,0:09:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku ini bagian\Ndari syarat menguntungkan itu?
Dialogue: 0,0:09:15.63,0:09:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:09:18.35,0:09:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tertarik menikah demi uang?
Dialogue: 0,0:09:20.76,0:09:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak kepikiran soal itu...
Dialogue: 0,0:09:23.45,0:09:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berhenti jadi pengurusku, Itsuki.
Dialogue: 0,0:09:26.95,0:09:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:31.10,0:09:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidur pulas sekali.
Dialogue: 0,0:09:33.17,0:09:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya aku akan sangat senang\Ndalam situasi begini,
Dialogue: 0,0:09:36.52,0:09:38.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekarang aku malah merasa tenang.
Dialogue: 0,0:09:38.52,0:09:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:09:41.42,0:09:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu ponselku?
Dialogue: 0,0:09:43.89,0:09:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune?
Dialogue: 0,0:09:46.42,0:09:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:09:47.29,0:09:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kau angkat telepon lebih cepat.
Dialogue: 0,0:09:49.14,0:09:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona sedang bersamamu?
Dialogue: 0,0:09:50.89,0:09:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dia, em...
Dialogue: 0,0:09:53.74,0:09:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang tidur.
Dialogue: 0,0:09:55.18,0:09:56.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:09:56.46,0:09:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kau terbiasa\Ndengan pekerjaanmu sebagai pengurus,
Dialogue: 0,0:09:59.37,0:10:02.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan memantaumu seperti ini\Nsaat istirahat makan siang.
Dialogue: 0,0:10:03.15,0:10:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, apa kau berakting sesuai skenario?
Dialogue: 0,0:10:05.76,0:10:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku cukup lancar untuk saat ini.
Dialogue: 0,0:10:08.14,0:10:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau mengobrol dengan teman sekelasmu?
Dialogue: 0,0:10:11.27,0:10:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi mengobrol dengan\NTaisho Katsuya dan Asahi Karen.
Dialogue: 0,0:10:16.70,0:10:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Taisho dan Nona Asahi, 'kan?
Dialogue: 0,0:10:20.57,0:10:24.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Nona Asahi\Nberbisnis di bidang retail.
Dialogue: 0,0:10:24.49,0:10:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perusahaan yang dikenal\Nsebagai Jays Holdings.
Dialogue: 0,0:10:27.18,0:10:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah dengar.
Dialogue: 0,0:10:29.02,0:10:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya?
Dialogue: 0,0:10:30.22,0:10:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Elektronik Jays\Nlebih dikenal oleh umum.
Dialogue: 0,0:10:32.59,0:10:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Elektronik Jays?
Dialogue: 0,0:10:34.86,0:10:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu 'kan sangat terkenal!
Dialogue: 0,0:10:37.09,0:10:38.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjualan mereka masuk lima besar nasional
Dialogue: 0,0:10:38.94,0:10:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk kategori ritel elektronik.
Dialogue: 0,0:10:42.14,0:10:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang rakyat biasa?
Dialogue: 0,0:10:44.36,0:10:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia gadis yang sangat kaya!
Dialogue: 0,0:10:46.14,0:10:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan, Keluarga Taisho terkenal\Ndengan Transportasi Taisho,
Dialogue: 0,0:10:49.17,0:10:51.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mereka pemain besar\Ndi bisnis transportasi.
Dialogue: 0,0:10:51.46,0:10:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga anak orang kaya?!
Dialogue: 0,0:10:56.17,0:10:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat...
Dialogue: 0,0:11:02.75,0:11:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya itu cukup.
Dialogue: 0,0:11:04.86,0:11:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali, Konohana.\NJawaban yang sempurna.
Dialogue: 0,0:11:11.53,0:11:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu dikelilingi orang lain,\Njadi apa dia membutuhkanku?
Dialogue: 0,0:11:15.46,0:11:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kecuali saat istirahat makan siang.
Dialogue: 0,0:11:19.68,0:11:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:11:20.58,0:11:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bicara?
Dialogue: 0,0:11:22.18,0:11:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:23.47,0:11:26.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Nona menjatuhkan dompetnya.
Dialogue: 0,0:11:26.59,0:11:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasi pemancar di dompetnya berbeda\Ndengan posisinya sekarang.
Dialogue: 0,0:11:32.18,0:11:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemancar di dompet?
Dialogue: 0,0:11:34.67,0:11:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencarinya sekarang.
Dialogue: 0,0:11:36.07,0:11:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana aku harus mencari?
Dialogue: 0,0:11:37.75,0:11:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasinya di sayap barat gedung utama,
Dialogue: 0,0:11:40.88,0:11:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tak ada detail lebih rinci selain itu.
Dialogue: 0,0:11:42.70,0:11:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kalau begitu mungkin di toilet.
Dialogue: 0,0:11:45.37,0:11:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu. Tolong ambilkan dompetnya.
Dialogue: 0,0:11:48.70,0:11:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:11:49.68,0:11:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, apa?
Dialogue: 0,0:11:52.30,0:11:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil?
Dialogue: 0,0:11:54.51,0:11:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin aku masuk ke sana?!
Dialogue: 0,0:11:56.39,0:11:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau, ada masalah?
Dialogue: 0,0:11:59.50,0:12:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu...
Dialogue: 0,0:12:01.56,0:12:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:12:02.96,0:12:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, wajah baru.
Dialogue: 0,0:12:06.45,0:12:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti murid pindahan di kelas A.
Dialogue: 0,0:12:09.60,0:12:12.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Tennoji Mirei.
Dialogue: 0,0:12:13.78,0:12:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri tunggal pemilik Grup Tennoji.
Dialogue: 0,0:12:23.45,0:12:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh...
Dialogue: 0,0:12:24.22,0:12:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa reaksimu lesu begitu?
Dialogue: 0,0:12:29.27,0:12:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti tahu soal Grup Tennoji, 'kan?
Dialogue: 0,0:12:33.26,0:12:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:12:34.63,0:12:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan ketidaktahuanku.
Dialogue: 0,0:12:37.32,0:12:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kelewatan!
Dialogue: 0,0:12:39.70,0:12:44.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup Tennoji adalah konglomerat besar\Nyang berakar di industri pertambangan.
Dialogue: 0,0:12:44.70,0:12:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini, kami adalah salah satu\Nprodusen logam non-besi
Dialogue: 0,0:12:47.54,0:12:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bahan kimia terbesar di Jepang,
Dialogue: 0,0:12:49.78,0:12:53.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}skalanya setara dengan Grup Konohana!
Dialogue: 0,0:12:53.52,0:12:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu?
Dialogue: 0,0:12:55.53,0:12:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksi itu...
Dialogue: 0,0:12:56.88,0:12:59.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau tahu soal Grup Konohana.
Dialogue: 0,0:12:59.71,0:13:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku tahu.
Dialogue: 0,0:13:01.68,0:13:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku benar-benar tak tahan dengannya...
Dialogue: 0,0:13:05.13,0:13:07.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konohana Hinako!
Dialogue: 0,0:13:07.19,0:13:11.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara dia, tak ada yang peduli padaku!
Dialogue: 0,0:13:15.19,0:13:18.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ada masalah apa?
Dialogue: 0,0:13:18.70,0:13:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu...
Dialogue: 0,0:13:20.67,0:13:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada dompet jatuh\Ndi toilet wanita.
Dialogue: 0,0:13:26.26,0:13:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini?
Dialogue: 0,0:13:28.51,0:13:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:13:30.50,0:13:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku tahu,
Dialogue: 0,0:13:32.17,0:13:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana anak laki-laki sepertimu bisa tahu\Nada dompet di toilet wanita?
Dialogue: 0,0:13:36.12,0:13:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, soal itu...
Dialogue: 0,0:13:38.88,0:13:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dimintai tolong oleh pemiliknya\Nuntuk mencari,
Dialogue: 0,0:13:41.71,0:13:43.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan setelah kucari ke mana-mana,\Npasti ada di sini.
Dialogue: 0,0:13:44.19,0:13:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak membenci Hinako,\Nsebaiknya aku tak menyebut namanya.
Dialogue: 0,0:13:50.08,0:13:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, kau disuruh-suruh orang lain?
Dialogue: 0,0:13:53.88,0:13:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu.
Dialogue: 0,0:13:55.69,0:13:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai murid di sini,
Dialogue: 0,0:13:57.34,0:14:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan jadi pemimpin di masa depan, 'kan?
Dialogue: 0,0:14:00.56,0:14:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau biarkan orang lain menyuruhmu,\Nitu pertanda buruk bagi masa depanmu.
Dialogue: 0,0:14:04.02,0:14:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, aku akan mengingatnya.
Dialogue: 0,0:14:06.41,0:14:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus lebih percaya diri!
Dialogue: 0,0:14:08.33,0:14:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawablah dengan tegas!
Dialogue: 0,0:14:10.02,0:14:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, akan kuingat!
Dialogue: 0,0:14:12.14,0:14:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, kau bisa kalau berusaha.
Dialogue: 0,0:14:14.61,0:14:18.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kau juga\Nharus perbaiki postur tubuhmu.
Dialogue: 0,0:14:18.34,0:14:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepercayaan diri berawal\Ndari postur yang tegap.
Dialogue: 0,0:14:22.18,0:14:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali.
Dialogue: 0,0:14:24.58,0:14:30.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada masalah,\Ncarilah gadis berambut emas ini.
Dialogue: 0,0:14:31.19,0:14:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em...
Dialogue: 0,0:14:33.42,0:14:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku tanya sesuatu...
Dialogue: 0,0:14:35.59,0:14:39.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tak masalah rambutmu diwarnai begitu\Ndi akademi ini?
Dialogue: 0,0:14:39.91,0:14:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu soal rambutku?
Dialogue: 0,0:14:42.66,0:14:44.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau mewarnainya.
Dialogue: 0,0:14:44.47,0:14:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau bilang rambutku palsu?!
Dialogue: 0,0:14:48.50,0:14:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu...
Dialogue: 0,0:14:50.37,0:14:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak diwarnai...
Dialogue: 0,0:14:52.40,0:14:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutku asli!
Dialogue: 0,0:14:57.06,0:14:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas-jelas itu diwarnai.
Dialogue: 0,0:15:01.62,0:15:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tomonari. Kau selamat.
Dialogue: 0,0:15:04.34,0:15:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana tadi?\NMau ikut pesta penyambutan?
Dialogue: 0,0:15:07.26,0:15:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku disuruh pulang cepat hari ini.
Dialogue: 0,0:15:11.01,0:15:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, wajar saja karena ini hari pertamamu.
Dialogue: 0,0:15:13.49,0:15:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kita undur ke lain hari?
Dialogue: 0,0:15:17.21,0:15:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu lebih banyak\Nsoal akademi ini.
Dialogue: 0,0:15:19.36,0:15:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu! Kapan saja bisa!
Dialogue: 0,0:15:21.79,0:15:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:15:33.51,0:15:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi apa?
Dialogue: 0,0:15:35.09,0:15:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pulang.
Dialogue: 0,0:15:37.23,0:15:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:15:38.09,0:15:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak mau pulang?
Dialogue: 0,0:15:39.79,0:15:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tadi pagi kau mau pulang?
Dialogue: 0,0:15:42.50,0:15:44.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau di sini saja.
Dialogue: 0,0:15:44.20,0:15:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bersantai setelah kita pulang.
Dialogue: 0,0:15:46.90,0:15:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:15:48.25,0:15:51.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak les dan sebagainya.
Dialogue: 0,0:15:51.41,0:15:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:15:52.58,0:15:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kita tak bisa di sini terus.
Dialogue: 0,0:15:56.24,0:15:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pulang.
Dialogue: 0,0:15:57.61,0:16:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau!
Dialogue: 0,0:16:01.31,0:16:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menolak sekuat tenaga!
Dialogue: 0,0:16:04.74,0:16:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, aku lupa Shizune memberiku sesuatu.
Dialogue: 0,0:16:13.66,0:16:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keripik kentang!
Dialogue: 0,0:16:17.33,0:16:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini berikan!
Dialogue: 0,0:16:19.88,0:16:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberikan kalau kita pulang.
Dialogue: 0,0:16:24.22,0:16:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu curang.
Dialogue: 0,0:16:26.27,0:16:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa menolaknya.
Dialogue: 0,0:16:30.15,0:16:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinako dilarang makan\Nmakanan ringan tak sehat,
Dialogue: 0,0:16:35.31,0:16:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku baru tahu itu dari Shizune.
Dialogue: 0,0:16:38.42,0:16:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis kaya pun punya masalahnya sendiri.
Dialogue: 0,0:16:40.86,0:16:43.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lelah setelah hari pertamaku di sekolah,
Dialogue: 0,0:16:43.55,0:16:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aturan yang lebih ketat menungguku.
Dialogue: 0,0:16:46.60,0:16:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran dari Shizune dimulai\Ndengan menyiapkan materi besok,
Dialogue: 0,0:16:50.69,0:16:52.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu etika dan bela diri...
Dialogue: 0,0:16:55.99,0:16:56.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyerah!
Dialogue: 0,0:16:56.93,0:16:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong lepaskan aku sebelum mati!
Dialogue: 0,0:16:58.83,0:17:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup untuk hari ini.
Dialogue: 0,0:17:01.18,0:17:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak...
Dialogue: 0,0:17:03.97,0:17:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau belajar lebih cepat dari dugaanku.
Dialogue: 0,0:17:08.51,0:17:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Em, boleh tanya satu hal?
Dialogue: 0,0:17:11.64,0:17:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:17:12.92,0:17:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinako bilang,
Dialogue: 0,0:17:15.15,0:17:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengurus yang paling lama\Nbertahan cuma sebulan.
Dialogue: 0,0:17:18.35,0:17:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:17:19.65,0:17:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa alasannya?
Dialogue: 0,0:17:21.82,0:17:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kagen yang memilih pengurus sebelumnya.
Dialogue: 0,0:17:26.56,0:17:29.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua sangat ketat pada Nona,
Dialogue: 0,0:17:29.47,0:17:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga gagal membangun\Nkepercayaan dengannya.
Dialogue: 0,0:17:34.16,0:17:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Kagen pasti sangat putus asa.
Dialogue: 0,0:17:37.65,0:17:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah pengurus pertama dari rakyat biasa
Dialogue: 0,0:17:39.48,0:17:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sama sekali tak punya ikatan\Ndengan Keluarga Konohana.
Dialogue: 0,0:17:43.30,0:17:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:17:45.33,0:17:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga jadi pertaruhan bagi kami.
Dialogue: 0,0:17:48.82,0:17:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru hari pertama...
Dialogue: 0,0:17:51.22,0:17:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku bisa bertahan?
Dialogue: 0,0:17:53.82,0:17:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:17:55.96,0:17:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Hinako?
Dialogue: 0,0:17:57.94,0:17:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bau keringat.
Dialogue: 0,0:17:59.63,0:18:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tentu. Aku baru mau mandi.
Dialogue: 0,0:18:02.38,0:18:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ikut aku.
Dialogue: 0,0:18:03.86,0:18:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:05.12,0:18:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei...
Dialogue: 0,0:18:08.59,0:18:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:18:10.01,0:18:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamarku.
Dialogue: 0,0:18:11.82,0:18:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah. Ini sungguhan kamar gadis kaya.
Dialogue: 0,0:18:15.50,0:18:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamar mandinya di sini.
Dialogue: 0,0:18:17.51,0:18:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, besar sekali!
Dialogue: 0,0:18:21.97,0:18:23.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:18:24.96,0:18:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mandi bareng.
Dialogue: 0,0:18:26.34,0:18:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:18:28.49,0:18:30.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:18:32.92,0:18:34.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti di surga.
Dialogue: 0,0:18:35.68,0:18:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya baju renang untukku juga?
Dialogue: 0,0:18:43.22,0:18:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang, tenang.
Dialogue: 0,0:18:44.66,0:18:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh pengalih perhatian...
Dialogue: 0,0:18:48.77,0:18:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:18:50.13,0:18:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Profil teman sekelas dari Shizune.
Dialogue: 0,0:18:53.94,0:18:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sekolah, bisnis keluarga\Nsering dibicarakan,
Dialogue: 0,0:18:57.23,0:18:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi dia menyuruhku membacanya.
Dialogue: 0,0:19:00.18,0:19:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinako, apa ada teman dekatmu di kelas?
Dialogue: 0,0:19:03.34,0:19:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:19:04.14,0:19:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali jawabnya.
Dialogue: 0,0:19:05.86,0:19:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau selalu dikerumuni banyak orang?
Dialogue: 0,0:19:09.31,0:19:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mereka bukan teman.
Dialogue: 0,0:19:11.28,0:19:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih tepat disebut penjilat.
Dialogue: 0,0:19:16.96,0:19:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak ingin punya teman?
Dialogue: 0,0:19:22.79,0:19:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma butuh kau, Itsuki.
Dialogue: 0,0:19:25.70,0:19:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:35.23,0:19:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuci rambutku.
Dialogue: 0,0:19:38.31,0:19:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}La-Lakukan sendiri.
Dialogue: 0,0:19:40.59,0:19:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya Shizune yang kerjakan.
Dialogue: 0,0:19:45.19,0:19:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini juga bagian dari pekerjaanku.
Dialogue: 0,0:19:48.49,0:19:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa kau memilihku jadi pengurusmu?
Dialogue: 0,0:19:53.75,0:19:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki...
Dialogue: 0,0:19:58.04,0:20:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka caramu mengurusku\Nmeski sambil mengeluh.
Dialogue: 0,0:20:04.49,0:20:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan jawaban.
Dialogue: 0,0:20:06.70,0:20:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku senang tahu dia memercayaiku.
Dialogue: 0,0:20:13.88,0:20:15.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas.
Dialogue: 0,0:20:15.26,0:20:16.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mengganggu.
Dialogue: 0,0:20:16.87,0:20:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}K-Kau mau apa?!
Dialogue: 0,0:20:19.20,0:20:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pakai baju renang di dalam air?
Dialogue: 0,0:20:22.12,0:20:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune memaksa, tapi tetap saja...
Dialogue: 0,0:20:27.71,0:20:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:29.15,0:20:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:20:30.44,0:20:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune yang menyuruhmu mandi denganku?!
Dialogue: 0,0:20:33.96,0:20:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:46.98,0:20:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Tuan Itsuki.
Dialogue: 0,0:20:49.60,0:20:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan kau mengintip?
Dialogue: 0,0:20:51.34,0:20:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari tadi.
Dialogue: 0,0:20:53.61,0:20:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada baju ganti di ruang ganti.
Dialogue: 0,0:20:56.42,0:20:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil ini juga.
Dialogue: 0,0:20:57.99,0:21:00.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat pemicu disfungsi ereksi.
Dialogue: 0,0:21:00.41,0:21:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, pil agar tidak berdiri.
Dialogue: 0,0:21:03.86,0:21:07.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Anda merasa akan tergoda oleh Nona,
Dialogue: 0,0:21:07.62,0:21:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan minum ini dulu.
Dialogue: 0,0:21:13.64,0:21:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini cuma vitamin.
Dialogue: 0,0:21:17.04,0:21:18.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari kedua sekolah.
Dialogue: 0,0:21:18.66,0:21:21.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku mencoba menyiapkan mentalku...
Dialogue: 0,0:21:21.46,0:21:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ups, aku lupa...
Dialogue: 0,0:21:24.06,0:21:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia.
Dialogue: 0,0:21:27.53,0:21:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cepat sebelum pelajaran dimulai.
Dialogue: 0,0:21:33.07,0:21:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:21:35.85,0:21:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah, sampai jumpa.
Dialogue: 0,0:21:41.35,0:21:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:21:42.68,0:21:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Itsuki?
Dialogue: 0,0:21:46.42,0:21:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}S-Salah orang.
Dialogue: 0,0:21:48.79,0:21:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong.
Dialogue: 0,0:21:50.22,0:21:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, tidak, tidak!\NKau pasti Itsuki!
Dialogue: 0,0:21:54.37,0:21:57.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti Itsuki! Tak salah lagi!
Dialogue: 0,0:22:02.73,0:22:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki! Aku rindu padamu!
