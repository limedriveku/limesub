Dialogue: 0,0:01:10.81,0:01:13.00,sign,,0000,0000,0000,,"EPISODE 1: WANITA SEMPURNA"
Dialogue: 0,0:02:07.00,0:02:08.10,sign,,0000,0000,0000,,SEMOGA BERUNTUNG
Dialogue: 0,0:03:21.44,0:03:23.69,sign,,0000,0000,0000,,"KARTU PELAJAR AKADEMI SWASTA KIOH"
Dialogue: 0,0:04:12.02,0:04:15.40,sign,,0000,0000,0000,,"KONOHANA HINAKO"
Dialogue: 0,0:08:21.44,0:08:22.52,sign,,0000,0000,0000,,SEMOGA BERUNTUNG
Dialogue: 0,0:20:54.82,0:20:55.82,sign,,0000,0000,0000,,YURI
Dialogue: 0,0:00:09.44,0:00:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali.
Dialogue: 0,0:00:12.85,0:00:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini Akademi Kioh.
Dialogue: 0,0:00:15.55,0:00:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu dari tiga sekolah\Npaling bergengsi di Jepang.
Dialogue: 0,0:00:18.52,0:00:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak siswanya berasal\Ndari keluarga kaya raya,
Dialogue: 0,0:00:21.42,0:00:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kelak akan menjadi\Ntokoh penting nasional,
Dialogue: 0,0:00:24.53,0:00:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti perdana menteri\Natau CEO perusahaan raksasa.
Dialogue: 0,0:00:30.66,0:00:32.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Konohana.
Dialogue: 0,0:00:34.93,0:00:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Konohana.
Dialogue: 0,0:00:38.45,0:00:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:00:40.35,0:00:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konohana cantik seperti biasa.
Dialogue: 0,0:00:43.39,0:00:45.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, dan anggun sekali.
Dialogue: 0,0:00:46.21,0:00:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seolah berasal dari dunia lain...
Dialogue: 0,0:00:48.93,0:00:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Tomonari?
Dialogue: 0,0:00:51.86,0:00:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak. Bukan apa-apa.
Dialogue: 0,0:00:55.12,0:00:56.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo jalan.
Dialogue: 0,0:00:56.86,0:00:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Y-Ya.
Dialogue: 0,0:00:59.67,0:01:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:01:00.56,0:01:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenalan Konohana?
Dialogue: 0,0:01:03.16,0:01:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai kemarin, ini adalah dunia\Nyang benar-benar asing bagiku.
Dialogue: 0,0:01:10.81,0:01:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tomonari!
Dialogue: 0,0:01:13.00,0:01:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaanmu selesai hari ini!
Dialogue: 0,0:01:14.56,0:01:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:01:15.33,0:01:17.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hari terakhirmu, 'kan?
Dialogue: 0,0:01:17.72,0:01:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gajimu sudah dikirim.
Dialogue: 0,0:01:19.84,0:01:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:01:21.48,0:01:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bisa bekerja bersamamu!
Dialogue: 0,0:01:22.97,0:01:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kerja bagus.
Dialogue: 0,0:01:26.00,0:01:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badannya memang kurus,\Ntapi dia pantang menyerah.
Dialogue: 0,0:01:29.17,0:01:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:01:30.15,0:01:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengambil banyak pekerjaan\Ndari pagi sampai malam.
Dialogue: 0,0:01:33.71,0:01:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa begitu?\NBukankah dia masih SMA?
Dialogue: 0,0:01:36.23,0:01:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar dia membayar sendiri\Nbiaya sekolahnya.
Dialogue: 0,0:01:40.98,0:01:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku suka mabuk dan berjudi,\Njadi kami selalu melarat.
Dialogue: 0,0:01:45.94,0:01:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku berhasil bertahan sejauh ini.
Dialogue: 0,0:01:48.49,0:01:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai hari ini...
Dialogue: 0,0:01:51.36,0:01:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!
Dialogue: 0,0:01:53.34,0:01:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka masih tidur?
Dialogue: 0,0:01:56.07,0:01:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun...
Dialogue: 0,0:01:57.24,0:01:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar mereka keluyuran tengah malam.
Dialogue: 0,0:01:59.87,0:02:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti mereka pindah-pindah bar...
Dialogue: 0,0:02:05.65,0:02:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:02:08.10,0:02:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Semoga beruntung"?
Dialogue: 0,0:02:10.12,0:02:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka akan\Nmendengar ini dari orang tuaku.
Dialogue: 0,0:02:15.18,0:02:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buku tabunganku!
Dialogue: 0,0:02:20.21,0:02:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hilang!
Dialogue: 0,0:02:21.96,0:02:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga beruntung!
Dialogue: 0,0:02:25.44,0:02:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja...
Dialogue: 0,0:02:29.56,0:02:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kami semelarat itu,\Nsampai mereka harus kabur malam-malam?
Dialogue: 0,0:02:35.00,0:02:37.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang 200 yen di sakuku...
Dialogue: 0,0:02:37.84,0:02:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ini uangku yang tersisa?
Dialogue: 0,0:02:40.70,0:02:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus makan...
Dialogue: 0,0:02:42.39,0:02:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimana untuk besok dan seterusnya?
Dialogue: 0,0:02:45.18,0:02:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:02:48.74,0:02:52.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu seragam sekolah elite\Ndi puncak bukit, 'kan?
Dialogue: 0,0:02:52.73,0:02:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok juga upacara penerimaan siswaku...
Dialogue: 0,0:02:56.50,0:02:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku batal sekolah.
Dialogue: 0,0:02:58.29,0:03:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruntungnya aku bisa menghabiskan waktu\Nbersamamu hari ini, Konohana.
Dialogue: 0,0:03:02.64,0:03:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berlebihan.
Dialogue: 0,0:03:03.71,0:03:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa besok.
Dialogue: 0,0:03:05.08,0:03:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, semoga harimu menyenangkan!
Dialogue: 0,0:03:06.80,0:03:08.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga.
Dialogue: 0,0:03:10.15,0:03:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia kami sangat berbeda.
Dialogue: 0,0:03:17.96,0:03:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kartu pelajar?
Dialogue: 0,0:03:20.14,0:03:21.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akademi Kioh?
Dialogue: 0,0:03:21.44,0:03:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang tadi!
Dialogue: 0,0:03:24.28,0:03:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, permisi!
Dialogue: 0,0:03:25.96,0:03:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barangmu jatuh!
Dialogue: 0,0:03:44.71,0:03:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masukkan dia ke mobil sekarang! Cepat!
Dialogue: 0,0:03:47.94,0:03:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu!
Dialogue: 0,0:03:50.93,0:03:52.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa kau?
Dialogue: 0,0:03:58.50,0:03:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:03:59.86,0:04:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku tak mungkin\Nmampu bayar uang tebusan...
Dialogue: 0,0:04:03.56,0:04:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam! Kau cuma tangkapan ekstra!
Dialogue: 0,0:04:06.25,0:04:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang tuaku kabur,\Ndan sekarang aku diculik...
Dialogue: 0,0:04:09.47,0:04:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dosa apa aku di kehidupan sebelumnya?!
Dialogue: 0,0:04:12.02,0:04:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dia benar-benar putri Konohana!
Dialogue: 0,0:04:15.74,0:04:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus! Kita beruntung, Bos!
Dialogue: 0,0:04:18.12,0:04:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia target utama kita!
Dialogue: 0,0:04:20.79,0:04:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Jepang!
Dialogue: 0,0:04:22.29,0:04:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena dia putri pemilik Grup Konohana!
Dialogue: 0,0:04:26.52,0:04:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konohana?
Dialogue: 0,0:04:31.67,0:04:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, gadis kaya raya sepertinya\Nbenar-benar ada di dunia nyata...
Dialogue: 0,0:04:35.13,0:04:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya cantik, dia juga sopan.
Dialogue: 0,0:04:37.64,0:04:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:04:38.35,0:04:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:40.16,0:04:41.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toilet.
Dialogue: 0,0:04:43.92,0:04:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Kami sedang berada\Ndalam situasi genting.
Dialogue: 0,0:04:45.98,0:04:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar jika dia\Ntidak bersikap seperti biasa.
Dialogue: 0,0:04:48.28,0:04:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis elite sepertinya juga tetap manusia.
Dialogue: 0,0:04:51.37,0:04:53.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toilet. Aku sudah di ujung tanduk.
Dialogue: 0,0:04:54.11,0:04:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tahan! Demi kita berdua!
Dialogue: 0,0:04:57.34,0:04:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir meledak...
Dialogue: 0,0:04:58.83,0:05:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Nona di sini\Ningin bicara dengan kalian!
Dialogue: 0,0:05:02.57,0:05:04.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan macam-macam!
Dialogue: 0,0:05:06.33,0:05:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa lega.
Dialogue: 0,0:05:08.10,0:05:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah laporan segala!
Dialogue: 0,0:05:10.41,0:05:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat berbeda dari kesan pertamaku.
Dialogue: 0,0:05:15.18,0:05:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, apa dia benar-benar\Ndari keluarga kaya?
Dialogue: 0,0:05:18.54,0:05:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapnya agak...
Dialogue: 0,0:05:19.55,0:05:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:05:20.31,0:05:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa lagi?!
Dialogue: 0,0:05:21.88,0:05:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau teh dan camilan.
Dialogue: 0,0:05:23.97,0:05:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak kenal takut!
Dialogue: 0,0:05:25.61,0:05:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, air!
Dialogue: 0,0:05:27.50,0:05:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan kubilang aku mau teh.
Dialogue: 0,0:05:30.90,0:05:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kau jaga gadis ini!
Dialogue: 0,0:05:34.01,0:05:35.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus aku?
Dialogue: 0,0:05:38.08,0:05:40.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tumpahkan semuanya?!
Dialogue: 0,0:05:40.77,0:05:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak terbiasa minum dari botol plastik.
Dialogue: 0,0:05:43.83,0:05:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang beda.
Dialogue: 0,0:05:47.57,0:05:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:05:48.39,0:05:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubantu.\NSini botolnya.
Dialogue: 0,0:05:51.20,0:05:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan dicuri, lo.
Dialogue: 0,0:05:52.28,0:05:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan! Jangan curiga begitu!
Dialogue: 0,0:05:57.01,0:06:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geser sedikit ke sini\Nbiar tidak kena tumpahan air.
Dialogue: 0,0:06:02.93,0:06:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:06:04.70,0:06:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:06:11.34,0:06:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya kau tersandung\Ndi tempat rata begini.
Dialogue: 0,0:06:14.40,0:06:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bangun?
Dialogue: 0,0:06:19.41,0:06:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:06:21.31,0:06:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, cuma lecet sedikit.
Dialogue: 0,0:06:24.14,0:06:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan disentuh, biar tidak infeksi.
Dialogue: 0,0:06:30.29,0:06:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa kau ikut diculik?
Dialogue: 0,0:06:33.47,0:06:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Oh...
Dialogue: 0,0:06:36.19,0:06:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barangmu jatuh, ya?
Dialogue: 0,0:06:40.05,0:06:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kartu pelajarku.
Dialogue: 0,0:06:44.41,0:06:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantuan akan segera datang.
Dialogue: 0,0:06:47.01,0:06:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Memangnya...
Dialogue: 0,0:06:48.40,0:06:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tidur.
Dialogue: 0,0:06:51.03,0:06:54.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa? Tidur saja.
Dialogue: 0,0:06:55.43,0:06:56.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bantal.
Dialogue: 0,0:06:58.16,0:07:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis cantik sepertinya minta dipeluk...
Dialogue: 0,0:07:02.99,0:07:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah melihat tingkah konyolnya,\Ndebar jantungku langsung hilang.
Dialogue: 0,0:07:09.18,0:07:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:07:12.83,0:07:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingginya pas.
Dialogue: 0,0:07:15.89,0:07:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:07:17.48,0:07:18.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyanyikan lagu pengantar tidur.
Dialogue: 0,0:07:18.89,0:07:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak jago menyanyi.
Dialogue: 0,0:07:22.02,0:07:25.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ceritakan hal lucu.
Dialogue: 0,0:07:25.50,0:07:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak maunya, ya.
Dialogue: 0,0:07:27.00,0:07:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Pasukan C.
Dialogue: 0,0:07:28.09,0:07:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Segera tiba di titik lokasi.
Dialogue: 0,0:07:30.04,0:07:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimengerti.
Dialogue: 0,0:07:31.35,0:07:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaga tunggu perintah selanjutnya.
Dialogue: 0,0:07:34.01,0:07:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa kali harus kubilang?!
Dialogue: 0,0:07:37.11,0:07:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku muak mendengar omong kosongmu itu!
Dialogue: 0,0:07:40.84,0:07:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit kupercaya\Ndia bisa tidur di saat begini.
Dialogue: 0,0:07:43.34,0:07:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar tak kenal takut.
Dialogue: 0,0:07:45.66,0:07:49.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat dia,\Naku juga merasa lebih tenang.
Dialogue: 0,0:07:50.22,0:07:52.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ilermu ke mana-mana.
Dialogue: 0,0:07:55.56,0:07:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa aku membangunkanmu?
Dialogue: 0,0:07:57.32,0:07:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:07:59.87,0:08:01.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan main-main!
Dialogue: 0,0:08:01.59,0:08:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika waktunya terus diulur,\Naku akan menghajar putrimu!
Dialogue: 0,0:08:07.24,0:08:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.
Dialogue: 0,0:08:08.84,0:08:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika hal terburuk terjadi,\Nsetidaknya aku bisa menjadi tameng hidupmu.
Dialogue: 0,0:08:14.53,0:08:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau rela bertindak\Nsejauh itu untukku?
Dialogue: 0,0:08:19.49,0:08:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, ya?
Dialogue: 0,0:08:22.52,0:08:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa depanku mungkin suram,\Ntapi aku masih bisa membantu orang lain.
Dialogue: 0,0:08:28.08,0:08:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya itu yang membuatku terus bertahan.
Dialogue: 0,0:08:31.32,0:08:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entahlah. Pertanyaan yang bagus.
Dialogue: 0,0:08:36.83,0:08:38.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau orang baik.
Dialogue: 0,0:08:38.76,0:08:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:39.65,0:08:41.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa nyaman bersamamu.
Dialogue: 0,0:08:41.71,0:08:45.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aromamu juga seperti futon\Nyang baru dijemur.
Dialogue: 0,0:08:45.02,0:08:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu pujian?
Dialogue: 0,0:08:46.95,0:08:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya banyak pengasuh,\Ntapi mereka hanya memikirkan pekerjaan.
Dialogue: 0,0:08:52.12,0:08:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau bicara santai denganku,
Dialogue: 0,0:08:55.28,0:08:57.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku juga bisa bersantai.
Dialogue: 0,0:08:59.36,0:09:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka itu.
Dialogue: 0,0:09:03.41,0:09:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa namamu?
Dialogue: 0,0:09:05.06,0:09:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tomonari Itsuki.
Dialogue: 0,0:09:07.70,0:09:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:09:09.04,0:09:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Konohana Hinako.
Dialogue: 0,0:09:13.53,0:09:14.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang...
Dialogue: 0,0:09:16.19,0:09:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ingin kau menjadi...
Dialogue: 0,0:09:24.07,0:09:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh unit, serbu!
Dialogue: 0,0:09:33.08,0:09:34.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua pelaku berhasil ditangkap!
Dialogue: 0,0:09:35.77,0:09:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalian bisa menemukan kami?
Dialogue: 0,0:09:38.37,0:09:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu! Aku ini korban!
Dialogue: 0,0:09:43.69,0:09:44.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wakil Komandan!
Dialogue: 0,0:09:45.19,0:09:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelaku ketiga berhasil dilumpuhkan!
Dialogue: 0,0:09:47.55,0:09:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketiga?
Dialogue: 0,0:09:49.65,0:09:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut informasi tim intai,\Ncuma ada dua penculik.
Dialogue: 0,0:09:53.51,0:09:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pelayan?
Dialogue: 0,0:09:56.85,0:09:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune.
Dialogue: 0,0:09:58.98,0:10:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan penculik.
Dialogue: 0,0:10:01.32,0:10:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:10:03.70,0:10:05.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona tidak terluka?
Dialogue: 0,0:10:06.08,0:10:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:06.89,0:10:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku karena\Nterlambat menyelamatkanmu.
Dialogue: 0,0:10:09.55,0:10:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lain kali kabari kami\Nsebelum pergi keluar.
Dialogue: 0,0:10:14.49,0:10:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi itu merepotkan.
Dialogue: 0,0:10:16.69,0:10:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau malah dalam bahaya begini.
Dialogue: 0,0:10:19.71,0:10:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar pasukan keamanan Konohana\Nyang urus sisanya.
Dialogue: 0,0:10:23.89,0:10:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita berdua akan pulang sekarang.
Dialogue: 0,0:10:25.76,0:10:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Shizune.
Dialogue: 0,0:10:28.02,0:10:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau dia.
Dialogue: 0,0:10:30.28,0:10:33.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai perintah Nona.\NAkan kami urus segera.
Dialogue: 0,0:10:34.02,0:10:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengurus?
Dialogue: 0,0:10:41.36,0:10:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:10:42.37,0:10:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu...
Dialogue: 0,0:10:43.31,0:10:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau dibawa ke mana?
Dialogue: 0,0:10:46.90,0:10:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kau bertemu seseorang.
Dialogue: 0,0:10:48.97,0:10:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:52.68,0:10:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah selesai\Nmemeriksa latar belakangmu.
Dialogue: 0,0:10:55.42,0:10:55.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:10:56.34,0:10:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tomonari Itsuki, 16 tahun.
Dialogue: 0,0:10:58.23,0:11:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak tunggal.\NKedua orang tua masih hidup.
Dialogue: 0,0:11:01.03,0:11:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau banting tulang menabung\Nuntuk biaya sekolah.
Dialogue: 0,0:11:06.44,0:11:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, orang tuamu membawa kabur\Nuang itu tadi malam,
Dialogue: 0,0:11:11.16,0:11:14.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sekarang kau sedang\Ndalam kondisi kritis.
Dialogue: 0,0:11:15.38,0:11:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana kau bisa tahu semua itu?
Dialogue: 0,0:11:17.72,0:11:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan remehkan jaringan Keluarga Konohana.
Dialogue: 0,0:11:20.84,0:11:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan, kau akan masuk kelas dua\Ndi SMA Ryugu besok,
Dialogue: 0,0:11:25.53,0:11:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kau belum membayar uang sekolah.
Dialogue: 0,0:11:27.60,0:11:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:29.00,0:11:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku benar-benar putus sekolah?
Dialogue: 0,0:11:32.55,0:11:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau juga sudah menunggak\Nuang sewa dan tagihan.
Dialogue: 0,0:11:36.71,0:11:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan aku terancam\Ntidak punya tempat tinggal?!
Dialogue: 0,0:11:42.26,0:11:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah\Nkami akan memberimu penawaran.
Dialogue: 0,0:11:45.65,0:11:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:46.80,0:11:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau bekerja untuk nonaku?
Dialogue: 0,0:11:49.86,0:11:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maksudmu...
Dialogue: 0,0:11:52.13,0:11:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi pelayan?!
Dialogue: 0,0:11:53.24,0:11:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang tepat.
Dialogue: 0,0:11:54.52,0:11:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya kepala pelayan.
Dialogue: 0,0:11:56.82,0:11:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bukan itu juga.
Dialogue: 0,0:12:00.41,0:12:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei...
Dialogue: 0,0:12:01.77,0:12:02.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal tahu saja...
Dialogue: 0,0:12:02.88,0:12:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berbuat tidak senonoh kepada Nona,
Dialogue: 0,0:12:05.60,0:12:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan langsung kami potong.
Dialogue: 0,0:12:07.43,0:12:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potong apanya...
Dialogue: 0,0:12:08.96,0:12:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan akan menjelaskan semuanya\Nsecara rinci nanti,
Dialogue: 0,0:12:13.88,0:12:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami ingin kau\Nbekerja sebagai pengurus Nona.
Dialogue: 0,0:12:23.37,0:12:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai, Nona.
Dialogue: 0,0:12:27.24,0:12:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:12:28.97,0:12:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vila Keluarga Konohana.
Dialogue: 0,0:12:30.81,0:12:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini cuma vila?!
Dialogue: 0,0:12:33.32,0:12:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa selama ini\Naku tinggal di kandang anjing?
Dialogue: 0,0:12:35.84,0:12:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang kembali, Nona.
Dialogue: 0,0:12:40.18,0:12:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup Konohana adalah perusahaan konglomerat\Nyang menaungi banyak bisnis,
Dialogue: 0,0:12:44.48,0:12:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}termasuk bank metropolitan\Ndan perusahaan dagang ternama.
Dialogue: 0,0:12:48.13,0:12:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Total asetnya mencapai 300 triliun yen.
Dialogue: 0,0:12:51.55,0:12:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nonaku adalah putri semata wayang\NKeluarga Konohana,
Dialogue: 0,0:12:54.37,0:12:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sebagian besar waktunya\Ndihabiskan di vila ini.
Dialogue: 0,0:13:00.14,0:13:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:13:01.12,0:13:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku cuma merinding\Nmelihat betapa berbedanya dunia kami.
Dialogue: 0,0:13:06.12,0:13:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap biasakan dirimu.
Dialogue: 0,0:13:07.61,0:13:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bekerja untuk Nona,\Nkau akan melihat ini setiap hari.
Dialogue: 0,0:13:13.54,0:13:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku belum buat keputusan.
Dialogue: 0,0:13:19.93,0:13:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:13:24.64,0:13:27.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti Itsuki.
Dialogue: 0,0:13:27.28,0:13:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:13:28.85,0:13:31.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kau dan Hinako selamat.
Dialogue: 0,0:13:31.55,0:13:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Konoha Kagen,\Nayah Hinako sekaligus Presdir Grup Konohana.
Dialogue: 0,0:13:39.90,0:13:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti sekarang.
Dialogue: 0,0:13:41.79,0:13:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat manja padamu.
Dialogue: 0,0:13:43.63,0:13:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:13:44.92,0:13:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertidur sambil berdiri...
Dialogue: 0,0:13:46.67,0:13:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum pernah kulihat dia bermanja-manja\Npada orang yang baru dikenalnya.
Dialogue: 0,0:13:50.80,0:13:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia sudah menemukan\Npengurus yang tepat.
Dialogue: 0,0:13:55.13,0:13:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya pengurus?
Dialogue: 0,0:13:58.07,0:14:03.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama, kau harus tahu\Nlebih banyak soal Hinako.
Dialogue: 0,0:14:03.48,0:14:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune.
Dialogue: 0,0:14:04.61,0:14:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:11.57,0:14:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Video?
Dialogue: 0,0:14:13.00,0:14:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini Akademi Kioh?
Dialogue: 0,0:14:20.76,0:14:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat siang.
Dialogue: 0,0:14:28.77,0:14:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai.
Dialogue: 0,0:14:32.54,0:14:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konohana, Konohana!
Dialogue: 0,0:14:39.05,0:14:40.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa ini?!
Dialogue: 0,0:14:40.21,0:14:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinako.
Dialogue: 0,0:14:43.17,0:14:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Hinako yang tadi.
Dialogue: 0,0:14:44.84,0:14:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:14:46.19,0:14:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinako selalu berpura-pura menjadi\Ngadis sempurna di depan orang lain.
Dialogue: 0,0:14:51.39,0:14:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kenyataannya...
Dialogue: 0,0:14:52.82,0:14:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona...
Dialogue: 0,0:14:54.35,0:14:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus pindah kelas\Nuntuk pelajaran berikutnya.
Dialogue: 0,0:14:57.04,0:14:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau. Selamat malam.
Dialogue: 0,0:14:59.05,0:15:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona?!
Dialogue: 0,0:15:01.08,0:15:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari raut wajahmu,\Nkau lebih kenal Hinako yang ini.
Dialogue: 0,0:15:05.05,0:15:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, beginilah sifat asli Hinako.
Dialogue: 0,0:15:07.74,0:15:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong bangun!\N- Dia selalu begini saat sendirian.
Dialogue: 0,0:15:10.01,0:15:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon, Nona, ganti baju dulu!
Dialogue: 0,0:15:12.57,0:15:16.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona! Nona!
Dialogue: 0,0:15:16.88,0:15:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pengurus Hinako sebelumnya.
Dialogue: 0,0:15:19.55,0:15:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beberapa hari lalu, dia masuk rumah sakit\Nkarena asam lambungnya naik akibat stres,
Dialogue: 0,0:15:24.06,0:15:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu mengajukan pengunduran diri.
Dialogue: 0,0:15:28.49,0:15:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, sebagai pengurus,
Dialogue: 0,0:15:30.90,0:15:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tugasmu adalah mendukung Hinako\Ndari balik layar
Dialogue: 0,0:15:34.43,0:15:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menutupi sifat cerobohnya\Ndari dunia luar.
Dialogue: 0,0:15:37.19,0:15:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:15:38.32,0:15:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan sangat lega\Njika kau mau menerima pekerjaan ini.
Dialogue: 0,0:15:43.65,0:15:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu...
Dialogue: 0,0:15:45.61,0:15:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku akan dapat gaji?
Dialogue: 0,0:15:49.09,0:15:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:50.62,0:15:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan tinggal di sini\Ndan dapat makan tiga kali sehari.
Dialogue: 0,0:15:52.72,0:15:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan upah\N20.000 yen per hari?
Dialogue: 0,0:15:55.82,0:15:56.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua puluh ribu?!
Dialogue: 0,0:15:56.94,0:15:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu masih kurang?
Dialogue: 0,0:15:58.72,0:16:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau 50.000 yen?
Dialogue: 0,0:16:00.80,0:16:02.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan begitu!
Dialogue: 0,0:16:02.63,0:16:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, 8.000 yen per hari saja\Nsudah sangat banyak...
Dialogue: 0,0:16:06.00,0:16:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:16:07.70,0:16:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggung jawab pengurus itu\Njauh lebih berat dari bayanganmu.
Dialogue: 0,0:16:13.77,0:16:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu kenapa Hinako berakting jadi\Ngadis sempurna di depan umum?
Dialogue: 0,0:16:19.15,0:16:19.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:16:20.29,0:16:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi mencari pria dari keluarga terpandang\Nuntuk dijodohkan dengannya.
Dialogue: 0,0:16:23.32,0:16:27.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi Grup Konohana\Nsedang memburuk akhir-akhir ini.
Dialogue: 0,0:16:27.59,0:16:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konflik internal antar faksi,\Npersaingan bisnis dengan kompetitor...
Dialogue: 0,0:16:32.00,0:16:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak masalah rumit\Nyang sedang kami hadapi.
Dialogue: 0,0:16:35.29,0:16:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, masa depan pernikahan putriku\Nsangatlah penting.
Dialogue: 0,0:16:39.55,0:16:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hinako tak pernah berhenti berakting,\Nbahkan di sekolah atau acara sosial.
Dialogue: 0,0:16:44.98,0:16:47.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di situlah peran pengurus\Nuntuk membantunya.
Dialogue: 0,0:16:48.57,0:16:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain,\Nkau akan memegang peran penting
Dialogue: 0,0:16:51.26,0:16:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menjaga nama baik Keluarga Konohana.
Dialogue: 0,0:16:53.74,0:16:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:16:55.24,0:16:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebutkan hargamu, dan akan kubayar.
Dialogue: 0,0:16:58.68,0:17:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang menguji keseriusanku?
Dialogue: 0,0:17:02.87,0:17:05.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua puluh ribu yen.
Dialogue: 0,0:17:06.78,0:17:08.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:17:08.09,0:17:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, pekerjaanmu dimulai besok.
Dialogue: 0,0:17:10.88,0:17:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok?!
Dialogue: 0,0:17:12.60,0:17:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa pengurus, Hinako bisa tersesat\Nbahkan di rumahnya sendiri.
Dialogue: 0,0:17:17.81,0:17:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune. Urus sisanya.
Dialogue: 0,0:17:20.31,0:17:21.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Tuan.
Dialogue: 0,0:17:21.97,0:17:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, satu lagi.
Dialogue: 0,0:17:24.36,0:17:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau berani menyentuh putriku...
Dialogue: 0,0:17:26.92,0:17:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anda akan memotongnya, 'kan?
Dialogue: 0,0:17:30.04,0:17:31.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memotongnya?
Dialogue: 0,0:17:32.72,0:17:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan melakukan itu.
Dialogue: 0,0:17:35.65,0:17:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma akan membunuhmu.
Dialogue: 0,0:17:37.44,0:17:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh!
Dialogue: 0,0:17:41.15,0:17:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kamarmu, Itsuki.
Dialogue: 0,0:17:46.78,0:17:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragammu ada di sini.
Dialogue: 0,0:17:48.90,0:17:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dicoba\Nuntuk memastikan ukurannya pas.
Dialogue: 0,0:17:51.15,0:17:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seragam pelayan rumah tangga?
Dialogue: 0,0:17:53.34,0:17:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, seragam Akademi Kioh.
Dialogue: 0,0:17:56.76,0:17:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:57.99,0:18:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekolah di Akademi Kioh?
Dialogue: 0,0:18:00.65,0:18:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, karena Nona sekolah di sana.
Dialogue: 0,0:18:04.00,0:18:06.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua kebetulan satu angkatan.
Dialogue: 0,0:18:06.20,0:18:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tapi orang biasa sepertiku...
Dialogue: 0,0:18:09.16,0:18:11.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini profil barumu.
Dialogue: 0,0:18:13.09,0:18:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pewaris perusahaan IT?
Dialogue: 0,0:18:16.00,0:18:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latar belakangmu tidak akan\Ndicurigai pihak akademi.
Dialogue: 0,0:18:19.02,0:18:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar tidak mencolok,\Nkami tidak menggunakan nama
Dialogue: 0,0:18:21.20,0:18:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak perusahaan Grup Konohana,
Dialogue: 0,0:18:22.73,0:18:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi menggunakan perusahaan rekanan.
Dialogue: 0,0:18:24.47,0:18:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tapi tetap saja...
Dialogue: 0,0:18:26.03,0:18:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kurikulum di sana\Njuga tidak main-main.
Dialogue: 0,0:18:29.23,0:18:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku bisa mengikuti pelajarannya?
Dialogue: 0,0:18:31.11,0:18:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulihat nilaimu cukup bagus.
Dialogue: 0,0:18:33.72,0:18:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak benci belajar, 'kan?
Dialogue: 0,0:18:36.48,0:18:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja...
Dialogue: 0,0:18:37.80,0:18:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau khawatir?
Dialogue: 0,0:18:40.32,0:18:42.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah aku ada di sini.
Dialogue: 0,0:18:44.52,0:18:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf baru memperkenalkan diri.
Dialogue: 0,0:18:46.61,0:18:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah pelayan pribadi Nona.
Dialogue: 0,0:18:48.60,0:18:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Tsurumi Shizune.
Dialogue: 0,0:18:50.65,0:18:53.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan melatihmu\Nmenjadi seorang pengurus.
Dialogue: 0,0:18:53.63,0:18:55.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:18:56.68,0:18:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:18:58.17,0:19:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, ini buku panduan pengurus.
Dialogue: 0,0:19:01.68,0:19:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebal sekali!
Dialogue: 0,0:19:03.16,0:19:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, buku pelajaran\Ndan buku referensi.
Dialogue: 0,0:19:05.35,0:19:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat sekali!
Dialogue: 0,0:19:06.83,0:19:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap hari sebelum makan malam,
Dialogue: 0,0:19:08.26,0:19:12.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus menyiapkan materi\Nuntuk pelajaran besok.
Dialogue: 0,0:19:12.79,0:19:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma soal akademik.
Dialogue: 0,0:19:14.45,0:19:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tata krama, cara bersikap...
Dialogue: 0,0:19:16.15,0:19:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan sampai ilmu bela diri.
Dialogue: 0,0:19:18.13,0:19:19.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bela diri?
Dialogue: 0,0:19:19.87,0:19:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Apa kau mulai ragu?
Dialogue: 0,0:19:22.28,0:19:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku terbiasa melakukan kerja kasar.
Dialogue: 0,0:19:25.80,0:19:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lumayan percaya diri dengan fisikku.
Dialogue: 0,0:19:28.13,0:19:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menilai kemampuanmu\Nsetelah sesi belajar nanti.
Dialogue: 0,0:19:32.14,0:19:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan kehebatan siswa\Nyang sudah terbiasa banting tulang!
Dialogue: 0,0:19:39.15,0:19:40.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tak kuat.\NTolong lepaskan aku.
Dialogue: 0,0:19:40.81,0:19:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum aku mati.
Dialogue: 0,0:19:42.16,0:19:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah. Sesi hari ini kita akhiri.
Dialogue: 0,0:19:45.97,0:19:47.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus.
Dialogue: 0,0:19:47.87,0:19:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih...
Dialogue: 0,0:19:52.39,0:19:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini benar-benar panjang.
Dialogue: 0,0:20:05.16,0:20:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No-Nona... Hinako!
Dialogue: 0,0:20:09.17,0:20:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Nona ada di sini?
Dialogue: 0,0:20:11.13,0:20:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidur di kasurku.
Dialogue: 0,0:20:13.97,0:20:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasur pengurusku adalah kasurku juga.
Dialogue: 0,0:20:22.01,0:20:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar, buku panduan!
Dialogue: 0,0:20:25.33,0:20:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, di mana itu, ya?
Dialogue: 0,0:20:31.41,0:20:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau berangkat sekolah bareng besok?
Dialogue: 0,0:20:33.48,0:20:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, aku belum bilang apa-apa ke Yuri.
Dialogue: 0,0:20:36.47,0:20:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak mau, ya sudah.
Dialogue: 0,0:20:38.62,0:20:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa pergi dengan orang lain saja.
Dialogue: 0,0:20:40.98,0:20:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana aku menjelaskannya, ya?
Dialogue: 0,0:20:43.05,0:20:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan cuma dibaca!
Dialogue: 0,0:20:46.73,0:20:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada banyak masalah, dan sekarang\Naku pindah sekolah.
Dialogue: 0,0:20:51.23,0:20:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau bisa\Nditelepon sekarang?
Dialogue: 0,0:20:54.05,0:20:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:20:57.49,0:21:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku lelah. Kapan-kapan saja, ya.
Dialogue: 0,0:21:00.69,0:21:02.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak dijawab?
Dialogue: 0,0:21:02.87,0:21:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:21:04.61,0:21:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:21:05.70,0:21:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:21:08.49,0:21:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah bangun?
Dialogue: 0,0:21:10.27,0:21:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:21:12.12,0:21:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:13.22,0:21:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, teman masa kecilku di sekolah lamaku.
Dialogue: 0,0:21:22.29,0:21:23.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang ini milikku.
Dialogue: 0,0:21:23.78,0:21:24.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:21:24.71,0:21:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya bisa tenang.
Dialogue: 0,0:21:27.51,0:21:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang apanya?
Dialogue: 0,0:21:29.18,0:21:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kembalikan.
Dialogue: 0,0:21:30.89,0:21:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau.
Dialogue: 0,0:21:31.67,0:21:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu, dong.\NTolong kembalikan, ya?
Dialogue: 0,0:21:34.49,0:21:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benci gaya bicaramu itu.
Dialogue: 0,0:21:36.77,0:21:38.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bicaralah seperti biasa.
Dialogue: 0,0:21:38.45,0:21:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shizune bilang aku harus\Nbicara lebih sopan padamu...
Dialogue: 0,0:21:42.34,0:21:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak bicara biasa,\Nponselmu aku sita selamanya.
Dialogue: 0,0:21:47.88,0:21:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini saja cukup?
Dialogue: 0,0:21:50.25,0:21:52.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Seperti itu.
Dialogue: 0,0:21:54.47,0:21:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itsuki.
Dialogue: 0,0:21:55.82,0:21:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:57.31,0:21:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai besok...
Dialogue: 0,0:21:59.32,0:22:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong urus aku, ya.
Dialogue: 0,0:22:02.11,0:22:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tentu.
Dialogue: 0,0:22:04.70,0:22:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan tidur di sini lagi!
Dialogue: 0,0:22:07.56,0:22:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kasurku, tahu!
Dialogue: 0,0:23:28.78,0:23:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rich Girl Caretaker:
Dialogue: 0,0:23:30.87,0:23:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I'm Secretly the Caregiver of the\NMost Popular Girl in This Rich Kid School
