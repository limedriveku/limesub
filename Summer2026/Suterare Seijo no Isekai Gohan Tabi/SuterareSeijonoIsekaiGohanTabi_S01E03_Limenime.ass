Dialogue: 0,0:00:55.74,0:01:01.42,sign,,0000,0000,0000,,THE FORSAKEN SAINTESS\NAND HER FOODIE ROADTRIP IN ANOTHER WORLD
Dialogue: 0,0:02:01.98,0:02:02.73,sign,,0000,0000,0000,,EPISODE 3: BERTARUNG DI TEPI PANTAI
Dialogue: 0,0:02:02.73,0:02:06.48,sign,,0000,0000,0000,,DAN BARBEKU HIDANGAN LAUT
Dialogue: 0,0:06:02.88,0:06:06.85,sign,,0000,0000,0000,,ELRAGE
Dialogue: 0,0:07:03.82,0:07:06.53,sign,,0000,0000,0000,,TAS PERALATAN
Dialogue: 0,0:07:22.13,0:07:23.09,sign,,0000,0000,0000,,MASAK NASI, MULAI
Dialogue: 0,0:09:05.07,0:09:09.28,sign,,0000,0000,0000,,PENUH AMARAH
Dialogue: 0,0:09:30.80,0:09:31.43,sign,,0000,0000,0000,,CUMI SURUIKA - BISA DIMAKAN: SANGAT LEZAT
Dialogue: 0,0:09:31.43,0:09:31.89,sign,,0000,0000,0000,,TEBAL, RENYAH, HATI BERLEMAK, ENAK,
Dialogue: 0,0:09:31.89,0:09:32.22,sign,,0000,0000,0000,,BISA MAKAN MENTAH ATAU MATANG
Dialogue: 0,0:09:32.22,0:09:32.84,sign,,0000,0000,0000,,SAAT MAKAN MENTAH, TEKSTUR RENYAH DAN KENYAL
Dialogue: 0,0:09:32.84,0:09:33.59,sign,,0000,0000,0000,,SETELAH DIMASAK, LEBIH EMPUK DAN MANIS
Dialogue: 0,0:09:33.59,0:09:34.39,sign,,0000,0000,0000,,TIDAK SEMUA ORANG SUKA, PORSI HATI BESAR
Dialogue: 0,0:09:34.39,0:09:35.01,sign,,0000,0000,0000,,RASA UNIK, SEGAR, DAN PEKAT
Dialogue: 0,0:14:12.44,0:14:13.12,sign,,0000,0000,0000,,KESAL
Dialogue: 0,0:16:03.19,0:16:03.90,sign,,0000,0000,0000,,BABY PLUP - BISA DIMAKAN: SANGAT LEZAT\NMONSTER MUDA YANG HIDUP DI DEKAT PANTAI
Dialogue: 0,0:16:03.90,0:16:04.78,sign,,0000,0000,0000,,SERAM, TEKSTUR DAGINGNYA COCOK UNTUK DIMAKAN
Dialogue: 0,0:16:04.78,0:16:05.94,sign,,0000,0000,0000,,ASALKAN OTAK DI ANTARA KEDUA MATA DIHANCURKAN,\NKEKAKUAN SETELAH MATI AKAN BERKURANG
Dialogue: 0,0:16:05.94,0:16:07.11,sign,,0000,0000,0000,,DAN DAGINGNYA AKAN LEBIH LEZAT
Dialogue: 0,0:23:35.02,0:23:40.02,sign,,0000,0000,0000,,EPISODE 4: IBLIS KULINER DATANG!\NHARUS PAKAI SAUS TARTAR
Dialogue: 0,0:00:06.72,0:00:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini atap ruangan yang asing.
Dialogue: 0,0:00:08.86,0:00:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda!
Dialogue: 0,0:00:10.16,0:00:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momen klise ini sudah kualami sebelumnya.
Dialogue: 0,0:00:14.69,0:00:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pagi kedua yang kualami\Nsejak dipanggil ke isekai.
Dialogue: 0,0:00:18.37,0:00:21.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat teman yang bersedia\Nmemberiku tempat tinggal.
Dialogue: 0,0:00:21.92,0:00:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti mimpi.
Dialogue: 0,0:00:23.34,0:00:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini, aku juga seorang petualang!
Dialogue: 0,0:00:26.05,0:00:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus balas rasa percaya mereka padaku!
Dialogue: 0,0:02:02.73,0:02:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini kita patroli di sekitar Elrage.
Dialogue: 0,0:02:06.48,0:02:09.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ingin patroli dari pantai dulu.
Dialogue: 0,0:02:09.19,0:02:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang punya saran?
Dialogue: 0,0:02:10.94,0:02:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesi diskusi sebelum menjalankan misi.
Dialogue: 0,0:02:13.78,0:02:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serasa seperti petualang betulan!\N- Pantai, ya.
Dialogue: 0,0:02:15.91,0:02:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ke pantai, kita makan ikan?
Dialogue: 0,0:02:17.62,0:02:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerang Sari pada musim ini juga\Nsangat besar dan rasanya enak.
Dialogue: 0,0:02:20.95,0:02:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, makan siang kita hari ini\Npesta hidangan laut.
Dialogue: 0,0:02:25.01,0:02:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita putuskan pergi ke pantai.
Dialogue: 0,0:02:26.53,0:02:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Setuju!
Dialogue: 0,0:02:27.96,0:02:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu dulu!
Dialogue: 0,0:02:30.30,0:02:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung diputuskan seperti itu?
Dialogue: 0,0:02:32.30,0:02:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, barusan kita baru sarapan,
Dialogue: 0,0:02:36.05,0:02:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa sudah bahas makan siang?
Dialogue: 0,0:02:38.26,0:02:41.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sarapan buatan Rin juga enak,
Dialogue: 0,0:02:41.52,0:02:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami juga menantikan makan siang.
Dialogue: 0,0:02:43.71,0:02:45.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, ya?
Dialogue: 0,0:02:46.35,0:02:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tamu sepagi ini?
Dialogue: 0,0:02:50.94,0:02:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, terima kasih banyak\Nuntuk yang kemarin!
Dialogue: 0,0:02:55.68,0:02:57.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kan sudah bilang.
Dialogue: 0,0:02:57.03,0:03:01.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menolong tim pemula\Nyang diserang Beruang Api.
Dialogue: 0,0:03:03.01,0:03:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat kamu bilang namanya\NSemanggi Keberuntungan, kan?
Dialogue: 0,0:03:05.84,0:03:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu aku sedang tidak ada,\Nsyukurlah kalian selamat.
Dialogue: 0,0:03:09.09,0:03:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:10.08,0:03:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sebenarnya sudah siap memusnahkannya.
Dialogue: 0,0:03:12.15,0:03:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi berkat bantuan kalian dari Meja Rakus,
Dialogue: 0,0:03:14.48,0:03:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami dan guru baru\Nbisa kembali dengan selamat!
Dialogue: 0,0:03:17.47,0:03:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu sungkan.
Dialogue: 0,0:03:18.91,0:03:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior membantu junior itu hal yang wajar.
Dialogue: 0,0:03:22.11,0:03:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:03:23.06,0:03:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti setelah kalian makin mahir,
Dialogue: 0,0:03:25.28,0:03:27.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}giliran kalian yang membantu pemula.
Dialogue: 0,0:03:27.48,0:03:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:03:29.97,0:03:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya langsung berseri!
Dialogue: 0,0:03:31.67,0:03:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville dan yang lainnya memang\Npetualang top yang terkenal!
Dialogue: 0,0:03:36.24,0:03:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, kamu...
Dialogue: 0,0:03:37.82,0:03:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rento!
Dialogue: 0,0:03:38.70,0:03:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Rento, Manusia Kucing.
Dialogue: 0,0:03:40.52,0:03:42.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memperkenalkan diri.
Dialogue: 0,0:03:42.20,0:03:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rin.
Dialogue: 0,0:03:43.65,0:03:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku porter sekaligus koki di Meja Rakus.
Dialogue: 0,0:03:47.65,0:03:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rento, kamu sekecil ini\Nsudah menjadi petualang?
Dialogue: 0,0:03:51.21,0:03:52.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:52.05,0:03:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dibesarkan\Ndi panti asuhan gereja sejak kecil.
Dialogue: 0,0:03:55.34,0:03:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk membantu menutupi\Nsebagian biaya operasional gereja,
Dialogue: 0,0:03:58.19,0:04:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku membentuk tim petualang bersama\Nguru pendeta dan teman-teman lainnya.
Dialogue: 0,0:04:02.15,0:04:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:04:03.56,0:04:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski isekai di sini klise,
Dialogue: 0,0:04:06.39,0:04:09.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya jangan bersimpati.
Dialogue: 0,0:04:09.06,0:04:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya,
Dialogue: 0,0:04:09.81,0:04:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tunggu sebentar, ya!
Dialogue: 0,0:04:11.90,0:04:13.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:15.18,0:04:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rento!
Dialogue: 0,0:04:16.69,0:04:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak keberatan, terima ini!
Dialogue: 0,0:04:20.20,0:04:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada aroma manis!
Dialogue: 0,0:04:22.39,0:04:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:04:23.99,0:04:27.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kue kering Ruleberi buatanku.
Dialogue: 0,0:04:27.00,0:04:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cuma kue kering panggang sederhana,
Dialogue: 0,0:04:28.83,0:04:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau tak keberatan,\Nmakanlah bersama orang-orang di panti.
Dialogue: 0,0:04:34.42,0:04:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:04:36.78,0:04:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Renyah dan manis saat dimakan,
Dialogue: 0,0:04:38.59,0:04:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}buah berinya juga segar dan berair!
Dialogue: 0,0:04:40.58,0:04:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku makan\Nkue kering seenak ini.
Dialogue: 0,0:04:44.14,0:04:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa bertarung,\Ndan hanya bisa mendukung seperti ini.
Dialogue: 0,0:04:47.72,0:04:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat terus ke depannya, ya!
Dialogue: 0,0:04:49.19,0:04:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:04:51.23,0:04:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Rin!
Dialogue: 0,0:04:55.47,0:04:57.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misi patroli yang kita terima kali ini
Dialogue: 0,0:04:57.92,0:05:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah agar anak-anak seperti itu\Nbisa bertualang dengan tenang.
Dialogue: 0,0:05:02.41,0:05:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi itu
Dialogue: 0,0:05:04.32,0:05:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- makanan apa?\N- Makanan?
Dialogue: 0,0:05:05.58,0:05:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tadi itu?\NMaksudnya kue kering Ruleberi?
Dialogue: 0,0:05:09.65,0:05:11.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, kemarin...
Dialogue: 0,0:05:11.92,0:05:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bertemu Ed dan kalian di hutan,\Naku sekalian memetiknya.
Dialogue: 0,0:05:15.34,0:05:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya mau kujadikan camilan hari ini.
Dialogue: 0,0:05:18.59,0:05:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, semuanya?
Dialogue: 0,0:05:20.84,0:05:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma bocah itu yang dikasih, curang.
Dialogue: 0,0:05:22.68,0:05:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau makan.
Dialogue: 0,0:05:24.39,0:05:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Camilan manis baru, membuatku penasaran.
Dialogue: 0,0:05:26.72,0:05:28.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan manis juga bisa kumakan!
Dialogue: 0,0:05:28.35,0:05:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Tenang dulu.
Dialogue: 0,0:05:30.31,0:05:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyisakan bagian kalian.
Dialogue: 0,0:05:33.06,0:05:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kapan kita pergi\Nmenjalankan misinya?
Dialogue: 0,0:05:41.00,0:05:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian baik-baik saja?\NTidak mabuk perjalanan?
Dialogue: 0,0:05:44.74,0:05:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami baik-baik saja.
Dialogue: 0,0:05:46.49,0:05:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, setelah dipikir, skill ini memang hebat.
Dialogue: 0,0:05:53.17,0:05:55.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi Aria yang berseri, imut sekali!
Dialogue: 0,0:05:55.78,0:05:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, mereka selalu heboh.
Dialogue: 0,0:05:58.09,0:06:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lewat pelabuhan,\Nkita bisa sampai ke pantai dengan cepat,
Dialogue: 0,0:06:00.89,0:06:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kita tak punya izin keluar masuk.
Dialogue: 0,0:06:02.88,0:06:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kita terpaksa memutar jauh begini.
Dialogue: 0,0:06:06.85,0:06:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:07.96,0:06:09.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya kalian punya porter.
Dialogue: 0,0:06:09.92,0:06:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuantar kalian ke mana pun\Ndengan aman!
Dialogue: 0,0:06:11.99,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas porter bukan mengangkut\Nrekan setim sendiri, kan?
Dialogue: 0,0:06:15.56,0:06:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pantai!
Dialogue: 0,0:06:16.98,0:06:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville, kita sudah sampai di pantai!
Dialogue: 0,0:06:18.81,0:06:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jalan kaki, butuh waktu\Nhampir setengah hari.
Dialogue: 0,0:06:27.20,0:06:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pergi patroli di sekitar sini dulu.
Dialogue: 0,0:06:29.62,0:06:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, sambil menunggu kalian,\Nakan kusiapkan makan siang.
Dialogue: 0,0:06:32.36,0:06:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, semuanya!
Dialogue: 0,0:06:34.33,0:06:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulangnya kami akan bawa banyak bahan.
Dialogue: 0,0:06:36.08,0:06:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan pada kami!
Dialogue: 0,0:06:37.07,0:06:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupa harus patroli juga.
Dialogue: 0,0:06:39.59,0:06:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yahuy!
Dialogue: 0,0:06:40.80,0:06:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kencan di pantai dengan Aria!\N- Langsung melupakan misinya.
Dialogue: 0,0:06:43.01,0:06:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita berangkat.
Dialogue: 0,0:06:48.47,0:06:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:06:49.68,0:06:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata kami adalah model khusus\Nyang dibuat dari kontrak sihir.
Dialogue: 0,0:06:53.48,0:06:55.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa disimpan dan diambil kapan saja.
Dialogue: 0,0:06:55.91,0:06:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, meski agak mahal,
Dialogue: 0,0:06:58.02,0:07:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak semua petualang memilikinya.
Dialogue: 0,0:07:00.23,0:07:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat praktis.
Dialogue: 0,0:07:01.19,0:07:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:07:02.71,0:07:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini
Dialogue: 0,0:07:03.82,0:07:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak ada Tas Peralatan yang biasa di gim?
Dialogue: 0,0:07:07.52,0:07:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sebabnya mereka butuh porter?
Dialogue: 0,0:07:18.96,0:07:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masukkan sayuran yang mirip tomat\Nyang baru dibeli di pasar
Dialogue: 0,0:07:22.13,0:07:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu masak bersama beras!
Dialogue: 0,0:07:23.09,0:07:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu buah yang mirip terong ini...
Dialogue: 0,0:07:25.42,0:07:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ribet, sebut terong saja.
Dialogue: 0,0:07:27.39,0:07:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville dan yang lainnya sepertinya\Nkurang suka sayuran.
Dialogue: 0,0:07:31.01,0:07:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku akan tunjukkan\Nbahwa sayur juga bisa jadi hidangan utama!
Dialogue: 0,0:07:34.31,0:07:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, sayur?
Dialogue: 0,0:07:36.64,0:07:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria?
Dialogue: 0,0:07:37.65,0:07:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang suka.
Dialogue: 0,0:07:41.36,0:07:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, vitamin sayuran baik\Nuntuk luka dan daya tahan tubuh.
Dialogue: 0,0:07:46.11,0:07:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kusarankan makan sedikit.
Dialogue: 0,0:07:48.89,0:07:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bilang begitu...
Dialogue: 0,0:07:50.62,0:07:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu ini, baru kutangkap dan ini buatmu.
Dialogue: 0,0:07:53.54,0:07:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ikan kakap, kan?\NSelain itu, ukurannya gede!
Dialogue: 0,0:07:56.83,0:07:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tak sabar ingin makan ikan.
Dialogue: 0,0:07:58.75,0:08:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahan untuk hidangan utama\Nsudah datang, ya?
Dialogue: 0,0:08:01.40,0:08:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakap goreng dan kakap goreng mentega\Njuga enak,
Dialogue: 0,0:08:03.55,0:08:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kali ini akan kugoreng renyah
Dialogue: 0,0:08:05.84,0:08:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kumasak jadi kakap goreng ala Prancis.
Dialogue: 0,0:08:08.48,0:08:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, ada orang yang kamu suka?
Dialogue: 0,0:08:10.97,0:08:12.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:12.18,0:08:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang kusuka?
Dialogue: 0,0:08:14.36,0:08:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia istri yang pintar dan imut sekali!
Dialogue: 0,0:08:17.48,0:08:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bahas percintaan denganmu.
Dialogue: 0,0:08:19.27,0:08:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ini obrolan rutin para wanita.
Dialogue: 0,0:08:21.19,0:08:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Ville?\NKamu membencinya?
Dialogue: 0,0:08:23.19,0:08:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:24.82,0:08:27.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, siapa yang bisa membenci\Norang sehebat itu?
Dialogue: 0,0:08:28.55,0:08:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cinta padanya?
Dialogue: 0,0:08:30.29,0:08:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih ke suka.
Dialogue: 0,0:08:32.28,0:08:34.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, suka, ya.
Dialogue: 0,0:08:34.58,0:08:35.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lirik.
Dialogue: 0,0:08:36.49,0:08:38.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak goyah, dia lawan yang sulit.
Dialogue: 0,0:08:39.51,0:08:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada membahas tentang diriku,
Dialogue: 0,0:08:41.40,0:08:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku lebih penasaran cerita dirimu dan Ed.
Dialogue: 0,0:08:44.84,0:08:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:08:47.63,0:08:48.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja.
Dialogue: 0,0:08:48.80,0:08:49.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!
Dialogue: 0,0:08:51.95,0:08:55.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak cerita,\Naku mungkin tidak bisa memasak.
Dialogue: 0,0:08:55.97,0:08:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Licik sekali.
Dialogue: 0,0:08:57.27,0:08:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang!
Dialogue: 0,0:08:58.92,0:09:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Aria?
Dialogue: 0,0:09:00.56,0:09:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua, kenapa?
Dialogue: 0,0:09:02.65,0:09:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dipermalukan oleh Rin.
Dialogue: 0,0:09:05.07,0:09:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, maksudnya?
Dialogue: 0,0:09:08.11,0:09:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salah paham!
Dialogue: 0,0:09:09.28,0:09:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya tanya bagaimana\Nkalian berdua bisa bertemu!
Dialogue: 0,0:09:14.16,0:09:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maksudnya itu, ya.
Dialogue: 0,0:09:16.66,0:09:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istriku yang sedang malu ini sangat imut.
Dialogue: 0,0:09:20.04,0:09:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena bisa membuat Aria malu,\Naku beri kamu hadiah!
Dialogue: 0,0:09:25.47,0:09:26.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini bisa dimakan?
Dialogue: 0,0:09:26.97,0:09:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubus yang dipenuhi air?
Dialogue: 0,0:09:28.34,0:09:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga sihir?
Dialogue: 0,0:09:29.99,0:09:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:09:30.80,0:09:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini kan cumi-cumi!
Dialogue: 0,0:09:32.84,0:09:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak, Ed!
Dialogue: 0,0:09:34.39,0:09:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak, Ed.
Dialogue: 0,0:09:35.01,0:09:36.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak?
Dialogue: 0,0:09:36.77,0:09:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:09:37.57,0:09:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma jadi hidangan utama,\Ncocok juga jadi camilan.
Dialogue: 0,0:09:40.31,0:09:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya bisa diolah jadi apa pun!
Dialogue: 0,0:09:42.90,0:09:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sekarang kita buat makan siang dulu!
Dialogue: 0,0:09:46.26,0:09:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, selamat makan!
Dialogue: 0,0:09:51.03,0:09:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, ini...
Dialogue: 0,0:09:53.00,0:09:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini sepertinya banyak sayurnya, ya?
Dialogue: 0,0:09:55.87,0:09:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar mengenyangkan,\Naku sengaja membuatnya lebih berminyak.
Dialogue: 0,0:09:59.70,0:10:02.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami jarang makan sayur.
Dialogue: 0,0:10:02.41,0:10:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sampai membuatmu cemas, ya.
Dialogue: 0,0:10:05.61,0:10:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayur...
Dialogue: 0,0:10:09.48,0:10:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:10:11.53,0:10:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sayur, tapi enak!
Dialogue: 0,0:10:13.84,0:10:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keju dan tomatnya sama-sama enak.
Dialogue: 0,0:10:16.35,0:10:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria mau makan sayur?
Dialogue: 0,0:10:18.06,0:10:19.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:10:19.14,0:10:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kombinasi terong, keju, dan tomat\Nmemang tidak terkalahkan!
Dialogue: 0,0:10:26.23,0:10:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil!
Dialogue: 0,0:10:27.44,0:10:29.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayur juga bisa dibuat seenak ini?
Dialogue: 0,0:10:29.69,0:10:31.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi tomat ini juga,
Dialogue: 0,0:10:31.28,0:10:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasa asam dan aroma mentega berpadu\Ndengan sempurna, sangat enak!
Dialogue: 0,0:10:35.07,0:10:36.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:36.16,0:10:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayur bisa membuat cita rasa\Nmasakan makin kaya,
Dialogue: 0,0:10:39.33,0:10:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, akan kubuat hidangan\Nsayuran yang bisa kalian makan!
Dialogue: 0,0:10:42.25,0:10:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, daging dan ikan juga kubuatkan!
Dialogue: 0,0:10:48.00,0:10:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih hidangannya!
Dialogue: 0,0:10:53.26,0:10:56.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, apa ada yang kamu inginkan?
Dialogue: 0,0:10:56.34,0:10:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada, akan kubawakan.
Dialogue: 0,0:10:58.19,0:10:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadanya menyentuhku!
Dialogue: 0,0:10:59.76,0:11:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, sudah ada cumi-cumi,
Dialogue: 0,0:11:01.93,0:11:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau ada ikan dan kerang lainnya,
Dialogue: 0,0:11:03.81,0:11:06.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin bisa dibuat Bouillabaisse.
Dialogue: 0,0:11:06.05,0:11:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal tambah tomat dan beri sedikit bumbu!
Dialogue: 0,0:11:08.36,0:11:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti sup makanan laut ala nelayan, ya?
Dialogue: 0,0:11:10.60,0:11:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bakal enak.
Dialogue: 0,0:11:13.07,0:11:15.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tambah kepiting atau udang juga enak, kan?
Dialogue: 0,0:11:15.28,0:11:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan pergi mencari ikan
Dialogue: 0,0:11:18.07,0:11:20.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terperangkap di kolam air surut.
Dialogue: 0,0:11:20.24,0:11:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tunggu, tadi pagi kita sudah bahas ini.\N- Kalau begitu, aku cari kerang!
Dialogue: 0,0:11:23.16,0:11:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tujuan kita ke sini\N- Aku akan tangkap ikan kecil
Dialogue: 0,0:11:25.21,0:11:26.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- untuk patroli area sekitar!\N- di perairan dangkal.
Dialogue: 0,0:11:27.92,0:11:29.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:11:33.63,0:11:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, bantu kami!
Dialogue: 0,0:11:39.43,0:11:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa sengaja, aku jadi ikut kemari.
Dialogue: 0,0:11:41.26,0:11:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka juga tidak bilang apa-apa,\Nseharusnya baik-baik saja, kan?
Dialogue: 0,0:11:45.01,0:11:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:45.81,0:11:48.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu... paus orca?
Dialogue: 0,0:11:48.09,0:11:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Prankster.
Dialogue: 0,0:11:50.12,0:11:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada juga yang memanggilnya\N"Pengacau Pantai".
Dialogue: 0,0:11:53.73,0:11:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis muda di sana,
Dialogue: 0,0:11:55.49,0:11:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu mendengarku?
Dialogue: 0,0:11:57.16,0:12:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku sedang berbicara\Nlangsung di dalam hatimu.
Dialogue: 0,0:12:01.37,0:12:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara makhluk ini\Nlangsung masuk ke pikiranku.
Dialogue: 0,0:12:06.83,0:12:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali, ya.
Dialogue: 0,0:12:08.71,0:12:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa situasiku jadi seperti ini?
Dialogue: 0,0:12:12.41,0:12:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada cerita panjang\Nyang tak diketahui siapa pun.
Dialogue: 0,0:12:15.38,0:12:17.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita yang tidak diketahui siapa pun?
Dialogue: 0,0:12:17.26,0:12:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sebenarnya...
Dialogue: 0,0:12:19.76,0:12:23.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berniat melompat keluar dari laut
Dialogue: 0,0:12:23.51,0:12:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengejutkan para petualang\Ndan menyerang mereka.
Dialogue: 0,0:12:27.25,0:12:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, hasilnya,
Dialogue: 0,0:12:30.91,0:12:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku malah terperangkap seperti ini!
Dialogue: 0,0:12:32.52,0:12:34.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena ulahmu sendiri!
Dialogue: 0,0:12:34.07,0:12:35.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hehe.
Dialogue: 0,0:12:35.13,0:12:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, senyumnya seram!
Dialogue: 0,0:12:36.78,0:12:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prankster suka mengganggu orang\Ndengan kemampuan telepati yang kuat.
Dialogue: 0,0:12:43.78,0:12:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Muda, reaksimu bagus sekali.
Dialogue: 0,0:12:46.41,0:12:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu hadiah terima kasih.\NBisakah membantuku?
Dialogue: 0,0:12:49.75,0:12:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita biarkan saja\Ndia kesulitan seperti ini.
Dialogue: 0,0:12:52.96,0:12:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, makhluk ini juga dijuluki\NPembawa Keberuntungan.
Dialogue: 0,0:12:57.09,0:12:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, akulah makhluk itu!
Dialogue: 0,0:13:00.23,0:13:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski suka usil, selama membantunya,
Dialogue: 0,0:13:03.64,0:13:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan memberikan hadiah\Ndan imbalan yang setimpal.
Dialogue: 0,0:13:06.02,0:13:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kami saja, tak sanggup mengangkatnya.
Dialogue: 0,0:13:08.64,0:13:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami butuh bantuan para ahli seperti kalian.
Dialogue: 0,0:13:11.29,0:13:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong, ini demi hadiahnya juga!
Dialogue: 0,0:13:17.31,0:13:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membiarkannya mati juga kasihan.
Dialogue: 0,0:13:19.76,0:13:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:13:28.79,0:13:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak bergerak.
Dialogue: 0,0:13:30.72,0:13:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena di sini licin.
Dialogue: 0,0:13:34.67,0:13:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas!
Dialogue: 0,0:13:42.53,0:13:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed.
Dialogue: 0,0:13:43.77,0:13:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubus air yang tadi, bisa dibuat satu lagi?
Dialogue: 0,0:13:46.99,0:13:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa.
Dialogue: 0,0:13:48.21,0:13:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, untuk apa?
Dialogue: 0,0:13:49.60,0:13:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matahari sekarang sangat terik,
Dialogue: 0,0:13:51.23,0:13:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kusarankan siram dia sesekali\Nuntuk mendinginkannya!
Dialogue: 0,0:13:54.61,0:13:57.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kalau untuk hal seperti itu,\Nserahkan padaku.
Dialogue: 0,0:14:04.11,0:14:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Muda, kamu sangat peka.
Dialogue: 0,0:14:07.45,0:14:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulitku yang mulus hampir saja\Nterbakar matahari.
Dialogue: 0,0:14:10.62,0:14:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu sedikit pujian.
Dialogue: 0,0:14:13.12,0:14:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa paus orca ini sebaiknya kupanggang\Npakai merica dan minyak zaitun sampai kuning?
Dialogue: 0,0:14:16.72,0:14:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Muda?
Dialogue: 0,0:14:17.63,0:14:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, dorong lebih kuat lagi!
Dialogue: 0,0:14:21.51,0:14:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peranku biasanya sebagai pendukung.
Dialogue: 0,0:14:24.67,0:14:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:14:26.49,0:14:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku ingin pamer di depan Aria!
Dialogue: 0,0:14:32.73,0:14:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalahnya pasir yang tinggi ini, ya?
Dialogue: 0,0:14:35.48,0:14:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed.
Dialogue: 0,0:14:36.94,0:14:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa buat kubus air besar\Nseukuran paus orca ini?
Dialogue: 0,0:14:41.65,0:14:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:42.87,0:14:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa kalau buat sebesar itu.
Dialogue: 0,0:14:45.70,0:14:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:14:48.28,0:14:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita gali saluran air\Nyang langsung terhubung ke laut saja?
Dialogue: 0,0:14:52.29,0:14:53.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus.
Dialogue: 0,0:14:53.47,0:14:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, bisa kamu lakukan\Ndengan sihir tanah atau semacamnya?
Dialogue: 0,0:14:55.99,0:14:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu bisa.
Dialogue: 0,0:14:57.60,0:15:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya giliranku menunjukkan\Nkemampuan sebagai alkemis sihir!
Dialogue: 0,0:15:02.51,0:15:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saluran air, gunakan sihir tanah\Ndan sihir air sudah cukup.
Dialogue: 0,0:15:09.47,0:15:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ada apa?
Dialogue: 0,0:15:14.27,0:15:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gran Nura!
Dialogue: 0,0:15:21.95,0:15:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gurita?
Dialogue: 0,0:15:23.32,0:15:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baby Plup?
Dialogue: 0,0:15:25.32,0:15:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa muncul di pantai seperti ini?
Dialogue: 0,0:15:28.18,0:15:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti karena tertarik pada kulitku\Nyang lembut dan kenyal ini.
Dialogue: 0,0:15:33.08,0:15:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ingin menyerangku\Ndengan tentakelnya yang ganas.
Dialogue: 0,0:15:35.97,0:15:38.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya aku tak bisa bilang\Nkarena itu agak memalukan!
Dialogue: 0,0:15:40.04,0:15:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu diincar, ya.
Dialogue: 0,0:15:41.85,0:15:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku untuk dimangsa.
Dialogue: 0,0:15:44.00,0:15:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, paus orca ini terlalu santai.
Dialogue: 0,0:15:49.39,0:15:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami Meja Rakus,\Nyang mengatasi Baby Plup.
Dialogue: 0,0:15:52.42,0:15:54.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian lanjut selamatkan Prankster itu.
Dialogue: 0,0:15:54.14,0:15:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:55.23,0:15:56.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ikut bantu!
Dialogue: 0,0:15:56.95,0:15:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, tunggu di sini.
Dialogue: 0,0:15:58.73,0:15:59.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria!
Dialogue: 0,0:16:07.11,0:16:08.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville!
Dialogue: 0,0:16:08.10,0:16:10.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bidik di antara kedua matanya!
Dialogue: 0,0:16:10.07,0:16:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk itu sepertinya sangat enak!
Dialogue: 0,0:16:11.83,0:16:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara mata?\NSangat enak?
Dialogue: 0,0:16:13.91,0:16:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang paham, tapi baiklah!
Dialogue: 0,0:16:15.83,0:16:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi ada kesempatan,\Nkita gali saluran air!
Dialogue: 0,0:16:17.90,0:16:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tak bisa sihir, kita tetap petualang!
Dialogue: 0,0:16:19.92,0:16:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gali dengan cara biasa!
Dialogue: 0,0:16:23.67,0:16:27.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terus menyirammu dengan ember.
Dialogue: 0,0:16:27.09,0:16:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus, Gadis Muda.
Dialogue: 0,0:16:29.84,0:16:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga jangan mengira\Nakan selalu muda dan cantik,
Dialogue: 0,0:16:32.37,0:16:35.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu jadi malas merawat kulitmu.
Dialogue: 0,0:16:35.22,0:16:41.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada pakai ember, mau kucincang\Ndan dijadikan ikan goreng?
Dialogue: 0,0:16:41.69,0:16:44.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk ini betulan bisa dimakan?
Dialogue: 0,0:16:44.44,0:16:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya hanya pedagang asongan\Nyang mengolahnya jadi sate.
Dialogue: 0,0:16:47.65,0:16:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, dagingnya keras,\Nbahkan ada bau amisnya.
Dialogue: 0,0:16:54.49,0:16:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu pernah makan, ya?
Dialogue: 0,0:16:56.70,0:16:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Esti Gard.
Dialogue: 0,0:17:01.01,0:17:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Rin bilang enak, pasti enak.
Dialogue: 0,0:17:04.25,0:17:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin bisa menyulap sayur jadi enak.
Dialogue: 0,0:17:07.21,0:17:08.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar.
Dialogue: 0,0:17:08.63,0:17:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:17:09.51,0:17:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayur-sayur itu sangat enak.
Dialogue: 0,0:17:11.83,0:17:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, makhluk ini pasti enak juga!
Dialogue: 0,0:17:17.60,0:17:19.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lagi, ayo semangat!
Dialogue: 0,0:17:19.73,0:17:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hadiah sudah menanti kita!
Dialogue: 0,0:17:21.98,0:17:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini berkat biskuit dari gadis itu!
Dialogue: 0,0:17:24.72,0:17:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seluruh tenagaku keluar!
Dialogue: 0,0:17:28.56,0:17:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalian semua\Nberjuang keras demi aku.
Dialogue: 0,0:17:32.03,0:17:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar dicintai oleh kalian.
Dialogue: 0,0:17:34.20,0:17:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mereka jelas-jelas mengincar hadiah.
Dialogue: 0,0:17:36.95,0:17:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah jelmaan keindahan\Nyang hadir di dunia ini,
Dialogue: 0,0:17:41.12,0:17:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sudah sepantasnya semua orang menyukaiku.
Dialogue: 0,0:17:43.89,0:17:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sebaiknya kugoreng saja.
Dialogue: 0,0:17:45.59,0:17:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging perutmu kelihatannya enak,
Dialogue: 0,0:17:47.38,0:17:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bolehkah kupotong?
Dialogue: 0,0:17:48.26,0:17:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Muda?
Dialogue: 0,0:17:55.91,0:17:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah tersambung!
Dialogue: 0,0:17:56.89,0:18:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorong!
Dialogue: 0,0:18:00.06,0:18:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadikan ikan goreng!
Dialogue: 0,0:18:02.94,0:18:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Muda?
Dialogue: 0,0:18:08.98,0:18:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah makanan kami!
Dialogue: 0,0:18:17.31,0:18:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbang kembali menuju kebebasan!
Dialogue: 0,0:18:23.71,0:18:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, anak-anak kecil.
Dialogue: 0,0:18:27.64,0:18:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkah dari Dewi Laut untuk kalian,\Ntangkap baik-baik.
Dialogue: 0,0:18:40.02,0:18:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hadiahnya?
Dialogue: 0,0:18:41.99,0:18:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, murah hati sekali.
Dialogue: 0,0:18:44.64,0:18:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik sifat maupun penampilannya.
Dialogue: 0,0:18:46.42,0:18:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh.
Dialogue: 0,0:18:48.11,0:18:49.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:18:51.45,0:18:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Muda.
Dialogue: 0,0:18:52.81,0:18:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengobrol denganmu sangat seru.
Dialogue: 0,0:18:56.84,0:18:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai jumpa lagi.
Dialogue: 0,0:18:58.59,0:19:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis muda dari dunia lain.
Dialogue: 0,0:19:01.29,0:19:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tu-tunggu sebentar!
Dialogue: 0,0:19:06.47,0:19:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti badai, datang dan pergi dengan cepat.
Dialogue: 0,0:19:09.54,0:19:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Udangnya besar-besar.
Dialogue: 0,0:19:11.71,0:19:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikannya juga masih hidup.
Dialogue: 0,0:19:13.42,0:19:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka dapat berkah Dewi Laut.
Dialogue: 0,0:19:16.31,0:19:19.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski beda keyakinan,\Naku sangat berterima kasih.
Dialogue: 0,0:19:19.39,0:19:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kita panen besar!
Dialogue: 0,0:19:22.72,0:19:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, ini barang jatuhan Baby Plup\Nyang kamu minta.
Dialogue: 0,0:19:26.44,0:19:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita betulan panen besar!
Dialogue: 0,0:19:29.41,0:19:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena makanan laut segarnya banyak,
Dialogue: 0,0:19:32.83,0:19:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menu makan malam hari ini...
Dialogue: 0,0:19:34.53,0:19:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menu makan malamnya?
Dialogue: 0,0:19:35.90,0:19:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barbeku hidangan laut!
Dialogue: 0,0:19:38.37,0:19:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:19:41.44,0:19:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah,
Dialogue: 0,0:19:43.29,0:19:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini barbeku hidangan laut!
Dialogue: 0,0:19:47.12,0:19:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, selain barbeku hidangan laut,
Dialogue: 0,0:19:49.08,0:19:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada juga Bouillabaisse mewah,
Dialogue: 0,0:19:51.03,0:19:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentakel Baby Plup dengan saus\Nminyak zaitun bawang putih yang kenyal!
Dialogue: 0,0:19:54.05,0:19:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tambah dua Cumi Suruika\Nsebagai tumis cumi
Dialogue: 0,0:19:56.97,0:19:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kentang mentega!
Dialogue: 0,0:19:58.22,0:19:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, semuanya.
Dialogue: 0,0:19:59.59,0:20:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan pilih dan makan sepuasnya!
Dialogue: 0,0:20:02.52,0:20:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:20:03.72,0:20:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu...
Dialogue: 0,0:20:05.25,0:20:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah datang!
Dialogue: 0,0:20:06.50,0:20:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Ville suka Bir Ale.
Dialogue: 0,0:20:08.48,0:20:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku biasanya minum anggur merah.
Dialogue: 0,0:20:10.15,0:20:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Aria, kamu suka anggur soda, ya?
Dialogue: 0,0:20:13.62,0:20:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, kamu mau minum apa?
Dialogue: 0,0:20:15.53,0:20:16.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:16.61,0:20:19.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih harus mengemudi,\Njadi minum teh barli saja.
Dialogue: 0,0:20:19.41,0:20:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:20:22.49,0:20:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski banyak hal tidak terduga terjadi,
Dialogue: 0,0:20:25.49,0:20:28.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hari ini kita berhasil menyelesaikan misi.
Dialogue: 0,0:20:28.58,0:20:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ini juga misi pertama Rin\Nsebagai petualang.
Dialogue: 0,0:20:33.09,0:20:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berhasil menyelamatkan Prankster itu
Dialogue: 0,0:20:35.68,0:20:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga berkat Rin.
Dialogue: 0,0:20:36.97,0:20:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:37.97,0:20:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan jasaku,\Ntapi berkat usaha semuanya.
Dialogue: 0,0:20:40.93,0:20:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, selamat.
Dialogue: 0,0:20:44.14,0:20:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Rin.
Dialogue: 0,0:20:46.67,0:20:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bersyukur\Nbisa bertemu denganmu saat itu.
Dialogue: 0,0:20:48.88,0:20:50.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville.
Dialogue: 0,0:20:50.10,0:20:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imajinasi dan skill-mu yang luar biasa\Nsangat membantu kita.
Dialogue: 0,0:20:54.01,0:20:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru kali ini aku\Nmenyelesaikan misi semudah ini!
Dialogue: 0,0:20:56.82,0:20:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, Senon.
Dialogue: 0,0:20:59.78,0:21:03.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih, kami bahagia\Nbisa makan banyak masakan enak.
Dialogue: 0,0:21:03.74,0:21:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini berkat Rin.
Dialogue: 0,0:21:06.57,0:21:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kepalaku tiba-tiba berputar.
Dialogue: 0,0:21:10.67,0:21:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Rin.
Dialogue: 0,0:21:12.51,0:21:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:14.72,0:21:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, terima kasih.
Dialogue: 0,0:21:16.67,0:21:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, dengan bergabungnya Rin,
Dialogue: 0,0:21:18.76,0:21:20.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita adalah Meja Rakus yang baru!
Dialogue: 0,0:21:20.79,0:21:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari bersulang untuk rekan baru!
Dialogue: 0,0:21:23.09,0:21:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bersulang!
Dialogue: 0,0:21:26.02,0:21:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, semuanya.
Dialogue: 0,0:21:28.39,0:21:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, semuanya.
Dialogue: 0,0:21:29.65,0:21:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan sampai puas!
Dialogue: 0,0:21:31.07,0:21:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sup yang isinya\N- Serius?
Dialogue: 0,0:21:33.72,0:21:35.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- banyak sekali ini apa?\N- Ini daging Baby Plup itu?
Dialogue: 0,0:21:35.65,0:21:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenyal dan enak!\N- Apinya pas, Rin!
Dialogue: 0,0:21:38.19,0:21:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Cuminya enak.\N- Apinya pas, Rin!
Dialogue: 0,0:21:40.01,0:21:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sayurnya, tapi tetap enak.
