Dialogue: 0,0:01:28.07,0:01:40.46,sign,,0000,0000,0000,,THE FORSAKEN SAINTESS\NAND HER FOODIE ROADTRIP IN ANOTHER WORLD
Dialogue: 0,0:02:40.01,0:02:45.27,sign,,0000,0000,0000,,EPISODE 1: MEMANCING IKAN TROUT\NDI ISEKAI DITEMANI KAKAK IBLIS
Dialogue: 0,0:03:10.38,0:03:12.13,sign,,0000,0000,0000,,IKAN TROUT SUSU - BISA DIMAKAN: SANGAT LEZAT
Dialogue: 0,0:03:12.13,0:03:14.38,sign,,0000,0000,0000,,IKAN SIHIR KAYA NUTRISI DAN AMAN DIMAKAN MENTAH
Dialogue: 0,0:08:36.03,0:08:38.28,sign,,0000,0000,0000,,SURVIVAL, STRATEGI BERTAHAN HIDUP
Dialogue: 0,0:09:09.82,0:09:12.07,sign,,0000,0000,0000,,KERONCONGAN
Dialogue: 0,0:11:23.37,0:11:24.91,sign,,0000,0000,0000,,MANA
Dialogue: 0,0:12:57.21,0:12:58.55,sign,,0000,0000,0000,,DAGING KHAS AL-MIRAJ
Dialogue: 0,0:12:58.55,0:13:00.09,sign,,0000,0000,0000,,ITEM DROP AL-MIRAJ, LEMBUT DAN LEZAT
Dialogue: 0,0:18:30.84,0:18:32.47,sign,,0000,0000,0000,,RULEBERI - BISA DIMAKAN: LEZAT
Dialogue: 0,0:18:32.47,0:18:33.29,sign,,0000,0000,0000,,BUAH WARNA UNGU DAN DAUNNYA
Dialogue: 0,0:18:33.29,0:18:34.30,sign,,0000,0000,0000,,BISA JADI TEH HERBAL
Dialogue: 0,0:18:43.27,0:18:43.91,sign,,0000,0000,0000,,GAGAK SILUMAN - BISA DIMAKAN: LEZAT
Dialogue: 0,0:18:43.91,0:18:44.94,sign,,0000,0000,0000,,MONSTER BURUNG DI DAERAH PEGUNUNGAN
Dialogue: 0,0:23:35.02,0:23:40.02,sign,,0000,0000,0000,,EPISODE 2: SATUKAN SEMUA REKAN DAN BAHAN,\NJADILAH NASI CAMPUR!
Dialogue: 0,0:00:07.07,0:00:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo semuanya.
Dialogue: 0,0:00:08.28,0:00:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Takanashi Rin.
Dialogue: 0,0:00:09.78,0:00:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usiaku 20-an tahun, mantan perawat.
Dialogue: 0,0:00:12.08,0:00:14.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang menjadi ahli akupunktur.
Dialogue: 0,0:00:14.33,0:00:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hobiku main gim cerita dan berkemah!
Dialogue: 0,0:00:17.29,0:00:18.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:00:18.41,0:00:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak kecil aku sangat suka
Dialogue: 0,0:00:20.63,0:00:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berkemah sendirian!
Dialogue: 0,0:00:23.34,0:00:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang saat libur,
Dialogue: 0,0:00:24.55,0:00:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pergi ke alam terbuka\Ndan memancing dengan tenang.
Dialogue: 0,0:00:28.30,0:00:30.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya membuat bahagia.
Dialogue: 0,0:00:32.18,0:00:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat!
Dialogue: 0,0:00:33.97,0:00:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat! Dapat! Dapat!
Dialogue: 0,0:00:38.18,0:00:39.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berat!
Dialogue: 0,0:00:39.64,0:00:41.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ini ikan besar.
Dialogue: 0,0:00:58.65,0:01:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menangkap Kakak Iblis\Nyang super tampan!
Dialogue: 0,0:01:03.00,0:01:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, situasinya jadi rumit.
Dialogue: 0,0:01:05.53,0:01:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini
Dialogue: 0,0:01:06.84,0:01:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}isekai, kan?
Dialogue: 0,0:02:59.53,0:03:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lemak yang manis, gurih,\Ndan asin pas di lidah.
Dialogue: 0,0:03:03.04,0:03:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebar ke seluruh mulut!
Dialogue: 0,0:03:05.79,0:03:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu aroma lembutnya masih terasa di hidung.
Dialogue: 0,0:03:08.79,0:03:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lezat!
Dialogue: 0,0:03:10.38,0:03:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dipancing dan dimakan.
Dialogue: 0,0:03:12.13,0:03:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan trout susu memang terbaik!
Dialogue: 0,0:03:25.60,0:03:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau coba?
Dialogue: 0,0:03:27.69,0:03:29.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:03:32.36,0:03:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikannya masih banyak kalau mau tambah.
Dialogue: 0,0:03:34.32,0:03:35.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf...
Dialogue: 0,0:03:37.99,0:03:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan minum.
Dialogue: 0,0:03:43.83,0:03:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa asin dan lemak di mulut hilang,
Dialogue: 0,0:03:46.46,0:03:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang tersisa hanya rasa segar dan nikmat!
Dialogue: 0,0:03:48.54,0:03:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menjelaskannya, ya?
Dialogue: 0,0:03:50.08,0:03:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, ini enak.
Dialogue: 0,0:03:52.30,0:03:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:03:53.17,0:03:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seleraku ditambah koktail gelas tinggi,\Ntapi ditambah teh barli juga enak.
Dialogue: 0,0:03:57.84,0:03:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah rasa di mulut hilang,
Dialogue: 0,0:03:59.76,0:04:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya ingin terus makan, kan?
Dialogue: 0,0:04:01.60,0:04:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:04:02.81,0:04:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bisa merasakan kembali\Nkelezatan makanannya lagi!
Dialogue: 0,0:04:06.10,0:04:08.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tusuk satenya habis, ya.
Dialogue: 0,0:04:08.56,0:04:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung panggang saja!
Dialogue: 0,0:04:10.65,0:04:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah.
Dialogue: 0,0:04:13.13,0:04:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar!
Dialogue: 0,0:04:17.07,0:04:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku berterima kasih sekali lagi.
Dialogue: 0,0:04:19.27,0:04:20.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ville.
Dialogue: 0,0:04:20.70,0:04:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bekerja sebagai petualang\Ndi kota bernama Elrage.
Dialogue: 0,0:04:23.12,0:04:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang?
Dialogue: 0,0:04:24.49,0:04:27.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, namaku Rin.
Dialogue: 0,0:04:27.46,0:04:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Rin!
Dialogue: 0,0:04:29.42,0:04:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu sungkan!
Dialogue: 0,0:04:31.54,0:04:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kenapa kamu bisa jatuh ke air?
Dialogue: 0,0:04:35.46,0:04:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini...
Dialogue: 0,0:04:36.30,0:04:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku tidak bersama grupku.
Dialogue: 0,0:04:38.67,0:04:40.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menerima misi seorang diri.
Dialogue: 0,0:04:40.95,0:04:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibatnya, saat sedang mandi,
Dialogue: 0,0:04:43.35,0:04:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}barang bawaanku tanpa sengaja\Ndirebut monster.
Dialogue: 0,0:04:46.77,0:04:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlengkapanku tidak ada yang hilang,
Dialogue: 0,0:04:48.98,0:04:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi makananku habis dimakan monster itu.
Dialogue: 0,0:04:51.60,0:04:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu karena terlalu lapar,\Naku agak nekat.
Dialogue: 0,0:04:54.48,0:04:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jatuh ke sungai dan hanyut terbawa arus.
Dialogue: 0,0:04:56.65,0:04:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah sebabnya jadi seperti ini.
Dialogue: 0,0:04:59.03,0:05:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terluka dalam situasi\Nseperti itu juga cukup hebat.
Dialogue: 0,0:05:01.74,0:05:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:02.62,0:05:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang kamu lihat,\Naku ras Naga Iblis.
Dialogue: 0,0:05:04.87,0:05:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami terkenal sangat tangguh.
Dialogue: 0,0:05:08.27,0:05:11.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi juga dikenal sangat boros energi.
Dialogue: 0,0:05:13.13,0:05:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting kamu baik-baik saja!
Dialogue: 0,0:05:16.09,0:05:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat dirimu aku bisa selamat,
Dialogue: 0,0:05:18.38,0:05:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bukankah sebaiknya\Nkamu lebih berhati-hati?
Dialogue: 0,0:05:22.09,0:05:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sembarangan menolong pria asing sepertiku,
Dialogue: 0,0:05:24.93,0:05:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan tanpa waspada memberikan makanan,
Dialogue: 0,0:05:27.43,0:05:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menurutku kamu kurang peka akan bahaya.
Dialogue: 0,0:05:30.27,0:05:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, harusnya begitu,
Dialogue: 0,0:05:33.19,0:05:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi skill-ku tak memberikan reaksi apa pun.
Dialogue: 0,0:05:35.44,0:05:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kamu ternyata baik!
Dialogue: 0,0:05:38.40,0:05:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik?
Dialogue: 0,0:05:40.08,0:05:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita baru bertemu,\Nkenapa kamu bisa begitu yakin?
Dialogue: 0,0:05:44.12,0:05:45.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, Ville...
Dialogue: 0,0:05:51.29,0:05:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju basah bisa membuat\Nsuhu tubuhnya turun.
Dialogue: 0,0:05:54.42,0:05:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus cari sesuatu untuk mengeringkannya.
Dialogue: 0,0:05:56.67,0:05:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Basah...
Dialogue: 0,0:05:59.17,0:06:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersihkan dan Keringkan!
Dialogue: 0,0:06:10.21,0:06:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ko-Kotoran di bajunya hilang semua!
Dialogue: 0,0:06:12.35,0:06:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, bajuku juga kering!
Dialogue: 0,0:06:14.56,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini sihir?
Dialogue: 0,0:06:15.56,0:06:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong.
Dialogue: 0,0:06:17.40,0:06:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:06:20.36,0:06:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihatmu bertindak begitu,
Dialogue: 0,0:06:22.15,0:06:23.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan hanya peduli padaku,
Dialogue: 0,0:06:23.74,0:06:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu juga terus berterima kasih padaku.
Dialogue: 0,0:06:25.95,0:06:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu aku langsung berpikir\Nkalau si Kakak ini baik.
Dialogue: 0,0:06:29.29,0:06:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, hanya karena itu?
Dialogue: 0,0:06:31.08,0:06:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya karena itu.
Dialogue: 0,0:06:32.62,0:06:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada bahas itu, Ville,
Dialogue: 0,0:06:34.21,0:06:36.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sihir, kan?
Dialogue: 0,0:06:36.79,0:06:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya sihir sehari-hari,\Nkenapa kamu sekaget itu?
Dialogue: 0,0:06:40.88,0:06:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku orang dari dunia lain,
Dialogue: 0,0:06:42.72,0:06:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sihir apa pun sangat menarik bagiku!
Dialogue: 0,0:06:46.80,0:06:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:06:47.89,0:06:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah dengar Pemanggilan Gadis Suci?
Dialogue: 0,0:06:51.60,0:06:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku orang asing yang dipanggil\Nke dunia ini oleh sihir itu.
Dialogue: 0,0:06:56.27,0:06:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemanggilan Gadis Suci?
Dialogue: 0,0:06:58.23,0:07:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah dengar itu\Ndi cerita rakyat waktu kecil.
Dialogue: 0,0:07:01.97,0:07:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah,
Dialogue: 0,0:07:02.82,0:07:06.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis Suci dari dunia lain\Nbisa menyucikan monster
Dialogue: 0,0:07:06.28,0:07:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengembalikan kedamaian dunia.
Dialogue: 0,0:07:08.49,0:07:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang lebih itu yang kudengar.
Dialogue: 0,0:07:10.98,0:07:12.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan aku,
Dialogue: 0,0:07:12.45,0:07:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}awalnya sedang berkemah di dunia lain,
Dialogue: 0,0:07:14.41,0:07:17.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tapi tiba-tiba jatuh ke lubang aneh.\N- Apa?
Dialogue: 0,0:07:17.17,0:07:21.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu sadar, aku ada di ruang rahasia istana\Nyang sering muncul di cerita fantasi!
Dialogue: 0,0:07:21.75,0:07:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sampingku,
Dialogue: 0,0:07:22.51,0:07:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada gadis SMA cantik yang sepertinya\Nikut dipanggil bersamaku.
Dialogue: 0,0:07:25.72,0:07:29.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu ada seseorang yang mirip pangeran\Nmemanggil gadis SMA itu Nona Gadis Suci.
Dialogue: 0,0:07:29.68,0:07:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan menghinaku lalu bilang aku\Nsampah dan skill-ku payah.
Dialogue: 0,0:07:34.14,0:07:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu ada bocah yang penampilannya\Nseperti penyihir
Dialogue: 0,0:07:36.69,0:07:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mulai merapalkan mantra.
Dialogue: 0,0:07:38.10,0:07:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lingkaran sihir di bawah kakiku\Nmendadak bersinar menyilaukan!
Dialogue: 0,0:07:41.40,0:07:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bangun,
Dialogue: 0,0:07:42.65,0:07:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah sampai di Danau Real ini.
Dialogue: 0,0:07:46.70,0:07:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sambil menguji skill\Nyang baru kubangkitkan,
Dialogue: 0,0:07:50.62,0:07:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mulai kemah sendirian.
Dialogue: 0,0:07:53.16,0:07:56.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu harusnya sihir teleportasi paksa.
Dialogue: 0,0:07:56.16,0:07:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanggil orang sesuka hati,
Dialogue: 0,0:07:58.33,0:08:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu seenaknya membuangnya ke alam liar!
Dialogue: 0,0:08:01.29,0:08:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar berengsek.
Dialogue: 0,0:08:02.84,0:08:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, berkat itu aku bisa bertemu denganmu
Dialogue: 0,0:08:05.42,0:08:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menyelamatkanmu.
Dialogue: 0,0:08:09.30,0:08:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena kamu orang dari dunia lain,\Nsemuanya jadi masuk akal.
Dialogue: 0,0:08:12.97,0:08:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlengkapanmu ini,
Dialogue: 0,0:08:14.52,0:08:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik model maupun bahannya,
Dialogue: 0,0:08:16.43,0:08:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya benda yang belum pernah kulihat.
Dialogue: 0,0:08:18.44,0:08:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, petualang memang hebat,\Npengamatanmu tajam!
Dialogue: 0,0:08:21.40,0:08:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, bagaimana denganmu,\Nkamu baik-baik saja?
Dialogue: 0,0:08:24.02,0:08:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba dipanggil ke isekai.
Dialogue: 0,0:08:26.65,0:08:29.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pasti sangat cemas\Ndan kangen tempat asalmu, kan?
Dialogue: 0,0:08:30.95,0:08:33.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville, kamu memang baik, ya.
Dialogue: 0,0:08:33.87,0:08:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara skill yang kubangkitkan,
Dialogue: 0,0:08:36.03,0:08:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada satu skill yang bernama Survival.
Dialogue: 0,0:08:38.28,0:08:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill ini membuat tubuh dan pikiranku
Dialogue: 0,0:08:40.27,0:08:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap bisa bertahan hidup\Ndi lingkungan atau situasi apa pun.
Dialogue: 0,0:08:44.21,0:08:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga memberitahuku\Npengetahuan tentang dunia ini.
Dialogue: 0,0:08:46.67,0:08:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan bisa mendeteksi tingkat keamanan.
Dialogue: 0,0:08:49.72,0:08:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena itu,
Dialogue: 0,0:08:51.64,0:08:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa tetap tenang\Ndi situasi seperti ini.
Dialogue: 0,0:08:53.97,0:08:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hebat!
Dialogue: 0,0:08:55.89,0:08:59.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu skill impian para petualang seperti kami.
Dialogue: 0,0:08:59.14,0:09:02.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi malah bilang skill-mu sampah,\Nitu sangat tak masuk akal.
Dialogue: 0,0:09:02.48,0:09:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, skill ini memang praktis,\Ntapi tidak mencolok.
Dialogue: 0,0:09:06.61,0:09:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, skill-ku yang lain sangat istimewa.
Dialogue: 0,0:09:12.07,0:09:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku mudah lapar.
Dialogue: 0,0:09:16.62,0:09:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah mengobrol cukup lama.
Dialogue: 0,0:09:18.58,0:09:21.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sudah waktunya makan malam.
Dialogue: 0,0:09:21.62,0:09:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ri-Rin!
Dialogue: 0,0:09:22.92,0:09:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu... bisa memasak juga?
Dialogue: 0,0:09:26.20,0:09:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma memasak makanan biasa.
Dialogue: 0,0:09:28.42,0:09:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, karena akan memasak,\Nsebaiknya tidak perlu ditutupi lagi.
Dialogue: 0,0:09:32.80,0:09:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku percaya kamu\Ntak akan menyebarkannya.
Dialogue: 0,0:09:44.27,0:09:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaturan penumpang, konfirmasi.
Dialogue: 0,0:09:52.85,0:09:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini skill-ku yang lain.
Dialogue: 0,0:09:56.95,0:09:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mobil kamping, Mo!
Dialogue: 0,0:10:01.04,0:10:02.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:03.79,0:10:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ri-Rin...
Dialogue: 0,0:10:05.13,0:10:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda apa ini?
Dialogue: 0,0:10:06.34,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu kaget.
Dialogue: 0,0:10:08.21,0:10:10.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill spesialku, selain sebagai pengguna,
Dialogue: 0,0:10:10.91,0:10:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang lain harus diatur dulu\Nagar bisa melihatnya.
Dialogue: 0,0:10:14.76,0:10:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:10:15.93,0:10:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda ini disebut mobil kamping\Ndi dunia asalku.
Dialogue: 0,0:10:19.89,0:10:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak hanya memuat banyak barang,
Dialogue: 0,0:10:21.35,0:10:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa tidur di dalamnya\Natau bepergian ke luar.
Dialogue: 0,0:10:24.10,0:10:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bepergian?\NKotak besar ini bisa bergerak?
Dialogue: 0,0:10:26.86,0:10:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, nanti akan kujelaskan.
Dialogue: 0,0:10:29.82,0:10:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau masuk dan lihat-lihat?
Dialogue: 0,0:10:32.36,0:10:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:10:51.51,0:10:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:53.47,0:10:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksinya sama sepertiku\Nsaat pertama melihatnya.
Dialogue: 0,0:10:56.72,0:10:59.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya di dalam ada semacam sihir ruang.
Dialogue: 0,0:10:59.47,0:11:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau taruh berapa banyak\Nbarang pun bukan masalah.
Dialogue: 0,0:11:02.18,0:11:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:03.14,0:11:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dapur.
Dialogue: 0,0:11:05.48,0:11:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kulkas.
Dialogue: 0,0:11:08.48,0:11:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi di dalamnya persis\Ndengan kulkas yang ada di rumahku.
Dialogue: 0,0:11:11.78,0:11:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang penting mudah digunakan.
Dialogue: 0,0:11:13.40,0:11:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini seperti gudang harta karun kastel!
Dialogue: 0,0:11:16.36,0:11:17.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong soal isinya,
Dialogue: 0,0:11:17.87,0:11:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan otomatis terisi kembali kalau habis.
Dialogue: 0,0:11:19.99,0:11:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa digunakan sepuasnya!
Dialogue: 0,0:11:21.45,0:11:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hal seperti ini masuk akal?
Dialogue: 0,0:11:23.37,0:11:24.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini, semua bahan-bahan ini
Dialogue: 0,0:11:24.91,0:11:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya diubah dari suatu zat energi\Ndi atmosfer yang disebut mana.
Dialogue: 0,0:11:29.63,0:11:31.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama mana-nya tidak habis,
Dialogue: 0,0:11:31.05,0:11:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benda itu akan terus memasok kebutuhanku.
Dialogue: 0,0:11:32.96,0:11:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana ada di seluruh penjuru dunia,\Njadi tidak akan habis.
Dialogue: 0,0:11:36.97,0:11:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, mana juga bisa\Nmenghasilkan air sihir,
Dialogue: 0,0:11:40.55,0:11:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tak perlu khawatir\Nkehabisan air minum.
Dialogue: 0,0:11:43.02,0:11:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan air limbah dan sampah\Nakan otomatis diubah jadi mana,
Dialogue: 0,0:11:46.35,0:11:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi tidak perlu repot-repot membersihkannya.
Dialogue: 0,0:11:49.31,0:11:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka malah bilang skill\Nseperti ini tak berguna?
Dialogue: 0,0:11:51.83,0:11:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya ada ruang penyimpanan raksasa\Nyang bisa diambil dan ditaruh sesuka hati,
Dialogue: 0,0:11:55.86,0:11:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selama dunia ini ada mana,
Dialogue: 0,0:11:57.07,0:12:00.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}singkatnya tempat ini\Ngudang perbekalan tanpa batas.
Dialogue: 0,0:12:00.62,0:12:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi perang,
Dialogue: 0,0:12:01.70,0:12:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma kamu yang bisa menangani\Nlogistik untuk seluruh pasukan!
Dialogue: 0,0:12:05.16,0:12:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang suka perang.
Dialogue: 0,0:12:07.16,0:12:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:12:08.29,0:12:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disalahartikan sebagai skill sampah\Noleh mereka mungkin bagus untukmu.
Dialogue: 0,0:12:11.84,0:12:13.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:12:13.09,0:12:16.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena skill ini hanya bisa\Ndigunakan di alam liar,
Dialogue: 0,0:12:16.51,0:12:19.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka tidak menyadarinya.
Dialogue: 0,0:12:19.47,0:12:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, mari siapkan makan malam!
Dialogue: 0,0:12:22.76,0:12:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu duduk saja dan istirahat di sini.
Dialogue: 0,0:12:24.93,0:12:27.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, tidak enak\Nkalau terus merepotkanmu.
Dialogue: 0,0:12:28.35,0:12:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku keluar sebentar,\Npatroli kalau ada bahaya.
Dialogue: 0,0:12:30.90,0:12:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku membuatnya sungkan?
Dialogue: 0,0:12:33.07,0:12:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, malam ini aku akan\Nmenunjukkan kemampuanku!
Dialogue: 0,0:12:39.15,0:12:41.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah siap!
Dialogue: 0,0:12:41.57,0:12:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya...
Dialogue: 0,0:12:42.57,0:12:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin.
Dialogue: 0,0:12:44.37,0:12:47.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada monster berbahaya di sekitar sini.
Dialogue: 0,0:12:47.37,0:12:49.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Ville.
Dialogue: 0,0:12:49.33,0:12:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sedang bersiap\Nmemasak makan malam.
Dialogue: 0,0:12:52.08,0:12:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini daging Al-Miraj.
Dialogue: 0,0:12:53.67,0:12:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terimalah.
Dialogue: 0,0:12:55.25,0:12:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Al-Miraj?
Dialogue: 0,0:12:57.21,0:12:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku ini monster kelinci
Dialogue: 0,0:12:58.55,0:13:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan satu tanduk.
Dialogue: 0,0:13:00.09,0:13:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dagingnya enak, ya?
Dialogue: 0,0:13:03.68,0:13:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:13:05.76,0:13:06.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:06.68,0:13:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tak seberapa karena kamu\Nsudah menyelamatkanku.
Dialogue: 0,0:13:09.89,0:13:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senyumannya manis!\NAku jadi kagum padanya.
Dialogue: 0,0:13:13.02,0:13:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin?
Dialogue: 0,0:13:14.44,0:13:17.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa...\NAyo kita makan!
Dialogue: 0,0:13:18.26,0:13:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu yang memasak semua ini?
Dialogue: 0,0:13:21.86,0:13:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:13:22.93,0:13:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh makan ini semua?
Dialogue: 0,0:13:24.70,0:13:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak dimakan, aku yang repot.
Dialogue: 0,0:13:27.33,0:13:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, duduk.
Dialogue: 0,0:13:31.61,0:13:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersyukur pada dunia ini\Nkarena hari ini aku masih bisa makan.
Dialogue: 0,0:13:37.11,0:13:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:13:45.00,0:13:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!
Dialogue: 0,0:13:46.51,0:13:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi putih yang manis dan daging Al-Miraj-nya\Nlangsung menyebar di mulut!
Dialogue: 0,0:13:51.39,0:13:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selanjutnya...
Dialogue: 0,0:13:59.10,0:14:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga enak!
Dialogue: 0,0:14:00.65,0:14:03.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lembut dan hangat, meleleh di mulut!
Dialogue: 0,0:14:06.37,0:14:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sasyimi ala Italia-nya juga sangat enak!
Dialogue: 0,0:14:08.37,0:14:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak terasa bau amis dan rasanya\Nsangat cocok dengan minyak zaitun!
Dialogue: 0,0:14:12.12,0:14:14.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau didiamkan semalaman,\Nharusnya akan lebih enak.
Dialogue: 0,0:14:15.03,0:14:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville, kamu kenapa?
Dialogue: 0,0:14:16.71,0:14:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak cocok dengan seleramu?
Dialogue: 0,0:14:18.76,0:14:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka,
Dialogue: 0,0:14:19.76,0:14:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa makan makanan selezat ini di alam liar!
Dialogue: 0,0:14:24.47,0:14:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:14:25.64,0:14:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melakukan sedikit penyesuaian,
Dialogue: 0,0:14:27.43,0:14:29.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini cuma risotto biasa.
Dialogue: 0,0:14:30.52,0:14:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, maaf,
Dialogue: 0,0:14:33.89,0:14:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}boleh tambah lagi?
Dialogue: 0,0:14:36.67,0:14:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja boleh, silakan makan sepuasnya!
Dialogue: 0,0:14:41.57,0:14:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, dulu kamu seorang koki?
Dialogue: 0,0:14:43.88,0:14:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya hobi memasak.
Dialogue: 0,0:14:46.12,0:14:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan bakar tadi pagi juga enak!
Dialogue: 0,0:14:48.83,0:14:51.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, aku cuma memanggangnya.
Dialogue: 0,0:14:52.41,0:14:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dunia ini ada juga orang\Nyang tak bisa memanggang.
Dialogue: 0,0:14:56.33,0:14:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, ya.
Dialogue: 0,0:14:58.34,0:15:01.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, apa rencanamu selanjutnya?
Dialogue: 0,0:15:01.00,0:15:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditanya begitu...
Dialogue: 0,0:15:04.42,0:15:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu cara pulang.
Dialogue: 0,0:15:07.14,0:15:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mau menikmati hidup di dunia ini\Nuntuk sementara waktu.
Dialogue: 0,0:15:10.39,0:15:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya aku tak perlu cemas\Nsoal kebutuhan hidup.
Dialogue: 0,0:15:13.56,0:15:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin jalan-jalan,
Dialogue: 0,0:15:15.23,0:15:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu butuh uang dan kartu identitas\Nuntuk masuk kota.
Dialogue: 0,0:15:18.65,0:15:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar juga.
Dialogue: 0,0:15:19.57,0:15:22.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak punya uang\Nmaupun kartu identitas di dunia ini!
Dialogue: 0,0:15:22.28,0:15:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak punya pekerjaan juga!
Dialogue: 0,0:15:23.90,0:15:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:15:24.95,0:15:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa di sini juga ada pekerjaan\Nseperti perawat?
Dialogue: 0,0:15:27.41,0:15:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin!
Dialogue: 0,0:15:28.16,0:15:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu tidak keberatan,
Dialogue: 0,0:15:29.58,0:15:33.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau jadi koki\Nsekaligus porter di grup kami?
Dialogue: 0,0:15:34.33,0:15:35.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:43.51,0:15:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk aku,
Dialogue: 0,0:15:45.47,0:15:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua orang di grup kami hanya bisa\Nmembuat masakan yang mengecewakan!
Dialogue: 0,0:15:49.43,0:15:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi petualang,
Dialogue: 0,0:15:50.47,0:15:53.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makan adalah salah satu kesenangan\Nsaat menjalankan misi.
Dialogue: 0,0:15:53.27,0:15:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanan bisa memengaruhi\Nsemangat seluruh grup!
Dialogue: 0,0:15:55.64,0:15:58.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat, terlalu dekat!\NIni sudah termasuk serangan ketampanan!
Dialogue: 0,0:15:58.81,0:16:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, kami akan memberimu\Nimbalan yang layak!
Dialogue: 0,0:16:01.36,0:16:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga akan bantu kamu\Ndapat kartu identitas.
Dialogue: 0,0:16:03.44,0:16:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup kami ada pria dan wanitanya,
Dialogue: 0,0:16:05.03,0:16:06.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak perlu cemas tentang keselamatan!
Dialogue: 0,0:16:06.86,0:16:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku tak bisa jamin\Nsepenuhnya tanpa bahaya.
Dialogue: 0,0:16:09.62,0:16:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan melindungimu\Nmenjalani kehidupan idealmu!
Dialogue: 0,0:16:11.83,0:16:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, Ville, tenang dulu!
Dialogue: 0,0:16:16.02,0:16:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, itu cuma basa-basi.
Dialogue: 0,0:16:18.67,0:16:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, itu semua yang kupikirkan.
Dialogue: 0,0:16:21.25,0:16:22.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlebih...
Dialogue: 0,0:16:22.50,0:16:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville?
Dialogue: 0,0:16:24.34,0:16:26.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin membantumu,
Dialogue: 0,0:16:26.13,0:16:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}orang baik yang rela menolong\Nseorang petualang asing.
Dialogue: 0,0:16:32.72,0:16:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria tampan terlalu menakutkan!
Dialogue: 0,0:16:34.60,0:16:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu mendebarkan untukku!
Dialogue: 0,0:16:38.81,0:16:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulannya...
Dialogue: 0,0:16:40.27,0:16:42.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang isekai.
Dialogue: 0,0:16:43.98,0:16:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kenal siapa pun.
Dialogue: 0,0:16:45.15,0:16:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak tahu apa pun.
Dialogue: 0,0:16:46.78,0:16:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bertemu dengannya
Dialogue: 0,0:16:48.57,0:16:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin termasuk takdir.
Dialogue: 0,0:16:55.70,0:16:57.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal yang kemarin,
Dialogue: 0,0:16:57.04,0:16:58.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku memutuskan menerima pekerjaannya!
Dialogue: 0,0:16:58.79,0:17:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum yakin,
Dialogue: 0,0:17:00.17,0:17:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi serahkan urusan perut\Ndan barang bawaan grupmu padaku!
Dialogue: 0,0:17:03.59,0:17:04.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:17:04.63,0:17:06.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga, mohon bantuannya!
Dialogue: 0,0:17:07.76,0:17:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita segera berangkat ke Kota Elrage!
Dialogue: 0,0:17:10.58,0:17:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus memperkenalkanmu ke anggota lain!
Dialogue: 0,0:17:12.47,0:17:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, bisa tunggu sebentar?
Dialogue: 0,0:17:15.54,0:17:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarin aku dapat\Nbeberapa seledri liar yang bagus.
Dialogue: 0,0:17:17.89,0:17:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum pergi dari sini,\Naku ingin memetik sedikit.
Dialogue: 0,0:17:20.60,0:17:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau makan rumput?
Dialogue: 0,0:17:22.48,0:17:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan untuk hidangan utama.
Dialogue: 0,0:17:24.60,0:17:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini akan kupakai sebagai bumbu penyedap.
Dialogue: 0,0:17:26.60,0:17:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risotto dan sasyimi ala Italia\Ntadi malam juga pakai ini.
Dialogue: 0,0:17:30.07,0:17:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian kuberi tahu,
Dialogue: 0,0:17:31.53,0:17:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ini seledri liar beracun\Nyang bentuknya sangat mirip.
Dialogue: 0,0:17:34.37,0:17:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau salah ambil, kamu bisa mati!
Dialogue: 0,0:17:36.01,0:17:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit membedakannya, ya.
Dialogue: 0,0:17:38.25,0:17:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu harus hati-hati.
Dialogue: 0,0:17:40.66,0:17:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membedakannya berkat skill-ku.
Dialogue: 0,0:17:42.71,0:17:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga itu bukan skill sampah.
Dialogue: 0,0:17:44.92,0:17:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami para petualang sampai iri sekali.
Dialogue: 0,0:17:48.67,0:17:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nseperti apa para anggota grupmu?
Dialogue: 0,0:17:52.47,0:17:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Grup kami namanya Meja Rakus.
Dialogue: 0,0:17:55.14,0:17:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Totalnya empat,\Ntermasuk aku si petarung berat.
Dialogue: 0,0:17:57.22,0:17:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu anggota kami ahli sihir,
Dialogue: 0,0:17:59.39,0:18:01.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seorang alkemis sihir, Ed.
Dialogue: 0,0:18:01.56,0:18:03.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alkemis?
Dialogue: 0,0:18:03.02,0:18:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria, ras manusia laba-laba, pengintai.
Dialogue: 0,0:18:04.98,0:18:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengendali benang laba-laba.
Dialogue: 0,0:18:06.52,0:18:07.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia laba-laba?
Dialogue: 0,0:18:07.40,0:18:09.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga istrinya Ed.
Dialogue: 0,0:18:09.15,0:18:11.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir ada Senon, dia pendeta elf.
Dialogue: 0,0:18:11.57,0:18:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf, gadis hutan!
Dialogue: 0,0:18:14.51,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar ingin bertemu mereka.
Dialogue: 0,0:18:16.45,0:18:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria juga rakus makan seperti aku.
Dialogue: 0,0:18:18.74,0:18:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan akrab denganmu.
Dialogue: 0,0:18:20.29,0:18:22.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Senon itu pria.
Dialogue: 0,0:18:22.12,0:18:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya.
Dialogue: 0,0:18:23.79,0:18:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai penikmat gim peran,\Naku mendambakan elf cantik.
Dialogue: 0,0:18:30.84,0:18:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Survival muncul memberi notifikasi.
Dialogue: 0,0:18:32.47,0:18:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya tak beracun dan enak!
Dialogue: 0,0:18:35.09,0:18:35.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Rin!
Dialogue: 0,0:18:39.89,0:18:41.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gagak Raksasa?
Dialogue: 0,0:18:43.91,0:18:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka monster?
Dialogue: 0,0:18:44.94,0:18:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana Survival?
Dialogue: 0,0:18:46.27,0:18:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak.
Dialogue: 0,0:18:47.40,0:18:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bergantung pada skill.
Dialogue: 0,0:18:49.69,0:18:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mati.
Dialogue: 0,0:18:51.15,0:18:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin!
Dialogue: 0,0:19:05.67,0:19:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, kamu baik-baik saja?
Dialogue: 0,0:19:07.60,0:19:09.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak apa-apa.
Dialogue: 0,0:19:09.38,0:19:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih banyak.
Dialogue: 0,0:19:11.42,0:19:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku belum tahu apa pun\Ntentang dunia ini
Dialogue: 0,0:19:15.01,0:19:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan malah gegabah menggunakan skill!
Dialogue: 0,0:19:17.47,0:19:19.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:19:19.16,0:19:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, sebagai rekan grup,\Naku akan selalu menemanimu!
Dialogue: 0,0:19:22.72,0:19:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silau!\NTerlalu silau!
Dialogue: 0,0:19:25.34,0:19:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Kalau terus begini,\Naku tak akan sanggup menahannya.
Dialogue: 0,0:19:29.82,0:19:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, lihat ke sana.
Dialogue: 0,0:19:31.48,0:19:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada drop item.
Dialogue: 0,0:19:33.49,0:19:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:34.61,0:19:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika berhasil mengalahkan monster,\Nakan ada material yang jatuh.
Dialogue: 0,0:19:37.88,0:19:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kadang dapat daging juga.
Dialogue: 0,0:19:40.35,0:19:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging yang kemarin\Ndapat dengan cara ini?
Dialogue: 0,0:19:42.95,0:19:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemahamanku tentang isekai\Nmasih sangat dangkal.
Dialogue: 0,0:19:47.92,0:19:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:19:49.08,0:19:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita pergi ke Kota Elrage.
Dialogue: 0,0:19:52.55,0:19:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, apa kotak ini betulan bisa bergerak?
Dialogue: 0,0:19:56.68,0:20:00.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu, sebaiknya langsung\Nkutunjukkan saja.
Dialogue: 0,0:20:00.83,0:20:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berangkat, Mo!
Dialogue: 0,0:20:06.14,0:20:07.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:20:07.56,0:20:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari kecepatan dan kenyamanan,\Njauh lebih baik dari kereta kuda!
Dialogue: 0,0:20:11.23,0:20:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, kita bisa sampai ke Elrage\Nkurang dari tiga jam.
Dialogue: 0,0:20:15.11,0:20:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau jalan kaki, perlu tiga hari?
Dialogue: 0,0:20:18.82,0:20:19.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:19.74,0:20:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bilang Mo\Npunya efek tersembunyi, kan?
Dialogue: 0,0:20:23.87,0:20:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku takut tak sengaja menabrak\Norang atau monster.
Dialogue: 0,0:20:27.71,0:20:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin dekat ke kota,
Dialogue: 0,0:20:29.82,0:20:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan ada lebih banyak petualang\Ndan pedagang keliling.
Dialogue: 0,0:20:33.13,0:20:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apa sebaiknya\Nkita lewat pegunungan?
Dialogue: 0,0:20:36.09,0:20:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jalannya agak rusak,
Dialogue: 0,0:20:37.80,0:20:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bisa lebih cepat sampai\Nkarena jalurnya lurus.
Dialogue: 0,0:20:41.29,0:20:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain lewat jalan pintas,\Nkita juga menghindari keramaian.
Dialogue: 0,0:20:44.01,0:20:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita lewat sana!
Dialogue: 0,0:20:48.94,0:20:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di jalan gunung pun tak terlalu berguncang.
Dialogue: 0,0:20:51.81,0:20:54.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, Mo memang hebat.
Dialogue: 0,0:20:54.48,0:20:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill-mu terlalu tidak masuk akal,
Dialogue: 0,0:20:56.90,0:20:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebaiknya jangan sampai orang lain tahu.
Dialogue: 0,0:20:58.78,0:20:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:21:00.24,0:21:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Survival bukan masalah, tapi Mo...
Dialogue: 0,0:21:03.49,0:21:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:21:04.33,0:21:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:21:05.24,0:21:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Survival tiba-tiba memberi peringatan.
Dialogue: 0,0:21:13.29,0:21:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruang?
Dialogue: 0,0:21:14.54,0:21:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Fire Bear.
Dialogue: 0,0:21:16.09,0:21:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya tak akan muncul di daerah ini.
Dialogue: 0,0:21:22.75,0:21:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan kabur, daging beruang.
Dialogue: 0,0:21:29.52,0:21:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, aku lupa kalau dia punya api.
Dialogue: 0,0:21:31.85,0:21:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, beraninya melukai Aria-ku!
Dialogue: 0,0:21:35.61,0:21:37.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dibakarnya itu benang Aria, kan?
Dialogue: 0,0:21:37.97,0:21:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sudah menyangkut Aria,\Nkamu langsung kalap.
Dialogue: 0,0:21:41.78,0:21:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria, Ed, Senon!
Dialogue: 0,0:21:44.32,0:21:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?\NJadi mereka...
Dialogue: 0,0:21:46.87,0:21:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka rekanku, anggota Meja Rakus.
Dialogue: 0,0:21:50.16,0:21:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, tunggu di sini.
Dialogue: 0,0:21:51.71,0:21:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya! Tapi...
Dialogue: 0,0:21:52.87,0:21:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
