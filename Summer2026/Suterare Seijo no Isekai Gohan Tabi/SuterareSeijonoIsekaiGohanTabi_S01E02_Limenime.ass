Dialogue: 0,0:01:01.12,0:01:14.01,sign,,0000,0000,0000,,THE FORSAKEN SAINTESS\NAND HER FOODIE ROADTRIP IN ANOTHER WORLD
Dialogue: 0,0:02:12.99,0:02:15.91,sign,,0000,0000,0000,,EPISODE 2: SATUKAN SEMUA REKAN DAN BAHAN,\NJADILAH NASI CAMPUR!
Dialogue: 0,0:09:32.13,0:09:34.00,sign,,0000,0000,0000,,SKILL KHUSUS, MOBIL KAMPING
Dialogue: 0,0:09:34.00,0:09:35.26,sign,,0000,0000,0000,,PENGATURAN PENUMPANG
Dialogue: 0,0:09:35.26,0:09:37.64,sign,,0000,0000,0000,,IZIN
Dialogue: 0,0:16:50.78,0:16:52.99,sign,,0000,0000,0000,,PROFESI: ORANG ASING, PENGEMBARA
Dialogue: 0,0:16:52.99,0:16:56.12,sign,,0000,0000,0000,,SKILL: SURVIVAL
Dialogue: 0,0:16:56.12,0:16:58.41,sign,,0000,0000,0000,,SKILL KHUSUS: MOBIL KAMPING
Dialogue: 0,0:18:55.41,0:18:56.87,sign,,0000,0000,0000,,KRUYUK
Dialogue: 0,0:19:34.53,0:19:36.15,sign,,0000,0000,0000,,MENANAK NASI, MULAI
Dialogue: 0,0:19:49.09,0:19:51.34,sign,,0000,0000,0000,,MIRIN, SAKE MASAK, KECAP ASIN
Dialogue: 0,0:23:35.02,0:23:40.07,sign,,0000,0000,0000,,EPISODE 3: BERTARUNG DI TEPI PANTAI\NDAN BARBEKU HIDANGAN LAUT
Dialogue: 0,0:00:09.70,0:00:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Ville.
Dialogue: 0,0:00:11.37,0:00:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pulang lebih cepat beberapa hari.
Dialogue: 0,0:00:14.16,0:00:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah pulang?
Dialogue: 0,0:00:16.58,0:00:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku berniat mengusir Senon
Dialogue: 0,0:00:18.54,0:00:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar bisa bermesraan dengan Aria.
Dialogue: 0,0:00:21.38,0:00:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kamu pulang karena lapar, kan?
Dialogue: 0,0:00:24.34,0:00:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu selalu begitu.
Dialogue: 0,0:00:25.59,0:00:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita urus dulu makhluk ini\Nlalu bahas itu nanti.
Dialogue: 0,0:00:29.59,0:00:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meja Rakus, beraksi!
Dialogue: 0,0:00:35.14,0:00:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini isekai.
Dialogue: 0,0:00:36.56,0:00:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini pertarungan grup!
Dialogue: 0,0:00:39.89,0:00:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat, Ville!
Dialogue: 0,0:02:15.91,0:02:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan!
Dialogue: 0,0:02:21.65,0:02:23.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin adu sihir denganku?
Dialogue: 0,0:02:23.62,0:02:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik dipukul dengan batu api saja.
Dialogue: 0,0:02:28.63,0:02:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Esti Gard.
Dialogue: 0,0:02:31.46,0:02:33.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aria!
Dialogue: 0,0:02:33.38,0:02:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, kamu menyepelekan lawan.
Dialogue: 0,0:02:35.30,0:02:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istriku memang terbaik!
Dialogue: 0,0:02:37.30,0:02:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau membuatku jatuh cinta\Nberapa kali lagi agar puas?
Dialogue: 0,0:02:40.56,0:02:44.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kamu sengaja\Nmembiarkan Aria menyelamatkanmu?
Dialogue: 0,0:02:44.06,0:02:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan lengah menghadapi\Nmonster seperti ini.
Dialogue: 0,0:02:47.52,0:02:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville, tolong urus sisanya.
Dialogue: 0,0:02:49.48,0:02:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:02:58.73,0:03:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak menantang.
Dialogue: 0,0:03:00.79,0:03:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:02.37,0:03:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan tidak bisa menggores\Ndinding es Ed sedikit pun.
Dialogue: 0,0:03:05.83,0:03:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun tak perlu ikut membantu.
Dialogue: 0,0:03:08.83,0:03:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senon.
Dialogue: 0,0:03:10.25,0:03:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, kulit mulus Aria terluka!
Dialogue: 0,0:03:13.71,0:03:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat obati dia, jangan sampai ada bekas!
Dialogue: 0,0:03:16.09,0:03:16.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon!
Dialogue: 0,0:03:16.76,0:03:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini luka saat berlari di hutan tadi,
Dialogue: 0,0:03:18.93,0:03:20.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak sengaja tergores sedikit.
Dialogue: 0,0:03:20.57,0:03:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, kamu terlalu berlebihan.
Dialogue: 0,0:03:22.22,0:03:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau sampai\Nmeninggalkan bekas luka?
Dialogue: 0,0:03:24.81,0:03:27.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mau ada bekas luka atau tidak,
Dialogue: 0,0:03:27.52,0:03:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cintaku padamu tetap sama!
Dialogue: 0,0:03:31.44,0:03:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cure Up.
Dialogue: 0,0:03:36.53,0:03:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, Aria!
Dialogue: 0,0:03:39.82,0:03:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kenapa kalian bisa ada di sini?
Dialogue: 0,0:03:42.58,0:03:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini area berburu\Nuntuk para petualang pemula, kan?
Dialogue: 0,0:03:45.84,0:03:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang senggang dan ingin mendaki.
Dialogue: 0,0:03:49.75,0:03:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian mengumpulkan\Nbahan yang mudah didapat.
Dialogue: 0,0:03:52.17,0:03:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kami kebetulan bertemu grup\Nyang diserang Beruang Api tadi.
Dialogue: 0,0:03:57.80,0:03:59.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka kelihatannya pemula.
Dialogue: 0,0:03:59.93,0:04:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ikut membantu\Nlalu menyuruh mereka kabur duluan.
Dialogue: 0,0:04:02.81,0:04:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:04:04.68,0:04:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ini masalah besar.
Dialogue: 0,0:04:07.27,0:04:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruang Api masih termasuk\Nkategori monster lemah,
Dialogue: 0,0:04:09.65,0:04:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kemunculannya di area petualang\Npemula tetap tidak biasa.
Dialogue: 0,0:04:13.07,0:04:16.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya masalah ini\Ndilaporkan ke serikat.
Dialogue: 0,0:04:16.08,0:04:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kenapa kamu juga ada di sini?
Dialogue: 0,0:04:19.13,0:04:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harusnya sedang menjelajah\Ndi Danau Real, kan?
Dialogue: 0,0:04:21.82,0:04:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ada hal yang harus\Nkulaporkan pada kalian.
Dialogue: 0,0:04:26.04,0:04:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Rin!
Dialogue: 0,0:04:28.56,0:04:30.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah aman, kamu boleh keluar.
Dialogue: 0,0:04:30.79,0:04:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:04:34.00,0:04:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ta-Tadi itu hebat, Ville!
Dialogue: 0,0:04:36.59,0:04:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku melihat langsung\Npertarungan sungguhan!
Dialogue: 0,0:04:39.93,0:04:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat Beruang Api itu mengeluarkan sihir,\Naku benar-benar kaget.
Dialogue: 0,0:04:43.22,0:04:46.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu bisa mengalahkannya\Ndengan satu serangan!
Dialogue: 0,0:04:46.14,0:04:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi antusias saat melihatnya!
Dialogue: 0,0:04:47.73,0:04:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, Ed dan yang lainnya juga hebat!
Dialogue: 0,0:04:49.85,0:04:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, dilihat dari dekat,\Nkalian menawan semua!
Dialogue: 0,0:04:53.52,0:04:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik pria, wanita, maupun elf,\Nsemuanya sangat menarik!
Dialogue: 0,0:04:56.61,0:04:57.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini isekai?
Dialogue: 0,0:04:57.61,0:04:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini memang isekai!
Dialogue: 0,0:05:00.22,0:05:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville, gadis ini kenalanmu?
Dialogue: 0,0:05:03.28,0:05:06.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, dari mana dia muncul tadi?
Dialogue: 0,0:05:06.87,0:05:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Rin.
Dialogue: 0,0:05:08.62,0:05:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Porter dan ahli masak\Nyang kalian cari selama ini.
Dialogue: 0,0:05:15.04,0:05:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu betulan bisa memasak?
Dialogue: 0,0:05:17.57,0:05:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bisa.
Dialogue: 0,0:05:18.76,0:05:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih sekadar masakan sederhana.
Dialogue: 0,0:05:21.91,0:05:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Kakak Cantik ini lembut sekali!
Dialogue: 0,0:05:24.10,0:05:26.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata dan wajahnya juga indah!
Dialogue: 0,0:05:26.68,0:05:29.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lama menunggumu.
Dialogue: 0,0:05:29.23,0:05:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu bisa memanggang daging?\NBisa panggang ikan juga?
Dialogue: 0,0:05:32.52,0:05:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku bisa keduanya.
Dialogue: 0,0:05:35.02,0:05:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain memanggang, aku juga bisa\Nmemasak dengan cara lain.
Dialogue: 0,0:05:38.48,0:05:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keajaiban!\NWahai dewa!
Dialogue: 0,0:05:42.07,0:05:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:05:43.49,0:05:45.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sekarang kamu paham, kan?
Dialogue: 0,0:05:45.41,0:05:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ucapanku itu serius.
Dialogue: 0,0:05:47.95,0:05:51.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sekarang aku paham.
Dialogue: 0,0:05:51.08,0:05:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, bagaimana kalau aku masakkan sesuatu?
Dialogue: 0,0:05:55.17,0:05:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin kalian menilai\Nkemampuan memasakku.
Dialogue: 0,0:05:59.55,0:06:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagusnya masak apa, ya?
Dialogue: 0,0:06:01.65,0:06:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ada daging\Nyang Ville berikan padaku.
Dialogue: 0,0:06:04.76,0:06:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Daging?
Dialogue: 0,0:06:08.35,0:06:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa Ville ikut bersemangat juga?
Dialogue: 0,0:06:12.59,0:06:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jreng!
Dialogue: 0,0:06:15.48,0:06:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging gagak siluman segar!
Dialogue: 0,0:06:18.82,0:06:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu aku terlalu panik,\Njadi tidak sempat memperhatikan.
Dialogue: 0,0:06:23.15,0:06:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dilihat baik-baik,
Dialogue: 0,0:06:24.86,0:06:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini sama seperti hasil penilaian Survival,
Dialogue: 0,0:06:27.20,0:06:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dagingnya kelihatannya sangat enak!
Dialogue: 0,0:06:29.70,0:06:32.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibuat sate bakar sederhana.
Dialogue: 0,0:06:32.58,0:06:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibumbui kecap asin, gula,\Njintan putih, dan biji ketumbar,
Dialogue: 0,0:06:36.29,0:06:39.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu buat dengan cita rasa teriyaki\Nyang manis gurih.
Dialogue: 0,0:06:41.84,0:06:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, potong seukuran sekali lahap.
Dialogue: 0,0:06:43.63,0:06:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, daging gagak siluman\Nyang sudah dibumbui
Dialogue: 0,0:06:46.76,0:06:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditusuk satu per satu.
Dialogue: 0,0:06:50.77,0:06:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi matang.\NKalian tunggu sebentar, ya.
Dialogue: 0,0:06:55.27,0:06:58.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu bolak-balik ke mobil\Nuntuk menyiapkan makanan, kan?
Dialogue: 0,0:06:58.69,0:06:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mereka lihat,
Dialogue: 0,0:06:59.86,0:07:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu seperti menghilang begitu saja.
Dialogue: 0,0:07:03.57,0:07:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tiba-tiba muncul lagi\Nmembawa banyak barang.
Dialogue: 0,0:07:06.33,0:07:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak lama kemudian, kamu menghilang lagi.
Dialogue: 0,0:07:08.45,0:07:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya reaksi mereka begitu.
Dialogue: 0,0:07:11.94,0:07:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa soal itu.
Dialogue: 0,0:07:13.87,0:07:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sebaiknya aku memasukkan pengaturan\Npenumpang untuk Ed dan yang lainnnya?
Dialogue: 0,0:07:19.29,0:07:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, untuk sementara begini saja dulu.
Dialogue: 0,0:07:22.35,0:07:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya lebih seru.
Dialogue: 0,0:07:25.78,0:07:28.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville ternyata cukup usil, ya.
Dialogue: 0,0:07:28.97,0:07:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari kita panggang!
Dialogue: 0,0:07:40.09,0:07:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aroma kecap asin yang terbakar ini,
Dialogue: 0,0:07:42.23,0:07:44.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau bagi orang Jepang,\Npasti sudah tergiur!
Dialogue: 0,0:07:44.86,0:07:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap warga isekai juga menyukainya!
Dialogue: 0,0:07:48.74,0:07:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat!\NAromanya wangi!
Dialogue: 0,0:07:51.66,0:07:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan...\NIni masakan yang sesungguhnya.
Dialogue: 0,0:07:55.37,0:07:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teknik yang mengalir alami ini...\Nsangat indah.
Dialogue: 0,0:07:58.71,0:08:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging, daging, daging, daging!
Dialogue: 0,0:08:01.32,0:08:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku hanya memanggang biasa saja.
Dialogue: 0,0:08:04.21,0:08:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak keberatan,\Nsilakan dimakan.
Dialogue: 0,0:08:06.85,0:08:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat makan!
Dialogue: 0,0:08:10.89,0:08:14.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak!\NIni sangat enak!
Dialogue: 0,0:08:14.77,0:08:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masakan seenak ini bisa dibuat\Ndalam waktu singkat?
Dialogue: 0,0:08:17.89,0:08:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dagingnya masih basah dan gurih.
Dialogue: 0,0:08:20.31,0:08:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memanggang,\Naku biasanya sampai kering.
Dialogue: 0,0:08:22.90,0:08:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis! Asin!\NIni rasa baru!
Dialogue: 0,0:08:27.85,0:08:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mereka sangat menyukainya.
Dialogue: 0,0:08:30.28,0:08:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, Nona Elf ternyata pemakan daging.
Dialogue: 0,0:08:33.20,0:08:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satenya masih banyak,\Nsilakan makan sampai puas!
Dialogue: 0,0:08:37.87,0:08:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iya!
Dialogue: 0,0:08:40.52,0:08:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, bagaimana makanannya?
Dialogue: 0,0:08:46.63,0:08:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu.
Dialogue: 0,0:08:49.38,0:08:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelukan dari Kakak Cantik!
Dialogue: 0,0:08:51.34,0:08:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia harum sekali, dadanya juga besar,\Ndan tubuhnya sangat lembut!
Dialogue: 0,0:08:54.18,0:08:56.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sanggup menahan diri!
Dialogue: 0,0:08:57.31,0:08:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat enak!
Dialogue: 0,0:08:59.73,0:09:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi menantikan\Nsetiap hidangan berikutnya.
Dialogue: 0,0:09:01.85,0:09:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan melepaskanmu.
Dialogue: 0,0:09:03.15,0:09:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:09:05.78,0:09:08.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lengket dengan Aria-ku...
Dialogue: 0,0:09:08.28,0:09:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kesal, masakanmu memang enak.
Dialogue: 0,0:09:10.53,0:09:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, mohon bantuannya, Rin.
Dialogue: 0,0:09:12.41,0:09:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging panggang tadi\Nbenar-benar sangat lezat.
Dialogue: 0,0:09:16.79,0:09:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang,\Nteruslah memberiku kejutan, Rin.
Dialogue: 0,0:09:18.91,0:09:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:09:19.83,0:09:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan berusaha sebaik mungkin.
Dialogue: 0,0:09:22.46,0:09:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bimbingannya.
Dialogue: 0,0:09:24.46,0:09:26.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah kenyang,
Dialogue: 0,0:09:26.71,0:09:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo kita kembali ke Elrage.
Dialogue: 0,0:09:28.80,0:09:30.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, tolong, ya.
Dialogue: 0,0:09:30.17,0:09:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Ville.
Dialogue: 0,0:09:32.13,0:09:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, Senon, Aria.
Dialogue: 0,0:09:35.26,0:09:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan naik Mo, konfirmasi.
Dialogue: 0,0:09:41.39,0:09:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi inilah yang ingin kulihat.
Dialogue: 0,0:09:44.36,0:09:45.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya,
Dialogue: 0,0:09:45.69,0:09:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baik masak maupun angkut barang,
Dialogue: 0,0:09:47.90,0:09:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan berusaha sebaik mungkin.
Dialogue: 0,0:09:50.24,0:09:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, mohon bimbingannya.
Dialogue: 0,0:09:59.37,0:10:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali.
Dialogue: 0,0:10:00.33,0:10:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi benda ini bergerak dengan mana, ya?
Dialogue: 0,0:10:03.01,0:10:04.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir angin dan tanah?
Dialogue: 0,0:10:04.83,0:10:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, bukan hanya itu.
Dialogue: 0,0:10:07.25,0:10:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat lapis.
Dialogue: 0,0:10:08.25,0:10:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, lebih dari lima lapis sihir gabungan.
Dialogue: 0,0:10:10.88,0:10:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah hidup cukup lama,
Dialogue: 0,0:10:13.30,0:10:15.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi belum pernah melihat skill seperti ini.
Dialogue: 0,0:10:16.80,0:10:22.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa skill-ku sebaiknya jangan diberitahu\Npada sembarangan orang?
Dialogue: 0,0:10:22.73,0:10:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, bagaimanapun,\Nskill ini terlalu di luar nalar.
Dialogue: 0,0:10:26.56,0:10:28.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, perihal Pemanggilan Gadis Suci,
Dialogue: 0,0:10:28.57,0:10:31.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku minta maaf, tapi aku sudah\Nmelaporkannya ke para petinggi.
Dialogue: 0,0:10:31.61,0:10:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masalah ini mungkin bisa\Nmelibatkan seluruh negara.
Dialogue: 0,0:10:34.70,0:10:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, itu hal wajar.
Dialogue: 0,0:10:37.27,0:10:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, negara?
Dialogue: 0,0:10:38.16,0:10:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum cerita, ya?
Dialogue: 0,0:10:40.43,0:10:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini namanya "Risfield",
Dialogue: 0,0:10:42.58,0:10:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}negara kepulauan yang dikelilingi lautan,
Dialogue: 0,0:10:44.29,0:10:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedikit lebih besar dari pulau biasa.
Dialogue: 0,0:10:46.71,0:10:50.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negara ini sangat damai,\Ntidak perlu memanggil Gadis Suci.
Dialogue: 0,0:10:50.39,0:10:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, negara ini awalnya didirikan\Nsekumpulan orang yang membenci perang.
Dialogue: 0,0:10:54.97,0:11:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu sekali, diskriminasi dari negara lain\Nsangat parah terhadap ras nonmanusia.
Dialogue: 0,0:11:00.75,0:11:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu sekelompok yang bersikap baik pada elf,\Ndwarf, dan orc menyeberangi lautan,
Dialogue: 0,0:11:06.06,0:11:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu akhirnya tiba di pulau ini.
Dialogue: 0,0:11:08.52,0:11:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk asli seperti\NRas Naga Iblis seperti kami,
Dialogue: 0,0:11:10.79,0:11:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang berevolusi secara terpisah\Nkarena tinggal di negara pulau ini,
Dialogue: 0,0:11:14.90,0:11:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga memilih menerima mereka.
Dialogue: 0,0:11:16.36,0:11:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama kelamaan, tempat ini
Dialogue: 0,0:11:18.87,0:11:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjadi negara tempat berbagai ras\Nyang saling hidup berdampingan.
Dialogue: 0,0:11:22.41,0:11:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat itu, terciptalah ekosistem\Nyang sangat unik,
Dialogue: 0,0:11:24.96,0:11:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}para akademisi pun berbondong-bondong\Ndatang untuk melakukan penelitian.
Dialogue: 0,0:11:28.17,0:11:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya dari seberang lautan,
Dialogue: 0,0:11:30.13,0:11:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan penduduk isekai pun\Nbisa diterima dengan mudah.
Dialogue: 0,0:11:33.01,0:11:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu karena pengaruh budaya?
Dialogue: 0,0:11:36.05,0:11:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiring berjalannya waktu,\Nsekarang kami juga
Dialogue: 0,0:11:38.22,0:11:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berinteraksi atau berdagang dengan negara\Nyang tidak berprasangka pada ras lain,
Dialogue: 0,0:11:44.10,0:11:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tetap menjaga jarak dengan negara\Nyang menganut paham supremasi manusia.
Dialogue: 0,0:11:47.77,0:11:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski situasi di dalam negeri Risfield damai,
Dialogue: 0,0:11:50.16,0:11:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami tetap tak boleh lengah\Nterhadap negara lain.
Dialogue: 0,0:11:53.23,0:11:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata petualang kelas satu harus paham\Nsituasi internasional dan politik.
Dialogue: 0,0:11:58.57,0:12:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku sudah melapor\Nke serikat petualang Elrage sebelumnya.
Dialogue: 0,0:12:02.97,0:12:04.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota pelabuhan ini
Dialogue: 0,0:12:04.79,0:12:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}satu-satunya pintu masuk\Nbagi pihak luar ke negara kami.
Dialogue: 0,0:12:07.29,0:12:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang Pemanggilan Gadis Suci\NMungkin kita bisa dapat petunjuk
Dialogue: 0,0:12:10.03,0:12:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melalui informasi yang datang\Ndari negara-negara lain.
Dialogue: 0,0:12:14.05,0:12:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena di sini ada pelabuhan,
Dialogue: 0,0:12:16.17,0:12:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti ada banyak ikan segar, kan?
Dialogue: 0,0:12:21.93,0:12:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:12:22.93,0:12:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elrage itu kota terbesar kedua\Nsetelah ibu kota kerajaan.
Dialogue: 0,0:12:25.47,0:12:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus menantikannya!
Dialogue: 0,0:12:27.27,0:12:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak terasa, sambil membahasnya,\Nkita sudah sampai.
Dialogue: 0,0:12:29.52,0:12:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill-mu memang hebat, ya.
Dialogue: 0,0:12:33.61,0:12:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Temboknya tinggi sekali!
Dialogue: 0,0:12:35.99,0:12:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan\Nmembatalkan skill-ku di sini.
Dialogue: 0,0:12:39.45,0:12:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, lebih baik begitu.
Dialogue: 0,0:12:49.00,0:12:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dunia fantasi!
Dialogue: 0,0:12:52.04,0:12:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi ke serikat petualang dulu\Nuntuk mengurus pendaftaran Rin.
Dialogue: 0,0:12:56.76,0:13:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kami pulang dulu\Nuntuk menyiapkan kamar Rin.
Dialogue: 0,0:13:00.55,0:13:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville.
Dialogue: 0,0:13:01.84,0:13:03.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum Rin resmi bergabung dengan kita,
Dialogue: 0,0:13:03.93,0:13:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jangan sampai dia kabur.
Dialogue: 0,0:13:05.64,0:13:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin.
Dialogue: 0,0:13:07.14,0:13:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus kembali, ya.
Dialogue: 0,0:13:09.14,0:13:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pergi ke tempat lain.
Dialogue: 0,0:13:12.98,0:13:15.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus belajar menahan diri.
Dialogue: 0,0:13:17.69,0:13:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini serikat petualang?
Dialogue: 0,0:13:22.16,0:13:25.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di serikat petualang.
Dialogue: 0,0:13:25.12,0:13:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut!
Dialogue: 0,0:13:26.83,0:13:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville, ada perlu apa hari ini?
Dialogue: 0,0:13:30.07,0:13:31.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melaporkan misi penyelamatan
Dialogue: 0,0:13:31.96,0:13:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengurus pendaftaran anggota baru.
Dialogue: 0,0:13:34.99,0:13:35.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:13:35.92,0:13:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anggota Grup Semanggi Keberuntungan\Nyang selamat juga sudah melapor.
Dialogue: 0,0:13:41.01,0:13:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah tidak ada yang terluka.
Dialogue: 0,0:13:43.14,0:13:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, untuk pendaftaran masuk grup,
Dialogue: 0,0:13:45.47,0:13:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan isi formulir permohonan ini.
Dialogue: 0,0:13:49.89,0:13:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vi-Ville.
Dialogue: 0,0:13:51.19,0:13:54.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Anjing yang imut dan berbulu ini...
Dialogue: 0,0:13:55.81,0:13:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru pertama kali\Nmelihat Kobold, ya?
Dialogue: 0,0:13:58.03,0:14:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku staf resepsionis, Shira.
Dialogue: 0,0:14:02.01,0:14:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malu sekali dibilang imut.
Dialogue: 0,0:14:04.87,0:14:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar, Rin,
Dialogue: 0,0:14:06.24,0:14:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shira sudah bekerja di sini\Nselama 20 tahun.
Dialogue: 0,0:14:09.33,0:14:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}20 tahun?
Dialogue: 0,0:14:10.70,0:14:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, Ville.
Dialogue: 0,0:14:12.62,0:14:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal membocorkan\Nusia seorang wanita.
Dialogue: 0,0:14:19.13,0:14:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada masalah.
Dialogue: 0,0:14:20.51,0:14:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin sudah terdaftar\Nsebagai porter Meja Rakus.
Dialogue: 0,0:14:25.04,0:14:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, terima kasih.
Dialogue: 0,0:14:27.64,0:14:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang kutulis itu bahasa Jepang,\Ntapi otomatis jadi tulisan lokal.
Dialogue: 0,0:14:30.42,0:14:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tulisan lokal,\Ntetap terbaca sebagai bahasa Jepang.
Dialogue: 0,0:14:32.89,0:14:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum terbiasa dengan hal ini.
Dialogue: 0,0:14:35.40,0:14:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya mungkin akan terasa agak sulit,
Dialogue: 0,0:14:37.65,0:14:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi anggota grup Ville orang baik semua.
Dialogue: 0,0:14:40.57,0:14:42.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon semangat, ya.
Dialogue: 0,0:14:42.90,0:14:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:14:45.99,0:14:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ada yang ingin kubicarakan\Ndengan Ketua Serikat.
Dialogue: 0,0:14:48.99,0:14:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, silakan langsung ke kantor ketua.
Dialogue: 0,0:14:54.04,0:14:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rin.
Dialogue: 0,0:14:56.04,0:15:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengalamanku masih sedikit,\Ntapi mohon bimbingan dan arahannya!
Dialogue: 0,0:15:01.55,0:15:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu serius?
Dialogue: 0,0:15:03.13,0:15:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka kamu bisa kenal orang bermutu.
Dialogue: 0,0:15:05.13,0:15:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana kamu menculiknya?
Dialogue: 0,0:15:06.43,0:15:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan konyol.
Dialogue: 0,0:15:07.97,0:15:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuai yang kulaporkan,
Dialogue: 0,0:15:08.97,0:15:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku hanya melindunginya\Ndan mengajaknya bergabung.
Dialogue: 0,0:15:11.39,0:15:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, maaf, Nona.
Dialogue: 0,0:15:13.35,0:15:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Tori, Ketua Serikat di sini.
Dialogue: 0,0:15:17.03,0:15:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Ville, jangan menakutiku seperti itu.
Dialogue: 0,0:15:20.77,0:15:23.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku heran kenapa kamu tiba-tiba\Nmengirim merpati darurat,
Dialogue: 0,0:15:23.86,0:15:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah mendadak membahas\NPemanggilan Gadis Suci dalam cerita rakyat,
Dialogue: 0,0:15:27.11,0:15:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu bilang bahwa kamu sudah\Nmerekrut Gadis Suci ini.
Dialogue: 0,0:15:30.21,0:15:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu dia sudah melapor,
Dialogue: 0,0:15:32.62,0:15:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kapan persisnya dia melapor?
Dialogue: 0,0:15:34.35,0:15:36.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya apa yang terjadi?
Dialogue: 0,0:15:37.42,0:15:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak tahu.
Dialogue: 0,0:15:38.75,0:15:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya mereka menganggapku sampah,
Dialogue: 0,0:15:40.54,0:15:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu langsung membuangku ke alam liar.
Dialogue: 0,0:15:42.17,0:15:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ada gadis yang dipanggil\Nbersamaan denganku.
Dialogue: 0,0:15:44.80,0:15:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memanggilnya "Gadis Suci".
Dialogue: 0,0:15:47.83,0:15:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan ingin mencurigaimu,
Dialogue: 0,0:15:49.68,0:15:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa aku boleh mengidentifikasimu dulu?
Dialogue: 0,0:15:52.68,0:15:54.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak perlu melotot begitu.
Dialogue: 0,0:15:54.77,0:15:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin memastikan profesi\Ndan skill-nya saja.
Dialogue: 0,0:15:57.77,0:15:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:15:58.90,0:16:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asalkan tidak menimbulkan\Nsakit atau tidak nyaman,
Dialogue: 0,0:16:01.40,0:16:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan juga tidak membocorkan berat badan\Nserta tabunganku, itu sudah cukup.
Dialogue: 0,0:16:05.49,0:16:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rin, info status semacam itu,
Dialogue: 0,0:16:08.61,0:16:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada dasarnya hanya boleh dilihat\Norang yang sudah dikenal.
Dialogue: 0,0:16:11.33,0:16:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lihat kamu sepertinya\Nsangat percaya pada Tori,
Dialogue: 0,0:16:14.20,0:16:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kupikir tak akan ada masalah.
Dialogue: 0,0:16:15.66,0:16:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang yang bisa melihat\Ninformasi sedetail itu.
Dialogue: 0,0:16:20.00,0:16:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:16:21.25,0:16:25.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, skill identifikasi mereka\Ntidak sehebat Survival?
Dialogue: 0,0:16:26.67,0:16:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona, kamu punya profesi orang asing, kan?
Dialogue: 0,0:16:29.38,0:16:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, ini profesi yang hanya\Nbisa diperoleh oleh orang dari dunia lain.
Dialogue: 0,0:16:34.03,0:16:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bisa mendapat satu\Nskill kuat secara acak
Dialogue: 0,0:16:36.53,0:16:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bisa mendapat satu profesi tambahan.
Dialogue: 0,0:16:39.49,0:16:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu memang\Nberasal dari dunia lain.
Dialogue: 0,0:16:42.98,0:16:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan sepertinya atau mungkin.
Dialogue: 0,0:16:45.44,0:16:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa diandalkan.
Dialogue: 0,0:16:46.44,0:16:49.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cerita rakyat dari ratusan tahun yang lalu.
Dialogue: 0,0:16:49.53,0:16:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin meninggalkan catatan akurat.
Dialogue: 0,0:16:50.78,0:16:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin ada catatan akurat.
Dialogue: 0,0:16:52.99,0:16:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, pengembara ini profesi keduaku
Dialogue: 0,0:16:56.12,0:16:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Mo adalah skill khusus.
Dialogue: 0,0:16:58.41,0:17:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mendapat skill khusus\Nmemang cukup menarik.
Dialogue: 0,0:17:01.79,0:17:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Pemanggilan Gadis Suci itu\Ntaruhan yang sangat besar.
Dialogue: 0,0:17:04.67,0:17:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa situasi di seberang lautan\Nsudah genting sampai harus pakai cara ini?
Dialogue: 0,0:17:08.38,0:17:11.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, sejauh ini aku\Nbelum menerima kabar perang
Dialogue: 0,0:17:11.22,0:17:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kemunculan banyak monster.
Dialogue: 0,0:17:15.41,0:17:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kenapa mereka melakukannya?
Dialogue: 0,0:17:17.46,0:17:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipaksakan,
Dialogue: 0,0:17:19.52,0:17:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski skalanya lebih kecil,
Dialogue: 0,0:17:21.02,0:17:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kerusuhan Beruang Api kali ini...
Dialogue: 0,0:17:23.15,0:17:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ada kaitannya.
Dialogue: 0,0:17:25.06,0:17:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya di area berburu pemula
Dialogue: 0,0:17:26.85,0:17:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan muncul\Nmonster buas seperti itu.
Dialogue: 0,0:17:31.15,0:17:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini baru terjadi satu kasus saja,
Dialogue: 0,0:17:32.95,0:17:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}belum bisa dipastikan apa ini\Nberkaitan dengan Pemanggilan Gadis Suci.
Dialogue: 0,0:17:36.03,0:17:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, berdasarkan laporan.
Dialogue: 0,0:17:37.58,0:17:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruang Api itu sepertinya lebih lemah\Ndaripada yang biasa, kan?
Dialogue: 0,0:17:40.41,0:17:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontradiksi seperti inilah\Nyang menurutku bagian paling aneh.
Dialogue: 0,0:17:43.38,0:17:46.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, serikat secara resmi\Nmengajukan misi pada kalian.
Dialogue: 0,0:17:46.52,0:17:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sementara, Meja Rakus
Dialogue: 0,0:17:47.88,0:17:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus membantu meningkatkan\Npatroli di sekitar Elrage.
Dialogue: 0,0:17:51.93,0:17:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tak pergi terlalu jauh dari sini,\Nkalian bebas mengambil misi lain.
Dialogue: 0,0:17:56.24,0:17:57.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:17:57.60,0:17:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski Beruang Api itu
Dialogue: 0,0:17:59.18,0:18:01.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih lemah dari Beruang Api pada umumnya,
Dialogue: 0,0:18:01.33,0:18:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}grup biasa mungkin sulit mengatasinya.
Dialogue: 0,0:18:03.84,0:18:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kami ambil misi ini.
Dialogue: 0,0:18:05.81,0:18:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih. Dengan bantuan kalian,\Naku jadi lega.
Dialogue: 0,0:18:09.30,0:18:11.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung mendapat misi dari Ketua Serikat,
Dialogue: 0,0:18:11.95,0:18:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ville dan lainnya memang hebat.
Dialogue: 0,0:18:14.32,0:18:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesampingkan soal Gadis Suci,
Dialogue: 0,0:18:15.99,0:18:18.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku sudah bergabung dengan grup ini,
Dialogue: 0,0:18:18.12,0:18:20.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus berusaha sebaik mungkin!
Dialogue: 0,0:18:24.88,0:18:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahnya megah, ya.
Dialogue: 0,0:18:27.38,0:18:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumah ini bagus, kan?
Dialogue: 0,0:18:28.88,0:18:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya ini vila milik orang kaya.
Dialogue: 0,0:18:31.97,0:18:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia mati misterius di sini,\Nlalu disewakan murah pada kami.
Dialogue: 0,0:18:35.51,0:18:37.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini rumah angker?
Dialogue: 0,0:18:37.80,0:18:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sebenarnya seorang pendeta.
Dialogue: 0,0:18:40.14,0:18:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu atau dua hantu masih bisa kuatasi.
Dialogue: 0,0:18:43.44,0:18:46.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ada halaman belakang yang bisa dipakai\Nuntuk memaksimalkan skill-mu.
Dialogue: 0,0:18:46.94,0:18:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus.
Dialogue: 0,0:18:48.44,0:18:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengajakmu keliling bagian dalam.
Dialogue: 0,0:18:51.77,0:18:54.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berusaha keras membersihkannya.
Dialogue: 0,0:18:58.70,0:19:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah waktunya,\Nkita makan malam dulu.
Dialogue: 0,0:19:03.66,0:19:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan malam hari ini...
Dialogue: 0,0:19:06.38,0:19:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi campur yang lezat.
Dialogue: 0,0:19:08.71,0:19:13.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahannya daging Al-Miraj\Npemberian dari Ville kemarin,
Dialogue: 0,0:19:13.17,0:19:16.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditambah jamur Tiratake yang dipetik Ed\Ndan yang lainnya hari ini.
Dialogue: 0,0:19:16.47,0:19:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku akan menyiapkan\Ndua hidangan lagi.
Dialogue: 0,0:19:19.68,0:19:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, selesaikan dengan cepat!
Dialogue: 0,0:19:22.81,0:19:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, suwir jamur Tiratake,\Nlalu tumis di wajan.
Dialogue: 0,0:19:25.50,0:19:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, daging Al-Miraj,
Dialogue: 0,0:19:27.27,0:19:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sudah dipotong seukuran sekali lahap\Ndirendam bumbu kecap asin, sake, dan gula,
Dialogue: 0,0:19:32.28,0:19:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dituang bersama bumbunya.
Dialogue: 0,0:19:33.65,0:19:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, masukkan
Dialogue: 0,0:19:34.53,0:19:36.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke dalam penanak nasi.
Dialogue: 0,0:19:36.66,0:19:38.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam telur gagak siluman,
Dialogue: 0,0:19:38.24,0:19:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tambahkan seledri liar yang sudah\Ndicincang untuk menambah rasa,
Dialogue: 0,0:19:41.03,0:19:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu tuangkan ke dalam wajan datar.
Dialogue: 0,0:19:43.43,0:19:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potong agak tebal beberapa daging Al-Miraj,\Nlalu taburi tepung.
Dialogue: 0,0:19:47.42,0:19:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campurkan jahe halus, kecap asin, sake,
Dialogue: 0,0:19:49.09,0:19:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mirin untuk membuat saus.
Dialogue: 0,0:19:51.34,0:19:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siram ke daging dan bawang bombai\Nyang sudah digoreng mengental.
Dialogue: 0,0:19:54.63,0:19:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah semua bahan meresap,
Dialogue: 0,0:19:57.09,0:19:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hidangannya sudah siap!
Dialogue: 0,0:19:59.76,0:20:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan malam hari ini,
Dialogue: 0,0:20:01.14,0:20:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nasi campur jamur Tiratake\Ndan daging Al-Miraj,
Dialogue: 0,0:20:04.06,0:20:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dipadukan tamagoyaki gagak siluman,
Dialogue: 0,0:20:05.77,0:20:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta daging Al-Miraj saus jahe.
Dialogue: 0,0:20:08.69,0:20:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telurnya diambil dari sarang gagak siluman\Nyang dikalahkan Ville pagi ini.
Dialogue: 0,0:20:13.82,0:20:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jahe dan bawang bombai dibeli di pasar\Nsaat pulang dari serikat.
Dialogue: 0,0:20:19.04,0:20:22.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng, kenapa semuanya diam?
Dialogue: 0,0:20:22.74,0:20:25.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kami tidak menyangka\Nakan ada momen
Dialogue: 0,0:20:25.62,0:20:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di meja makan kami disajikan\Nhidangan seistimewa ini.
Dialogue: 0,0:20:28.33,0:20:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidangan sebelumnya seperti hukuman dewa.
Dialogue: 0,0:20:31.46,0:20:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sepertinya aku\Nbelum cukup mengenalmu.
Dialogue: 0,0:20:35.42,0:20:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sudah boleh dimakan?
Dialogue: 0,0:20:38.26,0:20:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:20:39.93,0:20:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hasil kerjaku.
Dialogue: 0,0:20:41.76,0:20:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan nikmati rasanya!
Dialogue: 0,0:20:45.97,0:20:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak, ini enak sekali.
Dialogue: 0,0:20:49.27,0:20:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jamur dan daging\Nyang meresap sausnya, enak sekali.
Dialogue: 0,0:20:53.23,0:20:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu dimakan, rasanya hati jadi hangat.
Dialogue: 0,0:20:55.03,0:20:58.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada rasa puas saat perut perlahan terisi.\NRasanya membuat ketagihan.
Dialogue: 0,0:20:59.24,0:21:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak sekali.
Dialogue: 0,0:21:00.57,0:21:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus digoreng seperti apa agar bisa\Nmendapat tekstur selembut dan sehalus ini?
Dialogue: 0,0:21:04.24,0:21:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kalau hanya memakai telur,\Nrasanya cenderung terlalu kuat.
Dialogue: 0,0:21:07.54,0:21:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi setelah ditambahkan seledri liar,
Dialogue: 0,0:21:09.16,0:21:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aroma dan teksturnya\Nlangsung terasa lebih segar.
Dialogue: 0,0:21:12.13,0:21:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasi dan telurnya memang enak.
Dialogue: 0,0:21:14.61,0:21:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, inti dari hidangan ini\Ntetaplah daging!
Dialogue: 0,0:21:19.30,0:21:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging Al-Miraj yang selalu\Nkami panggang sampai alot itu,
Dialogue: 0,0:21:22.76,0:21:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata bisa dimasak selembut ini.
Dialogue: 0,0:21:24.60,0:21:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saus manis asin yang kental\Nmenyelimuti dagingnya dengan sempurna.
Dialogue: 0,0:21:27.64,0:21:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah aroma jahe dan tekstur bawang bombai,\Nmakin membangkitkan selera.
Dialogue: 0,0:21:32.40,0:21:35.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti sangat enak dimakan dengan nasi.
Dialogue: 0,0:21:35.44,0:21:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, beri aku semangkuk nasi.
Dialogue: 0,0:21:36.94,0:21:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau nasi!
Dialogue: 0,0:21:37.98,0:21:40.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ed, jaga nasinya.
Dialogue: 0,0:21:40.36,0:21:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau merebut daging.
Dialogue: 0,0:21:42.11,0:21:43.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku, Aria.
Dialogue: 0,0:21:43.95,0:21:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian ambilkan aku beberapa potong.
Dialogue: 0,0:21:45.99,0:21:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang berkaitan dengan daging,\Naku tentu tidak bisa tinggal diam.
Dialogue: 0,0:21:49.54,0:21:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan membantu.
Dialogue: 0,0:21:50.71,0:21:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, semuanya.
Dialogue: 0,0:21:54.00,0:21:57.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, nasi dan lauknya masih banyak,
Dialogue: 0,0:21:57.42,0:22:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong duduk dan nikmati baik-baik.
Dialogue: 0,0:22:00.09,0:22:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baik.
