Dialogue: 0,0:00:07.00,0:00:08.93,sign,,0000,0000,0000,,"ALICIA GLENFALL"
Dialogue: 0,0:00:08.93,0:00:10.90,sign,,0000,0000,0000,,"ALYSSA SLEIHUNT"
Dialogue: 0,0:00:12.57,0:00:13.94,sign,,0000,0000,0000,,"KLEN"
Dialogue: 0,0:00:13.94,0:00:16.70,sign,,0000,0000,0000,,"KLEN VATISS"
Dialogue: 0,0:02:14.30,0:02:16.14,sign,,0000,0000,0000,,EPISODE 2: DUNIA LAIN
Dialogue: 0,0:02:22.00,0:02:25.05,sign,,0000,0000,0000,,"LANG FEISS"
Dialogue: 0,0:04:14.35,0:04:15.70,sign,,0000,0000,0000,,"MIQUEL MENDES"
Dialogue: 0,0:04:15.70,0:04:17.75,sign,,0000,0000,0000,,"TEDDY SHAWN"
Dialogue: 0,0:04:31.15,0:04:32.04,sign,,0000,0000,0000,,"RHODE ROYES"
Dialogue: 0,0:04:32.04,0:04:34.25,sign,,0000,0000,0000,,MATTHEW BARNES
Dialogue: 0,0:07:42.95,0:07:45.82,sign,,0000,0000,0000,,"NATHAN FRANC"
Dialogue: 0,0:08:07.96,0:08:10.35,sign,,0000,0000,0000,,"MARY MERRYWEATHER"
Dialogue: 0,0:08:16.95,0:08:19.29,sign,,0000,0000,0000,,"ANDREW HWYP"
Dialogue: 0,0:00:05.15,0:00:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Salam kenal, semuanya.
Dialogue: 0,0:00:07.00,0:00:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dari Hiden, Al…
Dialogue: 0,0:00:08.93,0:00:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alyssa Sleihunt.
Dialogue: 0,0:00:11.47,0:00:12.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti dia.
Dialogue: 0,0:00:12.57,0:00:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dari Hiden.
Dialogue: 0,0:00:13.94,0:00:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klen Vatiss. Salam kenal.
Dialogue: 0,0:00:17.10,0:00:18.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:00:18.09,0:00:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini,\Nkalian adalah siswa kelas lima.
Dialogue: 0,0:00:21.10,0:00:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata selain aku,\Nada juga yang memiliki tanduk.
Dialogue: 0,0:00:24.19,0:00:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak perlu diberi perlakuan khusus\Nhanya karena mereka siswa pertukaran.
Dialogue: 0,0:00:28.19,0:00:29.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan saling berlatih.
Dialogue: 0,0:00:29.25,0:00:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berusahalah untuk meningkatkan\Nkemampuan kalian masing-masing.
Dialogue: 0,0:02:12.24,0:02:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Clevatess II
Dialogue: 0,0:02:16.15,0:02:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian para siswa pertukaran pasti\Nbaru pertama kali bertemu denganku.
Dialogue: 0,0:02:22.00,0:02:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku guru sihir, Lang Feiss.
Dialogue: 0,0:02:25.05,0:02:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah asisten baruku, Guru Shifonlitz.
Dialogue: 0,0:02:28.90,0:02:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan bertanggung jawab\Nuntuk demonstrasi praktik.
Dialogue: 0,0:02:31.60,0:02:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menguasai "ilmu sihir kristal"\Npaling menonjol saat ini
Dialogue: 0,0:02:36.20,0:02:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beserta mantra formula untuk latihan praktik.
Dialogue: 0,0:02:39.45,0:02:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tingkat adaptasi "ilmu sihir kristal"\Npada tubuh hanya beberapa persen,
Dialogue: 0,0:02:43.90,0:02:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga tidak cocok masuk kurikulum.
Dialogue: 0,0:02:47.05,0:02:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kalian akan mempelajari\Nsihir terbaru yang bisa dikuasai siapa saja,
Dialogue: 0,0:02:52.55,0:02:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"ilmu sihir pelafalan tongkat sihir".
Dialogue: 0,0:02:55.45,0:02:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tongkat sihir"?
Dialogue: 0,0:02:56.89,0:02:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bukan "lambang kutukan"\Nyang digunakan bocah itu.
Dialogue: 0,0:03:01.26,0:03:03.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mereka siswa pertukaran\Nyang bermasalah itu?
Dialogue: 0,0:03:04.16,0:03:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Lambang kutukan" adalah sihir tertinggi
Dialogue: 0,0:03:07.60,0:03:12.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hanya ahli "tongkat sihir"\Npilihan Dewa yang bisa memakainya.
Dialogue: 0,0:03:12.35,0:03:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian para pembuat onar tidak akan bisa\Nmencapainya hanya dalam dua tahun.
Dialogue: 0,0:03:16.49,0:03:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memulai pelajaran.
Dialogue: 0,0:03:18.20,0:03:19.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bagikan tongkat sihirnya.
Dialogue: 0,0:03:19.85,0:03:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:03:28.60,0:03:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran pertama kelas lima adalah sihir.
Dialogue: 0,0:03:32.15,0:03:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuda dari Surada dan gadis dari Orgg.
Dialogue: 0,0:03:35.25,0:03:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin tidak tahu tujuan asli\Ndari belajar di luar negeri kali ini.
Dialogue: 0,0:03:39.04,0:03:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya…
Dialogue: 0,0:03:40.65,0:03:42.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemuda Hiden itu.
Dialogue: 0,0:03:44.15,0:03:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Ibu Suri Toara\Nyang mempercayakan tugas penting kepadanya?
Dialogue: 0,0:03:48.05,0:03:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang satu lagi… Itu Pahlawan Alicia?
Dialogue: 0,0:03:50.90,0:03:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, mungkin hanya mirip dengannya.
Dialogue: 0,0:03:53.85,0:03:55.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja hal ini.
Dialogue: 0,0:03:55.49,0:03:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya bisa membawa pulang\Nsebanyak mungkin informasi berguna bagi Eslinn.
Dialogue: 0,0:04:00.40,0:04:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sudah mengirim Miquel\Nuntuk menyelidiki.
Dialogue: 0,0:04:02.75,0:04:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, hingga saat ini\Ndia masih belum menemukan celah apa pun.
Dialogue: 0,0:04:08.46,0:04:10.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, Guru Shawn.
Dialogue: 0,0:04:10.99,0:04:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kau lakukan di sini?
Dialogue: 0,0:04:13.50,0:04:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:04:14.35,0:04:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih belum terbiasa dengan lingkungan di sini.
Dialogue: 0,0:04:15.70,0:04:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tersesat.
Dialogue: 0,0:04:19.39,0:04:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sekolah ini\Npasti menyembunyikan rahasia.
Dialogue: 0,0:04:22.25,0:04:24.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru, Guru Barnes.
Dialogue: 0,0:04:25.45,0:04:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah selesai mengerjakannya.
Dialogue: 0,0:04:27.09,0:04:28.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:04:28.85,0:04:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jawabanmu benar.\NSilakan kembali ke tempat duduk.
Dialogue: 0,0:04:31.15,0:04:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:04:35.45,0:04:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu sebentar.
Dialogue: 0,0:04:38.35,0:04:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang yang merepotkan muncul bersamaan.
Dialogue: 0,0:04:41.50,0:04:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini adalah sang pahlawan.
Dialogue: 0,0:04:43.30,0:04:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun aku tidak mengerti\Nkenapa dia mengecil, tapi dia pasti pahlawan itu.
Dialogue: 0,0:04:47.35,0:04:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, orang ini.
Dialogue: 0,0:04:48.89,0:04:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti, pasti dia orang yang sangat berbahaya.
Dialogue: 0,0:04:51.80,0:04:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dengan membayangkan dia menatapku,
Dialogue: 0,0:04:53.05,0:04:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jantungku rasanya menciut seperti siput\Nyang ditaburi garam.
Dialogue: 0,0:04:55.80,0:04:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:04:57.15,0:05:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini? Apa aku harus kabur\Natau harus melapor? Namun, kepada siapa?
Dialogue: 0,0:05:00.35,0:05:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku datang atas perintah Yang Mulia Kaisar,\Naku belum diberi tahu siapa rekannya.
Dialogue: 0,0:05:03.90,0:05:06.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tujuanku memata-matai,\Naku tidak boleh ketahuan pihak sekolah, 'kan?
Dialogue: 0,0:05:06.30,0:05:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Guru, tongkat sihir.\N- Kepada siapa aku harus berbicara…
Dialogue: 0,0:05:08.45,0:05:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:05:12.94,0:05:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi keselamatanmu,\Nlebih baik jangan beri tahu siapa pun,
Dialogue: 0,0:05:15.35,0:05:16.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru.
Dialogue: 0,0:05:23.95,0:05:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali, ini tongkat sihir.
Dialogue: 0,0:05:26.25,0:05:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanyalah sebatang tongkat biasa.
Dialogue: 0,0:05:28.80,0:05:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai lupa.
Dialogue: 0,0:05:30.25,0:05:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu, di sekolah aku selalu\Ntidak punya tempat untuk lari.
Dialogue: 0,0:05:35.15,0:05:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah tongkat sihir.
Dialogue: 0,0:05:36.56,0:05:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di ujungnya ada manik bijih sihir\Nyang sudah diasah.
Dialogue: 0,0:05:39.94,0:05:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tongkat sihir" ini ibarat\Nalat pengeras suara.
Dialogue: 0,0:05:42.45,0:05:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manik bijih sihir ini bisa\Nmelengkapi mana penggunanya.
Dialogue: 0,0:05:44.85,0:05:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta kecocokan ilmu sihir\Nyang dibutuhkan untuk pelafalan.
Dialogue: 0,0:05:49.06,0:05:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, orang tanpa kecocokan\Nilmu sihir pun bisa menggunakannya.
Dialogue: 0,0:05:54.65,0:05:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:05:55.99,0:06:01.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa memakainya lebih sering\Ndan kekuatannya juga akan lebih hebat.
Dialogue: 0,0:06:01.14,0:06:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini sepenuhnya bergantung pada bakat.
Dialogue: 0,0:06:03.29,0:06:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa ditutupi dengan usaha atau teknik.
Dialogue: 0,0:06:07.20,0:06:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nmari kita mulai latihan praktik.
Dialogue: 0,0:06:08.85,0:06:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Shifonlitz, tolong bantuannya.
Dialogue: 0,0:06:11.60,0:06:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:06:12.25,0:06:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas hari ini adalah menyalakan lampu ini\Ntanpa membukanya,
Dialogue: 0,0:06:14.80,0:06:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan dengan menggunakan pelafalan.
Dialogue: 0,0:06:18.79,0:06:20.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatikan baik-baik, semuanya.
Dialogue: 0,0:06:20.54,0:06:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Mantra formula"-nya\Nadalah lingkaran sempurna.
Dialogue: 0,0:06:22.10,0:06:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata pelafalannya adalah "Fel".
Dialogue: 0,0:06:24.24,0:06:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan berhasil jika lingkarannya
Dialogue: 0,0:06:26.05,0:06:28.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak digambar dengan rapi\Natau pengucapannya salah.
Dialogue: 0,0:06:30.85,0:06:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:06:34.34,0:06:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah contoh sempurna\Ndari ilmu sihir pelafalan yang indah.
Dialogue: 0,0:06:37.65,0:06:38.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepuk tangan, semuanya.
Dialogue: 0,0:06:42.95,0:06:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya aku sudah berlatih sebelumnya.
Dialogue: 0,0:06:46.85,0:06:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ingin mencoba, silakan maju.
Dialogue: 0,0:06:49.35,0:06:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah dasar dari segalanya.
Dialogue: 0,0:06:51.70,0:06:55.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat, kalau ini saja tidak bisa,\Nkalian tidak akan bisa melangkah lebih jauh.
Dialogue: 0,0:06:55.04,0:06:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, pelayanku.
Dialogue: 0,0:06:56.95,0:06:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:06:58.00,0:07:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihat apakah orang sepertimu\Nyang kecocokan ilmu sihirnya nol
Dialogue: 0,0:07:00.35,0:07:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar bisa menggunakan sihir\Ndengan tongkat ini.
Dialogue: 0,0:07:05.75,0:07:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:07:07.35,0:07:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sepertinya siswa pertukaran mau mencoba.
Dialogue: 0,0:07:09.40,0:07:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sungguh berani.
Dialogue: 0,0:07:10.69,0:07:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah orang Hiden melakukannya?
Dialogue: 0,0:07:12.10,0:07:14.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, dia khusus datang ke sini\Nuntuk belajar setelah perang terjadi.
Dialogue: 0,0:07:14.60,0:07:16.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia cukup percaya diri.
Dialogue: 0,0:07:16.10,0:07:18.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi kehormatan warga Hiden,
Dialogue: 0,0:07:18.25,0:07:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak boleh mempermalukan diri di sini.
Dialogue: 0,0:07:20.40,0:07:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat.
Dialogue: 0,0:07:22.59,0:07:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku hanya bisa percaya\Npada tongkat sihir ini.
Dialogue: 0,0:07:27.04,0:07:27.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:07:30.75,0:07:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sama sekali tidak bisa.\N- "Fel".
Dialogue: 0,0:07:32.80,0:07:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Lebih tepatnya, aku tidak rasakan apa pun\N- Zilberto.
Dialogue: 0,0:07:33.95,0:07:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dari tongkat sihirnya.\N- Lulus. Selanjutnya.
Dialogue: 0,0:07:36.05,0:07:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak bisa dijadikan referensi.\N- Fel.
Dialogue: 0,0:07:39.30,0:07:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sebenarnya\N- Fel.
Dialogue: 0,0:07:40.34,0:07:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- ini memang sulit.\N- Lingkarannya tidak bulat sempurna.
Dialogue: 0,0:07:41.74,0:07:42.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau…\N- Forme.
Dialogue: 0,0:07:42.95,0:07:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Nathan Franc.
Dialogue: 0,0:07:46.25,0:07:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa tidak apa-apa, Nathan?\N- Selanjutnya.
Dialogue: 0,0:07:48.05,0:07:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bersikap ramah sekali, menghampiri kami\Npara siswa pertukaran untuk bicara.
Dialogue: 0,0:07:51.59,0:07:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, sampai tadi aku masih waspada.
Dialogue: 0,0:07:54.94,0:07:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, setelah tahu kau juga\Norang seperti aku, aku jadi lega.
Dialogue: 0,0:07:57.65,0:07:58.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Seperti kau"?
Dialogue: 0,0:07:58.85,0:08:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena di sini, semuanya ditentukan\Noleh tinggi rendahnya kemampuan sihir.
Dialogue: 0,0:08:02.10,0:08:03.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:08:04.26,0:08:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:08:07.96,0:08:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya yang tenang dan stabil.
Dialogue: 0,0:08:10.35,0:08:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mary Merryweather, lulus.
Dialogue: 0,0:08:13.19,0:08:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:08:16.95,0:08:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andrew Hwyp juga lulus.
Dialogue: 0,0:08:19.29,0:08:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cahaya yang menarik, seolah sedang menari.
Dialogue: 0,0:08:21.80,0:08:24.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menduduki\Nperingkat kedua dan ketiga di angkatan.
Dialogue: 0,0:08:24.89,0:08:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang paling hebat tentu saja…
Dialogue: 0,0:08:27.30,0:08:28.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:08:34.95,0:08:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan tanpa menggunakan lambang kutukan,\Ndia tetap yang terkuat.
Dialogue: 0,0:08:38.15,0:08:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun membuat keributan tadi pagi,\Ndia sama sekali tidak dihukum.
Dialogue: 0,0:08:41.35,0:08:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena dia spesial.
Dialogue: 0,0:08:43.65,0:08:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas di sini hampir sepenuhnya\Nditentukan oleh kekuatan sihir.
Dialogue: 0,0:08:48.05,0:08:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ray Forester, lulus.
Dialogue: 0,0:08:50.05,0:08:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:08:51.65,0:08:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini sungguh hebat.
Dialogue: 0,0:08:53.95,0:08:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam hal bakat sihir,\Ndia mungkin melampaui Tuan Maynard.
Dialogue: 0,0:08:57.09,0:09:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, prinsip sekolah ini adalah\Nmenciptakan masa depan dunia melalui sihir.
Dialogue: 0,0:09:03.00,0:09:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menjadi seperti dia.
Dialogue: 0,0:09:04.95,0:09:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku hanya bisa terus di kelas bawah.
Dialogue: 0,0:09:07.05,0:09:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencobanya.
Dialogue: 0,0:09:08.30,0:09:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun kemungkinan besar akan gagal lagi.
Dialogue: 0,0:09:11.09,0:09:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak ingin selamanya\Ndi kelas bawah…
Dialogue: 0,0:09:13.90,0:09:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minggir, sampah.
Dialogue: 0,0:09:15.05,0:09:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang antre di belakang bocah itu.
Dialogue: 0,0:09:18.70,0:09:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel"!
Dialogue: 0,0:09:21.14,0:09:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:09:21.94,0:09:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:09:22.44,0:09:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lulus, bodoh!
Dialogue: 0,0:09:24.25,0:09:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelafalan bukan makin keras makin baik
Dialogue: 0,0:09:26.35,0:09:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memang seharusnya\Ntidak boleh tumpang tindih.
Dialogue: 0,0:09:28.65,0:09:31.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya dua mana yang saling bertabrakan.
Dialogue: 0,0:09:31.80,0:09:33.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa dibilang hasil yang paling buruk.
Dialogue: 0,0:09:35.30,0:09:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini,\Nkita tidak bisa melanjutkan latihan praktik.
Dialogue: 0,0:09:38.26,0:09:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sisa waktunya kita kembali\Nke kelas untuk belajar.
Dialogue: 0,0:09:42.99,0:09:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guru Shifonlitz,\Ntolong ambil kembali tongkat sihirnya.
Dialogue: 0,0:09:45.95,0:09:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:46.60,0:09:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan si Kembar itu?
Dialogue: 0,0:09:48.60,0:09:50.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka orang Eslinn saja\Nsudah cukup bikin kesal.
Dialogue: 0,0:09:50.76,0:09:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:09:51.60,0:09:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pulang sana.
Dialogue: 0,0:09:53.04,0:09:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mencobanya.
Dialogue: 0,0:09:55.65,0:09:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:09:56.75,0:09:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka itu pasti karena kalau sendirian,\Nkemampuannya hanya keluar setengah
Dialogue: 0,0:09:58.44,0:09:59.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya mereka\Nharus bekerja sama berdua, 'kan?
Dialogue: 0,0:10:00.75,0:10:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, siapa yang barusan bicara?\NKeluar kau!
Dialogue: 0,0:10:02.84,0:10:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang bilang kami setengah matang?
Dialogue: 0,0:10:06.29,0:10:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau?
Dialogue: 0,0:10:06.90,0:10:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}B-Bukan aku.
Dialogue: 0,0:10:08.15,0:10:09.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kalian belum puas bertingkah?
Dialogue: 0,0:10:10.35,0:10:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran ini bukan permainan.
Dialogue: 0,0:10:12.25,0:10:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukai ketenangan.
Dialogue: 0,0:10:14.89,0:10:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena terlalu berisik hanya\Nakan merusak telinga dan otak.
Dialogue: 0,0:10:19.35,0:10:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuhabisi kalian berdua sekaligus.
Dialogue: 0,0:10:27.30,0:10:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga kau, sebagai murid Solsein.
Dialogue: 0,0:10:29.55,0:10:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan takut pada orang seperti itu.
Dialogue: 0,0:10:31.79,0:10:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar memalukan.
Dialogue: 0,0:10:36.10,0:10:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar musibah\Nyang tidak terduga, ya, Nathan.
Dialogue: 0,0:10:39.65,0:10:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, memang ini salahku.\NAku terlalu memalukan.
Dialogue: 0,0:10:45.70,0:10:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah anak itu tidak apa-apa?
Dialogue: 0,0:10:47.79,0:10:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:48.75,0:10:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah penyakit pahlawanmu kumat lagi?
Dialogue: 0,0:10:50.20,0:10:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu penyakit pahlawan?
Dialogue: 0,0:10:52.45,0:10:56.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyakit di mana kau tidak bisa\Nmembiarkan orang lemah begitu saja.
Dialogue: 0,0:10:56.96,0:11:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak… sebagai manusia, ini sangat normal.
Dialogue: 0,0:11:00.25,0:11:02.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu tentang\Nhal normal bagi manusia.
Dialogue: 0,0:11:02.34,0:11:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, kalau benar kelas dibedakan\Nberdasarkan kekuatan sihir,
Dialogue: 0,0:11:06.65,0:11:08.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka kau termasuk kelas bawah.
Dialogue: 0,0:11:08.70,0:11:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada khawatirkan dia,\Nlebih baik khawatirkan dirimu sendiri dulu.
Dialogue: 0,0:11:11.45,0:11:13.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu bagaimana denganmu?
Dialogue: 0,0:11:13.30,0:11:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau bisa menggunakan sihir?
Dialogue: 0,0:11:16.84,0:11:17.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:11:19.74,0:11:20.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:11:22.20,0:11:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku tidak cocok dengan benda\Nyang disebut "tongkat sihir" ini.
Dialogue: 0,0:11:26.50,0:11:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meledak?
Dialogue: 0,0:11:29.36,0:11:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan?\NBukannya kau sama buruknya?
Dialogue: 0,0:11:31.94,0:11:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sama sepertiku, kelas bawah.
Dialogue: 0,0:11:34.40,0:11:38.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku harus memahami\Nprinsip kerja sihir dulu.
Dialogue: 0,0:11:38.95,0:11:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, cepat atau lambat\Naku harus mengajari Luna sihir ini.
Dialogue: 0,0:11:42.39,0:11:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun lemah,\Ndi sini ada aura yang sama seperti Toah.
Dialogue: 0,0:11:47.19,0:11:50.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sihir yang mereka gunakan juga\Nmemiliki aura itu.
Dialogue: 0,0:11:53.05,0:11:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika jawabannya tersembunyi\Ndi laboratorium rahasia Dorel
Dialogue: 0,0:11:57.30,0:11:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka kita hanya perlu menemukannya.
Dialogue: 0,0:12:00.90,0:12:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sudah kudengar.
Dialogue: 0,0:12:07.00,0:12:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sama sekali tidak mewaspadaiku.\NSebenarnya…
Dialogue: 0,0:12:42.46,0:12:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai domba yang tersesat.
Dialogue: 0,0:12:45.34,0:12:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdoalah kepada Tuhan.
Dialogue: 0,0:12:48.45,0:12:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari.
Dialogue: 0,0:12:50.30,0:12:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akui semua dosamu.
Dialogue: 0,0:12:57.35,0:12:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian.
Dialogue: 0,0:12:58.50,0:13:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelajaran hari ini sampai di sini.
Dialogue: 0,0:13:00.84,0:13:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian harus benar-benar mengulang\Ndasar ilmu sihir pelafalan.
Dialogue: 0,0:13:03.15,0:13:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu cara bernapas\Ndan pengucapan yang benar.
Dialogue: 0,0:13:09.45,0:13:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya, hari ini tidak ada latihan praktik.
Dialogue: 0,0:13:12.25,0:13:13.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membosankan.
Dialogue: 0,0:13:14.65,0:13:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata Nathan memang tidak datang, ya?
Dialogue: 0,0:13:19.70,0:13:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan kau bilang "ternyata", 'kan?
Dialogue: 0,0:13:23.15,0:13:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kau…
Dialogue: 0,0:13:25.70,0:13:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Mary Merryweather.
Dialogue: 0,0:13:27.75,0:13:30.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-teman sekelas memanggilku Merry Merry.
Dialogue: 0,0:13:30.29,0:13:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah ketua kelas.
Dialogue: 0,0:13:32.65,0:13:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memiliki kewajiban untuk memantau\Nsetiap gerak-gerik teman sekelas.
Dialogue: 0,0:13:35.60,0:13:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga bertugas mengawasi pergerakan kalian,\Norang-orang asing dari luar.
Dialogue: 0,0:13:38.15,0:13:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti berat untukmu.
Dialogue: 0,0:13:40.60,0:13:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai Nathan Franc\Nyang absen tanpa alasan.
Dialogue: 0,0:13:43.10,0:13:45.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tahu sesuatu,\Ncepat katakan kepadaku.
Dialogue: 0,0:13:45.89,0:13:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang dia orang kelas bawah\Ndan mulai berpikiran buntu.
Dialogue: 0,0:13:50.05,0:13:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi aku juga khawatir.
Dialogue: 0,0:13:53.44,0:13:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah tadi perkataanku\Nterlalu kasar padanya?
Dialogue: 0,0:13:55.75,0:13:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mencarinya untuk\Nmemastikan langsung.
Dialogue: 0,0:13:58.10,0:13:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, aku juga ikut.
Dialogue: 0,0:13:59.76,0:14:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau harus ikut?
Dialogue: 0,0:14:00.95,0:14:02.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahnya?
Dialogue: 0,0:14:02.25,0:14:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita tinggal di asrama yang sama.
Dialogue: 0,0:14:03.50,0:14:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tinggal di asrama yang sama,
Dialogue: 0,0:14:04.70,0:14:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga tidak berniat bergaul\Ndengan orang terbawah sepertimu.
Dialogue: 0,0:14:07.90,0:14:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu.
Dialogue: 0,0:14:09.50,0:14:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sekarang juga teman sekelas di kelas ini,
Dialogue: 0,0:14:12.30,0:14:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua Kelas.
Dialogue: 0,0:14:13.05,0:14:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik sekali.
Dialogue: 0,0:14:15.84,0:14:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah pergi.
Dialogue: 0,0:14:18.74,0:14:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:14:19.60,0:14:21.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kita bertiga pulang bersama?
Dialogue: 0,0:14:21.85,0:14:23.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kita masih belum\Nterlalu akrab satu sama lain.
Dialogue: 0,0:14:23.90,0:14:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju.
Dialogue: 0,0:14:25.60,0:14:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:14:30.15,0:14:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah di sini?
Dialogue: 0,0:14:32.00,0:14:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nathan. Nathan Franc.
Dialogue: 0,0:14:34.19,0:14:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau ada di dalam, tolong sahut.
Dialogue: 0,0:14:37.15,0:14:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia tidak ada?
Dialogue: 0,0:14:38.00,0:14:39.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu sebentar.
Dialogue: 0,0:14:39.45,0:14:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bau darah.
Dialogue: 0,0:14:43.90,0:14:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah?
Dialogue: 0,0:14:44.90,0:14:46.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan darah Nathan?
Dialogue: 0,0:14:46.45,0:14:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:14:47.65,0:14:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah darah hewan.
Dialogue: 0,0:14:49.99,0:14:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari jumlah darahnya,\Nsepertinya bukan hanya satu atau dua ekor.
Dialogue: 0,0:14:53.85,0:14:55.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Nathan yang melakukannya?
Dialogue: 0,0:14:56.00,0:14:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak terlihat seperti\Norang yang bisa melakukan ini.
Dialogue: 0,0:15:01.45,0:15:04.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bulu binatang yang lebih besar.
Dialogue: 0,0:15:04.90,0:15:07.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan Nathan diserang cukup tinggi.
Dialogue: 0,0:15:07.35,0:15:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus cepat memberi tahu guru…
Dialogue: 0,0:15:11.55,0:15:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, ini lantai dua.
Dialogue: 0,0:15:16.05,0:15:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengannya?
Dialogue: 0,0:15:17.39,0:15:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kemampuan sihirnya sangat payah.
Dialogue: 0,0:15:33.35,0:15:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku…
Dialogue: 0,0:15:35.34,0:15:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini… apa?
Dialogue: 0,0:15:38.60,0:15:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambang kutukan?
Dialogue: 0,0:15:39.80,0:15:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambang kutukanku mana?
Dialogue: 0,0:15:43.00,0:15:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau menginginkan "lambang kutukan",\Ncobalah ingat kembali.
Dialogue: 0,0:15:46.60,0:15:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat memori tentang Toah
Dialogue: 0,0:15:48.44,0:15:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta hasratmu.
Dialogue: 0,0:15:50.65,0:15:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasratku?
Dialogue: 0,0:15:54.69,0:15:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau lari ke mana?
Dialogue: 0,0:15:57.95,0:16:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau menyerang…
Dialogue: 0,0:16:00.64,0:16:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluar! Akan kubunuh kau!
Dialogue: 0,0:16:03.09,0:16:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menemukan dan membunuhmu.
Dialogue: 0,0:16:07.20,0:16:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkanlah dirimu sepenuhnya, Nathan Franc.
Dialogue: 0,0:16:10.79,0:16:12.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan dirimu pada kekuatan Toah.
Dialogue: 0,0:16:24.90,0:16:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Fel".
Dialogue: 0,0:16:28.65,0:16:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat, 'kan?
Dialogue: 0,0:16:29.56,0:16:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kekuatan terkuat\Ndari ilmu sihir ramuan.
Dialogue: 0,0:16:36.34,0:16:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk ini…
Dialogue: 0,0:16:37.65,0:16:39.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah api tidak mempan padanya?
Dialogue: 0,0:16:44.65,0:16:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:16:46.15,0:16:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Angin kencang".
Dialogue: 0,0:16:49.26,0:16:51.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan harap kau bisa melukaiku,\Nmonyet besar.
Dialogue: 0,0:16:55.75,0:16:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu keterlaluan.
Dialogue: 0,0:16:57.05,0:16:58.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon, kau tidak apa-apa?
Dialogue: 0,0:16:58.26,0:17:00.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.\NTygel, bagaimana denganmu?
Dialogue: 0,0:17:00.25,0:17:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka kecil ini bukan apa-apa.
Dialogue: 0,0:17:03.09,0:17:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak masalah meski murahan,\Nasalkan ada pedang.
Dialogue: 0,0:17:09.95,0:17:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Klen.
Dialogue: 0,0:17:11.00,0:17:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu kau pasti sedang melihat.
Dialogue: 0,0:17:13.20,0:17:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat beri aku pedang, pedangku!
Dialogue: 0,0:17:15.96,0:17:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:17:17.20,0:17:18.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Klen!
Dialogue: 0,0:17:19.44,0:17:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia tidak mendengar suaraku?
Dialogue: 0,0:17:26.20,0:17:27.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cepat menjauh.
Dialogue: 0,0:17:27.64,0:17:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan ganggu aku".
Dialogue: 0,0:17:31.09,0:17:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, kena serangan dari depan.
Dialogue: 0,0:17:33.30,0:17:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Tygel.
Dialogue: 0,0:17:35.15,0:17:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa mendengar apa-apa.
Dialogue: 0,0:17:37.30,0:17:39.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan itu, makhluk ini…
Dialogue: 0,0:17:39.70,0:17:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi sepertinya dia bilang\N"Jangan ganggu aku".
Dialogue: 0,0:17:42.09,0:17:44.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Minggir".
Dialogue: 0,0:17:44.55,0:17:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diserang lagi.
Dialogue: 0,0:17:45.65,0:17:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Minggir"?
Dialogue: 0,0:17:47.00,0:17:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini suara monyet besar ini?
Dialogue: 0,0:17:55.90,0:17:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau tidak bertindak, kau akan terbunuh.
Dialogue: 0,0:17:57.84,0:17:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nathan Franc.
Dialogue: 0,0:17:59.50,0:18:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau ingin mendapatkan kekuatan,
Dialogue: 0,0:18:01.25,0:18:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bantai semuanya.
Dialogue: 0,0:18:04.55,0:18:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buktikan tekadmu.
Dialogue: 0,0:18:10.40,0:18:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Datang lagi.\N- Cepat menghindar.
Dialogue: 0,0:18:21.15,0:18:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:18:22.15,0:18:23.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tolong aku".
Dialogue: 0,0:18:24.49,0:18:26.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku rasanya mau pecah.
Dialogue: 0,0:18:26.85,0:18:29.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, serangan barusan\Nmemberikanku kepastian.
Dialogue: 0,0:18:29.50,0:18:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini hanya bisa terdengar\Njika berada tepat di pusat aumannya.
Dialogue: 0,0:18:32.64,0:18:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini tadi bilang,
Dialogue: 0,0:18:34.55,0:18:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tolong aku".
Dialogue: 0,0:18:36.59,0:18:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Badai Cermin.
Dialogue: 0,0:18:38.75,0:18:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembalikan.
Dialogue: 0,0:18:47.95,0:18:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu sihir si kembar?
Dialogue: 0,0:18:49.40,0:18:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita kabur saat dia sedang kacau.
Dialogue: 0,0:18:52.85,0:18:53.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau bodoh?
Dialogue: 0,0:18:55.19,0:18:57.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, aku ini pahlawan.
Dialogue: 0,0:18:57.39,0:18:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun tanpa pedang…
Dialogue: 0,0:19:03.19,0:19:05.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya diri dengan kekuatan kakiku.
Dialogue: 0,0:19:05.60,0:19:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk jurusnya,
Dialogue: 0,0:19:06.76,0:19:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan meminjam punya orang itu.
Dialogue: 0,0:19:21.25,0:19:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan-jangan kau Nathan?
Dialogue: 0,0:19:24.35,0:19:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Nathan? Nathan.
Dialogue: 0,0:19:29.15,0:19:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kurang terobsesi terhadap hasratnya\Ndan tidak punya tekad untuk mewujudkannya.
Dialogue: 0,0:19:34.70,0:19:37.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya,\Ndia tidak akan pernah bisa menggapai Toah.
Dialogue: 0,0:19:37.10,0:19:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak lulus.
Dialogue: 0,0:19:39.66,0:19:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambang kutukan yang cocok\Nuntuk orang sepertimu adalah…
Dialogue: 0,0:19:43.05,0:19:44.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merry…
Dialogue: 0,0:19:45.15,0:19:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merry Me…
Dialogue: 0,0:19:49.05,0:19:50.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Auranya berubah.
Dialogue: 0,0:19:51.00,0:19:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aura ini benar-benar\Nberasal dari monster sihir.
Dialogue: 0,0:19:54.65,0:19:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:20:07.20,0:20:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Jangan mendekat!
Dialogue: 0,0:20:14.90,0:20:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia malah berjalan mendekat dengan tenang.
Dialogue: 0,0:20:16.55,0:20:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan wanita itu?
Dialogue: 0,0:20:17.94,0:20:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling benci keributan.
Dialogue: 0,0:20:21.05,0:20:22.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tidak bisa diam,
Dialogue: 0,0:20:22.70,0:20:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lenyaplah dari dunia ini.
Dialogue: 0,0:20:26.25,0:20:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Lort".
Dialogue: 0,0:20:31.49,0:20:32.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:20:34.96,0:20:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambang kutukanku "Kejernihan Air Kaca".
Dialogue: 0,0:20:37.79,0:20:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan memaksa apa pun\Nyang menyentuh penghalangnya
Dialogue: 0,0:20:39.90,0:20:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berubah menjadi kondisi tenang.
Dialogue: 0,0:20:44.09,0:20:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika diperlebar dan ditipiskan,
Dialogue: 0,0:20:45.60,0:20:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan membentuk penghalang\Nyang memblokir suara dan angin.
Dialogue: 0,0:20:48.35,0:20:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisi di dalam\Ntidak akan tersampaikan ke luar.
Dialogue: 0,0:20:50.90,0:20:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gangguan dari luar juga\Ntidak bisa masuk ke dalam.
Dialogue: 0,0:20:54.09,0:20:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inikah alasannya kenapa Klen\Ntidak bisa mendengar suaraku?
Dialogue: 0,0:20:57.45,0:20:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasan dia begitu kesakitan
Dialogue: 0,0:20:59.50,0:21:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena setelah kukompres\Npenghalang lambang kutukan,
Dialogue: 0,0:21:01.96,0:21:04.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kupaksa masukkan ke dalam jantungnya.
Dialogue: 0,0:21:04.65,0:21:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makin dia bersemangat,\Nrasa sakit itu akan makin kuat.
Dialogue: 0,0:21:16.85,0:21:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh kejam.
Dialogue: 0,0:21:21.90,0:21:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nathan yang malang.
Dialogue: 0,0:21:23.89,0:21:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lupakan saja ucapanku.
Dialogue: 0,0:21:26.05,0:21:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya kau tahu diri,
Dialogue: 0,0:21:28.16,0:21:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka kau tidak akan berakhir seperti ini.
Dialogue: 0,0:21:30.50,0:21:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau sudah menyadari sejak awal\Nkalau monster sihir ini adalah Nathan?
Dialogue: 0,0:21:33.95,0:21:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kesempatan bagus. Perhatikan baik-baik.
Dialogue: 0,0:21:36.75,0:21:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah akhir dari pecundang tidak tahu diri\Nyang nekat menantang lambang kutukan.
Dialogue: 0,0:21:41.80,0:21:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan kehilangan semua ingatannya\Ndalam beberapa tahun terakhir.
Dialogue: 0,0:21:44.55,0:21:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecocokan ilmu sihirnya yang memang\Nsudah sedikit akan menjadi nol.
Dialogue: 0,0:21:48.55,0:21:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nathan bisa kembali ke wujud manusia\Nsudah cukup baik.
Dialogue: 0,0:21:52.90,0:21:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia dibasmi dalam wujud monster sihir,
Dialogue: 0,0:21:55.00,0:21:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka dunia akan menganggap dia\Ndibunuh oleh monster sihir itu,
Dialogue: 0,0:21:58.20,0:22:00.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu tidak ada yang akan\Nmencari tahu kebenarannya.
Dialogue: 0,0:22:01.95,0:22:03.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, selamat datang di sekolah ini.
Dialogue: 0,0:22:03.86,0:22:06.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi mereka yang berambisi mendalami sihir,
Dialogue: 0,0:22:06.94,0:22:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beginilah wujud asli sekolah ini.
