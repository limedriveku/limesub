Dialogue: 0,0:00:41.81,0:00:43.02,sign,,0000,0000,0000,,DILARANG MELEWATI GARIS BATAS
Dialogue: 0,0:03:16.09,0:03:21.60,sign,,0000,0000,0000,,KAIJU DARA CARAMELISE
Dialogue: 0,0:04:36.96,0:04:40.47,sign,,0000,0000,0000,,EPISODE 3:\NAKHIR PEKAN BERKILAU ~MENUJU DUNIA IMPIAN~
Dialogue: 0,0:07:00.36,0:07:01.73,sign,,0000,0000,0000,,DI DEPAN STASIUN PASTI RAMAI, KITA KETEMUAN\NDI DEPAN AIR MANCUR GEBANG DESTINY LAND.
Dialogue: 0,0:07:01.73,0:07:02.69,sign,,0000,0000,0000,,OKE.\NKALAU KAMU TERSESAT, HUBUNGI AKU, YA.
Dialogue: 0,0:07:10.16,0:07:10.87,sign,,0000,0000,0000,,BUKU PANDUAN UNTUK HARI H UNTUKKU SENDIRI
Dialogue: 0,0:09:02.61,0:09:03.40,sign,,0000,0000,0000,,KAIJU AGUNG HARUGON\NHARAP NANTIKAN, SEGERA TAYANG
Dialogue: 0,0:16:17.29,0:16:19.37,sign,,0000,0000,0000,,KAMU ADA DI MANA?
Dialogue: 0,0:16:37.23,0:16:37.73,sign,,0000,0000,0000,,KUROTAN, KAMU SUDAH MAU PULANG?
Dialogue: 0,0:16:37.73,0:16:39.19,sign,,0000,0000,0000,,IBU JEMPUT, YA?
Dialogue: 0,0:00:01.85,0:00:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk raksasa yang kembali\Nmuncul di pusat kota
Dialogue: 0,0:00:04.57,0:00:09.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}merusak sebagian bangunan SMA Ginjuji\Ndan masuk ke Sungai Toyosu.
Dialogue: 0,0:00:09.41,0:00:11.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:00:11.53,0:00:14.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harugon!
Dialogue: 0,0:00:19.62,0:00:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kembali ke sekolah.
Dialogue: 0,0:00:23.96,0:00:24.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:00:24.75,0:00:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak boleh bugil juga kali!
Dialogue: 0,0:00:38.31,0:00:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku harus berpakaian seperti ini?
Dialogue: 0,0:00:46.57,0:00:48.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar menakutkan!
Dialogue: 0,0:00:48.24,0:00:49.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kami bakal mati!
Dialogue: 0,0:00:55.37,0:00:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, betul.\NTapi, aku juga kurang mengerti...
Dialogue: 0,0:01:10.34,0:01:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang,\Ntidak ada orang di dalam...
Dialogue: 0,0:01:12.30,0:01:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin!
Dialogue: 0,0:01:13.97,0:01:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini!
Dialogue: 0,0:01:16.85,0:01:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi!
Dialogue: 0,0:01:21.14,0:01:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak terluka?\NEnggak apa-apa?
Dialogue: 0,0:01:23.81,0:01:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, iya.
Dialogue: 0,0:01:25.36,0:01:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah keluar sebelum kaiju itu muncul.
Dialogue: 0,0:01:28.19,0:01:31.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok dia muncul di tempat seperti itu, ya?
Dialogue: 0,0:01:31.11,0:01:32.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Entahlah.
Dialogue: 0,0:01:32.78,0:01:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya,
Dialogue: 0,0:01:35.53,0:01:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bertatap mata dengan kaiju itu.
Dialogue: 0,0:01:39.62,0:01:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya juga pernah.
Dialogue: 0,0:01:41.25,0:01:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bertatap mata selama lima detik.
Dialogue: 0,0:01:44.58,0:01:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Perasaanmu saja kali!
Dialogue: 0,0:01:48.55,0:01:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kok kamu bisa tetap tenang?
Dialogue: 0,0:01:52.51,0:01:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya makhluk itu seram?
Dialogue: 0,0:01:54.72,0:01:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tubuhnya besar.
Dialogue: 0,0:01:56.68,0:01:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buruk rupa pula.
Dialogue: 0,0:02:11.44,0:02:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Indah, kok.
Dialogue: 0,0:02:27.38,0:02:28.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunga sakura ini.
Dialogue: 0,0:02:32.22,0:02:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh, sakuranya, toh!
Dialogue: 0,0:02:34.59,0:02:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sakuranya indah!
Dialogue: 0,0:02:36.09,0:02:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ada dango!
Dialogue: 0,0:02:39.68,0:02:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakura di malam hari\Npunya kesan tersendiri.
Dialogue: 0,0:02:49.69,0:02:52.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah tidak hancur terinjak.
Dialogue: 0,0:02:56.57,0:02:58.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan apa-apa.
Dialogue: 0,0:02:58.57,0:03:00.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harugon!
Dialogue: 0,0:03:00.66,0:03:04.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan wujudmu sekali lagi!
Dialogue: 0,0:04:42.55,0:04:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuroe, bagaimana ukurannya?
Dialogue: 0,0:04:45.64,0:04:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, aku memang ingin meminjam baju...
Dialogue: 0,0:04:50.73,0:04:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi maksudku baju buat kencan!
Dialogue: 0,0:04:52.86,0:04:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, ternyata memang cocok.
Dialogue: 0,0:04:57.61,0:05:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kecewa begitu, dong.
Dialogue: 0,0:05:00.78,0:05:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada di sini, kok.
Dialogue: 0,0:05:03.28,0:05:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah baju yang cocok\Nbuat kencan pertamamu dengan Minami!
Dialogue: 0,0:05:07.04,0:05:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya aku memang tidak cocok\Npakai baju begini.
Dialogue: 0,0:05:10.25,0:05:12.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget, kok.
Dialogue: 0,0:05:12.63,0:05:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak makhluk berbentuk cakram.
Dialogue: 0,0:05:14.63,0:05:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kibas, kibas.\N- Itu pujian?
Dialogue: 0,0:05:17.76,0:05:22.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kemunculan kedua kalinya\Nmembuatku terkejut.
Dialogue: 0,0:05:22.30,0:05:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuanmu.
Dialogue: 0,0:05:24.93,0:05:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dadah.
Dialogue: 0,0:05:29.10,0:05:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Akaishi!\NApa kamu luang di hari Minggu?
Dialogue: 0,0:05:32.69,0:05:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:33.56,0:05:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke taman hiburan?\NKe Tokyo Destiny Land.
Dialogue: 0,0:05:36.52,0:05:38.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taman hiburan?
Dialogue: 0,0:05:38.73,0:05:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, aku dapat\Nsepasang tiket dari undian.
Dialogue: 0,0:05:42.70,0:05:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bingung harus pergi sama siapa.
Dialogue: 0,0:05:45.99,0:05:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini, aku ingin serius mengajakmu.
Dialogue: 0,0:05:51.91,0:05:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kalian jadi mesra\Ndi balik layar.
Dialogue: 0,0:05:56.25,0:05:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:05:58.17,0:05:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak!
Dialogue: 0,0:05:59.34,0:06:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma gugup.
Dialogue: 0,0:06:03.30,0:06:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kencan pertama di taman hiburan?\NDia pasti sangat serius.
Dialogue: 0,0:06:07.64,0:06:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu enggak mungkin.
Dialogue: 0,0:06:09.27,0:06:14.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin dia memilihku\Ndari sekian banyak gadis.
Dialogue: 0,0:06:14.23,0:06:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu orangnya hati-hati banget, ya.
Dialogue: 0,0:06:18.07,0:06:21.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga rasa gugupmu luntur\Ndi kencan esok hari.
Dialogue: 0,0:06:22.53,0:06:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:06:25.43,0:06:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:06:26.49,0:06:29.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}gaya rambut apa ini?
Dialogue: 0,0:06:30.29,0:06:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepang dua.
Dialogue: 0,0:06:40.50,0:06:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurotan, pakaianmu imut banget.
Dialogue: 0,0:06:44.01,0:06:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke mana?
Dialogue: 0,0:06:45.01,0:06:48.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Main bareng teman.\NKayaknya aku pulang telat.
Dialogue: 0,0:06:48.72,0:06:51.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Yakin aman?
Dialogue: 0,0:06:51.39,0:06:53.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aman.
Dialogue: 0,0:06:53.68,0:06:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berangkat.
Dialogue: 0,0:06:55.27,0:06:58.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati di jalan.
Dialogue: 0,0:07:02.69,0:07:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, aku jadi mual karena gugup.
Dialogue: 0,0:07:05.66,0:07:07.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman, tenanglah.
Dialogue: 0,0:07:07.99,0:07:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku punya ini.
Dialogue: 0,0:07:10.87,0:07:14.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bikin strategi\Nbiar enggak jadi kaiju!
Dialogue: 0,0:07:14.21,0:07:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah hafal tempat sembunyi\Nkalau gejalanya kambuh.
Dialogue: 0,0:07:17.58,0:07:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Solusi menunggu wahana pun sudah ada!
Dialogue: 0,0:07:19.54,0:07:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti berhasil!
Dialogue: 0,0:07:21.80,0:07:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung sudah diajak Minami,
Dialogue: 0,0:07:24.22,0:07:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku enggak mau menyerah begitu saja!
Dialogue: 0,0:07:28.80,0:07:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat orang itu.
Dialogue: 0,0:07:30.55,0:07:32.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren banget!
Dialogue: 0,0:07:39.73,0:07:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, itu Minami Arata?
Dialogue: 0,0:07:43.32,0:07:46.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Me-Menyilaukan sekali!
Dialogue: 0,0:07:46.11,0:07:47.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa karena pakai baju bebas?
Dialogue: 0,0:07:47.53,0:07:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana ini?\NAku enggak berani mendekatinya.
Dialogue: 0,0:07:53.74,0:07:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cis!
Dialogue: 0,0:07:56.83,0:07:58.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi!
Dialogue: 0,0:07:58.04,0:08:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dia datang!
Dialogue: 0,0:08:01.63,0:08:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah datang?\NMaaf, aku enggak sadar.
Dialogue: 0,0:08:04.51,0:08:06.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga sama, kok.
Dialogue: 0,0:08:06.67,0:08:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gayamu kayak berbeda hari ini.
Dialogue: 0,0:08:09.68,0:08:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?\NKayaknya sama saja, kok.
Dialogue: 0,0:08:13.22,0:08:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bohong!
Dialogue: 0,0:08:15.35,0:08:17.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cukup niat dandan, lo!
Dialogue: 0,0:08:17.44,0:08:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai bangun pagi dan pergi ke salon.
Dialogue: 0,0:08:19.60,0:08:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju ini pun hasil diskusi dua jam\Nsama pegawai toko.
Dialogue: 0,0:08:23.27,0:08:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh?
Dialogue: 0,0:08:24.90,0:08:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja "aura pemainnya" keluar.
Dialogue: 0,0:08:27.53,0:08:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sedikit senang.
Dialogue: 0,0:08:29.16,0:08:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah aku niat dandan.
Dialogue: 0,0:08:31.53,0:08:34.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar gugup\Nmelihat setelanmu ini.
Dialogue: 0,0:08:34.74,0:08:36.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut banget!
Dialogue: 0,0:08:36.65,0:08:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku ini bicara apa?
Dialogue: 0,0:08:39.21,0:08:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebablasan, ya?
Dialogue: 0,0:08:53.85,0:08:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini Bravo 2,\Nmeminta izin penyerangan.
Dialogue: 0,0:08:56.77,0:08:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bravo 2, serangan diizinkan.
Dialogue: 0,0:09:03.40,0:09:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaiju penghancur negeri impian\Nbahkan belum ada filmnya!
Dialogue: 0,0:09:07.32,0:09:09.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan! Tahanlah, diriku!
Dialogue: 0,0:09:09.24,0:09:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Akaishi?
Dialogue: 0,0:09:11.11,0:09:13.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.\NPandanganku agak kabur.
Dialogue: 0,0:09:13.87,0:09:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kamu baik-baik saja?
Dialogue: 0,0:09:17.95,0:09:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, enaknya naik apa, ya?
Dialogue: 0,0:09:20.12,0:09:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:09:21.58,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksakan diri\Nkalau kurang sehat.
Dialogue: 0,0:09:23.96,0:09:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lain kali saja lagi...
Dialogue: 0,0:09:25.00,0:09:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja!
Dialogue: 0,0:09:27.34,0:09:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh baik-baik saja.
Dialogue: 0,0:09:31.43,0:09:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyerah kali ini,\Nkurasa hari ini tidak akan datang lagi.
Dialogue: 0,0:09:39.31,0:09:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:09:41.69,0:09:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau kenapa-kenapa,\Nlangsung bilang, ya.
Dialogue: 0,0:09:51.86,0:09:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya hari ini\Nakan lebih berat dari dugaanku!
Dialogue: 0,0:10:04.42,0:10:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kostum semua orang sangat bagus, ya?
Dialogue: 0,0:10:07.59,0:10:10.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat mereka,\Nitu dari Friezen: Anna-ta dan Ratu Es.
Dialogue: 0,0:10:10.84,0:10:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, aku terlalu bersemangat, ya?
Dialogue: 0,0:10:13.38,0:10:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kok.
Dialogue: 0,0:10:14.80,0:10:15.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:10:15.97,0:10:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya itu asyik.
Dialogue: 0,0:10:18.35,0:10:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menempel banget!
Dialogue: 0,0:10:19.93,0:10:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku takut mual, yang itu saja, yuk!
Dialogue: 0,0:10:22.89,0:10:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahana itu buat sendiri-sendiri, lo.
Dialogue: 0,0:10:24.85,0:10:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku sangat suka karakter itu!
Dialogue: 0,0:10:27.65,0:10:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu?\NBaiklah.
Dialogue: 0,0:10:32.32,0:10:34.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:10:34.70,0:10:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang kencan.
Dialogue: 0,0:10:36.99,0:10:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ternyata ini lumayan asyik!\N- Siapa sangka hubungan mereka sejauh ini.
Dialogue: 0,0:10:39.03,0:10:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- I-Iya.\N- Siapa sangka hubungan mereka sejauh ini.
Dialogue: 0,0:10:40.37,0:10:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia anak baik.
Dialogue: 0,0:10:42.87,0:10:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau perasaan kalian setengah-setengah,\Nnanti menyesal, lo.
Dialogue: 0,0:10:47.21,0:10:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama!
Dialogue: 0,0:10:48.54,0:10:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena cinta kalian bisa jadi\Ncinta paling berbahaya di dunia.
Dialogue: 0,0:10:52.01,0:10:57.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharian ini aku akan mengukur\Nbibit, bebet, bobotmu, Minami.
Dialogue: 0,0:10:58.01,0:11:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, mungkin aku bisa\Nbertahan seharian.
Dialogue: 0,0:11:05.06,0:11:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata enggak!
Dialogue: 0,0:11:07.52,0:11:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, tapi aku bisa turun sendiri.
Dialogue: 0,0:11:10.77,0:11:13.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh, iya.\N- Aku terlalu meremehkan Minami Arata.
Dialogue: 0,0:11:13.32,0:11:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah, aku meremehkan kencan ini!
Dialogue: 0,0:11:15.11,0:11:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi ini akan berlangsung seharian?
Dialogue: 0,0:11:19.24,0:11:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lengah, diriku!
Dialogue: 0,0:11:35.26,0:11:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terkejut!
Dialogue: 0,0:11:36.72,0:11:39.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka Mitchi ikut naik juga!
Dialogue: 0,0:11:39.14,0:11:41.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, asyik banget!
Dialogue: 0,0:11:41.47,0:11:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama kalinya aku\Nmendengarmu teriak begitu.
Dialogue: 0,0:11:44.60,0:11:46.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal biasanya segan kalau bersamaku.
Dialogue: 0,0:11:46.69,0:11:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:11:48.31,0:11:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, menurutku itu bagus!\NAku juga senang!
Dialogue: 0,0:11:52.82,0:11:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, selanjutnya naik itu, yuk!
Dialogue: 0,0:11:55.90,0:11:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahana yang menempel lagi?
Dialogue: 0,0:11:57.74,0:12:01.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi-Mitchi mau ikut naik lagi, tidak, ya?
Dialogue: 0,0:12:05.33,0:12:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak usah, deh.
Dialogue: 0,0:12:08.08,0:12:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jual suvenir!
Dialogue: 0,0:12:09.33,0:12:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka ini!
Dialogue: 0,0:12:12.21,0:12:14.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Johnny dari Poy Stories.
Dialogue: 0,0:12:14.34,0:12:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia antagonis,\Ntapi tipe yang enggak bisa dibenci.
Dialogue: 0,0:12:17.01,0:12:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:12:19.59,0:12:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelek amat, persis sepertiku.
Dialogue: 0,0:12:25.85,0:12:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, cocok banget!
Dialogue: 0,0:12:27.85,0:12:28.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beli, yuk.
Dialogue: 0,0:12:28.56,0:12:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Enggak butuh!
Dialogue: 0,0:12:29.98,0:12:33.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang beginian cuma cocok\Ndipakai gadis yang manis!
Dialogue: 0,0:12:34.44,0:12:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga manis, kok.
Dialogue: 0,0:12:39.07,0:12:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan pakai, jadi ayo beli.
Dialogue: 0,0:12:40.82,0:12:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah tambah malu, dong?
Dialogue: 0,0:12:42.66,0:12:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}La-Lagian kita bukan pasangan!
Dialogue: 0,0:12:47.87,0:12:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu benar.
Dialogue: 0,0:13:00.13,0:13:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Serius?
Dialogue: 0,0:13:02.22,0:13:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus mau ke mana?
Dialogue: 0,0:13:03.10,0:13:04.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sana?
Dialogue: 0,0:13:04.39,0:13:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kan, aku sudah bilang\Nkalau ingin dipakaikan.
Dialogue: 0,0:13:11.06,0:13:13.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak itu, dia jadi jarang bicara.
Dialogue: 0,0:13:13.61,0:13:16.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sebegitunya mau pakai telinga?
Dialogue: 0,0:13:16.65,0:13:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yey!
Dialogue: 0,0:13:19.32,0:13:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku memang menolak\Nsemua ajakan Minami.
Dialogue: 0,0:13:24.95,0:13:28.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dia susah payah\Nmengajakku bersenang-senang.
Dialogue: 0,0:13:28.12,0:13:30.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, kencannya sia-sia, dong?
Dialogue: 0,0:13:31.83,0:13:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terus menutup hati,\Naku enggak akan bisa dekat dengannya!
Dialogue: 0,0:13:37.71,0:13:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata asmara memang\Nterlalu sulit untuk Kurotan.
Dialogue: 0,0:13:41.43,0:13:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupeluk dia saat pulang nanti!
Dialogue: 0,0:13:43.39,0:13:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi-Minami!
Dialogue: 0,0:13:44.89,0:13:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayo naik wahana\Nyang tadi kamu sarankan!
Dialogue: 0,0:13:48.35,0:13:51.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, benaran?\NKamu enggak memaksakan diri?
Dialogue: 0,0:13:51.44,0:13:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak! Ayo naik!
Dialogue: 0,0:13:53.94,0:13:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan gegabah, Kurotan!
Dialogue: 0,0:13:57.69,0:13:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:13:58.86,0:14:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suhu badan Minami langsung terasa olehku!
Dialogue: 0,0:14:02.32,0:14:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terlebih lagi...
Dialogue: 0,0:14:05.99,0:14:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga wangi!
Dialogue: 0,0:14:08.83,0:14:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu takut?\NIni tidak akan lama, kok.
Dialogue: 0,0:14:11.41,0:14:13.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hentikan!
Dialogue: 0,0:14:14.54,0:14:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya kakiku kena sesuatu.
Dialogue: 0,0:14:16.29,0:14:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat!
Dialogue: 0,0:14:23.18,0:14:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi basah kuyup, ya!
Dialogue: 0,0:14:25.34,0:14:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Akaishi?
Dialogue: 0,0:14:27.68,0:14:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nya-Nyaris saja.
Dialogue: 0,0:14:29.72,0:14:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku!
Dialogue: 0,0:14:31.31,0:14:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku mau ke toilet!
Dialogue: 0,0:14:34.06,0:14:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, sabuk pengamannya\Nharus dilepas dulu.
Dialogue: 0,0:14:36.52,0:14:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat!
Dialogue: 0,0:14:38.23,0:14:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sabuknya macet.
Dialogue: 0,0:14:52.04,0:14:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan aku.
Dialogue: 0,0:14:54.71,0:14:56.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga minta maaf.
Dialogue: 0,0:14:56.25,0:14:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:57.17,0:15:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sadar\Ntelah kamu hindari seharian ini,
Dialogue: 0,0:15:01.96,0:15:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kita malah sampai selarut ini.
Dialogue: 0,0:15:04.97,0:15:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena baik hati, kamu terpaksa\Nmenerima ajakanku hari ini, kan?
Dialogue: 0,0:15:10.93,0:15:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu memaksakan diri.
Dialogue: 0,0:15:12.98,0:15:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku janji tidak akan mengganggu lagi.
Dialogue: 0,0:15:16.69,0:15:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:15:18.36,0:15:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah paham.
Dialogue: 0,0:15:20.07,0:15:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sebaiknya kita berpisah di sini.\N- Tunggu!
Dialogue: 0,0:15:22.36,0:15:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Terima kasih banyak untuk hari ini.\N- Jangan menjauh.
Dialogue: 0,0:15:26.74,0:15:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang.
Dialogue: 0,0:15:37.50,0:15:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:15:39.84,0:15:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu salah!\NAku tidak seperti itu!
Dialogue: 0,0:15:46.88,0:15:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi, itu...
Dialogue: 0,0:15:50.39,0:15:51.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak apa-apa?
Dialogue: 0,0:15:53.85,0:15:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi!
Dialogue: 0,0:16:01.98,0:16:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat!
Dialogue: 0,0:16:05.19,0:16:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat aku!
Dialogue: 0,0:16:06.90,0:16:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi, itu...
Dialogue: 0,0:16:09.78,0:16:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak apa-apa?
Dialogue: 0,0:16:25.71,0:16:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia benar-benar\Nenggak mau bersamaku.
Dialogue: 0,0:16:30.47,0:16:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu salah paham, Minami.
Dialogue: 0,0:16:32.64,0:16:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kasihan, sebaiknya\Nhubungan kalian berakhir di sini.
Dialogue: 0,0:16:37.73,0:16:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip.
Dialogue: 0,0:16:41.69,0:16:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pulang, ya?
Dialogue: 0,0:16:43.52,0:16:45.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar, sih.
Dialogue: 0,0:16:45.82,0:16:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil dia bisa dekat\Ndengan pria manusia.
Dialogue: 0,0:16:49.24,0:16:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena anak itu...
Dialogue: 0,0:16:52.53,0:16:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah kalian berpisah\Nselagi luka hatinya belum dalam.
Dialogue: 0,0:16:56.83,0:16:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya mencari Kurotan.
Dialogue: 0,0:16:59.50,0:17:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parah.
Dialogue: 0,0:17:01.67,0:17:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tamat sudah.
Dialogue: 0,0:17:03.17,0:17:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia memang\Nenggak bisa menerima diriku.
Dialogue: 0,0:17:06.21,0:17:08.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku harus\Nterus menyembunyikannya.
Dialogue: 0,0:17:09.55,0:17:12.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti enggak akan\Nmengajakku bicara lagi.
Dialogue: 0,0:17:13.01,0:17:15.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa melihat\Nsenyuman itu lagi.
Dialogue: 0,0:17:16.01,0:17:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku terlahir\Ndengan wujud seperti ini?
Dialogue: 0,0:17:18.84,0:17:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dosa apa yang sudah kulakukan?
Dialogue: 0,0:17:22.44,0:17:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, padahal sehari ini saja.\NCukup sehari ini saja...
Dialogue: 0,0:17:28.78,0:17:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi gadis biasa.
Dialogue: 0,0:17:34.53,0:17:36.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak peduli lagi.
Dialogue: 0,0:17:38.79,0:17:41.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster!
Dialogue: 0,0:17:46.67,0:17:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang terjadi biarlah terjadi.
Dialogue: 0,0:17:49.88,0:17:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:17:50.88,0:17:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram.
Dialogue: 0,0:17:51.93,0:17:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang ada sesi foto, ya?
Dialogue: 0,0:17:53.30,0:17:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa?
Dialogue: 0,0:17:56.43,0:17:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurotan.
Dialogue: 0,0:17:58.89,0:18:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang kamu lakukan?
Dialogue: 0,0:18:01.73,0:18:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang terkejut, lo!
Dialogue: 0,0:18:03.77,0:18:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini Negeri Impian.
Dialogue: 0,0:18:07.02,0:18:09.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negeri Impian?
Dialogue: 0,0:18:09.32,0:18:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Mitchi.
Dialogue: 0,0:18:11.28,0:18:16.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster buruk rupa\Nenggak diizinkan bermimpi, ya?
Dialogue: 0,0:18:16.41,0:18:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejam sekali.
Dialogue: 0,0:18:22.00,0:18:25.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat benci negeri impian.
Dialogue: 0,0:18:25.09,0:18:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuinjak sampai hancur.
Dialogue: 0,0:18:28.30,0:18:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau enggak diizinkan\Nhidup seperti gadis biasa,
Dialogue: 0,0:18:31.63,0:18:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan hidup layaknya kaiju!
Dialogue: 0,0:18:34.13,0:18:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dimulai dari kastel itu.
Dialogue: 0,0:18:36.47,0:18:38.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurkan dari mana dulu, ya?
Dialogue: 0,0:18:38.68,0:18:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:18:59.24,0:19:01.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, akhirnya ketemu!
Dialogue: 0,0:19:01.95,0:19:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami?
Dialogue: 0,0:19:05.67,0:19:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat!
Dialogue: 0,0:19:07.46,0:19:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menjijikkan!
Dialogue: 0,0:19:10.05,0:19:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, aku terkejut.
Dialogue: 0,0:19:13.55,0:19:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, perasaanku bukan jijik.
Dialogue: 0,0:19:16.84,0:19:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku kurang pandai mengungkapkannya.
Dialogue: 0,0:19:20.81,0:19:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu itu...
Dialogue: 0,0:19:25.44,0:19:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata selalu serius, ya?
Dialogue: 0,0:19:31.07,0:19:34.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cosplay Johnny itu sangat luar biasa!
Dialogue: 0,0:19:34.61,0:19:35.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:19:35.70,0:19:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Saking kagetnya aku tidak sempat bereaksi.\N- Co-Cos...
Dialogue: 0,0:19:38.20,0:19:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, kelihatan terlalu asli, ya?\N- Kupikir kaiju benaran, lo.
Dialogue: 0,0:19:41.79,0:19:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin.
Dialogue: 0,0:19:43.20,0:19:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sangat terkesan!
Dialogue: 0,0:19:45.25,0:19:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ternyata ini alasanmu\N- Enggak, ini bukan cosplay...
Dialogue: 0,0:19:47.29,0:19:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bertingkah aneh sepanjang hari!\N- Enggak, ini bukan cosplay...
Dialogue: 0,0:19:51.55,0:19:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Co...
Dialogue: 0,0:19:54.42,0:19:56.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini cosplay!
Dialogue: 0,0:19:56.01,0:19:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga!
Dialogue: 0,0:19:57.09,0:19:58.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oalah.
Dialogue: 0,0:19:58.09,0:19:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku boleh minta foto?
Dialogue: 0,0:19:59.89,0:20:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak sadar!
Dialogue: 0,0:20:01.39,0:20:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kekuatan Negeri Impian!
Dialogue: 0,0:20:05.31,0:20:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:20:09.10,0:20:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku sempat cemas.
Dialogue: 0,0:20:12.73,0:20:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku lari ke sini sebenarnya...
Dialogue: 0,0:20:17.65,0:20:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku mencari tempat\Nuntuk ganti baju!
Dialogue: 0,0:20:20.66,0:20:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku lega setelah melihat ini.
Dialogue: 0,0:20:25.83,0:20:29.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu sangat\Nmenantikan kencan hari ini!
Dialogue: 0,0:20:30.21,0:20:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan lihat seenaknya!
Dialogue: 0,0:20:32.71,0:20:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, kok.
Dialogue: 0,0:20:34.80,0:20:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Destiny Lovers!
Dialogue: 0,0:20:37.30,0:20:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan nikmati pertunjukan sihir ini!
Dialogue: 0,0:20:47.31,0:20:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi di Negeri Impian,\Naku boleh bersikap jujur, kan?
Dialogue: 0,0:20:53.69,0:20:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bingung harus bagaimana.
Dialogue: 0,0:20:57.07,0:21:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku berpikir enggak akan\Npernah diajak pria kencan ke Destiny.
Dialogue: 0,0:21:02.24,0:21:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi gugup.
Dialogue: 0,0:21:04.24,0:21:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking takutnya dibenci dirimu,\Naku malah fokus ke diri sendiri.
Dialogue: 0,0:21:09.79,0:21:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:21:11.75,0:21:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:21:14.29,0:21:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar menantikan hari ini!
Dialogue: 0,0:21:17.96,0:21:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai-sampai berubah\Njadi wujud seperti ini!
Dialogue: 0,0:21:26.52,0:21:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, perasaanmu tersampaikan.
Dialogue: 0,0:21:32.85,0:21:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Negeri Impian!
Dialogue: 0,0:21:35.40,0:21:37.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mekanismenya bagaimana, ya?
Dialogue: 0,0:21:37.90,0:21:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurotan sampai bisa meluapkan\Nperasaannya begitu...
Dialogue: 0,0:21:41.91,0:21:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, makin tidak bisa kubiarkan!
Dialogue: 0,0:21:45.78,0:21:49.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kali ini aku tutup mata, deh.
Dialogue: 0,0:21:51.12,0:21:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berakhir.
Dialogue: 0,0:21:52.92,0:21:56.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada waktu sebelum waktu tutup.
Dialogue: 0,0:21:57.55,0:21:58.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau naik wahana lagi?
Dialogue: 0,0:22:00.42,0:22:01.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau!
Dialogue: 0,0:22:02.30,0:22:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku mau naik wahana itu!
Dialogue: 0,0:22:05.39,0:22:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus yang ini, yang ini, dan yang itu!
Dialogue: 0,0:23:52.83,0:23:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Capek banget!
Dialogue: 0,0:23:55.54,0:23:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mandi, ah.
Dialogue: 0,0:23:57.71,0:24:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian apa itu?
Dialogue: 0,0:24:01.59,0:24:03.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak jumpa.
Dialogue: 0,0:24:04.05,0:24:06.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Akaishi.
Dialogue: 0,0:24:08.93,0:24:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisan berikutnya,
Dialogue: 0,0:24:10.43,0:24:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}American Dog, dong!
Dialogue: 0,0:24:11.81,0:24:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu camilan panas!
