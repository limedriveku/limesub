Dialogue: 0,0:00:12.12,0:00:15.41,Default,,0,0,0,,Bagiku, cinta hanyalah rasa takut.
Dialogue: 0,0:00:18.41,0:00:19.75,Default,,0,0,0,,Begini...
Dialogue: 0,0:00:22.21,0:00:23.34,Default,,0,0,0,,Aku cinta kamu!
Dialogue: 0,0:00:28.76,0:00:31.05,Default,,0,0,0,,Mo-Monster!
Dialogue: 0,0:00:32.01,0:00:33.85,Default,,0,0,0,,Ucapannya kala itu...
Dialogue: 0,0:00:34.35,0:00:36.02,Default,,0,0,0,,Ekspresinya kala itu...
Dialogue: 0,0:00:36.60,0:00:37.93,Default,,0,0,0,,Mungkin
Dialogue: 0,0:00:41.31,0:00:42.19,Default,,0,0,0,,akan selalu
Dialogue: 0,0:00:43.40,0:00:45.07,Default,,0,0,0,,teringat olehku.
Dialogue: 0,0:00:48.11,0:00:49.49,Default,,0,0,0,,Minami!
Dialogue: 0,0:00:52.16,0:00:55.33,Default,,0,0,0,,Foto kemarin dapat dua ribu suka, lo!
Dialogue: 0,0:00:55.33,0:00:57.62,Default,,0,0,0,,Pesonamu luar biasa!
Dialogue: 0,0:00:57.62,0:00:59.79,Default,,0,0,0,,Kudengar kamu ditawari jadi model?
Dialogue: 0,0:00:59.79,0:01:03.08,Default,,0,0,0,,Eh? Ah, cuma sedikit ditanya-tanya, kok.
Dialogue: 0,0:01:03.08,0:01:04.34,Default,,0,0,0,,Hebat!
Dialogue: 0,0:01:04.34,0:01:06.88,Default,,0,0,0,,Foto dulu mumpung sempat, ah.
Dialogue: 0,0:01:09.01,0:01:12.89,Default,,0,0,0,,A-Ada apa, Neng Menhera?
Dialogue: 0,0:01:14.43,0:01:17.72,Default,,0,0,0,,O-Oh, ini bangkumu?
Dialogue: 0,0:01:17.72,0:01:19.68,Default,,0,0,0,,Aku pinjam sampai kelas dimulai, ya?
Dialogue: 0,0:01:19.68,0:01:22.98,Default,,0,0,0,,Bangku ini paling pas buat memfoto Minami.
Dialogue: 0,0:01:22.98,0:01:25.11,Default,,0,0,0,,Tidak usah, aku mau keluar.
Dialogue: 0,0:01:32.91,0:01:33.99,Default,,0,0,0,,Jijik!
Dialogue: 0,0:01:33.99,0:01:36.12,Default,,0,0,0,,Neng Menhera memang sakit jiwa!
Dialogue: 0,0:01:36.12,0:01:38.70,Default,,0,0,0,,Minimal bicara, kek!
Dialogue: 0,0:01:39.29,0:01:40.79,Default,,0,0,0,,Ngeri banget, kan?
Dialogue: 0,0:01:40.79,0:01:42.04,Default,,0,0,0,,Ngeri!
Dialogue: 0,0:01:49.21,0:01:52.55,Default,,0,0,0,,Aku ingin menghancurkan mereka semua.
Dialogue: 0,0:01:52.55,0:01:55.18,Default,,0,0,0,,Mereka selalu centil tiap hari!
Dialogue: 0,0:01:55.18,0:01:57.72,Default,,0,0,0,,Minami Arata sialan!
Dialogue: 0,0:01:57.72,0:02:01.18,Default,,0,0,0,,Kenapa bangku kita sebelahan, sih?
Dialogue: 0,0:02:01.18,0:02:05.40,Default,,0,0,0,,Kembalikan lingkup personalku!
Dialogue: 0,0:02:07.90,0:02:09.03,Default,,0,0,0,,Gawat.
Dialogue: 0,0:02:09.03,0:02:11.49,Default,,0,0,0,,Lagi-lagi begini.
Dialogue: 0,0:02:14.66,0:02:17.62,Default,,0,0,0,,Tenang, ini sudah biasa.
Dialogue: 0,0:02:17.62,0:02:20.08,Default,,0,0,0,,Di saat seperti ini...
Dialogue: 0,0:02:21.79,0:02:27.13,Default,,0,0,0,,Kepala ini harus dijejali lagu\Ndan makanan favoritku!
Dialogue: 0,0:02:28.63,0:02:32.13,Default,,0,0,0,,Aku ingin makan\Npanekuk premium Kafe Serizawa.
Dialogue: 0,0:02:32.13,0:02:35.51,Default,,0,0,0,,Tapi, harus punya tiket premium dulu.
Dialogue: 0,0:02:35.51,0:02:37.60,Default,,0,0,0,,Tiket premium itu apa?
Dialogue: 0,0:02:37.60,0:02:41.56,Default,,0,0,0,,Lagian, mustahil aku pergi sendirian\Nke tempat trendi begitu.
Dialogue: 0,0:02:41.56,0:02:45.23,Default,,0,0,0,,Aku tidak punya teman,\Ntakut pergi ke Omotesando pula.
Dialogue: 0,0:02:45.23,0:02:48.94,Default,,0,0,0,,Yah, memang mustahil.
Dialogue: 0,0:02:51.82,0:02:53.40,Default,,0,0,0,,Menyerah saja, lah.
Dialogue: 0,0:02:55.49,0:02:59.74,Default,,0,0,0,,Selama 16 tahun,\Naku dihantui oleh gejala misterius.
Dialogue: 0,0:02:59.74,0:03:03.20,Default,,0,0,0,,Sebagian tubuhku mendadak\Nmenjadi buruk rupa.
Dialogue: 0,0:03:03.20,0:03:04.83,Default,,0,0,0,,Penyebabnya belum jelas.
Dialogue: 0,0:03:04.83,0:03:06.54,Default,,0,0,0,,Tidak bisa diobati.
Dialogue: 0,0:03:06.54,0:03:11.42,Default,,0,0,0,,Para dokter menyerah karena gejala ini\Nbelum pernah ada di dunia.
Dialogue: 0,0:03:11.42,0:03:15.55,Default,,0,0,0,,Ini terjadi, saat pertama kali\Naku jatuh cinta.
Dialogue: 0,0:03:16.34,0:03:18.97,Default,,0,0,0,,Aku ingat betapa sakitnya waktu itu.
Dialogue: 0,0:03:20.39,0:03:23.72,Default,,0,0,0,,Jangan sering-sering bermain\Ndengan temanmu.
Dialogue: 0,0:03:23.72,0:03:26.52,Default,,0,0,0,,Cuma Mama yang ada di pihakmu, Kuroe.
Dialogue: 0,0:03:27.56,0:03:31.27,Default,,0,0,0,,Aku tidak mematuhi nasihat Ibu.
Dialogue: 0,0:03:31.27,0:03:33.78,Default,,0,0,0,,Akaishi!
Dialogue: 0,0:03:33.78,0:03:35.11,Default,,0,0,0,,Ayo main lempar bola!
Dialogue: 0,0:03:35.11,0:03:37.61,Default,,0,0,0,,Eh, boleh?
Dialogue: 0,0:03:38.36,0:03:40.95,Default,,0,0,0,,Sudah lama tidak bersenang-senang!
Dialogue: 0,0:03:42.87,0:03:44.87,Default,,0,0,0,,Akaishi!
Dialogue: 0,0:03:44.87,0:03:47.04,Default,,0,0,0,,Apa itu?
Dialogue: 0,0:03:48.25,0:03:53.30,Default,,0,0,0,,Mungkin aku masih agak berharap\Nditerima oleh seseorang.
Dialogue: 0,0:03:54.05,0:03:57.13,Default,,0,0,0,,Tapi, itu cuma angan.
Dialogue: 0,0:03:57.13,0:03:59.39,Default,,0,0,0,,Pengin operasi plastik, deh.
Dialogue: 0,0:03:59.39,0:04:01.68,Default,,0,0,0,,Kelopak mataku tebal kayak monster.
Dialogue: 0,0:04:01.68,0:04:03.76,Default,,0,0,0,,Bisa mati aku tanpa riasan.
Dialogue: 0,0:04:03.76,0:04:05.10,Default,,0,0,0,,Jerawatku ganggu!
Dialogue: 0,0:04:05.10,0:04:05.77,Default,,0,0,0,,Botak!
Dialogue: 0,0:04:05.77,0:04:07.06,Default,,0,0,0,,Mantan pacarku tepos.
Dialogue: 0,0:04:07.06,0:04:09.06,Default,,0,0,0,,Kualitasnya turun, deh.
Dialogue: 0,0:04:09.06,0:04:11.23,Default,,0,0,0,,Waktu kencan buta, orangnya gendut semua.
Dialogue: 0,0:04:11.23,0:04:15.32,Default,,0,0,0,,Mustahil ada yang menerimaku\Ndi dunia seperti ini.
Dialogue: 0,0:04:16.24,0:04:18.49,Default,,0,0,0,,Jangan ada yang melihatku.
Dialogue: 0,0:04:18.49,0:04:19.95,Default,,0,0,0,,Jangan lihat aku!
Dialogue: 0,0:04:26.20,0:04:30.21,Default,,0,0,0,,Kalau di sini, aku bisa\Nmakan siang dengan tenang.
Dialogue: 0,0:04:30.21,0:04:32.59,Default,,0,0,0,,Kenapa malah aku yang harus lari?
Dialogue: 0,0:04:32.59,0:04:33.92,Default,,0,0,0,,Dingin banget, woi.
Dialogue: 0,0:04:54.44,0:04:56.57,Default,,0,0,0,,Aku terkejut!
Dialogue: 0,0:04:56.57,0:04:59.03,Default,,0,0,0,,Eh, justru aku yang mengejutkanmu.
Dialogue: 0,0:04:59.03,0:04:59.95,Default,,0,0,0,,Maaf, ya.
Dialogue: 0,0:04:59.95,0:05:02.03,Default,,0,0,0,,Mi-Minami Arata?
Dialogue: 0,0:05:02.03,0:05:04.53,Default,,0,0,0,,Kalau makan di kelas pasti heboh,
Dialogue: 0,0:05:04.53,0:05:06.12,Default,,0,0,0,,jadi aku cari tempat lain.
Dialogue: 0,0:05:06.99,0:05:08.96,Default,,0,0,0,,Ternyata Akaishi juga di sini.
Dialogue: 0,0:05:08.96,0:05:11.04,Default,,0,0,0,,Akaishi?
Dialogue: 0,0:05:11.67,0:05:14.04,Default,,0,0,0,,Gambarmu bagus!
Dialogue: 0,0:05:14.04,0:05:15.46,Default,,0,0,0,,Jangan lihat!
Dialogue: 0,0:05:15.46,0:05:16.59,Default,,0,0,0,,Siapa sangka.
Dialogue: 0,0:05:16.59,0:05:19.72,Default,,0,0,0,,Kukira dia cuma kenal\Nteman sekelas yang elite.
Dialogue: 0,0:05:19.72,0:05:21.22,Default,,0,0,0,,Kok cuma abu-abu?
Dialogue: 0,0:05:21.22,0:05:22.09,Default,,0,0,0,,Hah?
Dialogue: 0,0:05:22.09,0:05:23.97,Default,,0,0,0,,Padahal banyak warna lain.
Dialogue: 0,0:05:23.97,0:05:27.06,Default,,0,0,0,,Bi-Biar lebih keren!
Dialogue: 0,0:05:27.06,0:05:28.89,Default,,0,0,0,,Oh, benar juga.
Dialogue: 0,0:05:28.89,0:05:31.06,Default,,0,0,0,,Maaf kalau seleraku jelek.
Dialogue: 0,0:05:32.27,0:05:33.98,Default,,0,0,0,,Kamu benaran jago.
Dialogue: 0,0:05:35.40,0:05:38.82,Default,,0,0,0,,Dia enggak bisa jaga jarak!
Dialogue: 0,0:05:38.82,0:05:40.24,Default,,0,0,0,,Aku suka Tokuho Cola.
Dialogue: 0,0:05:40.24,0:05:41.57,Default,,0,0,0,,Enggak peduli!
Dialogue: 0,0:05:41.57,0:05:43.28,Default,,0,0,0,,Ga-Gawat.
Dialogue: 0,0:05:43.78,0:05:45.24,Default,,0,0,0,,Bakal keluar!
Dialogue: 0,0:05:45.24,0:05:47.41,Default,,0,0,0,,Ada kalanya aku ingin menyendiri.
Dialogue: 0,0:05:50.79,0:05:55.08,Default,,0,0,0,,Saat disorot kamera,\Nkadang aku malah kepikiran.
Dialogue: 0,0:05:55.08,0:05:58.55,Default,,0,0,0,,Apa hebatnya diriku, sih?
Dialogue: 0,0:06:01.05,0:06:02.93,Default,,0,0,0,,Apa yang hebat darimu?
Dialogue: 0,0:06:02.93,0:06:05.01,Default,,0,0,0,,Maksudnya, ini sindiran?
Dialogue: 0,0:06:05.01,0:06:06.72,Default,,0,0,0,,Dia ingin aku puji?
Dialogue: 0,0:06:06.72,0:06:08.26,Default,,0,0,0,,Meski sudah sepopuler itu?
Dialogue: 0,0:06:08.72,0:06:12.56,Default,,0,0,0,,Jangan berlagak seakan\Nkamu tahu rasanya rendah diri.
Dialogue: 0,0:06:13.44,0:06:16.77,Default,,0,0,0,,Sikap setengah hati itu\Nbisa menyakiti orang lain, lo.
Dialogue: 0,0:06:16.77,0:06:18.94,Default,,0,0,0,,Kalau ogah difoto, tolak saja.
Dialogue: 0,0:06:18.94,0:06:22.03,Default,,0,0,0,,Kasihan sama orang yang tertarik padamu.
Dialogue: 0,0:06:22.03,0:06:23.65,Default,,0,0,0,,Beres, deh!
Dialogue: 0,0:06:23.65,0:06:25.91,Default,,0,0,0,,Dia pasti berpikir,\N"Sok tahu banget ini cewek."
Dialogue: 0,0:06:25.91,0:06:26.95,Default,,0,0,0,,Cepat pergi sa—
Dialogue: 0,0:06:30.20,0:06:31.33,Default,,0,0,0,,Benar juga.
Dialogue: 0,0:06:31.33,0:06:33.79,Default,,0,0,0,,Kayaknya kamu benar.
Dialogue: 0,0:06:33.79,0:06:36.00,Default,,0,0,0,,Ternyata sifatku jelek, ya?
Dialogue: 0,0:06:36.00,0:06:37.79,Default,,0,0,0,,Akan kuperbaiki.
Dialogue: 0,0:06:39.80,0:06:42.59,Default,,0,0,0,,Aku pergi dulu,\Ntakutnya mengganggu waktu gambarmu.
Dialogue: 0,0:06:42.59,0:06:45.47,Default,,0,0,0,,Oh, jangan sampai kedinginan.
Dialogue: 0,0:06:45.47,0:06:47.72,Default,,0,0,0,,Semangat, ya!
Dialogue: 0,0:06:50.81,0:06:53.43,Default,,0,0,0,,Gi-Gila!
Dialogue: 0,0:06:53.43,0:06:56.77,Default,,0,0,0,,Ke kasta rendahan pun sikapnya tetap keren!
Dialogue: 0,0:06:56.77,0:07:00.52,Default,,0,0,0,,Aneh, padahal tidak ada\Nuntungnya baik padaku.
Dialogue: 0,0:07:00.52,0:07:01.23,Default,,0,0,0,,Ah!
Dialogue: 0,0:07:01.23,0:07:03.49,Default,,0,0,0,,Jangan-jangan seleranya jadi aneh?
Dialogue: 0,0:07:03.49,0:07:04.20,Default,,0,0,0,,Aku bosan.
Dialogue: 0,0:07:04.20,0:07:05.24,Default,,0,0,0,,Seram!
Dialogue: 0,0:07:07.62,0:07:10.53,Default,,0,0,0,,Eng-Enggak butuh!
Dialogue: 0,0:07:12.70,0:07:14.00,Default,,0,0,0,,Aku tidak akan tertipu.
Dialogue: 0,0:07:14.00,0:07:17.46,Default,,0,0,0,,Aku berbeda dari wanita lainnya!
Dialogue: 0,0:07:18.46,0:07:21.92,Default,,0,0,0,,Mayu imut!
Dialogue: 0,0:07:21.92,0:07:24.76,Default,,0,0,0,,Yey!
Dialogue: 0,0:07:27.84,0:07:29.35,Default,,0,0,0,,Selamat datang, Kurotan.
Dialogue: 0,0:07:29.76,0:07:31.68,Default,,0,0,0,,Kalau pulang bilang, dong.
Dialogue: 0,0:07:31.68,0:07:33.56,Default,,0,0,0,,Mama jadi cemas.
Dialogue: 0,0:07:33.56,0:07:35.02,Default,,0,0,0,,Mana pelukan saat pulangnya?
Dialogue: 0,0:07:35.02,0:07:36.44,Default,,0,0,0,,Enggak usah!
Dialogue: 0,0:07:36.44,0:07:37.77,Default,,0,0,0,,Enggak boleh!
Dialogue: 0,0:07:37.77,0:07:39.98,Default,,0,0,0,,Yak, selamat datang.
Dialogue: 0,0:07:40.65,0:07:44.36,Default,,0,0,0,,Lo, Kurotan?\NGejalamu kambuh.
Dialogue: 0,0:07:44.36,0:07:46.45,Default,,0,0,0,,I-Ini sudah biasa!
Dialogue: 0,0:07:46.45,0:07:49.12,Default,,0,0,0,,Bukannya yang di punggung jarang kambuh?
Dialogue: 0,0:07:52.70,0:07:55.00,Default,,0,0,0,,Hei, Jumbo King.
Dialogue: 0,0:07:55.00,0:07:55.79,Default,,0,0,0,,Nakal.
Dialogue: 0,0:07:56.58,0:07:57.75,Default,,0,0,0,,Dasar.
Dialogue: 0,0:07:58.50,0:08:00.46,Default,,0,0,0,,Mama khawatir, tahu.
Dialogue: 0,0:08:06.72,0:08:08.22,Default,,0,0,0,,Menjijikkan.
Dialogue: 0,0:08:08.22,0:08:09.84,Default,,0,0,0,,Aneh sekali.
Dialogue: 0,0:08:09.84,0:08:12.05,Default,,0,0,0,,Padahal biasanya langsung hilang.
Dialogue: 0,0:08:13.01,0:08:15.68,Default,,0,0,0,,Bagaimana kalau begini selamanya?
Dialogue: 0,0:08:17.81,0:08:19.44,Default,,0,0,0,,Ya sudahlah.
Dialogue: 0,0:08:19.44,0:08:24.48,Default,,0,0,0,,Kalaupun jadi monster,\Nhidupku tidak akan banyak berubah.
Dialogue: 0,0:08:25.07,0:08:27.61,Default,,0,0,0,,Dunia akan tetap kelabu.
Dialogue: 0,0:08:27.61,0:08:28.95,Default,,0,0,0,,Sama saja.
Dialogue: 0,0:08:29.36,0:08:32.32,Default,,0,0,0,,Sebaiknya aku menjauhi dia.
Dialogue: 0,0:08:35.62,0:08:37.50,Default,,0,0,0,,Halo, Akaishi.
Dialogue: 0,0:08:37.50,0:08:40.58,Default,,0,0,0,,Kenapa dia di sini?\NAku pengin balik ke kelas!
Dialogue: 0,0:08:40.58,0:08:43.17,Default,,0,0,0,,Tapi aku tidak mau\Ndianggap salah tingkah.
Dialogue: 0,0:08:43.17,0:08:45.34,Default,,0,0,0,,Tokuho Cola enak banget, ya.
Dialogue: 0,0:08:45.34,0:08:46.55,Default,,0,0,0,,Sudah kubilang enggak peduli.
Dialogue: 0,0:08:46.96,0:08:49.26,Default,,0,0,0,,Aku memikirkannya sejak itu,
Dialogue: 0,0:08:49.26,0:08:52.22,Default,,0,0,0,,dianggap penting adalah anugerah.
Dialogue: 0,0:08:52.22,0:08:56.68,Default,,0,0,0,,Jadi sebaiknya aku menikmatinya\Ntanpa berpikir kejauhan.
Dialogue: 0,0:08:56.68,0:08:59.02,Default,,0,0,0,,- Dia benar-benar mengajak bicara.\N- Sejak kamu tegur dengan keras,
Dialogue: 0,0:08:59.02,0:09:00.31,Default,,0,0,0,,- Akan kuabaikan.\N- rasanya aku jadi sadar.
Dialogue: 0,0:09:00.31,0:09:03.31,Default,,0,0,0,,Terus, tadi aku diajak ke sini.
Dialogue: 0,0:09:03.31,0:09:04.61,Default,,0,0,0,,Kamu mau makan ini?
Dialogue: 0,0:09:08.32,0:09:09.49,Default,,0,0,0,,Mau.
Dialogue: 0,0:09:09.49,0:09:11.28,Default,,0,0,0,,Asyik juga kamu, Akaishi!
Dialogue: 0,0:09:12.41,0:09:14.66,Default,,0,0,0,,Kok tidak sesuai ceritamu?
Dialogue: 0,0:09:14.66,0:09:15.99,Default,,0,0,0,,Mana yang lainnya?
Dialogue: 0,0:09:15.99,0:09:18.54,Default,,0,0,0,,Mereka mendadak enggak bisa datang.
Dialogue: 0,0:09:18.54,0:09:20.25,Default,,0,0,0,,Padahal seru kalau ramai.
Dialogue: 0,0:09:20.25,0:09:21.33,Default,,0,0,0,,Ta-Tapi...
Dialogue: 0,0:09:21.33,0:09:24.13,Default,,0,0,0,,Dipikir-pikir, ramai pun malas, sih.
Dialogue: 0,0:09:24.13,0:09:26.25,Default,,0,0,0,,Tapi kalau berdua, kayak...
Dialogue: 0,0:09:26.25,0:09:27.88,Default,,0,0,0,,Selamat datang.
Dialogue: 0,0:09:27.88,0:09:29.80,Default,,0,0,0,,- Kumohon.\N- Untuk dua orang, ya?
Dialogue: 0,0:09:29.80,0:09:33.51,Default,,0,0,0,,- Bertahanlah, tubuhku!\N- Silakan lewat sini.
Dialogue: 0,0:09:37.52,0:09:39.85,Default,,0,0,0,,Bikin panekuk ternyata lama, ya.
Dialogue: 0,0:09:41.27,0:09:43.31,Default,,0,0,0,,Aku tidak kuat lagi.
Dialogue: 0,0:09:43.31,0:09:45.23,Default,,0,0,0,,Panekuk, cepatlah datang.
Dialogue: 0,0:09:45.23,0:09:47.19,Default,,0,0,0,,Ini panekuk premiumnya!
Dialogue: 0,0:09:47.19,0:09:47.90,Default,,0,0,0,,Aku selamat!
Dialogue: 0,0:09:47.90,0:09:50.61,Default,,0,0,0,,Akhirnya!
Dialogue: 0,0:09:50.61,0:09:52.07,Default,,0,0,0,,Boleh kumakan?
Dialogue: 0,0:09:52.07,0:09:53.61,Default,,0,0,0,,Silakan.
Dialogue: 0,0:10:02.04,0:10:04.54,Default,,0,0,0,,Enaknya!
Dialogue: 0,0:10:05.75,0:10:07.50,Default,,0,0,0,,Kenapa tertawa?
Dialogue: 0,0:10:07.50,0:10:08.42,Default,,0,0,0,,Maaf.
Dialogue: 0,0:10:08.42,0:10:09.96,Default,,0,0,0,,Ini di luar dugaanku.
Dialogue: 0,0:10:09.96,0:10:13.43,Default,,0,0,0,,Soalnya kamu biasanya\Nterkesan tegas dan berwibawa.
Dialogue: 0,0:10:15.43,0:10:19.47,Default,,0,0,0,,Selain gaya berpakaian,\Nsikapmu juga menonjolkan jati diri.
Dialogue: 0,0:10:20.10,0:10:23.14,Default,,0,0,0,,Dicaci maki pun kamu tetap santai.
Dialogue: 0,0:10:23.14,0:10:26.69,Default,,0,0,0,,Saat piket, semuanya kamu\Nbersihkan sampai mengilap.
Dialogue: 0,0:10:26.69,0:10:29.78,Default,,0,0,0,,Tanaman di pojok kelas juga\Nsudah berbunga, kan?
Dialogue: 0,0:10:30.40,0:10:33.15,Default,,0,0,0,,Karena kamu menyiramnya tiap hari.
Dialogue: 0,0:10:33.99,0:10:35.49,Default,,0,0,0,,Keren banget.
Dialogue: 0,0:10:36.16,0:10:38.24,Default,,0,0,0,,Lo, entah kenapa...
Dialogue: 0,0:10:39.29,0:10:44.12,Default,,0,0,0,,Panekuknya jadi tidak terasa.
Dialogue: 0,0:10:44.71,0:10:47.25,Default,,0,0,0,,Kamu mau makan punyaku juga?
Dialogue: 0,0:10:47.25,0:10:48.67,Default,,0,0,0,,Kamu enggak mau?
Dialogue: 0,0:10:50.25,0:10:52.38,Default,,0,0,0,,Aku ini gampang gemuk.
Dialogue: 0,0:10:53.34,0:10:54.97,Default,,0,0,0,,Ini aku waktu SMP.
Dialogue: 0,0:10:54.97,0:10:58.68,Default,,0,0,0,,Aku enggak percaya diri\Ndan enggak punya teman.
Dialogue: 0,0:10:59.18,0:11:03.43,Default,,0,0,0,,Kalau aku jadi begini lagi,\Norang-orang pasti menjauh.
Dialogue: 0,0:11:03.43,0:11:05.06,Default,,0,0,0,,Kalau memikirkan itu,
Dialogue: 0,0:11:05.06,0:11:09.40,Default,,0,0,0,,makanan yang biasanya lezat\Njadi terasa hambar belakangan ini.
Dialogue: 0,0:11:10.57,0:11:13.90,Default,,0,0,0,,Jangan berlagak seakan\Nkamu tahu rasanya rendah diri.
Dialogue: 0,0:11:16.99,0:11:21.08,Default,,0,0,0,,Pegawai kafe pun akan lebih senang\Nkalau kamu yang memakannya.
Dialogue: 0,0:11:22.83,0:11:24.04,Default,,0,0,0,,Makan ini.
Dialogue: 0,0:11:24.04,0:11:24.79,Default,,0,0,0,,Eh?
Dialogue: 0,0:11:24.79,0:11:29.50,Default,,0,0,0,,Aku tidak peduli\Nkamu gendut atau cungkring.
Dialogue: 0,0:11:29.50,0:11:33.46,Default,,0,0,0,,Tapi hari ini, aku bersyukur\Ndatang ke sini bersamamu.
Dialogue: 0,0:11:33.88,0:11:37.80,Default,,0,0,0,,Ada juga manusia seperti itu di sekitarmu.
Dialogue: 0,0:11:37.80,0:11:43.27,Default,,0,0,0,,Setidaknya, ada satu.
Dialogue: 0,0:11:43.27,0:11:46.73,Default,,0,0,0,,Ja-Jadi, makanlah tanpa ragu.
Dialogue: 0,0:11:57.70,0:11:59.95,Default,,0,0,0,,Enak banget!
Dialogue: 0,0:12:01.87,0:12:03.66,Default,,0,0,0,,Apa boleh buat.
Dialogue: 0,0:12:03.66,0:12:06.62,Default,,0,0,0,,Aku akan tertipu buat sementara.
Dialogue: 0,0:12:36.11,0:12:38.07,Default,,0,0,0,,Kamu baik-baik saja, Akaishi?
Dialogue: 0,0:12:38.07,0:12:39.91,Default,,0,0,0,,Kamu enggak enak badan?
Dialogue: 0,0:12:39.91,0:12:41.95,Default,,0,0,0,,Ah, bukan.
Dialogue: 0,0:12:41.95,0:12:43.91,Default,,0,0,0,,Kenapa tubuhku sepanas ini?
Dialogue: 0,0:12:43.91,0:12:46.95,Default,,0,0,0,,Karena banyak rangsangan\Nyang terlalu kuat?
Dialogue: 0,0:12:46.95,0:12:48.46,Default,,0,0,0,,Biar kuantar sampai rumah.
Dialogue: 0,0:12:48.46,0:12:49.92,Default,,0,0,0,,Eng-Enggak usah!
Dialogue: 0,0:12:50.33,0:12:52.42,Default,,0,0,0,,Itu Minami!
Dialogue: 0,0:12:52.42,0:12:53.34,Default,,0,0,0,,Benar!
Dialogue: 0,0:12:53.34,0:12:55.13,Default,,0,0,0,,Minami!
Dialogue: 0,0:12:55.13,0:12:56.84,Default,,0,0,0,,Eh, tunggu.
Dialogue: 0,0:12:56.84,0:12:58.80,Default,,0,0,0,,Di sebelahnya...
Dialogue: 0,0:12:58.80,0:13:00.48,Default,,0,0,0,,Neng Menhera!
Dialogue: 0,0:13:00.48,0:13:02.72,Default,,0,0,0,,Kenapa dia bareng cewek jelek itu?
Dialogue: 0,0:13:02.72,0:13:04.72,Default,,0,0,0,,Dia menguntit Minami?
Dialogue: 0,0:13:04.72,0:13:07.31,Default,,0,0,0,,Gawat, semua orang harus tahu.
Dialogue: 0,0:13:07.31,0:13:09.44,Default,,0,0,0,,Aku tahu, kok.
Dialogue: 0,0:13:09.44,0:13:11.81,Default,,0,0,0,,Aku juga sadar diri.
Dialogue: 0,0:13:11.81,0:13:13.15,Default,,0,0,0,,Ngeri banget!
Dialogue: 0,0:13:14.02,0:13:16.19,Default,,0,0,0,,Aku tahu, tapi...
Dialogue: 0,0:13:16.82,0:13:20.20,Default,,0,0,0,,Maaf, ya.
Dialogue: 0,0:13:32.42,0:13:33.71,Default,,0,0,0,,Ayo pergi.
Dialogue: 0,0:13:41.09,0:13:42.43,Default,,0,0,0,,Hei, tunggu!
Dialogue: 0,0:13:43.51,0:13:44.47,Default,,0,0,0,,Eh?
Dialogue: 0,0:13:44.47,0:13:45.97,Default,,0,0,0,,Serius?
Dialogue: 0,0:13:45.97,0:13:47.43,Default,,0,0,0,,Kenapa?
Dialogue: 0,0:13:47.93,0:13:49.14,Default,,0,0,0,,Kenapa?
Dialogue: 0,0:13:50.64,0:13:53.19,Default,,0,0,0,,Eh? Lo?
Dialogue: 0,0:13:54.94,0:13:58.78,Default,,0,0,0,,Dunia jadi berwarna pink.
Dialogue: 0,0:14:05.41,0:14:06.70,Default,,0,0,0,,Tubuhku
Dialogue: 0,0:14:07.66,0:14:10.62,Default,,0,0,0,,terasa aneh.
Dialogue: 0,0:14:11.29,0:14:11.79,Default,,0,0,0,,Maaf!
Dialogue: 0,0:14:14.25,0:14:15.29,Default,,0,0,0,,Akaishi!
Dialogue: 0,0:14:17.75,0:14:19.21,Default,,0,0,0,,Tubuhku terbakar.
Dialogue: 0,0:14:20.09,0:14:21.05,Default,,0,0,0,,Panas.
Dialogue: 0,0:14:21.76,0:14:23.30,Default,,0,0,0,,Tidak tertahankan.
Dialogue: 0,0:14:31.18,0:14:32.43,Default,,0,0,0,,Aduh.
Dialogue: 0,0:14:33.69,0:14:35.15,Default,,0,0,0,,Enggak bisa.
Dialogue: 0,0:14:43.32,0:14:47.01,Default,,0,0,0,,Apa-apaan dia?\NSudah jelas mustahil!
Dialogue: 0,0:14:47.62,0:14:49.24,Default,,0,0,0,,Kalau dia melakukan itu...
Dialogue: 0,0:14:51.29,0:14:53.21,Default,,0,0,0,,Mustahil!
Dialogue: 0,0:14:53.21,0:14:56.38,Default,,0,0,0,,Aku memang tidak bisa!\NIni mustahil!
Dialogue: 0,0:15:13.98,0:15:17.60,Default,,0,0,0,,Mustahil dia menerima diriku\Nyang seperti ini.
Dialogue: 0,0:15:18.27,0:15:21.57,Default,,0,0,0,,Padahal cinta isinya cuma rasa takut.
Dialogue: 0,0:15:26.49,0:15:30.83,Default,,0,0,0,,Aku...\NAku sudah tidak bisa berhenti!
Dialogue: 0,0:15:37.37,0:15:39.25,Default,,0,0,0,,Pemirsa!
Dialogue: 0,0:15:39.25,0:15:42.00,Default,,0,0,0,,Hal yang sulit dipercaya telah terjadi!
Dialogue: 0,0:15:42.00,0:15:44.01,Default,,0,0,0,,Ini bukan rekayasa kamera!
Dialogue: 0,0:15:44.72,0:15:49.26,Default,,0,0,0,,Monster raksasa telah muncul di Tokyo!
Dialogue: 0,0:15:57.44,0:15:59.40,Default,,0,0,0,,Kamu sudah tumbuh besar,
Dialogue: 0,0:15:59.90,0:16:01.23,Default,,0,0,0,,Kurotan.
Dialogue: 0,0:16:02.61,0:16:04.94,Default,,0,0,0,,Kaiju?
Dialogue: 0,0:16:16.71,0:16:19.96,Default,,0,0,0,,Aku melihat mimpi aneh.
Dialogue: 0,0:16:20.75,0:16:24.42,Default,,0,0,0,,Tapi, entah kenapa terasa nikmat.
Dialogue: 0,0:16:25.51,0:16:29.68,Default,,0,0,0,,Semua unek-unek dalam tubuhku\Nterasa keluar semuanya.
Dialogue: 0,0:16:29.68,0:16:32.64,Default,,0,0,0,,Jangan, Kurotan!\NJangan keluar dari sungai!
Dialogue: 0,0:16:32.64,0:16:34.85,Default,,0,0,0,,Efeknya bisa fatal!
Dialogue: 0,0:16:34.85,0:16:36.10,Default,,0,0,0,,Maaf!
Dialogue: 0,0:16:39.27,0:16:40.94,Default,,0,0,0,,Apa yang kamu lakukan?
Dialogue: 0,0:16:40.94,0:16:43.48,Default,,0,0,0,,Kayaknya ada gadis jatuh ke bawah sini!
Dialogue: 0,0:16:43.48,0:16:44.69,Default,,0,0,0,,Eh?
Dialogue: 0,0:16:44.69,0:16:46.57,Default,,0,0,0,,Akaishi!
Dialogue: 0,0:16:47.19,0:16:50.20,Default,,0,0,0,,Apa dia bertubuh mungil\Ndengan baju kegedean?
Dialogue: 0,0:16:50.20,0:16:51.91,Default,,0,0,0,,Eh, iya.
Dialogue: 0,0:16:51.91,0:16:53.08,Default,,0,0,0,,Benar!
Dialogue: 0,0:16:53.08,0:16:56.58,Default,,0,0,0,,Kalian bersama?\NSelarut ini? Berduaan?
Dialogue: 0,0:16:56.58,0:16:58.37,Default,,0,0,0,,I-Iya.
Dialogue: 0,0:16:59.87,0:17:01.29,Default,,0,0,0,,Begitu rupanya.
Dialogue: 0,0:17:01.29,0:17:03.79,Default,,0,0,0,,Dia anak tetangga kami.
Dialogue: 0,0:17:03.79,0:17:05.88,Default,,0,0,0,,Aku melihatnya mengungsi\Nke stasiun bawah tanah.
Dialogue: 0,0:17:05.88,0:17:06.88,Default,,0,0,0,,Benarkah?
Dialogue: 0,0:17:06.88,0:17:09.13,Default,,0,0,0,,Sini tasnya, kamu mengungsi saja.
Dialogue: 0,0:17:09.13,0:17:11.51,Default,,0,0,0,,Baik, terima kasih.
Dialogue: 0,0:17:12.80,0:17:14.72,Default,,0,0,0,,A-Anu, Kak!
Dialogue: 0,0:17:14.72,0:17:15.26,Default,,0,0,0,,Hm?
Dialogue: 0,0:17:15.68,0:17:20.19,Default,,0,0,0,,Tolong sampaikan padanya,\N"Hari ini sangat menyenangkan."
Dialogue: 0,0:17:20.19,0:17:21.81,Default,,0,0,0,,Oke.
Dialogue: 0,0:17:21.81,0:17:25.36,Default,,0,0,0,,Namaku Minami.\NKakak juga hati-hati, ya!
Dialogue: 0,0:17:26.61,0:17:30.70,Default,,0,0,0,,Kamu harus tanggung jawab, Minami.
Dialogue: 0,0:17:33.24,0:17:36.41,Default,,0,0,0,,Lo, Jumbo King?
Dialogue: 0,0:17:46.30,0:17:48.63,Default,,0,0,0,,Apa?
Dialogue: 0,0:17:49.55,0:17:51.51,Default,,0,0,0,,Geli, ih.
Dialogue: 0,0:17:52.47,0:17:55.93,Default,,0,0,0,,JSDF mulai menyerang monster itu!
Dialogue: 0,0:17:55.93,0:17:58.43,Default,,0,0,0,,Tapi tidak berpengaruh!
Dialogue: 0,0:18:02.98,0:18:04.35,Default,,0,0,0,,Dia ke sana?
Dialogue: 0,0:18:11.15,0:18:12.90,Default,,0,0,0,,Di sini berbahaya.
Dialogue: 0,0:18:28.71,0:18:32.34,Default,,0,0,0,,Apa-apaan, sih?\NPadahal aku sedang gembira.
Dialogue: 0,0:18:32.97,0:18:34.68,Default,,0,0,0,,Mengganggu saja.
Dialogue: 0,0:18:44.81,0:18:48.57,Default,,0,0,0,,Kenapa dia melihatku\Ndengan ekspresi itu?
Dialogue: 0,0:18:55.45,0:18:56.49,Default,,0,0,0,,Eh?
Dialogue: 0,0:19:00.54,0:19:03.83,Default,,0,0,0,,Jangan-jangan, saat ini...
Dialogue: 0,0:19:08.96,0:19:12.42,Default,,0,0,0,,Aku makhluk paling jelek sedunia?
Dialogue: 0,0:19:17.18,0:19:18.64,Default,,0,0,0,,Enggak mau.
Dialogue: 0,0:19:18.64,0:19:20.35,Default,,0,0,0,,Enggak mau!
Dialogue: 0,0:19:20.35,0:19:21.93,Default,,0,0,0,,Jangan lihat!
Dialogue: 0,0:19:21.93,0:19:23.85,Default,,0,0,0,,Jangan lihat aku!
Dialogue: 0,0:19:29.23,0:19:32.40,Default,,0,0,0,,Monster raksasa itu menghilang\Nke dasar sungai!
Dialogue: 0,0:19:34.95,0:19:39.41,Default,,0,0,0,,Kami saling bertatapan, kan?
Dialogue: 0,0:19:39.41,0:19:42.87,Default,,0,0,0,,Tunggu, Kurotan!\NGawat, dia hilang!
Dialogue: 0,0:19:43.95,0:19:47.00,Default,,0,0,0,,Jumbo King!\NKamu dari mana saja?
Dialogue: 0,0:19:47.92,0:19:49.67,Default,,0,0,0,,Kamu tahu dia di mana?
Dialogue: 0,0:19:49.67,0:19:51.55,Default,,0,0,0,,Anjing pintar!
Dialogue: 0,0:20:43.35,0:20:46.31,Default,,0,0,0,,Mimpi yang dahsyat.
Dialogue: 0,0:20:47.98,0:20:51.44,Default,,0,0,0,,Kemarin aku tidur jam berapa, ya?
Dialogue: 0,0:20:51.44,0:20:53.90,Default,,0,0,0,,Aku berangkat sekolah, kan?
Dialogue: 0,0:20:55.23,0:20:57.11,Default,,0,0,0,,Pagi.
Dialogue: 0,0:20:57.11,0:20:58.95,Default,,0,0,0,,Kurotan, tubuhmu aman?
Dialogue: 0,0:20:58.95,0:21:00.07,Default,,0,0,0,,Eh? I-Iya.
Dialogue: 0,0:21:00.07,0:21:01.49,Default,,0,0,0,,Syukurlah!
Dialogue: 0,0:21:01.49,0:21:05.29,Default,,0,0,0,,Seragammu kotor, jadi Mama cuci!\NKayak baru, kan?
Dialogue: 0,0:21:05.29,0:21:06.70,Default,,0,0,0,,Ah, terima kasih.
Dialogue: 0,0:21:06.70,0:21:09.08,Default,,0,0,0,,Setelah sekian lama,\NIbu masak panekuk lagi!
Dialogue: 0,0:21:09.08,0:21:10.37,Default,,0,0,0,,Makanlah tanpa nonton TV!
Dialogue: 0,0:21:10.37,0:21:11.92,Default,,0,0,0,,Ho-Hore.
Dialogue: 0,0:21:14.46,0:21:15.67,Default,,0,0,0,,Enak.
Dialogue: 0,0:21:15.67,0:21:18.59,Default,,0,0,0,,Panekuk kemarin juga enak.
Dialogue: 0,0:21:18.59,0:21:19.13,Default,,0,0,0,,Ah!
Dialogue: 0,0:21:19.13,0:21:22.93,Default Above,,0,0,0,,Ini video yang diambil pukul tujuh semalam.
Dialogue: 0,0:21:22.93,0:21:26.52,Default Above,,0,0,0,,Monster raksasa ini\Nmendadak muncul di Sungai Sumida
Dialogue: 0,0:21:26.52,0:21:29.52,Default,,0,0,0,,dan menghilang kembali di Sungai Sumida.
Dialogue: 0,0:21:29.52,0:21:31.48,Default,,0,0,0,,Berdasarkan laporan JSDF...
Dialogue: 0,0:21:40.36,0:21:42.32,Default,,0,0,0,,Wah, seram sekali!
Dialogue: 0,0:21:42.32,0:21:44.57,Default,,0,0,0,,Seperti kejadian dalam gim!
Dialogue: 0,0:21:45.08,0:21:46.95,Default,,0,0,0,,Aku juga lihat dari liputan televisi.
Dialogue: 0,0:21:46.95,0:21:50.21,Default,,0,0,0,,Benar-benar keajaiban\Ntidak ada korban jiwa.
Dialogue: 0,0:21:50.21,0:21:53.96,Default,,0,0,0,,Sebaiknya pemerintah\Nmenanggulanginya dengan cepat.
Dialogue: 0,0:21:53.96,0:21:56.00,Default,,0,0,0,,Kaiju ini mau diberi nama apa?
Dialogue: 0,0:21:56.00,0:21:57.50,Default Above,,0,0,0,,Benar juga.
Dialogue: 0,0:21:57.50,0:21:59.30,Default Above,,0,0,0,,Dia muncul di sekitar Sungai Harumi,
Dialogue: 0,0:21:59.30,0:22:01.51,Default,,0,0,0,,jadi Harugon rasanya cocok.
Dialogue: 0,0:22:01.51,0:22:05.85,Default,,0,0,0,,Tunggu, apa ini?\NKemarin itu bukan mimpi?
Dialogue: 0,0:22:05.85,0:22:07.81,Default,,0,0,0,,Tidak, itu tidak mungkin.
Dialogue: 0,0:22:07.81,0:22:11.18,Default,,0,0,0,,Ternyata sulit menyembunyikannya.
Dialogue: 0,0:22:13.10,0:22:14.23,Default,,0,0,0,,Hah?
Dialogue: 0,0:22:14.23,0:22:17.98,Default,,0,0,0,,Kaiju itu Kurotan, lo!
Dialogue: 0,0:22:17.98,0:22:18.90,Default,,0,0,0,,Ehe.
Dialogue: 0,0:22:18.90,0:22:21.28,Default,,0,0,0,,A-Apa katamu?
Dialogue: 0,0:22:21.28,0:22:23.78,Default,,0,0,0,,Makanya, tidak masuk akal.
Dialogue: 0,0:22:23.78,0:22:27.37,Default,,0,0,0,,Tubuhmu memang berubah\Nmengikuti fluktuasi perasaanmu,
Dialogue: 0,0:22:27.37,0:22:29.33,Default,,0,0,0,,tapi kali ini terlalu abnormal.
Dialogue: 0,0:22:29.33,0:22:32.54,Default,,0,0,0,,Apa ini yang disebut berahi?
Dialogue: 0,0:22:32.96,0:22:38.04,Default,,0,0,0,,Berahi?
Dialogue: 0,0:24:09.26,0:24:10.97,Default,,0,0,0,,Manisan selanjutnya...
Dialogue: 0,0:24:10.97,0:24:11.93,Default,,0,0,0,,Keripik kentang!
Dialogue: 0,0:24:11.93,0:24:14.35,Default,,0,0,0,,Memangnya itu manisan?
