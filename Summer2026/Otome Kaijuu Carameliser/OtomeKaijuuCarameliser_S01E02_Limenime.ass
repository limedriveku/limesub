Dialogue: 0,0:00:02.72,0:00:04.23,Default,,0,0,0,,Kaiju?
Dialogue: 0,0:00:04.82,0:00:06.53,Default,,0,0,0,,Berahi?
Dialogue: 0,0:00:06.53,0:00:10.16,Default,,0,0,0,,Enggak, aku cuma cewek SMA normal.
Dialogue: 0,0:00:26.74,0:00:29.91,Default,,0,0,0,,Ternyata itu memang bukan mimpi!
Dialogue: 0,0:00:43.48,0:00:45.57,Default,,0,0,0,,Kudengar Minami cedera!
Dialogue: 0,0:00:45.57,0:00:47.78,Default,,0,0,0,,Eh, aku khawatir banget!
Dialogue: 0,0:00:47.78,0:00:50.53,Default,,0,0,0,,Katanya dia berada tepat\Ndi sebelah kaiju itu.
Dialogue: 0,0:00:50.53,0:00:52.12,Default,,0,0,0,,- Apa kaiju itu masih ada di sekitar sana?\N- Enggak mungkin.
Dialogue: 0,0:00:52.12,0:00:54.49,Default,,0,0,0,,- Apa kaiju itu masih ada di sekitar sana?\N- Jangan bilang itu salahku?
Dialogue: 0,0:00:54.49,0:00:55.95,Default,,0,0,0,,Ganggu sumpah!
Dialogue: 0,0:00:55.95,0:00:59.12,Default,,0,0,0,,Hei, cederanya Minami separah apa?
Dialogue: 0,0:00:59.12,0:01:00.46,Default,,0,0,0,,Ke-Kenapa tanya tiba-tiba?
Dialogue: 0,0:01:00.46,0:01:02.75,Default,,0,0,0,,Enggak ada hubungannya sama kamu,\NNeng Menhera!
Dialogue: 0,0:01:02.75,0:01:05.42,Default,,0,0,0,,Lagian, kenapa kemarin\Nkamu bareng Minami?
Dialogue: 0,0:01:05.42,0:01:07.38,Default,,0,0,0,,Kalian juga gandengan tangan!
Dialogue: 0,0:01:07.38,0:01:08.01,Default,,0,0,0,,Benar!
Dialogue: 0,0:01:12.01,0:01:14.39,Default,,0,0,0,,Woi, apa-apaan ekspresimu itu?
Dialogue: 0,0:01:14.39,0:01:15.81,Default,,0,0,0,,Jangan kabur!
Dialogue: 0,0:01:15.81,0:01:17.85,Default,,0,0,0,,Tunggu, Neng Menhera!
Dialogue: 0,0:01:29.74,0:01:35.03,Default,,0,0,0,,Andai saja aku tahu alamat surel\Natau nomor teleponnya...
Dialogue: 0,0:01:35.53,0:01:37.93,Default,,0,0,0,,Aku enggak tahu apa-apa tentangnya,
Dialogue: 0,0:01:37.93,0:01:41.37,Default,,0,0,0,,tapi kenapa dadaku serasa mau meledak?
Dialogue: 0,0:01:43.29,0:01:45.42,Default,,0,0,0,,Aku ingin lihat ekspresi tanpa bebannya.
Dialogue: 0,0:01:46.13,0:01:47.92,Default,,0,0,0,,Aku ingin dengar suaranya.
Dialogue: 0,0:01:47.92,0:01:49.80,Default,,0,0,0,,Sekarang juga!
Dialogue: 0,0:01:50.26,0:01:54.22,Default,,0,0,0,,Gawat, kenapa aku\Nsangat ingin menemuinya?
Dialogue: 0,0:01:55.85,0:01:57.22,Default,,0,0,0,,Mi!
Dialogue: 0,0:01:59.68,0:02:01.15,Default,,0,0,0,,Syukurlah.
Dialogue: 0,0:02:01.93,0:02:04.23,Default,,0,0,0,,Dia tampak sehat!
Dialogue: 0,0:02:08.69,0:02:11.11,Default,,0,0,0,,Apa ini yang disebut berahi?
Dialogue: 0,0:02:11.11,0:02:12.61,Default,,0,0,0,,Bukan!
Dialogue: 0,0:02:12.61,0:02:17.74,Default,,0,0,0,,Tapi, kalau tubuhku bereaksi dengan sendirinya\Ndan berubah menjadi wujud itu,
Dialogue: 0,0:02:17.74,0:02:21.50,Default,,0,0,0,,aku enggak boleh dekat-dekat\Ndengan Minami Arata!
Dialogue: 0,0:02:25.04,0:02:26.46,Default,,0,0,0,,Minami!
Dialogue: 0,0:02:26.46,0:02:27.34,Default,,0,0,0,,Eh?
Dialogue: 0,0:02:27.72,0:02:28.96,Default,,0,0,0,,Kamu tidak apa-apa?
Dialogue: 0,0:02:28.96,0:02:30.51,Default,,0,0,0,,Bagaimana kondisi cederamu?
Dialogue: 0,0:02:30.51,0:02:32.38,Default,,0,0,0,,Sudah tidak apa-apa.
Dialogue: 0,0:02:32.38,0:02:33.67,Default,,0,0,0,,Syukurlah!
Dialogue: 0,0:02:33.67,0:02:36.97,Default,,0,0,0,,Dadaku serasa mau meledak!
Dialogue: 0,0:04:18.53,0:04:20.45,Default,,0,0,0,,Pacarnya?
Dialogue: 0,0:04:21.28,0:04:22.91,Default,,0,0,0,,Sudah kuduga!
Dialogue: 0,0:04:22.91,0:04:24.79,Default,,0,0,0,,Mana mungkin dia enggak punya pacar!
Dialogue: 0,0:04:24.79,0:04:27.04,Default,,0,0,0,,Soalnya dia cowok paling beken di sekolah!
Dialogue: 0,0:04:27.04,0:04:30.63,Default,,0,0,0,,Aku yang barusan sedikit nangis\Nbenar-benar menjijikkan.
Dialogue: 0,0:04:30.63,0:04:32.46,Default,,0,0,0,,Jijik...
Dialogue: 0,0:04:32.46,0:04:34.00,Default,,0,0,0,,Akaishi!
Dialogue: 0,0:04:34.00,0:04:35.63,Default,,0,0,0,,Syukurlah!\NKamu enggak apa-apa!
Dialogue: 0,0:04:35.63,0:04:36.34,Default,,0,0,0,,Jangan mendekat!
Dialogue: 0,0:04:36.34,0:04:38.80,Default,,0,0,0,,Jangan pernah dekat-dekat aku lagi!
Dialogue: 0,0:04:43.43,0:04:44.81,Default,,0,0,0,,Begini sudah benar.
Dialogue: 0,0:04:45.39,0:04:47.02,Default,,0,0,0,,Ini pilihan terbaik.
Dialogue: 0,0:04:50.73,0:04:52.15,Default,,0,0,0,,Minami.
Dialogue: 0,0:04:52.15,0:04:54.27,Default,,0,0,0,,Cederamu enggak apa-apa?
Dialogue: 0,0:04:54.27,0:04:55.73,Default,,0,0,0,,Iya, enggak apa-apa.
Dialogue: 0,0:04:55.73,0:04:56.98,Default,,0,0,0,,Cuma lecet sedikit.
Dialogue: 0,0:04:57.44,0:04:58.69,Default,,0,0,0,,Aku khawatir, tahu!
Dialogue: 0,0:04:58.69,0:05:00.53,Default,,0,0,0,,Kamu betulan lihat kaiju itu dari dekat?
Dialogue: 0,0:05:00.53,0:05:02.49,Default,,0,0,0,,Padahal biasanya cewek-cewek itu berisik.
Dialogue: 0,0:05:02.49,0:05:04.24,Default,,0,0,0,,Aku bersyukur banget hari ini.
Dialogue: 0,0:05:04.24,0:05:06.12,Default,,0,0,0,,Duduk di bangku masing-masing.
Dialogue: 0,0:05:07.58,0:05:09.66,Default,,0,0,0,,Buka halaman 30.
Dialogue: 0,0:05:21.47,0:05:23.14,Default,,0,0,0,,Wah, ada Neng Manatsu.
Dialogue: 0,0:05:23.14,0:05:24.60,Default,,0,0,0,,Imutnya!
Dialogue: 0,0:05:24.60,0:05:26.60,Default,,0,0,0,,Aku juga ingin sekelas dengannya!
Dialogue: 0,0:05:26.60,0:05:28.39,Default,,0,0,0,,Hei, sapa dia.
Dialogue: 0,0:05:28.39,0:05:30.56,Default,,0,0,0,,Ogah, kamu saja.
Dialogue: 0,0:05:41.53,0:05:43.45,Default,,0,0,0,,Kenapa di saat seperti ini?
Dialogue: 0,0:05:43.45,0:05:45.99,Default,,0,0,0,,Padahal mentalku stabil!
Dialogue: 0,0:05:45.99,0:05:49.95,Default,,0,0,0,,Duh, semuanya gara-gara dia!
Dialogue: 0,0:05:51.54,0:05:53.29,Default,,0,0,0,,Kurotan!
Dialogue: 0,0:05:56.54,0:06:00.13,Default,,0,0,0,,Ibu sudah mengkhawatirkanmu sejak pagi.
Dialogue: 0,0:06:00.13,0:06:01.84,Default,,0,0,0,,Bunga sakuranya indah, ya.
Dialogue: 0,0:06:01.84,0:06:03.51,Default,,0,0,0,,Rasanya jadi ingin melihat bunga!
Dialogue: 0,0:06:03.51,0:06:05.60,Default,,0,0,0,,Untung enggak kamu injak sampai hancur.
Dialogue: 0,0:06:05.60,0:06:08.89,Default,,0,0,0,,Aku berubah jadi kaiju raksasa, tahu.
Dialogue: 0,0:06:08.89,0:06:11.93,Default,,0,0,0,,Bukannya sebaiknya aku\Ndisembunyikan di suatu tempat?
Dialogue: 0,0:06:11.93,0:06:15.19,Default,,0,0,0,,Seperti biasa saja enggak apa-apa.
Dialogue: 0,0:06:15.19,0:06:18.65,Default,,0,0,0,,Mau jadi kaiju raksasa sekalipun,\Nkamu tetaplah putriku.
Dialogue: 0,0:06:21.74,0:06:23.20,Default,,0,0,0,,Orang aneh.
Dialogue: 0,0:06:23.20,0:06:25.11,Default,,0,0,0,,Banyak yang bilang begitu.
Dialogue: 0,0:06:26.20,0:06:27.83,Default,,0,0,0,,Enggak perlu khawatir!
Dialogue: 0,0:06:27.83,0:06:29.83,Default,,0,0,0,,Ibu yang akan melindungimu!
Dialogue: 0,0:06:30.45,0:06:32.58,Default,,0,0,0,,Hei, Jumbo King!
Dialogue: 0,0:06:37.67,0:06:40.30,Default,,0,0,0,,Enggak perlu khawatir?
Dialogue: 0,0:06:43.63,0:06:46.39,Default,,0,0,0,,Aku enggak akan berubah\Njadi kaiju lagi, kan?
Dialogue: 0,0:06:46.89,0:06:50.67,Default,,0,0,0,,Karena perasaan seperti itu\Nenggak akan terulang lagi.
Dialogue: 0,0:06:52.85,0:06:55.21,Default,,0,0,0,,"Cepatlah mengecil!"
Dialogue: 0,0:06:55.90,0:06:58.06,Default,,0,0,0,,Di saat itu, ekor ini
Dialogue: 0,0:06:58.48,0:07:00.44,Default,,0,0,0,,dan rasa sakit mungil ini
Dialogue: 0,0:07:00.44,0:07:03.23,Default,,0,0,0,,akan hilang seluruhnya.
Dialogue: 0,0:07:06.49,0:07:08.49,Default,,0,0,0,,Pikirku begitu.
Dialogue: 0,0:07:08.49,0:07:10.99,Default,,0,0,0,,Ekor ini batu banget, sumpah!
Dialogue: 0,0:07:10.99,0:07:13.20,Default,,0,0,0,,Kapan mau hilangnya?
Dialogue: 0,0:07:16.00,0:07:18.04,Default,,0,0,0,,Enggak bisa tidur.
Dialogue: 0,0:07:22.88,0:07:23.84,Default,,0,0,0,,Eh?
Dialogue: 0,0:07:24.38,0:07:27.39,Default,,0,0,0,,Jangan-jangan itu...
Dialogue: 0,0:07:27.39,0:07:30.01,Default,,0,0,0,,Ada kaiju yang datang kemari?
Dialogue: 0,0:07:31.47,0:07:34.10,Default,,0,0,0,,Dia datang untuk mengalahkanku?
Dialogue: 0,0:07:37.60,0:07:39.23,Default,,0,0,0,,Aku harus melakukan sesuatu.
Dialogue: 0,0:07:39.23,0:07:42.78,Default,,0,0,0,,Atau aku akan mengancam\Nkehidupan rakyat sipil lagi.
Dialogue: 0,0:07:49.49,0:07:53.87,Default,,0,0,0,,Kebetulan banget, Akaishi Kuroe.
Dialogue: 0,0:07:59.67,0:08:01.50,Default,,0,0,0,,Pacarnya Minami Arata?
Dialogue: 0,0:08:01.50,0:08:03.25,Default,,0,0,0,,Kenapa dia tahu namaku?
Dialogue: 0,0:08:03.67,0:08:05.26,Default,,0,0,0,,Enggak, sebelum itu...
Dialogue: 0,0:08:05.92,0:08:08.51,Default,,0,0,0,,Kamu sedang apa?
Dialogue: 0,0:08:08.51,0:08:10.51,Default,,0,0,0,,Aku sedang menunggu.
Dialogue: 0,0:08:10.51,0:08:12.01,Default,,0,0,0,,Menunggu apa?
Dialogue: 0,0:08:12.01,0:08:17.98,Default,,0,0,0,,Dia menyuruh pacarnya memakai kostum aneh\Ndan keluyuran tengah malam?
Dialogue: 0,0:08:17.98,0:08:20.73,Default,,0,0,0,,Beliau sungguh sosok yang menakjubkan.
Dialogue: 0,0:08:20.73,0:08:22.44,Default,,0,0,0,,Wajahnya yang laki banget...
Dialogue: 0,0:08:22.44,0:08:24.02,Default,,0,0,0,,Tubuhnya yang kekar...
Dialogue: 0,0:08:24.02,0:08:25.48,Default,,0,0,0,,Tu-Tubuh?
Dialogue: 0,0:08:25.48,0:08:27.32,Default,,0,0,0,,Mata merah yang membara panas!
Dialogue: 0,0:08:27.32,0:08:30.66,Default,,0,0,0,,Kulit bak baju zirahnya yang seperti\Ndaratan neraka!
Dialogue: 0,0:08:30.66,0:08:31.28,Default,,0,0,0,,Eh?
Dialogue: 0,0:08:31.28,0:08:33.58,Default,,0,0,0,,Raungan yang memecah heningnya malam!
Dialogue: 0,0:08:33.58,0:08:36.08,Default,,0,0,0,,Kurasakan romansa dalam hatiku!
Dialogue: 0,0:08:36.08,0:08:37.66,Default,,0,0,0,,Aku ingin bertemu dengannya!
Dialogue: 0,0:08:37.66,0:08:39.50,Default,,0,0,0,,Dengan Harugon!
Dialogue: 0,0:08:39.50,0:08:41.71,Default,,0,0,0,,Eh?
Dialogue: 0,0:08:42.46,0:08:44.13,Default,,0,0,0,,Haru... gon?
Dialogue: 0,0:08:44.13,0:08:45.30,Default,,0,0,0,,Iya!
Dialogue: 0,0:08:47.17,0:08:48.97,Default,,0,0,0,,Dia ingin ketemu denganku?
Dialogue: 0,0:08:48.97,0:08:54.97,Default,,0,0,0,,Karena pekerjaan ayahku, sejak kecil\Nhidupku selalu dikelilingi kaiju.
Dialogue: 0,0:08:54.97,0:08:58.31,Default Above,,0,0,0,,Mereka keluarga sekaligus\Nsahabatku yang berharga.
Dialogue: 0,0:08:58.31,0:09:01.19,Default Above,,0,0,0,,Selama ini, aku hanya bisa\Nmencintai mereka dalam bentuk fiksi.
Dialogue: 0,0:09:01.19,0:09:04.65,Default,,0,0,0,,Tapi, akhirnya fiksi berubah menjadi nyata.
Dialogue: 0,0:09:04.65,0:09:09.61,Default,,0,0,0,,Tapi, mungkin karena pemalu,\NHarugon langsung menghilang.
Dialogue: 0,0:09:09.61,0:09:13.70,Default,,0,0,0,,Aku belum pernah melihatnya\Ndengan mata kepalaku sendiri.
Dialogue: 0,0:09:13.70,0:09:15.37,Default,,0,0,0,,Aku tidak mau menyerah!
Dialogue: 0,0:09:15.37,0:09:19.33,Default,,0,0,0,,Aku akan selamanya menunggu di sini\Nsampai dia muncul!
Dialogue: 0,0:09:19.33,0:09:21.00,Default,,0,0,0,,Dengan kostum itu?
Dialogue: 0,0:09:21.00,0:09:22.88,Default,,0,0,0,,Ini kantung tidur buatanku sendiri!
Dialogue: 0,0:09:22.88,0:09:26.13,Default,,0,0,0,,Jadi, hari ini kamu bareng Minami...
Dialogue: 0,0:09:26.13,0:09:27.96,Default,,0,0,0,,Untuk bertanya pendapatnya.
Dialogue: 0,0:09:27.96,0:09:32.09,Default,,0,0,0,,Karena dia salah sedikit orang\Nyang melihat Harugon dari jarak dekat.
Dialogue: 0,0:09:32.09,0:09:34.01,Default,,0,0,0,,Kalian enggak pacaran?
Dialogue: 0,0:09:34.01,0:09:35.39,Default,,0,0,0,,Apa yang kamu bicarakan?
Dialogue: 0,0:09:35.39,0:09:37.64,Default,,0,0,0,,Soalnya kamu nempel banget padanya...
Dialogue: 0,0:09:37.64,0:09:41.39,Default,,0,0,0,,Karena aku sangat ingin mendapatkan\Ninformasi soal Harugon.
Dialogue: 0,0:09:41.39,0:09:45.31,Default,,0,0,0,,Contoh, kayak baunya Harugon...
Dialogue: 0,0:09:45.31,0:09:47.78,Default,,0,0,0,,Jumlah benjolan di ekornya...
Dialogue: 0,0:09:47.78,0:09:50.99,Default,,0,0,0,,Aku ingin tahu segalanya tentang dia!
Dialogue: 0,0:09:50.99,0:09:53.53,Default,,0,0,0,,Aku ingin diinjak olehnya!
Dialogue: 0,0:09:53.53,0:09:54.45,Default,,0,0,0,,Ngeri!
Dialogue: 0,0:09:55.32,0:09:58.49,Default,,0,0,0,,Aku juga ingin bertanya banyak hal padamu.
Dialogue: 0,0:09:58.49,0:09:59.29,Default,,0,0,0,,Eh?
Dialogue: 0,0:09:59.29,0:10:03.50,Default,,0,0,0,,Tapi, kamu langsung melangkah pergi\Ndengan buru-buru.
Dialogue: 0,0:10:03.50,0:10:07.25,Default,,0,0,0,,Kita yang bertemu di sini\Npastilah sebuah takdir!
Dialogue: 0,0:10:08.13,0:10:11.55,Default,,0,0,0,,Ternyata bukan pacar, ya?
Dialogue: 0,0:10:12.13,0:10:14.97,Default,,0,0,0,,Enggak, enggak.\NKenapa aku malah senang?
Dialogue: 0,0:10:14.97,0:10:17.26,Default,,0,0,0,,Jangan dekati aku lagi!
Dialogue: 0,0:10:17.26,0:10:18.39,Default,,0,0,0,,Aku sudah bilang begitu.
Dialogue: 0,0:10:18.39,0:10:21.10,Default,,0,0,0,,Pastinya dia sudah membenciku.
Dialogue: 0,0:10:21.10,0:10:24.35,Default,,0,0,0,,Halo, halo.\NKamu tidak boleh tidur di sini.
Dialogue: 0,0:10:24.77,0:10:27.82,Default,,0,0,0,,Kalian masih di bawah umur, kan?\NCepat pulang.
Dialogue: 0,0:10:27.82,0:10:29.32,Default,,0,0,0,,Enggak mau.
Dialogue: 0,0:10:29.32,0:10:30.82,Default,,0,0,0,,Iya, iya.
Dialogue: 0,0:10:30.82,0:10:34.03,Default,,0,0,0,,- Ikut aku ke pos polisi.\N- Enggak! Enggak mau!
Dialogue: 0,0:10:34.03,0:10:36.20,Default,,0,0,0,,Aku enggak mau pulang\Nsebelum bertemu Harugon!
Dialogue: 0,0:10:36.20,0:10:38.62,Default,,0,0,0,,- Paham, kaiju kan memang keren.\N- Lepaskan aku!
Dialogue: 0,0:10:38.62,0:10:41.66,Default,,0,0,0,,Hari ini dia enggak akan muncul!
Dialogue: 0,0:10:42.20,0:10:44.83,Default,,0,0,0,,Malahan, dia enggak akan muncul\Nuntuk sementara waktu.
Dialogue: 0,0:10:44.83,0:10:47.33,Default,,0,0,0,,Kenapa kamu bisa tahu?
Dialogue: 0,0:10:47.33,0:10:49.17,Default,,0,0,0,,Oh, iya!
Dialogue: 0,0:10:49.17,0:10:51.55,Default,,0,0,0,,Minami bilang begini!
Dialogue: 0,0:10:51.55,0:10:56.39,Default,,0,0,0,,"Waktu Harugon hendak muncul,\Nkamu tiba-tiba langsung lari menjauh!"
Dialogue: 0,0:10:56.39,0:10:59.22,Default,,0,0,0,,Apa kamu merasakan firasat\Nsaat kaiju hendak muncul?
Dialogue: 0,0:10:59.22,0:11:02.35,Default,,0,0,0,,Enggak, kamu menerima\Ntelepati dari Harugon?
Dialogue: 0,0:11:02.35,0:11:05.06,Default,,0,0,0,,Kamu bisa berkomunikasi\Ndengannya lewat telepati?
Dialogue: 0,0:11:05.06,0:11:08.36,Default,,0,0,0,,Seperti sosok khusus yang bisa berkomunikasi
Dialogue: 0,0:11:08.36,0:11:11.11,Default,,0,0,0,,dengan para kaiju di serial tokusatsu?
Dialogue: 0,0:11:11.11,0:11:13.44,Default,,0,0,0,,Jangan-jangan, kamu...
Dialogue: 0,0:11:13.44,0:11:15.91,Default,,0,0,0,,Miko Harugon?
Dialogue: 0,0:11:24.41,0:11:27.54,Default,,0,0,0,,Ah, bisa jadi.
Dialogue: 0,0:11:28.29,0:11:29.25,Default,,0,0,0,,Sudah kuduga!
Dialogue: 0,0:11:29.25,0:11:31.80,Default,,0,0,0,,Apa kamu bisa memanggil Harugon?
Dialogue: 0,0:11:31.80,0:11:37.97,Default,,0,0,0,,Kayaknya dia lagi kelelahan\Ndan malas keluar...
Dialogue: 0,0:11:37.97,0:11:40.10,Default,,0,0,0,,Begitu, ya.
Dialogue: 0,0:11:40.10,0:11:41.51,Default,,0,0,0,,Maaf, ya.
Dialogue: 0,0:11:41.51,0:11:42.43,Default,,0,0,0,,Enggak apa-apa.
Dialogue: 0,0:11:42.43,0:11:45.06,Default,,0,0,0,,Aku enggak mau memaksanya.
Dialogue: 0,0:11:45.06,0:11:50.40,Default,,0,0,0,,Tapi, kalau dia mau menunjukkan diri,\Ntolong beri tahu aku.
Dialogue: 0,0:11:51.52,0:11:53.15,Default,,0,0,0,,Nona Manatsu.
Dialogue: 0,0:11:53.15,0:11:56.65,Default,,0,0,0,,Aduh, jemputanku sudah datang.
Dialogue: 0,0:11:56.65,0:11:59.37,Default,,0,0,0,,Besok kita mengobrol lebih banyak lagi ya,
Dialogue: 0,0:11:59.37,0:12:01.24,Default,,0,0,0,,Akaishi Kuroe.
Dialogue: 0,0:12:01.24,0:12:03.33,Default,,0,0,0,,Sehat selalu!
Dialogue: 0,0:12:07.50,0:12:09.88,Default,,0,0,0,,Apa-apaan yang barusan itu?
Dialogue: 0,0:12:09.88,0:12:14.00,Default,,0,0,0,,Aku tidak paham pola pikir\Nanak zaman sekarang.
Dialogue: 0,0:12:17.59,0:12:20.55,Default,,0,0,0,,Pada akhirnya, ekorku enggak mau hilang.
Dialogue: 0,0:12:22.39,0:12:23.97,Default,,0,0,0,,Selamat pagi.
Dialogue: 0,0:12:23.97,0:12:27.23,Default,,0,0,0,,Terima kasih untuk malam\Nyang menyenangkan kemarin.
Dialogue: 0,0:12:27.23,0:12:31.61,Default,,0,0,0,,Aku sangat senang karena bisa akrab\Ndengan Miko Harugon.
Dialogue: 0,0:12:31.61,0:12:33.44,Default,,0,0,0,,Sekarang aku masih cenat-cenut!
Dialogue: 0,0:12:33.44,0:12:34.32,Default,,0,0,0,,Iya.
Dialogue: 0,0:12:34.32,0:12:37.40,Default,,0,0,0,,Apa mulai sekarang aku boleh\Nmemanggilmu Kuroe?
Dialogue: 0,0:12:37.40,0:12:41.12,Default,,0,0,0,,Kamu juga boleh memanggilku Manatsu.
Dialogue: 0,0:12:41.12,0:12:42.99,Default,,0,0,0,,I-Iya.
Dialogue: 0,0:12:47.08,0:12:49.54,Default,,0,0,0,,Apa kamu tertarik pada Minami?
Dialogue: 0,0:12:49.54,0:12:51.38,Default,,0,0,0,,Eng-Enggak!
Dialogue: 0,0:12:51.38,0:12:54.00,Default,,0,0,0,,Dia sudah punya pacar atau belum, ya?
Dialogue: 0,0:12:54.00,0:12:56.67,Default,,0,0,0,,E-Entahlah, aku juga enggak mau tahu.
Dialogue: 0,0:12:56.67,0:13:00.38,Default,,0,0,0,,Kamu itu peri cinta antara\Naku dan Harugon.
Dialogue: 0,0:13:00.38,0:13:02.89,Default,,0,0,0,,Aku juga ingin membantumu.
Dialogue: 0,0:13:02.89,0:13:03.55,Default,,0,0,0,,Eh?
Dialogue: 0,0:13:03.55,0:13:05.10,Default,,0,0,0,,Minami.
Dialogue: 0,0:13:05.81,0:13:09.02,Default,,0,0,0,,Apa kamu sudah punya pacar?
Dialogue: 0,0:13:12.35,0:13:13.19,Default,,0,0,0,,Belum.
Dialogue: 0,0:13:14.69,0:13:15.98,Default,,0,0,0,,Tapi...
Dialogue: 0,0:13:15.98,0:13:18.24,Default,,0,0,0,,Ada orang yang kusuka.
Dialogue: 0,0:13:37.17,0:13:38.88,Default,,0,0,0,,Ada orang yang kusuka.
Dialogue: 0,0:13:42.13,0:13:43.76,Default,,0,0,0,,Kuroe!
Dialogue: 0,0:13:47.43,0:13:49.60,Default,,0,0,0,,Gawat, gawat.
Dialogue: 0,0:13:51.06,0:13:52.06,Default,,0,0,0,,Kuroe.
Dialogue: 0,0:13:52.06,0:13:56.07,Default,,0,0,0,,Selamat, ya!\NMinami masih lajang!
Dialogue: 0,0:13:56.57,0:13:58.57,Default,,0,0,0,,Dia juga memperhatikanmu.
Dialogue: 0,0:13:58.57,0:14:00.61,Default,,0,0,0,,Jangan lakukan hal yang enggak perlu!
Dialogue: 0,0:14:01.65,0:14:06.24,Default,,0,0,0,,Dia enggak tahu apa-apa tentangku.
Dialogue: 0,0:14:06.66,0:14:10.37,Default,,0,0,0,,Karena ujung-ujungnya sengsara,\Naku tidak mau jatuh cinta!
Dialogue: 0,0:14:12.92,0:14:14.08,Default,,0,0,0,,Apa?
Dialogue: 0,0:14:14.75,0:14:17.88,Default,,0,0,0,,Di matamu ada lambang hati\Nyang membara.
Dialogue: 0,0:14:17.88,0:14:18.92,Default,,0,0,0,,Eh?
Dialogue: 0,0:14:18.92,0:14:22.13,Default,,0,0,0,,Aku juga mengerti karena\Nsedang jatuh cinta.
Dialogue: 0,0:14:22.13,0:14:25.26,Default,,0,0,0,,Ayo cintai diri kita sendiri\Nyang sedang jatuh cinta.
Dialogue: 0,0:14:26.05,0:14:28.97,Default,,0,0,0,,Dengan begitu, apa pun hasilnya nanti,
Dialogue: 0,0:14:28.97,0:14:31.48,Default,,0,0,0,,kita akan tetap bisa tersenyum.
Dialogue: 0,0:14:31.98,0:14:32.68,Default,,0,0,0,,Benar.
Dialogue: 0,0:14:32.68,0:14:36.36,Default,,0,0,0,,Meski tubuhku akan\Nhangus terbakar nantinya!
Dialogue: 0,0:14:36.36,0:14:39.02,Default,,0,0,0,,Aku enggak akan melakukan itu!\NMungkin.
Dialogue: 0,0:14:39.02,0:14:42.86,Default,,0,0,0,,Kalau bersedia, apa kamu mau mampir\Nke rumahku sepulang sekolah?
Dialogue: 0,0:14:42.86,0:14:43.57,Default,,0,0,0,,Eh?
Dialogue: 0,0:14:43.57,0:14:47.20,Default,,0,0,0,,Ayo nonton film kaiju\Nsambil makan camilan enak.
Dialogue: 0,0:14:47.20,0:14:49.62,Default,,0,0,0,,Kamu akan merasa bersemangat.
Dialogue: 0,0:14:57.79,0:14:59.59,Default,,0,0,0,,Hentikan Minami!
Dialogue: 0,0:15:05.09,0:15:07.80,Default,,0,0,0,,Mana mungkin dia menyukaiku.
Dialogue: 0,0:15:09.39,0:15:11.14,Default,,0,0,0,,Cuma lihat dari samping lagi?
Dialogue: 0,0:15:11.14,0:15:13.35,Default,,0,0,0,,Setidaknya bantu beres-beres.
Dialogue: 0,0:15:13.98,0:15:15.69,Default,,0,0,0,,Apa boleh buat.
Dialogue: 0,0:15:15.69,0:15:17.56,Default,,0,0,0,,Ekorku lagi keluar.
Dialogue: 0,0:15:21.61,0:15:22.78,Default,,0,0,0,,Eh, apa?
Dialogue: 0,0:15:22.78,0:15:24.78,Default,,0,0,0,,Kerja bagus sudah salah sangka.
Dialogue: 0,0:15:24.78,0:15:27.66,Default,,0,0,0,,Minami itu baik ke semua orang.
Dialogue: 0,0:15:27.66,0:15:30.83,Default,,0,0,0,,Dia menghiburmu karena\Nmelihat kamu yang penyendiri.
Dialogue: 0,0:15:30.83,0:15:33.04,Default,,0,0,0,,Mana mungkin tertarik\Nsama cewek jelek suram!
Dialogue: 0,0:15:34.45,0:15:37.96,Default,,0,0,0,,Aku yang paling tahu soal itu.
Dialogue: 0,0:15:37.96,0:15:39.50,Default,,0,0,0,,Hah?\NKamu bicara sesuatu?
Dialogue: 0,0:15:39.50,0:15:43.59,Default,,0,0,0,,Aku juga sadar enggak boleh\Njatuh cinta pada seseorang!
Dialogue: 0,0:15:45.22,0:15:47.84,Default,,0,0,0,,Apa-apaan dia?\NNgamuk di dalam?
Dialogue: 0,0:15:47.84,0:15:50.18,Default,,0,0,0,,Malah kamu yang harusnya sadar diri!
Dialogue: 0,0:15:50.18,0:15:51.31,Default,,0,0,0,,Ayo pergi!
Dialogue: 0,0:15:51.31,0:15:52.56,Default,,0,0,0,,Iya.
Dialogue: 0,0:15:53.97,0:15:56.31,Default,,0,0,0,,Mu-Mustahil...
Dialogue: 0,0:16:00.15,0:16:02.02,Default,,0,0,0,,Akaishi pergi ke mana?
Dialogue: 0,0:16:02.02,0:16:04.74,Default,,0,0,0,,Dia sakit dan pergi ke UKS.
Dialogue: 0,0:16:04.74,0:16:06.24,Default,,0,0,0,,Benarkah?
Dialogue: 0,0:16:09.20,0:16:11.03,Default,,0,0,0,,Permisi.
Dialogue: 0,0:16:11.78,0:16:13.54,Default,,0,0,0,,Dadah, Minami!
Dialogue: 0,0:16:13.54,0:16:14.49,Default,,0,0,0,,Iya!
Dialogue: 0,0:16:14.49,0:16:15.75,Default,,0,0,0,,Minami.
Dialogue: 0,0:16:16.46,0:16:18.79,Default,,0,0,0,,Apa kamu melihat Kuroe?
Dialogue: 0,0:16:18.79,0:16:21.38,Default,,0,0,0,,Aku janji pulang bersama dengannya.
Dialogue: 0,0:16:21.38,0:16:24.88,Default,,0,0,0,,Aku juga sedang mencarinya.\NMungkin dia sudah pulang?
Dialogue: 0,0:16:24.88,0:16:28.59,Default,,0,0,0,,Wah, aneh, ya.\NSepatu luar ruangannya masih ada.
Dialogue: 0,0:16:28.59,0:16:30.26,Default,,0,0,0,,Tuh, enggak bisa dibuka, kan?
Dialogue: 0,0:16:30.26,0:16:32.72,Default,,0,0,0,,Seperti ada yang mengganjal.
Dialogue: 0,0:16:32.72,0:16:35.06,Default,,0,0,0,,Besok kita harus minta teknisi datang.
Dialogue: 0,0:16:36.52,0:16:38.31,Default,,0,0,0,,Aman!
Dialogue: 0,0:16:38.31,0:16:41.23,Default,,0,0,0,,Kalau wujudku yang begini\Nsampai kelihatan, tamat riwayatku!
Dialogue: 0,0:16:41.23,0:16:43.65,Default,,0,0,0,,Tapi, kalau begini,\Naku enggak bisa keluar.
Dialogue: 0,0:16:43.65,0:16:47.03,Default,,0,0,0,,Bagaimana kalau aku\Nenggak kembali seperti semula?
Dialogue: 0,0:16:47.40,0:16:50.07,Default,,0,0,0,,Apa aku akan dikarantina\Ndan dikirim ke pusat penelitian?
Dialogue: 0,0:16:50.07,0:16:53.53,Default,,0,0,0,,Aku juga enggak tahu kapan bakal\Nberubah jadi kaiju dan mengamuk.
Dialogue: 0,0:16:53.53,0:16:56.04,Default,,0,0,0,,Jadi berita heboh berskala dunia!
Dialogue: 0,0:16:56.70,0:17:00.92,Default,,0,0,0,,Apa ekspresinya akan seperti itu lagi?
Dialogue: 0,0:17:05.75,0:17:08.84,Default,,0,0,0,,Padahal lebih baik kalau dia\Nmemandangku sebagai cewek jelek suram.
Dialogue: 0,0:17:12.80,0:17:15.18,Default,,0,0,0,,Apa Akaishi kita bebaskan sekarang saja?
Dialogue: 0,0:17:15.18,0:17:17.47,Default,,0,0,0,,Ah, si Neng Menhera?
Dialogue: 0,0:17:17.47,0:17:19.60,Default,,0,0,0,,Dia masih di gudang olahraga, kan?
Dialogue: 0,0:17:19.60,0:17:23.40,Default,,0,0,0,,Kuncinya sudah kita kembalikan.\NAnak ekskul voli pasti sudah membebaskannya.
Dialogue: 0,0:17:25.36,0:17:28.74,Default,,0,0,0,,Apa yang sudah kalian lakukan?
Dialogue: 0,0:17:28.74,0:17:31.57,Default,,0,0,0,,Kuroe itu Miko Harugon yang mahasuci!
Dialogue: 0,0:17:31.57,0:17:34.99,Default,,0,0,0,,Beliau pasti akan muncul kembali\Ndengan penuh amarah!
Dialogue: 0,0:17:34.99,0:17:36.74,Default,,0,0,0,,Apa-apaan dia?
Dialogue: 0,0:17:36.74,0:17:38.04,Default,,0,0,0,,Sinting.
Dialogue: 0,0:17:38.04,0:17:43.92,Default,,0,0,0,,Kalau masih sayang nyawa,\Ncepat minta maaf padanya dan enyah dari sini!
Dialogue: 0,0:17:43.92,0:17:47.13,Default,,0,0,0,,Kami cuma memberitahunya\Nkarena dia salah paham!
Dialogue: 0,0:17:47.13,0:17:50.51,Default,,0,0,0,,Kasihan Minami diganggu terus\Nsama cewek jelek!
Dialogue: 0,0:17:52.63,0:17:54.01,Default,,0,0,0,,Jahat.
Dialogue: 0,0:17:56.47,0:17:58.14,Default,,0,0,0,,Kalian jahat.
Dialogue: 0,0:17:59.10,0:18:00.06,Default,,0,0,0,,Aku
Dialogue: 0,0:18:01.18,0:18:03.35,Default,,0,0,0,,takut dibenci.
Dialogue: 0,0:18:03.35,0:18:05.36,Default,,0,0,0,,Jadi pasang muka baik hati ke semua orang.
Dialogue: 0,0:18:05.36,0:18:08.65,Default,,0,0,0,,Aku bahkan tidak sadar\Nada gadis yang tersakiti karena itu.
Dialogue: 0,0:18:09.40,0:18:12.99,Default,,0,0,0,,Aku akan berhenti bersikap baik\Nke semua orang.
Dialogue: 0,0:18:13.61,0:18:16.16,Default,,0,0,0,,Karena aku sudah punya gadis\Nyang paling kusayangi!
Dialogue: 0,0:18:22.83,0:18:27.67,Default,,0,0,0,,Masa depan Tokyo bergantung padamu, Minami.
Dialogue: 0,0:18:31.05,0:18:32.51,Default,,0,0,0,,Akaishi!
Dialogue: 0,0:18:32.51,0:18:34.05,Default,,0,0,0,,Akaishi, kamu di dalam?
Dialogue: 0,0:18:35.55,0:18:36.43,Default,,0,0,0,,Akaishi...
Dialogue: 0,0:18:38.72,0:18:41.43,Default,,0,0,0,,- Sakit...\N- Maaf, kamu lihat sesuatu?
Dialogue: 0,0:18:41.43,0:18:43.10,Default,,0,0,0,,Gelap, jadi enggak lihat apa-apa.
Dialogue: 0,0:18:43.10,0:18:45.73,Default,,0,0,0,,Be-Begitu, ya.\NSyukurlah.
Dialogue: 0,0:18:45.73,0:18:47.23,Default,,0,0,0,,Apa aku boleh masuk?
Dialogue: 0,0:18:47.23,0:18:49.69,Default,,0,0,0,,Pokoknya enggak boleh!
Dialogue: 0,0:18:52.65,0:18:55.45,Default,,0,0,0,,Kalau begitu, apa kamu mau dengar\Nucapanku dari dalam sana?
Dialogue: 0,0:18:56.49,0:19:01.87,Default,,0,0,0,,Waktu kita ke kedai panekuk tempo hari,\Naku bilangnya diajak teman,
Dialogue: 0,0:19:01.87,0:19:02.87,Default,,0,0,0,,tapi...
Dialogue: 0,0:19:03.33,0:19:04.33,Default,,0,0,0,,Itu bohong.
Dialogue: 0,0:19:08.38,0:19:11.05,Default,,0,0,0,,Sejak awal, aku memang ingin\Npergi bersamamu.
Dialogue: 0,0:19:11.88,0:19:14.42,Default,,0,0,0,,Aku ingin tahu lebih banyak tentangmu,
Dialogue: 0,0:19:14.80,0:19:16.72,Default,,0,0,0,,jadi aku membeli dua tiket.
Dialogue: 0,0:19:18.10,0:19:19.97,Default,,0,0,0,,Syukurlah aku memberanikan diri.
Dialogue: 0,0:19:21.68,0:19:23.60,Default,,0,0,0,,Ucapanmu waktu itu
Dialogue: 0,0:19:24.06,0:19:26.44,Default,,0,0,0,,mungkin akan kuingat seumur hidup.
Dialogue: 0,0:19:27.35,0:19:29.61,Default,,0,0,0,,Aku ingin lebih dekat denganmu.
Dialogue: 0,0:19:30.48,0:19:35.03,Default,,0,0,0,,Di situasi Tokyo yang seperti ini,\Nmungkin enggak ada yang bisa kulakukan,
Dialogue: 0,0:19:37.07,0:19:40.78,Default,,0,0,0,,tapi bagaimana caranya agar aku\Nbisa lebih dekat denganmu?
Dialogue: 0,0:19:42.29,0:19:43.50,Default,,0,0,0,,Kenapa?
Dialogue: 0,0:19:44.96,0:19:48.88,Default,,0,0,0,,Kenapa kamu mencoba\Nmendekatiku terang-terangan?
Dialogue: 0,0:19:48.88,0:19:51.38,Default,,0,0,0,,Mana bisa lari kalau begini!
Dialogue: 0,0:19:51.38,0:19:55.01,Default,,0,0,0,,Tapi, enggak ada yang bisa kamu lakukan.
Dialogue: 0,0:19:55.55,0:19:58.59,Default,,0,0,0,,Soalnya, aku yang harus berubah.
Dialogue: 0,0:20:01.60,0:20:03.31,Default,,0,0,0,,Kamu boleh buka pintunya.
Dialogue: 0,0:20:13.53,0:20:16.19,Default,,0,0,0,,Wujudku ini menjijikkan, ya?
Dialogue: 0,0:20:16.61,0:20:18.45,Default,,0,0,0,,Ini baru sebagian kecil.
Dialogue: 0,0:20:18.45,0:20:22.28,Default,,0,0,0,,Kalau kamu tahu diriku yang sebenarnya,\Nmungkin kamu akan makin membenciku.
Dialogue: 0,0:20:23.41,0:20:27.33,Default,,0,0,0,,Aku juga ingin lebih dekat denganmu.
Dialogue: 0,0:20:27.33,0:20:29.67,Default,,0,0,0,,Sebenarnya, aku sangat senang.
Dialogue: 0,0:20:29.67,0:20:32.13,Default,,0,0,0,,Waktu kamu mengajakku bicara di tangga,
Dialogue: 0,0:20:32.13,0:20:34.80,Default,,0,0,0,,mengobrol denganmu waktu di kedai panekuk,
Dialogue: 0,0:20:34.80,0:20:38.26,Default,,0,0,0,,dan saat kamu membelaku\Nsembari menggenggam tanganku...
Dialogue: 0,0:20:38.26,0:20:43.26,Default,,0,0,0,,Bahkan sekarang, saat kamu\Nmengungkapkan perasaanmu padaku!
Dialogue: 0,0:20:44.31,0:20:46.93,Default,,0,0,0,,Aku ingin mengatakan itu.
Dialogue: 0,0:20:46.93,0:20:51.94,Default,,0,0,0,,Wajar saja kalau kamu enggak bisa\Nmenerimaku yang mempunyai ekor, kan?
Dialogue: 0,0:20:52.36,0:20:55.65,Default,,0,0,0,,Akaishi, apa yang kamu maksud ekor?
Dialogue: 0,0:20:56.07,0:20:58.20,Default,,0,0,0,,Eh? Lo?
Dialogue: 0,0:20:58.20,0:21:00.57,Default,,0,0,0,,Maaf, di dalam sangat gelap!\NSakelarnya di mana, ya?
Dialogue: 0,0:21:00.57,0:21:01.62,Default,,0,0,0,,Ah, ketemu.
Dialogue: 0,0:21:02.24,0:21:03.99,Default,,0,0,0,,Padahal barusan ada di sini.
Dialogue: 0,0:21:07.50,0:21:09.96,Default,,0,0,0,,Apa-apaan tubuhku ini?
Dialogue: 0,0:21:09.96,0:21:14.46,Default,,0,0,0,,Padahal aku sudah memberanikan diri,\Ndia pasti bakal menganggapku aneh!
Dialogue: 0,0:21:14.46,0:21:17.13,Default,,0,0,0,,Terima kasih sudah mau\Nmengutarakan perasaanmu.
Dialogue: 0,0:21:18.76,0:21:23.51,Default,,0,0,0,,Pasti masih ada banyak tentang dirimu\Nyang belum kuketahui.
Dialogue: 0,0:21:23.51,0:21:26.26,Default,,0,0,0,,Kalau kamu membenci dirimu sendiri,
Dialogue: 0,0:21:26.26,0:21:30.89,Default,,0,0,0,,aku akan menemukan lebih banyak hal\Nyang membuatku suka dan memberitahumu!
Dialogue: 0,0:21:30.89,0:21:33.48,Default,,0,0,0,,Aku cukup percaya diri.
Dialogue: 0,0:21:40.65,0:21:42.61,Default,,0,0,0,,Akhirnya kamu menatapku.
Dialogue: 0,0:21:45.16,0:21:46.28,Default,,0,0,0,,Aku ambil tas dulu.
Dialogue: 0,0:21:46.28,0:21:48.95,Default,,0,0,0,,Manatsu biar sekalian kupanggil, ya.
Dialogue: 0,0:22:00.59,0:22:05.30,Default,,0,0,0,,Padahal aku sudah kembali\Nke wujud semula!
Dialogue: 0,0:22:07.51,0:22:09.98,Default,,0,0,0,,Aku sudah menunggumu!
Dialogue: 0,0:22:09.98,0:22:12.23,Default,,0,0,0,,Betulan muncul!
Dialogue: 0,0:22:14.48,0:22:17.36,Default,,0,0,0,,Maaf!
Dialogue: 0,0:22:19.15,0:22:20.99,Default,,0,0,0,,Maaf, Minami.
Dialogue: 0,0:22:20.99,0:22:25.37,Default,,0,0,0,,Sepertinya hubungan cinta normal\Nmemang mustahil bagiku.
Dialogue: 0,0:22:25.37,0:22:28.20,Default,,0,0,0,,Tapi, aku ingin menjaganya baik-baik.
Dialogue: 0,0:22:29.79,0:22:32.33,Default,,0,0,0,,Menjaga perasaan\Nyang sudah kamu berikan ini
Dialogue: 0,0:22:33.46,0:22:36.67,Default,,0,0,0,,agar tidak dihancurkan oleh diriku sendiri.
Dialogue: 0,0:24:08.89,0:24:10.47,Default,,0,0,0,,Manisan selanjutnya...
Dialogue: 0,0:24:10.47,0:24:12.01,Default,,0,0,0,,Churros.
Dialogue: 0,0:24:12.01,0:24:14.47,Default,,0,0,0,,Renyah dan lezat!
