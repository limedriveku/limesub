Dialogue: 0,0:02:06.23,0:02:11.65,sign,,0000,0000,0000,,KAIJU DARA CARAMELISE
Dialogue: 0,0:03:26.98,0:03:30.48,sign,,0000,0000,0000,,EPISODE 4: FESTIVAL KAIJU MENYERAMKAN
Dialogue: 0,0:05:34.02,0:05:35.73,sign,,0000,0000,0000,,TERIMA KASIH UNTUK HARI INI.\NDESTINY LAND SERU BANGET!
Dialogue: 0,0:05:38.19,0:05:41.15,sign,,0000,0000,0000,,LAIN KALI, AYO PERGI KE TEMPAT LAIN.
Dialogue: 0,0:05:46.37,0:05:47.95,sign,,0000,0000,0000,,TERIMA KASIH JUGA.\NASYIK BANGET.
Dialogue: 0,0:05:50.41,0:05:51.58,sign,,0000,0000,0000,,SELAMAT TIDUR.
Dialogue: 0,0:06:09.56,0:06:13.52,sign,,0000,0000,0000,,SELAMAT TIDUR!\NKAYAKNYA AKU BAKAL MIMPI INDAH.
Dialogue: 0,0:17:20.64,0:17:23.65,sign,,0000,0000,0000,,MARKAS PUSAT PENANGGULANGAN BENCANA
Dialogue: 0,0:19:35.24,0:19:38.20,sign,,0000,0000,0000,,HARUGON MUNCUL DI LOKASI FESTIVAL
Dialogue: 0,0:00:11.53,0:00:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambutmu sudah enggak pirang, ya.
Dialogue: 0,0:00:13.20,0:00:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekilas aku enggak mengenalimu.
Dialogue: 0,0:00:15.79,0:00:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yo, Jumbo King.
Dialogue: 0,0:00:18.83,0:00:21.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan kamu kembali ke Jepang?
Dialogue: 0,0:00:21.63,0:00:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga hari lalu.
Dialogue: 0,0:00:23.59,0:00:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti biasanya,
Dialogue: 0,0:00:25.17,0:00:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu enggak terlihat\Nseperti ilmuwan biologi, Hibino.
Dialogue: 0,0:00:29.30,0:00:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga sama, Kak Akaishi.
Dialogue: 0,0:00:33.01,0:00:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bukan ilmuwan.
Dialogue: 0,0:00:35.14,0:00:37.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, aku cuma ibu tunggal.
Dialogue: 0,0:00:37.93,0:00:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah tidak punya energi
Dialogue: 0,0:00:40.52,0:00:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk keliling dunia\Nmencari hewan langka bersamamu.
Dialogue: 0,0:00:44.19,0:00:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu enggak tertarik padanya?
Dialogue: 0,0:00:46.65,0:00:47.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa?
Dialogue: 0,0:00:47.90,0:00:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang tempo hari bikin dunia heboh.
Dialogue: 0,0:00:52.53,0:00:54.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu dari mana kalau itu perempuan?
Dialogue: 0,0:00:54.95,0:00:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin berkat pengalaman.
Dialogue: 0,0:00:57.12,0:01:00.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakan, suara, dan tatapannya.
Dialogue: 0,0:01:01.46,0:01:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu mata gadis yang sedang jatuh cinta.
Dialogue: 0,0:01:06.84,0:01:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu datang dari Afrika Timur\Ncuma buat merayu kaiju?
Dialogue: 0,0:01:11.18,0:01:13.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah kira-kira.
Dialogue: 0,0:01:13.43,0:01:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang merokok.
Dialogue: 0,0:01:15.35,0:01:19.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, semoga kamu tidak terinjak.
Dialogue: 0,0:01:21.85,0:01:25.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kerja sama lagi seperti dulu.
Dialogue: 0,0:01:26.77,0:01:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku khawatir, tahu.
Dialogue: 0,0:01:28.53,0:01:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padamu.
Dialogue: 0,0:01:34.78,0:01:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu masih sama saja, ya!
Dialogue: 0,0:01:37.91,0:01:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:01:38.91,0:01:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti itu telepon dari wanita, kan?
Dialogue: 0,0:01:40.83,0:01:42.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tahu?
Dialogue: 0,0:01:42.29,0:01:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahnya?\NToh, aku lajang.
Dialogue: 0,0:01:44.21,0:01:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga masih sendiri, kan?
Dialogue: 0,0:01:45.96,0:01:48.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu benci sifat gampanganmu itu!
Dialogue: 0,0:01:48.46,0:01:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aslinya kamu senang, kan?\N- Aku pulang.
Dialogue: 0,0:01:53.13,0:01:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro!
Dialogue: 0,0:01:55.14,0:01:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuro?
Dialogue: 0,0:03:30.48,0:03:31.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro!
Dialogue: 0,0:03:32.98,0:03:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setahun kita enggak jumpa!\NApa kabar?
Dialogue: 0,0:03:36.28,0:03:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan terlalu menempel!
Dialogue: 0,0:03:39.07,0:03:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru tahu Kotaro mampir!
Dialogue: 0,0:03:41.45,0:03:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada pekerjaan di sini.
Dialogue: 0,0:03:43.79,0:03:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kaget?\NPasti senang, kan?
Dialogue: 0,0:03:46.50,0:03:48.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku sudah kangen dari lama!
Dialogue: 0,0:03:48.75,0:03:51.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu manis banget,\Nenggak kayak seseorang!
Dialogue: 0,0:03:52.55,0:03:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih, oleh-oleh!\NAda album baru Spreekiller juga.
Dialogue: 0,0:03:55.59,0:03:57.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, terima kasih!
Dialogue: 0,0:03:57.55,0:04:01.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu? Lagu berisik\Nyang selalu diputar Kurotan?
Dialogue: 0,0:04:01.51,0:04:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik Ibu bilang?
Dialogue: 0,0:04:03.51,0:04:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Metal itu musik paling sakral sedunia!
Dialogue: 0,0:04:06.77,0:04:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kasih paham, Kuro!
Dialogue: 0,0:04:08.27,0:04:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Om turut senang\Nkamu sudah jadi veteran!
Dialogue: 0,0:04:11.65,0:04:14.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama lebih suka Hamasaki Mayumi.
Dialogue: 0,0:04:14.36,0:04:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makasih, Kotaro!
Dialogue: 0,0:04:16.14,0:04:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei, jangan terlalu bersemangat.
Dialogue: 0,0:04:19.70,0:04:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya gejalamu kambuh.
Dialogue: 0,0:04:21.52,0:04:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu belum sembuh, kan?
Dialogue: 0,0:04:23.83,0:04:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Belum.
Dialogue: 0,0:04:25.75,0:04:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, sekarang bisa lebih aku kontrol.
Dialogue: 0,0:04:29.08,0:04:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?\NKamu akan kuajak merayakannya!
Dialogue: 0,0:04:31.92,0:04:32.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:32.67,0:04:36.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ultra Bakuon Fes!\NTamu utamanya Spreekiller, lo!
Dialogue: 0,0:04:37.38,0:04:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiket yang tidak sanggup kubeli!
Dialogue: 0,0:04:40.38,0:04:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu!
Dialogue: 0,0:04:42.18,0:04:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival metal kedengaran bahaya!
Dialogue: 0,0:04:44.51,0:04:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama juga ikut!
Dialogue: 0,0:04:45.56,0:04:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat apa?
Dialogue: 0,0:04:46.77,0:04:48.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih saja protektif.
Dialogue: 0,0:04:48.73,0:04:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana bakal bising seharian, lo.
Dialogue: 0,0:04:51.94,0:04:53.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tidak suka bakal muak.
Dialogue: 0,0:04:53.48,0:04:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:54.44,0:04:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ke konser\Nbareng om-om lebih aman
Dialogue: 0,0:04:57.28,0:05:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daripada kencan\Ndi Negeri Impian sama Minami.
Dialogue: 0,0:05:00.45,0:05:04.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mama nonton DVD Hamasaki Mayumi\Ndi rumah saja, deh!
Dialogue: 0,0:05:06.04,0:05:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kalau kamu\Nberubah jadi kaiju, ya.
Dialogue: 0,0:05:08.96,0:05:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Informasi bisa bocor dari mana saja.
Dialogue: 0,0:05:11.42,0:05:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:05:13.71,0:05:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, nanti aku jemput, ya.
Dialogue: 0,0:05:16.25,0:05:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mau pulang?
Dialogue: 0,0:05:17.71,0:05:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan di sini sementara waktu.
Dialogue: 0,0:05:19.76,0:05:22.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apartemenku ada di Harumi,\Nkita bisa ketemu kapan saja.
Dialogue: 0,0:05:22.64,0:05:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- Asyik!
Dialogue: 0,0:05:42.66,0:05:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus kerja sambilan.
Dialogue: 0,0:05:57.75,0:06:01.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang "selamat tidur" kayaknya berlebihan.
Dialogue: 0,0:06:01.09,0:06:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan pacarnya.
Dialogue: 0,0:06:02.80,0:06:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, dia bakal jijik.
Dialogue: 0,0:06:15.98,0:06:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat! Gawat, ini gawat!
Dialogue: 0,0:06:20.99,0:06:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jatuh cinta
Dialogue: 0,0:06:24.03,0:06:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada Minami.
Dialogue: 0,0:06:26.95,0:06:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadar diri, bodoh!\NKamu itu kaiju!
Dialogue: 0,0:06:32.25,0:06:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak boleh minta lebih.
Dialogue: 0,0:06:35.00,0:06:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Takutnya malah tidak bisa berhenti.
Dialogue: 0,0:06:40.50,0:06:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini saja sudah cukup.
Dialogue: 0,0:06:47.64,0:06:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama kita enggak ke konser bareng!
Dialogue: 0,0:06:50.77,0:06:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terakhir dua tahun lalu, ya?\NWaktu itu kocak banget.
Dialogue: 0,0:06:54.52,0:06:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saking keasyikannya moshing\Ngejalamu sampai kambuh.
Dialogue: 0,0:06:58.56,0:07:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penonton lainnya langsung bingung.
Dialogue: 0,0:07:01.32,0:07:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu aku benaran panik.
Dialogue: 0,0:07:08.20,0:07:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enaknya di sisi Kotaro,\Naku bisa bersikap natural.
Dialogue: 0,0:07:12.08,0:07:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai saja sama Minami juga bisa begini.
Dialogue: 0,0:07:17.42,0:07:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:07:22.46,0:07:24.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Akaishi?
Dialogue: 0,0:07:25.42,0:07:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuro, belum beli juga?
Dialogue: 0,0:07:29.47,0:07:30.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami!
Dialogue: 0,0:07:32.43,0:07:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ko-Kok kamu di sini?
Dialogue: 0,0:07:34.35,0:07:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lagi kerja!\NKebetulan banget!
Dialogue: 0,0:07:36.73,0:07:38.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa? Kenalanmu?
Dialogue: 0,0:07:39.11,0:07:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Teman sekelasku, Minami.
Dialogue: 0,0:07:42.53,0:07:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:07:43.90,0:07:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sama kerabatmu?
Dialogue: 0,0:07:45.61,0:07:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pacarnya.
Dialogue: 0,0:07:47.24,0:07:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Woi, Om bilang apa, sih?
Dialogue: 0,0:07:49.12,0:07:49.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:49.66,0:07:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu!\NDia teman ibuku!
Dialogue: 0,0:07:52.66,0:07:55.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengenalku sejak kecil\Nsekaligus sesepuh metal!
Dialogue: 0,0:07:55.62,0:07:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga jadi suka metal\Ndan diajak kemari.
Dialogue: 0,0:07:58.42,0:08:00.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:08:00.13,0:08:02.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:08:05.59,0:08:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ganteng banget.\NModel? Aktor muda?
Dialogue: 0,0:08:09.09,0:08:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bukan.
Dialogue: 0,0:08:10.51,0:08:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pacaran?
Dialogue: 0,0:08:11.68,0:08:14.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Bukan begitu!
Dialogue: 0,0:08:14.14,0:08:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:08:15.60,0:08:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Su-Sudah kubilang...
Dialogue: 0,0:08:17.02,0:08:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belum menjawabku, Minami.
Dialogue: 0,0:08:29.03,0:08:30.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka band itu!
Dialogue: 0,0:08:30.70,0:08:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lihat, Kotaro!
Dialogue: 0,0:08:32.20,0:08:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:32.83,0:08:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu kerjaanmu.
Dialogue: 0,0:08:34.53,0:08:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, aman.
Dialogue: 0,0:08:37.00,0:08:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tanya aneh-aneh.
Dialogue: 0,0:08:38.90,0:08:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bertanya, kok.
Dialogue: 0,0:08:41.00,0:08:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tahu soal tubuhmu?
Dialogue: 0,0:08:44.46,0:08:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Enggak.
Dialogue: 0,0:08:46.55,0:08:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia orang baik.
Dialogue: 0,0:08:49.18,0:08:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenalanmu belum sebanyak itu\Nbuat membedakan orang baik dan jahat.
Dialogue: 0,0:08:55.10,0:08:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Minami berbeda.
Dialogue: 0,0:08:58.73,0:09:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, aku yakin.
Dialogue: 0,0:09:02.98,0:09:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Kuro.
Dialogue: 0,0:09:07.15,0:09:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu makhluk yang ingin populer!
Dialogue: 0,0:09:10.78,0:09:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bersikap baik\Nke wanita yang tidak dicintai!
Dialogue: 0,0:09:13.07,0:09:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tidak kedengaran!
Dialogue: 0,0:09:15.20,0:09:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bilang cinta meski aslinya tidak!
Dialogue: 0,0:09:17.54,0:09:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka bisa bohong demi hasrat pribadi!
Dialogue: 0,0:09:20.08,0:09:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:09:21.75,0:09:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, lain kali saja!
Dialogue: 0,0:09:23.88,0:09:24.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:26.21,0:09:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi makan dulu.
Dialogue: 0,0:09:32.05,0:09:33.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Acaranya baru mulai, lo.
Dialogue: 0,0:09:34.14,0:09:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu bersemangat.
Dialogue: 0,0:09:36.14,0:09:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raga ini sudah tua.
Dialogue: 0,0:09:41.14,0:09:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Band yang itu asyik, lo!
Dialogue: 0,0:09:42.77,0:09:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:09:56.24,0:09:58.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat pembatas, nih, hoki.
Dialogue: 0,0:09:58.87,0:10:00.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi.
Dialogue: 0,0:10:01.29,0:10:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami?
Dialogue: 0,0:10:02.79,0:10:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerjaannya kelar lebih awal,\Njadi aku mau nonton juga.
Dialogue: 0,0:10:05.96,0:10:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh.
Dialogue: 0,0:10:07.71,0:10:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana dia?
Dialogue: 0,0:10:08.80,0:10:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro? Ke toilet.
Dialogue: 0,0:10:10.63,0:10:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti juga kembali.
Dialogue: 0,0:10:12.22,0:10:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:13.76,0:10:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin mau nonton di depan sini?
Dialogue: 0,0:10:16.68,0:10:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak takut terdorong?
Dialogue: 0,0:10:18.22,0:10:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sering, kok, aman.
Dialogue: 0,0:10:19.97,0:10:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku dan Kotaro sudah sering begini.
Dialogue: 0,0:10:24.56,0:10:25.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:10:26.52,0:10:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spreekiller!
Dialogue: 0,0:10:28.48,0:10:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Spreekiller! Spreekiller!\N- Spreekiller!
Dialogue: 0,0:10:32.78,0:10:34.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke baris belakang saja, yuk!
Dialogue: 0,0:10:40.58,0:10:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si Kampret malah main peluk!
Dialogue: 0,0:10:43.75,0:10:47.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mi-Minami, sesak.
Dialogue: 0,0:10:47.54,0:10:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan aku.
Dialogue: 0,0:10:50.71,0:10:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami.
Dialogue: 0,0:10:57.68,0:11:00.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benaran enggak sanggup.
Dialogue: 0,0:11:04.52,0:11:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak sanggup, ya?
Dialogue: 0,0:11:05.39,0:11:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku bukan ke arah situ!
Dialogue: 0,0:11:08.19,0:11:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanmu enggan menatap mataku...
Dialogue: 0,0:11:10.69,0:11:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:11.36,0:11:15.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanmu tampak risi dan gelisah\Nsaat kita berdua...
Dialogue: 0,0:11:15.57,0:11:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir itu karena kamu pemalu.
Dialogue: 0,0:11:18.53,0:11:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata salah.
Dialogue: 0,0:11:21.91,0:11:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sadar setelah melihatmu\Ndengan pria itu.
Dialogue: 0,0:11:27.37,0:11:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro sudah seperti pamanku sendiri.
Dialogue: 0,0:11:31.42,0:11:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan kami bukan seperti itu.
Dialogue: 0,0:11:35.30,0:11:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus mengatakannya.
Dialogue: 0,0:11:37.22,0:11:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meredalah, tubuhku!
Dialogue: 0,0:11:40.43,0:11:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku menghindarimu...
Dialogue: 0,0:11:45.18,0:11:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Spreekiller!
Dialogue: 0,0:11:46.77,0:11:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai para pencinta kerusuhan!
Dialogue: 0,0:11:49.27,0:11:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarlah melodi neraka dari kami!
Dialogue: 0,0:11:55.07,0:11:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Akaishi!
Dialogue: 0,0:11:56.32,0:11:57.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:11:59.82,0:12:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo! Sikat!
Dialogue: 0,0:12:05.58,0:12:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alasanku enggan menatap matamu
Dialogue: 0,0:12:07.50,0:12:10.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan jadi salah tingkah saat kita berduaan,
Dialogue: 0,0:12:10.79,0:12:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukan karena aku membencimu!
Dialogue: 0,0:12:13.42,0:12:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membeli sampo yang sedikit mahal.
Dialogue: 0,0:12:16.34,0:12:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memberanikan diri ke toko baju\Nyang bukan gayaku.
Dialogue: 0,0:12:20.80,0:12:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangis karena memakan\Nkue buatanku yang gagal.
Dialogue: 0,0:12:25.10,0:12:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan tidak sabar akan hari esok.
Dialogue: 0,0:12:29.94,0:12:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua itu karena aku\Nmencintaimu, Minami!
Dialogue: 0,0:12:38.99,0:12:40.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Harugon!
Dialogue: 0,0:12:40.74,0:12:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:12:42.70,0:12:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, yang benar saja.
Dialogue: 0,0:12:53.25,0:12:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuro!
Dialogue: 0,0:12:54.13,0:12:55.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi!
Dialogue: 0,0:12:56.67,0:12:57.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi masih...
Dialogue: 0,0:12:57.84,0:12:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tahu.
Dialogue: 0,0:12:59.22,0:13:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengungsi saja dulu.
Dialogue: 0,0:13:03.97,0:13:05.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuro!
Dialogue: 0,0:13:07.47,0:13:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, mau apa kamu?
Dialogue: 0,0:13:11.98,0:13:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di mana, Akaishi?
Dialogue: 0,0:13:14.94,0:13:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang cari, pergi san—
Dialogue: 0,0:13:31.62,0:13:37.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami, meski di wujud ini,\Nbolehkah mengungkapkan perasaan?
Dialogue: 0,0:13:45.01,0:13:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengganggu datang.
Dialogue: 0,0:13:48.72,0:13:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi sana!
Dialogue: 0,0:13:55.86,0:14:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Minami juga\Nsama seperti yang lainnya?
Dialogue: 0,0:14:10.54,0:14:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengunjung saling dorong di gerbang.
Dialogue: 0,0:14:12.37,0:14:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa bahaya kalau kaijunya ke situ!
Dialogue: 0,0:14:14.88,0:14:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin Kuro juga ada di situ!
Dialogue: 0,0:14:18.84,0:14:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:14:19.67,0:14:23.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memancing kaijunya\Nke tempat sepi!
Dialogue: 0,0:14:23.47,0:14:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:24.30,0:14:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaiju itu selalu menatapku\Nlalu bergegas pergi.
Dialogue: 0,0:14:29.14,0:14:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia ingin menyampaikan sesuatu.
Dialogue: 0,0:14:31.48,0:14:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok tahu!
Dialogue: 0,0:14:33.14,0:14:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal konyol kalau kamu diinjak...
Dialogue: 0,0:14:35.27,0:14:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa!
Dialogue: 0,0:14:37.61,0:14:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin menyampaikan\Nsesuatu pada Akaishi.
Dialogue: 0,0:14:47.12,0:14:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami, kamu di mana?
Dialogue: 0,0:14:49.83,0:14:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tidak mau mengamuk,\Naku sulit berhenti.
Dialogue: 0,0:14:55.67,0:14:58.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hatiku juga perlahan jadi kaiju.
Dialogue: 0,0:14:59.75,0:15:06.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tahu begini sekalian saja\Naku menyatakan cinta padanya.
Dialogue: 0,0:15:06.93,0:15:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah aku kembali jadi manusia?
Dialogue: 0,0:15:15.73,0:15:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:15:17.19,0:15:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami!
Dialogue: 0,0:15:18.65,0:15:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalilah!
Dialogue: 0,0:15:20.23,0:15:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuat Kuro menangis!
Dialogue: 0,0:15:22.15,0:15:23.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:15:25.45,0:15:26.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harugon!
Dialogue: 0,0:15:28.16,0:15:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:29.28,0:15:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku sempat kabur.
Dialogue: 0,0:15:33.95,0:15:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada perlu denganku, kan?
Dialogue: 0,0:15:49.01,0:15:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kotaro, ternyata benar...
Dialogue: 0,0:15:51.35,0:15:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sok tahu!
Dialogue: 0,0:15:52.81,0:15:54.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:15:54.52,0:15:56.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, Harugon!
Dialogue: 0,0:15:56.98,0:15:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu temanku!
Dialogue: 0,0:15:59.90,0:16:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong biarkan dia pergi!
Dialogue: 0,0:16:03.03,0:16:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai gantinya, injak aku saja!
Dialogue: 0,0:16:06.57,0:16:07.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manatsu?
Dialogue: 0,0:16:08.57,0:16:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Enggak sampai!
Dialogue: 0,0:16:10.37,0:16:12.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Le-Lebih rendah lagi!
Dialogue: 0,0:16:16.75,0:16:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manatsu!
Dialogue: 0,0:16:20.13,0:16:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami, kamu baik-baik saja?
Dialogue: 0,0:16:22.29,0:16:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:16:24.34,0:16:26.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau lihat Harugon?
Dialogue: 0,0:16:26.42,0:16:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, aku langsung kemari\Nsaat melihat siaran TV.
Dialogue: 0,0:16:29.76,0:16:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya, aura kaiju Harugon\Nlebih kuat dari biasanya.
Dialogue: 0,0:16:34.39,0:16:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menatapku\Nbagaikan serangga yang hina.
Dialogue: 0,0:16:39.73,0:16:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia datang lagi!
Dialogue: 0,0:16:42.98,0:16:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manatsu, aku ingin memancing\NHarugon ke tempat sepi.
Dialogue: 0,0:16:46.49,0:16:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan Akaishi juga ada\Ndi kerumunan itu.
Dialogue: 0,0:16:48.49,0:16:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuroe?
Dialogue: 0,0:16:51.24,0:16:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:16:52.82,0:16:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuroe itu Miko-nya Harugon.
Dialogue: 0,0:16:55.37,0:16:58.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu bicara apa?
Dialogue: 0,0:16:58.16,0:17:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Harugon mengamuk lebih dari ini,
Dialogue: 0,0:17:00.46,0:17:03.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin JSDF akan\Nmenyerang sekuat tenaga!
Dialogue: 0,0:17:03.25,0:17:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:17:04.25,0:17:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum melihatnya\Nmenyemburkan napas atom
Dialogue: 0,0:17:06.80,0:17:10.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terbang melintasi langit\Ndengan mata kepala ini!
Dialogue: 0,0:17:10.93,0:17:11.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul, tuh!
Dialogue: 0,0:17:13.26,0:17:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei, hei.
Dialogue: 0,0:17:14.68,0:17:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau apa lagi dia?
Dialogue: 0,0:17:19.73,0:17:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:17:20.64,0:17:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan waktu yang tepat!
Dialogue: 0,0:17:27.10,0:17:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harugon, kemarilah!
Dialogue: 0,0:17:35.45,0:17:37.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harugon mengincar kita!
Dialogue: 0,0:17:37.91,0:17:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbanglah terus ke arah Gunung Fuji!
Dialogue: 0,0:17:46.67,0:17:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, seharusnya ini cukup jauh.
Dialogue: 0,0:17:51.51,0:17:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:52.34,0:17:54.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, wah!
Dialogue: 0,0:17:54.26,0:17:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini situasi yang kuimpikan!
Dialogue: 0,0:17:56.43,0:17:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya juga.
Dialogue: 0,0:17:58.43,0:18:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lupa memberi parasut ke Minami!
Dialogue: 0,0:18:36.51,0:18:38.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuh, kan.
Dialogue: 0,0:18:38.06,0:18:41.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata tatapanmu memang lembut.
Dialogue: 0,0:18:42.10,0:18:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti mata Akaishi.
Dialogue: 0,0:18:45.02,0:18:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kita bisa berdua.
Dialogue: 0,0:18:50.65,0:18:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau bilang sesuatu, kan?\NBilang saja.
Dialogue: 0,0:18:53.32,0:18:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi aku enggak bisa bahasa kaiju, sih.\N- Sudah kuduga,
Dialogue: 0,0:18:58.62,0:19:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu berbeda dari yang lainnya.
Dialogue: 0,0:19:06.38,0:19:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta.
Dialogue: 0,0:19:07.75,0:19:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintai Minami.
Dialogue: 0,0:19:09.75,0:19:11.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku sudah bulat.
Dialogue: 0,0:19:13.88,0:19:15.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sasaran!
Dialogue: 0,0:19:16.80,0:19:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahaya, tahu!
Dialogue: 0,0:19:18.05,0:19:20.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau sampai kena Minami?
Dialogue: 0,0:19:24.56,0:19:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuungkapkan.
Dialogue: 0,0:19:26.56,0:19:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku enggak akan menyesal\Nsudah mencintaimu.
Dialogue: 0,0:19:35.24,0:19:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski beberapa orang cedera ringan akibat jatuh,
Dialogue: 0,0:19:38.20,0:19:42.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ajaibnya belum ada korban luka serius.
Dialogue: 0,0:19:46.58,0:19:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami.
Dialogue: 0,0:19:47.87,0:19:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami!
Dialogue: 0,0:19:57.59,0:19:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi!
Dialogue: 0,0:19:59.64,0:20:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf!
Dialogue: 0,0:20:00.80,0:20:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu pakai parasut?
Dialogue: 0,0:20:02.64,0:20:06.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku pungut...\NBukan, soalnya bajuku kotor!
Dialogue: 0,0:20:06.89,0:20:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, kukira kita\Nenggak bisa bertemu lagi.
Dialogue: 0,0:20:10.23,0:20:12.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku kira bakal mati tadi.
Dialogue: 0,0:20:12.94,0:20:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu nekat banget.\NDekat-dekat sama kaiju segala.
Dialogue: 0,0:20:17.20,0:20:19.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Harugon!
Dialogue: 0,0:20:21.41,0:20:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akaishi?
Dialogue: 0,0:20:22.16,0:20:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minami!
Dialogue: 0,0:20:29.29,0:20:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku benci diriku sendiri.
Dialogue: 0,0:20:34.50,0:20:38.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak cantik, pemurung,\Ndan agak nyeleneh.
Dialogue: 0,0:20:38.38,0:20:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifatku juga jelek, dan banyak lagi.
Dialogue: 0,0:20:42.14,0:20:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:43.64,0:20:50.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak bersamamu, aku bisa sedikit\Nmenyukai diri sendiri.
Dialogue: 0,0:20:50.60,0:20:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuek meski dibilang jelek\Ndan jadi sering tertawa.
Dialogue: 0,0:20:54.69,0:20:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga jadi lebih berani\Nmencoba hal baru.
Dialogue: 0,0:20:59.57,0:21:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bersamamu, tiap hari\Nseperti mencari harta karun.
Dialogue: 0,0:21:04.87,0:21:06.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiap hari terasa seru
Dialogue: 0,0:21:06.58,0:21:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terasa bahagia.
Dialogue: 0,0:21:08.41,0:21:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir hari-hari seperti itu\Nenggak akan pernah datang.
Dialogue: 0,0:21:13.04,0:21:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membuatku\Nmerasakan perasaan ini!
Dialogue: 0,0:21:17.51,0:21:21.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebenarnya, aku men...
Dialogue: 0,0:21:22.93,0:21:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal tinggal sepatah kata lagi!
Dialogue: 0,0:21:32.19,0:21:33.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:21:34.27,0:21:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang melanjutkan.
Dialogue: 0,0:21:37.40,0:21:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berjuang selama ini.
Dialogue: 0,0:21:40.74,0:21:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku malah merajuk kayak anak kecil.
Dialogue: 0,0:21:43.41,0:21:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:21:46.16,0:21:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ujungnya aku enggak tahu\Napa yang kaiju itu mau sampaikan.
Dialogue: 0,0:21:51.25,0:21:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:21:52.79,0:21:57.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihatnya antusias meski terhalang bahasa
Dialogue: 0,0:21:57.80,0:22:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku seperti disemangati.
Dialogue: 0,0:22:04.76,0:22:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu.
Dialogue: 0,0:22:06.93,0:22:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kamu berpacaran denganku?
Dialogue: 0,0:22:14.69,0:22:16.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau.
Dialogue: 0,0:23:54.37,0:23:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini aku.
Dialogue: 0,0:23:57.92,0:24:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.\NAku akan pulang sekarang.
Dialogue: 0,0:24:02.38,0:24:03.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ini
Dialogue: 0,0:24:04.63,0:24:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan lebih gawat dari dugaanku.
Dialogue: 0,0:24:08.93,0:24:10.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisan berikutnya...
Dialogue: 0,0:24:10.60,0:24:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pisang!
Dialogue: 0,0:24:11.81,0:24:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parfait atau krep?
