Dialogue: 0,0:00:10.76,0:00:12.92,sign,,0000,0000,0000,,‎DISKON SAYURAN MUSIM SEMI\N‎SUPER HEMAT - DIPETIK HARI NI
Dialogue: 0,0:00:19.01,0:00:20.18,sign,,0000,0000,0000,,{\an8}‎DISKON 20% - SETENGAH HARGA\N‎ALKOHOL - KERUPUK BERAS
Dialogue: 0,0:00:58.43,0:00:59.51,sign,,0000,0000,0000,,‎BIASANYA
Dialogue: 0,0:06:02.36,0:06:03.78,sign,,0000,0000,0000,,‎JAGA KERAPIAN DAN KETERATURAN
Dialogue: 0,0:09:27.94,0:09:30.15,sign,,0000,0000,0000,,‎PERUSAHAAN HAPPY
Dialogue: 0,0:10:19.61,0:10:21.62,sign,,0000,0000,0000,,{\an8}‎JAGA TEMPAT INI BERSIH DAN RAPI
Dialogue: 0,0:10:26.12,0:10:28.54,sign,,0000,0000,0000,,{\an8}‎SUPER S
Dialogue: 0,0:12:10.31,0:12:13.18,sign,,0000,0000,0000,,‎KESAL
Dialogue: 0,0:13:09.37,0:13:12.37,sign,,0000,0000,0000,,‎DINGIN - HANGAT
Dialogue: 0,0:17:47.81,0:17:48.90,sign,,0000,0000,0000,,‎LAMBAN-SAKI
Dialogue: 0,0:19:06.64,0:19:07.64,sign,,0000,0000,0000,,‎DINGIN
Dialogue: 0,0:00:05.21,0:00:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aku pulang cepat! Hei, hei, hei, hei!{\i0}
Dialogue: 0,0:00:13.51,0:00:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Selanjutnya.
Dialogue: 0,0:00:17.47,0:00:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Baik.
Dialogue: 0,0:00:30.57,0:00:32.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Totalnya 1.040 yen.
Dialogue: 0,0:00:32.36,0:00:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Baik.
Dialogue: 0,0:00:33.78,0:00:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ini kembaliannya.
Dialogue: 0,0:00:36.91,0:00:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Kau akan segera punya cukup poin.\N‎- Baik.
Dialogue: 0,0:00:40.41,0:00:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau akan dapat kupon diskon 50%\N‎untuk kerupuk beras besok.
Dialogue: 0,0:00:44.04,0:00:45.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih.
Dialogue: 0,0:00:53.92,0:00:56.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Yamada-chan. Waktunya ganti giliran.
Dialogue: 0,0:00:56.38,0:00:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ada yang aneh.
Dialogue: 0,0:00:59.51,0:01:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Wow, banyak sekali poinnya!
Dialogue: 0,0:01:01.18,0:01:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih banyak.
Dialogue: 0,0:01:03.31,0:01:06.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Pelayananku gagal membangkitkan\N‎semangat pelangganku.
Dialogue: 0,0:01:06.69,0:01:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apanya?
Dialogue: 0,0:01:12.73,0:01:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aku butuh rokok.{\i0}
Dialogue: 0,0:01:16.15,0:01:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sampai jumpa lagi, Sasaki-san.
Dialogue: 0,0:02:58.92,0:03:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san…
Dialogue: 0,0:03:04.18,0:03:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak seharusnya merokok di sini\N‎karena ini gampang.
Dialogue: 0,0:03:08.73,0:03:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Halo. Aku wanita gampangan.
Dialogue: 0,0:03:13.61,0:03:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san?
Dialogue: 0,0:03:15.44,0:03:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa kabar?
Dialogue: 0,0:03:18.57,0:03:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Giliran kerjamu sudah selesai?\N‎- Ya.
Dialogue: 0,0:03:20.95,0:03:22.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kerja bagus hari ini.
Dialogue: 0,0:03:22.66,0:03:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Langsung saja, kau ingin merokok, 'kan?
Dialogue: 0,0:03:24.70,0:03:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau datang untukku, 'kan?
Dialogue: 0,0:03:26.03,0:03:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Silakan.
Dialogue: 0,0:03:27.54,0:03:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Baik. Maaf mengganggu.
Dialogue: 0,0:03:38.17,0:03:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Desahanmu keras sekali.
Dialogue: 0,0:03:40.42,0:03:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Harimu buruk, Sasaki-san?
Dialogue: 0,0:03:42.84,0:03:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kurasa begitu.
Dialogue: 0,0:03:50.31,0:03:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Yamada-san mengkhawatirkanmu.
Dialogue: 0,0:03:53.65,0:03:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa aku tak sopan padanya?
Dialogue: 0,0:03:56.61,0:03:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak.
Dialogue: 0,0:03:58.44,0:04:01.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia hanya berpikir kau sedih\N‎dan dia khawatir apa kau baik-baik saja.
Dialogue: 0,0:04:04.91,0:04:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Yamada-san benar-benar kasir\N‎yang perhatian dan hebat.
Dialogue: 0,0:04:09.99,0:04:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dan terima kasih juga, Tayama-san.
Dialogue: 0,0:04:12.08,0:04:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku hanya pembawa pesan.
Dialogue: 0,0:04:14.29,0:04:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tapi bukankah kau repot-repot ke sini\N‎dan memberitahuku ini?
Dialogue: 0,0:04:20.13,0:04:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Rambutmu tergerai.
Dialogue: 0,0:04:22.47,0:04:26.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Mungkin kau tak sabar untuk ke sini\N‎dan memberitahuku…
Dialogue: 0,0:04:27.26,0:04:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}‎Tayama-san!
Dialogue: 0,0:04:28.93,0:04:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}‎Kau tak boleh meniup asap\N‎ke wajah orang lain.
Dialogue: 0,0:04:36.40,0:04:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Rambutku seperti ini karena aku malas.
Dialogue: 0,0:04:40.40,0:04:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dan alasanku ingin memberitahumu…
Dialogue: 0,0:04:45.32,0:04:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak akan bilang.
Dialogue: 0,0:04:47.57,0:04:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Karena kau tengil hari ini.
Dialogue: 0,0:04:53.29,0:04:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tengil? Apa?
Dialogue: 0,0:04:55.54,0:04:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Bagaimana aku tengil?
Dialogue: 0,0:04:57.63,0:04:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau tengil untuk orang yang lamban.
Dialogue: 0,0:04:59.54,0:05:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak! Aku tak lamban.
Dialogue: 0,0:05:07.09,0:05:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Mungkin aku lamban.
Dialogue: 0,0:05:09.43,0:05:10.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa yang terjadi?
Dialogue: 0,0:05:11.22,0:05:13.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san…
Dialogue: 0,0:05:14.31,0:05:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku menghargai pendapat objektifmu.
Dialogue: 0,0:05:18.40,0:05:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Katakanlah.
Dialogue: 0,0:05:21.15,0:05:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa aku menyeramkan?
Dialogue: 0,0:05:24.99,0:05:26.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau baik-baik saja?
Dialogue: 0,0:05:26.61,0:05:29.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kenapa pertanyaanmu aneh sekali?
Dialogue: 0,0:05:29.20,0:05:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Itu aneh?
Dialogue: 0,0:05:31.08,0:05:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau tahu…
Dialogue: 0,0:05:36.16,0:05:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku membuat karyawan baru\N‎menangis hari ini.
Dialogue: 0,0:05:40.59,0:05:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa? Kau tipe orang yang marah saat kerja?
Dialogue: 0,0:05:44.42,0:05:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Itu lucu sekali.
Dialogue: 0,0:05:45.67,0:05:48.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kenapa, kau!
Dialogue: 0,0:05:48.18,0:05:49.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak begitu!
Dialogue: 0,0:05:50.93,0:05:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Itu kesalahan kecil,
Dialogue: 0,0:05:53.10,0:05:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎jadi aku berusaha menghiburnya.
Dialogue: 0,0:05:55.89,0:05:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tapi kelihatannya pasti kebalikannya.
Dialogue: 0,0:06:04.48,0:06:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Semoga beruntung lain kali.
Dialogue: 0,0:06:08.91,0:06:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tunggu.
Dialogue: 0,0:06:12.37,0:06:14.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa yang kau lakukan, Sasaki-kun?
Dialogue: 0,0:06:14.74,0:06:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maafkan aku.
Dialogue: 0,0:06:16.87,0:06:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kasihan Sasaki-san dimarahi habis-habisan.
Dialogue: 0,0:06:19.62,0:06:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia membuat karyawan baru menangis.
Dialogue: 0,0:06:21.42,0:06:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa? Sasaki-san?
Dialogue: 0,0:06:26.76,0:06:30.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak mau\N‎dia benci pekerjaannya karena aku.
Dialogue: 0,0:06:37.52,0:06:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Lalu kenapa jika dia begitu?
Dialogue: 0,0:06:39.39,0:06:42.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Pekerjaanmu termasuk menoleransi\N‎tempat kerja yang toksik
Dialogue: 0,0:06:42.11,0:06:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎yang membuatmu bekerja sampai malam, 'kan?
Dialogue: 0,0:06:44.69,0:06:46.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tetap saja dia akan keluar.
Dialogue: 0,0:06:46.15,0:06:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san.
Dialogue: 0,0:06:50.82,0:06:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jika dia karyawan baru, berarti dia baru\N‎bergabung dengan perusahaan, 'kan?
Dialogue: 0,0:06:55.91,0:06:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia akan tahu.
Dialogue: 0,0:06:58.41,0:07:00.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia akan tahu kau orang baik.
Dialogue: 0,0:07:04.54,0:07:07.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Itu jika dia belum berhenti.
Dialogue: 0,0:07:08.30,0:07:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih.
Dialogue: 0,0:07:14.30,0:07:18.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku yakin hal seperti ini\N‎tak pernah terjadi pada Yamada-san.
Dialogue: 0,0:07:18.77,0:07:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kenapa tiba-tiba Yamada-san?
Dialogue: 0,0:07:20.39,0:07:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku yakin Yamada-san tak pernah\N‎membuat karyawan baru ketakutan
Dialogue: 0,0:07:24.69,0:07:27.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎atau membuatnya menangis.
Dialogue: 0,0:07:28.69,0:07:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maksudmu, tak sepertiku\N‎yang penampilannya membuat orang takut?
Dialogue: 0,0:07:33.70,0:07:35.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maksudku bukan begitu.
Dialogue: 0,0:07:35.87,0:07:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Benar, Yamada-san mungkin tipe orang\N‎yang diremehkan,
Dialogue: 0,0:07:39.20,0:07:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎tapi dia tak menyeramkan.
Dialogue: 0,0:07:41.87,0:07:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Diremehkan?
Dialogue: 0,0:07:46.17,0:07:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Menurutku, dia luar biasa.
Dialogue: 0,0:07:48.71,0:07:51.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia bekerja larut malam,\N‎tapi tetap tersenyum
Dialogue: 0,0:07:51.22,0:07:53.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎dan bahkan mengkhawatirkan\N‎pelanggan sepertiku.
Dialogue: 0,0:07:54.55,0:07:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Seandainya aku bisa bekerja\N‎dengan senyum seperti Yamada-san.
Dialogue: 0,0:08:03.35,0:08:07.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Itu karena supermarket\N‎membuat kami berlatih tersenyum.
Dialogue: 0,0:08:07.48,0:08:08.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Benarkah?
Dialogue: 0,0:08:08.98,0:08:11.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Bahkan kau?
Dialogue: 0,0:08:11.03,0:08:12.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya.
Dialogue: 0,0:08:12.11,0:08:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎"Sipitkan mata agar terlihat seperti\N‎bulan sabit. Gerakkan otot wajah.
Dialogue: 0,0:08:16.37,0:08:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tunjukkan gigi atas."
Dialogue: 0,0:08:20.29,0:08:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Seperti ini!
Dialogue: 0,0:08:24.33,0:08:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san… Kau…
Dialogue: 0,0:08:35.26,0:08:37.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maafkan aku.
Dialogue: 0,0:08:38.14,0:08:40.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau membuatku takut.
Dialogue: 0,0:08:41.72,0:08:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Senyummu manis\N‎dan indah sekali, Tayama-san.
Dialogue: 0,0:08:50.02,0:08:51.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san?
Dialogue: 0,0:08:53.53,0:08:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sekarang, giliranku\N‎untuk minta maaf, Sasaki-san.
Dialogue: 0,0:08:56.57,0:08:59.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Lebih cepat begini\N‎daripada hanya menunjukkan.
Dialogue: 0,0:08:59.53,0:09:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf, Tayama-san. Kau marah?
Dialogue: 0,0:09:02.79,0:09:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak serius.
Dialogue: 0,0:09:08.29,0:09:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Baiklah. Latihan tersenyum berakhir.
Dialogue: 0,0:09:18.43,0:09:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf, Tayama-san.
Dialogue: 0,0:09:21.72,0:09:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ingat yang kau ajarkan padamu,\N‎dan buat aku bangga.
Dialogue: 0,0:09:24.31,0:09:25.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Tapi aku…\N‎- Mengerti?
Dialogue: 0,0:09:25.89,0:09:26.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya, Bu!
Dialogue: 0,0:09:30.15,0:09:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku minta maaf soal kemarin.
Dialogue: 0,0:09:35.40,0:09:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak bermaksud menangis, tapi…
Dialogue: 0,0:09:38.70,0:09:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tiba-tiba saja air mataku keluar.
Dialogue: 0,0:09:41.74,0:09:43.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Di sini berasap, ayo bicara di luar.
Dialogue: 0,0:09:43.79,0:09:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak apa-apa.
Dialogue: 0,0:09:45.71,0:09:49.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku minta maaf membuatmu terlihat\N‎seperti orang jahat.
Dialogue: 0,0:09:49.83,0:09:52.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak, aku seharusnya\N‎lebih hati-hati dalam bicara.
Dialogue: 0,0:09:52.84,0:09:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sama sekali tidak.
Dialogue: 0,0:09:54.42,0:09:58.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tahu kau orang baik,\N‎tapi aku tetap saja…
Dialogue: 0,0:09:58.63,0:09:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa?
Dialogue: 0,0:10:00.60,0:10:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia akan tahu.
Dialogue: 0,0:10:03.47,0:10:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Dia akan tahu kau orang baik.{\i0}
Dialogue: 0,0:10:09.65,0:10:12.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Semua orang buat kesalahan\N‎saat baru mulai.
Dialogue: 0,0:10:12.65,0:10:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jangan terlalu dibawa hati.
Dialogue: 0,0:10:14.53,0:10:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jika kau butuh bantuan,\N‎katakan saja padaku.
Dialogue: 0,0:10:17.82,0:10:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih.
Dialogue: 0,0:10:22.20,0:10:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau bermulut manis.
Dialogue: 0,0:10:23.53,0:10:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Hentikan itu! Jangan dirusak!
Dialogue: 0,0:10:31.00,0:10:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Selanjutnya.
Dialogue: 0,0:10:38.22,0:10:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ini setruknya.
Dialogue: 0,0:10:41.39,0:10:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih.
Dialogue: 0,0:10:43.39,0:10:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih banyak.
Dialogue: 0,0:10:56.65,0:11:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Senyummu manis\N‎dan indah sekali, Tayama-san.{\i0}
Dialogue: 0,0:11:02.20,0:11:03.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Berani sekali kau tertawa, Sasaki?
Dialogue: 0,0:11:06.99,0:11:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}‎Kau seharusnya sudah terbiasa.{\i0}
Dialogue: 0,0:11:25.10,0:11:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aku keluar untuk rokok hanya dengan\N‎satu lapis baju karena ini musim semi.{\i0}
Dialogue: 0,0:11:28.81,0:11:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Tapi masih dingin saat malam.{\i0}
Dialogue: 0,0:11:32.73,0:11:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}‎Mungkin aku akan merokok sebatang\N‎sebelum pulang.{\i0}
Dialogue: 0,0:11:38.32,0:11:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Yamada-chan. Waktunya ganti giliran.
Dialogue: 0,0:11:41.65,0:11:42.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Baik.
Dialogue: 0,0:11:48.04,0:11:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Dia tak mampir hari ini.{\i0}
Dialogue: 0,0:11:50.54,0:11:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Apa dia lembur?\N‎Menginap di kantor? Sampai pagi?{\i0}
Dialogue: 0,0:11:53.75,0:11:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Oh, dan Yamada-chan…
Dialogue: 0,0:11:56.04,0:11:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya?
Dialogue: 0,0:11:57.38,0:12:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Manajer toko ingin bicara padamu\N‎sebelum kau pulang.
Dialogue: 0,0:12:09.14,0:12:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san. Selamat ma…
Dialogue: 0,0:12:13.19,0:12:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Astaga.{\i0}
Dialogue: 0,0:12:14.27,0:12:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎ADA YANG SEDANG MARAH…
Dialogue: 0,0:12:21.07,0:12:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ternyata Sasaki-san.
Dialogue: 0,0:12:23.45,0:12:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Halo.
Dialogue: 0,0:12:24.53,0:12:26.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jangan hanya berdiri saja.\N‎Duduklah denganku.
Dialogue: 0,0:12:26.99,0:12:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Benar.
Dialogue: 0,0:12:33.46,0:12:37.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Semua baik-baik…\N‎- Sasaki-san. Kau libur hari ini?
Dialogue: 0,0:12:38.42,0:12:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya, anehnya.
Dialogue: 0,0:12:41.84,0:12:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Itulah kata orang\N‎yang bekerja di kantor toksik.
Dialogue: 0,0:12:51.47,0:12:53.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku senang kau libur.
Dialogue: 0,0:13:12.37,0:13:14.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak merokok hari ini?
Dialogue: 0,0:13:14.00,0:13:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Hari ini dingin, jadi aku butuh minuman.
Dialogue: 0,0:13:16.79,0:13:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau juga mau?
Dialogue: 0,0:13:21.59,0:13:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jika perasaanmu tak enak,
Dialogue: 0,0:13:23.34,0:13:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎bukankah orang bilang minuman hangat\N‎lebih baik daripada rokok atau alkohol?
Dialogue: 0,0:13:34.39,0:13:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku dapat keluhan.\N‎Pertama kalinya sejak lama.
Dialogue: 0,0:13:37.39,0:13:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎"Pelayanannya kepada pelanggan bagus,
Dialogue: 0,0:13:40.23,0:13:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎tapi sayang sekali\N‎dia selalu berbau rokok."
Dialogue: 0,0:13:43.82,0:13:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Manajer toko bilang itu tak sopan\N‎dan aku tak perlu khawatir, tapi…
Dialogue: 0,0:13:55.00,0:13:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tapi keluhan seperti itu\N‎membuatku merasa bodoh.
Dialogue: 0,0:14:04.96,0:14:06.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Menyedihkan sekali.
Dialogue: 0,0:14:07.38,0:14:11.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kehilangan kepercayaan pada orang\N‎yang dianggap hebat
Dialogue: 0,0:14:11.01,0:14:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎karena melihat sisi dirinya yang baru
Dialogue: 0,0:14:13.85,0:14:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎walaupun kau tetap orang yang sama…
Dialogue: 0,0:14:19.19,0:14:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tapi aku terlalu ikut campur.
Dialogue: 0,0:14:22.23,0:14:26.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku bahkan tak tahu\N‎kau bekerja di bagian mana…
Dialogue: 0,0:14:30.82,0:14:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf. Bajuku tipis hari ini,\N‎dan aku tak bisa berhenti bersin…
Dialogue: 0,0:14:40.58,0:14:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san! Apa yang kau…
Dialogue: 0,0:14:47.72,0:14:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau bisa pinjam ini.
Dialogue: 0,0:14:54.76,0:14:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Hangat.
Dialogue: 0,0:14:56.43,0:14:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih, Tayama-san.
Dialogue: 0,0:15:12.16,0:15:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak. Aku yang terima kasih.
Dialogue: 0,0:15:23.38,0:15:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dan maaf, Sasaki-san.
Dialogue: 0,0:15:27.17,0:15:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Aku tak bisa minum kopi.\N‎- Apa?
Dialogue: 0,0:15:29.88,0:15:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau tampak terkejut.
Dialogue: 0,0:15:32.38,0:15:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak, bukan begitu.
Dialogue: 0,0:15:34.97,0:15:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku sebenarnya juga tak bisa.
Dialogue: 0,0:15:38.14,0:15:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Haruskah kubeli jus saja?
Dialogue: 0,0:15:40.64,0:15:43.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku mau Depovita.
Dialogue: 0,0:15:50.53,0:15:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Cuacanya indah sekali.{\i0}
Dialogue: 0,0:15:53.86,0:15:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aku suka cuaca musim semi ini.{\i0}
Dialogue: 0,0:15:57.28,0:15:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Terasa sampai ke tulang.{\i0}
Dialogue: 0,0:16:01.83,0:16:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Terutama setelah dimarahi oleh klien itu.{\i0}
Dialogue: 0,0:16:05.17,0:16:07.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maafkan aku!
Dialogue: 0,0:16:08.34,0:16:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Sekarang aku harus kembali ke kantor.{\i0}
Dialogue: 0,0:16:10.92,0:16:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aku mungkin akan mampir\N‎ke Super S dan beli makanan.{\i0}
Dialogue: 0,0:16:16.80,0:16:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Tayama-san pasti bekerja malam.{\i0}
Dialogue: 0,0:16:22.69,0:16:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aku tak yakin dia akan ada di sana.{\i0}
Dialogue: 0,0:16:29.94,0:16:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san…
Dialogue: 0,0:16:33.95,0:16:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Yamada-san?
Dialogue: 0,0:16:36.57,0:16:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Halo.
Dialogue: 0,0:16:37.95,0:16:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa yang kau lakukan di sini?
Dialogue: 0,0:16:40.45,0:16:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jangan bilang kau juga bekerja\N‎di siang hari?
Dialogue: 0,0:16:43.96,0:16:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak apa-apa, Sasaki-san. Tenanglah.
Dialogue: 0,0:16:46.92,0:16:49.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maafkan aku.
Dialogue: 0,0:16:49.21,0:16:51.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku biasanya bekerja malam,
Dialogue: 0,0:16:51.55,0:16:54.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎tapi hari ini aku bekerja siang\N‎karena staf kami kurang.
Dialogue: 0,0:16:54.30,0:16:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dan aku ke sini karena…
Dialogue: 0,0:16:56.47,0:16:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tenanglah.
Dialogue: 0,0:17:02.73,0:17:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ini satu-satunya\N‎mesin penjual otomatis kami.
Dialogue: 0,0:17:05.14,0:17:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Begitu.
Dialogue: 0,0:17:07.44,0:17:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau pulang cepat hari ini?
Dialogue: 0,0:17:09.61,0:17:13.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak, aku akan kembali ke kantor,
Dialogue: 0,0:17:13.11,0:17:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎tapi kupikir jika Tayama-san di sini,\N‎aku ingin merokok…
Dialogue: 0,0:17:17.03,0:17:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf, Yamada-san.
Dialogue: 0,0:17:18.37,0:17:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tahu aku tak bekerja di sini, tapi…
Dialogue: 0,0:17:20.74,0:17:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku hanya menerima ajakan Tayama-san\N‎untuk merokok dengannya.
Dialogue: 0,0:17:24.37,0:17:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tolong jangan salahkan dia.
Dialogue: 0,0:17:27.75,0:17:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jadi…
Dialogue: 0,0:17:30.88,0:17:33.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak apa-apa, Sasaki-san.
Dialogue: 0,0:17:33.21,0:17:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku sudah tahu.
Dialogue: 0,0:17:35.88,0:17:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-chan sudah memberitahuku.
Dialogue: 0,0:17:38.84,0:17:41.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau membicarakan segalanya padanya.
Dialogue: 0,0:17:41.01,0:17:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kalian pasti teman baik.
Dialogue: 0,0:17:46.27,0:17:47.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Lamban-saki.
Dialogue: 0,0:17:48.90,0:17:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎- Apa?\N‎- Ya! Kami teman baik.
Dialogue: 0,0:17:51.65,0:17:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kupikir juga begitu.
Dialogue: 0,0:17:53.03,0:17:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku yakin kalian punya banyak kesamaan.
Dialogue: 0,0:17:56.28,0:18:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apalagi kalian berdua\N‎pandai membaca orang lain.
Dialogue: 0,0:18:04.79,0:18:07.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Oh, dan Yamada-san…
Dialogue: 0,0:18:07.66,0:18:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya?
Dialogue: 0,0:18:08.75,0:18:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Jadi,
Dialogue: 0,0:18:10.88,0:18:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎apa Tayama-san baik-baik saja?
Dialogue: 0,0:18:14.84,0:18:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya, dia baik.
Dialogue: 0,0:18:18.18,0:18:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maksudmu keluhan yang dia terima?
Dialogue: 0,0:18:20.84,0:18:22.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya.
Dialogue: 0,0:18:22.01,0:18:27.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf, tapi aku dan Tayama-san\N‎membicarakannya sedikit.
Dialogue: 0,0:18:27.85,0:18:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku penasaran dengan keadaannya.
Dialogue: 0,0:18:32.02,0:18:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia baik-baik saja.
Dialogue: 0,0:18:34.19,0:18:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku juga mengkhawatirkannya,
Dialogue: 0,0:18:36.36,0:18:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎tapi dia bilang dia makan ramen,\N‎tidur, dan melupakan semua itu.
Dialogue: 0,0:18:42.12,0:18:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Begitu. Senang mendengarnya.
Dialogue: 0,0:18:45.08,0:18:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kuharap kau terus\N‎jadi pendengarnya, Sasaki-san.
Dialogue: 0,0:18:50.12,0:18:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya, tapi…
Dialogue: 0,0:18:52.33,0:18:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa ide bagus mengungkit hal\N‎yang sudah dilupakan?
Dialogue: 0,0:18:58.72,0:19:02.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak hanya soal masalah ini saja.
Dialogue: 0,0:19:02.22,0:19:06.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Akan kuberi tahu padanya\N‎kau mengkhawatirkannya.
Dialogue: 0,0:19:08.64,0:19:12.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau yakin? Aku tak ingin ikut campur.
Dialogue: 0,0:19:12.23,0:19:14.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau sudah mendengarkannya.
Dialogue: 0,0:19:14.90,0:19:18.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa itu masih dianggap\N‎terlalu ikut campur?
Dialogue: 0,0:19:19.70,0:19:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kurasa tidak.
Dialogue: 0,0:19:23.95,0:19:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Omong-omong, Yamada-san,
Dialogue: 0,0:19:26.37,0:19:28.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎terima kasih soal sebelumnya.
Dialogue: 0,0:19:30.04,0:19:32.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-san bilang padaku.
Dialogue: 0,0:19:32.12,0:19:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Dia bilang kau mengkhawatirkanku\N‎saat aku merasa sedih.
Dialogue: 0,0:19:37.50,0:19:40.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak ingin mengganggu\N‎dengan mengobrol di kasir,
Dialogue: 0,0:19:40.42,0:19:43.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎jadi aku tak sempat berterima kasih.
Dialogue: 0,0:19:43.18,0:19:44.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Bukan apa-apa.
Dialogue: 0,0:19:47.64,0:19:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku ada masalah di kantor,\N‎jadi aku berterima kasih.
Dialogue: 0,0:19:51.69,0:19:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sangat berarti saat ada orang yang peduli.
Dialogue: 0,0:19:56.61,0:19:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak apa-apa.
Dialogue: 0,0:19:59.15,0:20:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tapi kuharap aku tak terlalu ikut campur.
Dialogue: 0,0:20:03.41,0:20:05.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau pikir kau ikut campur?
Dialogue: 0,0:20:06.78,0:20:09.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Lihat itu. Padahal aku baru bilang.
Dialogue: 0,0:20:11.29,0:20:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kurasa memang begitu, ya?
Dialogue: 0,0:20:17.50,0:20:19.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf! Aku mengoceh dan menahanmu di sini.
Dialogue: 0,0:20:19.96,0:20:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tak apa-apa.
Dialogue: 0,0:20:21.05,0:20:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku senang bisa mengobrol denganmu\N‎seperti Tayama-chan.
Dialogue: 0,0:20:28.68,0:20:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tayama-chan mungkin tak ada di sini,
Dialogue: 0,0:20:30.60,0:20:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎tapi silakan merokok jika kau mau.
Dialogue: 0,0:20:33.23,0:20:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terima kasih.
Dialogue: 0,0:20:36.73,0:20:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sebenarnya, kupikir aku akan kembali\N‎tanpa merokok hari ini.
Dialogue: 0,0:20:40.19,0:20:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Aku tak ingin baunya menempel padamu.
Dialogue: 0,0:20:44.07,0:20:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf mengganggu waktu istirahatmu.
Dialogue: 0,0:20:46.82,0:20:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sampai jumpa.
Dialogue: 0,0:20:53.83,0:20:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Sasaki-san.
Dialogue: 0,0:20:54.92,0:20:55.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ya?
Dialogue: 0,0:21:08.51,0:21:11.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Ada kelopak bunga di rambutmu sejak tadi.
Dialogue: 0,0:21:13.35,0:21:15.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Apa? Sejak tadi?
Dialogue: 0,0:21:15.35,0:21:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Benar.
Dialogue: 0,0:21:16.44,0:21:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Lucu sekali. Kelopak bunga\N‎di kepala pria tua…
Dialogue: 0,0:21:20.61,0:21:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Kau terlihat imut,\N‎jadi aku tak bilang apa-apa.
Dialogue: 0,0:21:23.74,0:21:25.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Maaf soal itu.
Dialogue: 0,0:21:26.74,0:21:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Tidak, terima kasih.
Dialogue: 0,0:21:37.50,0:21:39.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Yamada-san bisa sedikit…{\i0}
Dialogue: 0,0:21:40.84,0:21:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎usil.{\i0}
Dialogue: 0,0:22:06.15,0:22:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Sasaki-san lamban sekali.{\i0}
Dialogue: 0,0:22:13.66,0:22:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}‎Aneh.{\i0}
Dialogue: 0,0:23:34.87,0:23:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}‎Terjemahan subtitle oleh Rahayu Kinasih
