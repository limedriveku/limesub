Dialogue: 0,0:03:48.77,0:03:52.48,sign,,0000,0000,0000,,{\an8}PERHATIKAN LINGKUNGAN SEKITAR\NUNTUK MENCEGAH PAPARAN ASAP ROKOK PASIF.
Dialogue: 0,0:03:52.48,0:03:54.52,sign,,0000,0000,0000,,{\an8}DI BAWAH 20 TAHUN DILARANG MEROKOK.
Dialogue: 0,0:09:12.00,0:09:14.42,sign,,0000,0000,0000,,UANG TERSISA: 10 YEN
Dialogue: 0,0:11:00.49,0:11:01.41,sign,,0000,0000,0000,,LIHATLAH, ADIK!
Dialogue: 0,0:11:08.16,0:11:10.33,sign,,0000,0000,0000,,{\an8}MATI SAJA KAU
Dialogue: 0,0:11:42.61,0:11:46.12,sign,,0000,0000,0000,,{\an8}JANGAN COBA-COBA INI DI RUMAH
Dialogue: 0,0:17:47.31,0:17:50.61,sign,,0000,0000,0000,,{\an8}SATU HARI SEBELUMNYA
Dialogue: 0,0:23:37.99,0:23:38.91,sign,,0000,0000,0000,,INI KARYA FIKSI.
Dialogue: 0,0:23:38.91,0:23:40.91,sign,,0000,0000,0000,,ANAK-ANAK\NDILARANG MEROKOK DAN MINUM-MINUM.
Dialogue: 0,0:01:02.64,0:01:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah!
Dialogue: 0,0:01:04.64,0:01:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharian lagi aku menyapu puntung rokok\Nyang berserakan di atas tanah.
Dialogue: 0,0:01:10.23,0:01:11.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa-apaan?\N- Gawat.
Dialogue: 0,0:01:11.82,0:01:13.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajuku terkena noda tar.
Dialogue: 0,0:01:16.24,0:01:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yanineko, apa kau sudah gila?
Dialogue: 0,0:01:21.53,0:01:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayar uang sewanya\Nmasih minggu depan, bukan?
Dialogue: 0,0:01:25.62,0:01:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:01:27.12,0:01:29.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, lebih berhati-hati!
Dialogue: 0,0:01:42.93,0:01:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku baru dapat puntung rokok\Nyang masih panjang!
Dialogue: 0,0:01:45.93,0:01:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menghitam karena cairan aneh.
Dialogue: 0,0:01:50.23,0:01:52.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan apa-apa.
Dialogue: 0,0:02:00.74,0:02:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sial!{\i0}
Dialogue: 0,0:02:04.04,0:02:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dasar kucing cabul itu!{\i0}
Dialogue: 0,0:02:13.25,0:02:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini terjadi?
Dialogue: 0,0:03:54.52,0:03:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sebungkus rokok baru.
Dialogue: 0,0:03:56.52,0:04:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi ini saja masih belum lengkap.
Dialogue: 0,0:04:02.78,0:04:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bungkus rokok baru isinya padat.
Dialogue: 0,0:04:07.66,0:04:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mengeluarkan sekitar lima batang,
Dialogue: 0,0:04:09.83,0:04:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih ada ruang\Nuntuk menyelipkan korek murah.
Dialogue: 0,0:04:13.79,0:04:18.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebungkus rokok seperti ini\Ntak ada tandingannya.
Dialogue: 0,0:04:31.43,0:04:34.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempurnaan hidup hanya sementara.
Dialogue: 0,0:04:36.81,0:04:40.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya terlalu padat,\Njadi tak bisa kuambil.
Dialogue: 0,0:04:51.58,0:04:52.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil.
Dialogue: 0,0:04:53.12,0:04:54.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini terjadi?
Dialogue: 0,0:04:54.62,0:04:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa salahku sampai harus mengalami ini?
Dialogue: 0,0:04:59.54,0:05:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, belum tiga detik.
Dialogue: 0,0:05:01.30,0:05:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubawa pulang saja\Nrokok yang tak terkena kotoran.
Dialogue: 0,0:05:05.09,0:05:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uangku sudah pas-pasan bulan ini.
Dialogue: 0,0:05:14.35,0:05:16.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin bisa dipakai\Nkalau ujungnya kupotong.
Dialogue: 0,0:05:17.35,0:05:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat!{\i0}
Dialogue: 0,0:05:22.57,0:05:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, semua antro pegawai sementara,\Nbisa simak kata-kataku?
Dialogue: 0,0:05:26.07,0:05:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kujelaskan pekerjaan kalian hari ini.
Dialogue: 0,0:05:29.12,0:05:32.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, seluruh area ini\Nmenerapkan larangan merokok.
Dialogue: 0,0:05:32.24,0:05:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokok kalian disita\Nsampai jam kerja selesai.
Dialogue: 0,0:05:41.00,0:05:43.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Setelah 20 menit tanpa merokok,
Dialogue: 0,0:05:43.30,0:05:48.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}tekanan darah\Ndan tanda vital lainnya kembali normal.
Dialogue: 0,0:05:53.26,0:05:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah 30 menit tanpa merokok,
Dialogue: 0,0:05:55.48,0:06:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kadar nikotin tubuh berkurang separuh,\Ndan gejala putus nikotin mulai muncul.
Dialogue: 0,0:06:06.28,0:06:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah enam sampai delapan jam\Ntanpa merokok,
Dialogue: 0,0:06:09.45,0:06:15.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kadar karbon monoksida dan oksigen\Ndalam darah kembali normal.
Dialogue: 0,0:06:18.41,0:06:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Nomor 56 pergi ke mana?
Dialogue: 0,0:06:20.08,0:06:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dia kabur!
Dialogue: 0,0:06:21.29,0:06:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jam kerjanya masih tersisa 30 menit!
Dialogue: 0,0:06:39.31,0:06:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nikmat sekali!
Dialogue: 0,0:06:45.57,0:06:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau antro pembantu?
Dialogue: 0,0:06:47.69,0:06:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vas ini harta nasional.
Dialogue: 0,0:06:50.57,0:06:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sampai tergores olehmu,
Dialogue: 0,0:06:52.24,0:06:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau bau hewan dari tubuhmu\Nmenempel di sana.
Dialogue: 0,0:06:56.74,0:06:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:07:15.60,0:07:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa malah lebih kotor\Ndaripada sebelum kau poles?
Dialogue: 0,0:07:20.14,0:07:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan baunya seperti stasiun kereta api.
Dialogue: 0,0:07:30.86,0:07:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas kau!
Dialogue: 0,0:07:37.29,0:07:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku hanya punya 170 yen.{\i0}
Dialogue: 0,0:07:39.83,0:07:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan enam batang rokok.{\i0}
Dialogue: 0,0:07:41.71,0:07:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Masih enam hari\Nsampai aku masuk kerja lagi.{\i0}
Dialogue: 0,0:07:45.50,0:07:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus hidup dengan 28 yen sehari.{\i0}
Dialogue: 0,0:07:48.88,0:07:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan satu batang rokok per hari.{\i0}
Dialogue: 0,0:07:53.97,0:07:55.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik, aku sanggup!{\i0}
Dialogue: 0,0:07:58.39,0:08:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini rokokku yang pertama\Ndan terakhir untuk hari ini.{\i0}
Dialogue: 0,0:08:06.36,0:08:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Saat aku merokok,\Naku bebas dari segala kekhawatiranku.{\i0}
Dialogue: 0,0:08:10.90,0:08:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ya.{\i0}
Dialogue: 0,0:08:12.15,0:08:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bertahan hidup enam hari\Ndengan 170 yen tidak masalah.{\i0}
Dialogue: 0,0:08:22.41,0:08:24.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, mungkin satu lagi.
Dialogue: 0,0:08:33.17,0:08:35.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Gawat.{\i0}
Dialogue: 0,0:08:35.68,0:08:39.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, merokok hanya sebatang sehari\Npasti terlalu berat.
Dialogue: 0,0:08:39.43,0:08:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang setelah habis,\Naku bisa menerimanya.
Dialogue: 0,0:08:45.06,0:08:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ini selalu terjadi?
Dialogue: 0,0:08:47.27,0:08:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu, selalu, selalu!
Dialogue: 0,0:08:48.65,0:08:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tekadku terlalu lemah?
Dialogue: 0,0:08:51.82,0:08:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan orang jahat.
Dialogue: 0,0:09:01.99,0:09:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuhan masih menyayangiku!
Dialogue: 0,0:09:06.00,0:09:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Totalnya 1.160 yen.
Dialogue: 0,0:09:15.13,0:09:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:09:20.14,0:09:22.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak?
Dialogue: 0,0:09:22.77,0:09:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak mengobrol.
Dialogue: 0,0:09:24.14,0:09:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:09:25.77,0:09:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tak ada apa-apa, aku menelepon\Nkarena ingin mendengar suara adikku.{\i0}
Dialogue: 0,0:09:31.27,0:09:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau aneh.
Dialogue: 0,0:09:32.90,0:09:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merindukanmu. Lama tak mengobrol.
Dialogue: 0,0:09:35.82,0:09:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mampirlah sesekali.
Dialogue: 0,0:09:37.53,0:09:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak mau.\N- Apa?
Dialogue: 0,0:09:39.99,0:09:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatmu selalu berbau rokok.
Dialogue: 0,0:09:42.49,0:09:44.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti lantaimu penuh abu rokok.
Dialogue: 0,0:09:44.66,0:09:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak.
Dialogue: 0,0:09:46.87,0:09:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kirimi aku foto kamarmu.
Dialogue: 0,0:09:48.79,0:09:51.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupertimbangkan datang\Nsetelah melihatnya.
Dialogue: 0,0:10:00.05,0:10:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan membersihkan tempat ini.
Dialogue: 0,0:10:02.26,0:10:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan.
Dialogue: 0,0:10:04.68,0:10:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pertama, buang sampah.\NTidak, aku perlu kantong sampah dulu.{\i0}
Dialogue: 0,0:10:07.64,0:10:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lantai harus kuapakan?{\i0}
Dialogue: 0,0:10:08.89,0:10:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pungut puntung rokok,\Nbuang, bersihkan kulkas.{\i0}
Dialogue: 0,0:10:11.23,0:10:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bersihkan kloset.{\i0}
Dialogue: 0,0:10:12.40,0:10:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku dalam kesulitan besar.{\i0}
Dialogue: 0,0:10:14.57,0:10:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tak cukup waktu!{\i0}
Dialogue: 0,0:10:24.08,0:10:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sakit.{\i0}
Dialogue: 0,0:10:25.95,0:10:29.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa aku sangat sial?{\i0}
Dialogue: 0,0:10:29.37,0:10:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku perlu merokok.{\i0}
Dialogue: 0,0:10:35.21,0:10:38.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Puntung-puntung rokok ini\Nmasih bisa diisap.
Dialogue: 0,0:10:39.76,0:10:43.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini masih utuh! Senangnya!
Dialogue: 0,0:10:43.76,0:10:47.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat beruntung.
Dialogue: 0,0:10:51.69,0:10:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Kakak.
Dialogue: 0,0:10:54.07,0:10:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti buru-buru membereskan kamarnya.
Dialogue: 0,0:10:57.32,0:11:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa jika hanya berantakan sedikit,\Nakan kumaklumi.
Dialogue: 0,0:11:02.99,0:11:04.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Tinja.{\i0}
Dialogue: 0,0:11:14.21,0:11:16.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berhenti merokok
Dialogue: 0,0:11:16.55,0:11:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena adikku terlihat marah.
Dialogue: 0,0:11:20.42,0:11:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tulisannya terlalu panjang.
Dialogue: 0,0:11:28.22,0:11:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semakin banyak kupakai,\Nsemakin bagus, bukan?
Dialogue: 0,0:11:46.12,0:11:47.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:11:47.87,0:11:51.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tak merokok\Nselama tiga hari penuh?
Dialogue: 0,0:11:51.29,0:11:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya berusaha sebisaku.
Dialogue: 0,0:11:53.62,0:11:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dulu merokok sangat banyak,\Nseolah bernapas dengan nikotin.
Dialogue: 0,0:11:57.75,0:11:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat bangga padamu!
Dialogue: 0,0:11:59.34,0:12:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:12:01.26,0:12:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku serius!
Dialogue: 0,0:12:02.68,0:12:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti hal terhebat\Nyang pernah kau capai.
Dialogue: 0,0:12:06.76,0:12:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, kau terlalu memujiku.
Dialogue: 0,0:12:09.27,0:12:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:26.95,0:12:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada yang lebih nikmat\Ndaripada bir di tengah hari kerja.
Dialogue: 0,0:12:37.29,0:12:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lingkaran asapnya berbentuk hati.
Dialogue: 0,0:12:39.34,0:12:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti itu pertanda baik.
Dialogue: 0,0:12:47.39,0:12:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau.
Dialogue: 0,0:12:49.60,0:12:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maumu, Perokok?
Dialogue: 0,0:12:56.77,0:12:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya berbagi keberuntunganku.
Dialogue: 0,0:13:05.20,0:13:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:13:07.70,0:13:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi belikan minuman keras dan rokok.
Dialogue: 0,0:13:10.20,0:13:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bir dan rokok.
Dialogue: 0,0:13:11.74,0:13:15.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku harus mengerjakan PR.
Dialogue: 0,0:13:15.87,0:13:20.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau membantahku, Bocah?
Dialogue: 0,0:13:20.00,0:13:22.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan belajarmu yang bodoh itu!
Dialogue: 0,0:13:22.34,0:13:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kau\Nakan langsung bekerja setelah SMP!
Dialogue: 0,0:13:25.26,0:13:26.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi…
Dialogue: 0,0:13:27.68,0:13:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kau bersyukur\Naku mau mengurus wajah jelekmu.
Dialogue: 0,0:13:31.72,0:13:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkan terima kasihmu\Nbelikan aku miras dan rokok, Anak Sialan.
Dialogue: 0,0:13:42.27,0:13:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:14:01.63,0:14:03.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:14:03.59,0:14:08.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa adikku dan pemilik rumah\Nkompak mengatakan aku bau?
Dialogue: 0,0:14:14.81,0:14:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, aku benci mandi.\NMerepotkan sekali.
Dialogue: 0,0:14:37.25,0:14:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bagaimanapun,\Nmandi membuatku merasa segar.
Dialogue: 0,0:14:41.21,0:14:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mandi seperti mencuci jiwa.
Dialogue: 0,0:14:44.46,0:14:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin aku suka menjadi bersih.
Dialogue: 0,0:14:59.94,0:15:01.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadi bersih itu merepotkan,
Dialogue: 0,0:15:01.81,0:15:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku suka merokok setelah mandi.
Dialogue: 0,0:15:18.50,0:15:21.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tenggorokanku sakit, badanku meriang.{\i0}
Dialogue: 0,0:15:21.67,0:15:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa aku terkena flu?{\i0}
Dialogue: 0,0:15:26.38,0:15:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ya, ini pasti flu.{\i0}
Dialogue: 0,0:15:29.09,0:15:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Rokok terasa tak enak,\Naku tak bisa merokok.{\i0}
Dialogue: 0,0:15:32.76,0:15:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku perlu beristirahat.{\i0}
Dialogue: 0,0:15:44.77,0:15:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, datanglah lagi.
Dialogue: 0,0:15:57.58,0:16:00.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik, setidaknya aku bisa merokok mentol.{\i0}
Dialogue: 0,0:16:25.94,0:16:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong.
Dialogue: 0,0:16:30.94,0:16:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau kabur?
Dialogue: 0,0:16:33.86,0:16:36.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sengaja datang merawatmu.
Dialogue: 0,0:16:36.24,0:16:38.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kau petugas Dinas Kesehatan.
Dialogue: 0,0:16:38.99,0:16:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya tak mungkin\Nmerawat orang pakai pakaian hazmat.
Dialogue: 0,0:16:42.12,0:16:45.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena tempat ini bau rokok,
Dialogue: 0,0:16:45.08,0:16:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tak pernah kau bersihkan.
Dialogue: 0,0:16:47.88,0:16:51.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahan bau sampah dan tar.
Dialogue: 0,0:16:52.88,0:16:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau rasakan?
Dialogue: 0,0:16:56.22,0:16:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit lebih baik dari kemarin.
Dialogue: 0,0:17:02.14,0:17:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubuatkan kau bubur.
Dialogue: 0,0:17:05.10,0:17:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kata-katanya tak enak didengar,{\i0}
Dialogue: 0,0:17:08.02,0:17:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi dia tetap datang.{\i0}
Dialogue: 0,0:17:09.94,0:17:13.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Adikku menyayangiku.{\i0}
Dialogue: 0,0:17:15.53,0:17:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buburnya sudah matang.
Dialogue: 0,0:17:24.71,0:17:27.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kau tak apa-apa? Aku minta maaf!
Dialogue: 0,0:17:27.33,0:17:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan! Tak tahan!
Dialogue: 0,0:17:29.08,0:17:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana maskerku? Gawat!
Dialogue: 0,0:17:37.89,0:17:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan?
Dialogue: 0,0:17:39.55,0:17:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:17:42.22,0:17:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah baunya separah itu?
Dialogue: 0,0:17:44.48,0:17:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, itu menyakitkan.
Dialogue: 0,0:17:53.69,0:17:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini Imoko?
Dialogue: 0,0:17:56.49,0:17:58.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Kansai.
Dialogue: 0,0:17:59.62,0:18:01.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih telah menjaga kakakku.
Dialogue: 0,0:18:02.20,0:18:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat sopan.
Dialogue: 0,0:18:04.33,0:18:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh adik si "itu"?
Dialogue: 0,0:18:07.33,0:18:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa?
Dialogue: 0,0:18:08.58,0:18:11.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya kakakku terkena flu.
Dialogue: 0,0:18:11.79,0:18:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku ke sini membeli pakaian hazmat.
Dialogue: 0,0:18:14.34,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata karena itu kau ke sini.
Dialogue: 0,0:18:17.72,0:18:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit kupercaya, si "itu" bisa sakit juga.
Dialogue: 0,0:18:20.72,0:18:24.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku memang mudah terkena flu.
Dialogue: 0,0:18:24.64,0:18:27.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia suka makan\Nsampai 50 es loli sekaligus.{\i0}
Dialogue: 0,0:18:27.39,0:18:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Atau melompat ke salju\Ndengan hanya berpakaian kaus.{\i0}
Dialogue: 0,0:18:30.65,0:18:33.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan setiap kali, aku yang merawatnya.{\i0}
Dialogue: 0,0:18:33.40,0:18:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kedengarannya kau kerepotan.{\i0}
Dialogue: 0,0:18:34.98,0:18:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar sekali.{\i0}
Dialogue: 0,0:18:38.36,0:18:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti merepotkan datang ke sini.
Dialogue: 0,0:18:40.57,0:18:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengeceknya\Nkalau kau kirim pesan.
Dialogue: 0,0:18:45.24,0:18:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:18:48.41,0:18:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tak ada\Nyang lebih memahami kakakku dari aku.
Dialogue: 0,0:18:52.29,0:18:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir yang terbaik\Nadalah aku yang merawatnya.
Dialogue: 0,0:18:59.51,0:19:01.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Manisnya.
Dialogue: 0,0:19:02.30,0:19:03.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah adikku.
Dialogue: 0,0:19:03.72,0:19:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:19:06.60,0:19:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:19:14.57,0:19:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dokter, apakah paru-paru kakakku…
Dialogue: 0,0:19:17.57,0:19:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti akan mati.
Dialogue: 0,0:19:19.90,0:19:20.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:19:21.28,0:19:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupnya mungkin tinggal dua,\Ntiga bulan lagi.
Dialogue: 0,0:19:24.28,0:19:25.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:19:25.53,0:19:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin sedikit lebih lama.
Dialogue: 0,0:19:28.29,0:19:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekitar 100 hari?
Dialogue: 0,0:19:31.00,0:19:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seratus…
Dialogue: 0,0:19:32.33,0:19:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kucing?
Dialogue: 0,0:19:34.96,0:19:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adikku!
Dialogue: 0,0:19:36.84,0:19:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya membuat adikku menangis!
Dialogue: 0,0:19:38.59,0:19:41.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paru-parumu yang membuatnya menangis.
Dialogue: 0,0:19:41.93,0:19:44.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, aku paham.
Dialogue: 0,0:19:44.64,0:19:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang pasti akan mati.
Dialogue: 0,0:19:47.81,0:19:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesederhana itu.
Dialogue: 0,0:19:53.27,0:19:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilarang merokok di dalam rumah sakit,\Ndasar hewan kotor menjijikkan!
Dialogue: 0,0:19:59.11,0:20:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi?
Dialogue: 0,0:20:00.65,0:20:01.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya mimpi?
Dialogue: 0,0:20:03.49,0:20:06.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kanker paru-paru\Ndan sisa hidup 100 hari hanya mimpi?
Dialogue: 0,0:20:14.12,0:20:15.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak?
Dialogue: 0,0:20:15.42,0:20:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:16.88,0:20:18.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa aku membangunkanmu?{\i0}
Dialogue: 0,0:20:18.38,0:20:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku sedang mengerjakan PR.
Dialogue: 0,0:20:21.88,0:20:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terdengar lesu.
Dialogue: 0,0:20:23.88,0:20:25.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa flumu kambuh lagi?
Dialogue: 0,0:20:28.64,0:20:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku baik-baik saja.{\i0}
Dialogue: 0,0:20:31.64,0:20:32.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:20:32.77,0:20:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:35.23,0:20:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh. Tidak ada apa-apa.
Dialogue: 0,0:20:38.23,0:20:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin bicara denganmu.
Dialogue: 0,0:20:43.90,0:20:45.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benarkah?{\i0}
Dialogue: 0,0:20:45.24,0:20:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pokoknya, kau harus bisa menjaga diri.{\i0}
Dialogue: 0,0:20:48.12,0:20:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak mudah untuk datang\Nmemakai pakaian hazmat.{\i0}
Dialogue: 0,0:20:52.79,0:20:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Adikku.
Dialogue: 0,0:20:54.54,0:20:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Ya?{\i0}
Dialogue: 0,0:20:57.54,0:21:00.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku akan berhenti merokok, aku bersumpah!{\i0}
Dialogue: 0,0:21:04.88,0:21:08.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ke luar. Sangat indah.
Dialogue: 0,0:21:18.06,0:21:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengagumkan, bukan?
Dialogue: 0,0:21:20.48,0:21:23.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, Galaksi Bima Sakti\Nterlihat jelas malam ini.
Dialogue: 0,0:21:24.07,0:21:26.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak tahu apa yang terjadi,{\i0}
Dialogue: 0,0:21:26.53,0:21:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}tapi kau selalu boleh meneleponku\Nkapan saja kau mau.{\i0}
Dialogue: 0,0:21:35.08,0:21:36.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bintang-bintang sangat indah.
Dialogue: 0,0:21:37.37,0:21:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ya.{\i0}
Dialogue: 0,0:21:39.08,0:21:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tepat di sini{\i0}
Dialogue: 0,0:21:40.96,0:21:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di bawah bintang yang sama.
Dialogue: 0,0:21:44.38,0:21:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bentuknya seperti asap rokok.{\i0}
Dialogue: 0,0:21:46.97,0:21:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:49.47,0:21:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bunyi apa itu?
Dialogue: 0,0:21:50.72,0:21:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kak?{\i0}
Dialogue: 0,0:21:51.97,0:21:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku dengar bunyi "wus".{\i0}
Dialogue: 0,0:21:53.22,0:21:56.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Itu suara korek?{\i0}
Dialogue: 0,0:21:56.52,0:21:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau barusan menyalakan apa?{\i0}
Dialogue: 0,0:21:58.23,0:22:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Katamu kau akan berhenti merokok!{\i0}
Dialogue: 0,0:22:04.90,0:22:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, rasanya nikmat.
Dialogue: 0,0:23:32.91,0:23:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terjemahan subtitle oleh Stysa Alverina
