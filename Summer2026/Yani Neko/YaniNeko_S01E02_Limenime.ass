Dialogue: 0,0:01:04.14,0:01:07.98,sign,,0000,0000,0000,,LATIHAN RESEPTOR NIKOTIN
Dialogue: 0,0:06:09.45,0:06:12.20,sign,,0000,0000,0000,,{\an8}MENGANDUNG OBAT PENCEGAH RABIES
Dialogue: 0,0:06:48.99,0:06:51.99,sign,,0000,0000,0000,,VITAMIN, PENCAHAR, KARTU TELEPON,\NJARUM, PERMEN, AIR, RAMUAN
Dialogue: 0,0:07:40.41,0:07:45.42,sign,,0000,0000,0000,,YAKU NEKO SANGAT PAYAH\NDALAM MEMBUKTIKAN DIA TAK BERSALAH
Dialogue: 0,0:08:03.77,0:08:05.19,sign,,0000,0000,0000,,{\an8}PERAMAL NASIB - 2.000 YEN
Dialogue: 0,0:13:02.23,0:13:03.15,sign,,0000,0000,0000,,{\an8}MENGAMUK
Dialogue: 0,0:13:22.96,0:13:23.88,sign,,0000,0000,0000,,LAGA PERINGKAT
Dialogue: 0,0:13:28.39,0:13:29.47,sign,,0000,0000,0000,,ULTIMATE MASTER
Dialogue: 0,0:14:20.65,0:14:22.06,sign,,0000,0000,0000,,{\an8}MENGAMUK
Dialogue: 0,0:15:51.45,0:15:53.32,sign,,0000,0000,0000,,MOHON TUNGGU\NBERSIAP - KANAL HAME
Dialogue: 0,0:15:53.32,0:15:55.57,sign,,0000,0000,0000,,HANYA MENGOBROL:\NHAME SEDANG KESULITAN
Dialogue: 0,0:16:16.85,0:16:17.80,sign,,0000,0000,0000,,AGAKNYA REKAYASA
Dialogue: 0,0:16:25.31,0:16:26.40,sign,,0000,0000,0000,,PEMBAWAANNYA BERBEDA
Dialogue: 0,0:16:26.40,0:16:27.48,sign,,0000,0000,0000,,INI TIDAK DIJEDA
Dialogue: 0,0:16:27.48,0:16:28.56,sign,,0000,0000,0000,,INI BURUK
Dialogue: 0,0:16:28.57,0:16:29.73,sign,,0000,0000,0000,,HAME! INI TAK DIJEDA!
Dialogue: 0,0:16:29.73,0:16:30.82,sign,,0000,0000,0000,,KUSIMPAN CUPLIKANNYA
Dialogue: 0,0:16:30.82,0:16:31.90,sign,,0000,0000,0000,,INI BURUK
Dialogue: 0,0:16:31.90,0:16:32.99,sign,,0000,0000,0000,,HAME IMUT
Dialogue: 0,0:16:32.99,0:16:34.41,sign,,0000,0000,0000,,LALAT JENJANG PUNYA KELUARGA
Dialogue: 0,0:17:20.24,0:17:21.16,sign,,0000,0000,0000,,KECERDASAN
Dialogue: 0,0:17:36.47,0:17:37.30,sign,,0000,0000,0000,,KOPI SUSU ENAK
Dialogue: 0,0:19:29.16,0:19:31.16,sign,,0000,0000,0000,,{\an8}BALAI KOTA NYAGAMIHARA
Dialogue: 0,0:19:31.17,0:19:32.29,sign,,0000,0000,0000,,KOTA MANUSIA HEWAN
Dialogue: 0,0:19:55.44,0:19:56.94,sign,,0000,0000,0000,,HAMEKO MALAIKAT*MUDAH BERGAUL
Dialogue: 0,0:20:43.45,0:20:44.36,sign,,0000,0000,0000,,DEP MANUSIA HEWAN
Dialogue: 0,0:21:48.97,0:21:49.80,sign,,0000,0000,0000,,PENYIRAM BOKONG
Dialogue: 0,0:21:57.27,0:21:58.52,sign,,0000,0000,0000,,MALAIKAT*MUDAH BERGAUL
Dialogue: 0,0:21:58.52,0:22:02.19,sign,,0000,0000,0000,,MALAIKAT ANAL MUDAH BERGAUL
Dialogue: 0,0:23:38.04,0:23:39.16,sign,,0000,0000,0000,,INI KARYA FIKSI.
Dialogue: 0,0:23:39.16,0:23:40.96,sign,,0000,0000,0000,,ANAK-ANAK\NDILARANG MEROKOK DAN MINUM-MINUM.
Dialogue: 0,0:00:14.51,0:00:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kehabisan rokok.
Dialogue: 0,0:00:19.56,0:00:24.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Semuanya terlihat buram.\NAku butuh asupan nikotin.
Dialogue: 0,0:00:24.73,0:00:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yani Neko!
Dialogue: 0,0:00:28.57,0:00:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Peri Rokok.
Dialogue: 0,0:00:31.19,0:00:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang menyelamatkan\NManusia Hewan malang pecandu nikotin.
Dialogue: 0,0:00:35.07,0:00:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar cabul!
Dialogue: 0,0:00:37.66,0:00:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berusaha memberitahumu\Nsesuatu yang penting.
Dialogue: 0,0:00:41.62,0:00:43.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Yani Neko.
Dialogue: 0,0:00:43.50,0:00:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jelas sedang mengalami sakau nikotin.
Dialogue: 0,0:00:47.13,0:00:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokok seharusnya dinikmati dengan wajar.
Dialogue: 0,0:00:49.88,0:00:52.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menikmatinya dengan wajar!
Dialogue: 0,0:00:52.26,0:00:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reaksimu menunjukkan sebaliknya.
Dialogue: 0,0:00:55.09,0:00:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:00:56.51,0:00:58.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus ada yang diubah.
Dialogue: 0,0:00:58.60,0:01:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengajarimu\NLatihan Reseptor Nikotin.
Dialogue: 0,0:01:07.98,0:01:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ikat rambutnya berselimutkan asap{\i0}
Dialogue: 0,0:01:11.48,0:01:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Paru-paru ibunya juga dipenuhi asap{\i0}
Dialogue: 0,0:01:15.49,0:01:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Amat berasap, amat berasap{\i0}
Dialogue: 0,0:01:19.99,0:01:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sudah terlambat menangis\NSetelah ini berakhir{\i0}
Dialogue: 0,0:01:25.08,0:01:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini dia{\i0}
Dialogue: 0,0:01:30.08,0:01:34.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini dia, ini dia{\i0}
Dialogue: 0,0:01:35.30,0:01:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah berhasil?
Dialogue: 0,0:01:38.30,0:01:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan! Jangan biarkan nikotin menang!
Dialogue: 0,0:01:41.64,0:01:44.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kau jangan goyangkan\Nbokong nikmat itu di depanku.
Dialogue: 0,0:01:44.64,0:01:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Kenapa rasanya tak seperti rokok?
Dialogue: 0,0:01:48.60,0:01:50.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:01:50.06,0:01:52.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku hanyalah…
Dialogue: 0,0:01:52.07,0:01:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:01:53.44,0:01:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yani Neko, ini papan pengumuman warga.
Dialogue: 0,0:01:56.07,0:01:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada akhirnya, aku hanyalah imajinasimu.
Dialogue: 0,0:02:02.41,0:02:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yani Neko?
Dialogue: 0,0:02:03.58,0:02:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin. Aku jelas bisa merasakannya.
Dialogue: 0,0:02:07.12,0:02:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua hanya ilusi\Nyang ditampilkan oleh otakmu.
Dialogue: 0,0:02:11.08,0:02:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin.
Dialogue: 0,0:02:12.46,0:02:14.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mungkin…
Dialogue: 0,0:02:14.63,0:02:16.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau asap.
Dialogue: 0,0:02:16.59,0:02:18.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasi rami.
Dialogue: 0,0:02:18.22,0:02:20.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Pantulan matahari terbenam.{\i0}
Dialogue: 0,0:02:20.64,0:02:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Peluit kereta api di kejauhan.{\i0}
Dialogue: 0,0:02:22.72,0:02:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terjebak di sini.
Dialogue: 0,0:02:26.10,0:02:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu bersamamu.\NSekarang, kembali ke latihan.
Dialogue: 0,0:04:32.52,0:04:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yaku Neko.
Dialogue: 0,0:04:35.14,0:04:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh nikotin,\Nberi aku sebatang rokok!
Dialogue: 0,0:04:39.61,0:04:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Kak Yani.
Dialogue: 0,0:04:41.73,0:04:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sebenarnya aku juga kehabisan rokok.
Dialogue: 0,0:04:44.40,0:04:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bohong. Kau sedang merokok sekarang.
Dialogue: 0,0:04:46.74,0:04:48.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, ini?
Dialogue: 0,0:04:50.66,0:04:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan rokok?
Dialogue: 0,0:04:57.83,0:04:58.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Ini rokok.
Dialogue: 0,0:04:58.84,0:05:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, berikan.
Dialogue: 0,0:05:00.17,0:05:01.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:05:01.21,0:05:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pelit begitu!
Dialogue: 0,0:05:03.34,0:05:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingat aku pernah memberimu puntung rokok\Nsaat kau tak punya uang?
Dialogue: 0,0:05:07.55,0:05:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Yani.
Dialogue: 0,0:05:08.47,0:05:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sungguh tak tahu berterima kasih.
Dialogue: 0,0:05:19.02,0:05:20.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini, rasanya tak enak!
Dialogue: 0,0:05:20.98,0:05:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah mengisapnya.
Dialogue: 0,0:05:23.61,0:05:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus menahannya\Nsebelum mengembuskan napas.
Dialogue: 0,0:05:28.49,0:05:30.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak,\Ntak ada zat kimia yang terserap.
Dialogue: 0,0:05:31.74,0:05:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini rokok, kan?
Dialogue: 0,0:05:32.99,0:05:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu.
Dialogue: 0,0:05:49.18,0:05:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, ini lumayan juga.
Dialogue: 0,0:05:51.80,0:05:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan? Apa kau mau es krim?
Dialogue: 0,0:05:54.72,0:05:57.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya enak kalau kau makan sekarang!
Dialogue: 0,0:06:00.15,0:06:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sebatang rokok?
Dialogue: 0,0:06:01.81,0:06:02.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tentu.
Dialogue: 0,0:06:05.36,0:06:06.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:06:12.20,0:06:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya musim ini datang lagi.
Dialogue: 0,0:06:15.29,0:06:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak suka rasa obat ini,\Nseperti ramuan herbal menjijikkan.
Dialogue: 0,0:06:22.34,0:06:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaku, kau di rumah?
Dialogue: 0,0:06:26.96,0:06:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa?
Dialogue: 0,0:06:30.38,0:06:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Kak Yani?
Dialogue: 0,0:06:33.10,0:06:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku ingin minum obat rabies.\NBoleh minta air?
Dialogue: 0,0:06:37.06,0:06:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Air di apartemenku dimatikan.
Dialogue: 0,0:06:44.02,0:06:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini vaksin!
Dialogue: 0,0:06:46.44,0:06:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bertanya.
Dialogue: 0,0:06:51.99,0:06:54.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak sedang\Nmemakai obat-obatan lagi, kan?
Dialogue: 0,0:06:54.87,0:06:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu tidak!
Dialogue: 0,0:06:56.87,0:07:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu aku sudah bertobat!\NYang benar saja!
Dialogue: 0,0:07:00.87,0:07:04.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau tak memercayaiku,\Nmaka aku benar-benar kesepian!
Dialogue: 0,0:07:04.96,0:07:08.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira aku kembali diterima masyarakat\Nsetelah aku berubah.
Dialogue: 0,0:07:08.88,0:07:11.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti menanyaiku!
Dialogue: 0,0:07:13.34,0:07:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya,
Dialogue: 0,0:07:15.81,0:07:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}kenapa kau sangat peduli padaku?
Dialogue: 0,0:07:20.10,0:07:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu,
Dialogue: 0,0:07:21.23,0:07:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa kau penyidik narkoba?
Dialogue: 0,0:07:22.85,0:07:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyamaranmu hebat! Kembalikan Kak Yani!
Dialogue: 0,0:07:25.52,0:07:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenanglah! Tarik napas dalam-dalam!
Dialogue: 0,0:07:28.73,0:07:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hidupku berantakan karenamu!
Dialogue: 0,0:07:32.95,0:07:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan penyamaranmu!
Dialogue: 0,0:07:35.49,0:07:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Revelio!{\i0}
Dialogue: 0,0:07:46.42,0:07:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:07:56.60,0:07:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu lucu.
Dialogue: 0,0:08:01.14,0:08:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua.
Dialogue: 0,0:08:05.19,0:08:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Bartender itu sangat lucu.
Dialogue: 0,0:08:07.52,0:08:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tak kusangka dia bertingkah di sana.
Dialogue: 0,0:08:09.40,0:08:11.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian, Dua Manusia Hewan.
Dialogue: 0,0:08:13.28,0:08:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah telapak tangan kalian diramal?
Dialogue: 0,0:08:17.28,0:08:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahal sekali!
Dialogue: 0,0:08:18.78,0:08:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, pasti akan membosankan.
Dialogue: 0,0:08:20.91,0:08:23.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau jika bayarnya 100 yen.
Dialogue: 0,0:08:24.37,0:08:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak keberatan\Nmenghadapi pelanggan sombong sepertimu.
Dialogue: 0,0:08:30.00,0:08:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seorang peramal?
Dialogue: 0,0:08:31.30,0:08:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya perlu membayar 2.000 yen\Njika menurutmu yang kuramal itu benar.
Dialogue: 0,0:08:35.05,0:08:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepakat.
Dialogue: 0,0:08:38.01,0:08:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lihat.
Dialogue: 0,0:08:41.52,0:08:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan!
Dialogue: 0,0:08:42.77,0:08:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau pernah mencuci tangan?
Dialogue: 0,0:08:46.65,0:08:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau seorang perokok, kan?
Dialogue: 0,0:08:48.65,0:08:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya itu, kau pecandu\Nyang menyusahkan keluargamu.
Dialogue: 0,0:08:52.90,0:08:56.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tinggal sendiri di apartemen kumuh\Nkarena tak punya pekerjaan.
Dialogue: 0,0:08:58.53,0:08:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan
Dialogue: 0,0:08:59.70,0:09:02.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan mati karena kanker paru-paru\Ndalam lima tahun!
Dialogue: 0,0:09:02.66,0:09:04.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau karena kebakaran.
Dialogue: 0,0:09:06.67,0:09:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang. Itu hanya meramal nasib.
Dialogue: 0,0:09:09.71,0:09:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, merokoklah agar tenang.
Dialogue: 0,0:09:15.55,0:09:17.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya aku benar.
Dialogue: 0,0:09:17.93,0:09:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau selanjutnya.
Dialogue: 0,0:09:19.89,0:09:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulurkan tanganmu.
Dialogue: 0,0:09:21.10,0:09:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuramal hanya dengan 100 yen.
Dialogue: 0,0:09:23.39,0:09:25.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:09:25.98,0:09:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak terlalu percaya hal seperti ini.
Dialogue: 0,0:09:29.73,0:09:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah meramal itu hanya menyampaikan\Npola-pola yang umum dimiliki orang?
Dialogue: 0,0:09:33.36,0:09:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau menarik kesimpulan dari informasi\Nseperti yang kau lakukan kepada Kak Yani.
Dialogue: 0,0:09:37.36,0:09:40.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau memakai obat-obatan terlarang?
Dialogue: 0,0:09:44.12,0:09:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak.
Dialogue: 0,0:09:45.50,0:09:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau punya riwayat ditangkap?
Dialogue: 0,0:09:47.33,0:09:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak.
Dialogue: 0,0:09:48.25,0:09:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Rumahmu tak pernah digeledah?
Dialogue: 0,0:09:49.75,0:09:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tak pernah.
Dialogue: 0,0:09:50.84,0:09:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sungguh?
Dialogue: 0,0:09:52.00,0:09:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sungguh.
Dialogue: 0,0:09:53.96,0:09:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak masuk akal.
Dialogue: 0,0:09:55.30,0:09:57.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana bisa ramalan serinci itu?
Dialogue: 0,0:09:57.80,0:10:00.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, bukan berarti ramalanmu benar!
Dialogue: 0,0:10:01.30,0:10:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah mau percaya atau tidak.
Dialogue: 0,0:10:06.14,0:10:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jika kalian tak suka,\Ntinggalkan saja 100 yen dan enyahlah.
Dialogue: 0,0:10:20.66,0:10:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:10:23.24,0:10:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat!{\i0}
Dialogue: 0,0:10:52.52,0:10:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kak Yani.\N- Ya?
Dialogue: 0,0:10:54.19,0:10:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak bekerja?
Dialogue: 0,0:10:55.78,0:10:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita belum sedekat itu.
Dialogue: 0,0:10:58.32,0:11:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaan paruh waktuku\Ndibayar harian. Mau ikut denganku?
Dialogue: 0,0:11:03.45,0:11:04.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, Yaku.
Dialogue: 0,0:11:05.33,0:11:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah awan itu.
Dialogue: 0,0:11:08.95,0:11:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi seperti itu.
Dialogue: 0,0:11:12.83,0:11:16.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang bebas,\Ntak terikat pada apa pun.
Dialogue: 0,0:11:16.96,0:11:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjadi seperti itu.
Dialogue: 0,0:11:23.72,0:11:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa lapar saja\Ntak bisa merampas kebebasanku.
Dialogue: 0,0:11:27.97,0:11:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tadi keren sekali!
Dialogue: 0,0:11:31.14,0:11:34.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah kau tak peduli akan apa pun!
Dialogue: 0,0:11:34.61,0:11:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski aku menjadi awan,\Naku akan bekerja kalau kehabisan rokok.
Dialogue: 0,0:11:39.36,0:11:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat waktu itu tiba,\Nmaka kau bisa mencarikanku pekerjaan.
Dialogue: 0,0:11:42.36,0:11:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu! Hari itu juga\Nkumasukkan kau ke jadwal kerja.
Dialogue: 0,0:11:47.24,0:11:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kak Yani keren sekali hari ini.{\i0}
Dialogue: 0,0:11:54.38,0:11:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sama seperti saat aku\Npertama kali bertemu dengannya.{\i0}
Dialogue: 0,0:11:59.42,0:12:00.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar.{\i0}
Dialogue: 0,0:12:00.84,0:12:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku sangat mengaguminya.{\i0}
Dialogue: 0,0:12:03.13,0:12:06.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia begitu bebas bagai awan.{\i0}
Dialogue: 0,0:12:10.81,0:12:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buka! Carikan aku pekerjaan!
Dialogue: 0,0:12:15.77,0:12:17.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidur?
Dialogue: 0,0:12:17.06,0:12:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang kau sedang\Ndi bawah pengaruh obat!
Dialogue: 0,0:12:20.03,0:12:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah bangun!
Dialogue: 0,0:12:22.61,0:12:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tengah malam.
Dialogue: 0,0:12:24.66,0:12:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sangat gawat.
Dialogue: 0,0:12:26.28,0:12:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira masih punya sekarton rokok,\Ntapi ternyata itu minggu lalu!
Dialogue: 0,0:12:29.54,0:12:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku perlu uang untuk membeli rokok!
Dialogue: 0,0:12:31.66,0:12:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Carikan pekerjaan\Nyang bisa kumulai sekarang
Dialogue: 0,0:12:33.91,0:12:35.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dibayar harian.
Dialogue: 0,0:12:38.34,0:12:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Benar, dia bukan awan, dia asap.{\i0}
Dialogue: 0,0:13:00.15,0:13:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalah!{\i0}
Dialogue: 0,0:13:03.15,0:13:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Permainan payah!
Dialogue: 0,0:13:04.15,0:13:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Hame Neko! Permainan ini amat payah!
Dialogue: 0,0:13:06.99,0:13:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dalam permainan tarung,\Nkau kalah kalau kehilangan kendali.
Dialogue: 0,0:13:11.74,0:13:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau tak boleh menunjukkan emosimu.
Dialogue: 0,0:13:13.83,0:13:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau harus tetap tenang\Napa pun situasinya.
Dialogue: 0,0:13:15.87,0:13:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mengerti?
Dialogue: 0,0:13:17.37,0:13:20.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Masalahnya aku tak bisa melakukan itu.
Dialogue: 0,0:13:20.50,0:13:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Lihat aku main di laga peringkat.
Dialogue: 0,0:13:23.88,0:13:28.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Akan kutunjukkan\Nbagaimana aku mencapai peringkat {\i1}Ul-Mas.{\i0}
Dialogue: 0,0:13:29.47,0:13:30.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Siap?{\i0}
Dialogue: 0,0:13:39.61,0:13:40.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalah!{\i0}
Dialogue: 0,0:13:42.65,0:13:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Kau kalah! Ayo lawan aku!{\i0}
Dialogue: 0,0:13:47.15,0:13:50.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Yang mereka lakukan\Nhanya menggerakkan stik.
Dialogue: 0,0:13:58.75,0:14:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau lapar, Yani?
Dialogue: 0,0:14:01.17,0:14:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Mau makan siang?
Dialogue: 0,0:14:04.09,0:14:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Sepertinya aku punya\Nbeberapa bungkus ramen.
Dialogue: 0,0:14:28.86,0:14:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Dari tadi aku ingin memberitahumu.
Dialogue: 0,0:14:32.49,0:14:35.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Jangan merokok di sekitar peralatan gimku!
Dialogue: 0,0:14:36.16,0:14:37.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Maafkan aku!
Dialogue: 0,0:14:46.96,0:14:50.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh kau, Perokok Sialan!
Dialogue: 0,0:14:54.01,0:14:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu sandalku melayang.
Dialogue: 0,0:14:57.02,0:14:58.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tak mungkin.\N- Itu benar.
Dialogue: 0,0:14:59.64,0:15:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kulihat kau tak terlalu\Nberperilaku seperti hewan, Imoko.
Dialogue: 0,0:15:03.44,0:15:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersikaplah lebih mirip kucing.
Dialogue: 0,0:15:05.94,0:15:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang berbeda-beda.
Dialogue: 0,0:15:13.62,0:15:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kau barusan mengeong?
Dialogue: 0,0:15:14.95,0:15:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan.
Dialogue: 0,0:15:16.04,0:15:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sifat kucingmu keluar.
Dialogue: 0,0:15:18.66,0:15:20.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak anjing gembul!
Dialogue: 0,0:15:30.93,0:15:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada adik kecilku.
Dialogue: 0,0:15:33.05,0:15:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Kau pulang ke rumah dari sekolah?
Dialogue: 0,0:15:37.18,0:15:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kau punya kakak.
Dialogue: 0,0:15:39.06,0:15:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengeong tanpa henti.
Dialogue: 0,0:15:41.02,0:15:42.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manis sekali.
Dialogue: 0,0:15:43.77,0:15:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri aku kasih sayang.
Dialogue: 0,0:15:45.19,0:15:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak kenal dia.
Dialogue: 0,0:15:55.57,0:15:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hai, Semuanya!{\i0}
Dialogue: 0,0:15:58.08,0:16:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini saatnya Kanal Hame!{\i0}
Dialogue: 0,0:16:01.04,0:16:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Terima kasih kalian telah berkunjung.{\i0}
Dialogue: 0,0:16:03.33,0:16:05.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, omong-omong.
Dialogue: 0,0:16:05.17,0:16:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini adalah hari terburuk bagiku!
Dialogue: 0,0:16:09.80,0:16:12.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jijik! Serangga besar!{\i0}
Dialogue: 0,0:16:12.34,0:16:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tidak, enyahlah!{\i0}
Dialogue: 0,0:16:14.72,0:16:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku benci serangga!{\i0}
Dialogue: 0,0:16:17.81,0:16:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Serangga besar menyebalkan!{\i0}
Dialogue: 0,0:16:19.64,0:16:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baiklah, tak apa-apa!\NKubawa saja penyedot debu.{\i0}
Dialogue: 0,0:16:22.10,0:16:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Maaf, Semuanya. Aku akan menjeda siaran.{\i0}
Dialogue: 0,0:16:38.78,0:16:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kakakku sangat memalukan?
Dialogue: 0,0:16:45.12,0:16:48.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kurasa kau membenci kakakmu.
Dialogue: 0,0:16:48.50,0:16:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak membenci dia!
Dialogue: 0,0:16:50.13,0:16:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau sayang dia?
Dialogue: 0,0:16:54.22,0:16:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang?
Dialogue: 0,0:16:55.93,0:16:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalaku…
Dialogue: 0,0:16:59.35,0:17:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:01.64,0:17:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini rumit.
Dialogue: 0,0:17:05.27,0:17:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku…\N- Sungguh, kami minta maaf.
Dialogue: 0,0:17:11.48,0:17:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak menyangka kau bisa selantang ini.
Dialogue: 0,0:17:21.16,0:17:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kopi cocok dinikmati dengan rokok,
Dialogue: 0,0:17:22.87,0:17:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi hal yang tak enaknya,\Naku jadi ingin pipis.
Dialogue: 0,0:17:25.25,0:17:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, itu tidak membuatku kesal,
Dialogue: 0,0:17:28.42,0:17:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku paham soal ingin pipis.
Dialogue: 0,0:17:30.46,0:17:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak paham sama sekali.
Dialogue: 0,0:17:33.63,0:17:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kandung kemih kalian\Nsekecil punyanya hamster?
Dialogue: 0,0:17:39.39,0:17:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu, Peri Toilet?
Dialogue: 0,0:17:43.14,0:17:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peri? Apa itu?
Dialogue: 0,0:17:45.98,0:17:49.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat SMA, dia selalu\Nmemakan makan siangnya di kamar mandi.
Dialogue: 0,0:17:50.27,0:17:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kami selalu gagal mengeluarkannya,{\i0}
Dialogue: 0,0:17:52.11,0:17:55.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}jadi, kami mulai menjulukinya Peri Toilet.{\i0}
Dialogue: 0,0:17:55.36,0:17:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Aku disihir Toilet Bell.\N- Berhenti.{\i0}
Dialogue: 0,0:17:57.65,0:18:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Menjauhlah, atau tanda kutuk muncul.\N- Berhenti memberitahunya soal itu!{\i0}
Dialogue: 0,0:18:01.95,0:18:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Kenapa? Pantatmu sakit?\N- Tidak!{\i0}
Dialogue: 0,0:18:04.16,0:18:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh kau!
Dialogue: 0,0:18:08.79,0:18:10.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya,
Dialogue: 0,0:18:10.21,0:18:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku seorang idola,\Ndan idola tak boleh pipis.
Dialogue: 0,0:18:14.30,0:18:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tidak seperti Yakuko.
Dialogue: 0,0:18:21.43,0:18:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dengar itu, Kak Yani?\NBantu aku pegangi dia.
Dialogue: 0,0:18:27.39,0:18:28.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:18:28.31,0:18:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serangan penggetar!
Dialogue: 0,0:18:30.06,0:18:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu!
Dialogue: 0,0:18:32.94,0:18:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan!
Dialogue: 0,0:18:45.70,0:18:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau juga bisa pipis. Idola apanya?
Dialogue: 0,0:18:49.21,0:18:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pecundang yang mirip katak ini\Nadalah wujud asli peri toilet.
Dialogue: 0,0:18:54.96,0:18:56.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan sekali.
Dialogue: 0,0:19:00.63,0:19:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubunuh kau!
Dialogue: 0,0:19:04.01,0:19:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat asin!
Dialogue: 0,0:19:07.52,0:19:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar Pecandu Obat!\NItu rasa dari kehidupan!
Dialogue: 0,0:19:11.90,0:19:15.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf! Aku mau muntah! Hentikan!
Dialogue: 0,0:19:15.44,0:19:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muntah saja kalau begitu!
Dialogue: 0,0:19:20.40,0:19:24.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kuharap mereka\Nberhenti mengacak-acak kamarku.{\i0}
Dialogue: 0,0:19:24.95,0:19:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:19:32.29,0:19:34.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku di balai kota hari ini.{\i0}
Dialogue: 0,0:19:34.04,0:19:35.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Nomor 385.\N- Sudah giliran kita?
Dialogue: 0,0:19:35.79,0:19:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hame Neko datang\Nmembuat nama belakang untuk dirinya.{\i0}
Dialogue: 0,0:19:38.92,0:19:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dia tak punya nama belakang\Nkarena kedua orang tuanya Manusia Hewan.{\i0}
Dialogue: 0,0:19:44.05,0:19:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kabarnya, nilainya dipotong lima poin\Npada setiap ujian karena itu.{\i0}
Dialogue: 0,0:19:48.18,0:19:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua selesai!
Dialogue: 0,0:19:49.68,0:19:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Yani!
Dialogue: 0,0:19:52.69,0:19:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini nama belakangku yang baru!
Dialogue: 0,0:19:56.94,0:19:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:58.69,0:20:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut, kan?
Dialogue: 0,0:20:00.65,0:20:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Mulai hari ini,{\i0}
Dialogue: 0,0:20:02.45,0:20:04.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}namaku Hameko Malaikat*Mudah Bergaul!{\i0}
Dialogue: 0,0:20:04.66,0:20:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Senang berkenalan denganmu!{\i0}
Dialogue: 0,0:20:08.66,0:20:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu menggelikan sekali.
Dialogue: 0,0:20:10.66,0:20:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga panjang dan susah diucapkan.
Dialogue: 0,0:20:12.87,0:20:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Yang benar saja?
Dialogue: 0,0:20:15.29,0:20:19.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ragu apa ada\Nyang mau memanggilmu begitu.
Dialogue: 0,0:20:19.25,0:20:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapanmu jahat sekali!
Dialogue: 0,0:20:21.42,0:20:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku tak tahu nama belakangmu.
Dialogue: 0,0:20:25.01,0:20:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti namamu aneh, kan?
Dialogue: 0,0:20:27.93,0:20:28.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Namaku Sato.
Dialogue: 0,0:20:28.89,0:20:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu sangat normal!
Dialogue: 0,0:20:30.18,0:20:34.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar jauh lebih sulit\Nmengubah nama untuk kedua kali.
Dialogue: 0,0:20:34.06,0:20:36.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini kesempatanmu memikirkan lagi.
Dialogue: 0,0:20:36.19,0:20:40.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa! Aku akan mengajukannya.
Dialogue: 0,0:20:40.15,0:20:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau Hameko Tanaka?
Dialogue: 0,0:20:42.03,0:20:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak mau!
Dialogue: 0,0:20:44.36,0:20:47.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, semuanya sudah beres.\NDokumennya akan kami kirim nanti.
Dialogue: 0,0:20:47.82,0:20:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah dokumennya tiba,\Nbawa kembali ke sini,
Dialogue: 0,0:20:50.37,0:20:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kami akan perbarui kartu identitasmu.
Dialogue: 0,0:20:54.62,0:20:59.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hame Malaikat*Mudah Bergaul\Nadalah malaikat yang mudah bergaul.{\i0}
Dialogue: 0,0:21:02.09,0:21:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat. Aku harus ke kamar mandi.
Dialogue: 0,0:21:05.01,0:21:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buang air besar?
Dialogue: 0,0:21:06.01,0:21:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:21:10.10,0:21:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus kuapakan soal ini?
Dialogue: 0,0:21:12.64,0:21:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kulihat.
Dialogue: 0,0:21:15.06,0:21:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama belakang macam apa ini?
Dialogue: 0,0:21:17.19,0:21:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak Manusia Hewan\Nmemilih nama yang aneh.
Dialogue: 0,0:21:21.23,0:21:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Simbol di tengah ini.
Dialogue: 0,0:21:24.36,0:21:25.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu itu apa?
Dialogue: 0,0:21:25.78,0:21:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah pergi sebelum aku menanyakannya.
Dialogue: 0,0:21:29.37,0:21:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:21:30.95,0:21:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak bisa mendaftarkan simbol.
Dialogue: 0,0:21:34.71,0:21:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu bukan lubang bokong, kan?
Dialogue: 0,0:21:37.75,0:21:40.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar. Itu anus.
Dialogue: 0,0:21:41.50,0:21:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Haruskah kuketik "anus"\Natau "lubang bokong"?
Dialogue: 0,0:21:45.38,0:21:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua-duanya terdengar tak bagus.
Dialogue: 0,0:21:47.63,0:21:48.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau "anal"?
Dialogue: 0,0:21:50.55,0:21:53.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan siaran setelah pulang\Nuntuk merayakan nama belakang baruku.
Dialogue: 0,0:21:55.18,0:21:57.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hameko Malaikat*Mudah Bergaul!
Dialogue: 0,0:22:02.82,0:22:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hari ini, Hameko Malaikat Anal\NMudah Bergaul lahir.{\i0}
Dialogue: 0,0:23:32.95,0:23:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Terjemahan subtitle oleh Stysa Alverina
