Dialogue: 0,0:04:59.38,0:05:01.63,sign,,0000,0000,0000,,{\an8}RACUN KOTORAN JAHAT
Dialogue: 0,0:05:33.95,0:05:35.41,sign,,0000,0000,0000,,{\an8}AMARAH YANI NEKO
Dialogue: 0,0:05:47.59,0:05:48.59,sign,,0000,0000,0000,,{\an8}KOYO MIAUWKOTIN 22
Dialogue: 0,0:05:52.72,0:05:54.01,sign,,0000,0000,0000,,KOYO MIAUWKOTIN
Dialogue: 0,0:06:06.61,0:06:07.65,sign,,0000,0000,0000,,KOYO MIAUWKOTIN 22
Dialogue: 0,0:06:07.65,0:06:12.91,sign,,0000,0000,0000,,JANGAN GUNAKAN PADA MANUSIA.\NBISA MENYEBABKAN KEMATIAN.
Dialogue: 0,0:06:47.99,0:06:49.03,sign,,0000,0000,0000,,{\an8}GUNAKAN SEWAJARNYA
Dialogue: 0,0:11:34.90,0:11:37.90,sign,,0000,0000,0000,,TERSEGEL
Dialogue: 0,0:16:43.54,0:16:45.83,sign,,0000,0000,0000,,SUPER SEDERHANA\NRESEP AIR DAN WISKI
Dialogue: 0,0:17:01.27,0:17:02.10,sign,,0000,0000,0000,,SELESAI!
Dialogue: 0,0:17:42.47,0:17:43.52,sign,,0000,0000,0000,,CAHAYA IBLIS
Dialogue: 0,0:19:07.22,0:19:08.18,sign,,0000,0000,0000,,{\an8}PENYELAMATAN
Dialogue: 0,0:23:37.99,0:23:39.04,sign,,0000,0000,0000,,INI KARYA FIKSI.
Dialogue: 0,0:23:39.04,0:23:40.91,sign,,0000,0000,0000,,ANAK-ANAK\NDILARANG MEROKOK DAN MINUM-MINUM.
Dialogue: 0,0:00:05.75,0:00:06.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:00:07.88,0:00:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke sini!
Dialogue: 0,0:00:18.51,0:00:20.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa kalian siap?\N- Siap!
Dialogue: 0,0:00:23.02,0:00:24.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah!
Dialogue: 0,0:00:25.35,0:00:27.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan menendang bola ke sini.
Dialogue: 0,0:00:27.40,0:00:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:00:29.36,0:00:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu, lihat itu.
Dialogue: 0,0:00:31.90,0:00:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat siang bolong seperti ini.
Dialogue: 0,0:00:39.28,0:00:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga sering berkeliaran di sini?
Dialogue: 0,0:00:47.13,0:00:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Cerobong Asap!
Dialogue: 0,0:00:48.88,0:00:50.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berikan bolanya kepada kami?
Dialogue: 0,0:00:58.18,0:01:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku bermain bersama kalian.
Dialogue: 0,0:01:00.85,0:01:02.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:01:02.18,0:01:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, Cerobong Asap!
Dialogue: 0,0:01:17.66,0:01:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ambil bolanya dari dia!
Dialogue: 0,0:01:19.07,0:01:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:01:31.09,0:01:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}- Aku tak bisa fokus.\N- Aku tak bisa fokus.{\i0}
Dialogue: 0,0:01:39.22,0:01:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak apa, Cerobong Asap?
Dialogue: 0,0:01:40.68,0:01:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucing menjijikkan.
Dialogue: 0,0:01:42.26,0:01:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa bergerak.
Dialogue: 0,0:01:43.56,0:01:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru dua menit.
Dialogue: 0,0:01:45.64,0:01:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begini rasanya bertambah tua.
Dialogue: 0,0:01:47.73,0:01:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akibat merokok.
Dialogue: 0,0:01:49.10,0:01:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlukah panggil ambulans?
Dialogue: 0,0:01:50.69,0:01:54.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku akan bisa bangkit\Nbegitu aku merokok.
Dialogue: 0,0:01:54.28,0:01:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:01:56.78,0:02:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami menerima laporan\Nada orang mencurigakan mengejar anak-anak.
Dialogue: 0,0:02:03.12,0:02:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kalian harus lebih berhati-hati.
Dialogue: 0,0:02:05.25,0:02:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kau pikir itu diperbolehkan,\Nhanya karena ini Nyagamihara?
Dialogue: 0,0:02:15.76,0:02:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tak boleh merokok di taman!\N- Kacau sekali.
Dialogue: 0,0:02:17.97,0:02:19.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Baru kuperingatkan.\N- Benar-benar.
Dialogue: 0,0:04:38.36,0:04:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya mengerikan!
Dialogue: 0,0:04:43.53,0:04:44.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:04:46.07,0:04:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bau sekali.
Dialogue: 0,0:04:46.99,0:04:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti campuran bau kopi,\Nrokok, dan kaki kotor!
Dialogue: 0,0:04:50.91,0:04:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya seperti kedengkian\Ndan kepahitan manusia!
Dialogue: 0,0:04:54.54,0:04:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ini namanya
Dialogue: 0,0:04:56.62,0:04:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Racun Kotoran Jahat!
Dialogue: 0,0:05:01.63,0:05:03.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yani Neko! Kita harus lakukan evakuasi!
Dialogue: 0,0:05:03.84,0:05:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cairan bau akan menghujani kita\Njika kita tidak pergi dari sini!
Dialogue: 0,0:05:08.68,0:05:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buruk. Sangat buruk untukmu.
Dialogue: 0,0:05:11.43,0:05:15.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokok mengandung\Nlebih dari 70 zat karsinogen.
Dialogue: 0,0:05:16.89,0:05:22.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lagi asap rokok\Nyang membahayakan perokok pasif sepertiku.
Dialogue: 0,0:05:22.44,0:05:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau paham yang kukatakan, Yani Neko?
Dialogue: 0,0:05:24.94,0:05:27.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risiko strokmu jadi dua kali lipat,
Dialogue: 0,0:05:27.32,0:05:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pembuluh darahmu rusak.
Dialogue: 0,0:05:28.91,0:05:30.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penelitian terkini mengatakan
Dialogue: 0,0:05:30.45,0:05:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rokok bisa menyebabkan gagal jantung\Natau semacam itu.
Dialogue: 0,0:05:35.41,0:05:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:05:36.46,0:05:38.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku mau memberitahumu,
Dialogue: 0,0:05:38.54,0:05:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di daerah sini temanku\Nmembuka lokakarya berhenti merokok.
Dialogue: 0,0:05:41.67,0:05:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini kubawakan kau pamfletnya.
Dialogue: 0,0:05:44.01,0:05:45.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini.
Dialogue: 0,0:05:45.34,0:05:47.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku sulit melihat.
Dialogue: 0,0:05:48.59,0:05:50.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Di mana itu? Apa ini? Menjijikkan!
Dialogue: 0,0:05:51.51,0:05:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang ini?
Dialogue: 0,0:05:54.02,0:05:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, bukan yang itu.
Dialogue: 0,0:05:59.27,0:06:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya wajah\Ndi belakang kepalamu juga!
Dialogue: 0,0:06:01.31,0:06:04.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini kau bagian\Ndari klub pecandu nikotin juga!
Dialogue: 0,0:06:19.17,0:06:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bisa tunggu sampai wajahku pulih?\NAda apa?
Dialogue: 0,0:06:25.38,0:06:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau tempelkan\Nke kepalaku, Kucing Bodoh?
Dialogue: 0,0:06:30.80,0:06:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku merasa…
Dialogue: 0,0:06:38.39,0:06:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apakah ini rasa bersalah?{\i0}
Dialogue: 0,0:06:41.77,0:06:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kucing tak beretika ini\Nmemang sepenuhnya salah.{\i0}
Dialogue: 0,0:06:45.36,0:06:47.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi mungkin aku terlalu menghakimi dia.{\i0}
Dialogue: 0,0:06:49.03,0:06:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Aku selalu memakai rasa benarku sendiri\Nuntuk membuatku lebih nyaman.{\i0}
Dialogue: 0,0:06:55.03,0:06:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yani Neko, maaf, aku sudah keterlaluan.
Dialogue: 0,0:07:00.16,0:07:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:24.19,0:07:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sedang apa?
Dialogue: 0,0:07:32.99,0:07:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu baru enak.
Dialogue: 0,0:07:37.20,0:07:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Chainsmoker Cat!{\i0}
Dialogue: 0,0:08:16.37,0:08:17.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:08:29.34,0:08:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya satu saja sudah cukup!
Dialogue: 0,0:08:33.17,0:08:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak paham situasimu?
Dialogue: 0,0:08:34.88,0:08:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Pak.
Dialogue: 0,0:08:35.84,0:08:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau minta penundaan bayar sewa,\Nbilang akan melakukan apa saja,
Dialogue: 0,0:08:39.31,0:08:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kusuruh kau cabuti rumput di halaman!
Dialogue: 0,0:08:41.81,0:08:42.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Pak.
Dialogue: 0,0:08:42.73,0:08:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi baru lima menit,\Nsudah berhenti untuk istirahat merokok!
Dialogue: 0,0:08:45.98,0:08:48.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kau masih punya nyali\Nmenyalakan rokok kedua!
Dialogue: 0,0:08:48.48,0:08:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Pak.
Dialogue: 0,0:08:49.65,0:08:51.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mengeong saat menjawab!
Dialogue: 0,0:08:51.61,0:08:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, Pak.
Dialogue: 0,0:08:57.49,0:08:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sita ini, Bodoh!
Dialogue: 0,0:08:59.87,0:09:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu perampokan!
Dialogue: 0,0:09:00.99,0:09:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bersalah karena tak bayar sewa\Ndan membuang puntung rokok sembarangan!
Dialogue: 0,0:09:05.75,0:09:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukembalikan ini setelah selesai!
Dialogue: 0,0:09:14.80,0:09:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Sebaiknya aku beri dia teh\Ndan camilan setelah dia selesai.{\i0}
Dialogue: 0,0:09:21.14,0:09:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kau makan?
Dialogue: 0,0:09:23.98,0:09:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanaman paku ekor kuda, karena aku lapar.
Dialogue: 0,0:09:27.98,0:09:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau juga?
Dialogue: 0,0:09:31.57,0:09:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:09:33.36,0:09:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan makan terlalu banyak,\Nnanti perutmu sakit.
Dialogue: 0,0:09:43.16,0:09:45.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah selesai, Yani Neko?
Dialogue: 0,0:09:45.37,0:09:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubawakan kau camilan.
Dialogue: 0,0:09:50.08,0:09:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tunggu, dia sedang merokok?{\i0}
Dialogue: 0,0:09:52.42,0:09:54.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Dan ada apa dengan perutnya?{\i0}
Dialogue: 0,0:09:54.59,0:09:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kenapa kebun kubisku jadi begini?{\i0}
Dialogue: 0,0:09:58.97,0:10:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu camilan? Terima kasih!
Dialogue: 0,0:10:02.93,0:10:06.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebenarnya aku masih kenyang,\Njadi, akan kubawa pulang.
Dialogue: 0,0:10:11.06,0:10:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku! Mataku!
Dialogue: 0,0:10:15.57,0:10:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:10:25.95,0:10:28.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerobong Asap sialan!
Dialogue: 0,0:10:32.92,0:10:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar tak berguna!
Dialogue: 0,0:10:35.00,0:10:38.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, memikirkannya saja\Nsudah membuatku kesal!
Dialogue: 0,0:10:39.51,0:10:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuatku…
Dialogue: 0,0:10:46.68,0:10:48.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membuat…
Dialogue: 0,0:10:53.27,0:10:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kerusakan kertas dinding\Nbisa menjadi beban biaya saat kau pindah.{\i0}
Dialogue: 0,0:10:58.24,0:11:00.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Penyewa harus berhati-hati{\i0}
Dialogue: 0,0:11:00.91,0:11:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}agar asap rokok\Ntak membuat kertas dinding menguning.{\i0}
Dialogue: 0,0:11:04.62,0:11:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Perubahan warna karena asap…{\i0}
Dialogue: 0,0:11:06.54,0:11:09.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kertas dinding di kamarku berwarna krem.
Dialogue: 0,0:11:10.16,0:11:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin warnanya tetap sama\Nkarena sesekali kubuka jendelanya.
Dialogue: 0,0:11:13.88,0:11:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti bukan karena noda tar.
Dialogue: 0,0:11:16.92,0:11:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau diingat lagi, poster itu sudah ada\Nsejak sebelum aku tinggal di sini.
Dialogue: 0,0:11:48.70,0:11:51.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kira gedung apartemen ini berhantu?
Dialogue: 0,0:11:51.91,0:11:53.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bicara apa?
Dialogue: 0,0:11:53.25,0:11:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bohong!
Dialogue: 0,0:11:54.21,0:11:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada jimat-jimat aneh di dinding!
Dialogue: 0,0:11:56.71,0:11:59.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mendengar ketukan menyeramkan!
Dialogue: 0,0:11:59.46,0:12:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau harus beri tahu yang sebenarnya!
Dialogue: 0,0:12:01.80,0:12:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam!
Dialogue: 0,0:12:03.93,0:12:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu kau bicara apa!
Dialogue: 0,0:12:06.60,0:12:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik, itu tadi mencurigakan.{\i0}
Dialogue: 0,0:12:13.19,0:12:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris saja.
Dialogue: 0,0:12:15.27,0:12:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Peluk aku lebih erat, auuu!{\i0}
Dialogue: 0,0:12:26.99,0:12:28.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Yaniko.
Dialogue: 0,0:12:28.74,0:12:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, Kansai?
Dialogue: 0,0:12:30.54,0:12:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau bilang pada adikmu\Nkau akan berhenti merokok?
Dialogue: 0,0:12:35.17,0:12:36.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau masih merokok?
Dialogue: 0,0:12:37.71,0:12:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku akan\Nsungguh-sungguh berhenti.
Dialogue: 0,0:12:40.55,0:12:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak akan merokok lagi, mulai hari ini.
Dialogue: 0,0:12:42.72,0:12:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka tekadmu.
Dialogue: 0,0:12:50.89,0:12:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Yani-chan bercanda, itu jarang terjadi.{\i0}
Dialogue: 0,0:12:53.64,0:12:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku harus menyambungnya\Ndengan sesuatu yang lucu.{\i0}
Dialogue: 0,0:12:56.48,0:12:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, baru sebentar\Nsudah kau lakukan lagi!
Dialogue: 0,0:12:59.36,0:13:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ayah yang lupa hari jadinya!
Dialogue: 0,0:13:05.99,0:13:07.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak punya ayah?
Dialogue: 0,0:13:07.99,0:13:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya.
Dialogue: 0,0:13:09.62,0:13:11.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik, lumayan, Yani-chan.{\i0}
Dialogue: 0,0:13:11.83,0:13:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi kami, kucing barat,\Nbangga akan selera humor kami.{\i0}
Dialogue: 0,0:13:14.54,0:13:16.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tak menyerah sebelum berhasil melucu.{\i0}
Dialogue: 0,0:13:16.50,0:13:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Apa?{\i0}
Dialogue: 0,0:13:18.75,0:13:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau punya pengait hidung?
Dialogue: 0,0:13:22.67,0:13:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kutemukan di dalam majalah ini\Nyang kupinjam dari pemilik kos.
Dialogue: 0,0:13:25.88,0:13:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Bagaimana bisa benda ini\Nada di dalam situ?{\i0}
Dialogue: 0,0:13:29.26,0:13:30.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara memakainya?
Dialogue: 0,0:13:31.47,0:13:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaitkan ke hidungmu.
Dialogue: 0,0:13:33.22,0:13:34.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kau tiup.
Dialogue: 0,0:13:34.39,0:13:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihatmu memakainya.
Dialogue: 0,0:13:36.39,0:13:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kenapa? Itu sangat memalukan.
Dialogue: 0,0:13:39.61,0:13:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak sedekat itu\Nsampai aku mau menunjukkan wajah konyol!
Dialogue: 0,0:13:42.61,0:13:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku penasaran.
Dialogue: 0,0:13:44.15,0:13:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penasaran? Tapi itu…
Dialogue: 0,0:13:47.57,0:13:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:49.49,0:13:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Permintaan gila apa yang kau ajukan\Nkepada gadis sepertiku, Cerobong?{\i0}
Dialogue: 0,0:13:53.24,0:13:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tapi jika aku memakai ini,{\i0}
Dialogue: 0,0:13:55.16,0:13:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}{\i1}dia pasti akan tertawa terbahak-bahak!{\i0}
Dialogue: 0,0:13:58.67,0:14:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:14:00.42,0:14:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku tak punya pilihan.
Dialogue: 0,0:14:14.39,0:14:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katakan sesuatu!
Dialogue: 0,0:14:19.77,0:14:22.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Cerobong Asap sialan.{\i0}
Dialogue: 0,0:14:22.11,0:14:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kalau begitu sikapmu,\Naku harus mengerahkan segala cara.{\i0}
Dialogue: 0,0:14:27.28,0:14:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rokok apa itu?
Dialogue: 0,0:14:30.03,0:14:32.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rela keluar uang lebih\Nuntuk membeli rokok mahal.
Dialogue: 0,0:14:33.41,0:14:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak boleh ambil.
Dialogue: 0,0:14:34.79,0:14:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak mau mengambilnya.\NBukan itu maksudku.
Dialogue: 0,0:14:38.79,0:14:42.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Itu seperti yang terbentuk\Ndari mikroorganisme dalam susu?
Dialogue: 0,0:14:42.79,0:14:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tunggu, itu {\i1}"cheese"!{\i0}
Dialogue: 0,0:14:46.05,0:14:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari penjualan rokok, kita bisa tahu
Dialogue: 0,0:14:48.51,0:14:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perbandingan jumlah\Nmanusia hewan tiap daerah.
Dialogue: 0,0:14:51.09,0:14:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, memanfaatkan naluri hewan,\Nkita menentukan merek yang akan dijual…
Dialogue: 0,0:14:55.56,0:14:57.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tunggu, itu {\i1}"needs"!{\i0}
Dialogue: 0,0:14:58.43,0:15:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos, kita kehabisan benda itu.
Dialogue: 0,0:15:00.48,0:15:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toko perkakas masih buka?
Dialogue: 0,0:15:02.23,0:15:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang panjang, berulir itu.
Dialogue: 0,0:15:05.61,0:15:07.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, itu {\i1}"pins"!{\i0}
Dialogue: 0,0:15:08.24,0:15:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tersangka saat ini melarikan diri\Nmenuju Kariba dengan mobil Frankenstein.{\i0}
Dialogue: 0,0:15:11.86,0:15:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kendaraan darurat akan melintas.\NMohon beri jalan.{\i0}
Dialogue: 0,0:15:14.99,0:15:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tunggu, itu {\i1}"chase"!{\i0}
Dialogue: 0,0:15:20.25,0:15:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tunggu, itu {\i1}"Twin Peaks"!{\i0}
Dialogue: 0,0:15:30.63,0:15:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau {\i1}ahegao{\i0}\Ndengan kedua tangan membentuk {\i1}"peace"?{\i0}
Dialogue: 0,0:15:38.43,0:15:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kau tertawa, kumohon?
Dialogue: 0,0:15:46.69,0:15:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maafkan aku!
Dialogue: 0,0:15:50.99,0:15:52.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat.{\i0}
Dialogue: 0,0:16:06.34,0:16:07.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masuk.
Dialogue: 0,0:16:07.84,0:16:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yani-chan.
Dialogue: 0,0:16:09.55,0:16:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sering sekali mampir ke sini.\NJangan-jangan kau suka padaku?
Dialogue: 0,0:16:15.01,0:16:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa minum gratis di sini,
Dialogue: 0,0:16:17.64,0:16:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kau tak mengeluh aku merokok.
Dialogue: 0,0:16:24.73,0:16:28.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah? Aku memang tak keberatan.
Dialogue: 0,0:16:28.27,0:16:30.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kau membuatkanku minuman?
Dialogue: 0,0:16:30.36,0:16:33.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau, aku terlalu malas.
Dialogue: 0,0:16:33.74,0:16:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku membawa keju asap.
Dialogue: 0,0:16:36.41,0:16:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:16:39.37,0:16:40.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:16:46.71,0:16:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isi cangkir sedang dengan wiski apa pun\Nhingga setengah penuh.
Dialogue: 0,0:16:52.01,0:16:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tambahkan sirup gula sesuai selera.
Dialogue: 0,0:16:55.01,0:16:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedikit perasan air lemon.
Dialogue: 0,0:16:58.01,0:17:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu tuang banyak air keran, dan selesai.
Dialogue: 0,0:17:02.68,0:17:04.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana rasanya?
Dialogue: 0,0:17:05.52,0:17:07.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasa saja!
Dialogue: 0,0:17:07.06,0:17:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kritikmu kejam sekali.
Dialogue: 0,0:17:08.94,0:17:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi agar tak mubazir, akan kuhabiskan.
Dialogue: 0,0:17:11.53,0:17:14.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat peduli lingkungan.
Dialogue: 0,0:17:21.20,0:17:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku mulai merasa mabuk.
Dialogue: 0,0:17:24.75,0:17:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku, rasa alkohol hanyalah bonus.
Dialogue: 0,0:17:28.88,0:17:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya jalan menuju kenikmatan.
Dialogue: 0,0:17:32.46,0:17:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir aku mau berbaring sejenak.
Dialogue: 0,0:17:36.22,0:17:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini saatnya\Nkubiarkan kebahagiaan menghampiriku.
Dialogue: 0,0:18:35.82,0:18:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aruko! Aku butuh minuman!
Dialogue: 0,0:18:39.78,0:18:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi minum, tapi tak mengasyikkan.
Dialogue: 0,0:18:42.03,0:18:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kesempatan melucu,
Dialogue: 0,0:18:43.53,0:18:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi saat aku melucu,\Nkata mereka aku sok lucu.
Dialogue: 0,0:18:45.99,0:18:48.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan saat tepat untuk mengejek!
Dialogue: 0,0:18:48.62,0:18:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak kusangka\Nmereka lebih memilih lelucon murahan.
Dialogue: 0,0:18:52.58,0:18:54.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi itu sangat membosankan,
Dialogue: 0,0:18:54.92,0:18:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kukira aku hampir mati.
Dialogue: 0,0:19:04.30,0:19:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Tapi tidak sehampir mati sepertimu!
Dialogue: 0,0:19:08.18,0:19:10.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlalu ingin jadi lucu.
Dialogue: 0,0:19:14.27,0:19:17.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Chainsmoker Cat!{\i0}
Dialogue: 0,0:19:19.78,0:19:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Salam sejahtera,\NPara Penghuni Nyagamihara.{\i0}
Dialogue: 0,0:19:24.03,0:19:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Ini pengumuman untuk publik.{\i0}
Dialogue: 0,0:19:26.54,0:19:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hari ini udara sangat kering.{\i0}
Dialogue: 0,0:19:30.58,0:19:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Waspada terhadap bahaya kebakaran.{\i0}
Dialogue: 0,0:19:34.17,0:19:37.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan rokok sudah dipadamkan\Nsebelum dibuang.
Dialogue: 0,0:19:38.71,0:19:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaramu sangat merdu.
Dialogue: 0,0:19:42.76,0:19:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya dibuat-buat.
Dialogue: 0,0:19:45.26,0:19:47.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih lagi, kalian telah membantu.
Dialogue: 0,0:19:47.93,0:19:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, orang yang biasanya melakukan ini
Dialogue: 0,0:19:50.56,0:19:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cedera punggung saat "berolahraga".
Dialogue: 0,0:19:53.44,0:19:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berolahraga?
Dialogue: 0,0:19:54.56,0:19:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin banyak berlari.
Dialogue: 0,0:19:55.90,0:19:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bodoh.
Dialogue: 0,0:20:00.65,0:20:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaniko! Jangan buang angin\Ndi tempat tertutup!
Dialogue: 0,0:20:04.32,0:20:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakuko, buka semua jendela!
Dialogue: 0,0:20:06.41,0:20:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:20:11.91,0:20:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Jika kami menyiarkan bunyi buang angin\Nmelalui mikrofon, pasti akan kocak.{\i0}
Dialogue: 0,0:20:16.25,0:20:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaniko, arahkan bokongmu padaku!
Dialogue: 0,0:20:18.88,0:20:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat ke atas sedikit!
Dialogue: 0,0:20:21.38,0:20:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, buang angin\Nsekali lagi yang keras!
Dialogue: 0,0:20:24.55,0:20:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai bunyinya\Nbergema ke seluruh perumahan!
Dialogue: 0,0:20:27.18,0:20:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan kocak.
Dialogue: 0,0:20:29.22,0:20:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak ingin buang angin lagi.
Dialogue: 0,0:20:31.64,0:20:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Kubelikan rokok jika buang angin.
Dialogue: 0,0:20:33.44,0:20:34.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Baiklah!
Dialogue: 0,0:20:42.61,0:20:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kau sungguh buang angin! Kencang sekali!{\i0}
Dialogue: 0,0:20:44.74,0:20:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Kurasa terdengar ke seluruh kota!{\i0}
Dialogue: 0,0:20:46.91,0:20:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Lagi! Kubelikan sebungkus rokok\Nsetiap kali buang angin!{\i0}
Dialogue: 0,0:20:56.25,0:21:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Baik, cukup!\NPerutku sakit karena kebanyakan tertawa!{\i0}
Dialogue: 0,0:21:02.34,0:21:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Tunggu, itu lebih dari buang angin!{\i0}
Dialogue: 0,0:21:07.68,0:21:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Aku tak bisa begini lagi!{\i0}
Dialogue: 0,0:21:12.39,0:21:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\i1}Hentikan, terlalu banyak!{\i0}
Dialogue: 0,0:21:22.99,0:21:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang apa?
Dialogue: 0,0:21:24.57,0:21:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tersangkut.
Dialogue: 0,0:21:26.07,0:21:27.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kau dorong aku?
Dialogue: 0,0:21:27.91,0:21:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini bisa terjadi?
Dialogue: 0,0:21:31.74,0:21:32.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bokongmu amat empuk.
Dialogue: 0,0:21:34.25,0:21:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}Aku tak bisa erat memegangnya.\NKencangkan bokongmu!
Dialogue: 0,0:21:38.88,0:21:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa tak ada kemajuan.
Dialogue: 0,0:21:43.30,0:21:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa hanya perasaanku,\Natau ini terasa agak seksual?
Dialogue: 0,0:21:47.68,0:21:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali bawakan saja aku rokok.
Dialogue: 0,0:21:50.47,0:21:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau menyerah?
Dialogue: 0,0:21:52.18,0:21:54.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau hanya mengencangkan bokongmu!\NMau kupukul bokongmu?
