Dialogue: 0,0:01:50.79,0:01:58.13,sign,,0000,0000,0000,,(Saga of Tanya the Evil 2)
Dialogue: 0,0:03:12.96,0:03:15.01,sign,,0000,0000,0000,,KERAJAAN YIRUDOYA,\NMARKAS BESAR ANGKATAN DARAT
Dialogue: 0,0:03:19.31,0:03:21.26,sign,,0000,0000,0000,,PASUKAN GUNUNG KERAJAAN YIRUDOYA
Dialogue: 0,0:03:21.26,0:03:23.97,sign,,0000,0000,0000,,KOLONEL VIRGINIO CALANDRO
Dialogue: 0,0:03:23.97,0:03:26.74,sign,,0000,0000,0000,,PANGLIMA BESAR ANGKATAN DARAT, JENDERAL IGOR GASSMANN
Dialogue: 0,0:03:30.73,0:03:31.98,sign,,0000,0000,0000,,ANIMASI INI BERSIFAT FIKTIF
Dialogue: 0,0:03:31.98,0:03:35.11,sign,,0000,0000,0000,,ISI DRAMA TIDAK IDENTIK DENGAN DUNIA NYATA
Dialogue: 0,0:04:00.55,0:04:04.55,sign,,0000,0000,0000,,(Episode 3: Perantara yang Baik Hati)
Dialogue: 0,0:04:04.55,0:04:05.71,sign,,0000,0000,0000,,MARKAS BESAR STAF UMUM KEKAISARAN
Dialogue: 0,0:04:57.98,0:05:00.98,sign,,0000,0000,0000,,BAGIAN PENERIMAAN TAMU KERAJAAN YIRUDOYA
Dialogue: 0,0:14:22.98,0:14:28.97,sign,,0000,0000,0000,,(Saga of Tanya the Evil 2)
Dialogue: 0,0:20:09.18,0:20:11.18,sign,,0000,0000,0000,,MARKAS BESAR STAF UMUM KEKAISARAN
Dialogue: 0,0:23:35.97,0:23:39.98,sign,,0000,0000,0000,,(Episode Berikutnya: Pertempuran Martil)
Dialogue: 0,0:00:01.94,0:00:07.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentara Kekaisaran yang pusing akibat\Nserangan terus-menerus dari Federasi,
Dialogue: 0,0:00:07.14,0:00:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhasil menstabilkan situasi\Ndi wilayah timur dengan mengakui
Dialogue: 0,0:00:10.86,0:00:13.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hak otonomi kelompok anti-pemerintah\Ndi dalam Federasi.
Dialogue: 0,0:00:15.50,0:00:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mantel yang hangat.
Dialogue: 0,0:00:18.09,0:00:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak cocok dengan ukuranmu.\NBerikan padaku!
Dialogue: 0,0:00:20.23,0:00:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong tenang sedikit.
Dialogue: 0,0:00:21.55,0:00:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya kebagian.
Dialogue: 0,0:00:25.76,0:00:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm.
Dialogue: 0,0:00:26.74,0:00:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah-olah kejadian sebulan lalu\Ntidak pernah terjadi, ya.
Dialogue: 0,0:00:30.38,0:00:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Federasi dan Kerajaan Bersatu\Nmemperluas jalur kerja sama.
Dialogue: 0,0:00:34.68,0:00:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka melancarkan\Noperasi gabungan di utara.
Dialogue: 0,0:00:38.12,0:00:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kawan-kawan sekalian.
Dialogue: 0,0:00:39.40,0:00:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita lakukan dukungan\Ndari sisi samping.
Dialogue: 0,0:00:42.58,0:00:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga sekaligus dapat menjaga\Nkoordinasi internasional.
Dialogue: 0,0:00:44.89,0:00:48.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana jika melakukan operasi bersama\Ndengan Kerajaan Bersatu?
Dialogue: 0,0:00:48.69,0:00:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan-tuan sekalian.
Dialogue: 0,0:00:50.31,0:00:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mendukung negara sekutu,\Nkita akan melancarkan operasi pengalihan.
Dialogue: 0,0:00:54.29,0:00:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan memberi ancaman kepada\NTentara Kekaisaran di timur dari samping.
Dialogue: 0,0:00:59.04,0:01:01.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Federasi dan Kerajaan Bersatu
Dialogue: 0,0:01:01.54,0:01:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memperkuat operasi gabungan\Ndengan gerilyawan
Dialogue: 0,0:01:03.83,0:01:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di wilayah bekas persekutuan.
Dialogue: 0,0:01:06.26,0:01:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentara Kekaisaran yang kewalahan,
Dialogue: 0,0:01:08.44,0:01:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membutuhkan kekuatan tempur\Nyang dapat segera merespons,
Dialogue: 0,0:01:10.57,0:01:12.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka Grup Tempur Salamander\Ndikirim sebagai bala bantuan.
Dialogue: 0,0:01:18.28,0:01:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial.
Dialogue: 0,0:01:19.24,0:01:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana pun, tidak ada\Ntanda-tanda musim semi.
Dialogue: 0,0:01:22.67,0:01:23.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alhasil,
Dialogue: 0,0:01:23.71,0:01:26.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasukan Federasi dan Kerajaan Bersatu\Nmundur.
Dialogue: 0,0:01:27.11,0:01:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentara Kekaisaran juga menarik kembali\Npasukan tambahannya,
Dialogue: 0,0:01:29.60,0:01:32.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu menempatkannya kembali\Ndi front timur.
Dialogue: 0,0:01:33.22,0:01:36.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dari sudut pandang besar,\Nini hanyalah bentrokan kecil,
Dialogue: 0,0:01:37.25,0:01:38.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi di balik ini,
Dialogue: 0,0:01:38.82,0:01:41.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan Yirudoya sudah mulai\Nmengambil tindakan.
Dialogue: 0,0:03:15.01,0:03:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekaisaran terpaksa mengirimkan\Ntambahan pasukan ke utara?
Dialogue: 0,0:03:19.31,0:03:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:20.16,0:03:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiring dengan aksi mereka,
Dialogue: 0,0:03:21.26,0:03:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kantong mereka tampaknya ikut menipis.
Dialogue: 0,0:03:22.99,0:03:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya, bahan bakar beroktan tinggi
Dialogue: 0,0:03:23.97,0:03:26.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diam-diam disediakan.
Dialogue: 0,0:03:26.74,0:03:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya mereka ingin melakukan barter\Ndengan barang rampasan.
Dialogue: 0,0:03:30.44,0:03:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar gerombolan seperti pencuri.
Dialogue: 0,0:03:33.20,0:03:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya mereka sangat kekurangan
Dialogue: 0,0:03:35.11,0:03:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sumber daya.
Dialogue: 0,0:03:36.19,0:03:38.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita membantu pada saat ini,
Dialogue: 0,0:03:38.77,0:03:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa membuat Kekaisaran\Nberutang budi pada kita.
Dialogue: 0,0:03:40.90,0:03:43.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kita bisa menghentikan perang ini,
Dialogue: 0,0:03:43.02,0:03:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}negara-negara lain juga akan\Nmemberikan tepuk tangan pada kita.
Dialogue: 0,0:03:46.30,0:03:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:03:47.60,0:03:50.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah Kekaisaran mau mendengarkan kita?
Dialogue: 0,0:03:50.55,0:03:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ciptakan situasi yang\Nmembuat mereka harus mendengarkan.
Dialogue: 0,0:03:54.79,0:03:58.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menyelamatkan\Nnegara sekutu yang malang itu.
Dialogue: 0,0:04:05.71,0:04:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu Yirudoya tiba-tiba\Nmelakukan latihan mobilisasi?
Dialogue: 0,0:04:09.38,0:04:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentara Yirudoya berkumpul di depan perbatasan selatan?\N- Meski latihan ini seharusnya tidak ada maksud lain,
Dialogue: 0,0:04:11.89,0:04:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bukankah garis pertahanan kita kosong?\N- tapi kita juga tidak bisa tinggal diam.
Dialogue: 0,0:04:13.84,0:04:16.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika salah langkah, bisa mengulangi\Nkesalahan seperti Republik dulu.
Dialogue: 0,0:04:16.70,0:04:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Yirudoya sudah cukup\Nmenjadi ancaman,
Dialogue: 0,0:04:19.60,0:04:23.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rencana perang melawan Federasi\Ntentu harus direvisi besar-besaran.
Dialogue: 0,0:04:25.23,0:04:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ingin rasanya menikam gerombolan\Nspageti sialan itu sekarang juga.
Dialogue: 0,0:04:30.26,0:04:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga sependapat.
Dialogue: 0,0:04:31.75,0:04:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi Yirudoya adalah sekutu tercinta kita.
Dialogue: 0,0:04:34.21,0:04:36.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengabaikannya justru lebih menguntungkan.
Dialogue: 0,0:04:38.28,0:04:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu negara sekutu,
Dialogue: 0,0:04:39.89,0:04:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mestinya mereka mengizinkan kita\Nmengirim perwira pengamat, 'kan?
Dialogue: 0,0:04:43.16,0:04:45.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari bagian operasi,\Naku akan mengirim Rerugen.
Dialogue: 0,0:04:46.12,0:04:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu seharusnya bisa\Nmemahami situasi dengan jelas.
Dialogue: 0,0:05:01.39,0:05:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah Kolonel Virginio Calandro.
Dialogue: 0,0:05:04.18,0:05:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atas perintah Yang Mulia Igor Gassmann,\Naku ditugaskan mengantar Kolonel Rerugen.
Dialogue: 0,0:05:10.23,0:05:12.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini suatu kehormatan, Kolonel Calandro.
Dialogue: 0,0:05:19.13,0:05:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai seorang politikus militer,\Ntangannya terlalu kasar.
Dialogue: 0,0:05:22.95,0:05:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini berarti dia sudah\Nberkali-kali ke medan perang?
Dialogue: 0,0:05:27.43,0:05:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita teman dari negara sekutu,\Nkuharap bisa bicara dengan hati terbuka.
Dialogue: 0,0:05:32.19,0:05:35.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku langsung bicara terus terang saja.
Dialogue: 0,0:05:36.40,0:05:40.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai perantara yang baik hati,\NKerajaan Yirudoya
Dialogue: 0,0:05:41.17,0:05:43.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah menyiapkan komoditas\Nbernama "perdamaian" untuk kalian.
Dialogue: 0,0:05:44.69,0:05:46.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksud Anda...
Dialogue: 0,0:05:46.65,0:05:50.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sederhananya yaitu perundingan\Nuntuk memulihkan perdamaian.
Dialogue: 0,0:05:51.95,0:05:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:05:53.31,0:05:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, negara Anda akan menjadi\Npenengah untuk perundingan perdamaian?
Dialogue: 0,0:05:55.70,0:05:56.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:05:57.01,0:06:00.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penghubung bagi teman-teman.\NKami sangat senang bisa menjadi
Dialogue: 0,0:06:00.96,0:06:02.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ini agak lancang,
Dialogue: 0,0:06:02.82,0:06:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bukankah sekarang saatnya negara Anda\Nuntuk mencari momen mengakhiri ini?
Dialogue: 0,0:06:07.33,0:06:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini harus diputuskan\Noleh Kantor Panglima Tertinggi kami.
Dialogue: 0,0:06:13.20,0:06:14.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:06:14.18,0:06:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi seharusnya ini adalah\Npekerjaan diplomat, bukan?
Dialogue: 0,0:06:17.07,0:06:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:06:18.26,0:06:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}justru karena hubungan di antara kita,
Dialogue: 0,0:06:21.05,0:06:24.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa jika dibicarakan antar prajurit,\Nurusannya akan lebih cepat selesai.
Dialogue: 0,0:06:25.36,0:06:30.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah siap untuk menengahi antara\NKekaisaran dan negara yang berperang.
Dialogue: 0,0:06:31.07,0:06:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski saat ini masih dalam\Ntahap operasi rahasia,
Dialogue: 0,0:06:32.69,0:06:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kami juga sudah siap bekerja sama\Ndengan Negara Federasi,
Dialogue: 0,0:06:34.30,0:06:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyerukan kepada semua negara untuk\Nmengadakan konferensi gencatan senjata.
Dialogue: 0,0:06:38.60,0:06:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang maju berbicara ini\Njuga memiliki kekuatan yang sepadan.
Dialogue: 0,0:06:43.12,0:06:45.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap Anda bisa memahami hal ini.
Dialogue: 0,0:06:46.65,0:06:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:06:48.31,0:06:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi latihan mobilisasi yang mendadak ini\Nada maksud tersembunyi seperti itu?
Dialogue: 0,0:06:53.90,0:06:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lintah selatan sialan!
Dialogue: 0,0:06:56.47,0:06:59.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya maju sebagai penengah\Ndengan kedok negara netral.
Dialogue: 0,0:06:59.93,0:07:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika syarat-syaratnya bisa disepakati,\Nini bukanlah hal yang buruk.
Dialogue: 0,0:07:04.55,0:07:08.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuntutan kami adalah ganti rugi.
Dialogue: 0,0:07:09.14,0:07:10.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira begitulah.
Dialogue: 0,0:07:11.14,0:07:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah mengatur persiapan untuk\Nmenerima perwira pengamat dari Yirudoya.
Dialogue: 0,0:07:16.74,0:07:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Digunakan sebagai bahan pertimbangan\Nuntuk rancangan perundingan, ya?
Dialogue: 0,0:07:24.37,0:07:27.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus menemukan titik kompromi.
Dialogue: 0,0:07:28.07,0:07:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak,
Dialogue: 0,0:07:29.15,0:07:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}harus menemukannya.
Dialogue: 0,0:07:36.31,0:07:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah.
Dialogue: 0,0:07:37.37,0:07:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Front timur lagi?
Dialogue: 0,0:07:39.02,0:07:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tanah bersalju, sekarang lumpur.
Dialogue: 0,0:07:40.95,0:07:44.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kaus kaki tidak bisa habis dicuci.
Dialogue: 0,0:07:47.29,0:07:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garis depannya lebih rumit dan kacau\Ndari yang dibayangkan, ya.
Dialogue: 0,0:07:50.38,0:07:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tidak merapikan kembali\Ngaris depan?
Dialogue: 0,0:07:52.91,0:07:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini juga demi menjaga\Nmuka Majelis Otonomi.
Dialogue: 0,0:07:56.02,0:07:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mungkin juga dalam kondisi dilema.
Dialogue: 0,0:08:01.15,0:08:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru saja merasa unggul,\Nsekejap kemudian malah terdesak.
Dialogue: 0,0:08:04.89,0:08:09.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sekarang bukan waktunya santai\Nmemikirkan cara menyelamatkan diri.
Dialogue: 0,0:08:12.29,0:08:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana titik kompromi\Nuntuk mengakhiri perang ini?
Dialogue: 0,0:08:21.33,0:08:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letnan Kolonel, bolehkah ganggu sebentar?
Dialogue: 0,0:08:24.16,0:08:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:08:25.20,0:08:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada urusan apa?
Dialogue: 0,0:08:26.55,0:08:28.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang dari Markas Besar Staf Umum\Nyang berkunjung.
Dialogue: 0,0:08:30.49,0:08:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu,\NLetnan Kolonel Degurechaff.
Dialogue: 0,0:08:33.55,0:08:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kopi di garis depan,\Naromanya saja sudah sangat berbeda.
Dialogue: 0,0:08:37.53,0:08:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ada di ibu kota kekaisaran,\Npaling-paling termasuk ada warna kopi...
Dialogue: 0,0:08:40.14,0:08:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kolonel Rerugen.
Dialogue: 0,0:08:42.00,0:08:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keperluan apa Anda datang hari ini?
Dialogue: 0,0:08:45.81,0:08:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menerima seorang tamu.\NSebenarnya, aku ingin meminta bantuanmu
Dialogue: 0,0:08:49.82,0:08:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang kolonel dari Yirudoya.
Dialogue: 0,0:08:52.32,0:08:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah seorang perwira pengamat?
Dialogue: 0,0:08:54.61,0:08:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:55.87,0:08:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kolonel,
Dialogue: 0,0:08:56.99,0:09:00.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dalam situasi seperti ini, sama sekali\Nsulit melayani dengan layak.
Dialogue: 0,0:09:00.59,0:09:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu, tetap harus\Nmemohon bantuanmu.
Dialogue: 0,0:09:04.08,0:09:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya ada alasan mendalam di baliknya.
Dialogue: 0,0:09:09.01,0:09:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa cepat atau lambat,\Nkau pun akan tahu.
Dialogue: 0,0:09:11.34,0:09:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena tidak ada rahasia selamanya.
Dialogue: 0,0:09:16.44,0:09:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai hari ini, Grup Tempur Salamander\Nberada di bawah komandoku.
Dialogue: 0,0:09:20.89,0:09:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ditunjuk sebagai\Nkomandan kampfgruppe mekanis.
Dialogue: 0,0:09:25.04,0:09:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski di bawah komandoku,
Dialogue: 0,0:09:27.53,0:09:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kekuasaan komando yang sebenarnya\Ntetap ada padamu.
Dialogue: 0,0:09:32.21,0:09:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:09:33.72,0:09:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ini wakil komandan Kampfgruppe Rerugen\Nyang secara resmi tidak ada,
Dialogue: 0,0:09:37.83,0:09:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekaligus tetap menjabat sebagai komandan\NGrup Tempur Salamander yang sekarang?
Dialogue: 0,0:09:43.15,0:09:44.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:09:44.78,0:09:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi perlu memintamu menerima\Nsatu permintaan yang tidak masuk akal.
Dialogue: 0,0:09:48.72,0:09:52.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu di laporan hasil pertempuran resmi\Nakan dicantumkan namaku.
Dialogue: 0,0:09:53.12,0:09:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, secara resmi ini sama dengan\Nmerebut jasa militermu.
Dialogue: 0,0:09:57.11,0:09:58.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon,
Dialogue: 0,0:09:59.09,0:10:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maklumi aku.
Dialogue: 0,0:10:02.44,0:10:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:10:04.64,0:10:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm?
Dialogue: 0,0:10:05.62,0:10:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya penanggung jawab formal\Ndi atasku,
Dialogue: 0,0:10:08.34,0:10:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa buat orang di Departemen Personalia\Nberutang budi padaku.
Dialogue: 0,0:10:11.72,0:10:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini luar biasa?
Dialogue: 0,0:10:14.28,0:10:15.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:10:17.44,0:10:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku adalah seorang prajurit yang telah\Nbersumpah menjadi abdi negara.
Dialogue: 0,0:10:22.81,0:10:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun tidak bisa dikatakan\Ntanpa keluh kesah di hati,
Dialogue: 0,0:10:26.73,0:10:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi jika bisa mendapat perhatian\Nyang begitu cermat dari Anda,
Dialogue: 0,0:10:29.89,0:10:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah cukup puas.
Dialogue: 0,0:10:33.14,0:10:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lega.
Dialogue: 0,0:10:34.73,0:10:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku sudah bersiap mental\Nakan ditembak mati olehmu.
Dialogue: 0,0:10:38.96,0:10:41.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda benar-benar pandai bercanda.
Dialogue: 0,0:10:46.06,0:10:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang berkenalan denganmu, Nona.
Dialogue: 0,0:10:48.38,0:10:51.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mengalami segalanya, Kolonel.
Dialogue: 0,0:10:51.70,0:10:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekujur tubuhku sudah berlumuran darah.
Dialogue: 0,0:10:54.44,0:10:58.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah Anda mau memanggilku\Nnona atau Letnan Kolonel.
Dialogue: 0,0:11:00.86,0:11:05.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku perwira pengamat yang ditugaskan\Nke sini, Kolonel Virginio Calandro.
Dialogue: 0,0:11:05.22,0:11:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Letnan Kolonel Tanya von Degurechaff.
Dialogue: 0,0:11:10.34,0:11:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski sudah lama mendengar\Nkehebatan Perak Putih,
Dialogue: 0,0:11:13.68,0:11:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melihat sosokmu secara langsung,\Ntetap membuatku terkejut.
Dialogue: 0,0:11:16.63,0:11:19.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini hanya karena area sasarannya kecil,\Njadi aku diuntungkan.
Dialogue: 0,0:11:20.37,0:11:22.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, harap hati-hati\Nterhadap peluru nyasar.
Dialogue: 0,0:11:24.47,0:11:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu benar-benar merepotkan.
Dialogue: 0,0:11:25.81,0:11:28.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan berjalan setengah jongkok\Ndi medan perang.
Dialogue: 0,0:11:30.02,0:11:32.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di garis depan.
Dialogue: 0,0:11:33.55,0:11:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku mewakili negara sekutu
Dialogue: 0,0:11:35.83,0:11:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyampaikan sambutan hangat.
Dialogue: 0,0:11:53.56,0:11:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kalian selalu bisa\Nmakan makanan panas?
Dialogue: 0,0:11:57.07,0:11:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena makanan berkaitan dengan moral.
Dialogue: 0,0:11:59.66,0:12:01.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dinikmati selagi panas, Kolonel.
Dialogue: 0,0:12:05.66,0:12:07.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini garis depan,
Dialogue: 0,0:12:07.69,0:12:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disiplin pasukan tetap begitu ketat.
Dialogue: 0,0:12:11.00,0:12:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mempertahankan sistem\Ndalam skala ini,
Dialogue: 0,0:12:13.85,0:12:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengeluaran Kekaisaran pasti\Nakan terus meningkat, 'kan?
Dialogue: 0,0:12:19.22,0:12:20.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana situasi di sekitar?
Dialogue: 0,0:12:20.99,0:12:21.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:21.84,0:12:25.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan Kapten Ahrens bertemu\Ndengan kelompok tank musuh.
Dialogue: 0,0:12:25.35,0:12:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:12:27.28,0:12:29.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku ikut mendengar?
Dialogue: 0,0:12:29.93,0:12:31.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, tidak masalah.
Dialogue: 0,0:12:32.18,0:12:34.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, aku merasa agak repot.
Dialogue: 0,0:12:35.81,0:12:38.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Area pertempurannya tampak\Nseperti daerah pemukiman.
Dialogue: 0,0:12:38.48,0:12:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam situasi seperti ini,\Nbagaimana Anda menanganinya?
Dialogue: 0,0:12:40.66,0:12:42.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa ini saatnya artileri beraksi.
Dialogue: 0,0:12:42.91,0:12:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tembakan meriam?
Dialogue: 0,0:12:44.13,0:12:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah akan menembaki daerah pemukiman\Ntanpa peringatan?
Dialogue: 0,0:12:45.97,0:12:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:46.77,0:12:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, langkah ini bisa\Nmeminimalkan korban.
Dialogue: 0,0:12:48.99,0:12:50.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letnan Kolonel,
Dialogue: 0,0:12:50.16,0:12:53.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah penembakan seperti itu\Nmelanggar hukum internasional masa perang?
Dialogue: 0,0:12:53.91,0:12:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konvensi perang darat\Nmenganut asas timbal balik.
Dialogue: 0,0:12:56.72,0:13:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Hanya bila semua pihak yang berperang\Nadalah negara pihak pada konvensi ini,"
Dialogue: 0,0:13:01.32,0:13:04.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"barulah konvensi ini hanya berlaku\Ndi antara negara-negara penandatanganan."
Dialogue: 0,0:13:04.63,0:13:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejauh yang kutahu, Federasi tidak\Nmenandatangani konvensi perang darat.
Dialogue: 0,0:13:09.75,0:13:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, karena itu kau bilang\Nakan membombardir kota?
Dialogue: 0,0:13:12.56,0:13:13.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:13.58,0:13:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekaisaran juga sudah\Nmembombardir banyak kota.
Dialogue: 0,0:13:16.18,0:13:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kota mereka seharusnya\Nakan bernasib sama, 'kan?
Dialogue: 0,0:13:18.86,0:13:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:13:20.22,0:13:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau berniat menghancurkan\Ngereja juga?
Dialogue: 0,0:13:22.03,0:13:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerang fasilitas dan personel keagamaan\Nadalah tindakan yang melanggar norma.
Dialogue: 0,0:13:25.60,0:13:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, apa yang Anda bicarakan?
Dialogue: 0,0:13:28.14,0:13:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fasilitas dan personel keagamaan\Nadalah objek yang dilindungi...
Dialogue: 0,0:13:31.00,0:13:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami telah memastikan
Dialogue: 0,0:13:32.86,0:13:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di tempat itu tidak ada tanda khusus yang\Nmenunjukkan sebagai fasilitas keagamaan.
Dialogue: 0,0:13:36.59,0:13:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:37.89,0:13:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga menghormati\Nhukum kebiasaan dan norma.
Dialogue: 0,0:13:42.23,0:13:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:13:43.33,0:13:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenyataannya di sana tidak ada tanda.
Dialogue: 0,0:13:46.18,0:13:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bagaimanapun dilihat, itu adalah...
Dialogue: 0,0:13:50.40,0:13:51.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kolonel,
Dialogue: 0,0:13:51.82,0:13:54.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah Anda melihat suatu tanda?
Dialogue: 0,0:13:57.19,0:13:58.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:14:18.92,0:14:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak
Dialogue: 0,0:14:20.83,0:14:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atas bantuan Anda.
Dialogue: 0,0:14:29.67,0:14:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bilang ada urusan penting\Nyang ingin dibicarakan, apa itu?
Dialogue: 0,0:14:32.94,0:14:35.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bicara langsung saja.\NAku ingin menanyakan satu hal.
Dialogue: 0,0:14:36.29,0:14:39.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama bisa kujawab, silakan tanyakan.
Dialogue: 0,0:14:40.77,0:14:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tentang titik kompromi.
Dialogue: 0,0:14:42.18,0:14:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu, bagaimana perang ini diakhiri?
Dialogue: 0,0:14:46.83,0:14:48.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang kemari untuk itu.
Dialogue: 0,0:14:49.20,0:14:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:14:50.45,0:14:52.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yirudoya ingin menjadi penengah,
Dialogue: 0,0:14:53.32,0:14:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyiapkan jalan keluar\Nyang sudah lama kami cari-cari?
Dialogue: 0,0:14:57.48,0:14:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham ini sulit diterima,
Dialogue: 0,0:14:59.77,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tidak bisakah berkompromi?
Dialogue: 0,0:15:02.40,0:15:05.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, tanya apakah kami bisa\Nberkompromi untuk keluar dari masalah ini?
Dialogue: 0,0:15:06.41,0:15:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja bisa!
Dialogue: 0,0:15:08.27,0:15:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghentikan kerugian. Sekarang hanya bisa\Nmenghentikan kerugian.
Dialogue: 0,0:15:10.57,0:15:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah beri tahu aku syarat minimum apa\Nyang bisa kau terima?
Dialogue: 0,0:15:15.48,0:15:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syarat?
Dialogue: 0,0:15:16.60,0:15:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hal seperti itu.
Dialogue: 0,0:15:18.04,0:15:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:15:18.93,0:15:20.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada syarat?
Dialogue: 0,0:15:20.85,0:15:23.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sebagai seorang prajurit,
Dialogue: 0,0:15:23.13,0:15:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah bersumpah untuk mematuhi\Nperintah yang sah.
Dialogue: 0,0:15:27.19,0:15:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena titik kompromi perang ini\Nditentukan oleh atasan,
Dialogue: 0,0:15:30.61,0:15:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka selain patuh,\Ntidak mungkin ada syarat lain.
Dialogue: 0,0:15:34.47,0:15:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kewajiban mematuhi perintah yang sah
Dialogue: 0,0:15:37.57,0:15:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berada di atas segalanya.
Dialogue: 0,0:15:39.81,0:15:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah seorang prajurit.
Dialogue: 0,0:15:43.44,0:15:44.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:15:44.96,0:15:49.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Kekaisaran, bahkan perwira garis depan\Njuga mempertahankan rasionalitas negara?
Dialogue: 0,0:15:50.11,0:15:51.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:51.24,0:15:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan komandan lapangan berpengalaman\Ndi garis depan pun tahu batasan,
Dialogue: 0,0:15:55.03,0:15:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai tahap yang menakutkan.
Dialogue: 0,0:15:56.77,0:15:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat setia pada kewajiban.
Dialogue: 0,0:15:59.49,0:16:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus dilakukan agar mereka...
Dialogue: 0,0:16:02.10,0:16:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita sampaikan\Nsuara kita juga.
Dialogue: 0,0:16:05.34,0:16:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah melihat peluang keberhasilan\Noperasi penengahan ini.
Dialogue: 0,0:16:09.01,0:16:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan demikian,
Dialogue: 0,0:16:10.41,0:16:12.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perang pun akan berakhir.
Dialogue: 0,0:16:17.82,0:16:22.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampaknya perwira pengamat sudah paham\Nprajurit Kekaisaran sangat pengertian.
Dialogue: 0,0:16:23.52,0:16:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat situasi ini,
Dialogue: 0,0:16:24.83,0:16:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}perundingan perdamaian pasti bisa\Ntercapai dengan lancar.
Dialogue: 0,0:16:28.55,0:16:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah melakukan satu hal baik.
Dialogue: 0,0:16:31.67,0:16:34.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, perang ini pun...
Dialogue: 0,0:16:39.70,0:16:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letnan Kolonel, boleh ganggu sebentar?
Dialogue: 0,0:16:41.64,0:16:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:42.70,0:16:43.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Urusan apa?
Dialogue: 0,0:16:43.88,0:16:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang dari Markas Besar Staf Umum\Nyang berkunjung.
Dialogue: 0,0:16:46.94,0:16:48.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang lagi?
Dialogue: 0,0:16:49.61,0:16:52.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tidak bertemu,\NLetnan Kolonel Degurechaff.
Dialogue: 0,0:16:52.48,0:16:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi omong-omong,
Dialogue: 0,0:16:53.30,0:16:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah sekian lama minum kopi asli,\Nrasanya memang berbeda.
Dialogue: 0,0:16:56.47,0:16:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada minum kopi palsu\Nyang cuma warnanya mirip...
Dialogue: 0,0:16:59.67,0:17:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letnan Kolonel Uga.
Dialogue: 0,0:17:01.36,0:17:03.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada keperluan apa Anda datang hari ini?
Dialogue: 0,0:17:03.86,0:17:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada sedikit masalah\Ndi jalur kereta api sekitar sini,
Dialogue: 0,0:17:06.79,0:17:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat mengurus koordinasi, aku tiba-tiba\Nteringat kau, temanku di Akademi Militer,
Dialogue: 0,0:17:09.56,0:17:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sekalian mampir mengunjungimu.
Dialogue: 0,0:17:12.61,0:17:14.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku ini juga kesempatan yang bagus.
Dialogue: 0,0:17:14.93,0:17:18.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena pikir ini kesempatan langka,\Naku ajak serta anak buahku, Mayor Weiß.
Dialogue: 0,0:17:19.41,0:17:22.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang sekali melihatmu\Nmembawa serta anak buah.
Dialogue: 0,0:17:22.56,0:17:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya untuk berjaga-jaga kalau ada\Nyang menguping, jadi kusuruh dia berjaga.
Dialogue: 0,0:17:27.63,0:17:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu...
Dialogue: 0,0:17:29.46,0:17:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kita sedang melakukan\Nperundingan perdamaian melalui Yirudoya.
Dialogue: 0,0:17:35.86,0:17:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kau juga sudah\Nmendengar kabar anginnya?
Dialogue: 0,0:17:38.56,0:17:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba aku disuruh\Nmenerima perwira pengamat,
Dialogue: 0,0:17:42.14,0:17:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi sedikit penasaran.
Dialogue: 0,0:17:44.82,0:17:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ingin segera mendorong\Nrencana perundingan perdamaian,
Dialogue: 0,0:17:47.26,0:17:50.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah atasan menganggap bahwa\Nberkompromi adalah langkah terpaksa?
Dialogue: 0,0:17:51.29,0:17:52.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun menjengkelkan,
Dialogue: 0,0:17:52.72,0:17:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi memang begitu.
Dialogue: 0,0:17:54.13,0:17:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita mungkin harus berkompromi\Npada kenyataan, 'kan?
Dialogue: 0,0:17:57.19,0:18:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, solusinya tetap berupa perjanjian\Ntanpa bayar ganti rugi, kedua pihak saling
Dialogue: 0,0:18:01.62,0:18:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melepas hak tuntutan, kembalikan wilayah,\Nmemulihkan perbatasan ke kondisi semula?
Dialogue: 0,0:18:06.46,0:18:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:18:07.54,0:18:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin perjanjian pengurangan senjata\Njuga akan ikut ditandatangani...
Dialogue: 0,0:18:10.20,0:18:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Letnan Kolonel,
Dialogue: 0,0:18:12.39,0:18:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu bukanlah perjanjian perdamaian\Nyang terhormat.
Dialogue: 0,0:18:14.84,0:18:16.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja dengan menyerah.
Dialogue: 0,0:18:18.03,0:18:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmm?
Dialogue: 0,0:18:18.94,0:18:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kira berapa banyak biaya militer\Nyang sudah kita keluarkan?
Dialogue: 0,0:18:21.05,0:18:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berapa banyak mayat yang sudah bertumpuk?
Dialogue: 0,0:18:23.70,0:18:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena itu, kita tidak ingin\Nmelihat lebih banyak korban lagi, 'kan?
Dialogue: 0,0:18:28.28,0:18:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Letnan Kolonel Uga seharusnya\Nlebih merasakan hal ini dari siapa pun.
Dialogue: 0,0:18:34.69,0:18:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mayor Weiß,
Dialogue: 0,0:18:36.23,0:18:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana pendapatmu?
Dialogue: 0,0:18:38.13,0:18:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendengar pendapat perwira\Nyang memahami situasi di lapangan.
Dialogue: 0,0:18:41.84,0:18:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:18:42.66,0:18:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini boleh?
Dialogue: 0,0:18:44.45,0:18:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa. Katakan saja.
Dialogue: 0,0:18:48.44,0:18:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesimpulannya,
Dialogue: 0,0:18:50.90,0:18:52.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memilih antara hasil yang sepadan\Ndengan pengorbanan
Dialogue: 0,0:18:53.25,0:18:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan masa depan tanpa lebih banyak korban,
Dialogue: 0,0:18:56.71,0:18:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku berharap yang terakhir.
Dialogue: 0,0:18:59.58,0:19:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:19:02.54,0:19:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa menerima begitu saja.
Dialogue: 0,0:19:04.06,0:19:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:19:05.13,0:19:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah begitu banyak darah yang tertumpah,
Dialogue: 0,0:19:07.16,0:19:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akhirnya tidak mendapatkan hasil apa pun.
Dialogue: 0,0:19:09.36,0:19:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguh...
Dialogue: 0,0:19:10.27,0:19:12.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar...
Dialogue: 0,0:19:14.68,0:19:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar mengejutkan,
Dialogue: 0,0:19:16.28,0:19:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau juga berpikiran begitu?
Dialogue: 0,0:19:18.97,0:19:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya, kenapa Anda bisa merelakan,\NLetnan Kolonel?
Dialogue: 0,0:19:22.01,0:19:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hanya itu yang bisa kulakukan.
Dialogue: 0,0:19:23.92,0:19:27.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan seorang komandan garis depan\Nada pada pengambilan keputusan dan fokus.
Dialogue: 0,0:19:27.81,0:19:30.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika perlu, juga bisa\Nmenghentikan kerugian.
Dialogue: 0,0:19:30.85,0:19:33.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus terang, itu hanya logika sesat
Dialogue: 0,0:19:34.40,0:19:36.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan alasan yang dipaksakan!
Dialogue: 0,0:19:46.34,0:19:47.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buruk.
Dialogue: 0,0:19:47.70,0:19:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak disangka, bahkan rekan seangkatan\Ndan anak buah yang bisa dipercaya
Dialogue: 0,0:19:50.47,0:19:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga terjebak dalam efek biaya\Nyang telah dikeluarkan.
Dialogue: 0,0:19:54.39,0:19:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini, Markas Besar Staf Umum\Ndan Kantor Panglima Tertinggi
Dialogue: 0,0:19:58.02,0:20:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti akan kerepotan\Nuntuk meyakinkan garis depan.
Dialogue: 0,0:20:01.66,0:20:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skenario terburuk adalah penindasan\Ndengan kekuatan bersenjata, 'kan?
Dialogue: 0,0:20:04.55,0:20:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saling bunuh tidak baik\Nuntuk karier di masa depan.
Dialogue: 0,0:20:11.40,0:20:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Federasi menyampaikan tuntutan mereka\Nmelalui Yirudoya.
Dialogue: 0,0:20:15.75,0:20:21.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syaratnya adalah "tanpa ganti rugi,\Ntanpa penyerahan wilayah, tanpa syarat".
Dialogue: 0,0:20:22.71,0:20:24.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia Jenderal Gasman,
Dialogue: 0,0:20:24.85,0:20:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengenai perundingan perdamaian,\Nnegara kami sudah mengirim pemberitahuan.
Dialogue: 0,0:20:29.22,0:20:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendengarnya lebih rinci.
Dialogue: 0,0:20:31.78,0:20:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski tuntutan kami ditolak,
Dialogue: 0,0:20:34.14,0:20:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi negosiasi masih berlangsung.
Dialogue: 0,0:20:36.41,0:20:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama perundingan terus berjalan...
Dialogue: 0,0:20:37.71,0:20:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tidak berguna lagi.
Dialogue: 0,0:20:39.63,0:20:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:41.44,0:20:44.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang kau sudah tidak berguna, Zettour.
Dialogue: 0,0:20:45.82,0:20:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berbicara\Ndengan Kantor Panglima Tertinggi.
Dialogue: 0,0:20:50.17,0:20:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau...
Dialogue: 0,0:20:51.25,0:20:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:20:52.77,0:20:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:20:53.72,0:20:56.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sampaikan di sini\Njawaban dari negara kita.
Dialogue: 0,0:20:56.93,0:20:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:59.22,0:21:00.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan kotoran saja.
Dialogue: 0,0:21:00.97,0:21:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekian.
Dialogue: 0,0:21:03.77,0:21:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasib harus dikendalikan sendiri,
Dialogue: 0,0:21:06.79,0:21:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak boleh diserahkan\Nke tangan orang lain.
Dialogue: 0,0:21:09.98,0:21:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan tekad yang tak tergoyahkan,\Ntentara kita
Dialogue: 0,0:21:17.23,0:21:19.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan resmi melancarkan Pertempuran Martil.
Dialogue: 0,0:22:50.47,0:22:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku komandan Kompi Keempat.
Dialogue: 0,0:22:51.72,0:22:53.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan Kompi Ketiga.
Dialogue: 0,0:22:53.22,0:22:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan Kompi Kedua.
Dialogue: 0,0:22:54.36,0:22:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Komandan Kompi Pertama.
Dialogue: 0,0:22:58.30,0:22:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:22:59.20,0:23:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua anggota di pasukan archmage\Ndimutasi, ya.
Dialogue: 0,0:23:02.73,0:23:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:03.54,0:23:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Mayor Weiß?
Dialogue: 0,0:23:05.78,0:23:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengganti Letnan Kolonel Degurechaff\Nyang tadinya memimpin kampfgruppe,
Dialogue: 0,0:23:09.59,0:23:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memimpin keseluruhan pasukan archmage.
Dialogue: 0,0:23:12.32,0:23:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar luar biasa.
Dialogue: 0,0:23:13.71,0:23:14.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat.
Dialogue: 0,0:23:14.62,0:23:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik!
Dialogue: 0,0:23:19.66,0:23:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa denganmu?
Dialogue: 0,0:23:21.42,0:23:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, karena dia melepas jabatan\Nkomandan kompi, tunjangannya dipotong.
Dialogue: 0,0:23:25.47,0:23:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juga untuk menjaga operasional pasukan,\Npengeluaran sendiri malah bertambah.
Dialogue: 0,0:23:28.37,0:23:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gaji bersih yang diterima\Ntampaknya malah berkurang.
Dialogue: 0,0:23:31.71,0:23:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Naik pangkat itu menakutkan, ya.
