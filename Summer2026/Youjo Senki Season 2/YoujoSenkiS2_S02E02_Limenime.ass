Dialogue: 0,0:00:00.46,0:00:04.32,sign,,0,0,0,,AKHIR NOVEMBER 1926 KALENDER BERSATU
Dialogue: 0,0:00:33.80,0:00:41.11,sign,,0,0,0,,(Saga of Tanya the Evil 2)
Dialogue: 0,0:01:56.71,0:01:58.94,sign,,0,0,0,,ANIMASI INI BERSIFAT FIKTIF
Dialogue: 0,0:01:58.94,0:02:01.27,sign,,0,0,0,,ISI DRAMA TIDAK IDENTIK DENGAN DUNIA NYATA
Dialogue: 0,0:03:29.39,0:03:33.40,sign,,0,0,0,,(Bab 2: Persahabatan yang Aneh)
Dialogue: 0,0:04:50.25,0:04:53.56,sign,,0,0,0,,IBU KOTA KERAJAAN BERSATU, LONDINIUM
Dialogue: 0,0:05:23.09,0:05:24.44,sign,,0,0,0,,IBU KOTA FEDERASI, MOSKOW
Dialogue: 0,0:06:20.68,0:06:23.48,sign,,0,0,0,,KOMANDAN BATALION, LETNAN KOLONEL WILLIAM DOUGLAS DRAKE
Dialogue: 0,0:06:35.91,0:06:39.08,sign,,0,0,0,,PETUGAS POLITIK TENTARA FEDERAL SUKARELAWAN MULTINASIONAL
Dialogue: 0,0:06:39.08,0:06:40.00,sign,,0,0,0,,LETNAN LILYA IVANOVA TANECHKA
Dialogue: 0,0:06:40.00,0:06:42.92,sign,,0,0,0,,KOMANDAN TENTARA FEDERAL, KOLONEL MIKEL
Dialogue: 0,0:07:14.50,0:07:16.71,sign,,0,0,0,,SUKARELAWAN NEGARA FEDERASI, LETNAN MARY SUE
Dialogue: 0,0:12:50.00,0:12:52.99,sign,,0,0,0,,(Saga of Tanya the Evil 2)
Dialogue: 0,0:12:53.00,0:12:56.02,sign,,0,0,0,,(Saga of Tanya the Evil 2)
Dialogue: 0,0:12:57.77,0:13:00.77,sign,,0,0,0,,MARKAS BESAR STAF UMUM KEKAISARAN
Dialogue: 0,0:16:24.27,0:16:26.77,sign,,0,0,0,,DI DALAM WILAYAH FEDERAL,\NWILAYAH PENDUDUKAN TENTARA KEKAISARAN
Dialogue: 0,0:19:14.37,0:19:16.64,sign,,0,0,0,,KEDUTAAN BESAR KERAJAAN BERSATU MOSKOW
Dialogue: 0,0:21:20.15,0:21:23.15,sign,,0,0,0,,KERAJAAN YIRUDOYA,\NMARKAS BESAR ANGKATAN DARAT
Dialogue: 0,0:00:05.49,0:00:06.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya amunisi.
Dialogue: 0,0:00:06.79,0:00:08.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Barang sehari-hari\Nsama sekali tidak cukup.
Dialogue: 0,0:00:09.48,0:00:11.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setidaknya berikanlah sepasang kaus kaki.
Dialogue: 0,0:00:12.52,0:00:16.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan kita yang langsung berada di bawah\NStaf Umum juga hanya dapat sebanyak ini?
Dialogue: 0,0:00:16.35,0:00:19.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya situasi di seluruh\Nfront timur sudah bisa ditebak.
Dialogue: 0,0:00:22.89,0:00:24.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cuacanya benar-benar buruk.
Dialogue: 0,0:02:07.57,0:02:09.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf, aku terlambat.
Dialogue: 0,0:02:13.97,0:02:16.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi, ini jarang sekali.
Dialogue: 0,0:02:16.45,0:02:18.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisa-bisanya kau mengajakku minum.
Dialogue: 0,0:02:19.03,0:02:22.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya aku menemukan\Nsesuatu yang menarik.
Dialogue: 0,0:02:25.11,0:02:26.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:02:27.40,0:02:28.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Putarkanlah.
Dialogue: 0,0:02:38.36,0:02:39.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh mengejutkan.
Dialogue: 0,0:02:40.01,0:02:42.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah ini Komandan Batalion Rauden\Nyang membuat orang rindu?
Dialogue: 0,0:02:45.25,0:02:48.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu mengingatkanmu pada\Nkehidupan neraka saat itu, 'kan?
Dialogue: 0,0:02:48.96,0:02:50.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:02:50.32,0:02:52.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sampai berkeringat dingin.
Dialogue: 0,0:02:52.61,0:02:54.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimanapun, saat itu\Nbukan hanya bunyi terompet bangun,
Dialogue: 0,0:02:54.68,0:02:58.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}bahkan saat makan, mandi,\Ndan ke toilet pun lagu itu terus diputar.
Dialogue: 0,0:02:58.88,0:03:00.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Syukurlah kita bisa bertahan.
Dialogue: 0,0:03:00.98,0:03:03.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau bukan bersamamu,\Naku tidak akan sanggup.
Dialogue: 0,0:03:04.18,0:03:06.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita sama saja dalam hal ini.
Dialogue: 0,0:03:06.89,0:03:08.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Barang ini seharusnya\Nsudah tidak dicetak lagi, 'kan?
Dialogue: 0,0:03:10.18,0:03:12.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku kebetulan melihatnya di pasar loak.
Dialogue: 0,0:03:12.99,0:03:14.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meskipun aku kena tipu harganya.
Dialogue: 0,0:03:15.48,0:03:19.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika masa-masa itu bisa dicandain\Nsebagai kenangan, itu terhitung murah.
Dialogue: 0,0:03:20.10,0:03:21.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:03:21.87,0:03:25.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Piringan hitam ini akan kutitip di sini.\NKapan pun kau mau dengar, datang saja.
Dialogue: 0,0:03:26.93,0:03:28.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku terima\Ndengan senang hati.
Dialogue: 0,0:03:35.08,0:03:37.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah 30 tahun lebih ya.
Dialogue: 0,0:03:37.91,0:03:40.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Waktu benar-benar berlalu cepat.
Dialogue: 0,0:03:40.92,0:03:41.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:44.99,0:03:49.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi bagi kita, tidak ada waktu\Nuntuk bernostalgia.
Dialogue: 0,0:03:49.79,0:03:51.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:03:53.34,0:03:54.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Zettour.
Dialogue: 0,0:03:54.79,0:03:56.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita sudah lama kenal.
Dialogue: 0,0:03:56.58,0:04:00.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebagai teman lama, biarkan aku\Nmendengar isi hatimu yang sebenarnya.
Dialogue: 0,0:04:02.49,0:04:04.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Musim dingin datang terlalu cepat.
Dialogue: 0,0:04:05.31,0:04:09.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk memusnahkan pasukan musuh\Ndengan cepat sudah mustahil.
Dialogue: 0,0:04:09.31,0:04:11.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita harus menyusun ulang front.
Dialogue: 0,0:04:12.63,0:04:17.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kita harus menanggung\Nstigma ketidakmampuan juga?
Dialogue: 0,0:04:18.55,0:04:20.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masalahnya setelah musim dingin,
Dialogue: 0,0:04:20.53,0:04:23.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}apakah masih berencana\Nmelancarkan serangan lagi?
Dialogue: 0,0:04:23.70,0:04:25.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada cara lain selain itu.
Dialogue: 0,0:04:27.21,0:04:31.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Situasi Kekaisaran saat ini hanya bisa\Nbertahan hidup dengan swasembada.
Dialogue: 0,0:04:31.84,0:04:36.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dan itu pun hanya bisa dilakukan\Njika mengerahkan seluruh pasukan.
Dialogue: 0,0:04:37.65,0:04:40.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan hingga kini,\Ndarah masih terus mengalir.
Dialogue: 0,0:04:42.77,0:04:43.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:04:44.77,0:04:49.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}masa depan kita belum sampai\Npada titik putus asa.
Dialogue: 0,0:04:54.02,0:04:54.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:04:54.92,0:04:57.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}bagaimana kinerja iblis\Nyang bekerja sama dengan kita?
Dialogue: 0,0:04:57.92,0:05:01.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semoga dia bisa bertempur dengan\NKekaisaran hingga kedua pihak terluka.
Dialogue: 0,0:05:01.42,0:05:04.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentara Federal sedang\Ndalam pertempuran sengit.
Dialogue: 0,0:05:04.38,0:05:08.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para archmage yang dibersihkan\Ntampaknya telah kembali.
Dialogue: 0,0:05:08.03,0:05:11.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi saat ini tidak bisa\Nmemanfaatkan keunggulan jumlah.
Dialogue: 0,0:05:11.41,0:05:12.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oleh karena itu,
Dialogue: 0,0:05:12.64,0:05:15.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita manfaatkan saja\Nunit sukarelawan yang terkenal itu.
Dialogue: 0,0:05:16.10,0:05:18.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sambil menunjukkan kerja sama\Ndengan Federasi,
Dialogue: 0,0:05:18.74,0:05:23.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}juga bisa mendapatkan informasi\Nyang setara dengan kegiatan spionase.
Dialogue: 0,0:05:24.44,0:05:26.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benarkah tidak apa-apa?
Dialogue: 0,0:05:26.35,0:05:27.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:05:27.61,0:05:31.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengirim pasukan ke unit sukarelawan\Ntermasuk mengikuti arus.
Dialogue: 0,0:05:31.89,0:05:34.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Daripada bermusuhan\Ndengan Kerajaan Bersatu,
Dialogue: 0,0:05:34.42,0:05:37.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukankah lebih baik\Nmemanfaatkannya sebagai sekutu?
Dialogue: 0,0:05:37.30,0:05:39.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Strategi citra kita ke depan\Njuga sangat diperlukan.
Dialogue: 0,0:05:40.91,0:05:43.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untungnya,
Dialogue: 0,0:05:43.12,0:05:46.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita sedang berperang melawan\N"Kekaisaran", si musuh dunia.
Dialogue: 0,0:05:46.61,0:05:50.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita juga perlu menunjukkan sifat baik\NFederasi kita kepada dunia luar, 'kan?
Dialogue: 0,0:05:50.64,0:05:52.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan mencari\Norang yang tepat.
Dialogue: 0,0:05:52.76,0:05:53.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:05:53.65,0:05:57.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebaiknya pilih orang yang idealis\Ndan setia pada partai.
Dialogue: 0,0:05:57.65,0:06:00.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk archmage, kirimlah orang\Nyang berakhlak mulia.
Dialogue: 0,0:06:01.21,0:06:02.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:06:06.53,0:06:08.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, begitulah adanya.
Dialogue: 0,0:06:08.04,0:06:12.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katanya unit itu melihat\Nperi kecil itu, bukan?
Dialogue: 0,0:06:13.47,0:06:16.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan segera menangkapmu.
Dialogue: 0,0:06:18.89,0:06:19.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:06:20.68,0:06:23.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Atasan memberi kita persahabatan yang membosankan.
Dialogue: 0,0:06:33.59,0:06:35.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf membuat Anda menunggu.
Dialogue: 0,0:06:35.91,0:06:39.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku Lilya Ivanova Tanechka.
Dialogue: 0,0:06:39.08,0:06:42.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini archmage Federal, Kolonel Mikel.
Dialogue: 0,0:06:43.27,0:06:47.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku komisaris politik tingkat rendah,\Nsekaligus Letnan Tentara Federal.
Dialogue: 0,0:06:47.57,0:06:50.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan kata lain, seorang petugas politik\Nyang tidak berarti.
Dialogue: 0,0:06:50.91,0:06:54.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti aku akan cek kamus untuk arti\N"tidak berarti" dalam kosakata Federal.
Dialogue: 0,0:06:55.40,0:06:59.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku Letnan Kolonel Drake dari\NDivisi Terbang ke-42 Kerajaan Bersatu.
Dialogue: 0,0:07:00.31,0:07:03.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Salam kenal, Letnan Kolonel Drake.
Dialogue: 0,0:07:03.13,0:07:04.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebagai anggota partai,
Dialogue: 0,0:07:04.23,0:07:07.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku menyampaikan belasungkawa yang tulus\Natas pengorbanan yang kalian berikan.
Dialogue: 0,0:07:08.03,0:07:09.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:09.07,0:07:12.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan begitu, saudara-saudara yang gugur\Nmungkin sedikit terhibur.
Dialogue: 0,0:07:12.05,0:07:13.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:07:14.50,0:07:16.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah Anda petugas politik Federal?
Dialogue: 0,0:07:17.50,0:07:18.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Letnan Sue?
Dialogue: 0,0:07:19.53,0:07:21.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku Letnan Mary Sue.
Dialogue: 0,0:07:21.98,0:07:26.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kudengar petugas politik bersedia dengar\Ndan jawab keluhan kehidupan militer.
Dialogue: 0,0:07:27.17,0:07:30.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejujurnya, korban unit kami\Ndimakamkan di tanah ini.
Dialogue: 0,0:07:30.78,0:07:31.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Letnan.
Dialogue: 0,0:07:31.55,0:07:33.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita sudah membahas hal itu.
Dialogue: 0,0:07:33.54,0:07:35.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi tempat peristirahatan abadi\Nseharusnya di tanah air.
Dialogue: 0,0:07:36.50,0:07:38.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong pastikan mereka\Ndimakamkan di tanah air.
Dialogue: 0,0:07:39.61,0:07:42.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Merindukan tanah air adalah\Nhal yang wajar bagi siapa pun.
Dialogue: 0,0:07:42.95,0:07:44.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah begitu?
Dialogue: 0,0:07:46.41,0:07:49.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sangat memahami perasaanmu.
Dialogue: 0,0:07:49.54,0:07:52.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kau tidak keberatan,\Nizinkan aku membantu.
Dialogue: 0,0:07:53.17,0:07:55.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Be-benarkah?
Dialogue: 0,0:07:56.64,0:07:57.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Letnan Sue.
Dialogue: 0,0:07:57.92,0:08:00.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bolehkah aku memanggilmu Mary?
Dialogue: 0,0:08:00.06,0:08:01.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:08:01.40,0:08:02.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:08:03.09,0:08:05.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, panggil aku Lilya saja.
Dialogue: 0,0:08:05.40,0:08:08.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau bisa, maukah kau menjadi temanku?
Dialogue: 0,0:08:08.20,0:08:09.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, dengan senang hati.
Dialogue: 0,0:08:10.95,0:08:13.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku bantu siapkan formulir permohonannya.
Dialogue: 0,0:08:13.95,0:08:15.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik, mohon bantuannya.
Dialogue: 0,0:08:16.91,0:08:20.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat sekali letnan kalian bertindak.
Dialogue: 0,0:08:21.25,0:08:23.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya Anda juga cukup sibuk, Kolonel.
Dialogue: 0,0:08:25.60,0:08:28.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya, dia seperti itu\Nmasih tergolong baik.
Dialogue: 0,0:08:29.73,0:08:30.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti itu?
Dialogue: 0,0:08:30.96,0:08:32.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau bercanda?
Dialogue: 0,0:08:34.38,0:08:38.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebagai petugas politik negara kita,\Ngaya kerjanya bisa dibilang luar biasa.
Dialogue: 0,0:08:39.48,0:08:40.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:08:42.97,0:08:46.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak bisa membayangkan\Nkelak akan bagaimana.
Dialogue: 0,0:08:58.12,0:09:01.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Serangan pengintaian\Njuga semakin meningkat.
Dialogue: 0,0:09:02.52,0:09:07.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa semua tentara Federal sama,\Nmelakukan serangan sembrono seperti ini?
Dialogue: 0,0:09:09.41,0:09:11.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana hasil interogasi Polisi Militer?
Dialogue: 0,0:09:12.09,0:09:14.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya hampir sama.
Dialogue: 0,0:09:14.81,0:09:18.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Persis seperti slogan tetap\Npara penganut Komunisme.
Dialogue: 0,0:09:18.73,0:09:20.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar gaya Partai Komunis.
Dialogue: 0,0:09:20.79,0:09:24.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tampaknya ideologi luhur\Nyang mereka junjung tinggi itu
Dialogue: 0,0:09:24.13,0:09:26.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}sudah menyebar ke seluruh Federasi.
Dialogue: 0,0:09:26.71,0:09:30.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Letnan Kolonel benar-benar\Nmembenci Komunis.
Dialogue: 0,0:09:31.15,0:09:33.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu adalah prinsipku\Nsejak kehidupan sebelumnya.
Dialogue: 0,0:09:34.18,0:09:35.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Er,
Dialogue: 0,0:09:35.88,0:09:39.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku juga sudah membaca laporan itu.
Dialogue: 0,0:09:39.03,0:09:42.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi isinya terasa terlalu seragam\Ndan penuh prasangka.
Dialogue: 0,0:09:42.56,0:09:43.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:09:43.30,0:09:44.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:09:45.41,0:09:48.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sendiri juga ikut menginterogasi\Nbeberapa orang.
Dialogue: 0,0:09:48.82,0:09:50.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini catatan saat itu.
Dialogue: 0,0:09:51.40,0:09:52.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:09:52.77,0:09:57.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}keluarga Letnan itu keturunan Kekaisaran\Nyang dievakuasi dari Federasi saat revolusi, 'kan?
Dialogue: 0,0:09:57.98,0:10:00.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Keberadaan penutur asli Federasi\Nsangat membantu.
Dialogue: 0,0:10:02.94,0:10:07.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa semua orang selain komisaris politik,\Nmenunjukkan antipati terhadap Komunisme?
Dialogue: 0,0:10:07.70,0:10:08.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:08.77,0:10:10.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sesungguhnya,
Dialogue: 0,0:10:10.69,0:10:13.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}itu pernyataan yang menentang pimpinan.
Dialogue: 0,0:10:13.71,0:10:18.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya perasaan yang sebenarnya ini\Ndihilangkan dari laporan akhir.
Dialogue: 0,0:10:24.56,0:10:25.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Komandan.
Dialogue: 0,0:10:26.43,0:10:29.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau boleh, bisakah aku merokok?
Dialogue: 0,0:10:29.74,0:10:31.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku adalah archmage udara.
Dialogue: 0,0:10:32.23,0:10:34.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dilarang keras merokok.
Dialogue: 0,0:10:35.94,0:10:38.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Karena merokok merusak paru-paru.
Dialogue: 0,0:10:43.23,0:10:45.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi kau tidak punya korek api?
Dialogue: 0,0:10:45.94,0:10:46.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:46.98,0:10:48.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:10:48.87,0:10:51.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang Mayor WeiĆ,
Dialogue: 0,0:10:51.16,0:10:52.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}gerakannya sangat terampil.
Dialogue: 0,0:10:55.19,0:10:56.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Katakan padaku.
Dialogue: 0,0:10:57.03,0:10:58.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian... Salah.
Dialogue: 0,0:10:59.54,0:11:01.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk apa kau bertempur?
Dialogue: 0,0:11:01.48,0:11:02.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk apa bertempur?
Dialogue: 0,0:11:02.56,0:11:04.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa perlu ditanya lagi?
Dialogue: 0,0:11:04.01,0:11:05.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja demi diri sendiri.
Dialogue: 0,0:11:05.85,0:11:08.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertempur demi masa depan yang lebih baik.
Dialogue: 0,0:11:08.81,0:11:10.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masa depan yang lebih baik?
Dialogue: 0,0:11:10.35,0:11:12.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau bisa mengalahkan kalian,
Dialogue: 0,0:11:12.22,0:11:15.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}masyarakat kami pasti akan\Nsedikit membaik.
Dialogue: 0,0:11:16.56,0:11:18.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ganti pertanyaannya.
Dialogue: 0,0:11:18.34,0:11:22.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa kau memilih berperang\Nmelawan kami demi memperbaiki masyarakat?
Dialogue: 0,0:11:23.13,0:11:24.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah karena keyakinan pada Komunisme?
Dialogue: 0,0:11:26.04,0:11:28.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hampir sama dengan tingkat kepercayaan\Nkalian terhadap negara kalian.
Dialogue: 0,0:11:29.24,0:11:30.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}A-apa?
Dialogue: 0,0:11:30.60,0:11:33.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh jawaban yang cerdik.
Dialogue: 0,0:11:36.02,0:11:38.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, kau bodoh ya?
Dialogue: 0,0:11:38.18,0:11:38.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:11:39.49,0:11:41.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang tidak mencintai tanah air?
Dialogue: 0,0:11:42.60,0:11:43.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}A-apa?
Dialogue: 0,0:11:43.41,0:11:44.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau sama sekali tidak bisa memilih.
Dialogue: 0,0:11:45.71,0:11:46.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah begitu?
Dialogue: 0,0:11:48.10,0:11:49.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin memastikan.
Dialogue: 0,0:11:49.79,0:11:52.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, kau bertarung\Ndemi "tanah air", 'kan?
Dialogue: 0,0:11:54.19,0:11:57.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kudengar tentara Kekaisaran pintar-pintar,
Dialogue: 0,0:11:57.69,0:12:01.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi tak kusangka kau setara\Ndengan para komisaris politik itu.
Dialogue: 0,0:12:01.15,0:12:02.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, bocah!
Dialogue: 0,0:12:02.49,0:12:04.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertempur demi kampung halaman sendiri,
Dialogue: 0,0:12:04.52,0:12:06.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}apa perlu alasan?
Dialogue: 0,0:12:06.45,0:12:08.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selama kami berjasa dalam perang,
Dialogue: 0,0:12:08.94,0:12:11.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}para berengsek partai itu
Dialogue: 0,0:12:11.03,0:12:13.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}setidaknya akan mendengarkan\Nsedikit pendapat kami.
Dialogue: 0,0:12:23.92,0:12:26.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Siapa yang tidak mencintai tanah air?"
Dialogue: 0,0:12:26.52,0:12:27.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tadi dia berkata seperti ini, 'kan?
Dialogue: 0,0:12:28.44,0:12:29.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, benar.
Dialogue: 0,0:12:30.92,0:12:32.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajingan.
Dialogue: 0,0:12:32.68,0:12:35.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pantasan moral mereka begitu tinggi.
Dialogue: 0,0:12:35.68,0:12:36.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Let-Letnan Kolonel?
Dialogue: 0,0:12:36.90,0:12:38.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau masih belum mengerti?
Dialogue: 0,0:12:38.45,0:12:43.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita mengira berperang melawan Komunis,\Ntapi kenyataannya kita melawan nasionalis!
Dialogue: 0,0:12:45.09,0:12:46.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan cara saat ini,
Dialogue: 0,0:12:46.77,0:12:49.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}sama saja dengan membantu musuh.
Dialogue: 0,0:13:04.22,0:13:06.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang Mulia, aku terus terang saja.
Dialogue: 0,0:13:07.08,0:13:09.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita terlalu banyak membunuh.
Dialogue: 0,0:13:10.14,0:13:11.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini sungguh mengejutkan.
Dialogue: 0,0:13:12.22,0:13:16.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kukira perang total diukur\Ndari tumpukan mayat.
Dialogue: 0,0:13:17.22,0:13:19.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anda benar.
Dialogue: 0,0:13:19.07,0:13:23.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi jika bisa menghancurkan musuh\Ntanpa peluru, melainkan dengan kata-kata,
Dialogue: 0,0:13:23.55,0:13:25.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}biaya kata-kata lebih murah.
Dialogue: 0,0:13:25.67,0:13:28.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi saat ini tidak ada hasil.
Dialogue: 0,0:13:28.49,0:13:33.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Polisi Militer Lapangan sudah melakukan\Npropaganda anti-Komunis dan menenangkan,
Dialogue: 0,0:13:33.56,0:13:36.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi hasilnya menyedihkan.
Dialogue: 0,0:13:36.64,0:13:38.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, manfaatkan kesempatan ini,
Dialogue: 0,0:13:38.65,0:13:41.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}buang saja hal-hal seperti\Nserangan ideologis ke tempat sampah.
Dialogue: 0,0:13:42.88,0:13:43.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:43.90,0:13:45.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang penting bukanlah logika.
Dialogue: 0,0:13:45.59,0:13:49.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang Mulia, yang benar-benar penting\Nadalah "emosi" publik.
Dialogue: 0,0:13:50.63,0:13:52.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang disebut pekerjaan menenangkan,
Dialogue: 0,0:13:52.64,0:13:55.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukan mengurangi permusuhan mereka\Nterhadap kita,
Dialogue: 0,0:13:55.59,0:13:57.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}melainkan harus "memutuskan" mereka.
Dialogue: 0,0:13:58.54,0:14:01.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka mengangkat senjata
Dialogue: 0,0:14:01.33,0:14:04.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}bukan karena loyalitas pada partai,\Nmelainkan karena kerinduan pada tanah air.
Dialogue: 0,0:14:04.83,0:14:07.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, ini catatan interogasi.
Dialogue: 0,0:14:09.23,0:14:11.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Polisi Militer dicelakai oleh prasangka.
Dialogue: 0,0:14:12.86,0:14:15.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi aku sendiri juga terlalu\Nmembenci Partai Komunis,
Dialogue: 0,0:14:15.93,0:14:18.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}sehingga terjebak\Ndalam titik buta pemikiran.
Dialogue: 0,0:14:18.92,0:14:19.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:14:20.69,0:14:23.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dukungan mental musuh bukanlah ideologi,
Dialogue: 0,0:14:23.72,0:14:25.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}melainkan nasionalisme.
Dialogue: 0,0:14:25.33,0:14:26.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:14:26.63,0:14:30.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita hanya perlu memisahkan\NKomunis dari yang bukan.
Dialogue: 0,0:14:30.42,0:14:31.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Artinya,
Dialogue: 0,0:14:31.51,0:14:35.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}maksudmu lakukan "pecah belah dan kuasai"\Nterhadap nasionalisme Federal?
Dialogue: 0,0:14:35.92,0:14:38.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak. Jika ikut campur\Ndalam pemerintahan,
Dialogue: 0,0:14:38.00,0:14:40.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}institusi militer kemungkinan akan runtuh\Nkarena kelelahan.
Dialogue: 0,0:14:40.95,0:14:44.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang kita butuhkan adalah "teman unggul"
Dialogue: 0,0:14:44.68,0:14:46.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}yang bisa kita percayakan tugas.
Dialogue: 0,0:14:47.45,0:14:49.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pernyataan yang menarik.
Dialogue: 0,0:14:49.54,0:14:50.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi di usiaku ini,
Dialogue: 0,0:14:50.94,0:14:54.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}mendapat teman baru mungkin tidak mudah.
Dialogue: 0,0:14:54.30,0:14:55.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:14:55.68,0:14:58.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}dalam pepatah diplomatik ada satu kalimat,
Dialogue: 0,0:14:58.41,0:15:00.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}"musuh dari musuh adalah teman".
Dialogue: 0,0:15:01.20,0:15:04.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, sudahkah kau menemukan calonnya?
Dialogue: 0,0:15:04.55,0:15:05.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:15:06.39,0:15:10.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}"Majelis Nasional" di wilayah pendudukan\Ntimur adalah pilihan yang paling tepat.
Dialogue: 0,0:15:11.17,0:15:13.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika bekerja sama dengan mereka,
Dialogue: 0,0:15:13.10,0:15:15.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}seharusnya bisa menekan gerilyawan\Nyang mengganggu kita di timur.
Dialogue: 0,0:15:17.70,0:15:18.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang Mulia,
Dialogue: 0,0:15:18.82,0:15:21.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}kita mungkin bisa mendapatkan teman.
Dialogue: 0,0:15:28.15,0:15:30.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Konvoi pasokan lagi-lagi...
Dialogue: 0,0:15:30.08,0:15:31.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:31.12,0:15:32.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kudengar diserang...
Dialogue: 0,0:15:34.02,0:15:37.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang ini hanya bisa minum air\Nuntuk mengisi perut.
Dialogue: 0,0:15:37.30,0:15:38.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:15:38.69,0:15:40.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}kudengar ada beberapa tentara patroli\Nmati secara aneh...
Dialogue: 0,0:15:41.36,0:15:44.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada juga kabar sumur diracuni...
Dialogue: 0,0:15:50.40,0:15:52.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau minum...
Dialogue: 0,0:15:52.20,0:15:53.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:15:53.32,0:15:54.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terjadi sesuatu?
Dialogue: 0,0:15:54.96,0:15:56.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ti-tidak apa-apa.
Dialogue: 0,0:15:56.28,0:15:57.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:15:57.92,0:15:59.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk berjaga-jaga,\Naku katakan di awal dulu.
Dialogue: 0,0:15:59.85,0:16:03.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bertindak di area penerimaan\Nharus mematuhi hukum internasional.
Dialogue: 0,0:16:04.32,0:16:07.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bahkan jika terjadi insiden,\Nharus ditangani dengan baik.
Dialogue: 0,0:16:07.88,0:16:11.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dalam situasi seperti ini, harus mengambil\Ntindakan yang sama kek di negara sendiri?
Dialogue: 0,0:16:11.80,0:16:14.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejujurnya, kami sudah hampir tidak tahan.
Dialogue: 0,0:16:14.71,0:16:17.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengerti perasaan kalian.
Dialogue: 0,0:16:18.52,0:16:21.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tapi kekhawatiran seperti ini\Npasti akan segera hilang.
Dialogue: 0,0:17:00.23,0:17:01.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maka,
Dialogue: 0,0:17:01.69,0:17:03.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}aku, Letnan Jenderal Hans von Zettour,
Dialogue: 0,0:17:03.64,0:17:07.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}akan mewakili Kekaisaran untuk\Nmenyampaikan pidato kepada hadirin.
Dialogue: 0,0:17:08.72,0:17:11.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para pendengar yang kuhormati,
Dialogue: 0,0:17:11.40,0:17:15.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}harapan Kekaisaran sangat jelas,
Dialogue: 0,0:17:16.43,0:17:17.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}yaitu perdamaian.
Dialogue: 0,0:17:17.66,0:17:20.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku juga sama seperti kalian semua,
Dialogue: 0,0:17:20.54,0:17:24.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}hanya orang yang menginginkan\Nperdamaian bagi tanah air.
Dialogue: 0,0:17:25.81,0:17:28.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Perdamaian, perdamaian, perdamaian.
Dialogue: 0,0:17:29.03,0:17:32.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika bukan karena "Bandit Merah"\Nyang seperti setan itu,
Dialogue: 0,0:17:32.14,0:17:37.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}mana mungkin kami dan kalian\Nmengangkat senjata?
Dialogue: 0,0:17:38.06,0:17:42.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita hanya terpaksa berperang\Ndemi melindungi tanah air.
Dialogue: 0,0:17:43.01,0:17:46.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku berjanji, pada hari perdamaian,\Nkita pasti akan meletakkan senjata,
Dialogue: 0,0:17:46.83,0:17:50.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}kembali ke kampung halaman yang tercinta.
Dialogue: 0,0:17:50.62,0:17:55.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sama sekali tidak berniat\Nmencaplok wilayah pendudukan.
Dialogue: 0,0:17:55.38,0:17:57.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku hanya sangat mendambakan
Dialogue: 0,0:17:57.22,0:18:02.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}hidup berdampingan sama orang yang punya\Nwilayah, kedaulatan dan kemerdekaan.
Dialogue: 0,0:18:03.45,0:18:06.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang tidak mencintai tanah air?
Dialogue: 0,0:18:06.96,0:18:10.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang tidak mencintai\Nkampung halamannya?
Dialogue: 0,0:18:10.34,0:18:11.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sini, aku mohon kepada kalian semua,
Dialogue: 0,0:18:12.56,0:18:15.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}mari kita menjadi sahabat.
Dialogue: 0,0:18:16.27,0:18:19.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seperti Horatius yang menjaga jembatan,
Dialogue: 0,0:18:19.20,0:18:23.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}izinkan kami berjalan berdampingan\Ndengan kalian.
Dialogue: 0,0:18:24.42,0:18:29.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar yang dikatakan, "Orang baik sejati,\Nmalah merupakan anggota organisasi jahat"?
Dialogue: 0,0:18:30.72,0:18:35.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pada hari ini, saat ini, aku\Nmewakili Tentara Kekaisaran,
Dialogue: 0,0:18:41.69,0:18:46.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}menyatakan pengalihan\Nyurisdiksi wilayah militer ke unit sipil.
Dialogue: 0,0:18:53.45,0:18:54.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semoga Kekaisaran
Dialogue: 0,0:18:55.24,0:19:00.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan masa depan para sahabat semua\Ndipenuhi cahaya terang.
Dialogue: 0,0:19:02.58,0:19:03.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:19:03.91,0:19:06.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang ini benar-benar penipu ulung.
Dialogue: 0,0:19:06.32,0:19:11.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Neraka pasti sudah menyiapkan\Ntempat khusus untuk Yang Mulia.
Dialogue: 0,0:19:14.37,0:19:16.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersulang untuk pertemuan sama teman baru.
Dialogue: 0,0:19:16.65,0:19:17.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersulang untuk pertemuan sama teman baru.
Dialogue: 0,0:19:17.08,0:19:20.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersulang untuk kerja sama militer\Nyang gemilang antara kedua negara.
Dialogue: 0,0:19:20.12,0:19:22.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Untuk menunjukkan persahabatan kita\Nkepada Kekaisaran,
Dialogue: 0,0:19:22.92,0:19:25.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}harap dirikan front kedua.
Dialogue: 0,0:19:25.29,0:19:28.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tentu saja, tapi negara kami
Dialogue: 0,0:19:28.54,0:19:30.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}sedang dalam pertempuran sengit\Nperang udara besar...
Dialogue: 0,0:19:31.83,0:19:33.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekretaris Jenderal,
Dialogue: 0,0:19:33.12,0:19:34.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}ada masalah.
Dialogue: 0,0:19:35.34,0:19:37.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kekaisaran bekerja sama dengan orang lain.
Dialogue: 0,0:19:37.65,0:19:41.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka berdamai dengan kaum nasionalis.
Dialogue: 0,0:19:41.31,0:19:45.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mulai dirikan pemerintahan sementara\Ndi wilayah pendudukan Tentara Kekaisaran,
Dialogue: 0,0:19:45.23,0:19:47.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}dan mengurus proses penyerahan\Nurusan sipil.
Dialogue: 0,0:19:49.40,0:19:52.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Musuh dunia itu, Kekaisaran itu,
Dialogue: 0,0:19:52.70,0:19:54.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}berhasil mendapat teman!
Dialogue: 0,0:20:00.17,0:20:01.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berkat Yang Mulia,
Dialogue: 0,0:20:01.89,0:20:05.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}umur Kekaisaran mungkin bisa\Nsedikit diperpanjang.
Dialogue: 0,0:20:10.81,0:20:15.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya, semoga bisa jalin pertemanan\Nsama yang berguna untuk mengakhiri perang.
Dialogue: 0,0:20:15.01,0:20:16.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, Letnan Kolonel.
Dialogue: 0,0:20:16.41,0:20:19.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Oh ya, ada kopi dalam daftar pasokan.
Dialogue: 0,0:20:20.20,0:20:21.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa? Benarkah?
Dialogue: 0,0:20:21.79,0:20:22.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:20:22.54,0:20:24.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meskipun jenis yang paling biasa.
Dialogue: 0,0:20:24.44,0:20:26.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat seperti ini, tidak ada\Nyang perlu dipilih.
Dialogue: 0,0:20:27.13,0:20:29.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kafein!
Dialogue: 0,0:20:29.97,0:20:30.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah.
Dialogue: 0,0:20:30.76,0:20:32.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Inilah yang disebut\N"beri aku lebih banyak cahaya".
Dialogue: 0,0:20:32.81,0:20:35.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan menyiapkan kopi
Dialogue: 0,0:20:35.00,0:20:36.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}sehitam iblis,
Dialogue: 0,0:20:36.55,0:20:38.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}sepanas neraka,
Dialogue: 0,0:20:38.28,0:20:41.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}semurni malaikat, dan semanis cinta.
Dialogue: 0,0:20:43.52,0:20:45.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tolong buatkan.
Dialogue: 0,0:20:49.16,0:20:50.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,
Dialogue: 0,0:20:50.23,0:20:53.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}kali ini juga berkat ajudan yang hebat.
Dialogue: 0,0:20:53.80,0:20:56.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meski kami bersama sejak Front Rhein,
Dialogue: 0,0:20:56.69,0:20:59.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}tapi sekarang menyebutnya teman\Nmalah membuatku merasa tidak pantas.
Dialogue: 0,0:21:00.25,0:21:03.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain dia, yang bisa disebut\Nteman lama...
Dialogue: 0,0:21:05.48,0:21:07.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ja-jangan bercanda!
Dialogue: 0,0:21:07.20,0:21:09.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa yang mau dengan orang sepertimu?
Dialogue: 0,0:21:09.21,0:21:12.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Letnan, apa maksudnya boneka aneh itu?
Dialogue: 0,0:21:12.09,0:21:14.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ditemukan di rumah warga yang diterima.
Dialogue: 0,0:21:14.40,0:21:15.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menurutku lumayan lucu, jadi...
Dialogue: 0,0:21:15.84,0:21:16.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buang!
Dialogue: 0,0:21:16.73,0:21:18.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buang sekarang juga!
Dialogue: 0,0:21:23.51,0:21:27.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mendirikan dewan otonom\Ndi wilayah Federasi ya?
Dialogue: 0,0:21:27.37,0:21:31.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tampaknya sekutu kita benar-benar\Nperwujudan rasionalitas negara.
Dialogue: 0,0:21:31.58,0:21:32.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu,
Dialogue: 0,0:21:32.70,0:21:37.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}mereka pasti mau mendengarkan apa\Nyang dikatakan teman-teman mereka, 'kan?
Dialogue: 0,0:23:11.82,0:23:12.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Er,
Dialogue: 0,0:23:12.88,0:23:16.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}apakah Letnan Kolonel juga akan hadir\Nsaat menginterogasi tawanan?
Dialogue: 0,0:23:16.46,0:23:17.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sungguh mengejutkan.
Dialogue: 0,0:23:17.96,0:23:20.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tak kusangka bahkan letnan senior pun\Nberkata seperti itu.
Dialogue: 0,0:23:20.11,0:23:21.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat aku.
Dialogue: 0,0:23:22.32,0:23:23.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:23:23.08,0:23:25.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat aku!
Dialogue: 0,0:23:25.00,0:23:26.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Penampilanku ini mudah diremehkan, 'kan?
Dialogue: 0,0:23:27.31,0:23:29.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa kau ingin aku terus\Nmenatap tawanan dari bawah?
Dialogue: 0,0:23:29.44,0:23:31.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini bukan menjemput anak hilang.
Dialogue: 0,0:23:31.88,0:23:33.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ma-maafkan aku.
Dialogue: 0,0:23:33.76,0:23:35.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku siapkan kursi anak.
Dialogue: 0,0:23:35.93,0:23:37.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak perlu!
Dialogue: 0,0:23:37.52,0:23:40.04,sign,,0,0,0,,{\blur3}{\fad(00,40)}(Episode Berikutnya:\NPerantara yang Baik Hati)
