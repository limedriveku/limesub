Dialogue: 0,0:20:05.01,0:20:05.85,sign,,0000,0000,0000,,"LEGA"
Dialogue: 0,0:20:08.92,0:20:09.75,sign,,0000,0000,0000,,"ENGGAK TAHU HARUS BERSIKAP APA"
Dialogue: 0,0:20:30.27,0:20:32.51,sign,,0000,0000,0000,,"UKURAN COWOK - BUKAN PUNYA AYAH"
Dialogue: 0,0:20:55.30,0:20:56.43,sign,,0000,0000,0000,,"TING…"
