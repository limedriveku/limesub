Dialogue: 0,0:14:03.46,0:14:04.30,sign,,0000,0000,0000,,KAGET
Dialogue: 0,0:14:59.06,0:15:00.77,sign,,0000,0000,0000,,OLEH-OLEHNYA ENGGAK COCOK, YA?
Dialogue: 0,0:15:36.56,0:15:37.98,sign,,0000,0000,0000,,MALU BANGET KALAU ADA\NYANG LIHAT FOTO BERDUA INI
Dialogue: 0,0:15:38.93,0:15:40.73,sign,,0000,0000,0000,,"RAMEN"
Dialogue: 0,0:16:00.66,0:16:02.29,sign,,0000,0000,0000,,"SERU BANGET"
