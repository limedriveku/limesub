Dialogue: 0,0:11:54.13,0:11:56.71,sign,,0000,0000,0000,,"KUNJUNGAN KUIL TAHUN BARU"
Dialogue: 0,0:12:46.85,0:12:48.76,sign,,0000,0000,0000,,ITU ENGGAK BENAR, TAPI...
Dialogue: 0,0:12:48.85,0:12:52.77,sign,,0000,0000,0000,,"AKU BUTUH WAKTU BUAT SIAP-SIAP MENTAL"
Dialogue: 0,0:13:24.55,0:13:27.14,sign,,0000,0000,0000,,"KAGET"
