Dialogue: 0,0:19:29.96,0:19:30.83,sign,,0000,0000,0000,,PERUNTUNGAN BAIK
Dialogue: 0,0:19:30.92,0:19:31.83,sign,,0000,0000,0000,,"AKADEMIK: BELAJAR DENGAN PIKIRAN TENANG"
Dialogue: 0,0:19:32.25,0:19:34.00,sign,,0000,0000,0000,,PERUNTUNGAN KECIL - HUBUNGAN: BERSABAR
Dialogue: 0,0:19:34.59,0:19:36.34,sign,,0000,0000,0000,,PERUNTUNGAN KECIL - KEINGINAN:\NJANGAN TERPENGARUH ORANG LAIN
Dialogue: 0,0:19:36.88,0:19:39.30,sign,,0000,0000,0000,,PERUNTUNGAN KECIL - AKADEMIS:\NTERLALU BANYAK GANGGUAN. BELAJAR YANG GIAT
Dialogue: 0,0:19:39.80,0:19:42.14,sign,,0000,0000,0000,,"PERUNTUNGAN SEDANG - CINTA: BERI CINTA"
Dialogue: 0,0:19:42.97,0:19:44.68,sign,,0000,0000,0000,,"PERUNTUNGAN BESAR - SENGKETA: MENANG"
Dialogue: 0,0:19:46.89,0:19:48.56,sign,,0000,0000,0000,,PERUNTUNGAN BESAR - CINTA:\NJANGAN TERBURU-BURU
Dialogue: 0,0:19:56.78,0:19:58.15,sign,,0000,0000,0000,,"NYENGIR"
Dialogue: 0,0:20:45.20,0:20:47.78,sign,,0000,0000,0000,,HENING...
Dialogue: 0,0:21:37.08,0:21:38.46,sign,,0000,0000,0000,,"KECUALI KENDARAAN RINGAN"
Dialogue: 0,0:21:47.64,0:21:48.55,sign,,0000,0000,0000,,LIBURAN, BAJU SANTAI,\NCUMA KITA BERDUA
Dialogue: 0,0:21:48.64,0:21:49.56,sign,,0000,0000,0000,,"KALAU ADA ORANG DARI KAMPUNG HALAMANKU\NLIHAT KITA..."
Dialogue: 0,0:21:49.64,0:21:50.89,sign,,0000,0000,0000,,"SITUASI AZUMA"
Dialogue: 0,0:22:30.26,0:22:32.68,sign,,0000,0000,0000,,TERSEDU-SEDU - TERTAWA KERAS
Dialogue: 0,0:22:33.72,0:22:35.77,sign,,0000,0000,0000,,"NABE DAN YAMADA BAIK-BAIK SAJA"
Dialogue: 0,0:00:02.71,0:00:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ayo pergi ke suatu tempat\Nmusim dingin ini."
Dialogue: 0,0:00:06.13,0:00:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah,
Dialogue: 0,0:00:07.38,0:00:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini hari terakhir tahun ini, Yusuke.
Dialogue: 0,0:00:10.80,0:00:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak terasa, ya...
Dialogue: 0,0:00:12.22,0:00:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, cepat banget rasanya.
Dialogue: 0,0:00:14.30,0:00:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ketemu tanpa rencana.\NMau ngapain, nih?
Dialogue: 0,0:00:17.55,0:00:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma pengin ketemu kamu,\Njadi terserah saja.
Dialogue: 0,0:00:21.10,0:00:22.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:00:23.27,0:00:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal dulu kita enggak saling kenal
Dialogue: 0,0:00:26.27,0:00:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di awal tahun.
Dialogue: 0,0:00:28.52,0:00:29.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh juga, ya?
Dialogue: 0,0:00:30.19,0:00:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita nyaris enggak ngobrol\Nsampai akhirnya duduk sebangku.
Dialogue: 0,0:00:34.03,0:00:36.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dulu aku sering mencuri pandang.
Dialogue: 0,0:00:36.78,0:00:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf soal itu.
Dialogue: 0,0:00:38.33,0:00:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar tahun\Nyang enggak akan terlupakan.
Dialogue: 0,0:00:42.79,0:00:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa begitu.
Dialogue: 0,0:00:44.00,0:00:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan sempat kepikiran,\Nkalau nanti beli mobil,
Dialogue: 0,0:00:46.50,0:00:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau pakai angka tahun ini\Nbuat pelat nomornya.
Dialogue: 0,0:00:51.13,0:00:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku enggak kepikiran sampai situ.
Dialogue: 0,0:00:53.34,0:00:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa, kok.
Dialogue: 0,0:00:55.38,0:00:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebahagiaan ajaib dari cinta bertepuk\Nsebelah tangan yang akhirnya berbuah manis
Dialogue: 0,0:00:58.89,0:01:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cuma bisa dimengerti\Noleh orang yang menyatakan cinta duluan.
Dialogue: 0,0:01:01.39,0:01:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Logika macam apa itu?
Dialogue: 0,0:01:03.49,0:01:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan enggak tahu\Nsiapa yang naksir duluan.
Dialogue: 0,0:01:06.44,0:01:08.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:01:08.98,0:01:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kuberi tahu,
Dialogue: 0,0:01:11.57,0:01:13.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sejak pertama kali aku minta kontakmu,
Dialogue: 0,0:01:13.82,0:01:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sudah suka sama kamu.
Dialogue: 0,0:01:19.03,0:01:20.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kan?
Dialogue: 0,0:01:20.70,0:01:22.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku,
Dialogue: 0,0:01:22.74,0:01:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku baru mau foto pas momennya pas.
Dialogue: 0,0:01:26.17,0:01:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti itu benar.
Dialogue: 0,0:01:28.46,0:01:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,
Dialogue: 0,0:01:31.88,0:01:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu jatuh cinta sama aku itu kapan, Yusuke?
Dialogue: 0,0:01:38.01,0:01:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukamu merah banget.
Dialogue: 0,0:01:40.72,0:01:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya...
Dialogue: 0,0:01:44.22,0:01:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan, ya?
Dialogue: 0,0:01:54.32,0:01:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:01:58.11,0:01:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:01:59.20,0:02:00.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya aku enggak ingat.
Dialogue: 0,0:02:01.49,0:02:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada jeda antara saat aku\Nsadar punya perasaan ini
Dialogue: 0,0:02:03.54,0:02:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan saat, kalau diingat-ingat lagi,\Nternyata aku sudah jatuh cinta sama kamu.
Dialogue: 0,0:02:07.62,0:02:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku berubah pelan-pelan,
Dialogue: 0,0:02:10.96,0:02:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku enggak bisa menentukan\Ntepatnya kapan.
Dialogue: 0,0:02:13.92,0:02:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Detail banget! Aku suka!
Dialogue: 0,0:02:20.05,0:02:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak sabar cukup dewasa\Nbuat bisa keluar sampai malam.
Dialogue: 0,0:02:24.56,0:02:25.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengin ke tempat hitung mundur,
Dialogue: 0,0:02:25.85,0:02:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}teriak-teriak, terus ke kuil.
Dialogue: 0,0:02:28.60,0:02:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau ke sana tahun depan?
Dialogue: 0,0:02:32.02,0:02:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi nanti usiaku baru 17 tahun.
Dialogue: 0,0:02:35.11,0:02:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:02:37.28,0:02:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pergi ke kuil
Dialogue: 0,0:02:38.49,0:02:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bareng keluarga besar tiap Tahun Baru?
Dialogue: 0,0:02:40.91,0:02:44.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepupuku datang tiap Tahun Baru.
Dialogue: 0,0:02:44.24,0:02:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku selalu di rumah saja.
Dialogue: 0,0:02:48.46,0:02:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu aku berangkat tadi,\Norang tuaku bilang,
Dialogue: 0,0:02:52.13,0:02:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sampaikan salam buat Tani, ya."
Dialogue: 0,0:02:54.59,0:02:56.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sampaikan juga selamat Tahun Baru."
Dialogue: 0,0:02:58.80,0:03:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, sampai ketemu lagi tahun depan.
Dialogue: 0,0:03:02.72,0:03:03.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru.
Dialogue: 0,0:03:05.47,0:03:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru!
Dialogue: 0,0:03:11.10,0:03:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpacaran,
Dialogue: 0,0:03:13.06,0:03:14.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saling mengenal,
Dialogue: 0,0:03:14.98,0:03:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diterima,
Dialogue: 0,0:03:17.03,0:03:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menerima.
Dialogue: 0,0:03:20.82,0:03:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibanding awal dulu,
Dialogue: 0,0:03:24.70,0:03:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku lebih suka keadaan sekarang.
Dialogue: 0,0:03:42.18,0:03:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}You and I Are Polar Opposites Season 2
Dialogue: 0,0:04:57.79,0:05:00.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata Kayoko, mereka enggak bisa datang besok.
Dialogue: 0,0:05:01.59,0:05:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:05:02.55,0:05:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya
Dialogue: 0,0:05:03.51,0:05:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka kena flu di TK.
Dialogue: 0,0:05:04.47,0:05:06.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit bergiliran semua.
Dialogue: 0,0:05:06.51,0:05:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:05:07.76,0:05:08.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:05:09.35,0:05:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang banget, tapi mau gimana lagi.
Dialogue: 0,0:05:17.48,0:05:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya pacar.
Dialogue: 0,0:05:19.77,0:05:21.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku ajak dia?
Dialogue: 0,0:05:27.41,0:05:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau komedi, yang penting timing-nya.
Dialogue: 0,0:05:30.49,0:05:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada yang kayak begitu.
Dialogue: 0,0:05:32.45,0:05:35.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka cowok yang bawa bola dunia.
Dialogue: 0,0:05:38.63,0:05:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku angkat dulu, ya.
Dialogue: 0,0:05:45.47,0:05:46.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:05:46.72,0:05:47.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki.
Dialogue: 0,0:05:48.47,0:05:49.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Suzuki"?
Dialogue: 0,0:05:51.35,0:05:52.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal besok...
Dialogue: 0,0:05:52.89,0:05:55.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katamu sepupumu mau datang, kan?
Dialogue: 0,0:05:55.48,0:05:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka enggak bisa datang.
Dialogue: 0,0:05:57.73,0:05:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu mau jalan-jalan?
Dialogue: 0,0:06:00.11,0:06:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ke rumahku?
Dialogue: 0,0:06:02.90,0:06:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok tiba-tiba?
Dialogue: 0,0:06:04.90,0:06:06.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, cuma...
Dialogue: 0,0:06:08.07,0:06:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tiba-tiba pengin cerita ke keluargaku.
Dialogue: 0,0:06:16.91,0:06:18.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat banget!
Dialogue: 0,0:06:19.88,0:06:21.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, gantungan kunci dan jimat beruang
Dialogue: 0,0:06:21.88,0:06:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di tempat pensilmu itu,
Dialogue: 0,0:06:23.05,0:06:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama syal baru
Dialogue: 0,0:06:24.05,0:06:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sarung tangan yang baru kamu beli...
Dialogue: 0,0:06:25.13,0:06:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu semua gara-gara punya pacar, ya?
Dialogue: 0,0:06:27.09,0:06:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok Ibu bisa tahu semua itu?
Dialogue: 0,0:06:29.76,0:06:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama Ibu enggak lihat dia.\NIbu enggak sabar.
Dialogue: 0,0:06:43.98,0:06:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru!
Dialogue: 0,0:06:47.11,0:06:48.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun...
Dialogue: 0,0:06:48.95,0:06:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa dengan rambutmu?
Dialogue: 0,0:06:52.95,0:06:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh, ya?
Dialogue: 0,0:06:54.74,0:06:57.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak aneh. Cuma kaget saja.
Dialogue: 0,0:06:57.79,0:07:01.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu. Syukurlah.
Dialogue: 0,0:07:05.25,0:07:08.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak usah terlalu gugup.
Dialogue: 0,0:07:09.93,0:07:10.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu dengar, enggak?
Dialogue: 0,0:07:10.97,0:07:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku telat.
Dialogue: 0,0:07:13.10,0:07:15.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, jangan dipikirkan.
Dialogue: 0,0:07:15.72,0:07:16.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:07:20.19,0:07:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya gugup,
Dialogue: 0,0:07:23.11,0:07:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia lebih kayak enggak fokus?
Dialogue: 0,0:07:26.90,0:07:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang!
Dialogue: 0,0:07:28.90,0:07:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama enggak ketemu.
Dialogue: 0,0:07:30.61,0:07:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru!
Dialogue: 0,0:07:32.78,0:07:34.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini aku lagi mimpi, ya?
Dialogue: 0,0:07:37.49,0:07:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu, selamat datang...
Dialogue: 0,0:07:44.84,0:07:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku sempat terdiam.
Dialogue: 0,0:07:46.50,0:07:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu.\NTerima kasih sudah menjaga Yusuke.
Dialogue: 0,0:07:49.97,0:07:54.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali enggak. Dia yang jaga aku.
Dialogue: 0,0:07:54.51,0:07:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jeda apa itu tadi?
Dialogue: 0,0:07:56.39,0:07:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, masuk.
Dialogue: 0,0:07:58.10,0:07:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima...
Dialogue: 0,0:08:04.56,0:08:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak apa-apa?
Dialogue: 0,0:08:06.65,0:08:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak apa-apa...
Dialogue: 0,0:08:12.07,0:08:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sedikit oleh-oleh buat kalian.
Dialogue: 0,0:08:15.53,0:08:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini manisan. Selamat Tahun Baru.
Dialogue: 0,0:08:20.70,0:08:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih perhatiannya.
Dialogue: 0,0:08:24.42,0:08:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ucapkan "Selamat Tahun Baru"\Ndi saat yang aneh banget.
Dialogue: 0,0:08:29.88,0:08:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, harus gimana, nih?
Dialogue: 0,0:08:31.76,0:08:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatan enggak nyaman banget.
Dialogue: 0,0:08:34.47,0:08:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha?
Dialogue: 0,0:08:35.72,0:08:38.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku duduk?
Dialogue: 0,0:08:38.14,0:08:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu bantu, enggak?
Dialogue: 0,0:08:39.64,0:08:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa. Santai saja.
Dialogue: 0,0:08:42.60,0:08:45.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yusuke, boleh aku duduk di kursi lipat?
Dialogue: 0,0:08:45.65,0:08:47.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku duduk di kursi lipat saja!
Dialogue: 0,0:08:47.65,0:08:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak boleh. Kamu tamu kami.
Dialogue: 0,0:08:49.82,0:08:50.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:08:51.36,0:08:54.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu, kamu mau berapa potong moci di supmu?
Dialogue: 0,0:08:54.20,0:08:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami banyak stoknya,
Dialogue: 0,0:08:55.11,0:08:56.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi Ibu senang\Nkalau kamu makan yang banyak.
Dialogue: 0,0:08:56.91,0:08:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, dua...
Dialogue: 0,0:08:58.66,0:09:00.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, tiga saja!
Dialogue: 0,0:09:00.79,0:09:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yu yang bikin moci ini.
Dialogue: 0,0:09:02.91,0:09:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, aku cuma bantu bentuk-bentuk saja.
Dialogue: 0,0:09:05.71,0:09:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat makan.
Dialogue: 0,0:09:07.88,0:09:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini enak banget.
Dialogue: 0,0:09:09.88,0:09:12.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berasa banget suasana Tahun Barunya.
Dialogue: 0,0:09:14.42,0:09:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku...
Dialogue: 0,0:09:16.05,0:09:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sampai numbuk moci sendiri
Dialogue: 0,0:09:17.72,0:09:20.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bikin hidangan Tahun Baru dari nol.
Dialogue: 0,0:09:20.14,0:09:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku santai banget soal ini.
Dialogue: 0,0:09:22.64,0:09:24.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya menurutku ini keren.
Dialogue: 0,0:09:24.64,0:09:26.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:09:26.23,0:09:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami selalu begini,
Dialogue: 0,0:09:28.15,0:09:29.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi rasanya biasa saja buat kami.
Dialogue: 0,0:09:30.07,0:09:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak malu juga, nih.
Dialogue: 0,0:09:34.28,0:09:35.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimana rencana kunjungan kuil\NTahun Baru hari ini?
Dialogue: 0,0:09:35.95,0:09:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian pergi berdua saja?
Dialogue: 0,0:09:37.20,0:09:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu rencananya.
Dialogue: 0,0:09:39.28,0:09:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kuil di dekat sini.
Dialogue: 0,0:09:41.08,0:09:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke sana tiap tahun.
Dialogue: 0,0:09:42.54,0:09:43.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi bareng.
Dialogue: 0,0:09:44.33,0:09:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:09:48.29,0:09:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, setelah makan siang,
Dialogue: 0,0:09:50.17,0:09:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku ke kuil bareng sepupuku buat Tahun Baru.
Dialogue: 0,0:09:53.26,0:09:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tradisi.
Dialogue: 0,0:09:58.84,0:10:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:10:02.39,0:10:03.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak apa-apa, kan?
Dialogue: 0,0:10:04.93,0:10:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ajak kamu\Nkarena memang mau kamu ada di sini.
Dialogue: 0,0:10:07.19,0:10:10.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini bikin kamu enggak nyaman\Natau tertekan, aku...
Dialogue: 0,0:10:10.77,0:10:12.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf...
Dialogue: 0,0:10:20.78,0:10:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah nahan-nahan ini.
Dialogue: 0,0:10:25.16,0:10:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau ketemu orang tua Tani?
Dialogue: 0,0:10:27.50,0:10:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa, ya, kalau ada\Ndari keluarga kita yang ketemu mereka?
Dialogue: 0,0:10:29.88,0:10:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yakin orang tuanya ramah banget.
Dialogue: 0,0:10:32.13,0:10:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, ya?
Dialogue: 0,0:10:34.00,0:10:36.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, pas kamu pergi besok,
Dialogue: 0,0:10:36.13,0:10:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}beli sekotak manisan buat dibawa, ya.
Dialogue: 0,0:10:38.51,0:10:39.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, warna rambut ini
Dialogue: 0,0:10:40.01,0:10:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagus, enggak, ya?
Dialogue: 0,0:10:43.06,0:10:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, rambutku jadi kelewat terang!
Dialogue: 0,0:10:45.72,0:10:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak diamkan catnya cukup lama.
Dialogue: 0,0:10:48.02,0:10:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pakai rok panjang saja\Nbiar kelihatan agak lebih sopan.
Dialogue: 0,0:10:52.44,0:10:53.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekotak manisan...
Dialogue: 0,0:10:56.11,0:10:58.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus cari toko lain!
Dialogue: 0,0:10:59.03,0:11:00.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:11:16.92,0:11:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa tiba-tiba jadi sopan.
Dialogue: 0,0:11:21.34,0:11:24.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal-hal kecil yang dilakukan tiap hari\Njustru yang paling penting.
Dialogue: 0,0:11:24.85,0:11:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku enggak berguna banget.
Dialogue: 0,0:11:28.10,0:11:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku jadi nangis.\NIni pasti bikin kaget, ya?
Dialogue: 0,0:11:32.44,0:11:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa. Kamu baik-baik saja?
Dialogue: 0,0:11:35.40,0:11:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baik-baik saja.
Dialogue: 0,0:11:36.53,0:11:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf sudah bikin kamu khawatir.
Dialogue: 0,0:11:38.44,0:11:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan salahmu.
Dialogue: 0,0:11:40.99,0:11:43.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini urusanku sendiri.
Dialogue: 0,0:11:43.91,0:11:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi tetap saja, enggak apa-apa.
Dialogue: 0,0:11:45.66,0:11:48.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang mengganggumu, kasih tahu aku.
Dialogue: 0,0:11:48.41,0:11:51.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang pernah kamu bilang\Nwaktu aku bilang hal yang sama.
Dialogue: 0,0:11:54.13,0:11:56.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelet dan enggak peka...
Dialogue: 0,0:11:56.80,0:11:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan baru sekarang, kok.
Dialogue: 0,0:12:00.09,0:12:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah bikin kesalahan kecil\Nsejak pagi ini.
Dialogue: 0,0:12:03.09,0:12:05.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghancurkan manisan itu puncaknya.
Dialogue: 0,0:12:05.80,0:12:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:12:08.22,0:12:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak sengaja bilang\Nini berasa kayak Tahun Baru.
Dialogue: 0,0:12:10.93,0:12:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka bakal mikir\Naku enggak punya sopan santun?
Dialogue: 0,0:12:13.06,0:12:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, gini...
Dialogue: 0,0:12:14.56,0:12:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kumulai dengan bilang ini dulu.
Dialogue: 0,0:12:16.44,0:12:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku enggak seketat itu, kok.
Dialogue: 0,0:12:19.15,0:12:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kamu enggak perlu merasa\Nharus jaga tata krama banget.
Dialogue: 0,0:12:21.82,0:12:23.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:12:23.20,0:12:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beneran?
Dialogue: 0,0:12:26.33,0:12:29.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kok reaksinya begitu?
Dialogue: 0,0:12:30.79,0:12:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih perhatiannya.
Dialogue: 0,0:12:34.63,0:12:37.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kerja keras dan kecemasanmu hari ini
Dialogue: 0,0:12:37.63,0:12:40.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu semua salahku.
Dialogue: 0,0:12:40.21,0:12:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai aku enggak bilang ini ke kamu,\Nsemua ini enggak bakal terjadi.
Dialogue: 0,0:12:43.51,0:12:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:12:44.43,0:12:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu enggak benar...
Dialogue: 0,0:12:48.85,0:12:52.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tiba-tiba banget dan bikin takut.
Dialogue: 0,0:12:53.31,0:12:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kenapa tiba-tiba?
Dialogue: 0,0:12:56.56,0:12:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bahkan baru bilang ke mereka\Nkita pacaran.
Dialogue: 0,0:13:02.15,0:13:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gini...
Dialogue: 0,0:13:04.07,0:13:08.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kita ketemu kemarin, aku pulang,\Nterus pas ngobrol sama keluargaku,
Dialogue: 0,0:13:08.99,0:13:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiba-tiba aku kepikiran kamu.
Dialogue: 0,0:13:11.87,0:13:16.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma berharap kamu juga ada di sana.
Dialogue: 0,0:13:19.42,0:13:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:13:21.76,0:13:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kedengarannya kayak lamaran.
Dialogue: 0,0:13:24.55,0:13:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu termasuk jawaban, enggak?
Dialogue: 0,0:13:27.47,0:13:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap tenang. Jangan panik.
Dialogue: 0,0:13:32.10,0:13:33.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang.
Dialogue: 0,0:13:33.18,0:13:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:13:34.56,0:13:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu, mau lihat album foto Yusuke?
Dialogue: 0,0:13:37.44,0:13:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau!
Dialogue: 0,0:13:38.48,0:13:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:13:41.19,0:13:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisan yang kamu bawa enak banget.
Dialogue: 0,0:13:44.61,0:13:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, manisannya sampai hancur.
Dialogue: 0,0:13:48.32,0:13:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu, kamu bisa minum kopi?
Dialogue: 0,0:13:50.33,0:13:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa, terima kasih.
Dialogue: 0,0:13:53.37,0:13:54.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beneran bisa minum itu?
Dialogue: 0,0:13:54.29,0:13:55.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:13:55.21,0:13:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan berarti aku enggak bisa minum.
Dialogue: 0,0:13:57.79,0:13:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau gula atau susu?
Dialogue: 0,0:13:59.75,0:14:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh.
Dialogue: 0,0:14:01.63,0:14:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, kan?
Dialogue: 0,0:14:02.55,0:14:03.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Miyu.
Dialogue: 0,0:14:04.80,0:14:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia enggak pernah ngomong\Ndengan jelas, ya, kan?
Dialogue: 0,0:14:07.59,0:14:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pernah nyakitin kamu?
Dialogue: 0,0:14:09.68,0:14:12.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada keluhan,\Nsekarang saat yang tepat buat bilang.
Dialogue: 0,0:14:12.31,0:14:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bikin dia\Nmenjelek-jelekkan aku di depanku.
Dialogue: 0,0:14:14.64,0:14:16.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa gunanya kalau di belakangmu saja?
Dialogue: 0,0:14:18.77,0:14:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa, dia enggak pernah.
Dialogue: 0,0:14:21.52,0:14:22.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beneran?
Dialogue: 0,0:14:23.90,0:14:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:14:25.24,0:14:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:27.78,0:14:31.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan banget kalian ibu-anak.
Dialogue: 0,0:14:33.54,0:14:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gemas banget!
Dialogue: 0,0:14:34.91,0:14:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak disangka dia\Npernah ada fase pose kayak gini.
Dialogue: 0,0:14:37.92,0:14:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul.
Dialogue: 0,0:14:39.42,0:14:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya baru kemarin dia sekecil ini.
Dialogue: 0,0:14:43.84,0:14:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatan senang banget\Ndi foto museum ini.
Dialogue: 0,0:14:47.17,0:14:50.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu lebih suka buku referensi\Ndaripada kereta.
Dialogue: 0,0:14:50.22,0:14:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak gabung sama mereka?
Dialogue: 0,0:14:51.76,0:14:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak ikut dulu.
Dialogue: 0,0:14:53.93,0:14:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah undang aku.
Dialogue: 0,0:14:56.68,0:14:58.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak usah bawa oleh-oleh lagi lain kali.
Dialogue: 0,0:15:01.15,0:15:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang apa adanya saja sudah cukup.
Dialogue: 0,0:15:05.86,0:15:07.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak usah sekaku itu.
Dialogue: 0,0:15:08.82,0:15:09.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:15:10.82,0:15:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak fotogenik, ya?
Dialogue: 0,0:15:14.87,0:15:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa tiba-tiba ngomong begitu?
Dialogue: 0,0:15:17.37,0:15:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lihat foto grup\Ndari karyawisata sekolah.
Dialogue: 0,0:15:20.92,0:15:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku sampai enggak mengenalkan kamu.
Dialogue: 0,0:15:22.79,0:15:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresimu canggung banget.
Dialogue: 0,0:15:25.25,0:15:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jauh lebih kelihatan bagus\Nkalau senyum langsung ke kamera.
Dialogue: 0,0:15:31.22,0:15:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada foto yang lebih bagus?
Dialogue: 0,0:15:33.76,0:15:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toh kita bakal ketemu juga,\Njadi enggak penting.
Dialogue: 0,0:15:35.43,0:15:36.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, ini penting!
Dialogue: 0,0:15:38.93,0:15:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu, ya.
Dialogue: 0,0:15:41.02,0:15:42.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus hari ini.
Dialogue: 0,0:15:42.52,0:15:44.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa kamu kerja sejak Tahun Baru?
Dialogue: 0,0:15:45.02,0:15:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak apa-apa.
Dialogue: 0,0:15:47.11,0:15:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, aku cuma pengin\Ncepat-cepat umur 18 tahun.
Dialogue: 0,0:15:49.78,0:15:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar bisa ambil sif tengah malam.
Dialogue: 0,0:15:51.95,0:15:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa, memangnya?
Dialogue: 0,0:15:53.28,0:15:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya hampir semua pekerja paruh waktu\Ndi sini mahasiswa atau pekerja lepas.
Dialogue: 0,0:15:56.41,0:15:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku terus yang harus pulang lebih awal.
Dialogue: 0,0:15:59.25,0:16:00.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pengin ikut tutup toko
Dialogue: 0,0:16:00.66,0:16:02.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ngobrol-ngobrol setelah tutup,
Dialogue: 0,0:16:02.37,0:16:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau lihat pemandangan malam di gunung
Dialogue: 0,0:16:04.08,0:16:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bareng-bareng sepulang kerja.
Dialogue: 0,0:16:05.46,0:16:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya seru banget\Npas mereka cerita. Aku jadi iri.
Dialogue: 0,0:16:08.42,0:16:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak usah iri-iri, deh.
Dialogue: 0,0:16:11.05,0:16:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pergi ke mana saja kapan saja...
Dialogue: 0,0:16:13.14,0:16:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebebasan kayak begitu justru bikin aku iri.
Dialogue: 0,0:16:14.93,0:16:17.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya, kelihatannya dari mata anak SMA?
Dialogue: 0,0:16:18.35,0:16:20.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak pergi sama teman-temanmu?
Dialogue: 0,0:16:21.10,0:16:23.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mau ke kuil Tahun Baru\Ndi hari terakhir liburan musim dingin.
Dialogue: 0,0:16:23.81,0:16:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya kami mau berangkat besok,
Dialogue: 0,0:16:26.52,0:16:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi salah satu teman\Nsedang di rumah neneknya sekarang.
Dialogue: 0,0:16:28.40,0:16:30.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sepakat pergi setelah dia balik,
Dialogue: 0,0:16:30.99,0:16:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus kami juga mengajak beberapa cowok\Nyang dekat sama kami.
Dialogue: 0,0:16:32.78,0:16:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu jadwal semua orang pas...
Dialogue: 0,0:16:35.03,0:16:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kebanyakan ngomong, ya?
Dialogue: 0,0:16:36.95,0:16:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya
Dialogue: 0,0:16:38.16,0:16:41.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu menikmati banget kehidupan sekolahmu.
Dialogue: 0,0:16:41.25,0:16:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:16:42.25,0:16:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu aku gimana?
Dialogue: 0,0:16:45.46,0:16:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azu!
Dialogue: 0,0:16:46.67,0:16:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru!
Dialogue: 0,0:16:47.96,0:16:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru!
Dialogue: 0,0:16:49.21,0:16:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat Tahun Baru!
Dialogue: 0,0:16:50.21,0:16:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nabe, kamu sudah pulang, ya.
Dialogue: 0,0:16:51.67,0:16:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:16:52.63,0:16:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, kamu ganti penampilan?
Dialogue: 0,0:16:54.76,0:16:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, warnanya sudah hampir pudar sih.
Dialogue: 0,0:16:58.35,0:17:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita, dong, kenapa kamu mewarnainya.
Dialogue: 0,0:17:00.85,0:17:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ceritanya?
Dialogue: 0,0:17:02.02,0:17:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei,
Dialogue: 0,0:17:02.94,0:17:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita ketemuan di sini, deh?
Dialogue: 0,0:17:05.31,0:17:06.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira Enggak Kerja.
Dialogue: 0,0:17:06.73,0:17:07.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira Tahun Baru.
Dialogue: 0,0:17:07.73,0:17:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan asal ngomong apa yang kepikiran.
Dialogue: 0,0:17:10.31,0:17:12.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:17:12.40,0:17:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berasa kayak karyawisata.
Dialogue: 0,0:17:14.56,0:17:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya semua orang sudah pergi\Nke kuil Tahun Baru.
Dialogue: 0,0:17:17.20,0:17:18.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengin ke kuil\Nyang belum pernah aku kunjungi.
Dialogue: 0,0:17:18.99,0:17:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kami pilih yang agak jauh dari sini.
Dialogue: 0,0:17:21.95,0:17:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, capek juga, ya,\Nberangkat kerja dari rumah pas liburan?
Dialogue: 0,0:17:26.25,0:17:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaket militer itu bagus banget.
Dialogue: 0,0:17:28.38,0:17:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merek apa itu?
Dialogue: 0,0:17:29.29,0:17:31.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fokus satu topik dulu, dong.
Dialogue: 0,0:17:32.09,0:17:33.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:33.59,0:17:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Habis, sudah lama enggak ketemu\Nteman-teman sekelas,
Dialogue: 0,0:17:35.18,0:17:37.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku agak heboh sendiri.
Dialogue: 0,0:17:37.55,0:17:39.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka fesyen, ya?
Dialogue: 0,0:17:39.64,0:17:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu topik yang kamu pilih?
Dialogue: 0,0:17:42.72,0:17:45.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kalau kamu\Nke kuil Tahun Baru lebih dari sekali,
Dialogue: 0,0:17:45.81,0:17:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu sudah bukan "baru" lagi, dong?
Dialogue: 0,0:17:47.40,0:17:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gini...
Dialogue: 0,0:17:48.61,0:17:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya,
Dialogue: 0,0:17:49.57,0:17:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu boleh pergi sesering yang kamu mau.
Dialogue: 0,0:17:52.28,0:17:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, kamu mengeluh lagi?
Dialogue: 0,0:17:55.24,0:17:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak lagi mengeluh. Awas langkahmu.
Dialogue: 0,0:17:57.82,0:17:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, kok malah kamu yang tersandung?
Dialogue: 0,0:17:59.87,0:18:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuzuki, kamu enggak apa-apa?
Dialogue: 0,0:18:04.04,0:18:05.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ragu-ragu, nih?
Dialogue: 0,0:18:06.29,0:18:07.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:18:08.88,0:18:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti menggoda!
Dialogue: 0,0:18:10.04,0:18:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, sih, sama kamu?
Dialogue: 0,0:18:13.88,0:18:15.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di atas sana.
Dialogue: 0,0:18:21.14,0:18:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:18:24.98,0:18:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangganya panjang banget.
Dialogue: 0,0:18:26.94,0:18:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama enggak ke sini.
Dialogue: 0,0:18:28.90,0:18:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trauma karena dulu dipaksa lari di sini\Nbuat kegiatan klub SMP...
Dialogue: 0,0:18:32.27,0:18:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada orang di sini.
Dialogue: 0,0:18:33.90,0:18:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah tanggal 5 Januari, sih.
Dialogue: 0,0:18:35.40,0:18:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan soal tanggalnya, tapi lokasinya.
Dialogue: 0,0:18:37.78,0:18:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Liburan musim dingin hampir habis.
Dialogue: 0,0:18:40.87,0:18:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada, PR-mu sudah dikerjakan?
Dialogue: 0,0:18:43.29,0:18:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman.
Dialogue: 0,0:18:44.58,0:18:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aman? Kamu?
Dialogue: 0,0:18:46.12,0:18:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok reaksinya begitu?
Dialogue: 0,0:18:50.17,0:18:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai puncak!
Dialogue: 0,0:18:54.51,0:18:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Capek juga.
Dialogue: 0,0:18:55.84,0:18:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke.
Dialogue: 0,0:18:56.84,0:18:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kita sudah sampai gerbangnya,
Dialogue: 0,0:19:01.72,0:19:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ayo lempar batu ke gerbang torii.
Dialogue: 0,0:19:03.47,0:19:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Buat apa?\N- Enggak mau lempar?
Dialogue: 0,0:19:05.72,0:19:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang begitu
Dialogue: 0,0:19:07.35,0:19:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di kampung nenekku.
Dialogue: 0,0:19:08.69,0:19:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada begituan di sini!
Dialogue: 0,0:19:10.77,0:19:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nbiar aku yang bawa budaya itu ke sini.
Dialogue: 0,0:19:14.36,0:19:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan memaksa gitu, dong!
Dialogue: 0,0:19:17.07,0:19:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nabe lucu banget.
Dialogue: 0,0:19:18.57,0:19:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini emang ada-ada saja.
Dialogue: 0,0:19:26.58,0:19:27.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama banget.
Dialogue: 0,0:19:27.96,0:19:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:19:30.92,0:19:31.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bagus.
Dialogue: 0,0:19:39.80,0:19:42.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap!
Dialogue: 0,0:19:42.97,0:19:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang menang kalau ada sengketa.
Dialogue: 0,0:19:44.76,0:19:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:19:45.68,0:19:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lagi rencana apa, sih?
Dialogue: 0,0:19:48.93,0:19:53.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada, kamu tipe orang\Nyang peduli soal ramalan begini, enggak?
Dialogue: 0,0:19:53.44,0:19:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sih selalu
Dialogue: 0,0:19:55.48,0:19:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}percaya sama itu.
Dialogue: 0,0:19:56.78,0:19:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki, berhenti menatapku.
Dialogue: 0,0:20:02.78,0:20:05.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak disangka\Npemandangan dari sini sebagus ini.
Dialogue: 0,0:20:06.79,0:20:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok kamu bisa hafal banget daerah sini?
Dialogue: 0,0:20:09.00,0:20:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku sering ke kuil ini.
Dialogue: 0,0:20:11.08,0:20:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau masuk sedikit lebih dalam\Nke pegunungan,
Dialogue: 0,0:20:12.54,0:20:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada air terjun, kuil misterius,
Dialogue: 0,0:20:13.96,0:20:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama kuil seram dengan dekorasi aneh.
Dialogue: 0,0:20:16.71,0:20:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik juga.
Dialogue: 0,0:20:17.92,0:20:20.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kamu pergi sama siapa?
Dialogue: 0,0:20:20.42,0:20:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian.
Dialogue: 0,0:20:21.34,0:20:22.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian?
Dialogue: 0,0:20:23.09,0:20:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun.
Dialogue: 0,0:20:25.18,0:20:26.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu emang jago banget\Ncari kesenangan sendiri.
Dialogue: 0,0:20:27.18,0:20:28.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Azuma, kamu mau ke sana?
Dialogue: 0,0:20:28.47,0:20:29.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:20:29.68,0:20:32.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang kedinginan.\NMendingan pergi pas musim panas.
Dialogue: 0,0:20:32.27,0:20:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau ikut!
Dialogue: 0,0:20:34.06,0:20:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:20:35.23,0:20:37.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begini, ya, rasanya jadi\Nsegerombolan orang naik skuter
Dialogue: 0,0:20:37.90,0:20:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lewat pegunungan?
Dialogue: 0,0:20:40.32,0:20:41.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musim panas...
Dialogue: 0,0:20:42.57,0:20:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus belajar buat ujian masuk...
Dialogue: 0,0:20:48.04,0:20:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:20:49.33,0:20:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anak klub bisbol SMA juga tetap lanjut\Nsampai musim panas, kan.
Dialogue: 0,0:20:51.96,0:20:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bukan anak klub bisbol.
Dialogue: 0,0:20:54.08,0:20:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap saja,
Dialogue: 0,0:20:55.54,0:20:58.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enggak apa-apa, kan,\Nmemikirkan hal yang seru buat sekarang.
Dialogue: 0,0:20:59.38,0:21:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:21:01.17,0:21:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semoga kita bisa habiskan waktu\Nbersama tanpa penyesalan.
Dialogue: 0,0:21:06.55,0:21:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani!
Dialogue: 0,0:21:08.10,0:21:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak disangka kamu bisa\Nbilang begitu dengan wajah datar.
Dialogue: 0,0:21:10.97,0:21:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak disangka bakal dengar\Nkata-kata sesemangat itu dari kamu.
Dialogue: 0,0:21:14.39,0:21:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Seaneh itu, ya?
Dialogue: 0,0:21:16.44,0:21:18.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kaget juga,\Ntapi reaksi mereka lebai banget
Dialogue: 0,0:21:19.07,0:21:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sampai bikin momenku hilang.
Dialogue: 0,0:21:20.48,0:21:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, itu dia.
Dialogue: 0,0:21:21.82,0:21:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan silangkan tanganmu di belakang kami.
Dialogue: 0,0:21:26.20,0:21:28.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga jalan pulangnya bakal begini.
Dialogue: 0,0:21:29.08,0:21:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku iri banget sama Nabe.
Dialogue: 0,0:21:32.16,0:21:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar-benar bebas.
Dialogue: 0,0:21:33.33,0:21:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jago banget cari kesenangan sendiri.
Dialogue: 0,0:21:37.08,0:21:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kagum sama itu,
Dialogue: 0,0:21:38.54,0:21:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kayaknya aku tipe orang yang lebih suka\Nmelakukan sesuatu bareng orang lain.
Dialogue: 0,0:21:42.80,0:21:45.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggal satu semester lagi\Nsebelum kelas kita diacak ulang.
Dialogue: 0,0:21:49.64,0:21:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:21:51.22,0:21:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama enggak ketemu\Nteman-teman sekelasku.
Dialogue: 0,0:21:53.73,0:21:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini masih liburan musim dingin.
Dialogue: 0,0:21:57.98,0:21:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:58.94,0:22:00.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, enggak apa-apa.
Dialogue: 0,0:22:00.94,0:22:03.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benaran enggak mau kelas kita diacak.
Dialogue: 0,0:22:03.86,0:22:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:22:04.78,0:22:05.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:22:05.99,0:22:06.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku beli minuman?
Dialogue: 0,0:22:07.07,0:22:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau minuman panas.
Dialogue: 0,0:22:09.91,0:22:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo suten. Yang kalah traktir.
Dialogue: 0,0:22:12.45,0:22:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sok-sokan kayak pernah melakukan itu.
Dialogue: 0,0:22:14.33,0:22:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergaulan macam apa yang begitu?
Dialogue: 0,0:22:17.58,0:22:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang,
Dialogue: 0,0:22:19.67,0:22:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan pikiran masing-masing,
Dialogue: 0,0:22:22.75,0:22:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menyambut tahun baru.
Dialogue: 0,0:22:28.43,0:22:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:22:33.72,0:22:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah pegal-pegal...
