Dialogue: 0,0:17:50.86,0:17:51.94,sign,,0000,0000,0000,,ENGGAK ADA BATAS KUNJUNGAN KUIL TAHUN BARU\NBOLEH BERKALI-KALI
Dialogue: 0,0:18:04.04,0:18:05.75,sign,,0000,0000,0000,,"NYENGIR"
Dialogue: 0,0:18:08.88,0:18:09.96,sign,,0000,0000,0000,,"CEMBURU - PASTI SERU NIH"
