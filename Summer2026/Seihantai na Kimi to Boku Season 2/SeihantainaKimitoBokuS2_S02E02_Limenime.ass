Dialogue: 0,0:00:02.79,0:00:04.42,sign,,0000,0000,0000,,"KUE DISKON 50 PERSEN"
Dialogue: 0,0:00:08.00,0:00:10.46,sign,,0000,0000,0000,,TAIRA
Dialogue: 0,0:00:11.72,0:00:14.38,sign,,0000,0000,0000,,"POPURI"
Dialogue: 0,0:00:41.33,0:00:42.83,sign,,0000,0000,0000,,"PESAN KUE SEKALIGUS AYAM PANGGANG"
Dialogue: 0,0:00:42.91,0:00:44.54,sign,,0000,0000,0000,,"DAN HEMAT LEBIH BANYAK!"
Dialogue: 0,0:01:18.95,0:01:20.66,sign,,0000,0000,0000,,"TEMAN SMP, AZUMA"
Dialogue: 0,0:01:26.04,0:01:28.21,sign,,0000,0000,0000,,"SMP"
Dialogue: 0,0:01:29.84,0:01:31.75,sign,,0000,0000,0000,,"BERBISIK"
Dialogue: 0,0:02:02.78,0:02:03.95,sign,,0000,0000,0000,,KAMU DI SINI?
Dialogue: 0,0:02:04.04,0:02:06.00,sign,,0000,0000,0000,,AKU BARU TURUN DARI PERON
Dialogue: 0,0:02:26.06,0:02:27.39,sign,,0000,0000,0000,,TINGGI: 750 YEN
Dialogue: 0,0:02:27.48,0:02:28.69,sign,,0000,0000,0000,,TINGGI: 750 YEN - KAGET
Dialogue: 0,0:02:29.23,0:02:30.44,sign,,0000,0000,0000,,"MANGKUK DAGING SAPI: 600 YEN"
Dialogue: 0,0:02:30.52,0:02:31.69,sign,,0000,0000,0000,,MINUMAN LEBIH MAHAL DARIPADA MAKANAN?
Dialogue: 0,0:03:43.30,0:03:44.89,sign,,0000,0000,0000,,"TINGGI: 750 YEN - KAGET"
Dialogue: 0,0:03:44.97,0:03:46.31,sign,,0000,0000,0000,,"MANGKUK DAGING SAPI: 600 YEN"
Dialogue: 0,0:03:46.39,0:03:48.06,sign,,0000,0000,0000,,"MINUMAN LEBIH MAHAL DARIPADA MAKANAN?"
Dialogue: 0,0:03:48.68,0:03:50.98,sign,,0000,0000,0000,,"BERBISIK"
Dialogue: 0,0:05:44.17,0:05:50.47,sign,,0000,0000,0000,,POPURI
Dialogue: 0,0:05:52.10,0:05:54.22,sign,,0000,0000,0000,,INI DIA!
Dialogue: 0,0:05:59.23,0:06:03.98,sign,,0000,0000,0000,,"SYUKURLAH..."
Dialogue: 0,0:08:20.87,0:08:22.96,sign,,0000,0000,0000,,"SELESAI"
Dialogue: 0,0:09:26.60,0:09:29.36,sign,,0000,0000,0000,,"AOI"
Dialogue: 0,0:10:21.83,0:10:23.83,sign,,0000,0000,0000,,"SENANG, KESAL, AGAK KESEPIAN..."
Dialogue: 0,0:10:34.05,0:10:35.17,sign,,0000,0000,0000,,"OMONG-OMONG, SEBELUMNYA..."
Dialogue: 0,0:10:47.85,0:10:49.98,sign,,0000,0000,0000,,"JANGAN HARAP AKU MENGEJEK SEMUANYA"
Dialogue: 0,0:10:54.98,0:10:55.82,sign,,0000,0000,0000,,KAGET
Dialogue: 0,0:10:56.07,0:10:57.49,sign,,0000,0000,0000,,TEPAT SASARAN
Dialogue: 0,0:11:02.03,0:11:03.95,sign,,0000,0000,0000,,YUSUKE TANI: 2 PESAN BARU
Dialogue: 0,0:11:05.24,0:11:07.04,sign,,0000,0000,0000,,TERTAWA KECIL...
Dialogue: 0,0:11:07.12,0:11:08.96,sign,,0000,0000,0000,,MORIMO
Dialogue: 0,0:11:17.42,0:11:18.26,sign,,0000,0000,0000,,KYORYU CRASH!
Dialogue: 0,0:11:43.74,0:11:45.58,sign,,0000,0000,0000,,TERTAWA SANGAT KERAS
Dialogue: 0,0:11:45.66,0:11:47.08,sign,,0000,0000,0000,,MORIMO LUAR BIASA
Dialogue: 0,0:11:47.16,0:11:49.25,sign,,0000,0000,0000,,HEHE...
Dialogue: 0,0:11:51.21,0:11:53.17,sign,,0000,0000,0000,,DENGAN SATO
Dialogue: 0,0:12:14.77,0:12:17.15,sign,,0000,0000,0000,,"FESTIVAL OLAHRAGA TAHUN KEDUA SMA"
Dialogue: 0,0:12:26.66,0:12:28.95,sign,,0000,0000,0000,,MEREKA BELUM BERPACARAN
Dialogue: 0,0:12:40.30,0:12:41.80,sign,,0000,0000,0000,,KERJA BAGUS HARI INI!
Dialogue: 0,0:12:49.97,0:12:51.64,sign,,0000,0000,0000,,"HEI, KAUS HARI INI"
Dialogue: 0,0:12:51.73,0:12:53.52,sign,,0000,0000,0000,,"ADA NASI KEPAL DI ATASNYA!"
Dialogue: 0,0:12:54.52,0:12:55.90,sign,,0000,0000,0000,,"KANTIN MULAI MENYAJIKAN"
Dialogue: 0,0:12:55.98,0:12:59.07,sign,,0000,0000,0000,,"MI DINGIN TIONGKOK!"
Dialogue: 0,0:12:59.82,0:13:01.24,sign,,0000,0000,0000,,KAMU TAHU TUGAS MATEMATIKA YANG MANA?
Dialogue: 0,0:13:01.32,0:13:02.69,sign,,0000,0000,0000,,"AKU LUPA MENCATATNYA"
Dialogue: 0,0:13:02.78,0:13:04.70,sign,,0000,0000,0000,,"HALAMAN 40 SAMPAI 45"
Dialogue: 0,0:13:04.78,0:13:05.95,sign,,0000,0000,0000,,"CEPAT SEKALI"
Dialogue: 0,0:13:06.03,0:13:07.49,sign,,0000,0000,0000,,TERIMA KASIH
Dialogue: 0,0:13:09.03,0:13:09.95,sign,,0000,0000,0000,,SEEKOR KUCING
Dialogue: 0,0:13:11.58,0:13:13.21,sign,,0000,0000,0000,,MANIS SEKALI.
Dialogue: 0,0:15:06.24,0:15:10.28,sign,,0000,0000,0000,,"KUNYAH..."
Dialogue: 0,0:15:32.80,0:15:34.14,sign,,0000,0000,0000,,"SELAMAT NATAL!"
Dialogue: 0,0:15:40.98,0:15:41.90,sign,,0000,0000,0000,,HORE
Dialogue: 0,0:15:41.98,0:15:43.40,sign,,0000,0000,0000,,STIKER INI MANIS SEKALI,\NAKU HARUS MENDAPATKANNYA...
Dialogue: 0,0:16:30.28,0:16:31.78,sign,,0000,0000,0000,,"TIDAK MENYIMAK"
Dialogue: 0,0:16:31.86,0:16:33.49,sign,,0000,0000,0000,,"TIDAK MENYIMAK"
Dialogue: 0,0:16:33.57,0:16:35.57,sign,,0000,0000,0000,,AYO MENARI!
Dialogue: 0,0:16:43.62,0:16:47.09,sign,,0000,0000,0000,,"NAIK MOTOR SAJA"
Dialogue: 0,0:16:50.88,0:16:53.13,sign,,0000,0000,0000,,MEREKA BERDUA MENGOBROL DAN NONGKRONG BARENG
Dialogue: 0,0:16:53.22,0:16:54.26,sign,,0000,0000,0000,,DAN MEREKA MASIH BERKOMUNIKASI
Dialogue: 0,0:16:54.34,0:16:56.05,sign,,0000,0000,0000,,"ARTINYA SEMUANYA LANCAR"
Dialogue: 0,0:17:32.71,0:17:33.55,sign,,0000,0000,0000,,MAU MENGERJAKANNYA BARENG?\NMAU!
Dialogue: 0,0:17:33.63,0:17:34.63,sign,,0000,0000,0000,,MAU UNTUK!\NKATA "UNTUK" ITU TIDAK PERLU
Dialogue: 0,0:17:34.72,0:17:35.72,sign,,0000,0000,0000,,SANTAI SAJA\NKAPAN KAMU SENGGANG?
Dialogue: 0,0:17:35.80,0:17:36.68,sign,,0000,0000,0000,,NISHI TELAH MEMBATALKAN PESAN
Dialogue: 0,0:17:36.76,0:17:39.43,sign,,0000,0000,0000,,PERPUSTAKAAN PUSAT KOMUNITAS
Dialogue: 0,0:17:40.35,0:17:41.47,sign,,0000,0000,0000,,PLETOK...
Dialogue: 0,0:17:53.86,0:17:56.11,sign,,0000,0000,0000,,"MENATAP"
Dialogue: 0,0:17:59.12,0:18:00.28,sign,,0000,0000,0000,,MENGINTIP - BERBALIK
Dialogue: 0,0:18:22.60,0:18:24.31,sign,,0000,0000,0000,,"PERPUSTAKAAN PUSAT KOMUNITAS"
Dialogue: 0,0:18:32.32,0:18:34.90,sign,,0000,0000,0000,,"PERPUSTAKAAN, RUANG BELAJAR, RUANG BEBAS"
Dialogue: 0,0:18:59.26,0:19:00.72,sign,,0000,0000,0000,,"BELAJAR DI KAMARMU!"
Dialogue: 0,0:19:02.97,0:19:04.52,sign,,0000,0000,0000,,"HUH..."
Dialogue: 0,0:19:16.07,0:19:16.94,sign,,0000,0000,0000,,"HEHE..."
Dialogue: 0,0:19:41.72,0:19:42.72,sign,,0000,0000,0000,,HM?
Dialogue: 0,0:19:46.85,0:19:47.68,sign,,0000,0000,0000,,KAGET
Dialogue: 0,0:21:17.52,0:21:19.36,sign,,0000,0000,0000,,"MELAMBAIKAN TANGAN"
Dialogue: 0,0:22:24.97,0:22:26.01,sign,,0000,0000,0000,,PLETOK...
Dialogue: 0,0:00:02.79,0:00:04.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggal 25 Desember.
Dialogue: 0,0:00:04.50,0:00:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada malam
Dialogue: 0,0:00:06.96,0:00:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Natal...
Dialogue: 0,0:00:11.72,0:00:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kue sisa di toserba
Dialogue: 0,0:00:14.47,0:00:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang jadi tempat langganan sopir truk\Nkarena tempat parkirnya yang luas...
Dialogue: 0,0:00:19.10,0:00:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang mau beli?
Dialogue: 0,0:00:21.43,0:00:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kenapa kamu bilang begitu?
Dialogue: 0,0:00:25.23,0:00:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, mereka jual kue, lo.
Dialogue: 0,0:00:27.11,0:00:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kita baru saja makan?
Dialogue: 0,0:00:28.27,0:00:29.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau makan berapa banyak, sih?
Dialogue: 0,0:00:29.86,0:00:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya masalah?
Dialogue: 0,0:00:33.15,0:00:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diledek.
Dialogue: 0,0:00:37.37,0:00:40.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lagi enggak sibuk bekerja,
Dialogue: 0,0:00:41.33,0:00:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku selalu berakhir
Dialogue: 0,0:00:42.91,0:00:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berpikir yang enggak-enggak.
Dialogue: 0,0:00:47.08,0:00:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tahun pertamaku masuk SMA...
Dialogue: 0,0:00:49.55,0:00:51.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira.
Dialogue: 0,0:00:52.17,0:00:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menatap ke sini.
Dialogue: 0,0:00:54.01,0:00:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mereka memanggilku?
Dialogue: 0,0:00:56.13,0:00:58.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak kebingungan.
Dialogue: 0,0:00:59.30,0:01:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, banyak yang bilang kamu tampan, ya?
Dialogue: 0,0:01:02.68,0:01:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan? Kamu tinggi dan tampan.
Dialogue: 0,0:01:07.81,0:01:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:01:13.78,0:01:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak sama sekali.
Dialogue: 0,0:01:15.82,0:01:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kumohon jangan.
Dialogue: 0,0:01:18.03,0:01:18.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara Azuma
Dialogue: 0,0:01:18.95,0:01:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengar.
Dialogue: 0,0:01:21.08,0:01:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga.
Dialogue: 0,0:01:22.12,0:01:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tersipu, lo. Manisnya.
Dialogue: 0,0:01:24.00,0:01:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:01:26.04,0:01:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kursiku.
Dialogue: 0,0:01:28.29,0:01:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan.
Dialogue: 0,0:01:29.84,0:01:31.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia berusaha menyapa kita.
Dialogue: 0,0:01:31.84,0:01:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, baca situasi sedikit.
Dialogue: 0,0:01:33.88,0:01:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itulah nasibku saat SMP.
Dialogue: 0,0:01:37.09,0:01:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya rencanaku mengubah citra di SMA\Nenggak akan berjalan mulus.
Dialogue: 0,0:01:42.89,0:01:45.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau aku takut dengan penilaian Azuma...
Dialogue: 0,0:01:48.73,0:01:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tengah kebingunganku,
Dialogue: 0,0:01:50.77,0:01:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}diperlakukan berbeda dari sebelumnya
Dialogue: 0,0:01:54.03,0:01:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku mulai percaya itu nyata.
Dialogue: 0,0:02:17.34,0:02:18.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang.
Dialogue: 0,0:02:18.93,0:02:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pesan apa?
Dialogue: 0,0:02:20.26,0:02:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kali pertamaku datang ke tempat begini.
Dialogue: 0,0:02:22.68,0:02:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau pesan apa?
Dialogue: 0,0:02:23.85,0:02:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:02:29.23,0:02:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahal sekali...
Dialogue: 0,0:02:36.36,0:02:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf ya, Taira.
Dialogue: 0,0:02:38.11,0:02:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata sifat aslimu\Nenggak seperti bayanganku.
Dialogue: 0,0:02:42.28,0:02:45.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau penampilanku sedikit berubah,
Dialogue: 0,0:02:45.24,0:02:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hati dan sifatku tetap sama seperti dulu.
Dialogue: 0,0:02:48.37,0:02:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mungkin semuanya\Nbisa berjalan mulus semudah itu.
Dialogue: 0,0:02:52.08,0:02:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama beberapa waktu, bisikan para gadis
Dialogue: 0,0:02:54.55,0:02:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kebanyakan tertuju padaku.
Dialogue: 0,0:02:57.09,0:02:59.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa antara kamu\Ndengan Lengan Tiga Perempat?
Dialogue: 0,0:02:59.13,0:03:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, jangan ungkit masa laluku\Nyang memalukan.
Dialogue: 0,0:03:02.14,0:03:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lengan Tiga Perempat?
Dialogue: 0,0:03:03.76,0:03:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata selama ini mereka menjulukiku\N"Lengan Tiga Perempat".
Dialogue: 0,0:03:06.89,0:03:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru menyadarinya kemudian...
Dialogue: 0,0:03:09.27,0:03:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru saja berpapasan\Ndengan kakak kelas itu di lorong!
Dialogue: 0,0:03:13.06,0:03:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beruntungnya!
Dialogue: 0,0:03:14.27,0:03:15.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa enggak kamu sapa saja?
Dialogue: 0,0:03:15.90,0:03:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak bisa. Aku terlalu gugup.
Dialogue: 0,0:03:18.90,0:03:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia menganggapku menyebalkan,\Nlebih baik aku mati saja.
Dialogue: 0,0:03:21.36,0:03:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan yang mereka tunjukkan padaku
Dialogue: 0,0:03:24.91,0:03:28.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah rasa suka\Nyang memedulikan perasaanku.
Dialogue: 0,0:03:29.45,0:03:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sesuatu yang jauh lebih dangkal.
Dialogue: 0,0:03:33.13,0:03:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak saat itu,
Dialogue: 0,0:03:34.96,0:03:39.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap kali teringat aku memercayai\Nomongan mereka dan jadi sombong,
Dialogue: 0,0:03:39.84,0:03:42.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap kali teringat betapa noraknya diriku,
Dialogue: 0,0:03:43.30,0:03:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tiap kali teringat momen
Dialogue: 0,0:03:44.97,0:03:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat aku refleks melontarkan
Dialogue: 0,0:03:46.39,0:03:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}isi pikiranku,
Dialogue: 0,0:03:48.68,0:03:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa semua orang mentertawakan
Dialogue: 0,0:03:51.06,0:03:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan meremehkanku dari belakang.
Dialogue: 0,0:03:54.15,0:03:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau penampilanku sudah berubah,
Dialogue: 0,0:03:56.77,0:03:59.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku masih takut orang akan menertawakan
Dialogue: 0,0:03:59.53,0:04:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sikap kampungan\Nyang sudah mendarah daging dalam diriku.
Dialogue: 0,0:04:15.13,0:04:16.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak kedinginan?
Dialogue: 0,0:04:16.07,0:04:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja kedinginan!
Dialogue: 0,0:04:18.20,0:04:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kamu di sini?
Dialogue: 0,0:04:19.67,0:04:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang perjalanan pulang\Ndari les musim dingin.
Dialogue: 0,0:04:21.42,0:04:23.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di hari sedingin ini?
Dialogue: 0,0:04:23.68,0:04:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu bilang akan bekerja hari ini...
Dialogue: 0,0:04:28.01,0:04:29.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku mampir untuk melihat.
Dialogue: 0,0:04:29.31,0:04:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap menyebalkanmu itu\Nmakin mirip Suzuki saja.
Dialogue: 0,0:04:33.10,0:04:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kostum Sinterklas itu cocok juga.
Dialogue: 0,0:04:34.98,0:04:36.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengejekku, ya?
Dialogue: 0,0:04:36.52,0:04:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, sungguh keren.
Dialogue: 0,0:04:39.48,0:04:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tertawa!
Dialogue: 0,0:04:41.28,0:04:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira!
Dialogue: 0,0:04:43.28,0:04:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada.
Dialogue: 0,0:04:46.24,0:04:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani juga di sini.
Dialogue: 0,0:04:48.08,0:04:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali, ya.
Dialogue: 0,0:04:49.33,0:04:50.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian terus saja berdatangan.
Dialogue: 0,0:04:51.04,0:04:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lewat sini beberapa kali\Nsaat mengantar pesanan hari ini.
Dialogue: 0,0:04:54.08,0:04:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terus berpikir, "Oh, kamu di sini."
Dialogue: 0,0:04:56.42,0:04:58.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya?\NAku sama sekali enggak sadar.
Dialogue: 0,0:04:59.21,0:05:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, cosplay-mu keren sekali!
Dialogue: 0,0:05:01.88,0:05:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga mengejekku, kan?
Dialogue: 0,0:05:03.80,0:05:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, aku serius.
Dialogue: 0,0:05:05.22,0:05:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kostum di tempatku kainnya jauh lebih tipis.
Dialogue: 0,0:05:07.55,0:05:09.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga enggak dapat janggut atau topi.
Dialogue: 0,0:05:09.10,0:05:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya aku dicurangi.
Dialogue: 0,0:05:10.97,0:05:13.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu rupanya.
Dialogue: 0,0:05:13.60,0:05:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhentilah tertawa sendiri.
Dialogue: 0,0:05:21.61,0:05:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taira, sif kerjamu sudah selesai.
Dialogue: 0,0:05:24.95,0:05:26.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:05:26.91,0:05:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan segera ke luar.
Dialogue: 0,0:05:29.16,0:05:30.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat ganti bajumu.
Dialogue: 0,0:05:33.41,0:05:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kami menunggu di dalam saja.\NDi luar dingin,
Dialogue: 0,0:05:35.79,0:05:37.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, kamu mau beli apa?
Dialogue: 0,0:05:37.37,0:05:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada yang spesifik.
Dialogue: 0,0:05:54.73,0:05:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mau dibuang, lo.
Dialogue: 0,0:05:56.48,0:05:57.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo makan.\N- Oh, ya?
Dialogue: 0,0:05:57.85,0:05:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:05:59.23,0:06:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membelinya, Taira.
Dialogue: 0,0:06:19.08,0:06:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}You and I Are Polar Opposites\NSeason 2
Dialogue: 0,0:07:34.99,0:07:37.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah makan kue seperti ini.
Dialogue: 0,0:07:37.83,0:07:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswa teladan seperti Tani biasanya
Dialogue: 0,0:07:39.96,0:07:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enggak mungkin melakukan\Nhal yang enggak sopan, kan?
Dialogue: 0,0:07:42.54,0:07:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:07:44.08,0:07:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sering makan nongkrong\Ndengan rekan kerjamu?
Dialogue: 0,0:07:47.30,0:07:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bahas hal yang enggak-enggak.
Dialogue: 0,0:07:50.30,0:07:51.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kue ini lumayan enak.
Dialogue: 0,0:07:52.30,0:07:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikut les saat Natal...
Dialogue: 0,0:07:54.26,0:07:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki enggak protes?
Dialogue: 0,0:07:55.85,0:07:57.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah bertemu kemarin.
Dialogue: 0,0:07:58.64,0:07:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:07:59.77,0:08:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi kamu yang bertanya.
Dialogue: 0,0:08:02.06,0:08:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang berkumpul\Ndengan teman klub SMP-nya hari ini.
Dialogue: 0,0:08:05.36,0:08:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, jadi ada Sato, Nakao, Mito,
Dialogue: 0,0:08:09.15,0:08:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Furukawa, dan Sekine?
Dialogue: 0,0:08:10.94,0:08:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sirkel itu, ya?
Dialogue: 0,0:08:12.28,0:08:13.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak tahu detailnya.
Dialogue: 0,0:08:13.91,0:08:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sebutkan nama yang enggak kami kenal.
Dialogue: 0,0:08:17.20,0:08:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kenyang.
Dialogue: 0,0:08:20.87,0:08:22.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuki mengirimiku foto.
Dialogue: 0,0:08:23.37,0:08:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada, ini semua temanmu?
Dialogue: 0,0:08:26.00,0:08:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kenal mereka. Jadi nostalgia.
Dialogue: 0,0:08:28.36,0:08:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku enggak mengenali beberapa dari\Nmereka dengan riasan dan gaya rambut itu.
Dialogue: 0,0:08:31.59,0:08:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia sering mengabarimu?
Dialogue: 0,0:08:33.97,0:08:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan sering.
Dialogue: 0,0:08:36.42,0:08:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:08:37.97,0:08:40.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin agar kamu tenang.
Dialogue: 0,0:08:41.27,0:08:44.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tampak seperti tipe orang\Nyang mudah curiga atau cemburu.
Dialogue: 0,0:08:44.19,0:08:45.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa reaksimu begitu?
Dialogue: 0,0:08:45.65,0:08:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya benar?
Dialogue: 0,0:08:46.56,0:08:47.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kok.
Dialogue: 0,0:08:48.07,0:08:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abaikan saja itu benar atau enggak.
Dialogue: 0,0:08:49.57,0:08:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mengelak, ya.
Dialogue: 0,0:08:50.73,0:08:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa bukan begitu alasannya.
Dialogue: 0,0:08:52.57,0:08:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto itu bagaikan hard disk eksternal\Nuntuk menyimpan kenangan kita!
Dialogue: 0,0:08:55.82,0:08:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa dia membagikan ingatannya
Dialogue: 0,0:08:58.49,0:09:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar bisa mengingatnya dengan lebih baik.
Dialogue: 0,0:09:01.37,0:09:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu seperti AI?
Dialogue: 0,0:09:03.58,0:09:05.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu memikirkannya.
Dialogue: 0,0:09:05.58,0:09:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada gunanya memikirkan\Nsetiap hal kecil sedetail itu.
Dialogue: 0,0:09:09.04,0:09:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya.
Dialogue: 0,0:09:10.46,0:09:14.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia enggak seperti mesin.\NKita makhluk yang jauh lebih emosional.
Dialogue: 0,0:09:14.76,0:09:16.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan cuma memoles permukaannya.
Dialogue: 0,0:09:16.26,0:09:18.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bicara dua hal\Nyang bertolak belakang sekaligus.
Dialogue: 0,0:09:22.10,0:09:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aoi, selamat datang!
Dialogue: 0,0:09:24.94,0:09:26.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama enggak berjumpa.
Dialogue: 0,0:09:26.60,0:09:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan. Sapaan itu terlalu kaku.
Dialogue: 0,0:09:29.73,0:09:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu makin mirip seperti seorang kakak.
Dialogue: 0,0:09:31.90,0:09:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini gayamu modis sekali.
Dialogue: 0,0:09:33.61,0:09:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibuku selalu bilang begitu.
Dialogue: 0,0:09:36.28,0:09:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ramai sekali.
Dialogue: 0,0:09:38.66,0:09:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manganya pasti berat. Maaf, ya.
Dialogue: 0,0:09:40.74,0:09:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak masalah.
Dialogue: 0,0:09:41.66,0:09:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakakku bilang\Nkalau dia meminjamkan sedikit demi sedikit,
Dialogue: 0,0:09:43.25,0:09:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan lupa siapa yang meminjam apa.
Dialogue: 0,0:09:45.12,0:09:47.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia menyuruhku membawa semuanya\Nsekaligus kalau kamu mau membacanya.
Dialogue: 0,0:09:47.29,0:09:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak Sato...
Dialogue: 0,0:09:48.88,0:09:51.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti pernah ada yang pinjam\Nlalu enggak pernah mengembalikannya.
Dialogue: 0,0:09:55.17,0:09:57.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berkumpul\Ndan bersantai santai seperti ini
Dialogue: 0,0:09:57.34,0:09:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar terasa nuansa akhir tahunnya.
Dialogue: 0,0:09:59.34,0:10:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya kamu enggak sesibuk ini.
Dialogue: 0,0:10:03.22,0:10:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa kegiatan Tani hari ini?
Dialogue: 0,0:10:05.64,0:10:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:10:06.69,0:10:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pikir aku bisa tahu jadwal Tani\Nsemudah itu?
Dialogue: 0,0:10:11.32,0:10:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia mau nongkrong\Ndengan teman sekelas yang sedang senggang.
Dialogue: 0,0:10:15.07,0:10:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu tahu persis jadwalnya.
Dialogue: 0,0:10:16.95,0:10:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini, sepertinya mereka pikir\Nmengobrol dengan Tani itu seru.
Dialogue: 0,0:10:21.83,0:10:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bukan tipe yang bisa kamu temui setiap hari,
Dialogue: 0,0:10:23.91,0:10:25.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makanya semua orang menganggapnya menarik.
Dialogue: 0,0:10:25.54,0:10:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani mudah akur dengan siapa saja...
Dialogue: 0,0:10:27.79,0:10:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin bertemu dengannya.
Dialogue: 0,0:10:29.71,0:10:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini ibunya, ya?
Dialogue: 0,0:10:31.00,0:10:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada hal yang menarik,
Dialogue: 0,0:10:33.05,0:10:33.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yakin
Dialogue: 0,0:10:34.05,0:10:35.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia akan menceritakannya nanti.
Dialogue: 0,0:10:35.26,0:10:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani bukan seperti bapak guru yang bahas\Nharinya di setiap ada kesempatan.
Dialogue: 0,0:10:41.18,0:10:43.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu yang dihabiskan terpisah
Dialogue: 0,0:10:43.56,0:10:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu memupuk cinta dan jadi bahan obrolan.
Dialogue: 0,0:10:47.85,0:10:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu cuma asal bicara saja.
Dialogue: 0,0:10:50.44,0:10:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau bilang begitu,\Nkelihatannya kamu selalu mengiriminya pesan.
Dialogue: 0,0:11:00.91,0:11:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:11:04.33,0:11:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani?
Dialogue: 0,0:11:09.04,0:11:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia mengirim video.
Dialogue: 0,0:11:11.58,0:11:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini video Morimo.
Dialogue: 0,0:11:13.00,0:11:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Video Morimo?
Dialogue: 0,0:11:14.46,0:11:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siap! Mulai!
Dialogue: 0,0:11:15.71,0:11:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo!
Dialogue: 0,0:11:18.51,0:11:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat sekali! Apa?
Dialogue: 0,0:11:20.55,0:11:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Morimo hebat sekali!
Dialogue: 0,0:11:25.06,0:11:27.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skornya tinggi! Bagaimana bisa?
Dialogue: 0,0:11:27.35,0:11:29.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Refleksmu bagus juga walau mukamu begitu.
Dialogue: 0,0:11:29.18,0:11:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kamu mengandalkan\Nkekuatan fisik saja,
Dialogue: 0,0:11:30.69,0:11:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti main mesin tinju atau semacamnya.
Dialogue: 0,0:11:32.19,0:11:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian merekamnya?
Dialogue: 0,0:11:33.61,0:11:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:11:34.77,0:11:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hore!\N- Hei...
Dialogue: 0,0:11:35.86,0:11:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu dekat!
Dialogue: 0,0:11:40.07,0:11:40.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seru sekali!
Dialogue: 0,0:11:41.07,0:11:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tampak konyol sekali!
Dialogue: 0,0:11:53.50,0:11:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan terus-terusan asyik dengan ponselmu!
Dialogue: 0,0:11:55.54,0:11:57.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:11:59.17,0:12:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kamu lakukan?
Dialogue: 0,0:12:03.55,0:12:04.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang bersenang-senang.
Dialogue: 0,0:12:05.76,0:12:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:12:08.27,0:12:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena merasa senang,
Dialogue: 0,0:12:10.39,0:12:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi ingin berbagi cerita dengannya.
Dialogue: 0,0:12:14.77,0:12:17.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani!
Dialogue: 0,0:12:17.48,0:12:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, masuk ke bingkai kamera.
Dialogue: 0,0:12:21.40,0:12:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:12:22.65,0:12:25.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, Tani, bilang "hore" juga.
Dialogue: 0,0:12:25.53,0:12:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak mau.
Dialogue: 0,0:12:29.91,0:12:32.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan ada di frame berikutnya.
Dialogue: 0,0:12:32.75,0:12:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukirimkan fotonya nanti.
Dialogue: 0,0:12:34.96,0:12:37.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh minta kontakmu?
Dialogue: 0,0:12:44.76,0:12:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya, aku enggak paham.
Dialogue: 0,0:12:49.97,0:12:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana aku harus
Dialogue: 0,0:12:51.73,0:12:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membalas pesan ini?
Dialogue: 0,0:12:54.52,0:12:55.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seolah
Dialogue: 0,0:12:55.98,0:12:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku enggak perlu membalas ini.
Dialogue: 0,0:13:01.32,0:13:02.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagiku,
Dialogue: 0,0:13:02.78,0:13:04.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau itu permintaan atau pertanyaan,
Dialogue: 0,0:13:04.78,0:13:05.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu lebih mudah kubalas.
Dialogue: 0,0:13:10.04,0:13:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu memberitahuku ini?
Dialogue: 0,0:13:17.33,0:13:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seiring berjalannya waktu,
Dialogue: 0,0:13:19.34,0:13:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku perlahan mulai paham.
Dialogue: 0,0:13:21.84,0:13:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu memikirkannya.
Dialogue: 0,0:13:23.92,0:13:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada gunanya memikirkan\Nsetiap hal kecil sedetail itu.
Dialogue: 0,0:13:27.39,0:13:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar, ya.
Dialogue: 0,0:13:28.72,0:13:32.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia enggak seperti mesin.\NKita makhluk yang jauh lebih emosional.
Dialogue: 0,0:13:33.60,0:13:36.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sangat bertolak belakang,\NMeskipun mereka mengatakan hal
Dialogue: 0,0:13:36.10,0:13:37.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka berdua benar.
Dialogue: 0,0:13:38.86,0:13:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu perlahan ingin berbagi momen\Nyang membuatmu terharu dengan seseorang.
Dialogue: 0,0:13:47.41,0:13:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali.
Dialogue: 0,0:13:51.91,0:13:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salju!
Dialogue: 0,0:13:52.91,0:13:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langka sekali!
Dialogue: 0,0:13:53.95,0:13:56.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salju pertama?
Dialogue: 0,0:13:56.17,0:13:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di antara semua orang itu...
Dialogue: 0,0:13:58.67,0:14:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak saat itu,\Nsetiap kali merasakan angin sejuk ini,
Dialogue: 0,0:14:02.46,0:14:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan berpikir,\N"Festival sekolah tahun ini sudah berakhir."
Dialogue: 0,0:14:06.43,0:14:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajah satu orang ini\Nselalu terlintas di benakku.
Dialogue: 0,0:14:10.10,0:14:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia di sini hari ini,\Napa yang akan dia katakan?
Dialogue: 0,0:14:14.43,0:14:15.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dingin sekali!
Dialogue: 0,0:14:15.93,0:14:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sedingin\Nhari ujian masuk sekolah swasta!
Dialogue: 0,0:14:18.48,0:14:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap kamu bisa menginap.
Dialogue: 0,0:14:21.57,0:14:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak bisa menginap dadakan.
Dialogue: 0,0:14:23.69,0:14:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga. Azuma ingin mengunjungi\Nkuil di sini untuk Tahun Baru.
Dialogue: 0,0:14:26.36,0:14:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo? Dia enggak pergi ke kuil\Ndi dekat rumahnya?
Dialogue: 0,0:14:29.78,0:14:30.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya enggak.
Dialogue: 0,0:14:30.70,0:14:32.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo buat rencana.
Dialogue: 0,0:14:32.53,0:14:35.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena dia ada di rumah nenek.\NTapi Nabe mungkin protes
Dialogue: 0,0:14:37.16,0:14:38.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu...
Dialogue: 0,0:14:38.46,0:14:41.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salju! Ada salju!
Dialogue: 0,0:14:42.17,0:14:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu kupotret lalu kukirim pada Tani?
Dialogue: 0,0:14:45.01,0:14:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tempatnya pasti turun salju juga.
Dialogue: 0,0:14:46.67,0:14:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:14:49.47,0:14:51.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa...
Dialogue: 0,0:14:52.18,0:14:55.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani sedikit banyak\Nterus terbayang di pikiranku.
Dialogue: 0,0:14:55.89,0:14:57.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu aneh?
Dialogue: 0,0:14:57.89,0:14:58.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru sadar?
Dialogue: 0,0:14:58.81,0:15:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikapmu aneh sejak tadi, tahu.
Dialogue: 0,0:15:01.94,0:15:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sementara itu, di sisi lain...
Dialogue: 0,0:15:04.40,0:15:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kue Tsukitamago ini enak sekali.
Dialogue: 0,0:15:06.24,0:15:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Manami! Jangan dimakan sendiri!
Dialogue: 0,0:15:10.36,0:15:13.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang enggak berbagi kebahagiaan.
Dialogue: 0,0:15:15.91,0:15:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali ke Hari Natal, di samping toserba.
Dialogue: 0,0:15:20.17,0:15:22.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu terlalu memikirkannya.
Dialogue: 0,0:15:22.21,0:15:25.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada gunanya memikirkan\Nsetiap hal kecil sedetail itu.
Dialogue: 0,0:15:25.84,0:15:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang dia bilang,
Dialogue: 0,0:15:27.38,0:15:29.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cowok bernama Yamada ini biasanya
Dialogue: 0,0:15:29.13,0:15:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}enggak punya maksud mendalam\Ndi balik setiap ucapannya.
Dialogue: 0,0:15:31.59,0:15:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bicara yang dia mau
Dialogue: 0,0:15:32.80,0:15:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bertanya yang dia mau.
Dialogue: 0,0:15:34.22,0:15:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta mengirim apa yang dia mau.
Dialogue: 0,0:15:36.22,0:15:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang sangat sederhana.
Dialogue: 0,0:15:45.73,0:15:48.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia seseorang yang kamu sukai?
Dialogue: 0,0:15:48.57,0:15:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku mulai menyukainya.
Dialogue: 0,0:15:51.95,0:15:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:15:53.41,0:15:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tani, kamu
Dialogue: 0,0:15:55.12,0:15:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bersikap seolah enggak ikut mengobrol,
Dialogue: 0,0:15:57.24,0:15:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sebenarnya kamu menyimak semuanya.
Dialogue: 0,0:15:59.25,0:16:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Naku sangat menyukainya sekarang.
Dialogue: 0,0:16:01.21,0:16:02.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia manis sekali.
Dialogue: 0,0:16:02.75,0:16:06.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang ini bisa bicara apa saja tanpa ragu.
Dialogue: 0,0:16:06.80,0:16:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku kamu dapat kontaknya\Nsebelum liburan musim panas, kan?
Dialogue: 0,0:16:10.80,0:16:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah cukup lama juga, ya.
Dialogue: 0,0:16:13.05,0:16:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun sifatnya begitu,
Dialogue: 0,0:16:15.55,0:16:17.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cara PDKT-nya cukup sopan.
Dialogue: 0,0:16:19.18,0:16:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kamu bilang begitu, benar juga!
Dialogue: 0,0:16:21.19,0:16:22.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baru menyadarinya?
Dialogue: 0,0:16:23.02,0:16:26.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar jelas saja, aku enggak mendesakmu.
Dialogue: 0,0:16:26.77,0:16:28.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh?
Dialogue: 0,0:16:28.57,0:16:30.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu mendengarkan? Hei!
Dialogue: 0,0:16:30.28,0:16:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selama itu?
Dialogue: 0,0:16:31.86,0:16:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seram juga.
Dialogue: 0,0:16:35.66,0:16:37.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah mengirim stiker teraneh,
Dialogue: 0,0:16:37.74,0:16:39.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tiba-tiba berhenti membalas pesan.
Dialogue: 0,0:16:39.87,0:16:41.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku terlalu terbawa suasana?
Dialogue: 0,0:16:42.29,0:16:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak seperti Nishi, yang selalu
Dialogue: 0,0:16:43.62,0:16:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cemas dan memikirkan kemungkinan terburuk,
Dialogue: 0,0:16:47.17,0:16:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada enggak merasa cemas sampai sekarang.
Dialogue: 0,0:16:54.34,0:16:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau begitulah menurutnya.
Dialogue: 0,0:16:56.68,0:16:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:16:57.93,0:17:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku enggak menembaknya,\Napa akan begini selamanya?
Dialogue: 0,0:17:01.14,0:17:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, itu sudah jelas.\NItu sudah pasti.
Dialogue: 0,0:17:04.34,0:17:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kapan?
Dialogue: 0,0:17:05.52,0:17:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kami bertemu lagi?
Dialogue: 0,0:17:07.81,0:17:10.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak...
Dialogue: 0,0:17:11.03,0:17:13.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu terlalu mendadak.
Dialogue: 0,0:17:13.24,0:17:16.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba, dia diliputi rasa cemas!
Dialogue: 0,0:17:23.75,0:17:26.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memeriksa situasinya lebih dulu.
Dialogue: 0,0:17:26.46,0:17:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada belum pernah\Nmenembak siapa pun sebelumnya.
Dialogue: 0,0:17:41.56,0:17:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yamada.
Dialogue: 0,0:17:44.31,0:17:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf membuatmu menunggu.
Dialogue: 0,0:17:53.86,0:17:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang terasa berbeda.
Dialogue: 0,0:18:00.37,0:18:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kamu bersembunyi?
Dialogue: 0,0:18:03.00,0:18:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:18:10.50,0:18:11.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:18:13.55,0:18:14.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa kusadari, aku...
Dialogue: 0,0:18:15.76,0:18:17.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buruk.
Dialogue: 0,0:18:18.18,0:18:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin sekali berpacaran dengannya!
Dialogue: 0,0:18:22.60,0:18:24.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku enggak takut
Dialogue: 0,0:18:24.39,0:18:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memakai PR sebagai alasan.
Dialogue: 0,0:18:25.98,0:18:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mestinya aku mengajaknya\Nke tempat yang lebih bagus.
Dialogue: 0,0:18:29.52,0:18:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:18:32.32,0:18:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu ingin serius belajar,
Dialogue: 0,0:18:34.99,0:18:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ruang belajar lebih nyaman.
Dialogue: 0,0:18:36.82,0:18:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dilarang mengobrol dan makan.
Dialogue: 0,0:18:39.49,0:18:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau mengobrol,
Dialogue: 0,0:18:40.99,0:18:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita bisa duduk di ruang bebas.
Dialogue: 0,0:18:42.58,0:18:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo ke sana.
Dialogue: 0,0:18:44.49,0:18:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sering kemari, ya?
Dialogue: 0,0:18:46.33,0:18:47.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu hafal tempatnya.
Dialogue: 0,0:18:48.17,0:18:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa lebih fokus di ruang belajar,
Dialogue: 0,0:18:50.33,0:18:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku sering memakainya.
Dialogue: 0,0:18:53.17,0:18:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengesankan.
Dialogue: 0,0:18:54.13,0:18:57.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tipe yang bisa fokus belajar di rumah?
Dialogue: 0,0:18:57.97,0:18:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak sama sekali.
Dialogue: 0,0:18:59.26,0:19:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku enggak pernah belajar di kamar.
Dialogue: 0,0:19:00.80,0:19:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyebar catatanku di ruang tamu.
Dialogue: 0,0:19:02.97,0:19:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku sering dimarahi.
Dialogue: 0,0:19:04.81,0:19:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka ada yang mengawasi\Ndaripada sendirian.
Dialogue: 0,0:19:08.98,0:19:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa aku bisa paham perasaannya.
Dialogue: 0,0:19:13.82,0:19:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah alasanmu mengajakku\Nmengerjakan PR bersama?
Dialogue: 0,0:19:16.07,0:19:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak,
Dialogue: 0,0:19:17.03,0:19:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu cuma alasan saja.
Dialogue: 0,0:19:21.62,0:19:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu rupanya.
Dialogue: 0,0:19:23.20,0:19:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku membuatnya takut?
Dialogue: 0,0:19:26.29,0:19:28.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:19:28.37,0:19:31.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, bukannya teman sekelas\Nyang tinggal di dekat sini sering kemari?
Dialogue: 0,0:19:31.63,0:19:32.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu enggak keberatan terlihat?
Dialogue: 0,0:19:34.17,0:19:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak berpapasan dengan orang\Nyang kukenal akhir-akhir ini,
Dialogue: 0,0:19:36.84,0:19:38.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi enggak masalah.
Dialogue: 0,0:19:38.42,0:19:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitukah?
Dialogue: 0,0:19:43.18,0:19:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kamu enggak sekadar sering kemari,\Ntapi datang setiap hari, kan?
Dialogue: 0,0:19:47.77,0:19:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kuperhatikan\Nitu bukan halaman tugas kita, kan?
Dialogue: 0,0:19:53.48,0:19:55.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah mengerjakan lebih banyak.
Dialogue: 0,0:19:55.73,0:19:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya...
Dialogue: 0,0:19:59.90,0:20:02.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menyelesaikan PR-nya.
Dialogue: 0,0:20:04.20,0:20:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu? Sulit dipercaya!
Dialogue: 0,0:20:06.20,0:20:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sangat mengesankan, lo!
Dialogue: 0,0:20:08.16,0:20:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:09.66,0:20:12.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bilang padaku,\Naku akan mengubah rencana kita.
Dialogue: 0,0:20:12.42,0:20:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun...
Dialogue: 0,0:20:14.33,0:20:17.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau PR-mu belum selesai,\Nsebaiknya cepat selesaikan.
Dialogue: 0,0:20:17.84,0:20:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masuk akal.
Dialogue: 0,0:20:21.68,0:20:22.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu...
Dialogue: 0,0:20:24.55,0:20:28.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga mencari-cari alasan.
Dialogue: 0,0:20:32.10,0:20:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah pacarku.
Dialogue: 0,0:20:35.11,0:20:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sungguh ingin bilang begitu!
Dialogue: 0,0:20:39.36,0:20:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:20:41.61,0:20:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Jangan di sini.\N- Hei, berhenti!
Dialogue: 0,0:20:56.96,0:20:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:20:58.50,0:20:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memotong ponimu.
Dialogue: 0,0:21:01.05,0:21:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dadakan sekali.
Dialogue: 0,0:21:02.34,0:21:03.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:21:04.01,0:21:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupikir kamu tampak sedikit berbeda hari ini.
Dialogue: 0,0:21:06.35,0:21:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu karena kita bisa melakukan kontak mata.
Dialogue: 0,0:21:09.06,0:21:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aneh kalau aku membuatmu berpikir begitu?
Dialogue: 0,0:21:13.44,0:21:14.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak sama sekali.
Dialogue: 0,0:21:14.90,0:21:16.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sangat manis.
Dialogue: 0,0:21:17.52,0:21:19.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu enggak aneh.
Dialogue: 0,0:21:19.44,0:21:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali enggak aneh.
Dialogue: 0,0:21:21.32,0:21:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang begitu malah membuatku gelisah.
Dialogue: 0,0:21:25.24,0:21:27.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi hari itu...
Dialogue: 0,0:21:28.12,0:21:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan begini,\Nlebih mudah membuat kontak mata.
Dialogue: 0,0:21:30.45,0:21:33.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu tak pernah menatapku sebelumnya.
Dialogue: 0,0:21:33.46,0:21:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malu rasanya kalau aku terlihat\Nlangsung menuruti kata-katanya.
Dialogue: 0,0:21:37.79,0:21:39.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:21:39.42,0:21:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak, kurasa bukan begitu.
Dialogue: 0,0:21:44.88,0:21:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tumben hari ini Yamada pendiam sekali.\NBaru kali ini.
Dialogue: 0,0:21:49.30,0:21:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku akan menyatakannya,
Dialogue: 0,0:21:51.01,0:21:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya di tempat yang lebih baik,\Ndengan suasana yang lebih baik!
Dialogue: 0,0:21:55.10,0:22:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak hal yang ingin Yamada katakan,\Ntapi ia tak bisa menemukan kata yang tepat.
Dialogue: 0,0:22:02.73,0:22:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bonus.
Dialogue: 0,0:22:05.49,0:22:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belajar dari perjalanannya\Nke Yokohama saat itu,
Dialogue: 0,0:22:08.45,0:22:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nishi membeli sepatu untuk dipakai\Ndengan pakaian kasualnya.
Dialogue: 0,0:22:11.08,0:22:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:22:13.29,0:22:15.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enggak ada pakaian lain untuk dipakai.
Dialogue: 0,0:22:15.41,0:22:17.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pakai sweter di luar,
Dialogue: 0,0:22:17.08,0:22:19.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin dia tak sadar itu pakaian yang sama.
Dialogue: 0,0:22:20.46,0:22:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, tas besarku\Ncuma ransel sekolah tua ini.
Dialogue: 0,0:22:26.09,0:22:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepatunya juga lebih besar dari dugaan.
Dialogue: 0,0:22:29.18,0:22:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:22:30.10,0:22:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya pas saat kucoba di toko.
Dialogue: 0,0:22:32.43,0:22:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berusaha keras.
Dialogue: 0,0:22:33.89,0:22:35.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga berhasil, Nishi!
