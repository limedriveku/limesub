Dialogue: 0,0:12:04.95,0:12:05.41,sign,,0000,0000,0000,,GARDA BELAKANG TERKUAT DI DUNIA\N~PENJELAJAH PEMULA DI NEGERI LABIRIN~
Dialogue: 0,0:12:42.57,0:12:44.03,sign,,0000,0000,0000,,SAMBARAN PETIR
Dialogue: 0,0:13:26.58,0:13:27.54,sign,,0000,0000,0000,,PEMULIHAN DUKUNGAN LV. 1
Dialogue: 0,0:00:06.19,0:00:07.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia?
Dialogue: 0,0:00:07.82,0:00:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna?
Dialogue: 0,0:00:09.53,0:00:11.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna, mundurlah!
Dialogue: 0,0:00:11.16,0:00:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Slash Ripper!
Dialogue: 0,0:00:20.29,0:00:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Igarashi, Theresia,
Dialogue: 0,0:00:21.96,0:00:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kutarik perhatian lebahnya ke sini.
Dialogue: 0,0:00:25.21,0:00:26.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arihito!
Dialogue: 0,0:00:26.17,0:00:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan!
Dialogue: 0,0:00:31.34,0:00:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thunderbolt!
Dialogue: 0,0:00:40.31,0:00:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar Suzuna mendapatkan\Nbanyak poin kontribusi,
Dialogue: 0,0:00:43.82,0:00:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian membubarkan party,
Dialogue: 0,0:00:45.23,0:00:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu Elitia memancing musuh
Dialogue: 0,0:00:47.19,0:00:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membiarkan Suzuna\Nyang membunuhnya, ya.
Dialogue: 0,0:00:49.61,0:00:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:00:50.99,0:00:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lebah itu juga mengincar Suzuna\Nyang jadi garda belakang.
Dialogue: 0,0:00:54.49,0:00:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah mencari monster lain\Nakan lebih aman?
Dialogue: 0,0:00:58.12,0:01:00.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma membuang waktu.
Dialogue: 0,0:01:00.48,0:01:04.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membuat Suzuna sekuat diriku\Nagar aku bisa kembali.
Dialogue: 0,0:01:05.67,0:01:06.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali?
Dialogue: 0,0:01:09.17,0:01:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya "kembali"?
Dialogue: 0,0:01:10.80,0:01:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau salah,
Dialogue: 0,0:01:12.43,0:01:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Byakuya Rhodan, ya?
Dialogue: 0,0:01:19.52,0:01:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:01:20.76,0:01:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sudi kembali ke tempat itu.
Dialogue: 0,0:01:23.19,0:01:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ke mana?
Dialogue: 0,0:01:24.56,0:01:26.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ingin kembali
Dialogue: 0,0:01:28.94,0:01:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke tempat Misaki.
Dialogue: 0,0:03:10.71,0:03:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misaki?
Dialogue: 0,0:03:12.71,0:03:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misaki adalah sahabatnya Suzuna.
Dialogue: 0,0:03:15.97,0:03:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misaki memilih pekerjaan sebagai "Gambler".
Dialogue: 0,0:03:20.14,0:03:22.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya karena keberuntungannya\Nselalu bagus.
Dialogue: 0,0:03:24.27,0:03:25.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:03:25.31,0:03:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia mengambil kotak harta\Nyang dijatuhkan monster.
Dialogue: 0,0:03:28.69,0:03:31.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ternyata itu adalah\Nkotak harta jebakan.
Dialogue: 0,0:03:37.78,0:03:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teleportasi karena jebakan?
Dialogue: 0,0:03:39.99,0:03:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dia diteleportasi ke mana?
Dialogue: 0,0:03:42.74,0:03:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu jebakan dalam lantai,\Nkurasa masih ada di lantai ini.
Dialogue: 0,0:03:48.03,0:03:50.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus segera mencarinya.
Dialogue: 0,0:03:56.22,0:03:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe, sebaiknya kita juga ikut mencari dia.
Dialogue: 0,0:04:00.89,0:04:06.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti sangat ketakutan kalau bertemu\Nmonster setelah diteleportasi sendirian.
Dialogue: 0,0:04:06.02,0:04:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tidak bisa membiarkannya begitu saja.
Dialogue: 0,0:04:11.73,0:04:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:04:14.57,0:04:18.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia, apakah di lantai ini ada party lain?
Dialogue: 0,0:04:18.70,0:04:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada, aku ingin minta bantuan mereka.
Dialogue: 0,0:04:21.99,0:04:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:04:23.87,0:04:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, saat datang ke sini,\Naku merasa ada yang mengawasi kami.
Dialogue: 0,0:04:29.04,0:04:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya ada yang mengawasi\Norang-orang yang ke lantai dua?
Dialogue: 0,0:04:33.61,0:04:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk apa?
Dialogue: 0,0:04:39.05,0:04:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sulit untuk bekerja sama\Ndengan party lain.
Dialogue: 0,0:04:43.58,0:04:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau berpencar dan bertemu monster,\Nnantinya akan sulit diatasi.
Dialogue: 0,0:04:49.61,0:04:52.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia, Suzuna, untuk kali ini saja,
Dialogue: 0,0:04:52.71,0:04:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bergabunglah dengan party kami.
Dialogue: 0,0:04:56.07,0:04:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaanku adalah garda belakang.
Dialogue: 0,0:04:58.36,0:05:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku tak bisa memberi dukungan\Njika bukan dalam satu party.
Dialogue: 0,0:05:03.57,0:05:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan!
Dialogue: 0,0:05:07.45,0:05:10.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kamu bersedia membantu,
Dialogue: 0,0:05:10.45,0:05:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin level Suzuna bisa naik\Ndengan lebih aman.
Dialogue: 0,0:05:13.75,0:05:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa seperti itu.
Dialogue: 0,0:05:16.96,0:05:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:18.23,0:05:21.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna, bergabunglah dengan party Arihito.
Dialogue: 0,0:05:22.13,0:05:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kamu bagaimana?
Dialogue: 0,0:05:23.80,0:05:26.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan ikut secara solo.
Dialogue: 0,0:05:26.09,0:05:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku yang berlevel tinggi ikut masuk,
Dialogue: 0,0:05:28.52,0:05:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}poin pengalaman\Nyang kalian dapat akan sedikit.
Dialogue: 0,0:05:31.56,0:05:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh tanya satu hal?
Dialogue: 0,0:05:33.94,0:05:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelumnya, di guild,
Dialogue: 0,0:05:35.31,0:05:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai garda depan,\Naku dengar kamu punya beberapa kekurangan,
Dialogue: 0,0:05:39.71,0:05:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa ada sesuatu\Nyang harus kami perhatikan?
Dialogue: 0,0:05:45.24,0:05:48.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku bilang lari,
Dialogue: 0,0:05:48.04,0:05:49.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tinggalkanlah aku.
Dialogue: 0,0:05:49.91,0:05:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu saja permintaanku.
Dialogue: 0,0:05:52.04,0:05:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku mengerti.
Dialogue: 0,0:05:55.59,0:05:58.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah memberikan\NReturn Scroll pada Suzuna,
Dialogue: 0,0:05:58.13,0:05:59.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi gunakanlah itu.
Dialogue: 0,0:06:00.21,0:06:03.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunjukkanlah kemampuanmu, Tuan Arihito.
Dialogue: 0,0:06:03.18,0:06:05.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, mohon kerja samanya.
Dialogue: 0,0:06:07.39,0:06:09.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuturuti perintahmu\Nmeski tak satu party.
Dialogue: 0,0:06:09.89,0:06:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang yang aku dapat juga akan kuberikan.
Dialogue: 0,0:06:12.44,0:06:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau butuh uang, bilang saja padaku.
Dialogue: 0,0:06:15.52,0:06:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk sekarang masih aman.
Dialogue: 0,0:06:17.51,0:06:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, aku bukanlah benalu.
Dialogue: 0,0:06:19.61,0:06:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Benalu"?\NApa itu?
Dialogue: 0,0:06:23.29,0:06:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, Arihito,
Dialogue: 0,0:06:27.37,0:06:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi, aku adalah Shiromiya Suzuna.
Dialogue: 0,0:06:30.32,0:06:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaanku Gadis Kuil.
Dialogue: 0,0:06:32.65,0:06:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:06:34.21,0:06:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Atobe Arihito.
Dialogue: 0,0:06:36.92,0:06:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah Igarashi Kyouka,
Dialogue: 0,0:06:39.05,0:06:42.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sebelahnya adalah Theresia,\Nseorang Lizardman.
Dialogue: 0,0:06:42.09,0:06:43.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya.
Dialogue: 0,0:06:43.38,0:06:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang bisa bertambah teman.
Dialogue: 0,0:06:45.91,0:06:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon kerja samanya juga.
Dialogue: 0,0:06:53.79,0:06:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mo-Mohon kerja samanya!
Dialogue: 0,0:07:05.86,0:07:08.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hanya ikut sebagai tamu,
Dialogue: 0,0:07:08.24,0:07:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi tak bisa mengatur barisan Elitia.
Dialogue: 0,0:07:11.29,0:07:14.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski kemampuanku punya risiko,
Dialogue: 0,0:07:14.12,0:07:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tetap ingin memberikan Dukungan.
Dialogue: 0,0:07:16.25,0:07:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:07:18.42,0:07:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong! Tolong! Tolong aku!
Dialogue: 0,0:07:21.17,0:07:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu suaranya Misaki!
Dialogue: 0,0:07:27.26,0:07:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:07:36.31,0:07:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:07:38.02,0:07:39.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juggernaut!
Dialogue: 0,0:07:41.61,0:07:43.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk ini tidak seharusnya ada di sini.
Dialogue: 0,0:07:43.88,0:07:45.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada seseorang
Dialogue: 0,0:07:45.19,0:07:49.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang membawanya ke sini\Nuntuk memaksa kita mengalahkannya.
Dialogue: 0,0:07:49.04,0:07:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang?
Dialogue: 0,0:07:51.56,0:07:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka, ya?
Dialogue: 0,0:07:53.95,0:07:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nmereka pasti sedang mengawasi kita.
Dialogue: 0,0:07:57.58,0:07:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:07:59.50,0:08:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menyelamatkan Misaki,\Naku harus mengalahkannya!
Dialogue: 0,0:08:03.50,0:08:05.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian diamlah di situ!
Dialogue: 0,0:08:06.34,0:08:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia!
Dialogue: 0,0:08:07.38,0:08:10.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Muntahkanlah isi perut kalian, para Orc!
Dialogue: 0,0:08:18.02,0:08:19.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat.
Dialogue: 0,0:08:19.57,0:08:20.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:08:31.32,0:08:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia!
Dialogue: 0,0:08:32.40,0:08:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe, ayo kita tolong dia.
Dialogue: 0,0:08:34.40,0:08:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan kemari!
Dialogue: 0,0:08:36.12,0:08:38.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan aku dan cepat lari!
Dialogue: 0,0:08:40.50,0:08:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kondisinya...
Dialogue: 0,0:08:42.91,0:08:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berserk, Prajurit Pengamuk?
Dialogue: 0,0:08:46.71,0:08:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,\Ndia tak bisa kendalikan kekuatannya?
Dialogue: 0,0:08:49.96,0:08:53.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya dia tak ikut party\Ndan menjaga jarak.
Dialogue: 0,0:08:53.14,0:08:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti menyelamatkannya!
Dialogue: 0,0:08:55.01,0:08:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku...
Dialogue: 0,0:08:57.10,0:08:59.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukanlah pembunuh!
Dialogue: 0,0:09:00.52,0:09:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bukan pembunuh!
Dialogue: 0,0:09:03.48,0:09:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia berusaha menanggungnya sendiri
Dialogue: 0,0:09:06.82,0:09:09.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan melawan monster bernama dan Orc itu?
Dialogue: 0,0:09:32.76,0:09:33.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia!
Dialogue: 0,0:09:36.56,0:09:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan aku!
Dialogue: 0,0:09:41.10,0:09:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arihito, kabur!
Dialogue: 0,0:09:44.31,0:09:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabur?
Dialogue: 0,0:09:46.15,0:09:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia benar,
Dialogue: 0,0:09:47.19,0:09:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami bisa kabur kalau Suzuna\Nmenggunakan Return Scroll.
Dialogue: 0,0:09:50.69,0:09:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang seharusnya begitu.
Dialogue: 0,0:09:52.17,0:09:54.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak mungkin menang\Nmelawan monster itu.
Dialogue: 0,0:09:54.73,0:09:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:09:58.87,0:10:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tak mungkin kabur\Nmeskipun disuruh kabur!
Dialogue: 0,0:10:20.60,0:10:23.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Igarashi, Theresia, Suzuna,
Dialogue: 0,0:10:23.31,0:10:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau keadaan makin buruk,\Npergilah tanpa aku.
Dialogue: 0,0:10:25.85,0:10:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mungkin bisa melakukannya!
Dialogue: 0,0:10:27.90,0:10:29.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan bertarung...
Dialogue: 0,0:10:29.36,0:10:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon, dengarkanlah kata-kataku.
Dialogue: 0,0:10:32.71,0:10:35.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau selamat, aku akan melakukan apa pun!
Dialogue: 0,0:10:35.61,0:10:38.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seburuk apa pun keadaannya,\Naku tak akan kabur.
Dialogue: 0,0:10:38.16,0:10:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, biarkan aku di sini.
Dialogue: 0,0:10:40.41,0:10:42.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna, Theresia.
Dialogue: 0,0:10:43.75,0:10:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:45.01,0:10:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan Return Scroll\Nbisa dipakai kapan saja.
Dialogue: 0,0:10:48.01,0:10:49.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berjanjilah padaku.
Dialogue: 0,0:10:51.38,0:10:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendekati Juggernaut saja\Nbisa membunuh kami.
Dialogue: 0,0:10:55.84,0:10:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:10:57.76,0:11:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia mampu menghindari serangan Juggernaut.
Dialogue: 0,0:11:01.22,0:11:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya ada peluang\Nuntuk menyerang balik.
Dialogue: 0,0:11:04.98,0:11:08.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia, masuklah ke dalam party-ku!
Dialogue: 0,0:11:08.03,0:11:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar saja!
Dialogue: 0,0:11:12.78,0:11:15.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, Misaki tak bisa diselamatkan!
Dialogue: 0,0:11:15.31,0:11:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon!
Dialogue: 0,0:11:16.32,0:11:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia, aku mohon!
Dialogue: 0,0:11:18.49,0:11:21.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkanlah kata-kata Arihito!
Dialogue: 0,0:11:21.08,0:11:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ingin mati\Ndi tempat seperti ini, kan?
Dialogue: 0,0:11:33.09,0:11:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masuk ke dalam party.
Dialogue: 0,0:11:36.59,0:11:39.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia, gunakan serangan beruntun!
Dialogue: 0,0:11:39.68,0:11:40.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuberi Dukungan!
Dialogue: 0,0:11:41.60,0:11:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun serangan fisik tidak mempan,
Dialogue: 0,0:11:44.03,0:11:47.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau setiap serangan ditambah 10 poin,\Nmungkin akan ada peluang!
Dialogue: 0,0:11:48.98,0:11:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sonic Raid!
Dialogue: 0,0:11:52.94,0:11:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blossom Blade!
Dialogue: 0,0:12:01.12,0:12:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, namaku Misaki.
Dialogue: 0,0:12:05.41,0:12:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, aku anggota lama\Ndi party Atobe, namaku Kyouka.
Dialogue: 0,0:12:17.47,0:12:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil!
Dialogue: 0,0:12:22.01,0:12:24.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, Igarashi,
Dialogue: 0,0:12:24.10,0:12:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong lindungi Elitia!
Dialogue: 0,0:12:26.11,0:12:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dekat sini pasti masih ada musuh lain!
Dialogue: 0,0:12:32.56,0:12:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan.
Dialogue: 0,0:12:33.82,0:12:36.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya kamu pura-pura tidak melihatku!
Dialogue: 0,0:12:36.69,0:12:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, aku beri Dukungan!
Dialogue: 0,0:12:38.45,0:12:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:12:42.57,0:12:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thunderbolt!
Dialogue: 0,0:12:44.99,0:12:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan! Orang-orang tidak berguna!
Dialogue: 0,0:12:58.47,0:13:00.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koordinasimu luar biasa.
Dialogue: 0,0:13:00.84,0:13:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,\Naku merasakan sensasi yang aneh.
Dialogue: 0,0:13:04.01,0:13:05.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baru pertama kalinya begini.
Dialogue: 0,0:13:05.64,0:13:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian ada di depanku,
Dialogue: 0,0:13:07.53,0:13:10.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}anggap saja serangan kalian\Nmendapat efek bonus.
Dialogue: 0,0:13:10.01,0:13:11.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting,
Dialogue: 0,0:13:14.06,0:13:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia, kamu tidak apa-apa?
Dialogue: 0,0:13:17.36,0:13:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:13:19.19,0:13:22.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh memalukan,\Ntapi, aku tidak punya tenaga lagi.
Dialogue: 0,0:13:22.99,0:13:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, jangan memaksakan diri.
Dialogue: 0,0:13:27.54,0:13:30.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang harusnya tenagamu berangsur pulih.
Dialogue: 0,0:13:30.75,0:13:32.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:13:35.09,0:13:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misaki selamat.
Dialogue: 0,0:13:37.80,0:13:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia punya keberuntungan yang kuat.
Dialogue: 0,0:13:40.80,0:13:44.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun sebenarnya tak percaya diri\Nbisa menyelamatkannya.
Dialogue: 0,0:13:44.23,0:13:45.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:13:49.36,0:13:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku...
Dialogue: 0,0:13:51.56,0:13:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misaki, sekarang sudah aman.
Dialogue: 0,0:13:54.90,0:13:56.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa mungkin...
Dialogue: 0,0:13:56.65,0:13:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang menyelamatkanku, Suzu?
Dialogue: 0,0:14:00.19,0:14:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya aku, tapi berkat yang lain juga.
Dialogue: 0,0:14:02.74,0:14:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:14:04.74,0:14:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takut.
Dialogue: 0,0:14:07.21,0:14:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misaki.
Dialogue: 0,0:14:10.08,0:14:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:14:12.61,0:14:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku atas banyak hal.
Dialogue: 0,0:14:15.83,0:14:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti banyak yang tidak kamu mengerti.
Dialogue: 0,0:14:18.13,0:14:20.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong bersabarlah.
Dialogue: 0,0:14:20.38,0:14:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan menjelaskannya.
Dialogue: 0,0:14:22.84,0:14:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku mengerti.
Dialogue: 0,0:14:26.47,0:14:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?\NApa ada yang sakit?
Dialogue: 0,0:14:29.89,0:14:31.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:14:43.46,0:14:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu yang dinamakan kotak harta?
Dialogue: 0,0:14:47.32,0:14:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kotak hitam\Ndari monster bernama yang langka.
Dialogue: 0,0:14:50.43,0:14:53.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi para penjelajah,\Nitu harta yang paling diburu.
Dialogue: 0,0:14:53.29,0:14:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, jangan dibuka sembarangan.
Dialogue: 0,0:14:55.83,0:15:00.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minta guild mencarikan ahli perangkap\Nuntuk melepaskan jebakannya.
Dialogue: 0,0:15:00.05,0:15:02.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, akan kulakukan.
Dialogue: 0,0:15:02.36,0:15:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:15:04.49,0:15:07.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyelamatkanku.
Dialogue: 0,0:15:07.59,0:15:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ya.
Dialogue: 0,0:15:10.06,0:15:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya aku tidak mengerti\Napa itu labirin ataupun penjelajah,
Dialogue: 0,0:15:14.69,0:15:17.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sekarang aku akan berjuang keras.
Dialogue: 0,0:15:17.31,0:15:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:15:19.44,0:15:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong traktir aku makan!
Dialogue: 0,0:15:22.57,0:15:23.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:23.61,0:15:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku juga mulai lapar.
Dialogue: 0,0:15:26.03,0:15:27.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku mohon.\N- Atobe,
Dialogue: 0,0:15:27.53,0:15:30.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaimana kalau kita\Nmelapor ke guild dulu sebelum makan bersama?
Dialogue: 0,0:15:30.33,0:15:31.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, boleh.
Dialogue: 0,0:15:31.62,0:15:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asyik!
Dialogue: 0,0:15:34.12,0:15:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Theresia, akan kuantar kamu pulang.
Dialogue: 0,0:15:41.04,0:15:42.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia?
Dialogue: 0,0:15:43.59,0:15:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe, mungkin Theresia\Ningin ikut makan bersama kita.
Dialogue: 0,0:15:47.89,0:15:50.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, benarkah?
Dialogue: 0,0:15:55.14,0:15:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak tadi aku kepikiran.
Dialogue: 0,0:15:57.64,0:16:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi kadal ini lucu banget, ya.
Dialogue: 0,0:16:01.40,0:16:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Halus dan adem.
Dialogue: 0,0:16:09.03,0:16:09.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ju...
Dialogue: 0,0:16:09.95,0:16:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jugger... naut!
Dialogue: 0,0:16:12.66,0:16:15.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kami berpapasan di lantai dua.
Dialogue: 0,0:16:15.69,0:16:18.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kalahkan dan menyerahkannya\Nke pengangkut.
Dialogue: 0,0:16:18.96,0:16:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, mereka akan melaporkannya ke guild.
Dialogue: 0,0:16:22.25,0:16:24.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo-Louisa?
Dialogue: 0,0:16:25.30,0:16:26.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior?
Dialogue: 0,0:16:28.09,0:16:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan saya.
Dialogue: 0,0:16:30.09,0:16:34.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau begitu, mari lewat sini.
Dialogue: 0,0:16:36.64,0:16:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster bernama ada yang sering muncul
Dialogue: 0,0:16:39.98,0:16:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan ada juga yang jarang muncul.
Dialogue: 0,0:16:42.99,0:16:46.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Juggernaut sendiri, di antara\Nmonster bernama Fang Orc lainnya,
Dialogue: 0,0:16:46.44,0:16:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}termasuk jenis yang langka.
Dialogue: 0,0:16:49.10,0:16:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut catatan yang saya baca,
Dialogue: 0,0:16:50.99,0:16:53.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebelumnya ada party yang bertemu Juggernaut.
Dialogue: 0,0:16:53.87,0:16:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mengumpulkan 24 penjelajah,
Dialogue: 0,0:16:56.87,0:16:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi sayangnya kalah.
Dialogue: 0,0:16:59.62,0:17:01.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan kabarnya,
Dialogue: 0,0:17:01.29,0:17:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang selamat adalah party\Nyang dipimpin oleh Bergen.
Dialogue: 0,0:17:04.92,0:17:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.
Dialogue: 0,0:17:06.80,0:17:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bergen dan lainnya memanfaatkan Misaki,
Dialogue: 0,0:17:09.30,0:17:12.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar Elitia muncul untuk mengalahkannya.
Dialogue: 0,0:17:12.00,0:17:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lancar, mereka yang akan\Nmengambil barang jarahannya.
Dialogue: 0,0:17:16.31,0:17:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa jadi begitu.
Dialogue: 0,0:17:18.02,0:17:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:17:19.18,0:17:21.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serahkan urusan tersebut pada guild.
Dialogue: 0,0:17:21.95,0:17:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena menghukum orang-orang seperti Bergen
Dialogue: 0,0:17:24.65,0:17:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah tugas negeri kami.
Dialogue: 0,0:17:28.61,0:17:32.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Louisa, maaf jika\Nbaru menanyakannya sekarang,
Dialogue: 0,0:17:32.03,0:17:35.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi, apakah Negeri Labirin ini ada rajanya?
Dialogue: 0,0:17:35.83,0:17:36.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:17:36.79,0:17:41.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga yang mendirikan negeri ini\Ntelah diasingkan ke Distrik Pertama.
Dialogue: 0,0:17:42.17,0:17:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, yang memegang kekuasaan\Npemerintah Negeri Labirin ini,
Dialogue: 0,0:17:46.09,0:17:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah Kepala Kuil Agung
Dialogue: 0,0:17:48.30,0:17:51.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan pemimpin guild kami.
Dialogue: 0,0:17:51.68,0:17:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu artinya,
Dialogue: 0,0:17:53.41,0:17:57.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menjelajah memang\Nkarena kehendak negeri ini?
Dialogue: 0,0:17:57.64,0:18:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu maksudnya tak ada pilihan\Nselain menjadi penjelajah?
Dialogue: 0,0:18:01.39,0:18:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:18:02.63,0:18:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Labirin yang ada di Negeri Labirin ini
Dialogue: 0,0:18:04.98,0:18:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya merupakan tempat\Nyang berasal dari dunia lain.
Dialogue: 0,0:18:09.11,0:18:11.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya pintu masuk tempat berteleportasi
Dialogue: 0,0:18:11.49,0:18:14.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang dikumpulkan dalam\Ndinding Negeri Labirin ini.
Dialogue: 0,0:18:14.41,0:18:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ditanya mengapa demikian,
Dialogue: 0,0:18:16.53,0:18:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya juga tak punya wewenang\Nuntuk mengetahuinya.
Dialogue: 0,0:18:20.37,0:18:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:18:23.87,0:18:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, izinkan saya melihat\Ncatatan aktivitas penjelajah.
Dialogue: 0,0:18:28.73,0:18:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memasuki lantai dua Padang Fajar: 10 poin.
Dialogue: 0,0:18:32.13,0:18:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arihito naik ke level 3:10 poin.
Dialogue: 0,0:18:34.97,0:18:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyouka naik ke level 2:10 poin.
Dialogue: 0,0:18:37.39,0:18:39.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna naik ke level 2:10 poin.
Dialogue: 0,0:18:39.81,0:18:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menumpas 15 watadama: 75 poin.
Dialogue: 0,0:18:42.77,0:18:46.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menumpas 8 lebah beracun: 64 poin.
Dialogue: 0,0:18:46.09,0:18:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menumpas 23 Fang Orc: 230 poin.
Dialogue: 0,0:18:49.68,0:18:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menumpas buronan Juggernaut: 800 poin.
Dialogue: 0,0:18:52.86,0:18:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat kepercayaan Theresia\Nmeningkat: 50 poin.
Dialogue: 0,0:18:55.49,0:18:57.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat kepercayaan Kyouka\Nmeningkat: 50 poin.
Dialogue: 0,0:18:57.91,0:19:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat kepercayaan Suzuna\Nmeningkat: 10 poin.
Dialogue: 0,0:19:00.24,0:19:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat kepercayaan Elitia\Nmeningkat: 50 poin.
Dialogue: 0,0:19:03.04,0:19:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelamatkan party lain: 30 poin.
Dialogue: 0,0:19:05.61,0:19:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyelamatkan Misaki: 100 poin.
Dialogue: 0,0:19:07.38,0:19:10.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalahkan tiga penjahat: 90 poin.
Dialogue: 0,0:19:10.00,0:19:13.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membawa satu kotak harta hitam: 50 poin.
Dialogue: 0,0:19:15.09,0:19:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kemudian,
Dialogue: 0,0:19:16.72,0:19:20.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tingkat kontribusi penjelajah: 1.649 poin.
Dialogue: 0,0:19:20.18,0:19:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat kedua dalam sejarah Distrik 8.
Dialogue: 0,0:19:24.84,0:19:27.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat tiga digit saja sudah luar biasa.
Dialogue: 0,0:19:27.44,0:19:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini baru dua hari sudah mencapai empat digit?
Dialogue: 0,0:19:33.07,0:19:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa, Tuan Atobe!
Dialogue: 0,0:19:35.15,0:19:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Te-Terima kasih.
Dialogue: 0,0:19:40.37,0:19:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi!
Dialogue: 0,0:19:42.12,0:19:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sudah kuduga ada di sini.
Dialogue: 0,0:19:44.29,0:19:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa masih lama?
Dialogue: 0,0:19:45.96,0:19:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin cepat-cepat makan.
Dialogue: 0,0:19:48.67,0:19:50.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, sebentar.
Dialogue: 0,0:19:51.42,0:19:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bagaimana kalau Louisa juga ikut?
Dialogue: 0,0:19:55.37,0:19:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan malamlah bersama kami.
Dialogue: 0,0:19:57.13,0:19:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tanda terima kasih\Nkarena mengajariku banyak hal.
Dialogue: 0,0:20:00.97,0:20:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, apa boleh?
Dialogue: 0,0:20:06.44,0:20:09.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe, karena kamu pemimpinnya,
Dialogue: 0,0:20:09.65,0:20:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu harus duduk di tengah.
Dialogue: 0,0:20:11.94,0:20:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:20:13.57,0:20:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:20:14.82,0:20:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Louisa dari guild silakan duduk\Ndi sebelah Atobe.
Dialogue: 0,0:20:18.95,0:20:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, silakan Nona Igarashi saja.
Dialogue: 0,0:20:21.87,0:20:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemeran utama kali ini adalah\Nkalian semua anggota party.
Dialogue: 0,0:20:25.41,0:20:28.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak, jangan berkata seperti itu.
Dialogue: 0,0:20:28.25,0:20:31.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, wah, Nona Igarashi juga.
Dialogue: 0,0:20:32.13,0:20:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengingatkanku pada\Nzaman kerja kantoran dulu.
Dialogue: 0,0:20:35.57,0:20:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, bagaimana kalau\NSuzuna atau Theresia saja?
Dialogue: 0,0:20:39.26,0:20:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Aku juga mau duduk di sebelahnya.
Dialogue: 0,0:20:44.31,0:20:46.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku berutang budi pada Arihito,
Dialogue: 0,0:20:46.60,0:20:48.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa tuangkan minuman untukmu.
Dialogue: 0,0:20:48.81,0:20:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak boleh.
Dialogue: 0,0:20:50.44,0:20:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe bilang dia tidak suka\Ngadis yang terlalu ceria.
Dialogue: 0,0:20:53.90,0:20:58.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu cuma alasan\Nkarena cemburu pada yang lebih muda?
Dialogue: 0,0:21:07.04,0:21:10.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jago menuangkan sake, lo.
Dialogue: 0,0:21:10.50,0:21:11.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar,
Dialogue: 0,0:21:11.29,0:21:14.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Abang Arihito umurnya berapa, ya?
Dialogue: 0,0:21:14.79,0:21:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"A-Abang"?
Dialogue: 0,0:21:16.38,0:21:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Abang suka gadis yang pendiam?
Dialogue: 0,0:21:19.76,0:21:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti Suzuna.
Dialogue: 0,0:21:21.38,0:21:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Misaki...
Dialogue: 0,0:21:23.93,0:21:26.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bahas yang begituan.
Dialogue: 0,0:21:26.18,0:21:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kenapa tidak?
Dialogue: 0,0:21:28.77,0:21:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, suka yang lebih tua, ya?
Dialogue: 0,0:21:31.39,0:21:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:21:37.28,0:21:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah semuanya.
Dialogue: 0,0:21:38.65,0:21:41.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpin, tolong pimpin bersulangnya.
Dialogue: 0,0:21:41.74,0:21:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baik.\NKalau begitu...
Dialogue: 0,0:21:47.04,0:21:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, ada yang ingin aku bicarakan.
Dialogue: 0,0:21:52.96,0:21:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, setelah ini,\Naku berniat ke tempatnya Leila,
Dialogue: 0,0:21:56.53,0:22:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk meminta Theresia\Nmenjadi rekan party secara resmi.
Dialogue: 0,0:22:01.76,0:22:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mengembalikan Theresia\Nke wujud manusianya.
