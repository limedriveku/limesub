Dialogue: 0,0:00:00.40,0:00:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi.
Dialogue: 0,0:00:11.53,0:00:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Blink Step!
Dialogue: 0,0:00:14.62,0:00:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah kemampuan seorang Valkyrie?
Dialogue: 0,0:00:17.33,0:00:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aduh.
Dialogue: 0,0:00:20.09,0:00:21.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau mati.
Dialogue: 0,0:00:22.21,0:00:24.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak sudi lama-lama di sini!
Dialogue: 0,0:00:33.76,0:00:35.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi ditinggal?
Dialogue: 0,0:00:36.21,0:00:39.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia tidak bergabung\Ndengan party mereka?
Dialogue: 0,0:02:17.95,0:02:19.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah, Kepala!
Dialogue: 0,0:02:19.54,0:02:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kami yang urus!
Dialogue: 0,0:02:20.95,0:02:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe?
Dialogue: 0,0:02:22.51,0:02:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah, kamu saja yang pergi!
Dialogue: 0,0:02:24.96,0:02:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak boleh kalah\Ndi tempat seperti ini!
Dialogue: 0,0:02:33.93,0:02:35.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawanmu adalah aku!
Dialogue: 0,0:02:36.34,0:02:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thunderbolt!
Dialogue: 0,0:02:51.15,0:02:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan,
Dialogue: 0,0:02:52.24,0:02:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia tak punya tenaga lagi\Nuntuk mengaktifkan Blink Step?
Dialogue: 0,0:03:02.41,0:03:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan!
Dialogue: 0,0:03:11.42,0:03:12.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan!
Dialogue: 0,0:03:15.22,0:03:16.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang bisa aktif?
Dialogue: 0,0:03:16.75,0:03:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:03:17.80,0:03:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan hanya bisa diaktifkan\Npada target yang satu party denganku.
Dialogue: 0,0:03:24.31,0:03:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai waktu itu
Dialogue: 0,0:03:26.14,0:03:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia menjadi rekan party-ku
Dialogue: 0,0:03:30.73,0:03:32.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergilah.
Dialogue: 0,0:03:33.15,0:03:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe, maaf.
Dialogue: 0,0:03:36.61,0:03:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berguna bagimu.
Dialogue: 0,0:03:40.58,0:03:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akulah yang seharusnya meminta maaf.
Dialogue: 0,0:03:45.41,0:03:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menangkisnya, kini aku paham,
Dialogue: 0,0:03:48.05,0:03:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa serangannya bisa ditangkis\Ndengan Pertahanan Dukungan milikku.
Dialogue: 0,0:03:51.75,0:03:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau serangan seperti itu
Dialogue: 0,0:03:54.33,0:03:56.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak lebih dari 10 DMG...
Dialogue: 0,0:03:56.59,0:03:59.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, pinjamkan kekuatanmu.
Dialogue: 0,0:04:06.23,0:04:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak akan kubiarkan!
Dialogue: 0,0:04:12.48,0:04:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski seranganku tidak mempan,
Dialogue: 0,0:04:14.69,0:04:17.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan serangan Theresia\Nyang diperkuat Serangan Dukungan,
Dialogue: 0,0:04:17.89,0:04:19.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu pasti bisa dikalahkan!
Dialogue: 0,0:04:21.22,0:04:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, aku beri dukungan!
Dialogue: 0,0:04:38.97,0:04:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhasil.
Dialogue: 0,0:04:42.85,0:04:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi!
Dialogue: 0,0:04:44.60,0:04:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kalian tidak apa-apa?
Dialogue: 0,0:04:47.57,0:04:50.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, panggil Rival dan lainnya ke sini.
Dialogue: 0,0:05:03.12,0:05:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelku naik?
Dialogue: 0,0:05:04.95,0:05:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat poin skill juga.
Dialogue: 0,0:05:07.01,0:05:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, sekarang aku bisa ambil\NPemulihan Dukungan.
Dialogue: 0,0:05:15.21,0:05:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi, ini aku, Atobe.
Dialogue: 0,0:05:18.51,0:05:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi bantuan akan datang.
Dialogue: 0,0:05:20.42,0:05:23.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kujaga kamu sampai bantuan datang.
Dialogue: 0,0:05:23.01,0:05:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bisakah kamu bergabung\Ndengan party-ku?
Dialogue: 0,0:05:27.79,0:05:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melakukan hal yang aneh,
Dialogue: 0,0:05:30.27,0:05:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan melaporkanmu.
Dialogue: 0,0:05:49.29,0:05:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini parah sekali.
Dialogue: 0,0:05:50.62,0:05:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan membawanya ke tempat Healer.
Dialogue: 0,0:05:57.17,0:05:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:06:01.30,0:06:03.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami bertemu monster bernama.
Dialogue: 0,0:06:03.67,0:06:06.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monsternya berbahaya,\Ntapi kami bisa mengatasinya.
Dialogue: 0,0:06:06.26,0:06:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster bernama?
Dialogue: 0,0:06:08.16,0:06:10.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan, Watadama merah?
Dialogue: 0,0:06:10.53,0:06:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster itu bahkan bisa\Nmengalahkan party level 3, lo.
Dialogue: 0,0:06:14.31,0:06:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kamu mengalahkannya?
Dialogue: 0,0:06:16.86,0:06:19.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku banyak bicara.
Dialogue: 0,0:06:19.11,0:06:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:21.28,0:06:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Elitia, kamu siapa?
Dialogue: 0,0:06:24.53,0:06:26.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Arihito.
Dialogue: 0,0:06:26.56,0:06:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah, kamu Suzuna, kan?
Dialogue: 0,0:06:29.66,0:06:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar.
Dialogue: 0,0:06:31.01,0:06:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, orang yang dibawa tadi itu,
Dialogue: 0,0:06:34.00,0:06:36.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah orang\Nyang bereinkarnasi bersama kita?
Dialogue: 0,0:06:36.88,0:06:39.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi tenang saja.
Dialogue: 0,0:06:39.63,0:06:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang pingsan,\Ntapi vitalitasnya sudah pulih.
Dialogue: 0,0:06:46.14,0:06:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang ingin kamu tanyakan?
Dialogue: 0,0:06:48.30,0:06:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak, bukan apa-apa.
Dialogue: 0,0:06:50.51,0:06:51.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti itulah,
Dialogue: 0,0:06:51.77,0:06:55.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku suka heboh kalau ada garda belakang\Nyang serbabisa begitu.
Dialogue: 0,0:06:57.40,0:07:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia sedang mencari\Ngarda belakang yang andal.
Dialogue: 0,0:07:01.73,0:07:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku menjelaskan\Nkelas pekerjaanku di sini,
Dialogue: 0,0:07:04.36,0:07:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia pasti akan mengajakku berparty dengannya.
Dialogue: 0,0:07:07.03,0:07:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, untuk saat ini\Nprioritasku adalah Kepala dulu.
Dialogue: 0,0:07:11.74,0:07:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku permisi dulu.
Dialogue: 0,0:07:13.91,0:07:15.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, baik.
Dialogue: 0,0:07:15.21,0:07:17.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita juga pergi, Suzuna.
Dialogue: 0,0:07:19.63,0:07:20.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami duluan.
Dialogue: 0,0:07:26.43,0:07:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum juga lewat setengah hari,
Dialogue: 0,0:07:28.18,0:07:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berani sekali kalian\Nsudah bertarung dan kembali.
Dialogue: 0,0:07:31.35,0:07:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, serahkan senjata\Nyang kamu gunakan ke tukang.
Dialogue: 0,0:07:39.06,0:07:41.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang ingin kamu sampaikan?
Dialogue: 0,0:07:57.42,0:08:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kamu disukai olehnya.
Dialogue: 0,0:08:00.88,0:08:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:08:04.09,0:08:06.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Leila,
Dialogue: 0,0:08:06.00,0:08:10.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah secara resmi tentara bayaran\Nbisa dimasukkan ke dalam party?
Dialogue: 0,0:08:11.39,0:08:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya Theresia?
Dialogue: 0,0:08:18.19,0:08:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harganya seratus tiket perunggu.
Dialogue: 0,0:08:21.65,0:08:23.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa menjalin kontrak dengannya.
Dialogue: 0,0:08:23.75,0:08:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, aku hanya beri tahu orang\Nyang menyewa tentara bayaran manusia,
Dialogue: 0,0:08:27.85,0:08:30.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi biar aku sampaikan padamu juga.
Dialogue: 0,0:08:31.53,0:08:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seratus, ya.
Dialogue: 0,0:08:34.15,0:08:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa menjadikannya rekan party-ku,
Dialogue: 0,0:08:36.83,0:08:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku rasa itu tidak mahal.
Dialogue: 0,0:08:38.46,0:08:41.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski baru sekali menjelajah,
Dialogue: 0,0:08:41.03,0:08:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku sangat membutuhkannya\Nuntuk bekerja sama denganku.
Dialogue: 0,0:08:46.13,0:08:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Atobe.
Dialogue: 0,0:08:47.55,0:08:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang terluka?
Dialogue: 0,0:08:49.30,0:08:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Anda terkena racun?
Dialogue: 0,0:08:50.68,0:08:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang terlihat, aku tidak terluka.
Dialogue: 0,0:08:53.43,0:08:55.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, syukurlah.
Dialogue: 0,0:08:57.06,0:09:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Louisa, boleh aku membisikkan\Nsesuatu sebentar?
Dialogue: 0,0:09:01.31,0:09:03.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik.
Dialogue: 0,0:09:05.07,0:09:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasil dari penjelajahan kali ini:
Dialogue: 0,0:09:07.79,0:09:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menumpaskan monster Red Face,
Dialogue: 0,0:09:10.70,0:09:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hadiah sebesar 20 koin emas,
Dialogue: 0,0:09:12.91,0:09:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kontribusi yang didapatkan...
Dialogue: 0,0:09:17.04,0:09:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat! Luar biasa!
Dialogue: 0,0:09:19.29,0:09:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontribusi tertinggi saya\Nsaat masih aktif dulu hanya 105.
Dialogue: 0,0:09:22.79,0:09:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Level saya pun baru naik ke level 2
Dialogue: 0,0:09:25.71,0:09:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setelah mengalahkan 50 watadama.
Dialogue: 0,0:09:27.88,0:09:32.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Louisa, apa arti dari "tingkat kepercayaan"\Nyang tertulis di situ?
Dialogue: 0,0:09:32.84,0:09:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Guild, membangun hubungan\Nyang baik dengan orang lain
Dialogue: 0,0:09:37.85,0:09:40.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga dinilai sebagai poin kontribusi.
Dialogue: 0,0:09:41.44,0:09:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, kepercayaan tidak bisa diukur\Ndengan angka,
Dialogue: 0,0:09:45.36,0:09:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi lisensi akan mengevaluasi\Nkondisi anggota di dalam party
Dialogue: 0,0:09:48.86,0:09:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengubahnya menjadi angka.
Dialogue: 0,0:09:51.20,0:09:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tingkat kepercayaan tersebut\Nmemengaruhi poin kontribusi.
Dialogue: 0,0:09:56.12,0:09:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, biasanya dalam sekali menjelajah,
Dialogue: 0,0:09:59.16,0:10:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}paling banyak hanya dapat 5.
Dialogue: 0,0:10:02.04,0:10:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan ini 50?
Dialogue: 0,0:10:04.33,0:10:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seberapa dekat hubungan yang Anda buat\Ndalam waktu sesingkat ini?
Dialogue: 0,0:10:07.92,0:10:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini angka yang besar, lo!
Dialogue: 0,0:10:11.59,0:10:14.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walah, pantas saja.
Dialogue: 0,0:10:14.39,0:10:17.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindakan Theresia tadi...
Dialogue: 0,0:10:18.22,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar bisa berperan sebagai garda belakang,
Dialogue: 0,0:10:20.77,0:10:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus menjaga hubungan baik\Ndengan garda depan dan tengah.
Dialogue: 0,0:10:24.00,0:10:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya, makin banyak memberi dukungan,
Dialogue: 0,0:10:26.86,0:10:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}makin cepat pula mereka menyukaiku?
Dialogue: 0,0:10:31.24,0:10:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukankah itu bahaya?
Dialogue: 0,0:10:33.86,0:10:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya tingkat kepercayaan terhadap\Nsetengah manusia tidak akan naik.
Dialogue: 0,0:10:38.71,0:10:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja,\Npekerjaan Tuan Atobe yang misterius ini
Dialogue: 0,0:10:41.79,0:10:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah salah satu kelas pekerjaan\Ngarda belakang terkuat di dunia.
Dialogue: 0,0:10:47.75,0:10:49.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi...
Dialogue: 0,0:10:49.96,0:10:53.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, maaf, Louisa,
Dialogue: 0,0:10:53.11,0:10:56.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong rahasiakan ini dulu dari yang lain.
Dialogue: 0,0:10:56.26,0:10:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:10:58.72,0:11:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kemampuan Tuan Atobe\Nsampai tersebar luas,
Dialogue: 0,0:11:01.06,0:11:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa muncul orang\Nyang ingin memanfaatkannya.
Dialogue: 0,0:11:05.14,0:11:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mengerti.
Dialogue: 0,0:11:06.65,0:11:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak.
Dialogue: 0,0:11:08.15,0:11:09.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun,
Dialogue: 0,0:11:09.69,0:11:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}peringkat Tuan Atobe saat ini
Dialogue: 0,0:11:11.40,0:11:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah peringkat ke 137.529 secara keseluruhan,
Dialogue: 0,0:11:14.99,0:11:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan peringkat ke 1.124 di Distrik 8.
Dialogue: 0,0:11:18.07,0:11:21.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena jumlah penjelajah di Distrik 8\Nada sekitar 3.000 orang,
Dialogue: 0,0:11:21.37,0:11:23.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda sudah berada di paruh atas.
Dialogue: 0,0:11:23.56,0:11:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk akomodasi, Anda akan menempati\NSuite Room di penginapan di Distrik 8.
Dialogue: 0,0:11:28.08,0:11:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suite Room?
Dialogue: 0,0:11:31.05,0:11:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:11:32.09,0:11:37.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengenai Nona Kyouka Igarashi\Nyang tadi di bawa ke tempat Healer,
Dialogue: 0,0:11:37.01,0:11:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kabarnya beliau sudah sadar\Ndi ruang perawatan darurat.
Dialogue: 0,0:11:44.52,0:11:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:11:47.52,0:11:50.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah, aku sempat khawatir\Nakan bagaimana.
Dialogue: 0,0:11:50.36,0:11:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mengira akan mati.
Dialogue: 0,0:11:53.80,0:11:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menyelamatkanku, Atobe.
Dialogue: 0,0:11:57.74,0:12:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau orang lain tahu\Nkamu mengalahkan monster bernama,
Dialogue: 0,0:12:01.12,0:12:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan berebut merekrutmu.\Npara party penjelajah papan atas
Dialogue: 0,0:12:05.15,0:12:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung melonjak jadi orang penting.
Dialogue: 0,0:12:08.87,0:12:10.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibandingkan denganku,
Dialogue: 0,0:12:10.96,0:12:14.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tumbang dalam pertempuran,\Ndiselamatkan oleh pendukung,
Dialogue: 0,0:12:14.35,0:12:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak dapat poin kontribusi.
Dialogue: 0,0:12:18.22,0:12:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memilih kelas pekerjaan hanya karena keren,
Dialogue: 0,0:12:20.72,0:12:22.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak bisa mendapatkan rekan,
Dialogue: 0,0:12:22.85,0:12:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengira bisa bertahan sendirian,
Dialogue: 0,0:12:25.49,0:12:27.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pada akhirnya tidak bisa apa-apa.
Dialogue: 0,0:12:28.44,0:12:30.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku waktu itu,
Dialogue: 0,0:12:30.25,0:12:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala yang tidak melarikan diri itu\Nterlihat keren.
Dialogue: 0,0:12:35.69,0:12:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu juga yang memicu semangatku.
Dialogue: 0,0:12:38.15,0:12:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa mengalahkan monster itu pun\Nrasanya karena sedang beruntung saja.
Dialogue: 0,0:12:44.37,0:12:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, Kepala...
Dialogue: 0,0:12:47.25,0:12:48.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak keberatan,
Dialogue: 0,0:12:48.58,0:12:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maukah Kepala bergabung dengan party-ku?
Dialogue: 0,0:12:52.21,0:12:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dirasa aku tidak layak\Njadi rekan satu tim,
Dialogue: 0,0:12:55.59,0:12:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan keluar kapan saja.
Dialogue: 0,0:12:58.44,0:13:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu aku akan berusaha sebaik mungkin.
Dialogue: 0,0:13:05.14,0:13:09.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ditolong, disemangati pula.
Dialogue: 0,0:13:09.27,0:13:14.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menerima semua itu,
Dialogue: 0,0:13:14.19,0:13:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak mungkin aku tidak tahu diri\Ndengan menolak ajakanmu.
Dialogue: 0,0:13:17.48,0:13:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jadi, apakah itu artinya "iya"?
Dialogue: 0,0:13:25.08,0:13:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, terima kasih banyak.
Dialogue: 0,0:13:27.29,0:13:28.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:13:28.04,0:13:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Atobe.
Dialogue: 0,0:13:31.21,0:13:34.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berhenti memanggilku Kepala?
Dialogue: 0,0:13:36.96,0:13:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau begitu,
Dialogue: 0,0:13:39.05,0:13:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Igarashi.
Dialogue: 0,0:13:40.51,0:13:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa terasa geli.
Dialogue: 0,0:13:42.71,0:13:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mulai sekarang mohon bantuannya, ya.
Dialogue: 0,0:13:51.35,0:13:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana pendukung\Nyang tak tanggung-tanggung?
Dialogue: 0,0:13:56.94,0:13:59.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti iklan sampo.
Dialogue: 0,0:14:01.24,0:14:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh tidak apa-apa?
Dialogue: 0,0:14:02.99,0:14:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginap bersama di tempatmu.
Dialogue: 0,0:14:06.41,0:14:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:14:07.64,0:14:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan terima tawaranmu.
Dialogue: 0,0:14:14.00,0:14:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mampir dulu?
Dialogue: 0,0:14:15.79,0:14:17.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh?
Dialogue: 0,0:14:22.13,0:14:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai pakaian begitu juga, ya.
Dialogue: 0,0:14:24.43,0:14:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf,
Dialogue: 0,0:14:25.64,0:14:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}soalnya aku hanya pernah melihatmu\Npakai setelan jas.
Dialogue: 0,0:14:28.45,0:14:30.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar juga.
Dialogue: 0,0:14:30.32,0:14:32.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi kita tak pernah bertemu\Ndi luar kantor.
Dialogue: 0,0:14:32.89,0:14:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, pergi minum bersama\Njuga tidak pernah.
Dialogue: 0,0:14:37.06,0:14:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah,
Dialogue: 0,0:14:38.15,0:14:42.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kurasa kita tak pernah mengobrol\Ndi luar urusan pekerjaan.
Dialogue: 0,0:14:43.28,0:14:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya ini cerita yang memalukan.
Dialogue: 0,0:14:48.03,0:14:50.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya batas jam malam.
Dialogue: 0,0:14:50.62,0:14:53.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus pulang sebelum jam tertentu.
Dialogue: 0,0:14:53.41,0:14:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:14:55.37,0:14:59.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berpikir\Naku ini wanita yang sudah dewasa.
Dialogue: 0,0:14:59.03,0:15:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena hidupku\Nselalu ditentukan orang tuaku,
Dialogue: 0,0:15:02.13,0:15:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi tak bisa memutuskan.
Dialogue: 0,0:15:04.04,0:15:05.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan belakangan,
Dialogue: 0,0:15:05.43,0:15:09.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}muncul pembicaraan tentang perjodohanku\Ndengan rekan bisnis ayahku.
Dialogue: 0,0:15:09.68,0:15:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perjodohan?
Dialogue: 0,0:15:11.45,0:15:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keterlaluan sekali, kan?
Dialogue: 0,0:15:13.45,0:15:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, akhirnya aku sadar dalam hati kecilku
Dialogue: 0,0:15:17.20,0:15:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa aku tak bisa terus begini.
Dialogue: 0,0:15:19.48,0:15:22.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu aku membangun karier\Nagar bisa mandiri.
Dialogue: 0,0:15:22.05,0:15:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap hari berjuang agar orang tuaku\Ntidak bisa ikut campur urusanku lagi.
Dialogue: 0,0:15:33.83,0:15:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu banyak bicara.
Dialogue: 0,0:15:36.83,0:15:38.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:15:38.04,0:15:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:15:40.34,0:15:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku rasa dia hanya ingin
Dialogue: 0,0:15:42.32,0:15:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menjaga hidupnya dengan caranya sendiri.
Dialogue: 0,0:15:45.88,0:15:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski hanya sedikit,
Dialogue: 0,0:15:47.69,0:15:50.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku senang bisa mengetahui tentangmu.
Dialogue: 0,0:15:51.60,0:15:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mulai sekarang\Nkita adalah rekan satu party.
Dialogue: 0,0:15:55.00,0:15:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:15:56.39,0:15:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, kita makan sebelum dingin.
Dialogue: 0,0:15:59.07,0:16:00.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kamu dengar?
Dialogue: 0,0:16:00.81,0:16:04.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya si Death Sword datang ke Distrik 8.
Dialogue: 0,0:16:04.07,0:16:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, si Elitia itu, ya?
Dialogue: 0,0:16:07.03,0:16:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia menangkap seorang pemula
Dialogue: 0,0:16:09.20,0:16:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melatihnya agar bisa digunakan.
Dialogue: 0,0:16:11.89,0:16:14.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka membicarakan soal Elitia dan Suzuna?
Dialogue: 0,0:16:14.54,0:16:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kabur dari Byakuya Rhodan\Nsampai ke tempat seperti ini, ya.
Dialogue: 0,0:16:20.79,0:16:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini kesempatan bagus?
Dialogue: 0,0:16:22.88,0:16:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelajah papan atas itu\Nsedang dalam masalah,
Dialogue: 0,0:16:25.55,0:16:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kita manfaatkan...
Dialogue: 0,0:16:26.72,0:16:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, pembicaraan itu untuk nanti saja.
Dialogue: 0,0:16:34.89,0:16:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah.
Dialogue: 0,0:16:41.56,0:16:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:16:43.73,0:16:46.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, selamat tidur.
Dialogue: 0,0:16:51.87,0:16:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Atobe, maaf.
Dialogue: 0,0:16:58.04,0:17:00.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Igarashi?
Dialogue: 0,0:17:00.27,0:17:01.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:17:01.68,0:17:04.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bagaimana aku bilangnya...
Dialogue: 0,0:17:04.04,0:17:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harap kamu tidak tersinggung.
Dialogue: 0,0:17:06.76,0:17:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa tolong tidur dengan membelakangiku?
Dialogue: 0,0:17:10.38,0:17:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}O-Oh, aku tak sengaja berbalik arah.
Dialogue: 0,0:17:13.93,0:17:16.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu ini bukan salahmu.
Dialogue: 0,0:17:16.55,0:17:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau tidur menghadap ke arahku,\Nrasanya jadi kepikiran.
Dialogue: 0,0:17:21.34,0:17:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa aneh dengan diriku sendiri.
Dialogue: 0,0:17:26.78,0:17:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu.
Dialogue: 0,0:17:32.20,0:17:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garda belakang, Pemulihan Dukungan Lv. 1.
Dialogue: 0,0:17:34.95,0:17:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, kalau posisi kami begini,
Dialogue: 0,0:17:36.95,0:17:38.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia jadi depan dan aku belakang.
Dialogue: 0,0:17:41.00,0:17:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf.
Dialogue: 0,0:17:43.04,0:17:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan tidur di ruang tamu.
Dialogue: 0,0:17:50.01,0:17:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemulihan Dukungan Lv. 1 ini\Nterus aktif bahkan di waktu normal?
Dialogue: 0,0:17:55.05,0:17:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok aku harus pindahkan\Ntempat tidurku ke ruangan lain.
Dialogue: 0,0:18:04.90,0:18:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf,
Dialogue: 0,0:18:05.61,0:18:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku terlambat memperkenalkan diri.
Dialogue: 0,0:18:08.52,0:18:10.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kyouka Igarashi.
Dialogue: 0,0:18:10.75,0:18:14.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih\Nsudah menolongku kemarin, Theresia.
Dialogue: 0,0:18:16.83,0:18:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku berbuat salah?
Dialogue: 0,0:18:18.99,0:18:22.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, pasti bukan karena itu, kok.
Dialogue: 0,0:18:22.00,0:18:23.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi jangan dipikirkan.
Dialogue: 0,0:18:26.00,0:18:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi.
Dialogue: 0,0:18:27.29,0:18:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal pemotongan monster\Ndan permintaan perlengkapan kemarin.
Dialogue: 0,0:18:35.68,0:18:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia mendapat Red Buckler\Ndengan ketahanan atribut api.
Dialogue: 0,0:18:39.47,0:18:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Igarashi mendapat syal\Nyang mengurangi DMG atribut api.
Dialogue: 0,0:18:43.44,0:18:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Slingshot milikku mengubah tembakan\Nmenjadi Blaze Shot.
Dialogue: 0,0:18:47.77,0:18:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung tepat waktu, ya.
Dialogue: 0,0:18:49.35,0:18:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyerahkan Red Face ke tempat jagal kemarin\Nadalah keputusan tepat.
Dialogue: 0,0:18:55.03,0:19:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan perlengkapan ini,\Naku ingin kalian berdua menjadi garda depan.
Dialogue: 0,0:19:03.50,0:19:04.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Igarashi, aku beri dukungan!
Dialogue: 0,0:19:12.96,0:19:14.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan!
Dialogue: 0,0:19:15.18,0:19:18.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sip, dukungannya aktif\Nuntuk semua garda depan.
Dialogue: 0,0:19:27.73,0:19:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik sana sudah lantai dua.
Dialogue: 0,0:19:31.20,0:19:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya mengerikan, ya.
Dialogue: 0,0:19:34.15,0:19:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mendapatkan seratus tiket lebih cepat
Dialogue: 0,0:19:37.81,0:19:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}agar bisa menebus Theresia,
Dialogue: 0,0:19:39.95,0:19:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus bertarung\Nmelawan monster di lantai dua.
Dialogue: 0,0:19:43.92,0:19:45.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi,
Dialogue: 0,0:19:45.13,0:19:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kabarnya belakangan ini
Dialogue: 0,0:19:46.33,0:19:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada monster bernama yang muncul.
Dialogue: 0,0:19:48.85,0:19:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster ganas yang bisa\Nmengalahkan party level 3 atau 4.
Dialogue: 0,0:19:55.13,0:19:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan kami masih level 2.
Dialogue: 0,0:19:57.72,0:20:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertemu makhluk seperti itu,\Nkami pasti kalah.
Dialogue: 0,0:20:01.93,0:20:04.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, Igarashi,
Dialogue: 0,0:20:04.03,0:20:05.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hari ini kita pulang dulu...
Dialogue: 0,0:20:08.40,0:20:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini...
Dialogue: 0,0:20:11.48,0:20:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat!
Dialogue: 0,0:20:21.49,0:20:22.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elitia?
Dialogue: 0,0:20:22.87,0:20:24.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna?
Dialogue: 0,0:20:26.25,0:20:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster yang mereka lawan...
Dialogue: 0,0:20:29.00,0:20:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fang Orc?
Dialogue: 0,0:20:30.88,0:20:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suzuna, mundurlah!
Dialogue: 0,0:20:32.69,0:20:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Slash Ripper!
Dialogue: 0,0:20:41.97,0:20:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Igarashi, Theresia,
Dialogue: 0,0:20:43.68,0:20:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan kutarik perhatian lebahnya ke sini.
Dialogue: 0,0:20:45.89,0:20:47.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:20:50.81,0:20:51.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arihito!
Dialogue: 0,0:20:56.61,0:20:58.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaraknya terlalu jauh.
Dialogue: 0,0:21:00.36,0:21:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan!
Dialogue: 0,0:21:06.54,0:21:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Thunderbolt!
Dialogue: 0,0:21:14.84,0:21:16.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:21:17.03,0:21:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:18.05,0:21:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak apa-apa.
Dialogue: 0,0:21:19.59,0:21:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku benar-benar menjadi beban.
Dialogue: 0,0:21:24.05,0:21:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak benar.
Dialogue: 0,0:21:25.81,0:21:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah berjuang keras,\Nbahkan mengalahkan banyak Watadama.
Dialogue: 0,0:21:29.77,0:21:31.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:21:31.47,0:21:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agar Suzuna mendapatkan\Nbanyak poin kontribusi,
Dialogue: 0,0:21:34.77,0:21:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian membubarkan party,
Dialogue: 0,0:21:36.23,0:21:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu Elitia memancing musuh
Dialogue: 0,0:21:38.11,0:21:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan membiarkan Suzuna\Nyang membunuhnya, ya.
Dialogue: 0,0:21:40.64,0:21:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:21:41.80,0:21:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, lebah itu juga mengincar Suzuna\Nyang jadi garda belakang.
Dialogue: 0,0:21:45.43,0:21:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah mencari monster lain\Nakan lebih aman?
Dialogue: 0,0:21:49.08,0:21:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma membuang waktu.
Dialogue: 0,0:21:51.41,0:21:55.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus membuat Suzuna sekuat diriku\Nagar aku bisa kembali.
Dialogue: 0,0:21:56.59,0:21:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali?
Dialogue: 0,0:22:00.09,0:22:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya "kembali"?
Dialogue: 0,0:22:01.60,0:22:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau salah,\Nmaksudmu ke Byakuya Rhodan, ya?
