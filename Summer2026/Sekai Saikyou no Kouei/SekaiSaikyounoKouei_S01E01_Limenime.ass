Dialogue: 0,0:15:34.96,0:15:37.58,sign,,0000,0000,0000,,GARDA BELAKANG TERKUAT DI DUNIA\N~PENJELAJAH PEMULA DI NEGERI LABIRIN~
Dialogue: 0,0:19:27.35,0:19:27.81,sign,,0000,0000,0000,,MONSTER YANG DITEMUKAN: WATADAMA, LV. 1
Dialogue: 0,0:19:27.81,0:19:30.69,sign,,0000,0000,0000,,DROP: ???, STATUS: WASPADA
Dialogue: 0,0:20:22.62,0:20:23.33,sign,,0000,0000,0000,,PERTAHANAN DUKUNGAN LV. 1
Dialogue: 0,0:20:23.33,0:20:27.04,sign,,0000,0000,0000,,MENGURANGI 10 POIN DMG YANG DITERIMA REKAN
Dialogue: 0,0:20:35.84,0:20:37.34,sign,,0000,0000,0000,,PERTAHANAN DUKUNGAN LV. 1
Dialogue: 0,0:22:04.39,0:22:05.72,sign,,0000,0000,0000,,BOOMERANG DIVE
Dialogue: 0,0:00:22.38,0:00:23.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:00:24.25,0:00:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini serius?
Dialogue: 0,0:00:25.71,0:00:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku tidak bisa hidup kembali?
Dialogue: 0,0:00:28.13,0:00:30.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah,
Dialogue: 0,0:00:30.97,0:00:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau pergi bermain ski\Ndengan teman-teman sekantor.
Dialogue: 0,0:00:38.48,0:00:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini artinya bus yang aku naiki\Nmengalami kecelakaan?
Dialogue: 0,0:00:41.94,0:00:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, ingatanku...
Dialogue: 0,0:00:44.48,0:00:48.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa orang-orang yang di sini\Njuga sudah mati?
Dialogue: 0,0:00:49.30,0:00:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi?
Dialogue: 0,0:00:55.91,0:00:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya akan dipandu sesuai giliran.
Dialogue: 0,0:00:58.75,0:01:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tenang dan majulah.
Dialogue: 0,0:01:08.34,0:01:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia juga di sini?
Dialogue: 0,0:01:10.30,0:01:12.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, selanjutnya.
Dialogue: 0,0:01:14.39,0:01:16.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan Arihito Atobe, benar?
Dialogue: 0,0:01:17.02,0:01:18.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya?
Dialogue: 0,0:01:18.76,0:01:20.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan bawa ini.
Dialogue: 0,0:01:22.52,0:01:25.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah sampai di dunia sana,\Nsilakan pergi ke Guild
Dialogue: 0,0:01:25.32,0:01:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mendapatkan kelas pekerjaannya, ya.
Dialogue: 0,0:01:27.57,0:01:28.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Guild?
Dialogue: 0,0:01:30.45,0:01:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah...
Dialogue: 0,0:01:40.58,0:01:43.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Negeri Labirin.
Dialogue: 0,0:03:34.78,0:03:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini Guild?
Dialogue: 0,0:03:38.03,0:03:41.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik aku masuk dulu\Nseperti yang diperintahkan.
Dialogue: 0,0:03:51.17,0:03:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak itu...
Dialogue: 0,0:03:53.05,0:03:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tak salah, dia satu bus denganku.
Dialogue: 0,0:03:56.09,0:04:00.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Suzuna Shiromiya,\Nterima kasih telah mengisi formulirnya.
Dialogue: 0,0:04:00.26,0:04:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pekerjaan yang Anda inginkan\Nadalah Gadis Kuil.
Dialogue: 0,0:04:04.22,0:04:06.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat.
Dialogue: 0,0:04:06.11,0:04:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menilai kecocokannya,\Npermintaan tersebut diterima.
Dialogue: 0,0:04:14.32,0:04:16.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa minta waktunya?
Dialogue: 0,0:04:18.91,0:04:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ada apa?
Dialogue: 0,0:04:21.45,0:04:24.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru datang di kota ini.
Dialogue: 0,0:04:24.33,0:04:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu.
Dialogue: 0,0:04:25.29,0:04:27.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena mendaftar di sini,
Dialogue: 0,0:04:27.66,0:04:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}artinya kamu pemula\Nyang baru saja bereinkarnasi.
Dialogue: 0,0:04:31.58,0:04:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencari orang\Nuntuk posisi garda belakang.
Dialogue: 0,0:04:34.67,0:04:38.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai garda depan,\Naku punya beberapa kekurangan.
Dialogue: 0,0:04:38.01,0:04:41.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini agak sulit bagi seorang pemula,
Dialogue: 0,0:04:41.97,0:04:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei, si Elitia itu\N- ta-tapi, setelah masuk party,
Dialogue: 0,0:04:44.14,0:04:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- sedang merekrut orang lagi.\N- ta-tapi, setelah masuk party,
Dialogue: 0,0:04:45.72,0:04:48.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kira-kira dia bakal bertahan berapa hari, ya?\N- aku yakin kamu akan cepat naik level.
Dialogue: 0,0:04:49.02,0:04:52.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, aku mohon,\Nbentuklah party bersamaku!
Dialogue: 0,0:04:54.69,0:04:56.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau sekuat apa pun dia,
Dialogue: 0,0:04:56.32,0:04:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau masih punya "itu", membentuk party\Ndengan siapa pun hasilnya akan sama.
Dialogue: 0,0:05:01.49,0:05:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Itu"?
Dialogue: 0,0:05:07.70,0:05:10.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mohon bantuannya.
Dialogue: 0,0:05:11.29,0:05:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sung-Sungguh?
Dialogue: 0,0:05:15.04,0:05:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih!
Dialogue: 0,0:05:16.88,0:05:18.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, langsung saja,
Dialogue: 0,0:05:18.76,0:05:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita minum teh dulu, yuk.
Dialogue: 0,0:05:21.43,0:05:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan,
Dialogue: 0,0:05:23.22,0:05:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bawa lisensi\Nyang belum teregistrasi, bukan?
Dialogue: 0,0:05:25.72,0:05:27.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benar.
Dialogue: 0,0:05:27.77,0:05:29.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan, sebelah sini.
Dialogue: 0,0:05:32.81,0:05:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya petugas pendaftaran petualang
Dialogue: 0,0:05:36.64,0:05:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta pendamping pemula sebagai penasihat,
Dialogue: 0,0:05:39.85,0:05:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}nama saya Louisa Falmel.
Dialogue: 0,0:05:42.61,0:05:46.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Negeri Labirin, ada peraturan\Nbahwa siapa pun yang tidak terdaftar,
Dialogue: 0,0:05:46.78,0:05:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak diperkenankan memasuki labirin,
Dialogue: 0,0:05:50.84,0:05:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi silakan tunjukkan lisensinya.
Dialogue: 0,0:05:53.87,0:05:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, sebelumnya, ini tempat apa?
Dialogue: 0,0:05:56.79,0:06:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negeri Labirin itu maksudnya apa?
Dialogue: 0,0:06:00.09,0:06:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negeri Labirin adalah negeri\Nyang dihuni para penjelajah labirin
Dialogue: 0,0:06:04.55,0:06:07.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan orang-orang yang mendukung\Npekerjaan tersebut.
Dialogue: 0,0:06:07.72,0:06:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka yang bereinkarnasi ke Negeri Labirin
Dialogue: 0,0:06:10.77,0:06:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menjalani kehidupan baru\Ndi sini sebagai penjelajah.
Dialogue: 0,0:06:16.02,0:06:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reinkarnasi... Penjelajah?
Dialogue: 0,0:06:19.61,0:06:20.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:06:20.94,0:06:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata waktu itu aku benar-benar mati, ya.
Dialogue: 0,0:06:25.32,0:06:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tuan?
Dialogue: 0,0:06:27.78,0:06:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena baru saja bereinkarnasi,
Dialogue: 0,0:06:29.53,0:06:31.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin ingatan Anda jadi kacau.
Dialogue: 0,0:06:31.66,0:06:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf karena saya langsung\Nmembicarakan banyak hal.
Dialogue: 0,0:06:35.01,0:06:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Anda ingin diperiksa oleh Healer?
Dialogue: 0,0:06:37.13,0:06:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak usah.
Dialogue: 0,0:06:39.80,0:06:42.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sedikit sakit kepala saja.
Dialogue: 0,0:06:43.30,0:06:47.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku harus mendaftar dulu, ya?
Dialogue: 0,0:06:49.06,0:06:53.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam lisensi Anda,\Nada kolom yang masih kosong.
Dialogue: 0,0:06:53.73,0:06:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan tulis pekerjaan\Nyang sesuai kemampuan
Dialogue: 0,0:06:57.31,0:07:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau pekerjaan yang ingin Anda tekuni.
Dialogue: 0,0:07:01.44,0:07:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan memilih pekerjaan\Nyang sudah ditentukan, ya?
Dialogue: 0,0:07:04.90,0:07:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena orang-orang yang bereinkarnasi\Nmemiliki latar belakang yang beragam,
Dialogue: 0,0:07:09.03,0:07:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hal ini dibuat agar sesuai\Npengalaman mereka.
Dialogue: 0,0:07:12.13,0:07:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti penentuan akan seperti apa\Nkehidupanku di sini,
Dialogue: 0,0:07:15.87,0:07:19.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bergantung dari pekerjaan yang aku pilih.
Dialogue: 0,0:07:19.34,0:07:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan dipikirkan dulu baik-baik.
Dialogue: 0,0:07:23.96,0:07:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pekerjaan, ya?
Dialogue: 0,0:07:27.39,0:07:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe!
Dialogue: 0,0:07:28.72,0:07:30.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya ide proyek yang bagus!
Dialogue: 0,0:07:30.72,0:07:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampaikan saja pendapatmu.
Dialogue: 0,0:07:33.22,0:07:35.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya nanti bakal diloloskan!
Dialogue: 0,0:07:35.69,0:07:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum bereinkarnasi,
Dialogue: 0,0:07:36.98,0:07:38.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bekerja di perusahaan yang suram
Dialogue: 0,0:07:38.85,0:07:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diperas habis-habisan\Noleh atasan muda elite.
Dialogue: 0,0:07:43.61,0:07:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah Negeri Labirin,\Ndunia lain tempatku bereinkarnasi.
Dialogue: 0,0:07:47.57,0:07:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kini aku tidak harus bekerja\Ndi bawah bos gila kerja itu
Dialogue: 0,0:07:50.78,0:07:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terbebas dari belenggu dunia korporat.
Dialogue: 0,0:07:59.92,0:08:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saat ini, aku ingin bersiap\Nsupaya bisa menjalaninya dengan santai.
Dialogue: 0,0:08:04.71,0:08:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe.
Dialogue: 0,0:08:08.18,0:08:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah!
Dialogue: 0,0:08:10.14,0:08:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi?
Dialogue: 0,0:08:11.72,0:08:13.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya, "Lah!"
Dialogue: 0,0:08:13.89,0:08:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, bukan.
Dialogue: 0,0:08:15.22,0:08:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada di sini, Anda juga...
Dialogue: 0,0:08:18.27,0:08:23.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku mati dan bereinkarnasi ke sini.
Dialogue: 0,0:08:23.53,0:08:28.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilihat dari mana pun,\Nsemuanya seperti dunia cosplay.
Dialogue: 0,0:08:28.15,0:08:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memulai hidup baru di sini, ya.
Dialogue: 0,0:08:33.49,0:08:36.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau harus bertarung melawan monster,
Dialogue: 0,0:08:36.95,0:08:38.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya aku belum siap.
Dialogue: 0,0:08:38.71,0:08:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, monster?
Dialogue: 0,0:08:41.08,0:08:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, itu salah satu tugas\Norang yang bereinkarnasi.
Dialogue: 0,0:08:45.09,0:08:47.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini, kelas pekerjaan kita
Dialogue: 0,0:08:47.17,0:08:50.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dengan siapa kita membentuk party\Nsangatlah penting.
Dialogue: 0,0:08:50.97,0:08:53.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:08:53.05,0:08:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atobe, kamu belum menentukan\Nkelas pekerjaanmu?
Dialogue: 0,0:08:56.99,0:09:02.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, sih, aku ingin kamu mengambil\Nkelas pekerjaan yang bisa membantuku.
Dialogue: 0,0:09:02.94,0:09:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, apa kelas pekerjaanmu, Kepala?
Dialogue: 0,0:09:06.03,0:09:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku? Kalau aku...
Dialogue: 0,0:09:09.15,0:09:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar,
Dialogue: 0,0:09:10.61,0:09:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita ini sudah bukan atasan\Ndan bawahan lagi.
Dialogue: 0,0:09:14.58,0:09:17.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, jangan panggil aku Kepala.
Dialogue: 0,0:09:19.00,0:09:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lu-Lupakan saja.
Dialogue: 0,0:09:21.29,0:09:23.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pekerjaanku adalah Valkyrie.
Dialogue: 0,0:09:23.83,0:09:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pakai pedang dan tombak,
Dialogue: 0,0:09:25.50,0:09:28.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta sihir roh sampai tingkat tertentu.
Dialogue: 0,0:09:28.30,0:09:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pekerjaanmu luar biasa juga, ya.
Dialogue: 0,0:09:31.30,0:09:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pikir akan lebih baik\Nkalau bisa melakukan berbagai hal.
Dialogue: 0,0:09:34.76,0:09:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, pembagian peran\Ndalam party itu penting,
Dialogue: 0,0:09:38.60,0:09:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sebisa mungkin\Njangan ambil peran yang sama.
Dialogue: 0,0:09:41.68,0:09:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:09:42.77,0:09:45.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memberitahuku.
Dialogue: 0,0:09:45.33,0:09:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan ambil pekerjaan\Nyang berguna untuk party lain.
Dialogue: 0,0:09:48.98,0:09:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Party lain?
Dialogue: 0,0:09:50.69,0:09:53.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Itu, maksudku...
Dialogue: 0,0:09:53.91,0:09:57.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita sama-sama masih selamat,
Dialogue: 0,0:09:57.16,0:09:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari bertemu kembali di lain kesempatan,
Dialogue: 0,0:09:59.41,0:10:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi.
Dialogue: 0,0:10:03.00,0:10:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:10:03.96,0:10:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Naku juga harus segera cari party lain juga.
Dialogue: 0,0:10:13.68,0:10:17.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya dia berbeda dari sebelumnya.
Dialogue: 0,0:10:18.48,0:10:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pasti baik-baik saja.
Dialogue: 0,0:10:20.95,0:10:23.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NSudah menentukan pilihan?
Dialogue: 0,0:10:23.73,0:10:26.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, sebentar.
Dialogue: 0,0:10:26.11,0:10:27.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalau begitu,
Dialogue: 0,0:10:27.86,0:10:31.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}biar saya jelaskan sedikit\Ntentang kelas pekerjaan.
Dialogue: 0,0:10:31.19,0:10:35.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pekerjaan sangat berpengaruh pada\Ntingkat kontribusi seorang penjelajah.
Dialogue: 0,0:10:35.99,0:10:37.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingkat kontribusi?
Dialogue: 0,0:10:37.16,0:10:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misalnya membawa pulang harta langka,
Dialogue: 0,0:10:39.72,0:10:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengalahkan monster yang kuat,
Dialogue: 0,0:10:41.75,0:10:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau menyelamatkan rekan.
Dialogue: 0,0:10:43.92,0:10:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Intinya poin yang didapat\Ndari tindakan-tindakan tersebut.
Dialogue: 0,0:10:48.38,0:10:49.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu,
Dialogue: 0,0:10:50.21,0:10:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jumlah poin yang dimiliki itu,
Dialogue: 0,0:10:52.21,0:10:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan menentukan peringkat para penjelajah.
Dialogue: 0,0:10:55.89,0:10:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halaman ini
Dialogue: 0,0:10:57.01,0:11:01.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah bagian dari catatan aktivitas\Nyang dilakukan di dalam labirin.
Dialogue: 0,0:11:01.27,0:11:04.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Rasanya seperti tablet, ya.
Dialogue: 0,0:11:04.73,0:11:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peringkat ini menentukan hidup\Ndi Negeri Labirin.
Dialogue: 0,0:11:07.98,0:11:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti tempat tinggal, makanan, pakaian,\Ndan berbagai hal lainnya.
Dialogue: 0,0:11:12.61,0:11:14.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di peringkat paling bawah,
Dialogue: 0,0:11:14.28,0:11:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda bahkan harus tinggal di kandang kuda.
Dialogue: 0,0:11:16.95,0:11:19.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya agak keterlaluan.
Dialogue: 0,0:11:20.08,0:11:21.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Louisa,
Dialogue: 0,0:11:21.33,0:11:25.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah posisi garda belakang\Nbanyak dicari bahkan untuk pemula?
Dialogue: 0,0:11:25.04,0:11:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:11:26.12,0:11:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi tersebut sangat penting dalam party,
Dialogue: 0,0:11:28.50,0:11:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi dibanding garda depan atau tengah,
Dialogue: 0,0:11:30.54,0:11:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}stamina dan pertahanannya rendah,
Dialogue: 0,0:11:32.55,0:11:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga tingkat kelangsungan hidup\Nselama lima tahun cenderung rendah.
Dialogue: 0,0:11:36.01,0:11:37.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu,
Dialogue: 0,0:11:37.30,0:11:40.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}posisi garda belakang selalu banyak dicari.
Dialogue: 0,0:11:40.72,0:11:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau permintaannya tinggi,
Dialogue: 0,0:11:42.47,0:11:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski berisiko,\Nsepertinya masih layak untuk dipilih.
Dialogue: 0,0:11:46.89,0:11:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kira-kira garda belakang\Nyang bisa aku ambil itu apa, ya?
Dialogue: 0,0:11:50.69,0:11:52.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku tulis langsung "garda belakang",
Dialogue: 0,0:11:52.94,0:11:55.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah akan dicarikan posisi\Ngarda belakang yang cocok?
Dialogue: 0,0:12:06.12,0:12:08.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, ya.
Dialogue: 0,0:12:09.83,0:12:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang Anda tulis di sini?
Dialogue: 0,0:12:12.88,0:12:14.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garda belakang.
Dialogue: 0,0:12:24.56,0:12:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, Tuan Atobe.
Dialogue: 0,0:12:27.14,0:12:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permohonan Anda telah diterima.
Dialogue: 0,0:12:32.06,0:12:34.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tu-Tunggu dulu, Louisa.
Dialogue: 0,0:12:36.49,0:12:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, apa kelas pekerjaanku?
Dialogue: 0,0:12:39.07,0:12:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Seperti yang ditulis, "garda belakang".
Dialogue: 0,0:12:41.91,0:12:44.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, jadi garda belakang itu sendiri.
Dialogue: 0,0:12:45.41,0:12:49.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, saya belum pernah\Nmelihat tulisan seperti ini.
Dialogue: 0,0:12:49.25,0:12:51.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya tulisan apa pun akan terbaca
Dialogue: 0,0:12:51.88,0:12:53.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tertulis sebagaimana mestinya.
Dialogue: 0,0:12:53.88,0:12:57.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini kelas pekerjaan\Nyang belum pernah ada...
Dialogue: 0,0:12:57.01,0:13:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi saya memang bilang ini pekerjaan\Ndengan permintaan yang tinggi,
Dialogue: 0,0:13:01.34,0:13:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi sepertinya akan sulit mencari party.
Dialogue: 0,0:13:06.72,0:13:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena saya merasa bertanggung jawab\Natas saran sebelumnya,
Dialogue: 0,0:13:10.35,0:13:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saya akan memberi perlakuan khusus.
Dialogue: 0,0:13:12.94,0:13:15.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Anda memahami\Nkelebihan kelas pekerjaan ini,
Dialogue: 0,0:13:15.86,0:13:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan gunakan "Tiket Tentara Bayaran" ini.
Dialogue: 0,0:13:24.12,0:13:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan yang bisa aku pakai...
Dialogue: 0,0:13:28.25,0:13:32.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}10 poin DMG itu sebesar apa?
Dialogue: 0,0:13:32.46,0:13:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga belakang ini...
Dialogue: 0,0:13:34.88,0:13:39.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan untuk garda belakang\Nyang memiliki daya tahan rendah, ya.
Dialogue: 0,0:13:39.76,0:13:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya akan berguna.
Dialogue: 0,0:13:41.63,0:13:45.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi untuk permulaan,\Naku ambil Pertahanan Dukungan Lv. 1,
Dialogue: 0,0:13:45.26,0:13:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu setelah mengujinya,
Dialogue: 0,0:13:46.97,0:13:50.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baru ambil Pemulihan Dukungan Lv. 1\Nuntuk memulihkan diri.
Dialogue: 0,0:13:50.07,0:13:52.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, yang ini nanti saja.
Dialogue: 0,0:13:52.48,0:13:53.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cari tahu dulu
Dialogue: 0,0:13:53.81,0:13:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah ada ramuan penyembuh\Natau cara pemulihan lain.
Dialogue: 0,0:13:57.27,0:14:01.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku alokasikan\Nke Pertahanan Dukungan Lv. 1 dulu.
Dialogue: 0,0:14:04.07,0:14:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terasa ada perubahan yang berarti.
Dialogue: 0,0:14:07.37,0:14:11.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau membentuk party,\Nmungkin akan terlihat
Dialogue: 0,0:14:11.00,0:14:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahwa pilihanku berguna\Natau malah sia-sia.
Dialogue: 0,0:14:20.63,0:14:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Leila.
Dialogue: 0,0:14:22.76,0:14:25.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wakil Kepala penyalur\Ntentara bayaran di sini.
Dialogue: 0,0:14:26.47,0:14:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku ingin meminta bantuan\Nmengenai tiket ini.
Dialogue: 0,0:14:30.39,0:14:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiket itu hanya bisa\Nmerekrut Setengah Manusia.
Dialogue: 0,0:14:32.95,0:14:37.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memungkinkan, aku ingin yang bisa\Ndi garda depan dan menggunakan perisai.
Dialogue: 0,0:14:37.11,0:14:38.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:38.55,0:14:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini yang tersisa\Nadalah Lizardman perempuan.
Dialogue: 0,0:14:42.03,0:14:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lizardman?
Dialogue: 0,0:14:43.86,0:14:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pekerjaannya "Rogue".
Dialogue: 0,0:14:45.32,0:14:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa pakai senjata pada tingkat tertentu,\Ndan membawa perisai kecil dari kulit.
Dialogue: 0,0:14:49.93,0:14:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau untuk menjelajah\Nlantai pertama Padang Fajar,
Dialogue: 0,0:14:52.87,0:14:55.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya sudah cukup mumpuni.
Dialogue: 0,0:14:55.03,0:14:56.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi begitu.
Dialogue: 0,0:14:56.33,0:15:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, aku akan melawan monster lemah
Dialogue: 0,0:15:00.09,0:15:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk menguji Pertahanan Dukungan Lv. 1.
Dialogue: 0,0:15:03.42,0:15:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan memilih Lizardman itu.
Dialogue: 0,0:15:06.80,0:15:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:12.68,0:15:15.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lizardman, ya.
Dialogue: 0,0:15:15.81,0:15:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin seperti ini, ya?
Dialogue: 0,0:15:20.13,0:15:21.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:15:31.70,0:15:34.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu kehormatan jadi garda belakang.
Dialogue: 0,0:15:37.58,0:15:39.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:15:40.88,0:15:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Theresia.
Dialogue: 0,0:15:43.76,0:15:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak perempuan... manusia?
Dialogue: 0,0:15:46.88,0:15:49.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, mantan manusia.
Dialogue: 0,0:15:50.22,0:15:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setengah Manusia adalah
Dialogue: 0,0:15:51.64,0:15:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}manusia yang berubah wujud\Nsetelah dikalahkan monster dalam labirin.
Dialogue: 0,0:15:57.23,0:15:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah,
Dialogue: 0,0:15:58.44,0:16:02.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di Negeri Labirin ini, orang mati diyakini\Ntidak bisa dihidupkan lagi.
Dialogue: 0,0:16:02.82,0:16:04.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika bisa lepas dari wujud ini,
Dialogue: 0,0:16:04.53,0:16:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin dia bisa kembali seperti semula.
Dialogue: 0,0:16:07.24,0:16:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mereka diperlakukan sebagai Lizardman?
Dialogue: 0,0:16:11.51,0:16:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penggunaan segel perbudakan terhadap\NSetengah Manusia itu dilarang.
Dialogue: 0,0:16:16.91,0:16:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami pun jadi tidak bisa berkomunikasi.
Dialogue: 0,0:16:19.33,0:16:23.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada dasarnya,\Nmereka bertindak atas perintah orang lain.
Dialogue: 0,0:16:23.92,0:16:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, saat bertarung, mereka akan\Nbertindak secara mandiri sesuai naluri.
Dialogue: 0,0:16:29.12,0:16:32.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak terpikir\Nakan seperti ini.
Dialogue: 0,0:16:33.72,0:16:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, namaku Arihito.
Dialogue: 0,0:16:36.96,0:16:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal, Theresia.
Dialogue: 0,0:16:47.90,0:16:49.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku punya senjata,
Dialogue: 0,0:16:49.86,0:16:52.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan akhirnya mulai terasa\Nseperti seorang penjelajah.
Dialogue: 0,0:16:53.45,0:16:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi menyuruh anak ini bertarung\Nmembuatku merasa bersalah.
Dialogue: 0,0:16:58.58,0:17:02.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menemukan monster lemah\Nuntuk menguji kemampuanku,
Dialogue: 0,0:17:02.13,0:17:04.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bakal langsung pulang saja.
Dialogue: 0,0:17:06.13,0:17:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi itu labirin pertama, Padang Fajar.
Dialogue: 0,0:17:14.01,0:17:16.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, pemula lagi, ya?
Dialogue: 0,0:17:17.31,0:17:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama-sama orang Jepang seperti Valkyrie\Nyang di party tadi, ya?
Dialogue: 0,0:17:21.23,0:17:23.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, si wanita cantik itu.
Dialogue: 0,0:17:23.19,0:17:25.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Valkyrie orang Jepang?
Dialogue: 0,0:17:25.92,0:17:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya soal Kepala Igarashi.
Dialogue: 0,0:17:28.40,0:17:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah membentuk party, ya?
Dialogue: 0,0:17:31.01,0:17:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Rival.
Dialogue: 0,0:17:32.73,0:17:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pekerjaanku adalah\Nmenyelamatkan para penjelajah
Dialogue: 0,0:17:35.08,0:17:38.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terjebak di labirin tingkat pertama.
Dialogue: 0,0:17:38.50,0:17:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Halo.
Dialogue: 0,0:17:40.27,0:17:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Arihito.
Dialogue: 0,0:17:42.37,0:17:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salam kenal.
Dialogue: 0,0:17:44.58,0:17:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Tuan Rival.
Dialogue: 0,0:17:46.46,0:17:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Menyelamatkan" berarti\Ndi dalam labirin itu berbahaya, ya?
Dialogue: 0,0:17:50.84,0:17:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga selama kamu\Ntidak salah memilih lawan.
Dialogue: 0,0:17:54.05,0:17:56.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kamu bawa tentara bayaran.
Dialogue: 0,0:17:56.72,0:17:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lawannya monster level rendah,
Dialogue: 0,0:17:59.18,0:18:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}asal berhati-hati,\Npasti bisa kembali dengan selamat.
Dialogue: 0,0:18:04.40,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:18:05.52,0:18:07.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berhati-hatilah terhadap monster bernama.
Dialogue: 0,0:18:07.89,0:18:09.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster bernama?
Dialogue: 0,0:18:09.23,0:18:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau pemula bertemu dengannya,\Nhampir pasti akan terbunuh.
Dialogue: 0,0:18:13.70,0:18:15.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larilah kalau melihatnya.
Dialogue: 0,0:18:15.75,0:18:17.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbunuh?
Dialogue: 0,0:18:17.54,0:18:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:18:19.13,0:18:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah memberi tahu\Nhal sepenting ini.
Dialogue: 0,0:18:22.87,0:18:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada orang lain\Nyang menjelajah di dalam.
Dialogue: 0,0:18:25.29,0:18:28.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau dirasa berbahaya,\Npanggil saja kami.
Dialogue: 0,0:18:28.17,0:18:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berpatroli secara berkala,\Ntapi kadang ada saja yang terlewat.
Dialogue: 0,0:18:32.09,0:18:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:18:36.09,0:18:37.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:18:38.14,0:18:39.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia.
Dialogue: 0,0:18:39.89,0:18:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:19:22.18,0:19:24.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bola berbulu itu juga monster?
Dialogue: 0,0:19:27.81,0:19:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Watadama level 1?
Dialogue: 0,0:19:33.15,0:19:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster yang dibicarakan Tuan Rival tadi, ya?
Dialogue: 0,0:19:45.21,0:19:46.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila.
Dialogue: 0,0:19:46.71,0:19:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Level 1 saja sudah sekuat ini?
Dialogue: 0,0:19:49.17,0:19:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ki-Kita mundur dulu, Theresia.
Dialogue: 0,0:19:53.96,0:19:54.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia?
Dialogue: 0,0:19:57.59,0:20:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyawanya langsung terkuras banyak!
Dialogue: 0,0:20:01.35,0:20:01.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:20:11.44,0:20:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang aku lakukan?
Dialogue: 0,0:20:13.16,0:20:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai dilindungi anak perempuan sekecil itu!
Dialogue: 0,0:20:16.36,0:20:17.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus berbuat sesuatu.
Dialogue: 0,0:20:17.86,0:20:19.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa yang bisa kulakukan?
Dialogue: 0,0:20:19.69,0:20:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai garda belakang...
Dialogue: 0,0:20:23.33,0:20:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertahanan Dukungan?
Dialogue: 0,0:20:25.50,0:20:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga!
Dialogue: 0,0:20:31.84,0:20:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Theresia, aku beri dukungan!
Dialogue: 0,0:20:39.09,0:20:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus. Theresia,
Dialogue: 0,0:20:40.55,0:20:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serang setelah aku melepas tembakanku!
Dialogue: 0,0:20:57.40,0:20:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ber-Berhasil?
Dialogue: 0,0:21:03.03,0:21:06.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku gunakan kemampuanku sejak awal.
Dialogue: 0,0:21:07.29,0:21:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukamu tidak apa-apa?
Dialogue: 0,0:21:09.04,0:21:11.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita keluar dulu untuk memulihkanmu.
Dialogue: 0,0:21:15.92,0:21:17.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Theresia.
Dialogue: 0,0:21:17.92,0:21:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jujur saja, aku tidak benar-benar\Nmemikirkan soal bertarung
Dialogue: 0,0:21:21.18,0:21:23.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau kemungkinan mati.
Dialogue: 0,0:21:23.99,0:21:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sekarang aku mengerti.
Dialogue: 0,0:21:26.89,0:21:29.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah melindungiku.
Dialogue: 0,0:21:29.01,0:21:32.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai sekarang, aku juga akan melindungimu.
Dialogue: 0,0:21:37.11,0:21:38.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:21:43.57,0:21:45.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi?
Dialogue: 0,0:21:45.66,0:21:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Party dia sedang bertarung?
Dialogue: 0,0:21:55.13,0:21:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Red Face!
Dialogue: 0,0:21:56.67,0:21:57.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:21:57.93,0:22:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus bertemu monster bernama?
Dialogue: 0,0:22:00.55,0:22:02.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster bernama?
Dialogue: 0,0:22:07.22,0:22:08.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Igarashi!
