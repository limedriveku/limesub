Dialogue: 0,0:13:26.79,0:13:27.16,sign,,0000,0000,0000,,PENJAGA BELAKANG
Dialogue: 0,0:13:27.16,0:13:28.25,sign,,0000,0000,0000,,MENGGUNAKAN 5 POIN MP UNTUK\NMEMPERLUAS PANDANGAN SELAMA BEBERAPA WAKTU
Dialogue: 0,0:13:56.73,0:13:57.27,sign,,0000,0000,0000,,PERTAHANAN DUKUNGAN LV. 1\NMENGURANGI 10 POIN DMG YANG DITERIMA REKAN
