Dialogue: 0,0:00:38.83,0:00:40.37,sign,,0000,0000,0000,,KESATRIA KELAS BERAT
Dialogue: 0,0:03:00.74,0:03:03.41,sign,,0000,0000,0000,,KESATRIA KELAS BERAT TEREINKARNASI YANG DIASINGKAN\NJADI TANPA TANDING DENGAN PENGETAHUAN GIMNYA
Dialogue: 0,0:04:15.11,0:04:19.02,sign,,0000,0000,0000,,EPISODE 3:\NMISI PENYERBUAN: MISI SKALA BESAR
Dialogue: 0,0:08:32.65,0:08:33.49,sign,,0000,0000,0000,,PESIMIS
Dialogue: 0,0:08:40.08,0:08:40.88,sign,,0000,0000,0000,,AROGAN
Dialogue: 0,0:14:38.57,0:14:40.32,sign,,0000,0000,0000,,PARRY [SKILL BIASA]
Dialogue: 0,0:14:40.32,0:14:43.33,sign,,0000,0000,0000,,MENANGKIS SERANGAN LAWAN DENGAN PEDANG
Dialogue: 0,0:14:43.33,0:14:45.07,sign,,0000,0000,0000,,ATAU PERISAI UNTUK MEMBUAT CELAH
Dialogue: 0,0:15:20.32,0:15:21.86,sign,,0000,0000,0000,,TOLAKAN TEMBOK BENTENG
Dialogue: 0,0:16:13.20,0:16:16.12,sign,,0000,0000,0000,,MENDAPAT 1 SKILL POINT
Dialogue: 0,0:16:27.97,0:16:29.72,sign,,0000,0000,0000,,KELAS: KESATRIA KELAS BERAT LV. 16\NELYMAS EDVAUGHN
Dialogue: 0,0:16:29.72,0:16:30.89,sign,,0000,0000,0000,,DAYA SERANG: 13 (+5), DAYA PERTAHANAN: 34 (+5)\NDAYA SIHIR: 15, KECEPATAN: 15
Dialogue: 0,0:16:30.89,0:16:32.39,sign,,0000,0000,0000,,SKILL - JULUKAN
Dialogue: 0,0:18:47.06,0:18:49.57,sign,,0000,0000,0000,,PENGHANCUR BATU
Dialogue: 0,0:18:59.70,0:19:01.62,sign,,0000,0000,0000,,MONSTER: GHOUL HEAD
Dialogue: 0,0:21:21.26,0:21:22.55,sign,,0000,0000,0000,,GHOUL HEAD TELAH MENGALAMI
Dialogue: 0,0:21:22.55,0:21:23.55,sign,,0000,0000,0000,,EVOLUSI EKSISTENSI MENJADI MAD HEADDER
Dialogue: 0,0:00:38.83,0:00:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kelas Berat.
Dialogue: 0,0:00:40.37,0:00:44.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas ahli pertahanan\Nyang bertugas menarik serangan musuh
Dialogue: 0,0:00:44.19,0:00:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk melindungi rekan-rekannya.
Dialogue: 0,0:00:47.61,0:00:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, bila dibandingkan\Nkelas pertahanan lainnya,
Dialogue: 0,0:00:50.91,0:00:53.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kemampuannya sulit diaplikasikan.
Dialogue: 0,0:00:54.16,0:00:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemampuan serangnya juga terlalu rendah\Nsehingga sulit naik level.
Dialogue: 0,0:01:02.54,0:01:04.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah...
Dialogue: 0,0:01:05.30,0:01:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disebut kelas cacat\Nyang melebihi sebuah kesialan.
Dialogue: 0,0:01:56.72,0:01:59.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar di misi penyerbuan kali ini,
Dialogue: 0,0:01:59.77,0:02:03.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada petualang konyol yang ikut serta.
Dialogue: 0,0:02:03.81,0:02:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu orangnya, Elymas?
Dialogue: 0,0:02:06.81,0:02:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar juga nyalimu.
Dialogue: 0,0:02:08.44,0:02:12.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pemula yang meremehkan\Nserikat dan monster sepertimu.
Dialogue: 0,0:02:12.82,0:02:16.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengalahkan Ariandype di level 12?
Dialogue: 0,0:02:16.70,0:02:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan omong kosongmu!
Dialogue: 0,0:02:18.99,0:02:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang tidaklah seremeh itu!
Dialogue: 0,0:02:21.58,0:02:24.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kugembleng lagi nyalimu itu!
Dialogue: 0,0:02:40.77,0:02:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keterlaluan.
Dialogue: 0,0:04:46.75,0:04:48.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keterlaluan.
Dialogue: 0,0:04:49.23,0:04:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, misi penyerbuan yang punya\Nkesempatan menaikkan rank,
Dialogue: 0,0:04:53.23,0:04:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sayang dilewatkan karena jarang ada.
Dialogue: 0,0:04:57.81,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini aku harus...
Dialogue: 0,0:05:00.78,0:05:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon bimbingannya.
Dialogue: 0,0:05:12.42,0:05:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menyukaimu, tapi sudahlah.
Dialogue: 0,0:05:15.07,0:05:18.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Teal!\NCepat mulai!
Dialogue: 0,0:05:19.34,0:05:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, Gowtan.
Dialogue: 0,0:05:28.52,0:05:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Search!
Dialogue: 0,0:05:34.98,0:05:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Search.
Dialogue: 0,0:05:36.23,0:05:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill untuk memastikan keberadaan\Nmakhluk hidup di sekitar.
Dialogue: 0,0:05:40.11,0:05:43.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill yang jarang diperoleh di level rendah.
Dialogue: 0,0:05:56.50,0:06:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kawanan monster musuh,\Njumlahnya sekitar 30.
Dialogue: 0,0:06:01.22,0:06:03.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerja bagus, Teal!
Dialogue: 0,0:06:03.68,0:06:08.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja, aku memang punya\Nskill yang berguna.
Dialogue: 0,0:06:08.64,0:06:12.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tolong setujui aku\Nnaik ke Kelas E, ya.
Dialogue: 0,0:06:16.02,0:06:18.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah? Wah!
Dialogue: 0,0:06:18.27,0:06:20.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perilaku anehmu di serikat.
Dialogue: 0,0:06:20.40,0:06:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maksudku tindakanmu\Ncukup jadi buah bibir, Elymas.
Dialogue: 0,0:06:26.53,0:06:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat perlengkapannya,\Nmungkin Penyihir Merah.
Dialogue: 0,0:06:30.66,0:06:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau semua rumor itu benar adanya,\N- Punya kekuatan fisik yang tinggi,
Dialogue: 0,0:06:33.16,0:06:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- aku ingin bilang prestasimu luar biasa.\N- sihir serangan, sihir penyembuhan,
Dialogue: 0,0:06:35.42,0:06:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, sayang, sungguh sayang.\N- juga bisa menguasai
Dialogue: 0,0:06:37.04,0:06:38.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, sayang, sungguh sayang.\N- berbagai sihir pendukung.
Dialogue: 0,0:06:38.84,0:06:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali dirimu dapat kelas apes itu.
Dialogue: 0,0:06:42.88,0:06:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas perhatianmu.
Dialogue: 0,0:06:45.72,0:06:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku menyukai kelas ini.
Dialogue: 0,0:06:58.65,0:07:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sok kuat.
Dialogue: 0,0:07:00.86,0:07:03.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, berjuanglah biar tidak jadi beban.
Dialogue: 0,0:07:07.87,0:07:12.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh dibilang,\NPenyihir Merah itu kelas yang lebih sulit.
Dialogue: 0,0:07:13.08,0:07:17.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyihir Merah memang sekilas\Nterlihat kuat dan bisa segalanya.
Dialogue: 0,0:07:17.29,0:07:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, di gim disebut sebagai\N"Palugada Serbatanggung".
Dialogue: 0,0:07:21.84,0:07:24.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi, dunia ini bukanlah gim.
Dialogue: 0,0:07:24.45,0:07:28.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar saja kalau kelas yang mudah\Ndipakai itu banyak disukai.
Dialogue: 0,0:07:35.18,0:07:37.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupastikan sekali lagi!
Dialogue: 0,0:07:37.35,0:07:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang memimpin kawanan Undead\Nkali ini adalah Ghoul Head!
Dialogue: 0,0:07:42.15,0:07:43.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu musuh kuat.
Dialogue: 0,0:07:43.69,0:07:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku, sebagai petualang kelas D\Nyang memburunya!
Dialogue: 0,0:07:47.28,0:07:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian jaga jarak dan buru keroconya saja!
Dialogue: 0,0:07:49.45,0:07:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu rencananya?\N- Aku tidak mau bertarung!
Dialogue: 0,0:07:50.99,0:07:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian sampai ikut kena,\Ntidak bakal kutolong!
Dialogue: 0,0:07:54.41,0:07:55.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serius?\N- Aku mundur saja.
Dialogue: 0,0:07:55.96,0:07:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan bakal fokus melawan bosnya?
Dialogue: 0,0:07:59.21,0:08:02.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira kita cukup berdiri di samping dia?
Dialogue: 0,0:08:07.55,0:08:11.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghoul Head, perkiraan levelnya sekitar 30.
Dialogue: 0,0:08:11.27,0:08:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak punya skill serangan,
Dialogue: 0,0:08:12.93,0:08:17.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi bisa menciptakan Wight level rendah\Ndengan Napas Hades miliknya.
Dialogue: 0,0:08:18.64,0:08:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, kami ada Gowtan,\Npetualang Kelas D yang levelnya sekitar 40.
Dialogue: 0,0:08:24.57,0:08:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berjalan sesuai rencana,\Nharusnya tidak akan kalah.
Dialogue: 0,0:08:29.91,0:08:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:31.03,0:08:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti mati.
Dialogue: 0,0:08:32.65,0:08:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bakal mati.
Dialogue: 0,0:08:33.49,0:08:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ghoul Head itu terlalu kuat.\N- Pesimis.
Dialogue: 0,0:08:37.03,0:08:39.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dasar petualang kelas teri.\N- Bareng Gowtan memang mantap.
Dialogue: 0,0:08:40.88,0:08:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arogan.
Dialogue: 0,0:08:43.21,0:08:46.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para pemula yang mengira misi penyerbuan\Nadalah kerjaan gampang,
Dialogue: 0,0:08:46.55,0:08:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditambah komandan serampangan\Nyang tidak jago mengayomi.
Dialogue: 0,0:08:51.55,0:08:54.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluang semua bisa selamat sekitar 80%, ya.
Dialogue: 0,0:08:56.02,0:08:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu angka yang sudah cukup kalau di gim,
Dialogue: 0,0:08:58.52,0:09:01.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi di dunia ini risikonya\Nbukan cuma penalti kematian.
Dialogue: 0,0:09:08.57,0:09:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan.
Dialogue: 0,0:09:11.32,0:09:15.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah sebaiknya arahanmu\Ndiberikan lebih detail lagi?
Dialogue: 0,0:09:20.21,0:09:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:09:21.54,0:09:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kawanan Undead, tidak ada jaminan\Nsama dengan yang dilaporkan.
Dialogue: 0,0:09:26.50,0:09:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan terlambat kalau\Nsituasinya terlanjur buruk.
Dialogue: 0,0:09:31.05,0:09:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bicara apa dia?
Dialogue: 0,0:09:32.84,0:09:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak perlu kasih masukan!\N- Kesatria Kelas Berat!
Dialogue: 0,0:09:34.30,0:09:36.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah sinting, kah?
Dialogue: 0,0:09:38.52,0:09:42.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berani memerintahku?
Dialogue: 0,0:09:51.15,0:09:52.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:09:53.45,0:09:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelku masih rendah,
Dialogue: 0,0:09:55.49,0:09:58.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pengalaman bertualang juga minim,\Njadi aku cemas.
Dialogue: 0,0:10:00.50,0:10:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lain kurang lebih juga begitu.
Dialogue: 0,0:10:03.44,0:10:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mata veteran, mungkin ini\Nmisi biasa yang mudah,
Dialogue: 0,0:10:08.09,0:10:10.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi tolong beri arahan untuk kami.
Dialogue: 0,0:10:15.72,0:10:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak suka mengasuh amatiran,\Ntapi apa boleh buat!
Dialogue: 0,0:10:19.35,0:10:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, hei.
Dialogue: 0,0:10:21.90,0:10:24.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang untuk kami?
Dialogue: 0,0:10:27.57,0:10:33.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang takut sama Undead keroco\Npaling cuma kelas apes seperti Elymas.
Dialogue: 0,0:10:33.82,0:10:39.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah takut sebelum dimulai\Nlalu merengek ke Gowtan rupanya.
Dialogue: 0,0:10:41.70,0:10:43.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga takut!
Dialogue: 0,0:10:48.54,0:10:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu memberi arahan, Gowtan.
Dialogue: 0,0:10:52.97,0:10:58.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau takut, lari saja ke garis belakang\Nkarena cuma bakal ganggu.
Dialogue: 0,0:10:58.23,0:11:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah begitu, Gowtan?
Dialogue: 0,0:11:08.34,0:11:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan munculnya?
Dialogue: 0,0:11:46.02,0:11:50.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu memberi arahan, Gowtan.
Dialogue: 0,0:11:50.77,0:11:55.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau takut, lari saja ke garis belakang\Nkarena cuma bakal ganggu.
Dialogue: 0,0:11:55.99,0:11:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah begitu, Gowtan?
Dialogue: 0,0:12:33.69,0:12:35.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:12:35.11,0:12:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kalian?
Dialogue: 0,0:12:36.40,0:12:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teal! Paul!
Dialogue: 0,0:12:38.03,0:12:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian buka jalan untukku!
Dialogue: 0,0:12:41.07,0:12:42.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikuti aku!
Dialogue: 0,0:12:42.28,0:12:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baik!
Dialogue: 0,0:12:44.83,0:12:46.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih!
Dialogue: 0,0:12:57.80,0:13:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gada yang dipegang bukan item unik.
Dialogue: 0,0:13:01.97,0:13:04.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti tidak ada masalah.
Dialogue: 0,0:13:06.52,0:13:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugas kita membereskan keroco\Nyang mengelilingi kepala besar itu.
Dialogue: 0,0:13:10.10,0:13:11.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:13:11.40,0:13:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menerjang ke kerumunan\Nmonster sebanyak itu?
Dialogue: 0,0:13:16.69,0:13:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau cuma Wight, kalau terkepung\Ntetap tidak akan selamat!
Dialogue: 0,0:13:20.90,0:13:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada Gowtan, kukira dia\Nyang akan membuyarkan musuh.
Dialogue: 0,0:13:24.66,0:13:27.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, malah kelihatan mau fokus ke bos.
Dialogue: 0,0:13:28.04,0:13:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:13:29.66,0:13:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Mustahil! Mustahil!
Dialogue: 0,0:13:31.58,0:13:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja mereka terlihat sangat pasif.
Dialogue: 0,0:13:34.00,0:13:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja!
Dialogue: 0,0:13:36.17,0:13:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua baru pertama kali\Nmelawan kerumunan monster.
Dialogue: 0,0:13:41.18,0:13:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lawannya juga tipe Undead\Nyang menyeramkan.
Dialogue: 0,0:13:44.30,0:13:46.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah situasi tanpa arahan.
Dialogue: 0,0:13:47.35,0:13:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham kenapa mereka gentar.
Dialogue: 0,0:13:51.69,0:13:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku!
Dialogue: 0,0:13:54.40,0:13:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo berpencar dengan regu berisi tiga orang.
Dialogue: 0,0:13:57.11,0:13:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh?
Dialogue: 0,0:13:57.90,0:14:01.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama saling melindungi,\Nkita tidak akan kalah dari Wight.
Dialogue: 0,0:14:08.66,0:14:10.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Baiklah!
Dialogue: 0,0:14:10.37,0:14:13.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan melakukan itu!\NTapi, kamu sendiri...
Dialogue: 0,0:14:13.75,0:14:16.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memancing Undead di lini depan.
Dialogue: 0,0:14:16.29,0:14:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengulur waktu untuk kalian menata formasi.
Dialogue: 0,0:14:20.01,0:14:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kelihatan sudah terbiasa,\Ntapi maju sendirian itu gegabah!
Dialogue: 0,0:14:23.63,0:14:25.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan keburu buat disembuhkan.
Dialogue: 0,0:14:25.76,0:14:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, Kesatria Kelas Berat\Nyang lamban sepertimu—
Dialogue: 0,0:14:34.44,0:14:35.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:14:38.57,0:14:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill: Parry.
Dialogue: 0,0:14:40.32,0:14:43.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangkis serangan lawan dengan pedang
Dialogue: 0,0:14:43.33,0:14:45.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau perisai untuk membuat celah.
Dialogue: 0,0:14:50.79,0:14:52.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:14:53.04,0:14:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:14:56.13,0:14:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:15:00.67,0:15:01.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disarm!
Dialogue: 0,0:15:14.85,0:15:17.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng!
Dialogue: 0,0:15:28.45,0:15:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dibabat habis dalam sekejap?
Dialogue: 0,0:15:31.74,0:15:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja.
Dialogue: 0,0:15:33.29,0:15:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangani jumlah banyak\Nadalah tugas Kesatria Kelas Berat.
Dialogue: 0,0:15:36.42,0:15:40.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terjadi situasi darurat,\Nsegera beri tahu rekan kalian.
Dialogue: 0,0:15:40.88,0:15:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan ikut membantu.
Dialogue: 0,0:15:58.60,0:16:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengalahkan sebagian besar\Nkawanan Wight seorang diri!
Dialogue: 0,0:16:02.52,0:16:05.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya dia Kesatria Kelas Berat, kan?
Dialogue: 0,0:16:13.20,0:16:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah naik ke level 16.
Dialogue: 0,0:16:16.54,0:16:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus, ternyata Parry lebih efektif\Ndari bayanganku.
Dialogue: 0,0:16:21.42,0:16:22.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:16:22.51,0:16:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat efisien kalau musuhnya banyak\Ndan levelnya rendah.
Dialogue: 0,0:16:26.88,0:16:27.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status.
Dialogue: 0,0:16:30.89,0:16:32.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:16:32.97,0:16:34.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelku naik dengan lancar!
Dialogue: 0,0:16:35.39,0:16:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya tadi bilang mau memancing musuh?
Dialogue: 0,0:16:38.31,0:16:40.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah nyaris menghabisi semuanya sendirian!
Dialogue: 0,0:16:40.73,0:16:43.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya lebih baik berlindung\Ndi belakangnya saja?
Dialogue: 0,0:16:43.15,0:16:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya bisa diandalkan,\Ntapi justru lebih seram dia dari Wight.
Dialogue: 0,0:16:46.65,0:16:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:17:08.83,0:17:10.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lumayan banyak yang sudah dibereskan.
Dialogue: 0,0:17:13.47,0:17:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas, apa kita perlu pergi\Nmembantu Gowtan?
Dialogue: 0,0:17:17.52,0:17:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Level Ghoul Head jauh lebih tinggi dari kita.
Dialogue: 0,0:17:22.49,0:17:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kita serahkan ke Gowtan saja.
Dialogue: 0,0:18:03.98,0:18:05.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum tumbang juga?
Dialogue: 0,0:18:05.52,0:18:07.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar monster keras kepala!
Dialogue: 0,0:18:09.61,0:18:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teal! Paul!
Dialogue: 0,0:18:11.32,0:18:13.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Giring lebih banyak Wight lagi!
Dialogue: 0,0:18:15.45,0:18:17.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa malah ciut begitu?
Dialogue: 0,0:18:17.78,0:18:20.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengecut seperti kalian\Ntidak akan kubiarkan naik kelas!
Dialogue: 0,0:18:20.95,0:18:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku mengerti, tapi...
Dialogue: 0,0:18:23.42,0:18:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau maju lebih dekat\Ndan kena serangan Ghoul Head...
Dialogue: 0,0:18:27.25,0:18:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga bisa membantu dari sini...
Dialogue: 0,0:18:47.06,0:18:49.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghancur Batu!
Dialogue: 0,0:18:57.91,0:18:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status.
Dialogue: 0,0:19:01.62,0:19:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berhasil.
Dialogue: 0,0:19:03.25,0:19:07.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal serangan Gowtan kena sekali lagi,\Nsisa HP miliknya bisa dihabisi.
Dialogue: 0,0:19:08.25,0:19:09.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:14.59,0:19:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wight di sekitar sangat mengganggu.
Dialogue: 0,0:19:18.60,0:19:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Biar kita yang urus Wight itu...
Dialogue: 0,0:19:21.14,0:19:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu dulu.
Dialogue: 0,0:19:54.76,0:19:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dia memulihkan diri!
Dialogue: 0,0:19:56.59,0:19:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punya skill Memakan Mayat, ya.
Dialogue: 0,0:19:59.64,0:20:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill yang memulihkan HP\Nsaat memakan mayat atau Undead.
Dialogue: 0,0:20:03.97,0:20:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill dengan peluang rendah\Nuntuk dimiliki Ghoul Head.
Dialogue: 0,0:20:08.02,0:20:10.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ada yang aneh.
Dialogue: 0,0:20:10.77,0:20:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Memakan Mayat biasa,
Dialogue: 0,0:20:12.61,0:20:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak perlu memakan Undead sebanyak ini\Nuntuk sekali memulihkan diri.
Dialogue: 0,0:20:28.92,0:20:30.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang...
Dialogue: 0,0:20:30.13,0:20:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sudah memulihkan diri,\Ntapi sekarang Wight pengganggu sudah hilang!
Dialogue: 0,0:20:35.71,0:20:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, Gowtan!
Dialogue: 0,0:20:36.84,0:20:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauh dari dia!
Dialogue: 0,0:20:38.55,0:20:41.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan segera kuselesaikan ini!
Dialogue: 0,0:21:17.38,0:21:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghoul Head telah mengalami\NEvolusi Eksistensi menjadi Mad Headder.
Dialogue: 0,0:21:21.26,0:21:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelnya telah naik ke 40.
Dialogue: 0,0:23:11.87,0:23:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster mutasi, Evolusi Eksistensi.
Dialogue: 0,0:23:14.96,0:23:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini situasi paling gawat!
Dialogue: 0,0:23:16.79,0:23:19.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster yang berevolusi\Nmenjadi Mad Headder
Dialogue: 0,0:23:19.90,0:23:22.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}punya kekuatan yang melampaui Gowtan.
Dialogue: 0,0:23:22.17,0:23:25.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan musuh yang bisa ditangani\NKelas F seperti kami.
Dialogue: 0,0:23:25.80,0:23:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kena serangannya sekali saja,\Nakan membuat tewas.
Dialogue: 0,0:23:30.35,0:23:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya: Evolusi Eksistensi.
Dialogue: 0,0:23:33.43,0:23:37.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, justru situasi seperti inilah\Nyang membuat seru!
