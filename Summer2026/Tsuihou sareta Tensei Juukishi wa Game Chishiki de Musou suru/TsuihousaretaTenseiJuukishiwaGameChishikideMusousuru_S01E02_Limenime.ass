Dialogue: 0,0:15:02.05,0:15:06.09,sign,,0000,0000,0000,,TOLAKAN TEMBOK BENTENG
Dialogue: 0,0:15:30.62,0:15:35.37,sign,,0000,0000,0000,,MENDAPAT 4 SKILL POINT
Dialogue: 0,0:15:41.71,0:15:43.80,sign,,0000,0000,0000,,SAAT INI, IKRAR ZIRAH BERAT TIDAK DAPAT
Dialogue: 0,0:15:43.80,0:15:45.97,sign,,0000,0000,0000,,DITINGKATKAN LEBIH JAUH LAGI
Dialogue: 0,0:15:51.43,0:15:54.93,sign,,0000,0000,0000,,IKRAR ZIRAH BERAT TELAH NAIK KE LEVEL 15,
Dialogue: 0,0:15:54.93,0:15:57.31,sign,,0000,0000,0000,,MAKA MENDAPAT SKILL PARRY
Dialogue: 0,0:16:19.46,0:16:21.96,sign,,0000,0000,0000,,STATUS ABNORMAL: RACUN
Dialogue: 0,0:17:13.93,0:17:17.02,sign,,0000,0000,0000,,TOLAKAN TEMBOK BENTENG
Dialogue: 0,0:18:15.57,0:18:17.58,sign,,0000,0000,0000,,FORMULIR PENDAFTARAN\NSERIKAT PETUALANG RONDALM
Dialogue: 0,0:18:23.50,0:18:26.79,sign,,0000,0000,0000,,KELAS F, ELYMAS, TELAH DISETUJUI
Dialogue: 0,0:18:30.71,0:18:32.01,sign,,0000,0000,0000,,KELAS S, KELAS A, KELAS B, KELAS C
Dialogue: 0,0:18:32.01,0:18:35.01,sign,,0000,0000,0000,,KELAS D, KELAS E, KELAS F
Dialogue: 0,0:18:40.97,0:18:41.50,sign,,0000,0000,0000,,SAAT INI, IKRAR ZIRAH BERAT
Dialogue: 0,0:18:41.50,0:18:43.14,sign,,0000,0000,0000,,TIDAK DAPAT DITINGKATKAN LEBIH JAUH LAGI
Dialogue: 0,0:18:43.14,0:18:46.90,sign,,0000,0000,0000,,IKRAR ZIRAH BERAT F > E > D
Dialogue: 0,0:19:56.76,0:19:57.37,sign,,0000,0000,0000,,TELAH DISETUJUI
Dialogue: 0,0:20:02.01,0:20:02.51,sign,,0000,0000,0000,,TEKAN UNTUK MEMULAI
Dialogue: 0,0:00:00.31,0:00:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun, tolong aku!
Dialogue: 0,0:00:05.78,0:00:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!\NTolong aku!
Dialogue: 0,0:00:15.54,0:00:18.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal dibunuh!\NAku bakal dibunuh!
Dialogue: 0,0:00:19.33,0:00:20.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu petualang?
Dialogue: 0,0:00:20.83,0:00:23.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ku-Kumohon, tolong aku!
Dialogue: 0,0:00:35.47,0:00:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku!
Dialogue: 0,0:00:40.23,0:00:42.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu benaran bisa?
Dialogue: 0,0:00:43.36,0:00:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penampilanmu mewah,\Napa kamu aslinya petualang terkenal?
Dialogue: 0,0:00:48.07,0:00:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:00:52.66,0:00:56.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi baru pertama kalinya naik level.
Dialogue: 0,0:00:56.83,0:00:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Berarti kamu payah!
Dialogue: 0,0:00:59.79,0:01:03.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan jauh lebih lemah dariku!
Dialogue: 0,0:01:03.04,0:01:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pe-Pemula mana bisa membasmi\Nmonster sebanyak itu!
Dialogue: 0,0:01:06.71,0:01:08.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lepaskan zirah beratmu itu!
Dialogue: 0,0:01:08.92,0:01:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ayo lari!
Dialogue: 0,0:01:13.05,0:01:15.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng tidaklah\Nsakti mandraguna.
Dialogue: 0,0:01:16.26,0:01:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menangkal kerusakan dengan daya pertahanan\Nyang jauh di atas daya serang musuh.
Dialogue: 0,0:01:21.48,0:01:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak dibuat menerima kerusakan,\Nefeknya tidak bisa menyala.
Dialogue: 0,0:01:29.03,0:01:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:01:37.79,0:01:40.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mempan pada lawan lebih kuat\Ndan musuh tidak dikenal.
Dialogue: 0,0:01:41.33,0:01:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:01:43.37,0:01:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng!
Dialogue: 0,0:01:58.43,0:02:01.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah paham betul\Nsoal musuh di level awal!
Dialogue: 0,0:02:01.43,0:02:05.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya pertahananku sudah kumaksimalkan\Ndengan bonus Skill Tree dan perlengkapan.
Dialogue: 0,0:02:07.44,0:02:10.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau datang berapa puluh ekor pun,\Naku akan menang!
Dialogue: 0,0:02:24.83,0:02:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengalahkan Raana sebanyak itu?
Dialogue: 0,0:02:27.04,0:02:29.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu ini siapa sebenarnya?
Dialogue: 0,0:02:31.71,0:02:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Elymas Edva—
Dialogue: 0,0:02:34.26,0:02:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah melakukan hal memalukan!
Dialogue: 0,0:02:36.74,0:02:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan pernah tunjukkan wajahmu lagi!
Dialogue: 0,0:02:38.72,0:02:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berani sebut\Nnama Edvaughn di luar sana.
Dialogue: 0,0:02:41.35,0:02:45.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu terjadi,\Nlangsung kupenggal kepalamu!
Dialogue: 0,0:02:45.27,0:02:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:02:51.40,0:02:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:02:56.49,0:02:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Elymas si Kesatria Kelas Berat.
Dialogue: 0,0:05:03.99,0:05:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah naik ke level delapan.
Dialogue: 0,0:05:05.83,0:05:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendapat julukan: Yang Tak Tergoyahkan.
Dialogue: 0,0:05:11.67,0:05:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status.
Dialogue: 0,0:05:15.04,0:05:17.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sistem yang ada rasanya bukan masalah
Dialogue: 0,0:05:17.21,0:05:20.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau kuanggap sama seperti Magic World.
Dialogue: 0,0:05:21.30,0:05:22.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas!
Dialogue: 0,0:05:22.80,0:05:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Ares.
Dialogue: 0,0:05:24.85,0:05:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dari desa pinggiran\Nkarena ingin jadi petualang.
Dialogue: 0,0:05:28.77,0:05:30.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu!
Dialogue: 0,0:05:30.02,0:05:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau tidak bisa naik sendiri ke level tiga,\Nkatanya tidak bisa dipercaya.
Dialogue: 0,0:05:36.07,0:05:39.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya aku panik karena\Ntidak bisa bikin grup.
Dialogue: 0,0:05:39.19,0:05:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tertolong.
Dialogue: 0,0:05:43.82,0:05:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin berterima kasih sekali lagi.
Dialogue: 0,0:05:46.86,0:05:48.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak usah bingung buat berterima kasih.
Dialogue: 0,0:05:48.87,0:05:49.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:50.08,0:05:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pas sekali untuk menaikkan levelku.
Dialogue: 0,0:05:52.75,0:05:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, batu sihirnya akan kuambil semua.
Dialogue: 0,0:05:55.30,0:05:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, tidak apa-apa!
Dialogue: 0,0:05:57.50,0:06:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Elymas, setelah kembali nanti,\Nmau tidak kita membuat grup?
Dialogue: 0,0:06:00.97,0:06:02.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya sedikit ide.
Dialogue: 0,0:06:02.88,0:06:06.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sendirian, berarti kamu\Njuga dikucilkan, bukan?
Dialogue: 0,0:06:06.22,0:06:08.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pertahanan memang tidak populer...
Dialogue: 0,0:06:08.43,0:06:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kelas Berat?
Dialogue: 0,0:06:10.64,0:06:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?
Dialogue: 0,0:06:12.02,0:06:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain statusmu di bawah rata-rata,
Dialogue: 0,0:06:13.73,0:06:16.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu boneka kayu yang cuma punya\Nskill serangan tidak berguna!
Dialogue: 0,0:06:16.86,0:06:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak salah lagi, ini kelas cacat!
Dialogue: 0,0:06:22.70,0:06:24.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahanda, tolong tenang dulu!
Dialogue: 0,0:06:24.82,0:06:26.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}HP dan pertahananku tertinggi—
Dialogue: 0,0:06:26.70,0:06:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting sama sekali!
Dialogue: 0,0:06:31.08,0:06:33.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kurasa kamu sangat hebat.
Dialogue: 0,0:06:34.21,0:06:36.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya akan berhasil kalau bersamamu!
Dialogue: 0,0:06:36.83,0:06:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-temanku yang lain pasti\Nakan kubujuk agar setuju!
Dialogue: 0,0:06:41.34,0:06:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tidak perlu.
Dialogue: 0,0:06:43.72,0:06:45.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa?
Dialogue: 0,0:06:45.68,0:06:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari cara bertarung tadi,\Nkamu itu kelas pertahanan, kan?
Dialogue: 0,0:06:48.51,0:06:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelmu tidak akan pernah naik\Nkalau maju sendirian!
Dialogue: 0,0:06:51.93,0:06:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan keras kepala...
Dialogue: 0,0:07:03.36,0:07:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:07:06.66,0:07:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ucapan Ares memang benar.
Dialogue: 0,0:07:09.87,0:07:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umumnya, kelas khusus pertahanan,\Nakan menunjukkan kemampuan sejatinya
Dialogue: 0,0:07:14.16,0:07:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan menarik serangan musuh\Nuntuk melindungi rekannya.
Dialogue: 0,0:07:17.58,0:07:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, cara naik level yang ingin kulakukan,
Dialogue: 0,0:07:20.59,0:07:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}poin pengalaman akan makin terbagi\Nkalau bawa banyak rekan.
Dialogue: 0,0:07:23.96,0:07:25.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadinya tidak menguntungkan.
Dialogue: 0,0:07:26.03,0:07:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin mendapat item,\Nskill, dan julukan.
Dialogue: 0,0:07:30.26,0:07:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak yakin kalau yang lain\Nakan percaya perkataanku.
Dialogue: 0,0:07:34.93,0:07:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, aku...
Dialogue: 0,0:07:38.02,0:07:41.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak boleh terus diam di awal seperti ini!
Dialogue: 0,0:07:42.32,0:07:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk mengeluarkan kekuatan sejati\NKesatria Kelas Berat,
Dialogue: 0,0:07:45.40,0:07:48.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}banyak hal yang harus kulakukan!
Dialogue: 0,0:07:55.54,0:07:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, Elymas, aku bilang begini\Nuntuk kebaikanmu.
Dialogue: 0,0:07:59.83,0:08:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu hebat!
Dialogue: 0,0:08:01.88,0:08:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, caramu yang sekarang\Njelas akan ada batasnya.
Dialogue: 0,0:08:05.05,0:08:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus-terusan memburu Raana\Npasti bosan, kan?
Dialogue: 0,0:08:08.22,0:08:10.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo incar yang lebih tinggi lagi.
Dialogue: 0,0:09:20.37,0:09:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin!
Dialogue: 0,0:09:21.87,0:09:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada di tempat seperti ini?
Dialogue: 0,0:09:29.34,0:09:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status!
Dialogue: 0,0:09:33.14,0:09:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ariandype.
Dialogue: 0,0:09:34.76,0:09:37.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster yang levelnya\Ndua kali lipat diriku sekarang!
Dialogue: 0,0:09:38.18,0:09:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyelinap\Ndengan skill Langkah Senyap, ya.
Dialogue: 0,0:09:41.73,0:09:44.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ditambah racun pengganggu pergerakan.
Dialogue: 0,0:09:44.52,0:09:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, juga punya skill Cakar Api.
Dialogue: 0,0:09:48.32,0:09:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng nyaris tak berdaya\Nmelawan musuh yang lebih kuat.
Dialogue: 0,0:09:52.20,0:09:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak punya pertahanan dua kali lipat\Ndari daya serang musuh,
Dialogue: 0,0:09:55.24,0:09:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}syarat aktivasinya tak akan terpenuhi!
Dialogue: 0,0:09:58.70,0:10:02.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai kena Cakar Api,\Nsekali serang bisa menghabisiku.
Dialogue: 0,0:10:03.50,0:10:05.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, ini salahku!
Dialogue: 0,0:10:05.67,0:10:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menarik perhatiannya!
Dialogue: 0,0:10:13.63,0:10:16.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Biar aku yang menghadapinya!
Dialogue: 0,0:10:16.14,0:10:18.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu larilah selagi sempat!
Dialogue: 0,0:10:18.26,0:10:21.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku...\NBiar aku saja...
Dialogue: 0,0:10:21.48,0:10:23.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tenang saja.
Dialogue: 0,0:10:27.36,0:10:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang melawannya.
Dialogue: 0,0:10:28.77,0:10:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:10:30.07,0:10:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}He-Hei!
Dialogue: 0,0:10:31.36,0:10:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu gegabah, sehebat apa pun dirimu...
Dialogue: 0,0:10:33.78,0:10:34.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:10:38.16,0:10:39.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Musuh pertarungan ini
Dialogue: 0,0:10:41.41,0:10:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukanlah lawan yang tidak bisa dikalahkan!
Dialogue: 0,0:10:44.75,0:10:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ariandype bukan monster\Nyang bisa ditangani pemula!
Dialogue: 0,0:10:48.38,0:10:50.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas, aku tahu kalau kamu hebat!
Dialogue: 0,0:10:50.50,0:10:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, secara logika, kamu tidak berdaya!
Dialogue: 0,0:10:53.76,0:10:55.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status.
Dialogue: 0,0:10:58.97,0:11:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya tujuh skill point\Nyang baru kudapatkan.
Dialogue: 0,0:11:03.39,0:11:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kumasukkan semua poin ini
Dialogue: 0,0:11:06.48,0:11:08.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Ikrar Zirah Berat!
Dialogue: 0,0:11:13.74,0:11:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendapatkan skill Disarm.
Dialogue: 0,0:11:17.70,0:11:19.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disarm adalah skill yang akan menurunkan
Dialogue: 0,0:11:19.58,0:11:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daya serang musuh untuk sesaat,
Dialogue: 0,0:11:21.20,0:11:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bila aku berhasil menyerangnya.
Dialogue: 0,0:11:24.00,0:11:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya, akan turun sebesar 20%\Nselama satu menit penuh.
Dialogue: 0,0:11:28.50,0:11:32.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk mengalahkan Ariandype!\NIni skill yang kubutuhkan
Dialogue: 0,0:11:32.92,0:11:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, Laba-Laba Monyet!
Dialogue: 0,0:11:36.80,0:11:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan jadi lawanmu!
Dialogue: 0,0:11:39.51,0:11:40.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas?
Dialogue: 0,0:11:47.98,0:11:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disarm adalah skill yang akan menurunkan
Dialogue: 0,0:11:50.02,0:11:51.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daya serang musuh untuk sesaat,
Dialogue: 0,0:11:51.40,0:11:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bila aku berhasil menyerangnya.
Dialogue: 0,0:11:54.53,0:11:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepatnya, akan turun sebesar 20%\Nselama satu menit penuh.
Dialogue: 0,0:12:00.87,0:12:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Majulah, Laba-Laba Monyet!
Dialogue: 0,0:12:05.54,0:12:08.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan jadi lawanmu!
Dialogue: 0,0:12:08.71,0:12:10.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Risikonya tinggi tapi sepadan!
Dialogue: 0,0:12:13.21,0:12:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat seperti inilah yang paling seru!
Dialogue: 0,0:12:33.23,0:12:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju sini, Ariandype!
Dialogue: 0,0:12:36.19,0:12:38.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu pola serangan dan jangkauannya.
Dialogue: 0,0:12:39.24,0:12:41.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak akan bisa mengenaiku semudah itu!
Dialogue: 0,0:12:53.21,0:12:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu...
Dialogue: 0,0:13:00.47,0:13:02.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaliknya di sini,
Dialogue: 0,0:13:03.80,0:13:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku akan terima serangannya!
Dialogue: 0,0:13:05.14,0:13:06.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas!
Dialogue: 0,0:13:06.47,0:13:08.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dengan celah itu...
Dialogue: 0,0:13:10.02,0:13:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disarm!
Dialogue: 0,0:13:14.19,0:13:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyaris tidak berdampak, tapi harusnya efek\Npenurunan daya serang sudah masuk!
Dialogue: 0,0:13:23.16,0:13:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:13:30.12,0:13:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas!
Dialogue: 0,0:13:48.10,0:13:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elymas?
Dialogue: 0,0:13:50.10,0:13:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak akan berhasil.
Dialogue: 0,0:13:53.02,0:13:55.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Poizo butuh 7 MP.
Dialogue: 0,0:13:58.19,0:14:01.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Cakar Api butuh 5 MP!
Dialogue: 0,0:14:08.49,0:14:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disarm!
Dialogue: 0,0:14:11.16,0:14:13.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang Disarm sudah kena dua kali!
Dialogue: 0,0:14:13.29,0:14:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya serangnya menurun 40%!
Dialogue: 0,0:14:16.17,0:14:19.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, berkat julukan "Yang Tak Tergoyahkan",
Dialogue: 0,0:14:19.84,0:14:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku dapat efek daya pertahanan naik 10%\Nsaat di kondisi diam!
Dialogue: 0,0:14:23.68,0:14:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, syaratnya sudah terpenuhi!
Dialogue: 0,0:14:27.64,0:14:32.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbedaan level dan kemampuan\Nbisa dibalikkan dengan pengetahuan!
Dialogue: 0,0:14:32.52,0:14:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemenangan sudah di depan mata!
Dialogue: 0,0:14:56.17,0:14:58.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng!
Dialogue: 0,0:15:20.57,0:15:22.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, tamat sudah.
Dialogue: 0,0:15:30.62,0:15:32.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah naik ke level 12.
Dialogue: 0,0:15:32.62,0:15:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendapatkan 4 skill point.
Dialogue: 0,0:15:41.71,0:15:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini, Ikrar Zirah Berat tidak dapat
Dialogue: 0,0:15:43.80,0:15:45.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditingkatkan lebih jauh lagi.
Dialogue: 0,0:15:45.97,0:15:47.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat betul pesan ini.
Dialogue: 0,0:15:47.68,0:15:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sudah kuduga.\N- Sistem Magic World yang seperti itu
Dialogue: 0,0:15:49.60,0:15:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata masih berlaku.
Dialogue: 0,0:15:51.43,0:15:54.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikrar Zirah Berat telah naik ke level 15,
Dialogue: 0,0:15:54.93,0:15:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka mendapat skill Parry.
Dialogue: 0,0:15:57.31,0:16:00.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sekarang sudah terkumpul.\NTapi, dengan ini, skill dasarku
Dialogue: 0,0:16:00.19,0:16:03.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kamu ini sebenarnya siapa?
Dialogue: 0,0:16:03.44,0:16:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini,\Nrasanya kamu memang bisa sendirian.
Dialogue: 0,0:16:07.65,0:16:11.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata aku tak perlu mengkhawatirkanmu.
Dialogue: 0,0:16:11.12,0:16:13.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku akan merepotkanmu.
Dialogue: 0,0:16:15.70,0:16:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:16:16.71,0:16:19.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kena racun!
Dialogue: 0,0:16:19.46,0:16:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status abnormal, Racun.
Dialogue: 0,0:16:22.42,0:16:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kutemani sampai kota.
Dialogue: 0,0:16:24.30,0:16:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Ares.
Dialogue: 0,0:16:27.26,0:16:30.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kalau cuma itu, aku juga bisa.
Dialogue: 0,0:16:30.68,0:16:32.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:16:36.52,0:16:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar tertolong!
Dialogue: 0,0:16:38.19,0:16:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ketemu lagi, tolong bantuannya!
Dialogue: 0,0:16:40.52,0:16:42.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sehat-sehat, ya!
Dialogue: 0,0:17:02.67,0:17:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahanda, tolong tenang dulu!
Dialogue: 0,0:17:05.08,0:17:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}HP dan pertahananku tertinggi—
Dialogue: 0,0:17:06.71,0:17:09.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak penting sama sekali!
Dialogue: 0,0:17:10.68,0:17:12.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng!
Dialogue: 0,0:17:20.77,0:17:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku jadi ahli waris selanjutnya\Nterlalu berat untuk Tuan Elymas.
Dialogue: 0,0:17:34.87,0:17:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besoknya setelah mengalahkan Ariandype,
Dialogue: 0,0:17:37.95,0:17:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku datang ke Serikat Petualang kota Rondalm\Nuntuk mendaftar sebagai petualang.
Dialogue: 0,0:17:44.17,0:17:46.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang apa kamu ini?\NMana ada imbalan buatmu!
Dialogue: 0,0:17:46.88,0:17:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau gabung tidak?
Dialogue: 0,0:17:48.63,0:17:51.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin mendaftar jadi petualang.
Dialogue: 0,0:17:57.18,0:18:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Elymas, level 12.\NKelasku Kesatria Kelas Berat.
Dialogue: 0,0:18:02.60,0:18:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alah, ternyata Kesatria Kelas Berat.
Dialogue: 0,0:18:05.19,0:18:06.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kecewa sudah tertarik.
Dialogue: 0,0:18:06.90,0:18:10.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kelas Berat itu\Nartinya tidak berguna, kan?
Dialogue: 0,0:18:10.61,0:18:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, jadi Anda kelas pertahanan, ya.
Dialogue: 0,0:18:14.03,0:18:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya mengerti.
Dialogue: 0,0:18:23.50,0:18:26.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang Kelas F, Elymas, telah disetujui.
Dialogue: 0,0:18:26.79,0:18:30.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya, aku resmi menjadi petualang.
Dialogue: 0,0:18:32.01,0:18:35.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang punya tujuh tingkatan.
Dialogue: 0,0:18:35.01,0:18:40.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk masuk labirin, di dalam grup\Nharus ada petualang Kelas E atau di atasnya.
Dialogue: 0,0:18:41.50,0:18:43.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, tergantung tingkatan,
Dialogue: 0,0:18:43.14,0:18:44.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}skill poin yang bisa kutambahkan
Dialogue: 0,0:18:44.60,0:18:46.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke Ikrar Zirah Berat akan ada batasnya.
Dialogue: 0,0:18:46.90,0:18:50.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, aku harus segera\Nmenjadi petualang Kelas E.
Dialogue: 0,0:18:50.86,0:18:52.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, terus.
Dialogue: 0,0:18:52.32,0:18:53.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:18:55.61,0:19:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan bilang Kesatria Kelas Berat\Nlevel rendah kayak dia mau cari grup?
Dialogue: 0,0:19:00.87,0:19:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa juga yang mau satu grup\Nsama sampah kayak dia.
Dialogue: 0,0:19:03.29,0:19:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang sedang cari\Ngarda depan tidak, ya?
Dialogue: 0,0:19:06.36,0:19:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permintaan untuk jadi tameng itu sedikit.
Dialogue: 0,0:19:08.84,0:19:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya rasa mencari rekan akan butuh waktu.
Dialogue: 0,0:19:11.80,0:19:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:12.92,0:19:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Saya mohon maaf.
Dialogue: 0,0:19:15.22,0:19:18.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, akan kupikirkan soal grup\Ndi lain hari saja.
Dialogue: 0,0:19:19.18,0:19:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada itu...
Dialogue: 0,0:19:23.18,0:19:26.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kantong Sihir yang bisa\Nmenyimpan banyak benda.
Dialogue: 0,0:19:26.27,0:19:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung aku bisa membawanya.
Dialogue: 0,0:19:29.48,0:19:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin menjual batu sihir ini.
Dialogue: 0,0:19:33.19,0:19:34.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hah?\N- A-Apa?
Dialogue: 0,0:19:34.49,0:19:36.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dia Kelas F, kan?\N- Itu mustahil!
Dialogue: 0,0:19:37.03,0:19:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sebanyak ini?
Dialogue: 0,0:19:38.62,0:19:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda kumpulkan sendiri?
Dialogue: 0,0:19:39.91,0:19:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku berburu seorang diri.
Dialogue: 0,0:19:42.85,0:19:44.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong dilaporkan seperti itu.
Dialogue: 0,0:19:44.62,0:19:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, baik.
Dialogue: 0,0:19:47.17,0:19:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan bohongan, kan?
Dialogue: 0,0:19:48.92,0:19:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan si Kesatria Kelas Berat itu?
Dialogue: 0,0:19:51.42,0:19:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan dia curang?
Dialogue: 0,0:19:57.37,0:19:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selesai mendaftar jadi petualang,
Dialogue: 0,0:19:59.18,0:20:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}uang untuk hidup pun sudah kudapatkan.
Dialogue: 0,0:20:02.51,0:20:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, darahku sebagai mantan\Npemain Magic World mulai bergejolak!
Dialogue: 0,0:20:07.52,0:20:11.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada tidak misi naik kelas yang bisa kuambil?
Dialogue: 0,0:20:13.02,0:20:17.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau tanya ada atau tidak,\Nmemang ada, tapi...
Dialogue: 0,0:20:47.60,0:20:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar di misi penyerbuan kali ini,
Dialogue: 0,0:20:50.65,0:20:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada petualang konyol yang ikut serta.
Dialogue: 0,0:20:54.69,0:20:57.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kamu orangnya, Elymas?
Dialogue: 0,0:20:57.69,0:20:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar juga nyalimu.
Dialogue: 0,0:20:59.49,0:21:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk pemula yang meremehkan\Nserikat dan monster sepertimu.
Dialogue: 0,0:21:03.62,0:21:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa mengalahkan Ariandype di level 12?
Dialogue: 0,0:21:07.54,0:21:09.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan omong kosongmu!
Dialogue: 0,0:21:09.50,0:21:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang tidaklah seremeh itu!
Dialogue: 0,0:21:12.13,0:21:15.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kugembleng lagi nyalimu itu!
Dialogue: 0,0:21:32.56,0:21:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini keterlaluan.
Dialogue: 0,0:23:12.33,0:23:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akhirnya ikut misi penyerbuan\Nuntuk menaikkan rank petualangku.
Dialogue: 0,0:23:16.71,0:23:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rank itu berhubungan langsung\Ndengan batas pertumbuhan.
Dialogue: 0,0:23:21.13,0:23:24.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku punya firasat buruk\Nsoal misi penyerbuan kali ini.
Dialogue: 0,0:23:24.59,0:23:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang veteran yang arogan,\Npara pemula yang ketakutan.
Dialogue: 0,0:23:28.05,0:23:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga tidak ada hal buruk yang terjadi.
Dialogue: 0,0:23:30.39,0:23:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya: Misi Penyerbuan.
Dialogue: 0,0:23:33.02,0:23:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kalau melengkapi satu sama lain,\Nkita tidak akan kalah!
