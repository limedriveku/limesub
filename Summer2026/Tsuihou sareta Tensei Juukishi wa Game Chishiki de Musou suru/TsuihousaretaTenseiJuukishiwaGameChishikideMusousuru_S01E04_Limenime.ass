Dialogue: 0,0:02:08.90,0:02:10.19,sign,,0000,0000,0000,,GHOUL HEAD TELAH MENGALAMI
Dialogue: 0,0:02:10.19,0:02:11.19,sign,,0000,0000,0000,,EVOLUSI EKSISTENSI MENJADI MAD HEADDER
Dialogue: 0,0:02:42.73,0:02:45.40,sign,,0000,0000,0000,,KESATRIA KELAS BERAT TEREINKARNASI YANG DIASINGKAN\NJADI TANPA TANDING DENGAN PENGETAHUAN GIMNYA
Dialogue: 0,0:03:57.01,0:04:01.05,sign,,0000,0000,0000,,EPISODE 4: EVOLUSI EKSISTENSI
Dialogue: 0,0:04:16.27,0:04:18.77,sign,,0000,0000,0000,,HYAK! HYAK!
Dialogue: 0,0:04:22.78,0:04:25.50,sign,,0000,0000,0000,,KEKAR - YANG BENAR SAJA?
Dialogue: 0,0:04:26.29,0:04:28.21,sign,,0000,0000,0000,,TEKAN TOMBOL MULAI
Dialogue: 0,0:04:44.18,0:04:46.18,sign,,0000,0000,0000,,STATUS ABNORMAL: STUN
Dialogue: 0,0:05:15.17,0:05:17.92,sign,,0000,0000,0000,,STATUS ABNORMAL: LUMPUH
Dialogue: 0,0:05:43.74,0:05:45.16,sign,,0000,0000,0000,,HEAL: PENYEMBUH
Dialogue: 0,0:05:45.16,0:05:46.62,sign,,0000,0000,0000,,PARA-HEAL: PENYEMBUH LUMPUH
Dialogue: 0,0:06:31.08,0:06:34.29,sign,,0000,0000,0000,,MONSTER: MAD HEADDER
Dialogue: 0,0:09:52.40,0:09:54.74,sign,,0000,0000,0000,,SISA SKILL POINT: 5
Dialogue: 0,0:09:54.74,0:09:56.62,sign,,0000,0000,0000,,ILMU PEDANG DASAR: 5/50
Dialogue: 0,0:10:00.62,0:10:02.16,sign,,0000,0000,0000,,KARENA ILMU PEDANG DASAR TELAH NAIK
Dialogue: 0,0:10:02.16,0:10:03.50,sign,,0000,0000,0000,,KE LEVEL 5, MENDAPAT SKILL TEBASAN VITAL
Dialogue: 0,0:10:03.50,0:10:05.69,sign,,0000,0000,0000,,TEBASAN VITAL [SKILL BIASA]
Dialogue: 0,0:10:34.57,0:10:36.62,sign,,0000,0000,0000,,TEBASAN VITAL
Dialogue: 0,0:14:35.40,0:14:37.23,sign,,0000,0000,0000,,TAMENG SETAN GILA - DAYA PERTAHANAN +25
Dialogue: 0,0:14:37.23,0:14:39.82,sign,,0000,0000,0000,,HARGA PASAR: 3 JUTA G
Dialogue: 0,0:20:34.84,0:20:36.34,sign,,0000,0000,0000,,SKILL BOOK: BUKU KEMAMPUAN
Dialogue: 0,0:20:36.34,0:20:37.96,sign,,0000,0000,0000,,TARING BARA KEGILAAN
Dialogue: 0,0:20:51.10,0:20:51.73,sign,,0000,0000,0000,,IKRAR ZIRAH BERAT
Dialogue: 0,0:00:33.81,0:00:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penghancur Batu!
Dialogue: 0,0:01:23.98,0:01:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang...
Dialogue: 0,0:01:25.36,0:01:29.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang sudah memulihkan diri,\Ntapi sekarang Wight pengganggu sudah hilang!
Dialogue: 0,0:01:30.65,0:01:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti, Gowtan!
Dialogue: 0,0:01:32.07,0:01:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjauh dari dia!
Dialogue: 0,0:01:33.61,0:01:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan segera kuselesaikan ini!
Dialogue: 0,0:02:04.94,0:02:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ghoul Head telah mengalami\NEvolusi Eksistensi menjadi Mad Headder.
Dialogue: 0,0:02:08.90,0:02:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelnya telah naik ke 40.
Dialogue: 0,0:02:11.19,0:02:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Level Ghoul Head jadi setara\Natau malah lebih tinggi dari Gowtan?
Dialogue: 0,0:02:21.50,0:02:23.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa yang terjadi?
Dialogue: 0,0:02:24.00,0:02:25.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini situasi paling gawat!
Dialogue: 0,0:04:10.44,0:04:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Evolusi Eksistensi adalah kejadian langka\Nyang terjadi dalam kondisi tertentu.
Dialogue: 0,0:04:16.27,0:04:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya merujuk monster yang berusaha
Dialogue: 0,0:04:18.77,0:04:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}keluar dari kondisi terdesak dengan\Nmengeluarkan potensi tersembunyi mereka
Dialogue: 0,0:04:22.78,0:04:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bermutasi jadi ras lain.
Dialogue: 0,0:04:26.29,0:04:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan di Magic World,
Dialogue: 0,0:04:28.21,0:04:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}syarat Evolusi Eksistensi\Ntidak diketahui jelas.
Dialogue: 0,0:04:32.88,0:04:37.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi ini cuma bisa dibilang\Nkami sedang apes!
Dialogue: 0,0:04:39.13,0:04:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan, jangan berdiri di depannya!
Dialogue: 0,0:04:44.18,0:04:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status, +Stun.
Dialogue: 0,0:04:46.18,0:04:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teal, Paul!\NAlihkan perhatian monster besar itu!
Dialogue: 0,0:04:48.89,0:04:51.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kami harus bagaimana?
Dialogue: 0,0:04:51.19,0:04:53.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau menyerang monster itu dengan sihir,
Dialogue: 0,0:04:53.40,0:04:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah aku yang bisa terbunuh!
Dialogue: 0,0:04:56.15,0:04:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Gowtan sampai terbunuh,\Nkita semua bakal musnah!
Dialogue: 0,0:04:59.11,0:05:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Amankan peluang kemenangan kita!
Dialogue: 0,0:05:15.17,0:05:17.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Status Abnormal, Lumpuh.
Dialogue: 0,0:05:28.56,0:05:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:05:38.82,0:05:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menggiringnya!
Dialogue: 0,0:05:40.86,0:05:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teal, cepat amankan Gowtan
Dialogue: 0,0:05:43.74,0:05:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sembuhkan dia dengan Heal dan Para-Heal!
Dialogue: 0,0:05:46.62,0:05:49.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku punya Heal,\Ntapi tidak punya Para-Heal...
Dialogue: 0,0:05:49.12,0:05:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:49.62,0:05:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua skill milikku kufokuskan\Nuntuk peningkat daya serang!
Dialogue: 0,0:05:52.46,0:05:54.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menyembuhkan Lumpuh!
Dialogue: 0,0:05:54.46,0:05:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kepikiran membagi skill\Nsetengah-setengah begitu?
Dialogue: 0,0:05:57.75,0:06:01.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya cepat bawa Gowtan\Ndan sembuhkan dia di tempat aman!
Dialogue: 0,0:06:01.80,0:06:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lari!
Dialogue: 0,0:06:02.93,0:06:05.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah!
Dialogue: 0,0:06:08.81,0:06:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelumpuhan yang diakibatkan skill khusus,\NBangkai Racun Lumpuh Mad Headder,
Dialogue: 0,0:06:12.69,0:06:15.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rata-rata akan pulih sendiri\Ndalam tiga menit.
Dialogue: 0,0:06:15.48,0:06:18.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal bisa diulur selama itu...
Dialogue: 0,0:06:20.99,0:06:23.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan bisa bangkit lagi\Ndengan Heal milik Teal!
Dialogue: 0,0:06:23.53,0:06:24.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heal.
Dialogue: 0,0:06:25.49,0:06:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apa gim dan dunia nyata
Dialogue: 0,0:06:28.78,0:06:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan beda sampai sejauh ini?
Dialogue: 0,0:06:36.75,0:06:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai Gowtan bisa bangkit lagi,\Naku yang akan melawanmu.
Dialogue: 0,0:06:41.34,0:06:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mad Headder!
Dialogue: 0,0:06:45.84,0:06:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualang Kelas F jelas mustahil\Nmelawan monster seperti itu!
Dialogue: 0,0:06:50.89,0:06:51.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodoh!
Dialogue: 0,0:06:51.85,0:06:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat kabur selagi ada waktu!
Dialogue: 0,0:06:53.98,0:06:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dia sampai terbunuh,\Nselanjutnya kita yang mati!
Dialogue: 0,0:06:57.52,0:06:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!\NAku juga mau kabur!
Dialogue: 0,0:06:59.61,0:07:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik begitu.
Dialogue: 0,0:07:00.94,0:07:03.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ceroboh membantu,\Ntidak akan bertahan sepuluh detik.
Dialogue: 0,0:07:03.61,0:07:08.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lawannya dia, jelas tak akan sempat\Nmelindungi petualang kelas rendah.
Dialogue: 0,0:07:24.59,0:07:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku level 16.
Dialogue: 0,0:07:27.25,0:07:30.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedangkan Mad Headder level 40.
Dialogue: 0,0:07:30.43,0:07:33.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kesalahan saja bisa berakibat kematian!
Dialogue: 0,0:08:52.05,0:08:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perbedaan levelnya terlalu besar.
Dialogue: 0,0:08:54.39,0:08:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasinya benar-benar gawat.
Dialogue: 0,0:08:56.27,0:09:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka harus melawan musuh\Nsetangguh ini tanpa persiapan.
Dialogue: 0,0:09:01.48,0:09:04.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sebenarnya ingin\Nmenghindari situasi seperti ini,
Dialogue: 0,0:09:05.19,0:09:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dengan risiko tinggi hasilnya besar.
Dialogue: 0,0:09:07.76,0:09:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Situasi yang menguji seluruh\Nkemampuanku hingga batas.
Dialogue: 0,0:09:12.20,0:09:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau semangat tidak membara,\Nnamanya bukan laki-laki!
Dialogue: 0,0:09:24.59,0:09:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, si Kesatria Kelas Berat itu,
Dialogue: 0,0:09:27.05,0:09:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa seimbang melawan monster\Nyang mengempaskan Gowtan?
Dialogue: 0,0:09:31.09,0:09:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan konyol!
Dialogue: 0,0:09:32.22,0:09:34.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas-jelas dia makin terpojok.
Dialogue: 0,0:09:34.51,0:09:36.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia masih hidup saja sudah keajaiban!
Dialogue: 0,0:09:45.77,0:09:49.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Mad Headder terus kubiarkan\Nmenyerang sepihak begini,
Dialogue: 0,0:09:49.49,0:09:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang sekarang tidak akan bisa\Nmenghindari semuanya.
Dialogue: 0,0:09:52.40,0:09:56.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga perlu memberi pukulan balik.
Dialogue: 0,0:09:57.41,0:10:00.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Ilmu Pedang Dasar\Ntelah naik ke level 5,
Dialogue: 0,0:10:00.62,0:10:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mendapat skill Tebasan Vital.
Dialogue: 0,0:10:03.50,0:10:05.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill: Tebasan Vital.
Dialogue: 0,0:10:05.69,0:10:08.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill untuk memukul dengan\Npunggung pedang dari jarak dekat.
Dialogue: 0,0:10:08.42,0:10:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mudah memberi kerusakan pada musuh\Ndengan daya pertahanan tinggi sekalipun.
Dialogue: 0,0:10:21.02,0:10:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:10:31.11,0:10:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:10:34.57,0:10:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan Vital!
Dialogue: 0,0:10:55.01,0:10:59.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan Vital dianggap skill ampas\Nkarena mengorbankan jangkauan pedang.
Dialogue: 0,0:11:00.39,0:11:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi skill ini mudah memberikan kerusakan,
Dialogue: 0,0:11:03.10,0:11:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cocok untuk Kesatria Kelas Berat\Nyang pertahanannya tinggi.
Dialogue: 0,0:11:08.36,0:11:11.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, dia tidak selemah itu\Nuntuk dikalahkan dengan ini!
Dialogue: 0,0:11:19.48,0:11:20.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Parry!
Dialogue: 0,0:11:20.49,0:11:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanmu jadi kacau!
Dialogue: 0,0:11:26.00,0:11:28.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Mad Headder!
Dialogue: 0,0:11:28.13,0:11:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan sebenarnya\Nbaru dimulai sekarang, kan?
Dialogue: 0,0:11:30.42,0:11:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja.
Dialogue: 0,0:11:32.71,0:11:35.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasku sudah selesai!
Dialogue: 0,0:11:51.73,0:11:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:11:52.69,0:11:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakanmu jadi kacau!
Dialogue: 0,0:11:58.20,0:12:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Mad Headder!
Dialogue: 0,0:12:00.32,0:12:02.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan sebenarnya\Nbaru dimulai sekarang, kan?
Dialogue: 0,0:12:02.45,0:12:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja.
Dialogue: 0,0:12:04.62,0:12:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tugasku sudah selesai!
Dialogue: 0,0:12:18.59,0:12:21.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tebasan Pembelah Naga!
Dialogue: 0,0:12:34.69,0:12:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hebat!\N- Kita menang!
Dialogue: 0,0:12:51.38,0:12:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telah naik dari level 16 ke 23.
Dialogue: 0,0:12:56.26,0:12:58.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seorang petualang yang hanya kelas F,
Dialogue: 0,0:12:58.80,0:13:04.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa terus menahan amukan monster\Nyang hampir membunuhku.
Dialogue: 0,0:13:05.33,0:13:07.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas sekali tadi sudah batasku.
Dialogue: 0,0:13:07.27,0:13:09.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tertolong, Gowtan.
Dialogue: 0,0:13:21.07,0:13:23.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Elymas!
Dialogue: 0,0:13:24.37,0:13:28.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arahan yang payah dan kurangnya\Nkontrol keamanan.
Dialogue: 0,0:13:28.16,0:13:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua sesuai dengan ucapanmu!
Dialogue: 0,0:13:31.75,0:13:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan?
Dialogue: 0,0:13:33.75,0:13:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu saja yang bawa itu.
Dialogue: 0,0:13:41.76,0:13:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Batu sihir level 40?
Dialogue: 0,0:13:43.68,0:13:45.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan dihargai lumayan tinggi.
Dialogue: 0,0:13:45.60,0:13:48.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya aku senang diberi itu\Nkarena kekurangan uang.
Dialogue: 0,0:13:50.48,0:13:51.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yakin?
Dialogue: 0,0:13:51.98,0:13:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kamu yang mengalahkan monster itu.
Dialogue: 0,0:14:00.32,0:14:04.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Drop Item dari monster langka level 40, ya?
Dialogue: 0,0:14:05.49,0:14:07.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perlu buatmu saja?
Dialogue: 0,0:14:08.54,0:14:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja-Jangan konyol!
Dialogue: 0,0:14:10.20,0:14:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan menarik ucapanku!
Dialogue: 0,0:14:11.87,0:14:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang sudah mengalahkan monster itu!
Dialogue: 0,0:14:17.38,0:14:21.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, boleh tidak aku memeriksa\Ndetail item ini?
Dialogue: 0,0:14:21.55,0:14:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bo-Boleh.
Dialogue: 0,0:14:33.94,0:14:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tameng Setan Gila, Daya Pertahanan +25.
Dialogue: 0,0:14:37.23,0:14:39.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harga pasarnya tiga juta Gold.
Dialogue: 0,0:14:39.82,0:14:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berhasil menahan serangan musuh\Ndengan tameng ini,
Dialogue: 0,0:14:42.74,0:14:45.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}daya seranganmu berikutnya bertambah +8.
Dialogue: 0,0:14:46.37,0:14:49.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Drop langka yang harga pasarannya\Ntiga juta Gold?
Dialogue: 0,0:14:50.24,0:14:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolakan Tembok Benteng tidak akan aktif\Nkalau tidak ditahan dengan zirah.
Dialogue: 0,0:14:53.79,0:14:55.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau dengan kemampuan ini,
Dialogue: 0,0:14:55.50,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serangan yang setara bisa kutahan\Nsepenuhnya dengan tameng!
Dialogue: 0,0:14:59.29,0:15:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, kalau harganya setinggi ini,\Ndijual pun jadi masuk pertimbangan.
Dialogue: 0,0:15:03.47,0:15:05.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiga juta Gold, ya?
Dialogue: 0,0:15:15.23,0:15:17.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, Gowtan.
Dialogue: 0,0:15:17.35,0:15:19.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kenaikan kelasku...
Dialogue: 0,0:15:19.40,0:15:21.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu khawatir.
Dialogue: 0,0:15:21.36,0:15:26.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kubilang, serikat akan rugi\Nkalau tidak menaikkan kelasmu.
Dialogue: 0,0:15:27.61,0:15:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar cepat dinaikkan ke Kelas E.
Dialogue: 0,0:15:30.28,0:15:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:15:32.25,0:15:36.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serikat memintaku mengawasi\Ndirimu curang atau tidak,
Dialogue: 0,0:15:36.50,0:15:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata itu peringatan yang tidak benar.
Dialogue: 0,0:15:39.92,0:15:44.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada yang menentang,\Nbiar kuhajar orangnya!
Dialogue: 0,0:15:52.51,0:15:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permisi...
Dialogue: 0,0:15:54.39,0:15:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Gowtan...
Dialogue: 0,0:15:56.39,0:16:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menyetujui kenaikan kelasku juga tidak?
Dialogue: 0,0:16:01.44,0:16:05.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan bisa bangkit pulih lagi\Nitu berkat Heal milikku...
Dialogue: 0,0:16:05.49,0:16:06.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teal!
Dialogue: 0,0:16:06.70,0:16:11.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dirimu benar-benar kaku\Nsaat melawan monster itu?
Dialogue: 0,0:16:11.41,0:16:14.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa kusetujui naik kelas\Nkalau kondisimu seperti itu!
Dialogue: 0,0:16:15.12,0:16:19.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Dungeon ada banyak rintangan\Nyang lebih sulit dari kali ini.
Dialogue: 0,0:16:19.71,0:16:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihlah dirimu dengan ambil\Nlebih banyak misi yang sesuai!
Dialogue: 0,0:17:23.94,0:17:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu lagi, ya?
Dialogue: 0,0:17:25.06,0:17:26.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama sekali.
Dialogue: 0,0:17:26.10,0:17:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak salah pedati?
Dialogue: 0,0:17:31.32,0:17:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pengin lihat juga.
Dialogue: 0,0:17:32.99,0:17:34.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang manis ini saja!
Dialogue: 0,0:17:35.04,0:17:36.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ke Dungeon selanjutnya dulu!
Dialogue: 0,0:17:46.46,0:17:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Hei!\N- Lain kali, tertarik gabung sama kami?
Dialogue: 0,0:17:57.35,0:18:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm, imbalan untuk Raid kali ini...
Dialogue: 0,0:18:02.27,0:18:05.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini yang pertama, 130 ribu Gold.
Dialogue: 0,0:18:07.73,0:18:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah itu...
Dialogue: 0,0:18:10.86,0:18:15.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini 200 ribu Gold untuk jatah\Nbatu sihir dari 10 Wight.
Dialogue: 0,0:18:16.87,0:18:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, ini...
Dialogue: 0,0:18:18.54,0:18:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada lagi?
Dialogue: 0,0:18:20.12,0:18:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harga beli batu sihir Ghoul Head\Nyang telah menjadi Mad Headder...
Dialogue: 0,0:18:24.42,0:18:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Huft!
Dialogue: 0,0:18:25.71,0:18:27.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Totalnya 600 ribu Gold!
Dialogue: 0,0:18:30.92,0:18:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini kamu dapat cuan\Nlebih banyak dariku.
Dialogue: 0,0:18:34.30,0:18:36.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raid itu memang bikin cuan, ya.
Dialogue: 0,0:18:36.39,0:18:40.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Banyak banget cuannya.\N- Dia dapat lebih banyak dari Gowtan?
Dialogue: 0,0:18:40.85,0:18:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya dia Kesatria Kelas Berat?
Dialogue: 0,0:18:43.73,0:18:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan, begini...
Dialogue: 0,0:18:46.06,0:18:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar dia yang sudah\Nmengalahkan mutasi Ghoul Head?
Dialogue: 0,0:18:49.90,0:18:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar itu!
Dialogue: 0,0:18:50.78,0:18:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah dia tadinya dicurigai karena\Nbawa batu sihir dari monster level tinggi?
Dialogue: 0,0:18:55.57,0:18:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada udang di balik batunya.
Dialogue: 0,0:18:57.53,0:18:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Levelmu itu berapa?
Dialogue: 0,0:18:58.99,0:19:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pertahanan itu enggak guna, kan?
Dialogue: 0,0:19:01.20,0:19:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gowtan, tolong jelaskan!
Dialogue: 0,0:19:05.00,0:19:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:19:05.96,0:19:10.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas pertahanan seperti Kesatria Kelas Berat\Nmana bisa memburu monster sebanyak itu!
Dialogue: 0,0:19:14.38,0:19:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua mau meragukan Elymas?
Dialogue: 0,0:19:17.47,0:19:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama saja menghinaku\Nyang sudah mengakuinya naik kelas!
Dialogue: 0,0:19:31.69,0:19:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku banyak merepotkanmu, Gowtan.
Dialogue: 0,0:19:33.78,0:19:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:19:34.69,0:19:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:36.61,0:19:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai bertemu lagi.\NJaga dirimu.
Dialogue: 0,0:19:38.45,0:19:42.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkat Gowtan, orang-orang\Nyang mencibirku langsung lenyap.
Dialogue: 0,0:19:42.70,0:19:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pun berhasil naik\Nmenjadi petualang Kelas E.
Dialogue: 0,0:19:55.38,0:19:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, mau gabung enggak\Nsama lini depan yang jago ini?
Dialogue: 0,0:19:58.22,0:19:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benaran kuat tidak?
Dialogue: 0,0:20:00.60,0:20:04.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nah, selanjutnya aku harus bagaimana?
Dialogue: 0,0:20:05.39,0:20:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah naik ke Kelas E\Ndan boleh masuk ke Dungeon,
Dialogue: 0,0:20:08.94,0:20:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa saja cari uang dari sana.
Dialogue: 0,0:20:11.65,0:20:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, taktik serangan balik\NTolakan Tembok Benteng
Dialogue: 0,0:20:14.07,0:20:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang butuh pertahanan dahsyat
Dialogue: 0,0:20:16.99,0:20:18.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hanya akan mempan di level awal.
Dialogue: 0,0:20:19.07,0:20:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau komposisi skill milikku tetap begini,
Dialogue: 0,0:20:21.58,0:20:25.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sementara waktu aku harus naik level\Ndengan melelahkan.
Dialogue: 0,0:20:26.04,0:20:31.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk menentukan arah selanjutnya,\Nbiar kucoba mencari "itu".
Dialogue: 0,0:20:34.84,0:20:37.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill Book Taring Bara Kegilaan.
Dialogue: 0,0:20:37.96,0:20:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Skill Book adalah item yang diperlukan\Nuntuk mendapat Skill Tree.
Dialogue: 0,0:20:43.10,0:20:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu item yang berharga,\Nsulit dapat dengan cepat.
Dialogue: 0,0:20:47.56,0:20:49.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi mencoba cari itu tidak dipungut biaya!
Dialogue: 0,0:20:51.73,0:20:55.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikrar Zirah Berat\Ndan Taring Bara Kegilaan.
Dialogue: 0,0:20:56.15,0:20:58.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua skill ini akan bersinergi
Dialogue: 0,0:20:58.53,0:21:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}barulah Kesatria Kelas Berat jadi sempurna.
Dialogue: 0,0:21:01.36,0:21:06.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesatria Kelas Berat yang sudah sempurna\Nbukanlah kelas ahli pertahanan lagi.
Dialogue: 0,0:21:06.29,0:21:09.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disebut kelas ahli serangan\Njuga masih kurang tepat.
Dialogue: 0,0:21:09.37,0:21:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujudnya itu benar-benar\Nseperti senjata manusia.
Dialogue: 0,0:21:14.46,0:21:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Taring Bara Kegilaan.
Dialogue: 0,0:21:16.59,0:21:20.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu item terpenting Kesatria Kelas Berat\Nuntuk menunjukkan kekuatan sejatinya.
Dialogue: 0,0:21:21.09,0:21:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja...
Dialogue: 0,0:23:10.41,0:23:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan yang sungguh berbahaya,
Dialogue: 0,0:23:12.37,0:23:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku berhasil naik peringkat\Nmenjadi petualang Kelas E.
Dialogue: 0,0:23:15.79,0:23:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berarti, langkahku selanjutnya sudah jelas!
Dialogue: 0,0:23:19.04,0:23:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wujud sempurna dari Kesatria Kelas Berat.
Dialogue: 0,0:23:21.34,0:23:22.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan lagi ahli pertahanan,
Dialogue: 0,0:23:22.63,0:23:25.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}disebut ahli serangan juga terlalu remeh!
Dialogue: 0,0:23:25.72,0:23:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kukeluarkan potensi\Nsebagai senjata manusia!
Dialogue: 0,0:23:28.76,0:23:32.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, aku perlu Skill Book itu\Nuntuk mewujudkannya.
Dialogue: 0,0:23:32.68,0:23:35.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, Taring Bara Kegilaan.
Dialogue: 0,0:23:35.48,0:23:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, masalah utamanya adalah\Nharganya yang di luar nalar.
