Dialogue: 0,0:00:27.92,0:00:29.47,Default,,0,0,0,,Kesatria Kelas Berat.
Dialogue: 0,0:00:30.89,0:00:35.18,Default,,0,0,0,,Kelas ahli pertahanan\Nyang bertugas menarik serangan musuh
Dialogue: 0,0:00:35.18,0:00:37.52,Default,,0,0,0,,untuk melindungi rekan-rekannya.
Dialogue: 0,0:00:38.35,0:00:41.73,Default,,0,0,0,,Tetapi, bila dibandingkan\Nkelas pertahanan lainnya,
Dialogue: 0,0:00:41.73,0:00:44.65,Default,,0,0,0,,kemampuannya sulit diaplikasikan.
Dialogue: 0,0:00:44.65,0:00:50.20,Default,,0,0,0,,Kemampuan serangnya juga terlalu rendah\Nsehingga sulit naik level.
Dialogue: 0,0:00:52.95,0:00:54.78,Default,,0,0,0,,Karena itulah...
Dialogue: 0,0:00:55.49,0:00:59.87,Default,,0,0,0,,disebut kelas cacat\Nyang melebihi sebuah kesialan.
Dialogue: 0,0:02:47.40,0:02:52.24,Default,,0,0,0,,Sejak dulu, setiap mempelajari\Natau melihat sesuatu,
Dialogue: 0,0:02:59.87,0:03:04.96,Default,,0,0,0,,aku sering diserang sensasi seperti\Ntelah mengetahuinya sedari lama.
Dialogue: 0,0:03:06.54,0:03:10.59,Default,,0,0,0,,Eh, aku seperti pernah melihatnya...
Dialogue: 0,0:04:06.10,0:04:08.31,Default Above,,0,0,0,,Doppellusion!
Dialogue: 0,0:04:09.60,0:04:13.48,Default,,0,0,0,,Biar kutunjukkan skill dari Pedang Suci!
Dialogue: 0,0:04:14.19,0:04:17.36,Default,,0,0,0,,Serangan Beruntun Bajra!
Dialogue: 0,0:05:06.04,0:05:08.04,Default,,0,0,0,,Lalu, hari ini,
Dialogue: 0,0:05:09.12,0:05:11.62,Default,,0,0,0,,akan diadakan Ritual Berkat Ilahi yang vital
Dialogue: 0,0:05:11.62,0:05:14.63,Default,,0,0,0,,padaku selaku ahli waris\Nkeluarga Edvaughn...
Dialogue: 0,0:05:14.63,0:05:16.34,Default,,0,0,0,,- Akhirnya sebentar lagi.\N- Aku juga ikut gugup.
Dialogue: 0,0:05:16.34,0:05:18.38,Default,,0,0,0,,Betapa gagahnya.
Dialogue: 0,0:05:18.92,0:05:22.13,Default,,0,0,0,,Lagi-lagi aku merasakan dejavu yang aneh.
Dialogue: 0,0:05:23.39,0:05:26.56,Default,,0,0,0,,Tidak perlu khawatir, Elymas.\NKamu itu putraku.
Dialogue: 0,0:05:26.56,0:05:28.89,Default,,0,0,0,,Percayalah pada Dewa Pedang.
Dialogue: 0,0:05:35.86,0:05:38.32,Default,,0,0,0,,Elymas Edvaughn.
Dialogue: 0,0:05:43.78,0:05:47.33,Default,,0,0,0,,Daku berikan berkah kelas pada dikau!
Dialogue: 0,0:05:49.16,0:05:51.29,Default,,0,0,0,,Baptisma!
Dialogue: 0,0:05:52.42,0:05:54.96,Default,,0,0,0,,Tidak salah lagi, aku familier dengan ini.
Dialogue: 0,0:05:54.96,0:05:56.04,Default,,0,0,0,,Lima tahun?
Dialogue: 0,0:05:56.04,0:05:57.25,Default,,0,0,0,,Tidak, jauh sebelum itu.
Dialogue: 0,0:05:57.67,0:06:00.76,Default,,0,0,0,,Benar, sebelum aku terlahir?
Dialogue: 0,0:06:02.59,0:06:05.55,Default,,0,0,0,,Dunia ini sama persis dengan Magic World,
Dialogue: 0,0:06:05.55,0:06:10.68,Default,,0,0,0,,gim daring realitas virtual yang sering\Nkumainkan di kehidupan sebelumnya!
Dialogue: 0,0:06:12.64,0:06:16.56,Default,,0,0,0,,Memang sulit dipercaya,\Ntapi aku bereinkarnasi!
Dialogue: 0,0:06:16.56,0:06:20.86,Default,,0,0,0,,Karena sudah tahu seluk-beluk gimnya,\Naku jadi senang dan yakin bisa menang!
Dialogue: 0,0:06:20.86,0:06:26.16,Default,,0,0,0,,Tunggu, kalau begitu aku ingin kelas\Nyang dulu sering kupakai itu!
Dialogue: 0,0:06:27.83,0:06:31.83,Default,,0,0,0,,Kelas curang yang digadang-gadang\Nterkuat di Magic World.
Dialogue: 0,0:06:45.72,0:06:46.89,Default,,0,0,0,,Hore!
Dialogue: 0,0:06:48.51,0:06:50.31,Default,,0,0,0,,Berhasil, Ayahanda!
Dialogue: 0,0:06:50.31,0:06:51.43,Default,,0,0,0,,Aku Kesatria Kelas Berat!
Dialogue: 0,0:06:52.35,0:06:53.93,Default,,0,0,0,,Ba-Barusan...
Dialogue: 0,0:06:53.93,0:06:55.52,Default,,0,0,0,,Ayahanda?
Dialogue: 0,0:06:56.02,0:06:57.86,Default,,0,0,0,,Barusan kamu bilang apa?
Dialogue: 0,0:06:57.86,0:07:00.98,Default,,0,0,0,,Kamu bilang kelasmu Pedang Suci, kan?
Dialogue: 0,0:07:00.98,0:07:02.69,Default,,0,0,0,,Eh?
Dialogue: 0,0:07:08.37,0:07:10.99,Default,,0,0,0,,Ingatan kehidupanku yang dulu\Njadi campur aduk?
Dialogue: 0,0:07:11.41,0:07:14.83,Default,,0,0,0,,Kelas kuat dan mudah dipahami\Nsangat dipuja di dunia ini.
Dialogue: 0,0:07:14.83,0:07:17.50,Default,,0,0,0,,Tapi kelas yang lambat tumbuhnya\Ndan teknis kurang dihargai.
Dialogue: 0,0:07:18.46,0:07:23.00,Default,,0,0,0,,Ini mungkin karena analisis\Ndan testimoni kelasnya belum terlalu maju.
Dialogue: 0,0:07:24.80,0:07:27.26,Default,,0,0,0,,- Tidak, maksudku—\N- Tunjukkan padaku!
Dialogue: 0,0:07:29.01,0:07:30.68,Default,,0,0,0,,Kesatria Kelas Berat?
Dialogue: 0,0:07:30.68,0:07:32.26,Default,,0,0,0,,Apa-apaan ini?
Dialogue: 0,0:07:32.26,0:07:34.23,Default,,0,0,0,,Selain statusmu di bawah rata-rata,
Dialogue: 0,0:07:34.23,0:07:37.27,Default,,0,0,0,,kamu boneka kayu yang cuma punya\Nskill serangan tidak berguna!
Dialogue: 0,0:07:37.27,0:07:40.36,Default,,0,0,0,,Tidak salah lagi, ini kelas cacat!
Dialogue: 0,0:07:40.36,0:07:42.23,Default,,0,0,0,,Ayahanda, tolong tenang dulu!
Dialogue: 0,0:07:42.23,0:07:43.86,Default,,0,0,0,,HP dan pertahananku tertinggi—
Dialogue: 0,0:07:43.86,0:07:46.86,Default,,0,0,0,,Itu tidak penting sama sekali!
Dialogue: 0,0:07:55.83,0:07:56.96,Default,,0,0,0,,Cih!
Dialogue: 0,0:07:56.96,0:07:58.46,Default,,0,0,0,,Untung ini di dalam wastu.
Dialogue: 0,0:07:58.46,0:08:02.84,Default,,0,0,0,,Apa jadinya keluarga Edvaughn\Nkalau aib ini sampai terbongkar di luar!
Dialogue: 0,0:08:25.07,0:08:26.19,Default,,0,0,0,,Aku sampai pangling.
Dialogue: 0,0:08:26.19,0:08:28.03,Default,,0,0,0,,Iya, dia jadi sangat anggun.
Dialogue: 0,0:08:28.03,0:08:29.07,Default,,0,0,0,,Gadis yang rapuh itu...
Dialogue: 0,0:08:29.07,0:08:30.87,Default,,0,0,0,,- Dia itu...\N- Dari keluarga cabang?
Dialogue: 0,0:08:30.87,0:08:31.95,Default,,0,0,0,,- Cantiknya.\N- Oh, dari keluarga cabang.
Dialogue: 0,0:08:31.95,0:08:32.91,Default,,0,0,0,,- Berarti anak kesayangan?\N- Pernah lihat waktu kecil? Tidak, itu, hm?
Dialogue: 0,0:08:32.91,0:08:33.58,Default,,0,0,0,,Oh, dari keluarga cabang.
Dialogue: 0,0:08:43.88,0:08:49.34,Default,,0,0,0,,Aku juga ikut menerima\NRitual Berkah Ilahi, apakah boleh?
Dialogue: 0,0:08:49.34,0:08:50.84,Default,,0,0,0,,- Keluarga cabang mau apa?\N- Sadar akan posisimu.
Dialogue: 0,0:08:50.84,0:08:53.85,Default,,0,0,0,,Dia putri dari keluarga cabang Edvaughn.
Dialogue: 0,0:08:53.85,0:08:56.39,Default,,0,0,0,,Namanya Malice.
Dialogue: 0,0:08:56.39,0:08:59.60,Default,,0,0,0,,Waktu kecil, aku pernah beberapa kali\Nmain dengannya.
Dialogue: 0,0:08:59.60,0:09:01.60,Default,,0,0,0,,Tapi mungkin karena keluarga cabang,
Dialogue: 0,0:09:01.60,0:09:04.82,Default,,0,0,0,,lima tahun terakhir kami hampir\Ntidak pernah saling bicara.
Dialogue: 0,0:09:07.65,0:09:09.57,Default,,0,0,0,,Tapi, maaf, sekarang...
Dialogue: 0,0:09:09.57,0:09:10.57,Default,,0,0,0,,Tidak apa-apa!
Dialogue: 0,0:09:10.57,0:09:12.91,Default,,0,0,0,,Cepat mulai Ritual Berkat Ilahinya.
Dialogue: 0,0:09:19.00,0:09:21.33,Default,,0,0,0,,Firasatku buruk.
Dialogue: 0,0:09:30.76,0:09:32.59,Default,,0,0,0,,Baptisma!
Dialogue: 0,0:10:02.29,0:10:05.42,Default,,0,0,0,,Pedang Suci, ya?
Dialogue: 0,0:10:10.76,0:10:13.68,Default,,0,0,0,,Maaf, ya.
Dialogue: 0,0:10:13.68,0:10:17.43,Default,,0,0,0,,Tampaknya saya sudah merebut\Nbakat Tuan Elymas!
Dialogue: 0,0:10:17.43,0:10:20.31,Default,,0,0,0,,Firasat burukku ternyata tepat.
Dialogue: 0,0:10:20.98,0:10:24.19,Default,,0,0,0,,Kalau putri keluarga cabang\Nmendapat Pedang Suci,
Dialogue: 0,0:10:24.19,0:10:27.15,Default,,0,0,0,,hati Ayah yang sudah buruk nanti malah...
Dialogue: 0,0:10:31.40,0:10:33.61,Default,,0,0,0,,Luar biasa, Malice!
Dialogue: 0,0:10:33.61,0:10:35.74,Default,,0,0,0,,Anggota keluarga Edvaughn memang hebat!
Dialogue: 0,0:10:35.74,0:10:39.66,Default,,0,0,0,,Malice, mulai hari ini,\Nkamu adalah putriku!
Dialogue: 0,0:10:39.66,0:10:41.95,Default,,0,0,0,,Kamu ahli waris keluarga Edvaughn!
Dialogue: 0,0:10:43.91,0:10:45.58,Default,,0,0,0,,Gadis keluarga cabang jadi ahli waris?
Dialogue: 0,0:10:45.58,0:10:47.21,Default,,0,0,0,,Ini belum pernah terjadi...
Dialogue: 0,0:10:50.34,0:10:51.71,Default,,0,0,0,,Ayahanda.
Dialogue: 0,0:10:51.71,0:10:53.88,Default,,0,0,0,,Bukankah Tuan Elymas yang akan...
Dialogue: 0,0:10:53.88,0:10:55.43,Default,,0,0,0,,Tidak.
Dialogue: 0,0:10:56.55,0:11:00.97,Default,,0,0,0,,Menurutku jadi ahli waris selanjutnya\Nterlalu berat untuk Tuan Elymas.
Dialogue: 0,0:11:01.81,0:11:03.60,Default,,0,0,0,,Enyahlah, Elymas.
Dialogue: 0,0:11:04.31,0:11:08.48,Default,,0,0,0,,Kamu yang sudah mengecewakanku\Nbukan lagi putraku!
Dialogue: 0,0:11:08.48,0:11:12.19,Default,,0,0,0,,Kesatria Kelas Berat terlahir\Ndi keluarga Edvaughn adalah aib!
Dialogue: 0,0:11:12.19,0:11:15.49,Default,,0,0,0,,Cepat pergi dari wastu ini!
Dialogue: 0,0:11:24.62,0:11:27.54,Default,,0,0,0,,Ayahanda, itu terlalu berlebihan!
Dialogue: 0,0:11:27.54,0:11:30.46,Default,,0,0,0,,Kesatria Kelas Berat itu kelas yang kuat!
Dialogue: 0,0:11:30.46,0:11:31.63,Default,,0,0,0,,Keluarga Edvaughn pasti—
Dialogue: 0,0:11:31.63,0:11:33.38,Default,,0,0,0,,Diam!
Dialogue: 0,0:11:33.38,0:11:35.72,Default,,0,0,0,,Kamu sudah melakukan hal memalukan!
Dialogue: 0,0:11:35.72,0:11:37.64,Default,,0,0,0,,Jangan pernah tunjukkan wajahmu lagi!
Dialogue: 0,0:11:37.64,0:11:40.64,Default,,0,0,0,,Jangan berani sebut\Nnama Edvaughn di luar sana.
Dialogue: 0,0:11:40.64,0:11:44.60,Default,,0,0,0,,Kalau itu terjadi,\Nlangsung kupenggal kepalamu!
Dialogue: 0,0:11:52.27,0:11:53.94,Default,,0,0,0,,Ayahanda!
Dialogue: 0,0:11:57.49,0:11:59.53,Default,,0,0,0,,Bereskan dia!
Dialogue: 0,0:12:21.51,0:12:24.68,Default,,0,0,0,,- Ayah tidak mau mendengar perkataanku.\N- Maaf kalau hanya sedikit.
Dialogue: 0,0:12:24.68,0:12:26.06,Default,,0,0,0,,- Ayah tidak mau mendengar perkataanku.\N- Maaf tidak bisa berbuat apa-apa.
Dialogue: 0,0:12:26.06,0:12:28.98,Default,,0,0,0,,- Aku diberikan sedikit uang\N- Maaf tidak bisa berbuat apa-apa.
Dialogue: 0,0:12:28.98,0:12:31.44,Default,,0,0,0,,- Terima kasih.\N- dan diusir dari wastu di hari itu juga.
Dialogue: 0,0:12:31.44,0:12:33.07,Default,,0,0,0,,- Tuan Elymas?\N- dan diusir dari wastu di hari itu juga.
Dialogue: 0,0:13:22.70,0:13:24.73,Default,,0,0,0,,Cari anggotanya mau bagaimana?
Dialogue: 0,0:13:25.35,0:13:28.37,Default,,0,0,0,,Siapa saja boleh asal kelas\Nyang serangannya cepat.
Dialogue: 0,0:13:31.92,0:13:33.46,Default,,0,0,0,,Belakangan ini Anda bagaimana?
Dialogue: 0,0:13:33.46,0:13:37.13,Default,,0,0,0,,Aku ingin ambil misi naik rank\Ndalam waktu dekat.
Dialogue: 0,0:13:37.13,0:13:39.59,Default,,0,0,0,,- Aku punya kenalan di pihak penilai.\N- Keren!
Dialogue: 0,0:13:39.59,0:13:41.59,Default,,0,0,0,,Tuan Teal memang hebat!
Dialogue: 0,0:13:45.35,0:13:49.60,Default,,0,0,0,,Hari ini! Hari ini aku pasti\Nakan berjuang keras!
Dialogue: 0,0:13:51.56,0:13:54.23,Default,,0,0,0,,Setidaknya, jangan jadi beban.
Dialogue: 0,0:13:54.23,0:13:56.82,Default,,0,0,0,,Aku ingin berburu dengan normal.
Dialogue: 0,0:14:19.88,0:14:22.88,Default,,0,0,0,,Ayah sialan, bikin aku merana begini.
Dialogue: 0,0:14:23.84,0:14:27.60,Default,,0,0,0,,Rumah, keluarga, dan keseharian,\Naku kehilangan semuanya.
Dialogue: 0,0:14:27.60,0:14:29.10,Default,,0,0,0,,Tapi...
Dialogue: 0,0:14:29.10,0:14:33.06,Default,,0,0,0,,Aku punya kelas terkuat,\NKesatria Kelas Berat!
Dialogue: 0,0:14:37.36,0:14:39.02,Default,,0,0,0,,Hanya saja...
Dialogue: 0,0:14:39.02,0:14:41.82,Default,,0,0,0,,Sejarah dan topografi dunia ini.
Dialogue: 0,0:14:41.82,0:14:46.66,Default,,0,0,0,,Bahkan nama kota yang disebut Rondalm ini\Nbenar-benar beda dari latar gim.
Dialogue: 0,0:14:47.28,0:14:50.33,Default,,0,0,0,,Sepertinya aku perlu menyelidiki banyak hal.
Dialogue: 0,0:14:52.25,0:14:55.62,Default,,0,0,0,,Pertama, aku harus memastikan\Nkelas dan skill dulu.
Dialogue: 0,0:14:55.62,0:14:57.21,Default,,0,0,0,,Status!
Dialogue: 0,0:14:58.00,0:15:00.13,Default,,0,0,0,,Kalau fiturnya berubah
Dialogue: 0,0:15:00.13,0:15:02.55,Default,,0,0,0,,dan kemampuan curang Kesatria Kelas Berat hilang,
Dialogue: 0,0:15:02.55,0:15:04.51,Default,,0,0,0,,situasinya akan gawat.
Dialogue: 0,0:15:07.51,0:15:09.64,Default,,0,0,0,,Syukurlah, masih sama.
Dialogue: 0,0:15:09.64,0:15:11.85,Default,,0,0,0,,Skill Tree.
Dialogue: 0,0:15:11.85,0:15:16.65,Default,,0,0,0,,Intinya memungkinkan untuk memilih bidang\Nketerampilan apa yang ingin dipelajari.
Dialogue: 0,0:15:17.44,0:15:20.19,Default,,0,0,0,,Sisa skill point yang kumiliki ada lima,
Dialogue: 0,0:15:20.19,0:15:22.44,Default,,0,0,0,,tapi ini adalah bonus awalan
Dialogue: 0,0:15:22.44,0:15:24.32,Default,,0,0,0,,yang didapat saat menerima kelas.
Dialogue: 0,0:15:24.32,0:15:27.45,Default,,0,0,0,,Lalu, poin ini akan bertambah satu
Dialogue: 0,0:15:27.45,0:15:28.87,Default,,0,0,0,,setiap naik level.
Dialogue: 0,0:15:29.70,0:15:34.37,Default,,0,0,0,,Bukan berlebihan kalau menyebut\Npembagian poin ini sebagai penentu takdir.
Dialogue: 0,0:15:35.46,0:15:38.54,Default,,0,0,0,,Skill Tree ada dua jenis, skill bawaan kelas
Dialogue: 0,0:15:38.54,0:15:40.42,Default,,0,0,0,,dan skill random yang didapat
Dialogue: 0,0:15:40.42,0:15:42.00,Default,,0,0,0,,saat pembuatan karakter.
Dialogue: 0,0:15:42.67,0:15:45.97,Default,,0,0,0,,Di antara ini, skill bawaanku\Nhanya Ikrar Zirah Berat.
Dialogue: 0,0:15:46.59,0:15:48.22,Default,,0,0,0,,Ikrar Zirah Berat
Dialogue: 0,0:15:48.22,0:15:52.51,Default,,0,0,0,,adalah skill khusus Kesatria Kelas Berat\Ndan disebut skill konyol terlemah.
Dialogue: 0,0:15:52.51,0:15:55.18,Default,,0,0,0,,Kalau kena memang cukup kuat,
Dialogue: 0,0:15:55.18,0:15:57.31,Default,,0,0,0,,tapi sangat sulit dipakai
Dialogue: 0,0:15:57.31,0:16:00.36,Default,,0,0,0,,dan lebih sering tidak ada momen\Nuntuk menggunakannya.
Dialogue: 0,0:16:00.94,0:16:04.65,Default,,0,0,0,,Peningkatan Daya Pertahanan\Nadalah Skill Tree yang cukup berguna.
Dialogue: 0,0:16:04.65,0:16:08.49,Default,,0,0,0,,Memang tidak memberi skill apa-apa,\Nhanya menaikkan daya pertahanan.
Dialogue: 0,0:16:09.24,0:16:11.49,Default,,0,0,0,,Ilmu Pedang Dasar juga lumayan.
Dialogue: 0,0:16:11.49,0:16:14.20,Default,,0,0,0,,Kalau naik sampai habis,\Nbisa pakai item khusus
Dialogue: 0,0:16:14.20,0:16:16.62,Default,,0,0,0,,dan berevolusi jadi Ilmu Pedang Atas.
Dialogue: 0,0:16:18.21,0:16:19.12,Default,,0,0,0,,Tapi!
Dialogue: 0,0:16:25.30,0:16:28.47,Default,,0,0,0,,Karena Ikrar Zirah Berat telah naik ke level 2,
Dialogue: 0,0:16:28.47,0:16:31.72,Default,,0,0,0,,mendapat skill Tolakan Tembok Benteng.
Dialogue: 0,0:16:31.72,0:16:34.81,Default,,0,0,0,,Karena Ikrar Zirah Berat telah naik ke level 5,
Dialogue: 0,0:16:34.81,0:16:37.60,Default,,0,0,0,,Daya Pertahanan +10.
Dialogue: 0,0:16:38.02,0:16:39.14,Default,,0,0,0,,Sip!
Dialogue: 0,0:16:40.60,0:16:42.02,Default,,0,0,0,,Pasti bisa!
Dialogue: 0,0:17:58.02,0:17:59.56,Default,,0,0,0,,Raana, ya?
Dialogue: 0,0:18:00.06,0:18:01.18,Default,,0,0,0,,Status!
Dialogue: 0,0:18:08.11,0:18:09.94,Default,,0,0,0,,Langsung menyerang, ya?
Dialogue: 0,0:18:09.94,0:18:11.36,Default,,0,0,0,,Maju sini!
Dialogue: 0,0:18:14.32,0:18:16.49,Default,,0,0,0,,Tolakan Tembok Benteng!
Dialogue: 0,0:18:31.76,0:18:33.09,Default,,0,0,0,,Telah naik ke level dua.
Dialogue: 0,0:18:33.09,0:18:34.26,Default,,0,0,0,,Tapi...
Dialogue: 0,0:18:34.72,0:18:37.64,Default,,0,0,0,,- Skill Tolakan Tembok Benteng.\N- Brutal juga kalau dilihat begini.
Dialogue: 0,0:18:37.64,0:18:39.51,Default,,0,0,0,,Bila berhasil menahan serangan jarak dekat musuh
Dialogue: 0,0:18:39.51,0:18:41.52,Default,,0,0,0,,dengan daya pertahanan,
Dialogue: 0,0:18:41.52,0:18:44.27,Default,,0,0,0,,memberi kerusakan sesuai status\Ndaya pertahanan pengguna.
Dialogue: 0,0:18:53.24,0:18:55.32,Default,,0,0,0,,Batu Sihir level 2.
Dialogue: 0,0:18:55.32,0:18:58.03,Default,,0,0,0,,Harganya memang murah,\Ntapi kusimpan saja.
Dialogue: 0,0:19:02.33,0:19:06.42,Default,,0,0,0,,Tolong!\NTolong aku!
Dialogue: 0,0:19:11.63,0:19:12.55,Default,,0,0,0,,Bakal dibunuh!
Dialogue: 0,0:19:12.55,0:19:13.92,Default,,0,0,0,,Aku bakal dibunuh!
Dialogue: 0,0:19:15.09,0:19:16.64,Default,,0,0,0,,Kamu petualang?
Dialogue: 0,0:19:16.64,0:19:19.22,Default,,0,0,0,,Ku-Kumohon, tolong aku!
Dialogue: 0,0:19:30.61,0:19:31.90,Default,,0,0,0,,Serahkan padaku!
Dialogue: 0,0:19:33.53,0:19:36.03,Default,,0,0,0,,Apa kamu benaran bisa?
Dialogue: 0,0:19:36.03,0:19:40.28,Default,,0,0,0,,Penampilanmu mewah,\Napa kamu aslinya petualang terkenal?
Dialogue: 0,0:19:40.91,0:19:42.54,Default,,0,0,0,,Bukan.
Dialogue: 0,0:19:45.62,0:19:49.67,Default,,0,0,0,,Aku tadi baru pertama kalinya naik level.
Dialogue: 0,0:19:49.67,0:19:52.63,Default,,0,0,0,,Be-Berarti kamu payah!
Dialogue: 0,0:19:52.63,0:19:55.17,Default,,0,0,0,,Bahkan jauh lebih lemah dariku!
Dialogue: 0,0:19:55.17,0:19:59.26,Default,,0,0,0,,Pe-Pemula mana bisa membasmi\Nmonster sebanyak itu!
Dialogue: 0,0:19:59.26,0:20:01.51,Default,,0,0,0,,Lepaskan zirah beratmu itu!
Dialogue: 0,0:20:02.18,0:20:03.64,Default,,0,0,0,,Ayo lari!
Dialogue: 0,0:20:04.14,0:20:06.56,Default,,0,0,0,,Tolakan Tembok Benteng tidaklah\Nsakti mandraguna.
Dialogue: 0,0:20:07.35,0:20:12.40,Default,,0,0,0,,Menangkal kerusakan dengan daya pertahanan\Nyang jauh di atas daya serang musuh.
Dialogue: 0,0:20:12.40,0:20:16.36,Default,,0,0,0,,Kalau tidak dibuat menerima kerusakan,\Nefeknya tidak bisa menyala.
Dialogue: 0,0:20:19.03,0:20:20.53,Default,,0,0,0,,Lari!
Dialogue: 0,0:20:24.20,0:20:27.33,Default,,0,0,0,,Tidak mempan pada lawan lebih kuat\Ndan musuh tidak dikenal.
Dialogue: 0,0:20:28.21,0:20:29.08,Default,,0,0,0,,Tapi...
Dialogue: 0,0:20:29.08,0:20:30.33,Default,,0,0,0,,Maju sini!
Dialogue: 0,0:20:30.33,0:20:32.38,Default,,0,0,0,,Tolakan Tembok Benteng!
Dialogue: 0,0:20:33.59,0:20:35.67,Default,,0,0,0,,Hah?
Dialogue: 0,0:20:41.14,0:20:44.14,Default,,0,0,0,,Aku sudah paham betul\Nsoal musuh di level awal!
Dialogue: 0,0:20:44.14,0:20:48.39,Default,,0,0,0,,Daya pertahananku sudah kumaksimalkan\Ndengan bonus Skill Tree dan perlengkapan.
Dialogue: 0,0:20:49.39,0:20:51.15,Default,,0,0,0,,Kalau lawannya cuma Raana,
Dialogue: 0,0:20:51.15,0:20:54.94,Default,,0,0,0,,mau datang puluhan ekor pun\Naku akan menang!
Dialogue: 0,0:21:07.87,0:21:09.92,Default,,0,0,0,,Mengalahkan Raana sebanyak itu?
Dialogue: 0,0:21:09.92,0:21:12.33,Default,,0,0,0,,Ka-Kamu ini siapa sebenarnya?
Dialogue: 0,0:21:13.63,0:21:16.09,Default,,0,0,0,,Aku Elymas Edva—
Dialogue: 0,0:21:16.09,0:21:18.26,Default,,0,0,0,,Jangan berani sebut\Nnama Edvaughn di luar sana.
Dialogue: 0,0:21:18.26,0:21:22.47,Default,,0,0,0,,Kalau itu terjadi,\Nlangsung kupenggal kepalamu!
Dialogue: 0,0:21:22.47,0:21:25.47,Default,,0,0,0,,Maaf, ya.
Dialogue: 0,0:21:28.98,0:21:30.48,Default,,0,0,0,,Tidak.
Dialogue: 0,0:21:33.90,0:21:35.36,Default,,0,0,0,,Aku Elymas
Dialogue: 0,0:21:35.98,0:21:37.48,Default,,0,0,0,,si Kesatria Kelas Berat.
Dialogue: 0,0:23:11.33,0:23:15.12,Default,,0,0,0,,Aku berhasil meraih kemenangan pertama\Nsebagai Kesatria Kelas Berat.
Dialogue: 0,0:23:15.12,0:23:19.00,Default,,0,0,0,,Ternyata Kesatria Kelas Berat memang\Nkelas terkuat seperti di gim.
Dialogue: 0,0:23:19.00,0:23:24.13,Default,,0,0,0,,Tapi, perlu menaikkan level lebih tinggi\Nuntuk mengeluarkan kemampuan sejatinya.
Dialogue: 0,0:23:24.13,0:23:27.18,Default,,0,0,0,,Aku tidak boleh terus berdiam di sini.
Dialogue: 0,0:23:27.18,0:23:32.64,Default,,0,0,0,,Saat seperti itu, muncul monster jahat\Ndengan level dua kali lipat di hadapanku.
Dialogue: 0,0:23:32.64,0:23:34.85,Default,,0,0,0,,Selanjutnya, Laba-Laba Monyet Menakutkan.
Dialogue: 0,0:23:34.85,0:23:38.10,Default,,0,0,0,,Pertarungan ini tidak mustahil dimenangkan!
