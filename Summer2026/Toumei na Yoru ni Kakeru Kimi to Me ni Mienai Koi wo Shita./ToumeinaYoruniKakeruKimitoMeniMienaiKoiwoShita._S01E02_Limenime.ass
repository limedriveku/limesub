Dialogue: 0,0:01:04.62,0:01:07.84,sign,,0000,0000,0000,,LOVE UNSEEN BENEATH THE CLEAR NIGHT SKY
Dialogue: 0,0:04:47.98,0:04:53.73,sign,,0000,0000,0000,,DILARANG MASUK SELAIN YANG BERKEPENTINGAN
Dialogue: 0,0:05:27.35,0:05:30.23,sign,,0000,0000,0000,,AULA PERINGATAN
Dialogue: 0,0:09:32.47,0:09:33.94,sign,,0000,0000,0000,,TOMBOL PENYEBERANGAN MALAM HARI
Dialogue: 0,0:10:57.72,0:11:00.49,sign,,0000,0000,0000,,EFEK JEMBATAN GANTUNG, EFEK PAPARAN SEMATA
Dialogue: 0,0:11:00.49,0:11:02.10,sign,,0000,0000,0000,,IKATAN KELOMPOK ATAU JATUH CINTA KARENA TEGANG
Dialogue: 0,0:11:02.10,0:11:04.98,sign,,0000,0000,0000,,SERING LIHAT JADI SUKA
Dialogue: 0,0:11:42.97,0:11:46.19,sign,,0000,0000,0000,,FUYUTSUKI KOHARU
Dialogue: 0,0:12:05.45,0:12:07.77,sign,,0000,0000,0000,,KOHARU FUYUTSUKI
Dialogue: 0,0:12:07.77,0:12:09.83,sign,,0000,0000,0000,,AKU MENUNGGUMU DI DEPAN MEIJI MARU
Dialogue: 0,0:16:37.73,0:16:41.07,sign,,0000,0000,0000,,PERHATIAN: JANGAN BERSANDAR PADA PAGAR PEMBATAS!
Dialogue: 0,0:16:41.07,0:16:43.86,sign,,0000,0000,0000,,KARENA SANGAT BERBAHAYA.
Dialogue: 0,0:22:24.78,0:22:30.04,sign,,0000,0000,0000,,FUYUTSUKI KOHARU
Dialogue: 0,0:00:22.43,0:00:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki.
Dialogue: 0,0:00:24.00,0:00:26.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tongkatmu.
Dialogue: 0,0:00:28.60,0:00:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas bantuanmu\Nuntuk minggu lalu juga.
Dialogue: 0,0:00:33.90,0:00:35.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano.
Dialogue: 0,0:00:35.21,0:00:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak ada kelas kedua, kan?
Dialogue: 0,0:02:29.61,0:02:30.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:02:32.02,0:02:33.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Yuko.
Dialogue: 0,0:02:37.58,0:02:40.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa langsung tahu\NHayase dari suaranya?
Dialogue: 0,0:02:40.83,0:02:44.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara Yuko sangat imut,\Njadi mudah dikenali.
Dialogue: 0,0:02:45.55,0:02:46.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:02:48.19,0:02:49.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tidak bisa melihat,
Dialogue: 0,0:02:49.61,0:02:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- katanya pendengaran orang jadi tajam.\N- Ternyata di sini, pagi.
Dialogue: 0,0:02:52.33,0:02:53.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:02:53.33,0:02:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski ingin bertanya,
Dialogue: 0,0:02:54.57,0:02:56.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- rasanya kurang sopan\N- Kamu datang lebih awal dari biasanya.
Dialogue: 0,0:02:56.45,0:02:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- kalau terus menanyakan hal itu.\N- Iya.
Dialogue: 0,0:02:59.49,0:03:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelas keduaku dibatalkan\Nkarena dosennya tiba-tiba ada urusan.
Dialogue: 0,0:03:03.56,0:03:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sedang membicarakan apa?
Dialogue: 0,0:03:05.85,0:03:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suaramu yang mudah dikenali\Nmeski dari jauh.
Dialogue: 0,0:03:10.51,0:03:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:03:12.46,0:03:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa benar pendengaran jadi lebih tajam\Nsetelah tidak bisa melihat?
Dialogue: 0,0:03:16.63,0:03:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya itu tidak benar.
Dialogue: 0,0:03:18.72,0:03:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia malah menanyakannya.
Dialogue: 0,0:03:20.22,0:03:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kudengar bisa tahu posisi benda dari gema.\N- Dia benar-benar tidak peka.
Dialogue: 0,0:03:23.96,0:03:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu tidak mungkin.
Dialogue: 0,0:03:26.65,0:03:30.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena belajar piano sejak kecil,
Dialogue: 0,0:03:30.31,0:03:32.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku lebih pandai mengenali suara.
Dialogue: 0,0:03:32.48,0:03:35.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah belajar piano?
Dialogue: 0,0:03:35.15,0:03:37.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku mau minta tolong.
Dialogue: 0,0:03:37.61,0:03:39.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:03:39.03,0:03:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu aula peringatan?
Dialogue: 0,0:03:41.19,0:03:42.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana ada piano.
Dialogue: 0,0:03:42.83,0:03:45.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kurasa aku bisa pulang duluan.\N- Konser jaz untuk hari jadi sekolah sudah dekat.
Dialogue: 0,0:03:45.61,0:03:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu, aku harus kembali ke asrama.\N- Aku mau minta tolong periksa suaranya.
Dialogue: 0,0:03:47.96,0:03:48.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kalau begitu, aku harus kembali ke asrama.\N- Boleh saja.
Dialogue: 0,0:03:48.96,0:03:51.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Sorano.
Dialogue: 0,0:03:51.34,0:03:54.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa sekalian mengantar kami\Nke aula peringatan?
Dialogue: 0,0:03:54.36,0:03:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengantar kalian?\NApa maksudmu?
Dialogue: 0,0:03:56.57,0:03:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tadi sudah kusebutkan?
Dialogue: 0,0:03:59.12,0:04:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konser jaz hari jadi sekolah\Nakan memakai piano di aula peringatan.
Dialogue: 0,0:04:03.28,0:04:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku panitia hari jadi sekolah,
Dialogue: 0,0:04:06.35,0:04:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi harus memastikan pianonya\Nbisa berbunyi normal dulu.
Dialogue: 0,0:04:09.73,0:04:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu bilang dia bisa bantu\Nmemeriksa suaranya juga.
Dialogue: 0,0:04:13.16,0:04:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku yang harus memandu?
Dialogue: 0,0:04:16.24,0:04:18.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau kembali ke asrama, kan?
Dialogue: 0,0:04:18.51,0:04:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aula peringatan ada di dalam area asrama.
Dialogue: 0,0:04:24.76,0:04:29.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana ada papan bertuliskan\N"Dilarang Masuk Selain yang Berkepentingan",
Dialogue: 0,0:04:29.79,0:04:32.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya jadi sungkan masuk\Nkalau bukan penghuninya.
Dialogue: 0,0:04:33.64,0:04:35.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, kumohon.
Dialogue: 0,0:04:41.81,0:04:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, lagi pula searah.
Dialogue: 0,0:04:58.79,0:04:59.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:05:03.29,0:05:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku segera ke sana.
Dialogue: 0,0:05:07.77,0:05:11.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, panitia hari jadi sekolah\Nharus berkumpul.
Dialogue: 0,0:05:11.23,0:05:12.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:12.58,0:05:15.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu, tolong periksa pianonya, ya.
Dialogue: 0,0:05:15.80,0:05:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:05:17.96,0:05:20.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Sorano, selanjutnya kuserahkan padamu.\N- Tunggu...
Dialogue: 0,0:05:20.55,0:05:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:05:25.40,0:05:26.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:05:34.28,0:05:35.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa duduk?
Dialogue: 0,0:05:37.88,0:05:39.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:49.23,0:05:51.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini piano grand.
Dialogue: 0,0:05:51.20,0:05:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok bisa tahu?
Dialogue: 0,0:05:52.41,0:05:55.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sensasi menekan tuts pianonya\Nbenar-benar berbeda.
Dialogue: 0,0:05:55.59,0:05:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuts piano grand punya kecepatan\Npantulan yang lebih cepat.
Dialogue: 0,0:05:58.97,0:06:00.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:06:01.63,0:06:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Npiano itu bisa dimainkan tanpa melihat?
Dialogue: 0,0:06:05.26,0:06:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih bisa memainkan lagu\Nyang sudah kuhafal dulu.
Dialogue: 0,0:06:09.47,0:06:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku memang ada pianis\Ntunanetra di dunia ini.
Dialogue: 0,0:06:12.85,0:06:15.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berada di level yang berbeda.
Dialogue: 0,0:06:15.83,0:06:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah tidak bisa melihat,\Naku jadi kesulitan menghafal lagu baru.
Dialogue: 0,0:06:19.89,0:06:24.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya masih punya banyak kenangan\Ndan kebiasaan saat masih bisa melihat.
Dialogue: 0,0:06:25.50,0:06:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat bermain piano, aku masih refleks\Nmelihat ke arah partitur.
Dialogue: 0,0:06:29.83,0:06:32.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ada yang mengajakku bicara,\Naku refleks memalingkan wajah.
Dialogue: 0,0:06:33.31,0:06:36.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ada kembang api,\Naku juga refleks menengadah ke langit.
Dialogue: 0,0:06:37.64,0:06:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena masih ada kesan\Nsaat bisa melihat,
Dialogue: 0,0:06:40.30,0:06:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa bersyukur pernah\Nmengalami masa melihat.
Dialogue: 0,0:06:45.41,0:06:49.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku memuji dia hebat,\Napa itu reaksi yang tepat?
Dialogue: 0,0:06:50.28,0:06:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau akan terdengar tidak sopan?
Dialogue: 0,0:06:56.50,0:07:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkan permainanku akan\Ndidengar olehmu, aku jadi gugup.
Dialogue: 0,0:07:01.65,0:07:04.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu,\Nboleh aku mulai memainkannya?
Dialogue: 0,0:07:04.52,0:07:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:08:03.14,0:08:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bermain dengan sangat bagus.
Dialogue: 0,0:08:28.08,0:08:30.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?
Dialogue: 0,0:08:30.85,0:08:32.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana...
Dialogue: 0,0:08:32.91,0:08:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:08:34.75,0:08:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu Bach memang luar biasa.
Dialogue: 0,0:08:40.77,0:08:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan Bach.
Dialogue: 0,0:08:43.03,0:08:44.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Mozart?
Dialogue: 0,0:08:44.90,0:08:47.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir!\NTapi masih salah.
Dialogue: 0,0:08:48.35,0:08:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, pasti Chopin.
Dialogue: 0,0:08:52.12,0:08:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang menarik.
Dialogue: 0,0:08:55.44,0:08:59.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu ini judulnya Laut Arab\Nkarya Fuuki Harumi.
Dialogue: 0,0:08:59.85,0:09:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas aku belum pernah mendengarnya.
Dialogue: 0,0:09:03.20,0:09:06.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lagu yang sering dipilih\Ndalam lomba piano.
Dialogue: 0,0:09:06.15,0:09:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah memainkannya\Nsaat kelas lima SD.
Dialogue: 0,0:09:09.09,0:09:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka memainkannya lebih lambat\Ndari tempo di partitur.
Dialogue: 0,0:09:13.01,0:09:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, permainanmu sangat bagus.
Dialogue: 0,0:09:16.95,0:09:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa memainkan lagu seperti ini sejak SD,\Nkamu benar-benar hebat.
Dialogue: 0,0:09:22.68,0:09:24.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih atas pujianmu.
Dialogue: 0,0:09:25.65,0:09:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan aku main sebentar lagi.
Dialogue: 0,0:09:28.03,0:09:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan.
Dialogue: 0,0:09:33.94,0:09:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Piano itu mungkin perlu sedikit disetem,\Ntapi kondisinya masih aman.
Dialogue: 0,0:09:41.78,0:09:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:09:43.24,0:09:45.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan apa-apa.
Dialogue: 0,0:09:46.07,0:09:50.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain soal piano, ada juga saat\Ntongkat putihku jatuh...
Dialogue: 0,0:09:50.21,0:09:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:52.08,0:09:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu, aku merasa kamu akan\Nmengambilkannya lagi untukku.
Dialogue: 0,0:09:57.05,0:10:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu benaran mengambilkannya,\Naku senang sekali.
Dialogue: 0,0:10:01.86,0:10:05.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal belum tentu\Naku yang akan mengambilkannya.
Dialogue: 0,0:10:05.65,0:10:08.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kamu mengambilkannya, kan?
Dialogue: 0,0:10:08.92,0:10:13.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku ingin minum teh di teras lagi\Nkalau hari ini bertemu denganmu lagi.
Dialogue: 0,0:10:13.92,0:10:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau harus memanggil namamu di kelas,\Nrasanya agak malu.
Dialogue: 0,0:10:19.62,0:10:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang kita bisa berbincang\Nseperti ini lagi.
Dialogue: 0,0:10:24.15,0:10:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kita sudah bertukar kontak LIME?
Dialogue: 0,0:10:26.19,0:10:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung hubungi aku saja.
Dialogue: 0,0:10:29.76,0:10:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya boleh?
Dialogue: 0,0:10:33.18,0:10:34.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:10:36.77,0:10:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:10:38.68,0:10:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, ayo pergi.
Dialogue: 0,0:10:43.20,0:10:44.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa,
Dialogue: 0,0:10:45.99,0:10:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}suara Fuyutsuki terdengar begitu riang
Dialogue: 0,0:10:47.73,0:10:53.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagaikan kicauan burung yang terdengar\Ndari lampu penyeberangan.
Dialogue: 0,0:10:56.62,0:10:57.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa suka pada manusia
Dialogue: 0,0:10:57.72,0:11:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bisa meningkat dengan cara sederhana,
Dialogue: 0,0:11:00.49,0:11:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti efek paparan semata
Dialogue: 0,0:11:02.10,0:11:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau efek jembatan gantung.
Dialogue: 0,0:11:04.98,0:11:08.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita cenderung menyukai orang\Nyang sering kita temui,
Dialogue: 0,0:11:08.95,0:11:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau salah mengira detak jantung yang cepat\Nkarena rasa takut sebagai debaran cinta.
Dialogue: 0,0:11:13.99,0:11:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kalian juga pernah mengalaminya.
Dialogue: 0,0:11:17.03,0:11:19.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang sering kita temui...
Dialogue: 0,0:11:20.24,0:11:23.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah sudah saatnya\Naku menyukai Narumi?
Dialogue: 0,0:11:23.04,0:11:24.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyukaimu!
Dialogue: 0,0:11:24.20,0:11:28.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin,\Ntapi setelah lama tinggal sekamar,
Dialogue: 0,0:11:28.61,0:11:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mulai merasa kami cocok.
Dialogue: 0,0:11:32.53,0:11:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Psikologi benar-benar hebat.
Dialogue: 0,0:11:42.97,0:11:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Katanya kita bisa masuk ke Meiji Maru."
Dialogue: 0,0:11:46.19,0:11:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Sorano, apa kamu bisa ikut?"
Dialogue: 0,0:11:51.33,0:11:54.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu kubilang boleh dihubungi,\Nlangsung begini jadinya.
Dialogue: 0,0:11:54.44,0:11:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudahlah.
Dialogue: 0,0:11:57.14,0:12:01.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena kampusku\Npunya jurusan pelatihan navigator kapal,
Dialogue: 0,0:12:01.24,0:12:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}entah kenapa ada kapal layar\Nyang terdampar di daratan.
Dialogue: 0,0:12:05.45,0:12:07.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapal bernama Meiji Maru itu
Dialogue: 0,0:12:07.77,0:12:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}katanya termasuk warisan budaya penting
Dialogue: 0,0:12:10.76,0:12:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan punya sejarah yang cukup megah,
Dialogue: 0,0:12:13.03,0:12:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi di kalangan mahasiswa, kapal itu cuma\Ndianggap semacam monumen raksasa.
Dialogue: 0,0:12:18.72,0:12:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu awal masuk, reaksiku cuma\N"Wah, ada kapal."
Dialogue: 0,0:12:23.81,0:12:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang sudah kebiasaan lihat,\Njadi cuma "Oh, kapal."
Dialogue: 0,0:12:30.19,0:12:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki.
Dialogue: 0,0:12:32.65,0:12:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Sorano, aku sudah datang.
Dialogue: 0,0:12:35.80,0:12:37.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano!
Dialogue: 0,0:12:39.20,0:12:42.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaan berdebar ini mungkin karena itu.
Dialogue: 0,0:12:42.59,0:12:46.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek jembatan gantung yang baru kupelajari.
Dialogue: 0,0:12:46.83,0:12:51.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untungnya aku mengambil kelas psikologi.\NKalau tidak, aku hampir salah paham.
Dialogue: 0,0:12:52.38,0:12:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa tiba-tiba ingin ke Meiji Maru?
Dialogue: 0,0:12:55.72,0:13:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, di depan tangga ada pagar besi,\Njadi tidak bisa naik ke kapal.
Dialogue: 0,0:13:00.59,0:13:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin masuk,\Njadi bertanya ke bagian administrasi.
Dialogue: 0,0:13:03.33,0:13:07.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata hari ini kebetulan hari buka,\Njadi boleh masuk berkunjung.
Dialogue: 0,0:13:08.11,0:13:09.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:13:09.83,0:13:11.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak penasaran?
Dialogue: 0,0:13:11.39,0:13:13.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak melihat-lihat sebelum wisuda,
Dialogue: 0,0:13:13.27,0:13:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kamu tidak bisa masuk ke sana\Nseumur hidup.
Dialogue: 0,0:13:15.61,0:13:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku tipe orang\Nyang tidak akan masuk seumur hidup.
Dialogue: 0,0:13:19.83,0:13:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali jadinya.
Dialogue: 0,0:13:22.49,0:13:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa melangkah ke dalam kapal\Ndari zaman Meiji,
Dialogue: 0,0:13:24.99,0:13:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti petualangan yang mendebarkan, bukan?
Dialogue: 0,0:13:30.88,0:13:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, meski ingin masuk melihat,\Naku tidak akan melakukannya.
Dialogue: 0,0:13:37.57,0:13:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya akan berpikir "Bagaimana cara masuknya?"\NLalu tidak ada kelanjutannya.
Dialogue: 0,0:13:43.19,0:13:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pasti tidak ada hubungannya\Ndengan bisa melihat atau tidak.
Dialogue: 0,0:13:47.69,0:13:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki benar-benar hebat.
Dialogue: 0,0:13:49.73,0:13:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang yang luar biasa.
Dialogue: 0,0:13:52.95,0:13:55.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, aku akan menemanimu masuk.
Dialogue: 0,0:13:55.69,0:13:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:13:57.48,0:14:00.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kamu yang menyuruhku kemari?
Dialogue: 0,0:14:00.03,0:14:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:14:08.87,0:14:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa menyembunyikan kekagumanku,\Nternyata ada kapal yang begini dulunya.
Dialogue: 0,0:14:15.03,0:14:17.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagian dalam kapal itu banyak undakannya.
Dialogue: 0,0:14:17.50,0:14:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Fuyutsuki pasti kesulitan berjalan di sini.\N- Ini kabin kelas satu, di tengah ada meja...
Dialogue: 0,0:14:21.26,0:14:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Aku menjelaskan sedetail mungkin\N- Tertulis ruang singgah, ada sofa merah.
Dialogue: 0,0:14:23.88,0:14:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- bagaimana bentuk konstruksinya, warnanya apa,\N- Di tepi dinding ada alat perbaikan tiang...
Dialogue: 0,0:14:27.01,0:14:31.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- dan semewah apa tampilannya.\N- Ruangan ini berisi berbagai suku cadang kapal.
Dialogue: 0,0:14:40.99,0:14:43.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:14:44.83,0:14:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh aku berjalan ke haluan kapal?
Dialogue: 0,0:14:47.03,0:14:48.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati, ya.
Dialogue: 0,0:14:55.76,0:14:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya seperti benar-benar naik kapal.
Dialogue: 0,0:14:59.40,0:15:01.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah puas?
Dialogue: 0,0:15:01.13,0:15:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemandangan seperti apa\Nyang terlihat dari sini?
Dialogue: 0,0:15:05.38,0:15:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:15:08.96,0:15:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari haluan kapal, ada tongkat kuning\Nyang menjulur namanya cucur.
Dialogue: 0,0:15:13.23,0:15:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari arah depan sampai kanan,\Nkelihatan laut.
Dialogue: 0,0:15:16.98,0:15:20.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sebelah kiri, pepohonan kampus\Nbergoyang-goyang.
Dialogue: 0,0:15:20.73,0:15:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di jam sebegini, tidak ada orang\Nyang lewat sekitar sini.
Dialogue: 0,0:15:25.85,0:15:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya indah.
Dialogue: 0,0:15:28.55,0:15:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tempat yang bagus.
Dialogue: 0,0:15:31.87,0:15:37.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga kaget\Nada tempat seperti ini di kampus.
Dialogue: 0,0:15:38.82,0:15:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah menemaniku.
Dialogue: 0,0:15:40.97,0:15:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku senang bisa masuk ke sini.
Dialogue: 0,0:15:43.63,0:15:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mendapat pengalaman seru.
Dialogue: 0,0:15:46.17,0:15:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah.
Dialogue: 0,0:15:48.76,0:15:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa tidak enak\Nkalau bersenang-senang sendirian.
Dialogue: 0,0:15:52.98,0:15:54.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita pulang.
Dialogue: 0,0:15:58.86,0:15:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya.
Dialogue: 0,0:16:04.99,0:16:06.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kamu lakukan?
Dialogue: 0,0:16:06.79,0:16:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang merasakan angin.
Dialogue: 0,0:16:09.21,0:16:11.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu film "Titanic"?
Dialogue: 0,0:16:11.99,0:16:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah menontonnya di TV saat SMP.
Dialogue: 0,0:16:16.64,0:16:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga pernah menontonnya.
Dialogue: 0,0:16:18.50,0:16:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu aku masih bisa melihat.
Dialogue: 0,0:16:21.94,0:16:24.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano.
Dialogue: 0,0:16:24.01,0:16:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau bermain peran sebagai tokoh\Ndari film Titanic bersamaku?
Dialogue: 0,0:16:27.57,0:16:28.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini?
Dialogue: 0,0:16:28.69,0:16:31.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah biasanya orang-orang\Nbermain di haluan kapal?
Dialogue: 0,0:16:31.64,0:16:33.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak boleh.
Dialogue: 0,0:16:33.72,0:16:37.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum naik ke kapal,\Npetugasnya sudah mengingatkan kita.
Dialogue: 0,0:16:37.73,0:16:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan bersandar pada pagar pembatas
Dialogue: 0,0:16:41.07,0:16:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena itu berbahaya."
Dialogue: 0,0:16:43.86,0:16:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:16:46.00,0:16:47.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak harus di sini juga...
Dialogue: 0,0:16:47.49,0:16:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:16:49.03,0:16:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku tidak bisa melihat,\Ndi mana pun aku berada,
Dialogue: 0,0:16:52.62,0:16:55.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku bisa membayangkan pemandangannya.
Dialogue: 0,0:16:57.31,0:16:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:16:58.75,0:17:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, permainan peran Titanic\Nmaksudmu itu,
Dialogue: 0,0:17:01.75,0:17:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku yang jadi Rose dan kamu jadi Jack?
Dialogue: 0,0:17:05.45,0:17:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, biar aku menyanyi lagu tema\Nuntuk menghidupkan suasana.
Dialogue: 0,0:17:09.88,0:17:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku hanya ingin bercanda,\Nternyata dia serius.
Dialogue: 0,0:17:14.53,0:17:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, memangnya boleh\Naku yang jadi pasangannya?
Dialogue: 0,0:17:18.21,0:17:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, aku takut kapalnya tenggelam\Nkalau kita benaran memerankannya.
Dialogue: 0,0:17:24.42,0:17:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapalnya ada di darat,\Nmana mungkin akan tenggelam.
Dialogue: 0,0:17:28.74,0:17:32.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetap harus berjaga-jaga.
Dialogue: 0,0:17:32.11,0:17:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa-bisanya bilang berjaga-jaga.
Dialogue: 0,0:17:48.56,0:17:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, tadi suaraku agak aneh.
Dialogue: 0,0:17:52.36,0:17:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku yang seharusnya minta maaf.
Dialogue: 0,0:17:58.23,0:18:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tadi aku bisa menahan tawa,
Dialogue: 0,0:18:00.64,0:18:03.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}permainan peran Titanic ini pasti berhasil.
Dialogue: 0,0:18:05.72,0:18:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hampir saja...\NIni hanya efek jembatan gantung.
Dialogue: 0,0:18:10.15,0:18:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Efek jembatan gantung...
Dialogue: 0,0:18:22.84,0:18:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan terbang.
Dialogue: 0,0:18:27.92,0:18:30.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, apa aku membangunkanmu?
Dialogue: 0,0:18:33.10,0:18:36.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Apa ini juga efek jembatan gantung?\N- Eh? Aku menaruhnya di mana?
Dialogue: 0,0:18:40.95,0:18:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian bangun saja, deh.
Dialogue: 0,0:18:48.80,0:18:51.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara petualangan itu kali, ya?
Dialogue: 0,0:18:52.24,0:18:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:18:54.52,0:18:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu...
Dialogue: 0,0:19:16.03,0:19:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:19:17.30,0:19:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki!
Dialogue: 0,0:19:22.83,0:19:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki.
Dialogue: 0,0:19:25.65,0:19:27.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berhenti sebentar?
Dialogue: 0,0:19:28.73,0:19:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu Sorano?
Dialogue: 0,0:19:31.31,0:19:33.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku Sorano.
Dialogue: 0,0:19:33.75,0:19:36.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:19:36.66,0:19:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya sedang jalan-jalan.
Dialogue: 0,0:19:39.28,0:19:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat hujan begini?
Dialogue: 0,0:19:41.91,0:19:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sendiri tidak kesulitan\Nberjalan saat cuaca begini?
Dialogue: 0,0:19:46.29,0:19:50.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bisa menyelesaikan\Nsemua urusanku sendiri.
Dialogue: 0,0:19:50.97,0:19:52.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:19:53.35,0:19:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti repot sambil bawa payung.
Dialogue: 0,0:19:55.42,0:19:56.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang memayungimu.
Dialogue: 0,0:19:58.03,0:19:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalian.
Dialogue: 0,0:19:59.61,0:20:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:20:03.73,0:20:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo.
Dialogue: 0,0:20:11.16,0:20:12.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang baik hati.
Dialogue: 0,0:20:12.72,0:20:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:20:14.43,0:20:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya kebetulan melihatmu.
Dialogue: 0,0:20:17.03,0:20:19.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedua tanganmu juga penuh\Ndan terlihat kerepotan.
Dialogue: 0,0:20:33.65,0:20:36.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena hujan, begitu masuk gerbang utama,
Dialogue: 0,0:20:36.09,0:20:39.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita lewat aula satu saja untuk ke kelas.
Dialogue: 0,0:20:39.08,0:20:41.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano.
Dialogue: 0,0:20:41.39,0:20:42.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya?
Dialogue: 0,0:20:45.90,0:20:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kita saling memanggil dengan nama?
Dialogue: 0,0:20:49.99,0:20:50.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:51.61,0:20:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah saling kenal selama sebulan.
Dialogue: 0,0:20:56.43,0:20:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga sudah banyak membantuku...
Dialogue: 0,0:21:00.37,0:21:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau dengan nama panggilan?
Dialogue: 0,0:21:04.37,0:21:08.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau begitu,\Nkamu mau memanggilku Koharun?
Dialogue: 0,0:21:08.25,0:21:09.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa...
Dialogue: 0,0:21:09.79,0:21:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memanggil nama keluargamu saja\Naku sudah kesusahan!
Dialogue: 0,0:21:15.88,0:21:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak memayungimu dengan baik.
Dialogue: 0,0:21:26.52,0:21:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:21:33.53,0:21:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita sudah terpayungi dengan baik?
Dialogue: 0,0:21:39.83,0:21:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:49.13,0:21:53.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tetap panggil aku Fuyutsuki saja.
Dialogue: 0,0:21:53.03,0:21:53.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:56.18,0:22:00.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bolehkah aku memanggilmu Kakeru?
Dialogue: 0,0:22:03.40,0:22:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:22:10.48,0:22:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:22:13.40,0:22:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita berangkat, Kakeru.
