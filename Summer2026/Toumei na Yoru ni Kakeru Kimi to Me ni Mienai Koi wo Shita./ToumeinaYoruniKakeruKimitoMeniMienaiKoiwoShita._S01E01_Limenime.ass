Dialogue: 0,0:00:39.60,0:00:42.81,sign,,0000,0000,0000,,LOVE UNSEEN BENEATH THE CLEAR NIGHT SKY
Dialogue: 0,0:13:42.30,0:13:44.43,sign,,0000,0000,0000,,AKU TITIPKAN KOHARU PADAMU!
Dialogue: 0,0:22:08.68,0:22:09.14,sign,,0000,0000,0000,,TEMAN YANG BARU DITAMBAHKAN\NFUYUTSUKI KOHARU, HAYASE YUKO
Dialogue: 0,0:22:09.14,0:22:09.43,sign,,0000,0000,0000,,TEMAN - AIKAWA EKSPRES, SORANO KYOKO,\NNARUMI USHIO, KARGO MINATO
Dialogue: 0,0:22:09.43,0:22:09.68,sign,,0000,0000,0000,,GRUP - ASRAMA PUTRA 5
Dialogue: 0,0:22:09.68,0:22:10.57,sign,,0000,0000,0000,,FUYUTSUKI KOHARU
Dialogue: 0,0:22:24.70,0:22:29.95,sign,,0000,0000,0000,,PERTEMUAN
Dialogue: 0,0:00:06.09,0:00:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginanku adalah
Dialogue: 0,0:00:08.14,0:00:10.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetap bisa hidup,
Dialogue: 0,0:00:10.08,0:00:11.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan setelah aku mati.
Dialogue: 0,0:01:56.60,0:01:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano, sudah bangun?
Dialogue: 0,0:01:59.16,0:02:00.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bermimpi aneh.
Dialogue: 0,0:02:00.93,0:02:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi apa?
Dialogue: 0,0:02:02.00,0:02:04.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi yang suram dan menyesakkan.
Dialogue: 0,0:02:04.27,0:02:05.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa coba?
Dialogue: 0,0:02:06.23,0:02:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang semangat, dong.
Dialogue: 0,0:02:07.88,0:02:10.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mumpung di sini,\Nsayang kalau tidak dinikmati.
Dialogue: 0,0:02:10.18,0:02:13.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu\Nyang memaksaku ke sini, Narumi.
Dialogue: 0,0:02:15.83,0:02:19.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gara-gara kamu, aku jadi kurang tidur.
Dialogue: 0,0:02:19.13,0:02:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah dekor ulang kamar sampai pagi.
Dialogue: 0,0:02:22.86,0:02:25.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya, punya teman sekamar kayak aku.
Dialogue: 0,0:02:25.21,0:02:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku, sih, aman saja.
Dialogue: 0,0:02:27.21,0:02:29.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Staminamu tidak ada habisnya, ya?
Dialogue: 0,0:02:41.62,0:02:43.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Panas banget.
Dialogue: 0,0:02:43.60,0:02:51.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun.
Dialogue: 0,0:02:51.23,0:02:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun\Nuntuk teman anonim yang tersayang.
Dialogue: 0,0:02:56.91,0:03:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat ulang tahun.
Dialogue: 0,0:03:03.91,0:03:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah risi?
Dialogue: 0,0:03:04.98,0:03:06.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun pasti merasa risi.
Dialogue: 0,0:03:06.75,0:03:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal seru banget, lo.
Dialogue: 0,0:03:08.79,0:03:11.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak merasa seru.
Dialogue: 0,0:03:13.01,0:03:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kamu tidak merasa risi\Nmelihat pemandangan seperti itu?
Dialogue: 0,0:03:17.51,0:03:20.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang suka bau rokok...
Dialogue: 0,0:03:22.60,0:03:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku suka urat yang terlihat di lengan.
Dialogue: 0,0:03:32.40,0:03:33.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa itu bikin risi?
Dialogue: 0,0:03:33.76,0:03:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu cowok yang polos.
Dialogue: 0,0:03:36.32,0:03:37.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sedang mengejekku?
Dialogue: 0,0:03:37.49,0:03:39.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:03:39.41,0:03:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang seperti itu, sih.
Dialogue: 0,0:03:42.45,0:03:45.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya?
Dialogue: 0,0:03:45.62,0:03:46.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat.
Dialogue: 0,0:03:46.97,0:03:49.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang pun kamu tidak mau\Nberanjak dari sini, kan?
Dialogue: 0,0:03:49.97,0:03:53.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal semua lagi berjuang mati-matian\Nmencari sirkel pertemanan baru.
Dialogue: 0,0:03:53.71,0:03:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru harus mati-matian itulah...
Dialogue: 0,0:03:55.84,0:03:58.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhatian!
Dialogue: 0,0:04:01.16,0:04:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya pengumuman penting.
Dialogue: 0,0:04:06.10,0:04:09.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mahasiswi baru, Hayase Yuko.
Dialogue: 0,0:04:10.99,0:04:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:04:12.76,0:04:14.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ayo berdiri.\N- Cepat!
Dialogue: 0,0:04:17.64,0:04:21.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak pernah jatuh cinta\Npada pandangan pertama.
Dialogue: 0,0:04:21.49,0:04:24.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku sudah tidak tahan lagi.
Dialogue: 0,0:04:24.83,0:04:26.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah pacarku!
Dialogue: 0,0:04:28.83,0:04:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, terima saja!
Dialogue: 0,0:04:30.67,0:04:32.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadilah pacarku juga.
Dialogue: 0,0:04:32.59,0:04:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:04:34.74,0:04:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sama sekali bukan seleraku.
Dialogue: 0,0:04:38.53,0:04:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:04:40.12,0:04:41.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius.
Dialogue: 0,0:04:47.71,0:04:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano, ikut ramaikan suasana, dong.
Dialogue: 0,0:04:50.48,0:04:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak dulu aku tidak suka orang caper.
Dialogue: 0,0:04:54.19,0:04:55.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:04:56.05,0:04:58.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena aku tidak suka\Nberjuang mati-matian.
Dialogue: 0,0:04:58.99,0:05:01.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mengatakannya, ya?
Dialogue: 0,0:05:01.20,0:05:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sikap bersungguh-sungguhnya itu?
Dialogue: 0,0:05:03.87,0:05:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin saja dia ingin memulai\Nlembaran baru di kampus.
Dialogue: 0,0:05:07.29,0:05:09.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampus memang tempat seperti itu.
Dialogue: 0,0:05:09.58,0:05:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu,
Dialogue: 0,0:05:11.21,0:05:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak suka melakukan hal\Nyang bisa mancing perkara.
Dialogue: 0,0:05:14.40,0:05:16.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau menimbulkan\Nriak sekecil apa pun.
Dialogue: 0,0:05:16.44,0:05:17.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Riak apaan?
Dialogue: 0,0:05:18.65,0:05:22.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bukan karena ajakanmu,\Naku tidak akan datang.
Dialogue: 0,0:05:24.87,0:05:29.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano, bagaimana kalau kita coba ke sana?
Dialogue: 0,0:05:30.64,0:05:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:05:33.57,0:05:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya...
Dialogue: 0,0:05:35.25,0:05:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana seperti dunia yang berbeda.
Dialogue: 0,0:05:40.14,0:05:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan penampilan semodis itu,
Dialogue: 0,0:05:42.03,0:05:44.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi takut diabaikan.
Dialogue: 0,0:05:44.81,0:05:46.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik jangan mendekat.
Dialogue: 0,0:05:47.58,0:05:49.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita ke sana.
Dialogue: 0,0:05:49.81,0:05:52.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Tu-Tunggu!
Dialogue: 0,0:05:52.96,0:05:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada yang ingin kamu ambil?
Dialogue: 0,0:05:54.69,0:05:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eng...
Dialogue: 0,0:05:55.23,0:05:56.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kami duduk di sini?
Dialogue: 0,0:05:56.75,0:05:58.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo.
Dialogue: 0,0:06:01.05,0:06:02.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya mereka risi.
Dialogue: 0,0:06:02.62,0:06:04.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:05.08,0:06:06.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Narumi Ushio.
Dialogue: 0,0:06:06.97,0:06:09.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia teman sekamarku di asrama.
Dialogue: 0,0:06:09.64,0:06:11.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Sorano Kakeru.
Dialogue: 0,0:06:11.92,0:06:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namaku Hayase Yuko, dan dia...
Dialogue: 0,0:06:17.52,0:06:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki Koharu.
Dialogue: 0,0:06:21.89,0:06:24.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahnya terlalu sempurna, bikin segan.
Dialogue: 0,0:06:29.85,0:06:31.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melihat apa?
Dialogue: 0,0:06:36.83,0:06:40.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu, gelasnya ada di arah jam 12.
Dialogue: 0,0:06:44.09,0:06:46.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Yuko.
Dialogue: 0,0:06:49.72,0:06:52.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki, penglihatanmu kurang baik?
Dialogue: 0,0:06:53.89,0:06:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:06:56.83,0:06:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa melihat.
Dialogue: 0,0:07:03.97,0:07:06.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi yang mau lanjut, lewat sini.
Dialogue: 0,0:07:07.28,0:07:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu tahu Koharu tidak bisa melihat,\Nmereka langsung pindah ke meja lain.
Dialogue: 0,0:07:12.01,0:07:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:07:14.50,0:07:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja meja kalian\Nseperti pulau terpencil.
Dialogue: 0,0:07:17.33,0:07:18.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulau terpencil?
Dialogue: 0,0:07:18.79,0:07:20.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayak daerah terasing begitu.
Dialogue: 0,0:07:21.36,0:07:22.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perumpamaan apa itu?
Dialogue: 0,0:07:24.22,0:07:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak mengerti\Napa yang dijelaskan dosen itu.
Dialogue: 0,0:07:28.22,0:07:31.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba aku dipanggil,\Nbikin kaget saja.
Dialogue: 0,0:07:32.04,0:07:33.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu lucu banget.
Dialogue: 0,0:07:36.00,0:07:39.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia juga tidak bisa\Nmelihat bulan ini?
Dialogue: 0,0:07:42.55,0:07:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku yang kehilangan penglihatan,
Dialogue: 0,0:07:45.36,0:07:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- pasti tidak bisa tetap seoptimis dia.\N- Kok tiba-tiba ngomong begitu?
Dialogue: 0,0:07:48.70,0:07:50.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, mi campurnya enak.
Dialogue: 0,0:07:51.99,0:07:54.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki, kamu kan tidak bisa melihat,
Dialogue: 0,0:07:54.54,0:07:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kenapa mau ikut acara kumpul-kumpul?
Dialogue: 0,0:07:56.66,0:07:59.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku belum pernah ikut sebelumnya.
Dialogue: 0,0:07:59.75,0:08:02.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena belum pernah ikut, ya?
Dialogue: 0,0:08:02.81,0:08:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bilang apa?
Dialogue: 0,0:08:05.38,0:08:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak suka sama aku?
Dialogue: 0,0:08:08.24,0:08:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:08:10.03,0:08:11.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bercanda.
Dialogue: 0,0:08:12.83,0:08:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu menggandeng tangannya?
Dialogue: 0,0:08:14.76,0:08:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama tidak ada halangan\Ndi jalur ubin pemandu,
Dialogue: 0,0:08:17.52,0:08:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia bisa berjalan sendiri.
Dialogue: 0,0:08:19.95,0:08:22.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah berteman lama?
Dialogue: 0,0:08:22.21,0:08:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bertanya begitu?
Dialogue: 0,0:08:23.34,0:08:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kelihatan terbiasa menemaninya.
Dialogue: 0,0:08:27.04,0:08:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami mulai akrab\Nsaat upacara penerimaan mahasiswa baru.
Dialogue: 0,0:08:30.27,0:08:34.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya nama kami "Hayase" dan "Fuyutsuki",\Njadi urutan absennya pas sebelahan.
Dialogue: 0,0:08:34.62,0:08:36.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:08:37.25,0:08:41.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu di kampus kita ada pekerjaan\Nbernama "pemandu mahasiswa"?
Dialogue: 0,0:08:41.63,0:08:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.
Dialogue: 0,0:08:43.13,0:08:49.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kegiatan sukarelawan untuk membantu\Nmahasiswa difabel beradaptasi di kampus.
Dialogue: 0,0:08:49.55,0:08:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga membantu di sana.
Dialogue: 0,0:08:51.64,0:08:55.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Intinya, kalau tidak ada meminta bantuan,\N- Dia orang yang aneh.
Dialogue: 0,0:08:55.51,0:08:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- sebaiknya jangan asal ikut campur.\N- Terkadang ada yang seperti ini.
Dialogue: 0,0:08:57.63,0:09:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tapi, aku tidak tahan untuk membantu.\N- Tipe yang sangat berbeda denganku.
Dialogue: 0,0:09:01.21,0:09:05.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya Koharu yang memintaku\Nmenemaninya hari ini.
Dialogue: 0,0:09:05.48,0:09:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, setelah jadi mahasiswa,\Ndia ingin mencoba ikut acara kumpul-kumpul.
Dialogue: 0,0:09:11.22,0:09:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hebat, kan?
Dialogue: 0,0:09:13.75,0:09:16.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, memang hebat.
Dialogue: 0,0:09:20.11,0:09:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano, kamu ambil kelas Ilmu Komputer\Ndi jam pertama hari Senin?
Dialogue: 0,0:09:25.88,0:09:29.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku ambil kelas itu.
Dialogue: 0,0:09:29.51,0:09:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi terlalu susah, jadi menyesal.
Dialogue: 0,0:09:32.64,0:09:35.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu juga bilang begitu.
Dialogue: 0,0:09:35.04,0:09:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki?
Dialogue: 0,0:09:37.45,0:09:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tertarik jadi pemandu mahasiswa?
Dialogue: 0,0:09:42.24,0:09:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa bertanya begitu?
Dialogue: 0,0:09:43.77,0:09:45.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup untuk mata kuliah itu saja.
Dialogue: 0,0:09:45.86,0:09:49.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kepikiran apa kamu bisa bantu\Nmemandu Koharu, begitu.
Dialogue: 0,0:09:49.51,0:09:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tapi...
Dialogue: 0,0:09:51.15,0:09:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan senang kalau kamu bisa.
Dialogue: 0,0:09:53.28,0:09:55.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa juga bukan masalah.
Dialogue: 0,0:10:01.62,0:10:02.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:10:02.71,0:10:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak memperhatikan.
Dialogue: 0,0:10:05.75,0:10:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:10:06.88,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:10:08.21,0:10:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepeda usang kayak begini,\Nsiapa pun pasti akan menabraknya.
Dialogue: 0,0:10:12.20,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini biasa terjadi kalau ada sepeda\Nparkir di ubin pemandu.
Dialogue: 0,0:10:17.14,0:10:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga semua orang lebih peduli soal ini.
Dialogue: 0,0:10:19.77,0:10:20.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:10:21.27,0:10:23.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kan?
Dialogue: 0,0:10:23.20,0:10:25.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang pemandu mahasiswa\Nyang kubicarakan tadi...
Dialogue: 0,0:10:25.60,0:10:28.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupertimbangkan lagi.
Dialogue: 0,0:10:28.86,0:10:29.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:10:30.58,0:10:32.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu aku kontakmu.
Dialogue: 0,0:10:32.05,0:10:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:10:36.62,0:10:39.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ubin pemandu itu dirasakan lewat telapak kaki?\N- Oke, sudah ditambahkan.
Dialogue: 0,0:10:39.99,0:10:43.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tolong bantu Koharu kalau kesulitan, ya.\N- Sebenarnya dengan tongkat putih ini.
Dialogue: 0,0:10:43.29,0:10:44.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Parah banget.\N- Sebenarnya dengan tongkat putih ini.
Dialogue: 0,0:10:44.37,0:10:45.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Parah banget.\N- Seperti tangan tambahan.
Dialogue: 0,0:10:50.71,0:10:54.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku mau bilang\Nkalau aku tidak pandai dalam hal itu.
Dialogue: 0,0:10:59.97,0:11:04.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama hidup berpindah-pindah\Nbersama ibu yang bercerai,
Dialogue: 0,0:11:04.52,0:11:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tanpa kusadari,\Nmenemukan zona aman jadi keahlianku.
Dialogue: 0,0:11:08.72,0:11:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana pun, mencolok berarti dibenci.
Dialogue: 0,0:11:12.09,0:11:15.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baca situasi, lalu jadi seperti udara.
Dialogue: 0,0:11:15.64,0:11:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ikut campur.
Dialogue: 0,0:11:19.01,0:11:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu yang terbaik.
Dialogue: 0,0:11:27.17,0:11:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apartemen ini, kan?
Dialogue: 0,0:11:30.88,0:11:33.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apartemennya bagus, ya.
Dialogue: 0,0:11:38.39,0:11:40.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai sini saja tidak apa-apa?
Dialogue: 0,0:11:40.31,0:11:41.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, terima kasih.
Dialogue: 0,0:11:45.52,0:11:47.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara apa itu?
Dialogue: 0,0:11:47.96,0:11:49.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari sebelah sana, ya?
Dialogue: 0,0:11:53.84,0:11:56.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu arah kampus, kan?
Dialogue: 0,0:11:56.03,0:11:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana bisa main kembang api?
Dialogue: 0,0:11:59.62,0:12:01.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembang api, ya?
Dialogue: 0,0:12:03.48,0:12:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati!
Dialogue: 0,0:12:09.65,0:12:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano, tanganmu hangat sekali.
Dialogue: 0,0:12:13.75,0:12:15.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan itu bahaya banget.
Dialogue: 0,0:12:15.76,0:12:17.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:12:17.52,0:12:20.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:12:24.23,0:12:26.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku melewatkannya.
Dialogue: 0,0:12:26.12,0:12:27.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu bisa melihatnya?
Dialogue: 0,0:12:27.24,0:12:28.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa.
Dialogue: 0,0:12:29.11,0:12:32.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya suka kembang api.
Dialogue: 0,0:12:32.69,0:12:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena suka, ya?
Dialogue: 0,0:12:35.97,0:12:40.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari, aku ingin bisa bermain\Nkembang api bersama teman.
Dialogue: 0,0:12:42.53,0:12:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara bermain kembang api
Dialogue: 0,0:12:44.05,0:12:46.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia yang tidak bisa dia lihat, ya?
Dialogue: 0,0:12:47.90,0:12:49.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa bentuk kembang api
Dialogue: 0,0:12:49.43,0:12:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia yang tidak bisa dilihat itu?
Dialogue: 0,0:12:53.61,0:12:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang berpura-pura tegar
Dialogue: 0,0:12:55.29,0:12:56.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau memang isi hatinya?
Dialogue: 0,0:12:57.28,0:12:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang tidak bisa ditebak.
Dialogue: 0,0:13:46.10,0:13:47.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar, deh.
Dialogue: 0,0:13:47.99,0:13:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jago banget maksa orang.
Dialogue: 0,0:14:22.45,0:14:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:14:26.72,0:14:27.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi.
Dialogue: 0,0:14:27.68,0:14:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:29.18,0:14:30.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:14:30.76,0:14:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tidak bisa tahu arah wajah\Natau pandangan lawan bicaranya.
Dialogue: 0,0:14:35.55,0:14:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki, selamat pagi.
Dialogue: 0,0:14:39.91,0:14:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sorano?
Dialogue: 0,0:14:41.99,0:14:44.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kok malah dibalas pertanyaan?
Dialogue: 0,0:14:44.43,0:14:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku tidak tahu lawan bicaraku\Nkalau dia tidak menyebutkan namanya dulu.
Dialogue: 0,0:14:50.77,0:14:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini aku menebak dari suara.
Dialogue: 0,0:14:54.17,0:14:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya suaramu cukup unik.
Dialogue: 0,0:14:57.71,0:14:59.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:14:59.19,0:15:02.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kebanyakan orang bernada Do,
Dialogue: 0,0:15:02.99,0:15:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi suaramu seperti Fa.
Dialogue: 0,0:15:05.01,0:15:07.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu punya pendengaran nada sempurna?
Dialogue: 0,0:15:08.43,0:15:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belajar piano sejak kecil.
Dialogue: 0,0:15:17.38,0:15:19.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, ambillah.
Dialogue: 0,0:15:23.65,0:15:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembatas bukumu jatuh.
Dialogue: 0,0:15:28.21,0:15:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu yang mengambilnya?
Dialogue: 0,0:15:30.98,0:15:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik sekali.
Dialogue: 0,0:15:46.35,0:15:49.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dalam operasi AND
Dialogue: 0,0:15:49.39,0:15:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau keduanya benar,\Nhasilnya adalah benar.
Dialogue: 0,0:15:53.22,0:15:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya untuk operasi OR,
Dialogue: 0,0:15:55.68,0:16:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalau salah satu saja benar,\Nhasilnya otomatis akan menjadi benar.
Dialogue: 0,0:16:00.94,0:16:02.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai contoh...
Dialogue: 0,0:16:02.65,0:16:05.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Saat kita mau naik wahana,\N- Alat ketik braille...
Dialogue: 0,0:16:05.57,0:16:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di pintu masuknya tertulis,\N"Anak-anak di bawah 12 tahun,
Dialogue: 0,0:16:07.74,0:16:10.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- atau lansia di atas 75 tahun dilarang naik."\N- Alat untuk membuat catatan, ya?
Dialogue: 0,0:16:26.21,0:16:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diriku yang tanpa sadar kasihan padanya,
Dialogue: 0,0:16:29.66,0:16:32.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan diriku yang sakit hati\Nkarena menyadari itu...
Dialogue: 0,0:16:35.17,0:16:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulang saja.
Dialogue: 0,0:16:53.73,0:16:55.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan.
Dialogue: 0,0:16:55.81,0:16:57.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat seperti ini,
Dialogue: 0,0:16:57.02,0:16:59.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}masih sempat ragu-ragu...
Dialogue: 0,0:16:59.08,0:17:01.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau malah ingin bergantung\Npada orang lain...
Dialogue: 0,0:17:01.17,0:17:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di sisi lain,\Nlega karena tidak ada orang...
Dialogue: 0,0:17:07.81,0:17:09.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fuyutsuki, tunggu sebentar.
Dialogue: 0,0:17:09.40,0:17:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang ambil.
Dialogue: 0,0:17:11.16,0:17:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:15.43,0:17:16.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nih.
Dialogue: 0,0:17:19.65,0:17:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:17:21.74,0:17:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan masalah.
Dialogue: 0,0:17:25.19,0:17:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu begini aku pasangkan lonceng saja.
Dialogue: 0,0:17:28.06,0:17:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, bukannya percuma\Nsaat berhenti menggelinding?
Dialogue: 0,0:17:32.36,0:17:33.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:17:42.48,0:17:44.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ada kelas jam kedua?
Dialogue: 0,0:17:44.68,0:17:46.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku tidak ambil.
Dialogue: 0,0:17:49.21,0:17:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah ada rencana lain?
Dialogue: 0,0:17:50.92,0:17:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mencari tempat bersantai?
Dialogue: 0,0:17:55.52,0:17:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuko menghubungiku kalau dia ada urusan.
Dialogue: 0,0:17:58.28,0:18:00.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menghubungi?\NLewat telepon?
Dialogue: 0,0:18:00.68,0:18:02.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan, lewat LIME.
Dialogue: 0,0:18:02.44,0:18:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu bisa pakai LIME?
Dialogue: 0,0:18:05.84,0:18:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nanti kuberi tahu caranya.
Dialogue: 0,0:18:12.93,0:18:14.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau minum apa?
Dialogue: 0,0:18:14.72,0:18:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa beli sendiri.
Dialogue: 0,0:18:20.35,0:18:22.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caramu memilih tadi?
Dialogue: 0,0:18:23.73,0:18:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu penasaran?
Dialogue: 0,0:18:25.36,0:18:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya kamu tidak bisa melihat?
Dialogue: 0,0:18:29.16,0:18:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mesin penjual otomatis khusus untukku.
Dialogue: 0,0:18:33.43,0:18:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Fuyutsuki, keluarga Anda\Npengelola mesin penjual otomatis?
Dialogue: 0,0:18:40.63,0:18:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.
Dialogue: 0,0:18:43.19,0:18:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya kamu menegaskan\Nmesin itu milikmu.
Dialogue: 0,0:18:50.55,0:18:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata kamu suka bercanda, ya?
Dialogue: 0,0:18:54.30,0:18:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang aku dianggap cowok madesu\Nyang tidak bisa bercanda?
Dialogue: 0,0:18:58.08,0:19:00.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Madesu?
Dialogue: 0,0:19:03.69,0:19:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa selucu itu?
Dialogue: 0,0:19:06.27,0:19:08.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin penjual otomatis khusus itu
Dialogue: 0,0:19:08.15,0:19:11.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mesin yang sering kami gunakan.
Dialogue: 0,0:19:11.21,0:19:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagi kami, mesin yang asing itu\Nibarat Rolet Rusia.
Dialogue: 0,0:19:16.68,0:19:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suka kejadian pas mau minum teh susu,\Ndapatnya malah sup kacang merah.
Dialogue: 0,0:19:20.66,0:19:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya menarik.
Dialogue: 0,0:19:24.42,0:19:28.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf telah berpikiran begitu.
Dialogue: 0,0:19:28.03,0:19:30.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu minta maaf.
Dialogue: 0,0:19:30.97,0:19:33.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang itu cukup menyenangkan,
Dialogue: 0,0:19:33.48,0:19:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi repot kalau keseringan,
Dialogue: 0,0:19:36.22,0:19:38.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku terus beli di mesin yang sama.
Dialogue: 0,0:19:38.61,0:19:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya...
Dialogue: 0,0:19:39.77,0:19:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mesin penjual otomatis milikmu?
Dialogue: 0,0:19:41.95,0:19:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tepat sekali.
Dialogue: 0,0:19:44.62,0:19:49.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuko pernah memberitahuku semua tombolnya,\Njadi aku cukup paham mesin ini.
Dialogue: 0,0:19:49.37,0:19:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ingat semua tombol minumannya?
Dialogue: 0,0:19:52.21,0:19:56.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku hanya ingat tombol\Nmenambah gula dan teh susu.
Dialogue: 0,0:19:56.57,0:19:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa harus dilebih-lebihkan?
Dialogue: 0,0:19:58.55,0:20:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu cuma kiasan, kok.
Dialogue: 0,0:20:02.65,0:20:07.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berinteraksi dengannya begini membuatku\Nsering lupa kalau dia tidak bisa melihat.
Dialogue: 0,0:20:08.63,0:20:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembaca Layar?
Dialogue: 0,0:20:10.85,0:20:11.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:12.69,0:20:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponsel zaman sekarang\Nsudah punya fitur ini.
Dialogue: 0,0:20:15.94,0:20:17.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti ini.
Dialogue: 0,0:20:17.39,0:20:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu, maaf, hari ini aku ada urusan.
Dialogue: 0,0:20:21.19,0:20:23.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada yang membacakan teksnya.
Dialogue: 0,0:20:23.83,0:20:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketuk sekali untuk dibacakan,\Ndua kali untuk memilih.
Dialogue: 0,0:20:28.67,0:20:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerakan dua jari dan tiga jari juga\Nmemiliki fungsi yang berbeda.
Dialogue: 0,0:20:32.17,0:20:34.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perlu usaha keras untuk menghafalkannya.
Dialogue: 0,0:20:34.21,0:20:36.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.\NKayaknya susah, ya.
Dialogue: 0,0:20:37.30,0:20:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang susah, tapi kalau sudah kepepet,\Nmanusia bisa melakukan apa pun.
Dialogue: 0,0:20:43.01,0:20:44.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana caramu mengetik?
Dialogue: 0,0:20:45.29,0:20:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku memakai masukan suara.
Dialogue: 0,0:20:47.52,0:20:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang pesanku ada salah ketik.\NMohon dimaklumi, ya.
Dialogue: 0,0:20:52.20,0:20:54.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Narumi pernah menanyakan\Nhal yang sama juga padaku.
Dialogue: 0,0:20:54.94,0:20:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kujelaskan, dia malah ingin\Nmenambahkanku sebagai teman.
Dialogue: 0,0:21:00.74,0:21:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sebagai penyandang tunanetra,
Dialogue: 0,0:21:03.07,0:21:05.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kami menjalani hidup\Nyang hampir sama dengan kalian.
Dialogue: 0,0:21:07.10,0:21:11.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bisa dengan begitu tenang\Nmengatakan dirinya penyandang tunanetra.
Dialogue: 0,0:21:12.82,0:21:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu aku,
Dialogue: 0,0:21:14.25,0:21:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mustahil bisa dengan ceria mengatakan\Naku dari keluarga orang tua tunggal.
Dialogue: 0,0:21:19.78,0:21:23.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah berapa banyak konflik batin\Nyang telah dilaluinya selama ini.
Dialogue: 0,0:21:24.96,0:21:26.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai tidak mengerti
Dialogue: 0,0:21:27.11,0:21:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mana yang boleh kutanyakan
Dialogue: 0,0:21:29.06,0:21:32.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mana yang akan menyakitinya.
Dialogue: 0,0:21:34.63,0:21:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa ada tembok tidak terlihat.
Dialogue: 0,0:21:38.45,0:21:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dinding yang kuciptakan sendiri.
Dialogue: 0,0:21:43.27,0:21:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup dengarkan dan bicara dengan baik.
Dialogue: 0,0:21:48.48,0:21:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti...\NKukira aku sudah memahami itu.
Dialogue: 0,0:21:54.78,0:21:57.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong beri tahu punyamu juga.
Dialogue: 0,0:21:57.46,0:21:58.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:21:58.36,0:21:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:22:02.78,0:22:06.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh minta tolong pindai kodeku?
Dialogue: 0,0:22:10.57,0:22:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Foto profilnya gambar bunga\Nyang belum pernah kulihat.
