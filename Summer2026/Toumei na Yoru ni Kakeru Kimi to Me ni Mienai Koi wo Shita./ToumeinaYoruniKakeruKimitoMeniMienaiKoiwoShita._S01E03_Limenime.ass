Dialogue: 0,0:00:03.98,0:00:06.19,sign,,0000,0000,0000,,TERIMA KASIH ATAS PEMBELIANNYA
Dialogue: 0,0:00:12.12,0:00:16.62,sign,,0000,0000,0000,,TANPA GULA, DENGAN GULA\NKOPI BRAZIL
Dialogue: 0,0:01:07.30,0:01:17.85,sign,,0000,0000,0000,,LOVE UNSEEN BENEATH THE CLEAR NIGHT SKY
Dialogue: 0,0:06:29.04,0:06:29.99,sign,,0000,0000,0000,,ADA HAL YANG INGIN KAMU KETAHUI
Dialogue: 0,0:07:32.86,0:07:35.14,sign,,0000,0000,0000,,HARI-HARI KETIKA MENYATAKAN CINTA PADAMU
Dialogue: 0,0:07:45.40,0:07:46.80,sign,,0000,0000,0000,,MEMUDAR KE LANGIT MALAM\NHINGGA MENGHILANG
Dialogue: 0,0:15:14.87,0:15:16.15,sign,,0000,0000,0000,,DILARANG MASUK TANPA IZIN
Dialogue: 0,0:16:15.54,0:16:23.46,sign,,0000,0000,0000,,KLUB PENELITIAN KEMBANG API
Dialogue: 0,0:16:26.80,0:16:30.74,sign,,0000,0000,0000,,APAR
Dialogue: 0,0:16:33.68,0:16:36.52,sign,,0000,0000,0000,,KLUB PENELITIAN KEMBANG API
Dialogue: 0,0:17:15.93,0:17:18.64,sign,,0000,0000,0000,,JAUHKAN DARI API
Dialogue: 0,0:20:37.76,0:20:38.88,sign,,0000,0000,0000,,FUYUTSUKI KOHARU
Dialogue: 0,0:22:24.70,0:22:29.95,sign,,0000,0000,0000,,PEMBATAS BUKU KUNING
Dialogue: 0,0:00:06.19,0:00:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:00:07.86,0:00:12.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teh susu yang biasa kubeli habis.
Dialogue: 0,0:00:17.20,0:00:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:00:18.83,0:00:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tombol yang biasa dia tekan
Dialogue: 0,0:00:21.38,0:00:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sedang tidak bisa dipakai.
Dialogue: 0,0:00:24.40,0:00:26.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau beli yang lain saja?
Dialogue: 0,0:00:26.00,0:00:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih saja antara kopi atau jus,\Nnanti aku bantu tekan.
Dialogue: 0,0:00:29.76,0:00:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pilih yang mana, ya?
Dialogue: 0,0:00:32.88,0:00:34.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini!
Dialogue: 0,0:00:34.35,0:00:36.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu yakin?
Dialogue: 0,0:00:36.72,0:00:38.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:00:38.53,0:00:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesekali ingin coba yang seperti ini, kan?
Dialogue: 0,0:00:42.61,0:00:44.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia bilang begitu...
Dialogue: 0,0:00:44.59,0:00:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah kepikiran\Nmemilih minuman
Dialogue: 0,0:00:47.95,0:00:50.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sambil menutup mata.
Dialogue: 0,0:02:23.82,0:02:25.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat senggang selepas kuliah,
Dialogue: 0,0:02:25.95,0:02:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi biasa menghabiskan waktu\Nbersama Fuyutsuki di teras.
Dialogue: 0,0:02:31.30,0:02:36.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya dia mengajakku minum teh\Ndi teras lagi tempo hari.
Dialogue: 0,0:02:36.96,0:02:38.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Susah juga menolaknya.
Dialogue: 0,0:02:47.12,0:02:49.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf menunggu.
Dialogue: 0,0:02:54.50,0:02:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:02:56.82,0:03:00.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya firasatku jelek.
Dialogue: 0,0:03:12.00,0:03:13.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu kenapa?
Dialogue: 0,0:03:14.45,0:03:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak kuat minum soda.
Dialogue: 0,0:03:17.38,0:03:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu membuat tenggorokanku terbakar.
Dialogue: 0,0:03:21.95,0:03:25.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu, sih, coba-coba rolet Rusia.
Dialogue: 0,0:03:28.30,0:03:33.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Kakeru, boleh minta tolong\Nhabiskan minumannya?
Dialogue: 0,0:03:33.90,0:03:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh saja.
Dialogue: 0,0:03:41.39,0:03:43.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh langsung diminum saja, nih?
Dialogue: 0,0:03:44.77,0:03:47.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau terlalu dipikirkan,\Naku merasa kalah.
Dialogue: 0,0:03:47.22,0:03:50.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pura-pura tidak dipikirkan pun\Njuga merasa kalah.
Dialogue: 0,0:03:50.96,0:03:52.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:03:54.96,0:03:56.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa boleh buat.
Dialogue: 0,0:04:10.51,0:04:12.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, itu dia.
Dialogue: 0,0:04:14.15,0:04:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu.
Dialogue: 0,0:04:17.25,0:04:18.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuko!
Dialogue: 0,0:04:19.83,0:04:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kok kamu bareng dia?\N- Pagi.
Dialogue: 0,0:04:22.40,0:04:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami kebetulan bertemu,\Ndan sudah tidak ada kelas hari ini.
Dialogue: 0,0:04:26.03,0:04:28.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kami ingin mengusulkan\Nmain ke suatu tempat.
Dialogue: 0,0:04:28.86,0:04:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, kan?
Dialogue: 0,0:04:29.87,0:04:31.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:04:31.75,0:04:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh juga.
Dialogue: 0,0:04:34.00,0:04:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau makan dulu?
Dialogue: 0,0:04:36.74,0:04:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah!
Dialogue: 0,0:04:37.90,0:04:39.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:04:39.66,0:04:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau boleh,
Dialogue: 0,0:04:40.89,0:04:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian mau karaoke tidak?
Dialogue: 0,0:04:43.39,0:04:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, waktu itu kamu bilang\Nbelum pernah ke sana, ya?
Dialogue: 0,0:04:47.89,0:04:53.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, dari dulu aku ingin coba ke sana.
Dialogue: 0,0:04:53.65,0:04:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh, di sana juga ada makanan.
Dialogue: 0,0:04:57.67,0:04:59.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ikut.
Dialogue: 0,0:05:00.42,0:05:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi tidak sabar!
Dialogue: 0,0:05:02.00,0:05:03.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahu tempat terdekat?
Dialogue: 0,0:05:03.36,0:05:07.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat yang buka di Monzennakacho...
Dialogue: 0,0:05:07.07,0:05:09.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karaoke, ya?
Dialogue: 0,0:05:23.17,0:05:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuko, kamu jago nyanyi!
Dialogue: 0,0:05:25.64,0:05:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau penyanyi pertamanya sejago ini,\Nyang selanjutnya jadi tertekan.
Dialogue: 0,0:05:30.91,0:05:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakeru, Yuko jago banget menyanyi, ya?
Dialogue: 0,0:05:35.09,0:05:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya.
Dialogue: 0,0:05:37.15,0:05:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dekat, dia terlalu dekat...
Dialogue: 0,0:05:47.74,0:05:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia juga jago!
Dialogue: 0,0:05:50.77,0:05:53.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu akan menyanyikan lagu apa, Kakeru?
Dialogue: 0,0:05:53.44,0:05:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku nanti saja.
Dialogue: 0,0:05:56.35,0:05:58.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu duluan saja, Fuyutsuki.
Dialogue: 0,0:05:59.40,0:06:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana cara memilih lagu di karaoke?
Dialogue: 0,0:06:03.63,0:06:08.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga, bagaimana cara Fuyutsuki\Nmenambah lagu, ya?
Dialogue: 0,0:06:10.52,0:06:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebut saja, nanti biar kutambahkan lagunya.
Dialogue: 0,0:06:13.64,0:06:15.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu.
Dialogue: 0,0:06:15.22,0:06:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bareng-bareng,
Dialogue: 0,0:06:16.56,0:06:19.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- tinggal minta tolong teman saja.\N- Aku juga suka!
Dialogue: 0,0:06:19.30,0:06:21.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu juga suka?
Dialogue: 0,0:06:21.28,0:06:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, soalnya lagu kembang api.
Dialogue: 0,0:06:25.31,0:06:27.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia suka banget kembang api.
Dialogue: 0,0:06:58.40,0:07:00.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Koharu, kamu jago banget!
Dialogue: 0,0:07:00.88,0:07:03.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai kaget!
Dialogue: 0,0:07:03.66,0:07:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya kamu, Kakeru.
Dialogue: 0,0:07:06.16,0:07:08.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tunjukkan bakatmu, Sorano!\N- Tekanannya bukan main.
Dialogue: 0,0:07:08.58,0:07:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Eh, Sorano nyanyi lagu apa?\N- Jujur aku tidak jago nyanyi.
Dialogue: 0,0:07:11.17,0:07:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah fales banget.
Dialogue: 0,0:07:13.26,0:07:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyanyi setelah suara indahnya Fuyutsuki\Npasti bikin suasana canggung.
Dialogue: 0,0:07:18.64,0:07:20.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak usah...
Dialogue: 0,0:07:20.25,0:07:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakeru, semangat!
Dialogue: 0,0:07:24.32,0:07:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bodo amat, ah.
Dialogue: 0,0:07:30.76,0:07:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ingin lagu gampang,
Dialogue: 0,0:07:32.86,0:07:35.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}malah kepilih
Dialogue: 0,0:07:35.14,0:07:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lagu cinta.
Dialogue: 0,0:07:50.03,0:07:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:07:51.78,0:07:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku memang tidak bisa nyanyi.
Dialogue: 0,0:07:59.00,0:08:01.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf bikin kalian terpaksa menyemangatiku.
Dialogue: 0,0:08:03.20,0:08:06.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tahu lagu ini.
Dialogue: 0,0:08:14.90,0:08:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lirik yang isinya cuma soal\N"kamu yang berharga"
Dialogue: 0,0:08:18.83,0:08:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau "aku mencintaimu",
Dialogue: 0,0:08:21.25,0:08:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bikin geli sampai malu banget rasanya.
Dialogue: 0,0:08:23.93,0:08:26.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi begitu melihat Fuyutsuki\Ntertawa di sampingku,
Dialogue: 0,0:08:26.46,0:08:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku merasa bernyanyi itu\Njadi menyenangkan.
Dialogue: 0,0:08:30.66,0:08:35.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lukisan itu ternyata gambar dua ekor\Nyang berenang sambil bercanda.
Dialogue: 0,0:08:51.62,0:08:53.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakeru?
Dialogue: 0,0:08:53.10,0:08:54.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:08:54.39,0:08:57.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kira kamu pergi.
Dialogue: 0,0:08:57.85,0:09:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya aku menghapus hawa kehadiranku.
Dialogue: 0,0:09:01.96,0:09:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar jail.
Dialogue: 0,0:09:05.73,0:09:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut Fuyutsuki, kalau aku diam sebentar\Ndan menghilangkan kehadiranku,
Dialogue: 0,0:09:09.63,0:09:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya benar-benar seperti tidak ada.
Dialogue: 0,0:09:12.36,0:09:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya caraku menghilangkan kehadiran ini\Nbeda jauh dari orang lain.
Dialogue: 0,0:09:17.75,0:09:22.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sangka bisa jadi seakrab ini\Nsampai bisa bercanda santai
Dialogue: 0,0:09:22.67,0:09:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama Fuyutsuki.
Dialogue: 0,0:09:25.46,0:09:28.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah karena ritmenya cocok atau apa,
Dialogue: 0,0:09:28.64,0:09:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi rasanya nyaman saja.
Dialogue: 0,0:09:31.57,0:09:35.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku merasa senang\Nmengobrol sama perempuan.
Dialogue: 0,0:09:36.96,0:09:41.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong,\Nbuku apa yang sering kamu baca itu?
Dialogue: 0,0:09:41.73,0:09:43.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:09:43.44,0:09:44.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini?
Dialogue: 0,0:09:44.51,0:09:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, itu.
Dialogue: 0,0:09:47.60,0:09:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Judulnya tertulis di sini.
Dialogue: 0,0:09:49.94,0:09:52.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa baca tulisan braille.
Dialogue: 0,0:09:53.89,0:09:55.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Buku Harian Anne".
Dialogue: 0,0:09:55.70,0:09:58.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Buku Harian Anne!
Dialogue: 0,0:09:58.45,0:10:00.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Kamu pernah baca?
Dialogue: 0,0:10:00.96,0:10:02.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum pernah.
Dialogue: 0,0:10:02.38,0:10:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, reaksimu seperti sudah pernah baca.
Dialogue: 0,0:10:07.09,0:10:08.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu suka itu?
Dialogue: 0,0:10:08.34,0:10:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:10:10.50,0:10:13.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat sosok yang hidup dengan kuat\Ndan pantang menyerah,
Dialogue: 0,0:10:13.59,0:10:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatku ingin berjuang juga.
Dialogue: 0,0:10:16.72,0:10:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, ada satu bagian\Nyang sangat kusukai,
Dialogue: 0,0:10:19.18,0:10:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi sering membaca ulang\Nbagian itu saja.
Dialogue: 0,0:10:22.85,0:10:25.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baca tulisan braille itu susah tidak?
Dialogue: 0,0:10:26.00,0:10:30.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya memang butuh waktu,\Ntapi nanti juga terbiasa.
Dialogue: 0,0:10:30.69,0:10:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belakangan ini sudah banyak buku audio,\Njadi bisa mendengarkan itu saja,
Dialogue: 0,0:10:36.20,0:10:40.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ada sensasi menyenangkan\Nsaat menyentuh kertas.
Dialogue: 0,0:10:41.70,0:10:43.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah.
Dialogue: 0,0:10:43.58,0:10:46.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau coba baca braille juga?
Dialogue: 0,0:10:53.46,0:10:54.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:10:54.51,0:10:56.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan "Oh," doang!
Dialogue: 0,0:10:56.35,0:10:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar kupertimbangkan dulu.
Dialogue: 0,0:10:58.37,0:11:01.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu perkataan orang malas.
Dialogue: 0,0:11:01.62,0:11:03.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, ini apa?
Dialogue: 0,0:11:04.40,0:11:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang mana?
Dialogue: 0,0:11:06.90,0:11:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh.
Dialogue: 0,0:11:08.93,0:11:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pembatas buku buatanku.
Dialogue: 0,0:11:12.21,0:11:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tulisannya?
Dialogue: 0,0:11:15.18,0:11:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin kamu bisa segera membacanya.
Dialogue: 0,0:11:19.03,0:11:22.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan coba cari tahu\Nkalau lagi ada motivasi.
Dialogue: 0,0:11:22.29,0:11:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perkataan orang malas lagi.
Dialogue: 0,0:11:26.62,0:11:29.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu memang orang yang menarik.
Dialogue: 0,0:11:30.54,0:11:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakeru, kamu suka kembang api luncur?
Dialogue: 0,0:11:34.74,0:11:36.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah tanya soal itu.
Dialogue: 0,0:11:36.22,0:11:38.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masa, sih?
Dialogue: 0,0:11:38.30,0:11:40.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal kembang api...
Dialogue: 0,0:11:40.80,0:11:43.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kampung halamanku ada di Shimonoseki.
Dialogue: 0,0:11:43.28,0:11:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, karena aku sering pindah,
Dialogue: 0,0:11:46.04,0:11:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu hanya tempat tinggal\Nsebelum pindah ke sini.
Dialogue: 0,0:11:50.15,0:11:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada acara namanya\NFestival Kembang Api Selat Kanmon,
Dialogue: 0,0:11:52.83,0:11:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat kembang api diluncurkan\Nbersamaan dari dua sisi selat,
Dialogue: 0,0:11:57.28,0:12:00.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dari Shimonoseki\Ndan Pelabuhan Moji di Fukuoka.
Dialogue: 0,0:12:00.74,0:12:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu kecil aku pernah ke sana\Nsama orang tua...
Dialogue: 0,0:12:08.02,0:12:10.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramai banget di sana.
Dialogue: 0,0:12:12.56,0:12:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kukira akan mendengar cerita indah,
Dialogue: 0,0:12:16.63,0:12:19.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata cuma pendapat anehmu.
Dialogue: 0,0:12:19.04,0:12:21.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian benaran ramai banget.
Dialogue: 0,0:12:21.71,0:12:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Festival kembang api kedua\Npaling ramai di Jepang.
Dialogue: 0,0:12:26.03,0:12:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu banget, deh.
Dialogue: 0,0:12:28.60,0:12:31.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku penasaran ingin ke sana.
Dialogue: 0,0:12:31.15,0:12:33.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti sangat meriah.
Dialogue: 0,0:12:33.49,0:12:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kembang apinya diluncurkan\Ndari dua sisi selat.
Dialogue: 0,0:12:37.09,0:12:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi banyak orang.
Dialogue: 0,0:12:39.36,0:12:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya ada di kerumunan penonton\Nkembang api itu seru?
Dialogue: 0,0:12:42.74,0:12:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:45.17,0:12:49.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya menengadah ke langit malam.
Dialogue: 0,0:12:49.00,0:12:54.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan dipenuhi orang-orang\Nyang sedang berbahagia.
Dialogue: 0,0:12:54.05,0:12:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dilihat dengan cara seperti itu,\Nkembang api jadi luar biasa, kan?
Dialogue: 0,0:13:00.94,0:13:03.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bisa berkata-kata.
Dialogue: 0,0:13:03.01,0:13:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah melihat\Ndengan cara seperti itu.
Dialogue: 0,0:13:07.14,0:13:10.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya dunia seperti apa\Nyang dilihat Fuyutsuki?
Dialogue: 0,0:13:11.26,0:13:13.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia yang dilihat dirinya\Nyang tidak bisa melihat,
Dialogue: 0,0:13:13.83,0:13:15.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasti berbeda dariku.
Dialogue: 0,0:13:17.47,0:13:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memang mengagumkan.
Dialogue: 0,0:13:22.51,0:13:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata bisa juga bikin pembatas buku\Nbraille seperti ini.
Dialogue: 0,0:13:26.43,0:13:30.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada alat pencetak khusus,\Nsebenarnya cukup mudah.
Dialogue: 0,0:13:31.33,0:13:35.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu permukaannya bertekstur,\Ntapi tidak menyangka ini tulisan.
Dialogue: 0,0:13:35.55,0:13:37.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat juga yang bisa membacanya.
Dialogue: 0,0:13:38.30,0:13:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kubuat waktu sudah jadi mahasiswa.
Dialogue: 0,0:13:41.79,0:13:43.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu pernah bikin daftar hal
Dialogue: 0,0:13:43.73,0:13:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang ingin dilakukan sebelum mati?
Dialogue: 0,0:13:47.15,0:13:48.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang ingin dilakukan?
Dialogue: 0,0:13:50.13,0:13:52.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menang lotre,
Dialogue: 0,0:13:52.40,0:13:56.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus mengurung diri di rumah\Nsambil baca buku.
Dialogue: 0,0:13:56.23,0:13:59.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, rasanya bukan hal yang ingin\Ndilakukan sebelum mati,
Dialogue: 0,0:13:59.63,0:14:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih ke angan-angan biasa.
Dialogue: 0,0:14:02.11,0:14:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia tidak pernah tahu\Nkapan akan mati.
Dialogue: 0,0:14:06.12,0:14:07.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:07.86,0:14:10.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku cuma bercanda, kok.
Dialogue: 0,0:14:10.82,0:14:13.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan begitu, dong.
Dialogue: 0,0:14:19.00,0:14:20.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:14:34.10,0:14:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:14:37.68,0:14:39.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:39.23,0:14:42.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pembatas bukumu terbawa angin.
Dialogue: 0,0:14:42.99,0:14:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:14:45.15,0:14:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:14:47.28,0:14:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, lagian aku\Nmasih ingat tulisannya.
Dialogue: 0,0:14:52.90,0:14:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:14:57.47,0:14:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tahu?
Dialogue: 0,0:14:59.73,0:15:03.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya ada\NKlub Penelitian Kembang Api.
Dialogue: 0,0:15:03.30,0:15:04.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:15:08.40,0:15:12.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin karena kampus ini punya\Njurusan pelatihan navigator kapal,
Dialogue: 0,0:15:12.21,0:15:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ada tempat berlabuh bernama Pond
Dialogue: 0,0:15:14.87,0:15:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di area kampus,
Dialogue: 0,0:15:16.15,0:15:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memang ada kapal kecil di sana.
Dialogue: 0,0:15:20.11,0:15:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut Fuyutsuki,
Dialogue: 0,0:15:21.65,0:15:25.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sebelah gudang kapal pertama di depan\Npond itu ada bangunan pracetak,
Dialogue: 0,0:15:25.44,0:15:28.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat Klub Penelitian Kembang Api\Nberaktivitas.
Dialogue: 0,0:15:28.85,0:15:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang dia dengar dari Hayase.
Dialogue: 0,0:15:32.10,0:15:34.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah karena rasa bersalah sudah\Nmenghilangkan pembatas buku,
Dialogue: 0,0:15:34.82,0:15:39.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa menolak ajakan Fuyutsuki\Nuntuk diantar ke sana.
Dialogue: 0,0:15:39.54,0:15:43.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya aku merasa tidak enak\Nminta bantuan Yuko terus.
Dialogue: 0,0:15:43.92,0:15:47.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pagi hari ini,\NHayase ada kerja sambilan, ya?
Dialogue: 0,0:15:47.65,0:15:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, saat ini dia lagi kerja di kafe.
Dialogue: 0,0:15:52.31,0:15:55.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yuko terlihat lebih menawan
Dialogue: 0,0:15:55.54,0:15:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}saat ada aroma kopi di sekitarnya.
Dialogue: 0,0:15:58.21,0:16:01.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku setuju dengan pendapatmu.
Dialogue: 0,0:16:01.89,0:16:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi ingin kerja sambilan juga, deh.
Dialogue: 0,0:16:08.63,0:16:10.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini tempatnya.
Dialogue: 0,0:16:10.53,0:16:12.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya seperti apa?
Dialogue: 0,0:16:13.52,0:16:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya...
Dialogue: 0,0:16:15.54,0:16:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:16:17.42,0:16:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak menjelaskan.
Dialogue: 0,0:16:20.17,0:16:23.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bangunan pracetak seperti gudang,
Dialogue: 0,0:16:23.46,0:16:26.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di pintunya tertulis\N"Klub Penelitian Kembang Api".
Dialogue: 0,0:16:26.80,0:16:30.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di sekelilingnya, banyak tabung besi berjejer,
Dialogue: 0,0:16:30.74,0:16:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai dari sekitar 20 senti\Nsampai setinggi lutut.
Dialogue: 0,0:16:33.68,0:16:36.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempatnya seperti sarang monster begitu.
Dialogue: 0,0:16:36.52,0:16:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?\NMau kuketuk pintunya?
Dialogue: 0,0:16:40.02,0:16:41.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:16:50.29,0:16:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tidak ada orang.
Dialogue: 0,0:16:52.41,0:16:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya?
Dialogue: 0,0:16:57.41,0:16:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa?
Dialogue: 0,0:17:03.92,0:17:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf.
Dialogue: 0,0:17:05.42,0:17:08.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu anggota penelitian ini?
Dialogue: 0,0:17:08.31,0:17:11.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Kotomugi Yuichi,\Nperwakilan klub ini.
Dialogue: 0,0:17:11.18,0:17:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi anggotanya cuma aku.
Dialogue: 0,0:17:13.98,0:17:15.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada perlu apa memangnya?
Dialogue: 0,0:17:15.93,0:17:18.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya ingin berkunjung.
Dialogue: 0,0:17:21.41,0:17:24.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan di sampingmu\Ntidak bisa melihat?
Dialogue: 0,0:17:24.65,0:17:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, iya.
Dialogue: 0,0:17:27.56,0:17:31.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa melihat,\Ntapi tertarik sama kembang api.
Dialogue: 0,0:17:31.09,0:17:33.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya bukan masalah juga.
Dialogue: 0,0:17:34.28,0:17:38.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa menikmati dari suaranya juga.
Dialogue: 0,0:17:38.10,0:17:41.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini bisa meluncurkan kembang api?
Dialogue: 0,0:17:42.24,0:17:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:43.49,0:17:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya waktu itu ada kembang api\Ndari arah kampus.
Dialogue: 0,0:17:50.62,0:17:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu pesta penyambutan.
Dialogue: 0,0:17:52.43,0:17:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya memang ada kembang api\Ndari sekitar Pond.
Dialogue: 0,0:17:58.50,0:18:02.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin coba\Nmeluncurkan kembang api.
Dialogue: 0,0:18:02.53,0:18:06.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya tidak bisa lihat bersama\Nteman-teman dari kejauhan saja?
Dialogue: 0,0:18:06.40,0:18:09.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bisa, ingin dari dekat.
Dialogue: 0,0:18:09.90,0:18:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agak susah, sih, soalnya berbahaya.
Dialogue: 0,0:18:14.66,0:18:17.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apalagi tidak bisa melihat,\Nitu lebih bahaya.
Dialogue: 0,0:18:18.96,0:18:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pasti luka bakar dari kembang api.
Dialogue: 0,0:18:22.72,0:18:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia serius ingin menekankan\Nbetapa berbahanya itu.
Dialogue: 0,0:18:26.88,0:18:29.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu hanya bisa tersampaikan\Nkalau bisa melihat.
Dialogue: 0,0:18:30.11,0:18:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:18:31.46,0:18:33.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:35.07,0:18:36.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.
Dialogue: 0,0:18:36.80,0:18:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jelaskan padaku.
Dialogue: 0,0:18:45.07,0:18:47.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Fuyutsuki.
Dialogue: 0,0:18:51.70,0:18:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barusan ada apa?
Dialogue: 0,0:18:54.40,0:18:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya?
Dialogue: 0,0:18:55.87,0:19:00.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sunyi, kukira dia sedang\Nmenunjukkan sesuatu.
Dialogue: 0,0:19:00.96,0:19:03.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menunjukkan\Nbekas luka bakar di lengannya.
Dialogue: 0,0:19:04.02,0:19:05.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:05.92,0:19:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sedih saat ada yang menyerah\Nuntuk menjelaskan padaku.
Dialogue: 0,0:19:11.68,0:19:14.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak salah, delapan puluh persen.
Dialogue: 0,0:19:14.32,0:19:17.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya manusia mendapat informasi\Nkebanyakan lewat penglihatan.
Dialogue: 0,0:19:17.73,0:19:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kontak mata, gestur, dan semacamnya.
Dialogue: 0,0:19:20.68,0:19:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketika itu semua tidak bisa dilakukan,\Nakan dianggap tidak akan pernah bisa.
Dialogue: 0,0:19:25.41,0:19:28.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang bisa terasa\Nmenyakitkan di hati.
Dialogue: 0,0:19:30.03,0:19:31.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau menyerah.
Dialogue: 0,0:19:33.69,0:19:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:19:37.32,0:19:40.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita luncurkan kembang api!
Dialogue: 0,0:19:40.20,0:19:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menolak.
Dialogue: 0,0:19:41.70,0:19:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, apa kamu tidak kesal?
Dialogue: 0,0:19:44.69,0:19:46.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:19:46.33,0:19:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya, ada toko kembang api\Ndi Asakusabashi!
Dialogue: 0,0:19:50.84,0:19:52.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menolak dengan tegas!
Dialogue: 0,0:19:52.59,0:19:54.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu kali lagi!
Dialogue: 0,0:19:54.21,0:19:56.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apanya yang satu kali lagi?
Dialogue: 0,0:19:56.84,0:19:59.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Kakeru orangnya baik banget.
Dialogue: 0,0:19:59.50,0:20:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku disangka mau ikut, nih?
Dialogue: 0,0:20:05.54,0:20:08.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah menghilangkan\Npembatas bukuku, kan?
Dialogue: 0,0:20:08.44,0:20:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:09.81,0:20:11.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon.
Dialogue: 0,0:20:11.77,0:20:14.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan berangkatnya?
Dialogue: 0,0:20:24.16,0:20:27.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besok, ya?
Dialogue: 0,0:20:29.22,0:20:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tentukan pakaian\Nbuat besok dulu, deh.
Dialogue: 0,0:20:37.76,0:20:38.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:20:38.88,0:20:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:20:40.76,0:20:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ada urusan mendadak besok?
Dialogue: 0,0:20:43.84,0:20:47.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu berita bagu—\NBukan, sayang kalau tidak jadi.
Dialogue: 0,0:20:48.24,0:20:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, Sorano di sini.
Dialogue: 0,0:20:52.08,0:20:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo?
Dialogue: 0,0:20:52.88,0:20:55.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha-Halo, aku Fuyutsuki Koharu.
Dialogue: 0,0:20:55.71,0:20:59.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, kok.\NAda apa?
Dialogue: 0,0:20:59.11,0:21:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku menelepon hari ini
Dialogue: 0,0:21:04.08,0:21:09.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena belum menentukan tempat\Ndan waktu ketemuan besok.
Dialogue: 0,0:21:09.12,0:21:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya jadi gugup.
Dialogue: 0,0:21:12.38,0:21:16.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa gugup?\NKita kan sering mengobrol di kampus.
Dialogue: 0,0:21:16.69,0:21:21.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengobrol langsung\Ndan lewat telepon itu berbeda, ya.
Dialogue: 0,0:21:21.78,0:21:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya sangat malu.
Dialogue: 0,0:21:26.89,0:21:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membayangkan Fuyutsuki yang sedang tersipu malu,
Dialogue: 0,0:21:31.46,0:21:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuat wajahku terasa panas.
Dialogue: 0,0:21:34.88,0:21:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Duh, aku juga jadi ikut malu!
Dialogue: 0,0:21:37.65,0:21:40.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo kita tentukan tempat\Ndan waktu ketemuannya.
Dialogue: 0,0:21:40.34,0:21:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ayo.
Dialogue: 0,0:21:43.04,0:21:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kujemput di depan\Napartemenmu saja?
Dialogue: 0,0:21:46.24,0:21:49.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya bukan seperti kencan, dong?
Dialogue: 0,0:21:49.34,0:21:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, kita mau kencan besok?
Dialogue: 0,0:21:52.64,0:21:54.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:21:54.40,0:21:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya cuma belanja bareng?
Dialogue: 0,0:21:57.34,0:22:00.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya kencan.
Dialogue: 0,0:22:03.84,0:22:08.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita ketemuan di kaki Jembatan Aioi\Njam sembilan.
Dialogue: 0,0:22:08.37,0:22:09.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:22:09.75,0:22:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tidur.
Dialogue: 0,0:22:16.78,0:22:18.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Telingaku panas.
Dialogue: 0,0:22:18.82,0:22:23.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merasa seolah napas Fuyutsuki\Nmasih terngiang di telingaku.
