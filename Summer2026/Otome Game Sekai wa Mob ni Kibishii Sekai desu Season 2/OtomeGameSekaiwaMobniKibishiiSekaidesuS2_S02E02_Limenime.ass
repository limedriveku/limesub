Dialogue: 0,0:02:57.59,0:03:00.04,sign,,0000,0000,0000,,APAKAH KAU MENYUKAI ESTETIKA KEHANCURAN?
Dialogue: 0,0:09:32.59,0:09:34.34,sign,,0000,0000,0000,,BERHENTI
Dialogue: 0,0:14:58.77,0:15:00.55,sign,,0000,0000,0000,,AI?
Dialogue: 0,0:00:04.73,0:00:08.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle, kau bisa saja bilang\Nkau lahir di sini.
Dialogue: 0,0:00:09.11,0:00:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bisa membawakan hadiah untukmu.
Dialogue: 0,0:00:12.02,0:00:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak butuh hadiah apa pun.
Dialogue: 0,0:00:14.27,0:00:17.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu Kyle bersikap aneh?
Dialogue: 0,0:00:17.28,0:00:19.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akhirnya pulang ke rumah...
Dialogue: 0,0:00:19.12,0:00:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua aneh. Sama saja.
Dialogue: 0,0:00:21.65,0:00:24.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon! Kau nakal!
Dialogue: 0,0:00:24.00,0:00:27.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang lebih penting,\Naku harus interogasi Marie.
Dialogue: 0,0:00:27.38,0:00:29.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kita akan terus jalan kaki?
Dialogue: 0,0:00:29.27,0:00:31.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian kan bisa tunggu di pelabuhan.
Dialogue: 0,0:00:31.92,0:00:34.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu yang dilakukan pengikut Marie.
Dialogue: 0,0:00:34.52,0:00:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedengarannya merepotkan.
Dialogue: 0,0:00:36.07,0:00:37.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak mau begitu.
Dialogue: 0,0:00:38.04,0:00:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu keputusanku.
Dialogue: 0,0:00:40.27,0:00:45.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus lapor di pulau, dan aku mau\Nlihat reruntuhan serta harta karunnya.
Dialogue: 0,0:00:45.48,0:00:49.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Putri kerajaan musuh\Nbersikap cukup aneh.
Dialogue: 0,0:00:49.62,0:00:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, katanya ini pulau elf.
Dialogue: 0,0:00:53.16,0:00:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu "elf"?
Dialogue: 0,0:00:55.11,0:00:58.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada data soal mereka di bank dataku.
Dialogue: 0,0:00:58.41,0:01:01.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin mereka muncul setelah aku hibernasi.
Dialogue: 0,0:01:02.02,0:01:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka dijadikan budak dan pelayan,
Dialogue: 0,0:01:04.45,0:01:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta dihargai terutama karena tak bisa\Npunya anak dengan manusia.
Dialogue: 0,0:01:09.53,0:01:12.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rentang hidup mereka lama sekali\Ndan mahir dalam sihir.
Dialogue: 0,0:01:12.38,0:01:14.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mereka spesies yang beda\Ndari manusia baru.
Dialogue: 0,0:01:16.43,0:01:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai.
Dialogue: 0,0:01:24.09,0:01:26.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:01:32.60,0:01:33.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trapped in a Dating Sim
Dialogue: 0,0:01:36.31,0:01:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}The World of Otome Games is Tough for Mobs
Dialogue: 0,0:01:46.03,0:01:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trapped in a Dating Sim 2: The World\Nof Otome Games is Tough for Mobs
Dialogue: 0,0:03:00.05,0:03:01.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang luar?
Dialogue: 0,0:03:01.22,0:03:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langka, nih.
Dialogue: 0,0:03:02.55,0:03:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari Kerajaan?
Dialogue: 0,0:03:03.94,0:03:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wisatawan?
Dialogue: 0,0:03:05.30,0:03:08.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gila! Semuanya cantik-cantik!
Dialogue: 0,0:03:08.13,0:03:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sih yang dipikirkannya?
Dialogue: 0,0:03:10.30,0:03:13.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf tak peduli soal penampilan luar.
Dialogue: 0,0:03:13.06,0:03:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Afinitas mereka bergantung pada mana.
Dialogue: 0,0:03:16.58,0:03:18.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya?
Dialogue: 0,0:03:18.56,0:03:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua cantik sekali.
Dialogue: 0,0:03:21.42,0:03:23.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski harus kuakui aku ini saingan berat.
Dialogue: 0,0:03:24.32,0:03:26.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:03:27.04,0:03:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:03:28.36,0:03:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa denganmu hari ini?
Dialogue: 0,0:03:30.09,0:03:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa. Bisa tidak usah\Nbaik-baikin aku demi egomu sendiri?
Dialogue: 0,0:03:34.37,0:03:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang aku benci pecundang
Dialogue: 0,0:03:35.31,0:03:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang menafsirkan segalanya\Ndemi keuntungan sendiri.
Dialogue: 0,0:03:37.70,0:03:41.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah! Aku juga benci anak nakal sepertimu!
Dialogue: 0,0:03:41.50,0:03:44.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenalkan Marie ke keluargamu\Nmalah bikin canggung!
Dialogue: 0,0:03:44.46,0:03:46.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini bodoh banget.
Dialogue: 0,0:03:46.22,0:03:47.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu elf dijual sebagai budak,
Dialogue: 0,0:03:47.79,0:03:50.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu diperlakukan\Nseperti keluar rumah untuk kerja.
Dialogue: 0,0:03:50.59,0:03:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak diperlakukan buruk.\NSementara anak lelaki di akademi...
Dialogue: 0,0:03:53.12,0:03:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam! Jangan bilang itu!
Dialogue: 0,0:03:55.13,0:03:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle...
Dialogue: 0,0:03:59.97,0:04:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agh. Itu Yumeria.
Dialogue: 0,0:04:01.94,0:04:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle juga.
Dialogue: 0,0:04:02.72,0:04:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Aku pergi dulu.
Dialogue: 0,0:04:08.52,0:04:09.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscountess Marie.
Dialogue: 0,0:04:10.38,0:04:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku memperkenalkan.
Dialogue: 0,0:04:12.17,0:04:13.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ibuku, Yumeria.
Dialogue: 0,0:04:13.98,0:04:15.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ibu?!
Dialogue: 0,0:04:20.91,0:04:21.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:04:21.77,0:04:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Senang bertemu denganmu!
Dialogue: 0,0:04:23.29,0:04:24.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak, aku yang senang!
Dialogue: 0,0:04:24.81,0:04:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah jaga Kyle.
Dialogue: 0,0:04:26.66,0:04:29.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beda banget dari bayanganku...
Dialogue: 0,0:04:29.91,0:04:34.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sedang menuju reruntuhan.\NPermisi.
Dialogue: 0,0:04:34.29,0:04:35.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle...
Dialogue: 0,0:04:37.29,0:04:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ini kenapa, sih?\NAneh banget hari ini.
Dialogue: 0,0:04:42.00,0:04:44.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu salahku.
Dialogue: 0,0:04:44.17,0:04:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku darah campuran yang menjijikkan.
Dialogue: 0,0:04:47.51,0:04:48.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campuran?
Dialogue: 0,0:04:50.86,0:04:52.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reruntuhan?
Dialogue: 0,0:04:52.24,0:04:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Boleh kami ke sana?
Dialogue: 0,0:04:54.72,0:04:56.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:04:56.59,0:04:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tempat suci.
Dialogue: 0,0:04:59.39,0:05:02.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlarang bagi siapa pun\Nselain penduduk pulau.
Dialogue: 0,0:05:02.86,0:05:05.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurasa Kepala Suku takkan setuju.
Dialogue: 0,0:05:05.76,0:05:07.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa Kepala Suku?
Dialogue: 0,0:05:07.94,0:05:10.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita tua yang menyatukan desa-desa.
Dialogue: 0,0:05:10.41,0:05:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ahli ramalan.\NDulu banyak orang datang mengunjunginya,
Dialogue: 0,0:05:14.25,0:05:18.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kekuatannya sudah menurun,\Nramalannya jadi kurang akurat.
Dialogue: 0,0:05:18.51,0:05:19.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalan...
Dialogue: 0,0:05:19.99,0:05:21.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku agak penasaran juga.
Dialogue: 0,0:05:22.40,0:05:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya kita tak bisa ke reruntuhan?!
Dialogue: 0,0:05:24.71,0:05:26.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus hartaku bagaimana?
Dialogue: 0,0:05:26.94,0:05:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam dulu. Aku lagi cari cara,\Njangan berisik.
Dialogue: 0,0:05:30.67,0:05:32.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya kau ngomong begitu!
Dialogue: 0,0:05:32.21,0:05:35.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kapten pengawalku!\NBertindaklah kayak antekku!
Dialogue: 0,0:05:35.47,0:05:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, ini menyebalkan.\NJelas ada barang hilang di pulau ini,
Dialogue: 0,0:05:40.91,0:05:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi aku tak pernah pakai,\Njadi tak tahu banyak soal itu.
Dialogue: 0,0:05:44.60,0:05:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalan dari Kepala Suku!
Dialogue: 0,0:05:46.26,0:05:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tak terjadi.
Dialogue: 0,0:05:47.40,0:05:48.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya kita wajib mendengarkannya...
Dialogue: 0,0:05:48.76,0:05:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Apa?
Dialogue: 0,0:05:51.25,0:05:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, Kepala Suku bersabda!
Dialogue: 0,0:05:57.19,0:05:59.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak seorang pun boleh masuk reruntuhan.
Dialogue: 0,0:05:59.45,0:06:01.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka akan kena murka Raja Kegelapan kuno!
Dialogue: 0,0:06:01.86,0:06:03.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini ramalannya?
Dialogue: 0,0:06:03.94,0:06:05.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau sama sekali tak percaya?
Dialogue: 0,0:06:05.84,0:06:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu.\NOrang berkekuatan aneh memang ada.
Dialogue: 0,0:06:09.62,0:06:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau salah satunya, Tuan,\Ndengan kenangan kehidupan masa lalumu.
Dialogue: 0,0:06:13.01,0:06:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul juga.
Dialogue: 0,0:06:14.63,0:06:16.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, kau tahu soal\NRaja Kegelapan ini?
Dialogue: 0,0:06:16.88,0:06:21.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak tahu.\NMungkin muncul di gim otome-mu?
Dialogue: 0,0:06:21.17,0:06:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak muncul.\NMakanya aku jadi sangat resah soal ini.
Dialogue: 0,0:06:26.18,0:06:27.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau Kepala Suku?
Dialogue: 0,0:06:28.22,0:06:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku masuk reruntuhan!\NAku harus dapatkan harta itu!
Dialogue: 0,0:06:36.21,0:06:37.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:06:38.13,0:06:39.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah Saint.
Dialogue: 0,0:06:41.15,0:06:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu betul!\NBagaimana kau bisa tahu?
Dialogue: 0,0:06:43.93,0:06:45.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matamu jeli. Kupuji itu.
Dialogue: 0,0:06:45.94,0:06:47.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, izinkan aku masuk reruntuhan...
Dialogue: 0,0:06:47.19,0:06:49.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tak keberatan kau masuk.
Dialogue: 0,0:06:49.03,0:06:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Benarkah?
Dialogue: 0,0:06:50.95,0:06:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saint akan membawa Raja Kegelapan kuno.\NKepala Suku sudah meramalkannya.
Dialogue: 0,0:06:56.28,0:06:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ra-Raja Kegelapan?
Dialogue: 0,0:06:58.55,0:07:00.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak kenal Raja Kegelapan mana pun.
Dialogue: 0,0:07:00.91,0:07:02.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari penghakiman...
Dialogue: 0,0:07:02.93,0:07:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari Raja Kegelapan kuno menghukum kita\Natas kesombongan kita akan tiba.
Dialogue: 0,0:07:07.93,0:07:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semoga kalian tetap tenang\Nsampai saat itu datang.
Dialogue: 0,0:07:11.67,0:07:12.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Kegelapan?
Dialogue: 0,0:07:12.64,0:07:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konyol.
Dialogue: 0,0:07:13.68,0:07:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti salah lagi.
Dialogue: 0,0:07:15.27,0:07:17.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu Kepala Suku selalu benar...
Dialogue: 0,0:07:17.45,0:07:21.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah apa yang terjadi,\Ntapi harta itu milikku!
Dialogue: 0,0:07:23.43,0:07:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kayaknya dia Raja Kegelapan, deh.
Dialogue: 0,0:07:30.67,0:07:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi? Bagaimana di sana?
Dialogue: 0,0:07:32.06,0:07:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada apa-apa.
Dialogue: 0,0:07:33.57,0:07:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm. Kosong juga di sini.
Dialogue: 0,0:07:37.26,0:07:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:07:38.44,0:07:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:07:40.07,0:07:43.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini reruntuhan kuno sungguhan!\NAku merasa sangat terhubung!
Dialogue: 0,0:07:43.41,0:07:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benarkah?
Dialogue: 0,0:07:45.01,0:07:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada harta karun?\NTak ada petualangan?
Dialogue: 0,0:07:49.20,0:07:51.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, pasti ada kok kalau kau cari lagi.
Dialogue: 0,0:07:51.87,0:07:55.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayang sekali.\NEkspektasiku besar tadi.
Dialogue: 0,0:07:55.09,0:07:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kadang kita juga\Nharus nikmati kekalahan.
Dialogue: 0,0:07:58.74,0:07:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lo?
Dialogue: 0,0:08:00.21,0:08:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berharap sesuatu, ya?
Dialogue: 0,0:08:02.21,0:08:05.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma kepikiran karena tak ada\Nyang bisa dilaporkan.
Dialogue: 0,0:08:05.13,0:08:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Ini tidak adil!\NMasa tak ada satu koin emas pun?!
Dialogue: 0,0:08:10.71,0:08:15.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja. Kita bisa lakukan\Npetualangan lain bareng Pangeran Julius.
Dialogue: 0,0:08:15.53,0:08:18.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Aku bosan hidup dalam utang!
Dialogue: 0,0:08:18.67,0:08:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku takkan pernah menyerah!
Dialogue: 0,0:08:21.51,0:08:22.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marie!
Dialogue: 0,0:08:22.52,0:08:23.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesempatanku!
Dialogue: 0,0:08:23.52,0:08:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marie! Tunggu!
Dialogue: 0,0:08:25.29,0:08:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahan! Biar aku yang kejar.
Dialogue: 0,0:08:27.17,0:08:28.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:08:28.06,0:08:31.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintah Kapten.\NAnge, kalian tunggu di sini juga.
Dialogue: 0,0:08:32.97,0:08:34.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon...
Dialogue: 0,0:08:35.27,0:08:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya aku dapat kesempatan\Nbuat ngobrol dengannya.
Dialogue: 0,0:08:39.85,0:08:42.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?! Di mana itu?!
Dialogue: 0,0:08:42.99,0:08:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Argh! Di mana harta karunnya?!
Dialogue: 0,0:08:46.70,0:08:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya kau sendirian.
Dialogue: 0,0:08:48.92,0:08:51.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa ini?
Dialogue: 0,0:08:52.47,0:08:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marie, kau bereinkarnasi dari dunia lain.
Dialogue: 0,0:08:56.22,0:08:59.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah caramu bikin Julius\Ndan antek-anteknya jatuh cinta,
Dialogue: 0,0:08:59.36,0:09:01.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan sampai jadi Saint.
Dialogue: 0,0:09:02.35,0:09:04.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Terus kenapa?
Dialogue: 0,0:09:04.63,0:09:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga bereinkarnasi di dunia ini.
Dialogue: 0,0:09:08.20,0:09:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah tahu?
Dialogue: 0,0:09:09.73,0:09:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selalu saja menghalangi jalanku...
Dialogue: 0,0:09:13.10,0:09:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti punya pengetahuan soal gim ini.
Dialogue: 0,0:09:16.06,0:09:20.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kuduga.\NJadi kau tahu ini dunia gim otome.
Dialogue: 0,0:09:20.12,0:09:22.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul!\NMakanya aku ambil semuanya!
Dialogue: 0,0:09:22.46,0:09:24.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahnya apa?
Dialogue: 0,0:09:24.18,0:09:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pasti akan temukan kebahagiaan dalam...
Dialogue: 0,0:09:34.99,0:09:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh...
Dialogue: 0,0:09:36.78,0:09:38.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:09:39.00,0:09:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gendong aku.
Dialogue: 0,0:09:40.89,0:09:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mau. Kau berat.
Dialogue: 0,0:09:43.26,0:09:46.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku sakit. Aku tak bisa jalan.
Dialogue: 0,0:09:46.49,0:09:48.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pura-pura lagi?
Dialogue: 0,0:09:48.26,0:09:51.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bodohi orang lain,\Ntapi tak bisa bodohi aku.
Dialogue: 0,0:09:53.27,0:09:56.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Argh! Kau kakak paling menyebalkan\Nyang pernah ada!
Dialogue: 0,0:09:57.33,0:09:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini kehidupan masa laluku...
Dialogue: 0,0:10:04.39,0:10:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi setelah itu?
Dialogue: 0,0:10:10.74,0:10:12.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka lama banget!
Dialogue: 0,0:10:12.81,0:10:14.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cari mereka.
Dialogue: 0,0:10:14.98,0:10:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau kau malah tersesat?
Dialogue: 0,0:10:17.53,0:10:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan saja ke Leon.\NPasti baik-baik saja.
Dialogue: 0,0:10:19.83,0:10:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya aku cemas!
Dialogue: 0,0:10:21.57,0:10:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa tahu Bartfort bakal lakukan hal aneh?!
Dialogue: 0,0:10:25.17,0:10:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bodoh! Leon tak seperti kalian!
Dialogue: 0,0:10:28.36,0:10:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa bedanya?!\NDia juga pria, sama kayak kami!
Dialogue: 0,0:10:31.54,0:10:34.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manisnya Marie pasti bikin dia...
Dialogue: 0,0:10:34.05,0:10:37.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan kebodohan ini!\NMuka Dua! Otot Besar!
Dialogue: 0,0:10:37.09,0:10:40.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ange, kau memang tak bisa\Nbilang yang sebenarnya...
Dialogue: 0,0:10:41.18,0:10:43.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak membantu mereka.
Dialogue: 0,0:10:47.36,0:10:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Di mana aku?
Dialogue: 0,0:10:49.93,0:10:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:10:50.56,0:10:51.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana selanjutnya?
Dialogue: 0,0:10:51.76,0:10:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua makhluk tak dikenal dari langit-langit.
Dialogue: 0,0:10:54.37,0:10:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati sisa amunisimu.
Dialogue: 0,0:11:00.78,0:11:03.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya mereka bukan monster biasa.
Dialogue: 0,0:11:03.90,0:11:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Mereka tak lenyap\Nsetelah ditembak mati.
Dialogue: 0,0:11:06.63,0:11:07.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa ini?!
Dialogue: 0,0:11:08.16,0:11:10.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita jatuh ke lantai reruntuhan\Nyang lebih bawah.
Dialogue: 0,0:11:10.94,0:11:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini Tuan sedang membantai\Nmakhluk tak dikenal.
Dialogue: 0,0:11:14.25,0:11:16.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makhluk tak dikenal?!
Dialogue: 0,0:11:23.22,0:11:24.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:11:24.02,0:11:25.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakiku! Aku tak bisa berdiri!
Dialogue: 0,0:11:26.59,0:11:28.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pura-pura lagi?
Dialogue: 0,0:11:28.92,0:11:32.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa bodohi orang lain,\Ntapi tak bisa bodohi aku.
Dialogue: 0,0:11:32.01,0:11:35.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Argh! Kau kakak paling menyebalkan...
Dialogue: 0,0:11:35.99,0:11:38.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau Saint, 'kan?
Dialogue: 0,0:11:38.21,0:11:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau bisa pakai mantra penyembuhanmu.
Dialogue: 0,0:11:52.95,0:11:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Di mana jalan keluarnya?!
Dialogue: 0,0:11:57.67,0:12:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat banget! Kau pakai mantra\Npenyembuhan ke diri sendiri?
Dialogue: 0,0:12:00.53,0:12:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih terasa sakit\Nsesaat setelah disembuhkan!
Dialogue: 0,0:12:02.83,0:12:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Livia juga bisa hilangkan rasa sakitnya.
Dialogue: 0,0:12:05.38,0:12:07.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah masalahnya yang palsu.
Dialogue: 0,0:12:07.04,0:12:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah! Percuma berbaik-baik ke wanita itu!
Dialogue: 0,0:12:10.25,0:12:13.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau cuma mob!\NMereka takkan pernah lirik kau!
Dialogue: 0,0:12:13.10,0:12:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kenapa kau malah bikin harem?!
Dialogue: 0,0:12:15.68,0:12:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Kalau ada kebahagiaan,\Nambil saja! Begitulah manusia!
Dialogue: 0,0:12:20.07,0:12:23.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salahnya apa kalau aku jalani\Nhidup kedua sesuai maunya?!
Dialogue: 0,0:12:23.42,0:12:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekalipun itu berarti\Nsabotase Livia dan jebak Ange?
Dialogue: 0,0:12:28.63,0:12:30.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga sama saja, Tuan.
Dialogue: 0,0:12:30.88,0:12:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:12:31.69,0:12:34.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau dapatkan aku di posisi Olivia.
Dialogue: 0,0:12:34.94,0:12:37.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu kau kalahkan Julius dan yang lain,
Dialogue: 0,0:12:37.42,0:12:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menikmati setiap momennya, bukan?
Dialogue: 0,0:12:40.45,0:12:42.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Kau di pihak siapa sih?!
Dialogue: 0,0:12:42.92,0:12:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph! Kau tak punya hak untuk protes!
Dialogue: 0,0:12:46.04,0:12:49.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam! Aku cuma sedang bereskan\Nkesalahanmu, itu saja!
Dialogue: 0,0:12:49.72,0:12:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan kau lakukan\Nkalau kau memicu perang dengan Kerajaan
Dialogue: 0,0:12:52.88,0:12:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan bos akhir muncul?!
Dialogue: 0,0:12:54.25,0:12:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulakukan sesuatu\Ndengan kekuatan Saint!
Dialogue: 0,0:12:57.50,0:12:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus kekuatan Livia gimana?!
Dialogue: 0,0:12:59.58,0:13:03.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau cuma andalkan kekuatan Saint,\Ntamat sudah, permainan berakhir!
Dialogue: 0,0:13:06.87,0:13:09.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di tempat semuanya bermula.
Dialogue: 0,0:13:09.55,0:13:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkat kedua tangan kalian!
Dialogue: 0,0:13:22.10,0:13:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luxion, apa ini...
Dialogue: 0,0:13:24.27,0:13:24.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:26.43,0:13:29.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang, Manusia Pria dan Wanita,
Dialogue: 0,0:13:29.52,0:13:31.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta tumpukan sampah aneh.
Dialogue: 0,0:13:31.99,0:13:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian subjek eksperimen sempurna\Nbuat pembedahanku.
Dialogue: 0,0:13:35.42,0:13:37.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kalian yang buat monster-monster ini?
Dialogue: 0,0:13:38.10,0:13:41.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Cepat juga tanggapmu\Nuntuk seorang manusia.
Dialogue: 0,0:13:41.63,0:13:45.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di reruntuhan ini,\Nkami sudah menginjakkan kaki
Dialogue: 0,0:13:45.06,0:13:47.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di wilayah para dewa\Ndan menciptakan kehidupan!
Dialogue: 0,0:13:49.79,0:13:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, bukan kalian, manusia biadab,
Dialogue: 0,0:13:52.78,0:13:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kuasai dunia, melainkan kami, elf.
Dialogue: 0,0:13:55.95,0:13:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reruntuhan ini buktinya.
Dialogue: 0,0:13:58.37,0:14:02.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leluhur kami menciptakan\Nsejumlah besar makhluk hidup di sini.
Dialogue: 0,0:14:02.30,0:14:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian, manusia, cuma salah satu\Nspesies inferior ciptaan mereka.
Dialogue: 0,0:14:07.27,0:14:09.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Itu bukan bagian dari gim...
Dialogue: 0,0:14:09.81,0:14:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan rebut kembali\Ndunia yang kalian ambil dari kami!
Dialogue: 0,0:14:13.99,0:14:19.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, elf akan dominasi semua spesies\Ndan kembalikan dunia ke wujud aslinya!
Dialogue: 0,0:14:19.61,0:14:22.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua yang barusan kau bilang itu salah.
Dialogue: 0,0:14:22.52,0:14:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:23.57,0:14:26.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu semua cuma interpretasi\Ngampangan hasil khayalanmu.
Dialogue: 0,0:14:26.83,0:14:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenyataannya,\Nmanusia yang kelola fasilitas ini.
Dialogue: 0,0:14:30.24,0:14:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang diciptakan
Dialogue: 0,0:14:32.03,0:14:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kalian, elf.
Dialogue: 0,0:14:34.87,0:14:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, familiar apaan itu?
Dialogue: 0,0:14:37.34,0:14:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Luxion, cheat item.
Dialogue: 0,0:14:39.62,0:14:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti tahu kalau kau main gimnya.
Dialogue: 0,0:14:41.51,0:14:44.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu?!\NCheat? Curang banget!
Dialogue: 0,0:14:44.84,0:14:45.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini.
Dialogue: 0,0:14:45.86,0:14:49.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kepribadianmu luar biasa sekali.
Dialogue: 0,0:14:49.66,0:14:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia menciptakan kami?
Dialogue: 0,0:14:52.24,0:14:54.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leluconmu jelek banget, sampah.
Dialogue: 0,0:14:54.18,0:14:58.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, aku dapat informasi ini\Ndari AI fasilitas ini.
Dialogue: 0,0:15:02.61,0:15:04.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata dia.
Dialogue: 0,0:15:04.37,0:15:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:15:05.15,0:15:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf di pulau ini tipe elf liar\Nyang diciptakan di fasilitas ini.
Dialogue: 0,0:15:10.54,0:15:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}AI yang beda dari Luxion?
Dialogue: 0,0:15:13.02,0:15:17.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Aku hibernasi\Nuntuk waktu yang sangat lama.
Dialogue: 0,0:15:17.27,0:15:20.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau punya ciri manusia lama.
Dialogue: 0,0:15:20.20,0:15:22.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu kehormatan bertemu denganmu.
Dialogue: 0,0:15:22.04,0:15:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf diciptakan?! Hentikan omong kosongmu!
Dialogue: 0,0:15:25.48,0:15:28.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami jauh lebih unggul\Ndari kehidupan lainnya!
Dialogue: 0,0:15:28.22,0:15:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umur kami panjang,\Ndan kami mahir dalam sihir!
Dialogue: 0,0:15:31.58,0:15:34.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umur panjang kalian\Nmemungkinkan bertarung lama.
Dialogue: 0,0:15:34.34,0:15:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keahlian sihir kalian\Nmemang dirancang begitu.
Dialogue: 0,0:15:39.43,0:15:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, kalian lebih rendah\Ndari elf yang awalnya kami ciptakan.
Dialogue: 0,0:15:44.31,0:15:46.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu mustahil benar!
Dialogue: 0,0:15:46.82,0:15:48.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami, elf...
Dialogue: 0,0:15:48.35,0:15:50.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ras terhebat.
Dialogue: 0,0:15:53.32,0:15:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya. Jadi kau juga\Nterlibat di fasilitas ini, Kepala.
Dialogue: 0,0:15:57.11,0:15:59.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan percaya kebohongan mereka.
Dialogue: 0,0:15:59.86,0:16:04.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampah itu pasti ubah suaranya\Ndan lontarkan omong kosong.
Dialogue: 0,0:16:04.87,0:16:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu betul...
Dialogue: 0,0:16:06.83,0:16:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi bakal jadi masalah kalau ini ketahuan.
Dialogue: 0,0:16:10.35,0:16:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan teman-teman mereka\Ntak tahu soal ini.
Dialogue: 0,0:16:12.46,0:16:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat kematian mereka\Ntampak seperti kecelakaan.
Dialogue: 0,0:16:14.50,0:16:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih. Aku ingin cabik-cabik mereka\Npakai tanganku sendiri.
Dialogue: 0,0:16:37.54,0:16:39.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, dasar bajingan bermuka dua!
Dialogue: 0,0:16:39.52,0:16:44.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia lemah! Yang inferior\Nharus tunduk di hadapan kami!
Dialogue: 0,0:16:47.40,0:16:50.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keadaan darurat terdeteksi.\NMenetapkan penanggulangan.
Dialogue: 0,0:17:07.13,0:17:09.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Ini...
Dialogue: 0,0:17:13.09,0:17:15.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Lakukan! Bunuh mereka!
Dialogue: 0,0:17:25.27,0:17:27.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma segitu kemampuan kalian?
Dialogue: 0,0:17:28.33,0:17:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian bahkan takkan bisa\Nmenggores Tuan dengan itu.
Dialogue: 0,0:17:34.40,0:17:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kalian serang manusia lama,\Nkalian juga akan tersingkir.
Dialogue: 0,0:17:38.40,0:17:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengar itu? Masih mau lanjut?
Dialogue: 0,0:17:44.07,0:17:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Katanya ras terbaik,\Ntapi lihat dirimu sendiri!
Dialogue: 0,0:17:48.08,0:17:51.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Umur panjang dan keterampilan sihir?
Dialogue: 0,0:17:51.58,0:17:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf yang mulia dan bijaksana, ya?
Dialogue: 0,0:17:53.90,0:17:56.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau menyukai estetika kehancuran?
Dialogue: 0,0:18:00.38,0:18:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengingatkanku pada kakakku...
Dialogue: 0,0:18:03.63,0:18:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham kalau manusia lama sudah hancur.
Dialogue: 0,0:18:07.23,0:18:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fasilitas ini harus hancur dengan sendirinya.
Dialogue: 0,0:18:10.10,0:18:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini diciptakan untuk lawan manusia baru.
Dialogue: 0,0:18:14.63,0:18:18.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau gagal mencapai tujuan itu,\Nberbahaya kalau dibiarkan tetap ada.
Dialogue: 0,0:18:18.68,0:18:21.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau baik-baik saja?\NAkhirnya bangun lagi rupanya.
Dialogue: 0,0:18:21.11,0:18:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak masalah.\NLuxion, kupercayakan dataku padamu.
Dialogue: 0,0:18:26.36,0:18:30.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuterima. Performaku bakal\Nmeningkat dari sebelumnya.
Dialogue: 0,0:18:31.11,0:18:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Data tak penting bagiku...
Dialogue: 0,0:18:33.99,0:18:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus harta karunnya bagaimana?
Dialogue: 0,0:18:36.18,0:18:40.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada sesuatu yang mungkin\Nberharga buatmu di sini.
Dialogue: 0,0:18:40.47,0:18:41.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kau ambil?
Dialogue: 0,0:18:41.87,0:18:42.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:18:46.13,0:18:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, ada di sini?
Dialogue: 0,0:18:48.38,0:18:50.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, ternyata memang ada sesuatu!
Dialogue: 0,0:18:50.88,0:18:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa ini di punggungmu!
Dialogue: 0,0:18:52.83,0:18:55.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bisa bawa harta karun\Ndi punggungmu, 'kan?
Dialogue: 0,0:18:57.79,0:19:01.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlalu mirip adikku\Ndari kehidupan masa laluku.
Dialogue: 0,0:19:02.91,0:19:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat buka.
Dialogue: 0,0:19:04.64,0:19:06.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, ini lagi kubuka! Berisik!
Dialogue: 0,0:19:08.01,0:19:10.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Apa ini?
Dialogue: 0,0:19:12.02,0:19:15.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang hilang ini...\NNamanya apa?
Dialogue: 0,0:19:16.15,0:19:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?!
Dialogue: 0,0:19:18.95,0:19:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luxion, kenapa? Tenang.
Dialogue: 0,0:19:21.57,0:19:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat tenang!
Dialogue: 0,0:19:23.57,0:19:26.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan dengan tenang\Nhancurkan benda ini, menggilingnya,
Dialogue: 0,0:19:26.84,0:19:30.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu memusnahkannya\Nsampai tak satu atom pun tersisa...
Dialogue: 0,0:19:33.85,0:19:35.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luxion rusak...
Dialogue: 0,0:19:35.42,0:19:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lux, tenang!\NTarik napas! Tarik napas!
Dialogue: 0,0:19:40.17,0:19:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak perlu bernapas.
Dialogue: 0,0:19:43.98,0:19:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya... Maaf.
Dialogue: 0,0:19:47.35,0:19:50.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tahu ini barang hilang\Ncuma aku dan Marie?
Dialogue: 0,0:19:50.80,0:19:55.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Agh! Aku tak mau punya barang ini!
Dialogue: 0,0:19:55.26,0:19:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, kau juga tak tahu?
Dialogue: 0,0:19:57.48,0:19:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa cari harta lain.
Dialogue: 0,0:19:59.86,0:20:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keselamatanmu itu harta terbesar.
Dialogue: 0,0:20:06.51,0:20:08.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancur dengan sendirinya?
Dialogue: 0,0:20:08.40,0:20:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, AI itu akhirnya\Nbisa istirahat dengan tenang...
Dialogue: 0,0:20:11.91,0:20:12.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:20:14.11,0:20:17.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cloaking?! Kapal Luxion?!
Dialogue: 0,0:20:18.83,0:20:21.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beraninya dia paksakan ini pada kita.
Dialogue: 0,0:20:21.50,0:20:23.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan tanggung akibatnya!
Dialogue: 0,0:20:26.08,0:20:28.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kepala, langitnya aneh.
Dialogue: 0,0:20:28.65,0:20:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Apa ini yang diramalkan Kepala Suku?!
Dialogue: 0,0:20:35.09,0:20:38.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Murka Raja Kegelapan!
Dialogue: 0,0:20:38.09,0:20:41.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan! Itu rekanku!
Dialogue: 0,0:20:46.39,0:20:49.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini jadinya kalau kau bikin aku marah.
Dialogue: 0,0:20:49.26,0:20:51.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin kau bukan Raja Kegelapan?
Dialogue: 0,0:20:54.12,0:20:56.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Yang Mulia?
Dialogue: 0,0:20:56.06,0:20:59.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan apa-apa.\NKau senang menemukan harta itu, 'kan?
Dialogue: 0,0:21:00.22,0:21:02.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan-jangan dia...
Dialogue: 0,0:21:07.61,0:21:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Kegelapan!
Dialogue: 0,0:21:09.02,0:21:10.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan kami!
Dialogue: 0,0:21:10.43,0:21:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mohon tinggalkan pulau kami!
Dialogue: 0,0:21:18.59,0:21:20.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jadi keributan besar...
Dialogue: 0,0:21:21.87,0:21:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle! Kau tidak apa-apa?
Dialogue: 0,0:21:24.37,0:21:27.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak lihat?\NTinggalkan aku sendiri.
Dialogue: 0,0:21:27.63,0:21:30.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya. Maafkan aku.
Dialogue: 0,0:21:34.24,0:21:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hancurnya reruntuhan memang disayangkan,
Dialogue: 0,0:21:36.81,0:21:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi terima kasih sudah tangkap mereka\Nyang langgar tabu.
Dialogue: 0,0:21:40.69,0:21:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai tanda terima kasih,\NKepala akan ramalkan sesuatu untukmu.
Dialogue: 0,0:21:45.75,0:21:46.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalan?
Dialogue: 0,0:21:49.49,0:21:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Ramalan
Dialogue: 0,0:21:52.47,0:21:54.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tentang masa depanmu.
Dialogue: 0,0:23:25.87,0:23:27.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu dan anak bersatu kembali!
Dialogue: 0,0:23:27.57,0:23:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang misterius, dan hubungan tegang?
Dialogue: 0,0:23:30.04,0:23:33.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, aku lagi santai di pesta teh,\Ntapi ini apaan?!
Dialogue: 0,0:23:33.54,0:23:35.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Hei, Bocah Ingusan".
Dialogue: 0,0:23:35.58,0:23:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian percaya ramalan?
Dialogue: 0,0:23:37.19,0:23:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku percaya.
Dialogue: 0,0:23:38.33,0:23:39.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, serius?
