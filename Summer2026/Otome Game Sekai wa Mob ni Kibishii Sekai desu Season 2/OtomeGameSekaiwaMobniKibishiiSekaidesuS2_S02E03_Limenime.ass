Dialogue: 0,0:01:55.53,0:01:59.50,sign,,0000,0000,0000,,HEI, BOCAH INGUSAN
Dialogue: 0,0:15:37.55,0:15:39.85,sign,,0000,0000,0000,,"PEMBUATAN LUXION"
Dialogue: 0,0:00:01.21,0:00:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Suku lega\Nkarena murka Raja Kegelapan kuno
Dialogue: 0,0:00:04.70,0:00:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berakhir cuma dengan hancurnya reruntuhan.
Dialogue: 0,0:00:08.65,0:00:11.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ada sedikit hal yang bisa kita lakukan,
Dialogue: 0,0:00:11.43,0:00:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi untuk mengungkapkan\Nrasa terima kasih kami,
Dialogue: 0,0:00:13.73,0:00:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia ingin meramalkan masa depan kalian.
Dialogue: 0,0:00:16.14,0:00:17.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalan?
Dialogue: 0,0:00:17.49,0:00:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sangat menghargainya.
Dialogue: 0,0:00:19.11,0:00:22.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cih. Aku lebih mau harta karun\Ndaripada itu.
Dialogue: 0,0:00:22.68,0:00:24.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita ini...
Dialogue: 0,0:00:30.63,0:00:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trapped in a Dating Sim
Dialogue: 0,0:00:34.34,0:00:35.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}The World of Otome Games is Tough for Mobs
Dialogue: 0,0:00:44.18,0:00:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trapped in a Dating Sim 2: The World\Nof Otome Games is Tough for Mobs
Dialogue: 0,0:02:00.94,0:02:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama, Saint.
Dialogue: 0,0:02:04.37,0:02:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau dengar.
Dialogue: 0,0:02:05.83,0:02:08.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri aku keberuntungan sebisa mungkin.
Dialogue: 0,0:02:08.27,0:02:09.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:02:09.34,0:02:12.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau subjek dari nasib yang aneh.
Dialogue: 0,0:02:13.39,0:02:16.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, meski kau temukan\Npasangan yang ditakdirkan,
Dialogue: 0,0:02:16.30,0:02:17.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kalian takkan pernah sejalan.
Dialogue: 0,0:02:17.84,0:02:21.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Maksudmu ada yang lain\Nselain Julius dan yang lain?
Dialogue: 0,0:02:23.22,0:02:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu detailnya,\Ntapi kau sudah berpisah dengannya
Dialogue: 0,0:02:27.51,0:02:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan takkan pernah bersama lagi.
Dialogue: 0,0:02:29.35,0:02:32.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mustahil! Kalau begitu,\Nkenapa harus kau beri tahu?!
Dialogue: 0,0:02:33.86,0:02:36.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak bisa lepas dari apa yang kau pikul.
Dialogue: 0,0:02:36.73,0:02:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang menantimu adalah kehidupan yang sulit.
Dialogue: 0,0:02:39.31,0:02:42.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau akan dapatkan semua keinginanmu\Natau kehilangan semua yang kau punya.
Dialogue: 0,0:02:42.99,0:02:45.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya cuma ada dua kemungkinan.
Dialogue: 0,0:02:45.12,0:02:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:02:46.24,0:02:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini kenapa? Seram amat!
Dialogue: 0,0:02:48.67,0:02:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ulang! Aku minta diulang!
Dialogue: 0,0:02:51.14,0:02:52.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya, kau berambut hitam.
Dialogue: 0,0:02:52.87,0:02:53.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku!
Dialogue: 0,0:02:53.78,0:02:58.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari, titik balik hidupmu\Nakan datang lewat kesulitan.
Dialogue: 0,0:02:58.90,0:03:00.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Benarkah?
Dialogue: 0,0:03:01.24,0:03:04.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, meski hadapi kesulitan,
Dialogue: 0,0:03:04.33,0:03:06.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau juga akan bertemu pasangan\Nyang ditakdirkan.
Dialogue: 0,0:03:06.36,0:03:08.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak adil! Kenapa dia?!
Dialogue: 0,0:03:10.92,0:03:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau bisa berjalan bersamanya,\Ncahaya akan sinari jalan sulitmu,
Dialogue: 0,0:03:17.01,0:03:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan dia akan jadi dukungan\Nyang bisa diandalkan.
Dialogue: 0,0:03:19.52,0:03:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu. Aku akan mengingatnya.
Dialogue: 0,0:03:22.75,0:03:24.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tampak bahagia.
Dialogue: 0,0:03:26.98,0:03:28.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berikutnya, kalian berdua.
Dialogue: 0,0:03:28.90,0:03:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku?
Dialogue: 0,0:03:30.42,0:03:31.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga?
Dialogue: 0,0:03:32.17,0:03:35.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nasib kalian terkait secara rumit.
Dialogue: 0,0:03:35.07,0:03:37.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah banyak berubah dari yang seharusnya.
Dialogue: 0,0:03:38.61,0:03:44.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beban yang seharusnya kalian pikul\Nmalah ditanggung orang lain.
Dialogue: 0,0:03:44.33,0:03:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, kalian berdua\Npunya berkah seorang pahlawan,
Dialogue: 0,0:03:48.05,0:03:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mampu tundukkan bahkan Raja Kegelapan kuno.
Dialogue: 0,0:03:50.15,0:03:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahlawan?
Dialogue: 0,0:03:51.71,0:03:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu...
Dialogue: 0,0:03:53.12,0:03:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu...
Dialogue: 0,0:03:54.19,0:03:54.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:03:54.76,0:03:56.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu bukan aku!
Dialogue: 0,0:03:56.61,0:03:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada pahlawan, suruh dia tunjukkan diri!\NBukan aku!
Dialogue: 0,0:04:00.00,0:04:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas sekali.\NKau terlalu mementingkan diri.
Dialogue: 0,0:04:02.24,0:04:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sadarlah, Mob.
Dialogue: 0,0:04:07.75,0:04:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepala Suku, kau tampak lelah.
Dialogue: 0,0:04:10.17,0:04:11.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak keberatan kalau kau istirahat...
Dialogue: 0,0:04:15.97,0:04:19.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau orang yang sangat baik.
Dialogue: 0,0:04:19.89,0:04:21.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik?
Dialogue: 0,0:04:21.22,0:04:22.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria ini?
Dialogue: 0,0:04:22.33,0:04:24.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian ada masalah?
Dialogue: 0,0:04:24.43,0:04:31.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sekali lagi\Nkarena sudah selamatkan Desa Fan.
Dialogue: 0,0:04:32.19,0:04:37.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ramalanku tak dapat melihat masa depanmu.
Dialogue: 0,0:04:37.42,0:04:40.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, suatu hari nanti, kau akan...
Dialogue: 0,0:04:47.32,0:04:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:04:48.53,0:04:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kepala Suku?
Dialogue: 0,0:04:50.73,0:04:52.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia tertidur.
Dialogue: 0,0:04:52.76,0:04:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu! Buka matamu!\NJangan tidur sambil gantung ucapan!
Dialogue: 0,0:04:56.68,0:04:58.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon, hentikan itu!
Dialogue: 0,0:04:58.27,0:05:00.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hormati orang yang lebih tua!
Dialogue: 0,0:05:00.09,0:05:01.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak nakal!
Dialogue: 0,0:05:01.44,0:05:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasakan itu.
Dialogue: 0,0:05:05.44,0:05:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku minta diulang!
Dialogue: 0,0:05:11.95,0:05:16.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kepikiran.\NRasanya tidak enak jadinya.
Dialogue: 0,0:05:16.31,0:05:18.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, kau memalukan.
Dialogue: 0,0:05:18.58,0:05:20.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah selesai?
Dialogue: 0,0:05:20.17,0:05:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah lelah menunggu.
Dialogue: 0,0:05:22.18,0:05:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kyle di mana?
Dialogue: 0,0:05:24.08,0:05:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia balik ke kapal lebih dulu.
Dialogue: 0,0:05:26.34,0:05:28.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan tanpa pamit ke ibunya.
Dialogue: 0,0:05:29.22,0:05:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bocah dingin.
Dialogue: 0,0:05:31.96,0:05:35.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu... Apa itu "campuran"?
Dialogue: 0,0:05:37.84,0:05:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah Yumeria menyebut dirinya sendiri.
Dialogue: 0,0:05:41.66,0:05:43.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:44.68,0:05:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu standar kecantikan elf\Nbergantung pada mananya?
Dialogue: 0,0:05:49.94,0:05:53.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku baca soal itu di buku.
Dialogue: 0,0:05:54.63,0:05:59.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biasanya, mana tiap elf cuma satu warna.
Dialogue: 0,0:06:00.51,0:06:05.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kadang ada juga yang lahir\Ndengan berbagai warna mana.
Dialogue: 0,0:06:06.30,0:06:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mereka istimewa dan besar sekali,
Dialogue: 0,0:06:10.58,0:06:15.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi di mata kami,\Nkami malah menganggapnya menjijikkan.
Dialogue: 0,0:06:16.38,0:06:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya mereka menghindarinya...
Dialogue: 0,0:06:19.28,0:06:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu,
Dialogue: 0,0:06:20.77,0:06:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk waktu tertentu,
Dialogue: 0,0:06:22.47,0:06:25.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yumeria pergi dari desa\Njadi penampil keliling.
Dialogue: 0,0:06:26.23,0:06:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pulang sambil mengandung anak,
Dialogue: 0,0:06:29.77,0:06:32.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi ayahnya kemungkinan besar manusia.
Dialogue: 0,0:06:32.06,0:06:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Bukankah elf cuma bisa\Npunya anak sesama elf?
Dialogue: 0,0:06:36.83,0:06:38.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tepat sekali.
Dialogue: 0,0:06:38.56,0:06:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sepertinya yang punya\Nmana khusus itu pengecualian.
Dialogue: 0,0:06:42.40,0:06:44.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, Kyle itu...
Dialogue: 0,0:06:44.26,0:06:47.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setengah elf?\NMereka benar-benar ada?
Dialogue: 0,0:06:47.24,0:06:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Bagi elf yang tinggalkan desa\Nuntuk bekerja, keberadaannya merepotkan.
Dialogue: 0,0:06:53.79,0:06:57.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu alasan elf dihargai sebagai budak
Dialogue: 0,0:06:57.50,0:07:01.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah karena mereka tak bisa\Npunya anak dengan manusia.
Dialogue: 0,0:07:01.19,0:07:03.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu bisa dibantah...
Dialogue: 0,0:07:03.85,0:07:08.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Yumeria dan Kyle\Ndiperlakukan buruk di desa.
Dialogue: 0,0:07:08.84,0:07:13.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan?! Itu semua gara-gara\Npria bodoh yang menghamili Yumeria!
Dialogue: 0,0:07:13.75,0:07:15.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma karena dia punya bayi...
Dialogue: 0,0:07:16.09,0:07:22.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, ini urusan elf,\Nurusan keluarga di luar kendali kalian.
Dialogue: 0,0:07:22.36,0:07:24.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ragu kalian bisa selesaikan ini.
Dialogue: 0,0:07:24.93,0:07:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kalau dia tetap di sini,\NYumeria akan...
Dialogue: 0,0:07:39.45,0:07:42.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau terlalu ikut campur\Nurusan keluarga orang lain.
Dialogue: 0,0:07:42.73,0:07:45.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa tinggalkan dia begitu saja.
Dialogue: 0,0:07:45.30,0:07:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung Kepala Suku\Nmemutuskan untuk membantu.
Dialogue: 0,0:07:48.00,0:07:52.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapan pun kau mau,\Nkau bisa hancurkan nilai elf sebagai budak.
Dialogue: 0,0:07:52.68,0:07:54.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya. Itu kartu as yang bagus.
Dialogue: 0,0:07:55.39,0:07:57.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupakai dengan baik.
Dialogue: 0,0:07:58.06,0:07:59.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu...
Dialogue: 0,0:08:00.32,0:08:03.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang akan terjadi padaku sekarang?
Dialogue: 0,0:08:03.48,0:08:07.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku sedang cari pelayan\Nyang tinggal di rumah.
Dialogue: 0,0:08:07.03,0:08:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mau kerja di sana?
Dialogue: 0,0:08:08.51,0:08:10.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi aku...
Dialogue: 0,0:08:10.66,0:08:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sebut aku\Norang bodoh dan dungu di desa...
Dialogue: 0,0:08:14.18,0:08:17.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sama sekali bukan masalah.\NKami pasti akan bayar kau juga.
Dialogue: 0,0:08:17.97,0:08:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan ini?!
Dialogue: 0,0:08:20.30,0:08:21.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle...
Dialogue: 0,0:08:21.62,0:08:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bawa Ibu keluar desa?!
Dialogue: 0,0:08:23.57,0:08:24.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau punya hak apa?!
Dialogue: 0,0:08:24.90,0:08:27.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kyle, Leon mengkhawatirkanku...
Dialogue: 0,0:08:27.50,0:08:30.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah cara mereka selalu membodohi Ibu!
Dialogue: 0,0:08:30.46,0:08:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gampang banget Ibu ketipu!
Dialogue: 0,0:08:32.22,0:08:34.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kita miskin dan menderita!
Dialogue: 0,0:08:35.15,0:08:36.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:08:36.23,0:08:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu sikap yang sangat buruk!
Dialogue: 0,0:08:38.78,0:08:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Livia...
Dialogue: 0,0:08:39.87,0:08:42.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ini bukan urusanmu!
Dialogue: 0,0:08:42.53,0:08:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak! Kau tak boleh bicara\Nbegitu ke ibumu! Minta maaf!
Dialogue: 0,0:08:49.02,0:08:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu apa-apa...
Dialogue: 0,0:08:51.30,0:08:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu kenapa aku jadi budak,
Dialogue: 0,0:08:53.17,0:08:55.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}atau bagaimana\Nmereka perlakukan aku di desa.
Dialogue: 0,0:08:55.24,0:08:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak tahu apa-apa!
Dialogue: 0,0:09:01.60,0:09:05.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti kata Kyle. Ini salahku.
Dialogue: 0,0:09:05.62,0:09:09.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku gagal,\Ndan dia jadi menderita karenanya...
Dialogue: 0,0:09:14.26,0:09:16.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Campuran sepertiku
Dialogue: 0,0:09:16.83,0:09:20.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tak bisa lakukan pekerjaan\Nyang sama dengan yang lain di desa.
Dialogue: 0,0:09:20.78,0:09:21.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:09:23.76,0:09:24.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vas?
Dialogue: 0,0:09:25.42,0:09:26.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah.
Dialogue: 0,0:09:26.95,0:09:29.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salah satu hal yang bisa kulakukan.
Dialogue: 0,0:09:35.39,0:09:36.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah...
Dialogue: 0,0:09:36.42,0:09:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu luar biasa.
Dialogue: 0,0:09:37.84,0:09:42.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penduduk desa tak akui\Nkekuatan luar biasa seperti itu?
Dialogue: 0,0:09:42.16,0:09:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elf memang ras yang bodoh.
Dialogue: 0,0:09:44.54,0:09:46.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, itu tak sopan.
Dialogue: 0,0:09:46.51,0:09:51.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu tak begitu istimewa.\NCuma sedikit yang bisa kulakukan.
Dialogue: 0,0:09:52.26,0:09:55.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin tahu lebih banyak dunia luar,
Dialogue: 0,0:09:55.30,0:09:56.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku pergi berkelana.
Dialogue: 0,0:09:56.81,0:10:00.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak lama setelah itu,\Naku jatuh cinta pada seorang bangsawan.
Dialogue: 0,0:10:01.50,0:10:05.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi waktu aku hamil anak\Nyang seharusnya mustahil terjadi,
Dialogue: 0,0:10:05.14,0:10:08.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia kira aku selingkuh dengan elf lain,\Nlalu mengusirku.
Dialogue: 0,0:10:09.10,0:10:11.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pulang ke desa dan lahirkan Kyle,
Dialogue: 0,0:10:11.70,0:10:17.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi dia tumbuh seperti manusia,\Ndan mereka tahu dia setengah elf.
Dialogue: 0,0:10:18.25,0:10:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya kau kirim dia pergi jadi budak?
Dialogue: 0,0:10:21.42,0:10:22.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Jaga bicaramu!
Dialogue: 0,0:10:23.20,0:10:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sendiri yang menginginkannya.
Dialogue: 0,0:10:26.59,0:10:32.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sangat menentangnya,\Ntapi dia pergi dari rumah tanpa sepatah kata,
Dialogue: 0,0:10:32.55,0:10:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tinggalkan uang hasil\Nmenjual dirinya di rumah.
Dialogue: 0,0:10:37.71,0:10:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajar kalau dia menyerangku.
Dialogue: 0,0:10:41.78,0:10:46.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia anak baik.\NSelalu kirim uang ke rumah untukku.
Dialogue: 0,0:10:47.63,0:10:48.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon...
Dialogue: 0,0:10:48.79,0:10:49.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:10:49.54,0:10:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak tahu apa-apa...
Dialogue: 0,0:10:52.80,0:10:55.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan khawatir.\NAkan kulakukan sesuatu.
Dialogue: 0,0:11:01.04,0:11:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bocah Ingusan.
Dialogue: 0,0:11:03.64,0:11:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa, Kesatria Sampah?
Dialogue: 0,0:11:05.65,0:11:07.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini soal ibumu.
Dialogue: 0,0:11:09.03,0:11:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku butuh pelayan baru.
Dialogue: 0,0:11:12.61,0:11:14.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kupastikan dia hidup dengan layak.
Dialogue: 0,0:11:14.96,0:11:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka jelas bakal manfaatkan dia.
Dialogue: 0,0:11:17.72,0:11:20.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pikir aku percaya kau atau keluargamu?
Dialogue: 0,0:11:20.92,0:11:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jarang pulang ke rumah,\Ndan ayahku sayang ibuku.
Dialogue: 0,0:11:25.58,0:11:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka takkan manfaatkan\Nseorang pelayan. Kurasa. Mungkin.
Dialogue: 0,0:11:31.83,0:11:33.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, maksudku, pasti!
Dialogue: 0,0:11:33.57,0:11:35.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa percaya kau.
Dialogue: 0,0:11:35.41,0:11:36.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph.
Dialogue: 0,0:11:39.04,0:11:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau khawatir,\Nkau bisa temui dia kapan pun kau mau.
Dialogue: 0,0:11:42.57,0:11:44.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marie tak boleh datang,
Dialogue: 0,0:11:44.56,0:11:47.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi akan kubilang ke ayahku\Nsupaya izinkan kau masuk.
Dialogue: 0,0:11:48.87,0:11:52.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau satu-satunya anak lelaki\Nyang dimiliki Yumeria.
Dialogue: 0,0:11:55.81,0:11:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wanita itu... Ibu terlalu baik.
Dialogue: 0,0:12:00.39,0:12:03.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanya dia tak bisa benci siapa pun.
Dialogue: 0,0:12:03.95,0:12:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia payah sebagai orang tua,\Ntapi dia satu-satunya ibu yang kupunya.
Dialogue: 0,0:12:12.22,0:12:17.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount, tolong jaga ibuku.\NDia kutitipkan padamu.
Dialogue: 0,0:12:21.91,0:12:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti.
Dialogue: 0,0:12:25.65,0:12:27.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku punya satu pertanyaan untukmu.
Dialogue: 0,0:12:28.11,0:12:30.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tak menyerah soal Marie?
Dialogue: 0,0:12:32.52,0:12:37.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cari tuan baru itu susah,\Ndan dia sekarang Saint.
Dialogue: 0,0:12:37.86,0:12:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatan sangat tak berguna,\Ntapi ternyata bisa diandalkan.
Dialogue: 0,0:12:41.85,0:12:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia peduli pada Marie\Ndengan caranya sendiri?
Dialogue: 0,0:12:45.27,0:12:49.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masuk akal untuk karakter pendukung\Ndalam gim. Kau jeli.
Dialogue: 0,0:12:50.01,0:12:51.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya pertanyaan untukmu.
Dialogue: 0,0:12:51.94,0:12:52.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:12:52.75,0:12:56.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebaiknya kau hati-hati\Nsama putri Kerajaan itu.
Dialogue: 0,0:12:56.91,0:12:58.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sedang merencanakan sesuatu.
Dialogue: 0,0:12:59.22,0:13:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan. Aku juga kepikiran hal yang sama.
Dialogue: 0,0:13:02.75,0:13:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang bikin kau berpikir begitu?
Dialogue: 0,0:13:04.57,0:13:06.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah lihat orang-orang
Dialogue: 0,0:13:06.18,0:13:09.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mengincar aku dan Ibu\Ndari balik bayangan sejak lama.
Dialogue: 0,0:13:09.03,0:13:12.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang merencanakan sesuatu\Npunya tatapan mata yang sama.
Dialogue: 0,0:13:12.25,0:13:12.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:13:13.96,0:13:15.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti matamu itu.
Dialogue: 0,0:13:16.02,0:13:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga sama!
Dialogue: 0,0:13:32.21,0:13:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini, Kerajaan akan jadi...
Dialogue: 0,0:13:39.61,0:13:41.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Ada apa ini?!
Dialogue: 0,0:13:41.82,0:13:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bacaan yang tak biasa dari ruang kargo.
Dialogue: 0,0:13:44.42,0:13:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sebaiknya kau tak pernah\Nmembawa itu bersamamu.
Dialogue: 0,0:13:54.80,0:13:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga! Menjijikkan!
Dialogue: 0,0:13:57.20,0:14:00.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harap hati-hati. Ia hidup.
Dialogue: 0,0:14:00.89,0:14:01.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:14:02.97,0:14:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial! Kita harus apa?
Dialogue: 0,0:14:05.26,0:14:07.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, pegangan yang kuat.
Dialogue: 0,0:14:07.73,0:14:08.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:14:08.73,0:14:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melepas kargo.
Dialogue: 0,0:14:21.91,0:14:23.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menembakkan meriam utama.
Dialogue: 0,0:14:35.11,0:14:37.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu perlu banget?
Dialogue: 0,0:14:37.20,0:14:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senjata itu tak seharusnya ada.
Dialogue: 0,0:14:40.54,0:14:44.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin begitu rasanya disegarkan.
Dialogue: 0,0:14:45.25,0:14:46.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon!
Dialogue: 0,0:14:46.42,0:14:48.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tadi itu? Ada apa ini?
Dialogue: 0,0:14:48.39,0:14:52.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang saja. Ada sedikit masalah,\Ntapi sudah kami selesaikan.
Dialogue: 0,0:14:52.90,0:14:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada yang membangunkannya.
Dialogue: 0,0:14:55.87,0:14:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau kau periksa rekaman kamera pengawas?
Dialogue: 0,0:14:58.15,0:14:59.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:15:00.91,0:15:05.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini tujuanmu, Putri?
Dialogue: 0,0:15:08.52,0:15:10.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa artinya ini?
Dialogue: 0,0:15:10.46,0:15:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dengar kabar bahwa kau\Ndapatkan sesuatu yang sangat berharga.
Dialogue: 0,0:15:15.16,0:15:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau buang tanpa konsultasi?
Dialogue: 0,0:15:18.41,0:15:20.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi mereka tahu semua sejak awal.
Dialogue: 0,0:15:20.66,0:15:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspedisimu itu permintaan\Ndari Kuil dan Istana!
Dialogue: 0,0:15:25.05,0:15:27.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami punya hak periksa barang yang didapat!
Dialogue: 0,0:15:27.92,0:15:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti sudah kubilang,\Nkami tak punya pilihan.
Dialogue: 0,0:15:30.60,0:15:32.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau terus kubawa pulang,
Dialogue: 0,0:15:32.20,0:15:33.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu benda itu tenggelamkan kapalku?
Dialogue: 0,0:15:33.63,0:15:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Istana akan kasih ganti rugi untuk itu?
Dialogue: 0,0:15:37.55,0:15:39.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong-omong, aku sudah tuliskan
Dialogue: 0,0:15:39.85,0:15:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya dalam laporan.
Dialogue: 0,0:15:41.56,0:15:45.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ada masalah,\Nkasih ke aku secara tertulis.
Dialogue: 0,0:15:46.20,0:15:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar pemula...
Dialogue: 0,0:15:47.94,0:15:50.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, silakan.
Dialogue: 0,0:15:57.89,0:16:01.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin harus ambil sikap begitu?
Dialogue: 0,0:16:01.06,0:16:02.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya mereka berterima kasih
Dialogue: 0,0:16:02.70,0:16:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}karena aku datang\Nsampaikan laporan langsung.
Dialogue: 0,0:16:04.84,0:16:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada pesta teh penting besok.
Dialogue: 0,0:16:08.52,0:16:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti biasanya, ya.
Dialogue: 0,0:16:09.86,0:16:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:16:11.46,0:16:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh!
Dialogue: 0,0:16:12.83,0:16:14.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratu Mylene!
Dialogue: 0,0:16:14.42,0:16:19.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama tak jumpa, Leon.\NAda waktu sebentar untuk mengobrol?
Dialogue: 0,0:16:22.17,0:16:24.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat atas ekspedisimu.
Dialogue: 0,0:16:24.83,0:16:27.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kau bawa Putri Hertrude bersamamu...
Dialogue: 0,0:16:27.63,0:16:29.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu cukup mengejutkan.
Dialogue: 0,0:16:29.63,0:16:32.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa dia bersamaku?\NDia ikut sendiri.
Dialogue: 0,0:16:32.97,0:16:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya soal perintah kerajaan.
Dialogue: 0,0:16:35.36,0:16:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perintah kerajaan?
Dialogue: 0,0:16:36.82,0:16:40.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita resminya,\Nitu untuk mengamati perbatasan.
Dialogue: 0,0:16:40.55,0:16:42.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah cerita resminya.
Dialogue: 0,0:16:42.73,0:16:46.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertikaian antarfaksi\Nsedang intens di Istana.
Dialogue: 0,0:16:46.20,0:16:49.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak orang punya pandangan\Nyang sangat berbeda.
Dialogue: 0,0:16:49.24,0:16:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudmu, orang-orang yang benci aku?
Dialogue: 0,0:16:53.15,0:16:56.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang yang mau\Nmencuri barang hilang dariku?
Dialogue: 0,0:16:57.82,0:17:01.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jelas banyak orang yang iri kekuatanmu.
Dialogue: 0,0:17:01.30,0:17:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubantu sebisaku,\Njadi minta dukungan yang kau perlukan.
Dialogue: 0,0:17:05.68,0:17:10.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tadi Yumeria, sekarang ini.\NPara ibu benar-benar ikut terlibat.
Dialogue: 0,0:17:10.91,0:17:11.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ratu Mylene!
Dialogue: 0,0:17:13.15,0:17:15.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, tolong tetap dekat sisiku.
Dialogue: 0,0:17:15.57,0:17:16.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:17:16.83,0:17:18.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menginginkanmu.
Dialogue: 0,0:17:21.35,0:17:27.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tak bisa!\NUmurku cukup untuk jadi ibumu!
Dialogue: 0,0:17:27.42,0:17:30.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga punya putra seumuranmu...
Dialogue: 0,0:17:30.10,0:17:33.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tak masalah. Kau cantik!
Dialogue: 0,0:17:33.26,0:17:34.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari siapa pun...
Dialogue: 0,0:17:35.28,0:17:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:17:38.19,0:17:42.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Yang Mulia.\NKita pernah begini di festival terakhir?
Dialogue: 0,0:17:42.17,0:17:46.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bartfort, kau berani sekali\Nmenggoda Ratu di Istana.
Dialogue: 0,0:17:46.95,0:17:48.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak begitu, Julius.
Dialogue: 0,0:17:48.94,0:17:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami cuma...
Dialogue: 0,0:17:50.63,0:17:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyatakan cinta satu sama lain.
Dialogue: 0,0:17:57.21,0:17:59.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu, jaga sikapmu, dong!
Dialogue: 0,0:17:59.51,0:18:03.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung, aku datang ke Istana\Nuntuk tanyakan soal utang Marie...
Dialogue: 0,0:18:03.09,0:18:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami tak begitu! Ada sesuatu\Nyang mau kuberitahukan padanya!
Dialogue: 0,0:18:06.93,0:18:09.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang mau kau beritahukan padanya?
Dialogue: 0,0:18:09.38,0:18:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:18:11.87,0:18:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal Kerajaan.
Dialogue: 0,0:18:14.71,0:18:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti akan\Nmengeluarkan taring lagi ke Kerajaan.
Dialogue: 0,0:18:18.49,0:18:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian Berdua, harap hati-hati\Nsoal situasinya mulai sekarang.
Dialogue: 0,0:18:27.57,0:18:30.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si sialan Kyle bilang dia takkan bantu.
Dialogue: 0,0:18:30.24,0:18:35.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun juga, dia pelayan Saint.\NDia takkan lakukan apa-apa.
Dialogue: 0,0:18:35.34,0:18:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, bagaimana kau bisa dapat kuncinya?
Dialogue: 0,0:18:37.99,0:18:41.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakaknya punya kunci cadangan.
Dialogue: 0,0:18:41.25,0:18:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma perlu meminjamnya.
Dialogue: 0,0:18:44.00,0:18:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pastikan kau kembalikan tanpa dia sadari.
Dialogue: 0,0:18:46.50,0:18:47.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seolah aku peduli aja.
Dialogue: 0,0:18:47.77,0:18:53.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kutaruh ini di kamarnya,\Naku ambil uangnya.
Dialogue: 0,0:18:53.46,0:18:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, soal apa yang terjadi padanya...
Dialogue: 0,0:18:55.75,0:18:58.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu pantas dia dapat, dasar sialan.
Dialogue: 0,0:18:59.46,0:19:02.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengaturan sudah dibuat.
Dialogue: 0,0:19:02.42,0:19:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Orang bodoh itu\Nsudah hancurkan barang hilang.
Dialogue: 0,0:19:06.49,0:19:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia harus ditangani semestinya.
Dialogue: 0,0:19:10.76,0:19:12.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kasih kami kapal?
Dialogue: 0,0:19:12.19,0:19:13.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gratis?
Dialogue: 0,0:19:14.24,0:19:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, kapal terbang yang kutangkap\Ndalam pertempuran dengan Kerajaan.
Dialogue: 0,0:19:18.42,0:19:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tinggalkan itu di rumah,\Ntapi kalian boleh miliki.
Dialogue: 0,0:19:22.07,0:19:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?! Ya, aku mau!
Dialogue: 0,0:19:24.36,0:19:26.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bakal bantu cari istri!
Dialogue: 0,0:19:26.08,0:19:29.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, tahan! Tak ada orang\Nyang mau kasih sebegitu gratis.
Dialogue: 0,0:19:29.38,0:19:33.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, ini Leon.\NKau merencanakan apa?
Dialogue: 0,0:19:33.00,0:19:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sikapmu seolah aku sedang\Nrencanakan sesuatu yang buruk.
Dialogue: 0,0:19:35.97,0:19:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak coba sedekah.\NAda manfaatnya juga buatku.
Dialogue: 0,0:19:40.78,0:19:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:19:42.01,0:19:43.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kasih kapal gratis,
Dialogue: 0,0:19:43.98,0:19:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi kalian bayar\Nperbaikan dan perawatannya.
Dialogue: 0,0:19:47.24,0:19:50.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang pikirkan bangun\Npabrik kapal terbang di rumah.
Dialogue: 0,0:19:50.56,0:19:53.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bakal susah dapat pelanggan awal,
Dialogue: 0,0:19:53.28,0:19:56.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi aku mau kalian kasih\Numpan balik pelanggan.
Dialogue: 0,0:19:56.77,0:20:00.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja biaya manajemen\Ndan perbaikannya masuk akal.
Dialogue: 0,0:20:00.16,0:20:04.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga dapat kapal gratis.\NKeputusan yang mudah, 'kan?
Dialogue: 0,0:20:04.02,0:20:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu, ya.
Dialogue: 0,0:20:05.70,0:20:07.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu yang diperlukan...
Dialogue: 0,0:20:07.38,0:20:08.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, kalau kau daftar sekarang,
Dialogue: 0,0:20:08.32,0:20:10.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kusertakan baju besi gratis\Nselama persediaan masih ada!
Dialogue: 0,0:20:10.78,0:20:12.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Aku daftar sekarang!
Dialogue: 0,0:20:12.36,0:20:13.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak adil! Aku duluan!
Dialogue: 0,0:20:13.78,0:20:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:20:14.63,0:20:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga mau!
Dialogue: 0,0:20:15.37,0:20:18.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, ya, ini kontraknya!
Dialogue: 0,0:20:18.04,0:20:22.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya, saat tak ada\Nyang lebih mahal daripada gratis...
Dialogue: 0,0:20:27.86,0:20:30.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Ini bikin aku puas!
Dialogue: 0,0:20:30.67,0:20:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tampak agak riang.
Dialogue: 0,0:20:32.94,0:20:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon, kau paham posisimu sekarang?
Dialogue: 0,0:20:36.48,0:20:37.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Posisi apa?
Dialogue: 0,0:20:37.64,0:20:41.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Faksi Keluarga Redgrave\Nkehilangan dukungan di Istana.
Dialogue: 0,0:20:42.14,0:20:46.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayahku menteri,\Ntapi dia kehilangan hak bicara.
Dialogue: 0,0:20:46.27,0:20:50.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquess Malcolm Frampton\Nyang sedang naik daun menegaskan
Dialogue: 0,0:20:50.03,0:20:53.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau harus diperlakukan dengan keras.
Dialogue: 0,0:20:53.98,0:20:58.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah, kalian berdua tahu banyak\Nsoal yang terjadi di Istana.
Dialogue: 0,0:20:58.95,0:21:02.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon, kau harus waspada.
Dialogue: 0,0:21:02.00,0:21:05.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marquess Frampton bisa buat\Nhal tak masuk akal terjadi sekarang.
Dialogue: 0,0:21:05.70,0:21:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerajaan juga punya masalah denganmu.
Dialogue: 0,0:21:08.61,0:21:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pahami bahaya yang kau hadapi.
Dialogue: 0,0:21:11.07,0:21:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak, kau akan tersandung...
Dialogue: 0,0:21:18.21,0:21:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudnya ini?!
Dialogue: 0,0:21:19.67,0:21:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekurangajaran apa ini?!\NDia resmi seorang viscount!
Dialogue: 0,0:21:23.75,0:21:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat tak punya pangkat.
Dialogue: 0,0:21:26.47,0:21:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat?
Dialogue: 0,0:21:27.98,0:21:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukti pengkhianatan ditemukan\Ndi kamar pria ini.
Dialogue: 0,0:21:33.04,0:21:34.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa maksudmu?
Dialogue: 0,0:21:34.76,0:21:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia merencanakan pemberontakan\Nmelawan Kerajaan.
Dialogue: 0,0:21:38.29,0:21:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia takkan pernah lakukan itu!
Dialogue: 0,0:21:40.01,0:21:43.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pahlawan yang selamatkan\Nnyawa siswa tak terhitung jumlahnya!
Dialogue: 0,0:21:43.04,0:21:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bisa perdebatkan argumenmu\Ndi pengadilan.
Dialogue: 0,0:21:48.53,0:21:50.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang, ikut kami!
Dialogue: 0,0:21:52.40,0:21:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah besar, nih.
Dialogue: 0,0:23:26.69,0:23:28.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadinya pahlawan, sekarang aku pengkhianat?!
Dialogue: 0,0:23:28.78,0:23:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konspirasi ditanam!\NKerajaan bergerak!
Dialogue: 0,0:23:30.98,0:23:33.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin ini karma atas perilakumu.
Dialogue: 0,0:23:33.06,0:23:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon...
Dialogue: 0,0:23:34.32,0:23:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, "Perubahan Mendadak Lainnya".
Dialogue: 0,0:23:36.86,0:23:39.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir,\Ncukup menyegarkan, 'kan?
