Dialogue: 0,0:01:23.55,0:01:24.96,sign,,0000,0000,0000,,PANGERAN MENYERANG\NLIHAT JURUS PEMUNGKASKU!
Dialogue: 0,0:01:37.19,0:01:39.19,sign,,0000,0000,0000,,PANGERAN MENYERANG\NLIHAT JURUS PEMUNGKASKU!
Dialogue: 0,0:03:49.50,0:03:53.01,sign,,0000,0000,0000,,CINTA AKAN MENYELAMATKAN DUNIA, 'KAN?
Dialogue: 0,0:12:47.74,0:12:50.75,sign,,0000,0000,0000,,"TUNGGU! DIA TAK PANTAS DI SINI!"
Dialogue: 0,0:19:36.54,0:19:39.55,sign,,0000,0000,0000,,"MENATAP"
Dialogue: 0,0:00:17.80,0:00:20.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak mungkin...
Dialogue: 0,0:00:20.83,0:00:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekuatan Saint pun tidak bisa\Nmengalahkan mereka?
Dialogue: 0,0:00:24.66,0:00:25.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Olivia!
Dialogue: 0,0:00:37.26,0:00:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Julius, tidak akan pernah kalah\Noleh musuh mana pun!
Dialogue: 0,0:00:43.33,0:00:44.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:00:45.14,0:00:48.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini kulakukan demi dirimu.
Dialogue: 0,0:00:48.05,0:00:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kekuatan cinta!
Dialogue: 0,0:00:54.69,0:00:57.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah kekuatan cinta!
Dialogue: 0,0:00:57.09,0:00:59.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, begitu? Cinta, ya?
Dialogue: 0,0:00:59.90,0:01:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar.\NCinta akan menyelamatkan dunia, 'kan?
Dialogue: 0,0:01:04.01,0:01:05.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamatkan apanya?!
Dialogue: 0,0:01:05.28,0:01:07.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa sih yang bikin gim otome ini?!
Dialogue: 0,0:01:07.29,0:01:10.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti kaum feminis\Nyang cuma pikirin untung wanita!
Dialogue: 0,0:01:10.04,0:01:11.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang yang terbaik.
Dialogue: 0,0:01:12.54,0:01:15.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus tiba-tiba ada kapal perang\Nterbang dan baju zirah?!
Dialogue: 0,0:01:15.54,0:01:17.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kubereskan ini semua!
Dialogue: 0,0:01:17.34,0:01:21.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus ujung-ujungnya lawan monster raksasa?!\NApa-apaan ini?!
Dialogue: 0,0:01:21.80,0:01:23.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang Mulia! Awas!
Dialogue: 0,0:01:25.05,0:01:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa susah banget, sih?!
Dialogue: 0,0:01:26.50,0:01:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Olivia.
Dialogue: 0,0:01:28.18,0:01:30.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gim ini kayak duduk di kursi kaki satu,\Ngoyang terus!
Dialogue: 0,0:01:30.65,0:01:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah berapa kali aku harus ulang, coba?!
Dialogue: 0,0:01:34.61,0:01:36.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Argh!
Dialogue: 0,0:01:36.11,0:01:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan!
Dialogue: 0,0:01:39.19,0:01:41.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulindungi kau apa pun taruhannya.
Dialogue: 0,0:01:41.34,0:01:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:01:42.26,0:01:43.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak mau kalah.
Dialogue: 0,0:01:43.67,0:01:44.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku muak sama kamu.
Dialogue: 0,0:01:44.57,0:01:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga cinta kamu.
Dialogue: 0,0:01:46.17,0:01:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyah.
Dialogue: 0,0:01:46.95,0:01:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini yang namanya cinta?
Dialogue: 0,0:01:47.96,0:01:48.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu.
Dialogue: 0,0:01:48.82,0:01:51.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Olivia!
Dialogue: 0,0:01:51.62,0:01:52.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya!
Dialogue: 0,0:01:52.36,0:01:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak!
Dialogue: 0,0:01:55.27,0:01:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlahir kembali di gim otome\Nyang paling kubenci,
Dialogue: 0,0:01:59.83,0:02:02.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai karakter mob yang bahkan\Ntak pernah muncul di gim aslinya.
Dialogue: 0,0:02:02.83,0:02:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah ceritanya kau bisa dapat aku.
Dialogue: 0,0:02:06.38,0:02:09.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dan sepertinya jalan cerita gim\Nsudah berubah gara-gara aku.
Dialogue: 0,0:02:09.88,0:02:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sulit percaya itu, Tuan.\NKau yakin bukan cuma berkhayal?
Dialogue: 0,0:02:13.42,0:02:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kau ini selalu kasar!\NSetidaknya percayalah pada tuanmu!
Dialogue: 0,0:02:24.64,0:02:25.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trapped in a Dating Sim
Dialogue: 0,0:02:28.35,0:02:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}The World of Otome Games\Nis Tough for Mobs
Dialogue: 0,0:02:38.28,0:02:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Trapped in a Dating Sim 2: The World\Nof Otome Games is Tough for Mobs
Dialogue: 0,0:03:53.01,0:03:55.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, kenapa hidupku bisa jadi begini?
Dialogue: 0,0:03:55.76,0:03:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua gara-gara ulahmu sendiri, Tuan.
Dialogue: 0,0:03:59.26,0:04:02.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tapi 'kan aku sudah berhasil\Nmenghindari perang dengan Kerajaan?
Dialogue: 0,0:04:02.89,0:04:06.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma heran kenapa waktunya\Nbeda dari yang ada di gim.
Dialogue: 0,0:04:06.53,0:04:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau juga dapat pangkat dan harta,\Nya sekaligus?
Dialogue: 0,0:04:08.89,0:04:10.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak menginginkan itu!
Dialogue: 0,0:04:11.23,0:04:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi viscount di kerajaan ini\Ncuma bikin repot ngurusin orang!
Dialogue: 0,0:04:15.15,0:04:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setuju banget sama itu.
Dialogue: 0,0:04:17.14,0:04:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah serahkan putri Fanoss ke Kerajaan,\Nbiar mereka yang urus.
Dialogue: 0,0:04:22.45,0:04:24.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya tidak jadi masalah.
Dialogue: 0,0:04:24.03,0:04:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau yakin soal itu?
Dialogue: 0,0:04:25.63,0:04:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sejujurnya aku juga tidak yakin.
Dialogue: 0,0:04:28.51,0:04:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang tahu bagaimana\Ntanggapan Kerajaan nanti?
Dialogue: 0,0:04:30.78,0:04:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga sudah memamerkan kekuatanmu.
Dialogue: 0,0:04:33.97,0:04:35.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kau merasa itu merepotkan,
Dialogue: 0,0:04:35.45,0:04:38.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mau kubasmi saja sekalian\Nsemua manusia baru itu?
Dialogue: 0,0:04:38.50,0:04:39.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:04:40.58,0:04:41.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius, deh.
Dialogue: 0,0:04:44.00,0:04:45.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutmu bagaimana, Leon?
Dialogue: 0,0:04:45.47,0:04:48.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, kau membangunnya kembali\Ndengan cukup rapi.
Dialogue: 0,0:04:48.80,0:04:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini semua berkat dana yang kau kirimkan.
Dialogue: 0,0:04:51.03,0:04:53.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount peringkat empat terbawah\Nkita ini memang hebat!
Dialogue: 0,0:04:53.83,0:04:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan itu, Ayah.
Dialogue: 0,0:04:55.49,0:04:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa antara kau dan ahli waris\NKeluarga Redgrave di akademi?
Dialogue: 0,0:04:59.54,0:05:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu bukan urusan Kakak!
Dialogue: 0,0:05:02.35,0:05:05.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nicks, sampai kapan kau mau\Ncari istri di akademi terus?
Dialogue: 0,0:05:05.93,0:05:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu juga bukan urusan Ayah!
Dialogue: 0,0:05:09.60,0:05:10.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:05:11.17,0:05:13.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamar untuk Miall sudah beres, 'kan?
Dialogue: 0,0:05:13.72,0:05:16.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Budakku harus punya kamar pribadi sendiri!
Dialogue: 0,0:05:16.99,0:05:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, aku tahu, Jenna.
Dialogue: 0,0:05:19.50,0:05:22.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga. Kok bisa\Nmakhluk itu jadi saudari kita?
Dialogue: 0,0:05:23.71,0:05:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial. Ada yang lebih parah lagi mendekat.
Dialogue: 0,0:05:26.31,0:05:27.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:05:27.48,0:05:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak durhaka kurang ajar!
Dialogue: 0,0:05:30.69,0:05:32.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Ibu!
Dialogue: 0,0:05:32.65,0:05:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Wanita Tua. Masih hidup, ya?
Dialogue: 0,0:05:35.89,0:05:38.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kembalikan harta karun itu ke Kuil!
Dialogue: 0,0:05:39.40,0:05:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun ke Kuil?
Dialogue: 0,0:05:41.99,0:05:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscount Bartfort,\Nkudengar kau pernah menaklukkan bajak laut?
Dialogue: 0,0:05:46.75,0:05:48.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, betul. Memangnya kenapa?
Dialogue: 0,0:05:48.88,0:05:53.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalung milik para bajak laut itu!\NKau ambil dari mereka, 'kan?
Dialogue: 0,0:05:53.68,0:05:56.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalung Suci?
Dialogue: 0,0:05:56.11,0:05:59.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang cari waktu yang pas\Nuntuk memberikannya ke Livia.
Dialogue: 0,0:05:59.32,0:06:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat kembalikan itu ke Kuil!
Dialogue: 0,0:06:02.07,0:06:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Penakluk bajak laut\Nberhak atas harta rampasannya.
Dialogue: 0,0:06:07.39,0:06:09.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hukum Kerajaan.
Dialogue: 0,0:06:09.08,0:06:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalung itu pasti ada ukiran lambang Kuil.
Dialogue: 0,0:06:13.39,0:06:16.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sewajarnya kau kembalikan ke Kuil.
Dialogue: 0,0:06:17.40,0:06:21.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, sayangnya kurasa\Nkau harus turuti permintaan mereka.
Dialogue: 0,0:06:21.00,0:06:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?! Kenapa?
Dialogue: 0,0:06:22.95,0:06:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah dikepung armada.
Dialogue: 0,0:06:24.78,0:06:25.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:06:26.23,0:06:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu kapal penjelajah Kuil.
Dialogue: 0,0:06:30.36,0:06:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya tak ada pilihan lain.
Dialogue: 0,0:06:34.98,0:06:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ini.
Dialogue: 0,0:06:36.89,0:06:39.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, ini harta yang hilang itu?
Dialogue: 0,0:06:39.72,0:06:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tidak diragukan lagi.
Dialogue: 0,0:06:41.77,0:06:44.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma ini yang kalian mau?\NKalau begitu, cepat pulang sana.
Dialogue: 0,0:06:44.67,0:06:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan berani-berani\Nminta sumbangan dariku sekarang.
Dialogue: 0,0:06:47.00,0:06:49.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini benar-benar pria yang kasar, ya.
Dialogue: 0,0:06:49.02,0:06:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Persis seperti kata Saint.
Dialogue: 0,0:06:51.44,0:06:52.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saint?
Dialogue: 0,0:06:52.87,0:06:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama seperti kalung ini,\Ndia muncul di Kuil bersama Gelang Suci.
Dialogue: 0,0:06:58.65,0:07:01.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tongkat Suci pun memberi respons padanya.
Dialogue: 0,0:07:01.65,0:07:02.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu, jangan-jangan...
Dialogue: 0,0:07:03.96,0:07:06.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Viscountess Marie Fou Lafan!
Dialogue: 0,0:07:08.04,0:07:10.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai lupa soal dia!
Dialogue: 0,0:07:12.73,0:07:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sampai juga di tanganku.
Dialogue: 0,0:07:15.43,0:07:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merebut posisi tokoh utama,\Nbahkan sampai jadi Saint.
Dialogue: 0,0:07:21.33,0:07:26.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini sepadan dengan kerja kerasku\Nbelajar sihir penyembuhan.
Dialogue: 0,0:07:29.06,0:07:32.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku benar-benar mengerikan.
Dialogue: 0,0:07:32.07,0:07:33.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak ada cinta, tak ada uang.
Dialogue: 0,0:07:33.98,0:07:37.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma bangsawan nama doang.\NHidupku bagai sampah.
Dialogue: 0,0:07:38.32,0:07:41.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehidupan masa laluku juga tak kalah buruk.
Dialogue: 0,0:07:41.00,0:07:43.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mulai punya pelanggan tetap di bar itu,
Dialogue: 0,0:07:43.32,0:07:46.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi malah harus ketemu pria berengsek itu.
Dialogue: 0,0:07:47.15,0:07:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi
Dialogue: 0,0:07:48.33,0:07:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dunia ini...
Dialogue: 0,0:07:50.49,0:07:53.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku pasti akan menemukan kebahagiaan!
Dialogue: 0,0:07:55.04,0:07:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marie!
Dialogue: 0,0:07:55.79,0:07:57.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rupanya kau di sini!
Dialogue: 0,0:07:57.54,0:07:59.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kucari-cari ke mana-mana!
Dialogue: 0,0:07:59.55,0:08:01.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk memperingati kau jadi Saint,
Dialogue: 0,0:08:02.71,0:08:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mau mendirikan sebuah patung.
Dialogue: 0,0:08:04.76,0:08:06.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biayanya 500.000 dia.
Dialogue: 0,0:08:08.27,0:08:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sih kalian tak pernah berhenti?!
Dialogue: 0,0:08:12.03,0:08:16.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Julius, kau paham posisimu sekarang, 'kan?
Dialogue: 0,0:08:16.11,0:08:17.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Memangnya kenapa?
Dialogue: 0,0:08:17.85,0:08:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bartfort sudah memusuhi dan mempermalukanmu,
Dialogue: 0,0:08:20.96,0:08:23.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan kau kehilangan\Nposisi sebagai putra mahkota.
Dialogue: 0,0:08:23.45,0:08:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua juga tak dapat hak waris!
Dialogue: 0,0:08:26.23,0:08:31.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Marie, hal sepele seperti itu\Ntak mungkin menghalangi cinta kita.
Dialogue: 0,0:08:31.78,0:08:35.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bahagia dicintai\Nbangsawan gagal dan miskin begini!
Dialogue: 0,0:08:35.73,0:08:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kulindungi kau apa pun taruhannya.
Dialogue: 0,0:08:37.41,0:08:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam.
Dialogue: 0,0:08:38.90,0:08:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tak mau kalah.
Dialogue: 0,0:08:40.52,0:08:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku muak sama kamu.
Dialogue: 0,0:08:41.95,0:08:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga cinta kamu.
Dialogue: 0,0:08:44.02,0:08:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enyah!
Dialogue: 0,0:08:45.01,0:08:46.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ini yang namanya cinta?
Dialogue: 0,0:08:46.72,0:08:48.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana aku tahu.
Dialogue: 0,0:08:49.41,0:08:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua kekacauan ini salah si mob sialan itu!
Dialogue: 0,0:08:52.62,0:08:55.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kutunjukkan\Nsiapa yang berkuasa di sini!
Dialogue: 0,0:08:57.29,0:08:59.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, itu antek Keluarga Ofree.
Dialogue: 0,0:08:59.66,0:09:01.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Salah satu kaki tangan Stephanie.
Dialogue: 0,0:09:01.39,0:09:02.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengkhianat.
Dialogue: 0,0:09:02.60,0:09:04.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mencoreng nama akademi.
Dialogue: 0,0:09:04.24,0:09:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Andai dia tak ada di hadapanku sekarang.
Dialogue: 0,0:09:07.09,0:09:09.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang harus kulakukan?
Dialogue: 0,0:09:10.39,0:09:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku cuma putri baronet.\NMana bisa aku lawan putri count!
Dialogue: 0,0:09:15.84,0:09:20.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin lebih baik keluargaku\Ndibubarkan saja seperti Keluarga Ofree.
Dialogue: 0,0:09:24.41,0:09:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, kau ini Carla?
Dialogue: 0,0:09:35.15,0:09:37.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kau melewati masa yang berat.
Dialogue: 0,0:09:37.56,0:09:39.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa berteman, 'kan?
Dialogue: 0,0:09:46.86,0:09:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Semua gadis yang dijatuhkan\Nmob itu akan jadi antekku.
Dialogue: 0,0:09:50.53,0:09:52.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah rasakan panasnya pembalasan!
Dialogue: 0,0:10:00.15,0:10:03.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, itu si viscount baru.
Dialogue: 0,0:10:03.07,0:10:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar Marie\Nterlahir kembali sepertiku.
Dialogue: 0,0:10:06.84,0:10:08.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi apa yang dia coba lakukan?
Dialogue: 0,0:10:08.79,0:10:10.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dapat banyak uang, 'kan?
Dialogue: 0,0:10:11.08,0:10:15.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam gim otome, tokoh utamanya,\NOlivia, jadi Saint
Dialogue: 0,0:10:15.02,0:10:17.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan mengalahkan bos akhir\Nbersama orang-orang yang mencintainya.
Dialogue: 0,0:10:17.95,0:10:19.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak keberatan menikahi orang kaya itu.
Dialogue: 0,0:10:21.46,0:10:24.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi kunci sebenarnya\Nmenuju kemenangan bukan kekuatan Saint,
Dialogue: 0,0:10:24.78,0:10:26.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan kekuatan Livia sendiri.
Dialogue: 0,0:10:26.47,0:10:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mukanya selalu bikin aku kesal.
Dialogue: 0,0:10:28.46,0:10:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam, dasar rakyat jelata!
Dialogue: 0,0:10:31.32,0:10:32.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun...
Dialogue: 0,0:10:34.40,0:10:38.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kami sampai perang lagi\Ndengan Kerajaan dan bos akhir muncul,
Dialogue: 0,0:10:38.72,0:10:41.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Livia tak akan bisa berbuat apa-apa,\Ngim akan tamat.
Dialogue: 0,0:10:42.52,0:10:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kemungkinan dunia ini akan makin hancur.
Dialogue: 0,0:10:47.08,0:10:47.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:10:50.75,0:10:51.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:10:53.49,0:10:57.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perubahan sedrastis ini\Ntentu jadi angin segar.
Dialogue: 0,0:10:57.06,0:10:59.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Undangan dari siswi?
Dialogue: 0,0:10:59.56,0:11:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meraih nama dan harta sebelum\Nlibur musim dingin, ini kudeta.
Dialogue: 0,0:11:03.03,0:11:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapkan pesta tehku dalam tiga hari!
Dialogue: 0,0:11:06.06,0:11:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita menikah,\Nkau harus belikan aku baju baru tiap hari!
Dialogue: 0,0:11:08.93,0:11:11.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga baik-baik pelayan pribadi\Ndan mainan lelakiku.
Dialogue: 0,0:11:11.76,0:11:13.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tak pernah berubah.
Dialogue: 0,0:11:13.42,0:11:15.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua wanita sama saja, menyebalkan.
Dialogue: 0,0:11:16.67,0:11:19.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Kau tak akan mengundang\Nsatu pun dari mereka?
Dialogue: 0,0:11:19.33,0:11:20.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melihat kepribadianmu,
Dialogue: 0,0:11:20.88,0:11:23.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kupikir kau bakal\Nterus mengeluh soal mereka.
Dialogue: 0,0:11:23.80,0:11:26.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kira aku ini apa?
Dialogue: 0,0:11:26.33,0:11:30.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak peduli pada wanita\Nyang cuma incar nama dan harta.
Dialogue: 0,0:11:30.50,0:11:35.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu. Jadi kau memang peduli\Npada Olivia dan Angelica.
Dialogue: 0,0:11:36.93,0:11:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku, sudah waktunya\Nkau perjelas posisimu dengan mereka.
Dialogue: 0,0:11:41.91,0:11:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu itu! Aku tahu, tapi...
Dialogue: 0,0:11:50.35,0:11:51.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:11:52.14,0:11:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seruling ajaib dan Putri Hertrude\Nsudah direbut dari kita.
Dialogue: 0,0:11:56.20,0:11:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku, Vandel,\Nkalah melawan seorang anak kecil.
Dialogue: 0,0:11:59.17,0:12:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehormatanku benar-benar ternoda.
Dialogue: 0,0:12:01.58,0:12:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, anak itu...
Dialogue: 0,0:12:06.22,0:12:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan.
Dialogue: 0,0:12:07.13,0:12:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm?
Dialogue: 0,0:12:08.43,0:12:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin jumlahnya terlalu banyak\Nuntuk dijadikan sandera.
Dialogue: 0,0:12:11.59,0:12:12.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm...
Dialogue: 0,0:12:14.53,0:12:16.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian berdua tak kubutuhkan.\NPulang sana.
Dialogue: 0,0:12:17.72,0:12:20.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkutuklah anak itu!
Dialogue: 0,0:12:23.05,0:12:24.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak...
Dialogue: 0,0:12:29.56,0:12:31.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:12:31.48,0:12:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi kau menginap di tempat Ange\Nselama libur musim dingin?
Dialogue: 0,0:12:34.67,0:12:37.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya! Seru banget!
Dialogue: 0,0:12:37.53,0:12:39.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bahkan mengajariku cara menunggang kuda.
Dialogue: 0,0:12:39.49,0:12:42.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ange keren banget!
Dialogue: 0,0:12:45.16,0:12:47.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia lebih pangeran\Ndaripada pangeran aslinya.
Dialogue: 0,0:12:47.74,0:12:50.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia penjahat dalam gim.
Dialogue: 0,0:12:50.75,0:12:54.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon, sepertinya kau agak kelelahan.
Dialogue: 0,0:12:54.60,0:12:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, undangan yang datang padaku\Nmulai banyak banget.
Dialogue: 0,0:12:58.07,0:13:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menolak semuanya sangat merepotkan.
Dialogue: 0,0:13:00.23,0:13:02.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, wajar, kau 'kan pahlawan.
Dialogue: 0,0:13:02.56,0:13:04.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tahu itu bukan aku.
Dialogue: 0,0:13:04.90,0:13:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sendiri juga cukup hebat, Livia.
Dialogue: 0,0:13:07.33,0:13:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku juga tak tahu\Napa yang merasukiku saat itu...
Dialogue: 0,0:13:10.68,0:13:13.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu namanya kekuatan Saint, ya?
Dialogue: 0,0:13:13.39,0:13:17.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tapi apa ada perempuan\Nyang kau taksir sekarang?
Dialogue: 0,0:13:17.33,0:13:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak ada.
Dialogue: 0,0:13:18.60,0:13:21.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Minum teh bersamamu dan Ange saja\Nsudah lebih dari cukup.
Dialogue: 0,0:13:22.90,0:13:28.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi sebelumnya kau mengajak\NClarice dan Deirdre minum teh, 'kan?
Dialogue: 0,0:13:30.63,0:13:32.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo cepat! Bisa telat ke kelas nanti!
Dialogue: 0,0:13:35.16,0:13:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kabur, ya.
Dialogue: 0,0:13:41.01,0:13:43.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku juga harus daftar.
Dialogue: 0,0:13:43.24,0:13:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak bisa biarkan Leon\Nterlalu jauh mendahuluiku!
Dialogue: 0,0:13:45.67,0:13:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan daftar.\NBagus juga buat berburu istri.
Dialogue: 0,0:13:49.32,0:13:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm? Ada apa?
Dialogue: 0,0:13:51.32,0:13:52.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, Leon?
Dialogue: 0,0:13:53.19,0:13:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat ini.
Dialogue: 0,0:13:54.80,0:13:56.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kulihat.
Dialogue: 0,0:13:56.07,0:13:58.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pendaftaran pertukaran pelajar\Nke Republik Alzer?
Dialogue: 0,0:13:58.19,0:13:59.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan yang itu!
Dialogue: 0,0:13:59.18,0:14:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang ini!
Dialogue: 0,0:14:00.53,0:14:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pengawal pribadi Saint?
Dialogue: 0,0:14:02.89,0:14:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan cuma Kuil Kerajaan,\Ntapi Istana Kerajaan juga!
Dialogue: 0,0:14:07.56,0:14:11.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, Pangeran Julius\Npandai menilai wanita.
Dialogue: 0,0:14:11.59,0:14:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada wacana mengembalikan dia\Nsebagai putra mahkota
Dialogue: 0,0:14:15.37,0:14:18.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menjadikan Saint Marie\Nsebagai permaisuri.
Dialogue: 0,0:14:18.48,0:14:20.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wacana yang gila.
Dialogue: 0,0:14:20.85,0:14:23.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, apa sih yang mereka pikirkan?
Dialogue: 0,0:14:23.96,0:14:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar cewek.
Dialogue: 0,0:14:25.65,0:14:26.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon!
Dialogue: 0,0:14:27.08,0:14:28.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ange?
Dialogue: 0,0:14:29.69,0:14:31.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa? Kenapa buru-buru?
Dialogue: 0,0:14:31.81,0:14:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku baru terima kabar dari rumah.
Dialogue: 0,0:14:35.57,0:14:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau diterima\Njadi anggota pengawal pribadi Saint.
Dialogue: 0,0:14:38.90,0:14:39.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:14:41.49,0:14:45.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan ini aku menunjuk\NViscount Leon Fou Bartfort
Dialogue: 0,0:14:45.49,0:14:48.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebagai kapten pengawal pribadi Saint.
Dialogue: 0,0:14:49.81,0:14:52.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin kita harus lakukan ini?
Dialogue: 0,0:14:52.42,0:14:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ragu menjadikan dia pengawal.
Dialogue: 0,0:14:55.30,0:14:59.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga Redgrave sudah tak punya\Npengaruh sekuat dulu.
Dialogue: 0,0:14:59.25,0:15:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak bisa batalkan ini dengan\Nsatu suara penolakan, Menteri Bernard.
Dialogue: 0,0:15:04.30,0:15:09.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berutang budi padanya\Nsoal Clarice, putriku.
Dialogue: 0,0:15:10.26,0:15:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku lebih suka tak melibatkan dia.
Dialogue: 0,0:15:13.94,0:15:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini demi kebaikan Istana Kerajaan.
Dialogue: 0,0:15:16.43,0:15:20.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut laporan, dia memusnahkan\Narmada Kerajaan dan pasukan monsternya,
Dialogue: 0,0:15:20.97,0:15:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bahkan berhasil mengalahkan Kesatria Hitam.
Dialogue: 0,0:15:24.20,0:15:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Potensi militernya benar-benar besar.
Dialogue: 0,0:15:26.85,0:15:28.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita tak boleh menutup mata.
Dialogue: 0,0:15:28.74,0:15:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus perintahkan dia ikut ekspedisi
Dialogue: 0,0:15:31.34,0:15:34.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan amati apakah dia punya niat memberontak.
Dialogue: 0,0:15:34.80,0:15:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau kita kirim sandera\Nsekaligus minta dia mengawasi,
Dialogue: 0,0:15:37.70,0:15:38.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita dapat dua keuntungan sekaligus.
Dialogue: 0,0:15:38.92,0:15:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hm.
Dialogue: 0,0:15:39.80,0:15:43.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ide bagus!\NKau sepenuhnya benar, Frampton.
Dialogue: 0,0:15:43.51,0:15:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberadaannya merupakan\Nancaman bagi Istana Kerajaan.
Dialogue: 0,0:15:46.65,0:15:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum dia berkonspirasi\Ndengan Kuil dan makin kuat,
Dialogue: 0,0:15:49.88,0:15:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus ambil kembali barang\Nyang hilang darinya.
Dialogue: 0,0:15:52.42,0:15:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bertentangan dengan hukum Kerajaan.
Dialogue: 0,0:15:54.61,0:15:57.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa Kerajaan mau jadi\Npencuri harta orang lain?
Dialogue: 0,0:15:57.94,0:16:03.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vince, sepertinya putrimu\Ncukup akrab dengan Viscount.
Dialogue: 0,0:16:03.62,0:16:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin kau berniat merebut\Nbarang hilang itu untuk dirimu?
Dialogue: 0,0:16:07.45,0:16:09.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hmph. Omong kosong.
Dialogue: 0,0:16:09.77,0:16:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kau tak akan keberatan.
Dialogue: 0,0:16:12.31,0:16:13.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanpa penundaan,
Dialogue: 0,0:16:14.24,0:16:19.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan kirim Bartfort\Nmencari harta karun bersama Saint.
Dialogue: 0,0:16:19.37,0:16:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun?
Dialogue: 0,0:16:21.33,0:16:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Saint sedang kesulitan keuangan.
Dialogue: 0,0:16:24.55,0:16:28.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan penuhi sebagian permintaannya.
Dialogue: 0,0:16:31.72,0:16:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gimana? Aku mirip Saint sungguhan, 'kan?
Dialogue: 0,0:16:35.35,0:16:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:16:36.76,0:16:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:16:38.66,0:16:41.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perempuan itu jadi besar kepala.
Dialogue: 0,0:16:41.79,0:16:43.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa juga sih maunya Carla?
Dialogue: 0,0:16:43.64,0:16:46.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkin dia lakukan itu\Nkarena dendam padamu.
Dialogue: 0,0:16:46.92,0:16:48.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah...
Dialogue: 0,0:16:50.74,0:16:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau berpakaian begitu?
Dialogue: 0,0:16:52.35,0:16:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sok-sokan jadi petualang sekarang?
Dialogue: 0,0:16:54.33,0:16:56.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah, sudah.\NHentikan itu.
Dialogue: 0,0:16:57.20,0:16:59.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau terlihat lumayan cantik memakainya.
Dialogue: 0,0:16:59.21,0:17:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saint Marie...
Dialogue: 0,0:17:01.15,0:17:04.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hehe. Aku yakin kau kesal.\NRasakan itu.
Dialogue: 0,0:17:06.79,0:17:10.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa? Merajuk karena mereka\Nrebut perhatian tuanmu?
Dialogue: 0,0:17:11.08,0:17:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bicara padaku.\NAku sudah cukup benci kamu.
Dialogue: 0,0:17:16.76,0:17:20.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ugh! Anak nakal yang kurang ajar!
Dialogue: 0,0:17:20.58,0:17:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tuan, kenapa Partner\Nharus ikut bersama kita?
Dialogue: 0,0:17:25.05,0:17:28.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah adanya.\NIstana yang perintahkan.
Dialogue: 0,0:17:28.81,0:17:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Istana yang perintahkan?
Dialogue: 0,0:17:30.52,0:17:35.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mewaspadaiku.\NIni sudah keterlaluan.
Dialogue: 0,0:17:35.90,0:17:38.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon!
Dialogue: 0,0:17:41.17,0:17:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan jadi yang pertama\Nmenemukan harta karun itu!
Dialogue: 0,0:17:44.21,0:17:46.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sampai tak bisa tidur\Nsaking semangatnya kemarin!
Dialogue: 0,0:17:47.23,0:17:50.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarga kerajaan dan bangsawan\Nmemang keturunan petualang.
Dialogue: 0,0:17:50.41,0:17:52.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Darah pemburunya memang tak bisa diam.
Dialogue: 0,0:17:53.18,0:17:56.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar menyelidiki reruntuhannya!
Dialogue: 0,0:17:56.43,0:17:59.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa ya kehidupan orang zaman dahulu?
Dialogue: 0,0:17:59.79,0:18:03.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau memang murid beasiswa sejati.\NTak pernah berhenti belajar.
Dialogue: 0,0:18:04.08,0:18:08.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Partner punya bak mandi besar.\NKalian bisa santai sampai kita tiba.
Dialogue: 0,0:18:08.12,0:18:09.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:18:09.00,0:18:10.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tak sabar!
Dialogue: 0,0:18:10.68,0:18:12.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Bak mandi?
Dialogue: 0,0:18:12.69,0:18:16.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pas banget! Aku mau membasuh keringatku.
Dialogue: 0,0:18:16.93,0:18:18.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian juga ikut?
Dialogue: 0,0:18:19.12,0:18:22.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pangeran Julius ada urusan\Ndi Istana Kerajaan.
Dialogue: 0,0:18:22.55,0:18:24.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami yang akan lindungi Marie!
Dialogue: 0,0:18:24.69,0:18:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah. Tapi kalian berdua, benalu,\Ndilarang pakai bak mandi.
Dialogue: 0,0:18:29.46,0:18:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang mandi 'kan karena kepanasan?
Dialogue: 0,0:18:32.00,0:18:34.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali\Ntak kepanasan atau berkeringat.
Dialogue: 0,0:18:34.95,0:18:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngomong sok tahu dengan suara pas-pasan...
Dialogue: 0,0:18:38.19,0:18:41.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi yang lebih penting,\Nkenapa dia ada di sini?
Dialogue: 0,0:18:42.17,0:18:44.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tak pernah diam mulutnya, ya.
Dialogue: 0,0:18:44.60,0:18:48.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa orang-orang dari Kerajaan\Nmemang selalu begini?
Dialogue: 0,0:18:50.43,0:18:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Kerajaan Fanoss\Npemegang seruling ajaib...
Dialogue: 0,0:18:54.67,0:18:59.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ada gencatan senjata,\Ndia jadi sandera bagus bagi Kerajaan,
Dialogue: 0,0:18:59.95,0:19:03.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi Istana justru menyuruh dia\Nmenemani kami.
Dialogue: 0,0:19:03.63,0:19:06.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan dalih mengamati perbatasan?
Dialogue: 0,0:19:06.07,0:19:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh.
Dialogue: 0,0:19:06.77,0:19:08.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, siapa dia?
Dialogue: 0,0:19:08.52,0:19:12.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putri Hertrude dari Kerajaan Fanoss.
Dialogue: 0,0:19:12.09,0:19:14.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia dianggap sebagai siswa pertukaran.
Dialogue: 0,0:19:14.40,0:19:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ngapain seorang putri ada di sini?
Dialogue: 0,0:19:17.53,0:19:20.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betul. Meski dia sedang diawasi ketat,
Dialogue: 0,0:19:20.81,0:19:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini tetap jadi masalah\Nbagi keamanan kerajaan.
Dialogue: 0,0:19:22.78,0:19:26.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh? Silakan sampaikan keluhanmu ke Istana.
Dialogue: 0,0:19:26.04,0:19:29.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ragu mereka mau dengar\NKeluarga Redgrave yang sudah surut.
Dialogue: 0,0:19:31.02,0:19:33.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seruling ajaib itu\Nsudah diamankan di ibu kota.
Dialogue: 0,0:19:34.24,0:19:36.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selama dia masih terlihat,
Dialogue: 0,0:19:36.54,0:19:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bos akhir tak mungkin muncul.
Dialogue: 0,0:19:39.55,0:19:43.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf. Bisa jangan tatap aku\Ndengan mata mesum itu?
Dialogue: 0,0:19:43.20,0:19:44.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?
Dialogue: 0,0:19:44.36,0:19:46.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata mesum?
Dialogue: 0,0:19:50.21,0:19:52.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, uh, maaf deh.
Dialogue: 0,0:19:52.50,0:19:54.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa matamu malah penuh belas kasihan?!
Dialogue: 0,0:19:58.02,0:19:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini luar biasa.
Dialogue: 0,0:19:59.57,0:20:02.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Enak banget!\NSuhu airnya pas!
Dialogue: 0,0:20:09.95,0:20:11.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, tidak, em...
Dialogue: 0,0:20:11.47,0:20:13.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya lembut banget,
Dialogue: 0,0:20:13.16,0:20:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi...
Dialogue: 0,0:20:15.20,0:20:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Punyamu juga, Ange!
Dialogue: 0,0:20:17.75,0:20:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan itu, Livia!
Dialogue: 0,0:20:19.38,0:20:22.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saint, aku benci mereka berdua.
Dialogue: 0,0:20:22.09,0:20:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hampir setahun ini\Naku membenci mereka.
Dialogue: 0,0:20:29.30,0:20:31.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Sudah terlihat!
Dialogue: 0,0:20:31.91,0:20:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Leon, itu tujuan kita, pulau terapung!
Dialogue: 0,0:20:35.06,0:20:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiap mendarat sekarang juga!\NAku mau harta itu segera!
Dialogue: 0,0:20:41.87,0:20:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:20:43.10,0:20:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau ini seorang Saint, lo.
Dialogue: 0,0:20:46.48,0:20:49.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obsesimu pada uang\Nkelihatan agak tidak pantas.
Dialogue: 0,0:20:49.35,0:20:52.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang kau tahu, Tuan Putri?!
Dialogue: 0,0:20:52.49,0:20:55.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tak punya uang itu hal yang buruk.
Dialogue: 0,0:20:55.48,0:20:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini nasib yang lebih buruk daripada mati!
Dialogue: 0,0:20:57.74,0:21:00.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluargaku terus terlilit utang makin dalam,
Dialogue: 0,0:21:00.49,0:21:02.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan terus buang-buang uang\Nuntuk hal tak berguna!
Dialogue: 0,0:21:02.76,0:21:04.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begitu, ya...
Dialogue: 0,0:21:04.43,0:21:07.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku... jadi agak kasihan sama dia sekarang.
Dialogue: 0,0:21:07.70,0:21:10.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia mengingatkanku\Npada adikku di kehidupan lalu.
Dialogue: 0,0:21:10.20,0:21:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Uang!
Dialogue: 0,0:21:11.87,0:21:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, di mana kita harus mendarat?\NHarta karun pasti di reruntuhan.
Dialogue: 0,0:21:18.40,0:21:22.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, pasti ada juga\Nbarang hilang di sini.
Dialogue: 0,0:21:22.42,0:21:24.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan pandu kalian.
Dialogue: 0,0:21:25.19,0:21:29.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pulau ini ditutupi hutan.\NCuma sedikit tempat untuk mendarat.
Dialogue: 0,0:21:29.89,0:21:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah? Kok kau bisa tahu itu?
Dialogue: 0,0:21:33.83,0:21:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku besar di sini.
Dialogue: 0,0:21:40.15,0:21:45.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya Saint akan sampai\Ndi tempat tujuan sebentar lagi.
Dialogue: 0,0:21:45.64,0:21:49.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuharap mereka bisa mendapatkannya.
Dialogue: 0,0:23:25.98,0:23:28.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjelajahi reruntuhan mencari harta karun!
Dialogue: 0,0:23:28.36,0:23:32.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lokasinya pulau elf yang indah,\Ntapi ada kejahatan di baliknya?
Dialogue: 0,0:23:32.99,0:23:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih parah darimu, Tuan?
Dialogue: 0,0:23:34.26,0:23:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:23:34.99,0:23:37.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya,\N"Apakah Kau Menyukai Estetika Kehancuran?"
Dialogue: 0,0:23:37.87,0:23:40.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju, menuju petualangan yang mengasyikkan!
