Dialogue: 0,0:00:11.00,0:00:14.79,sign,,0000,0000,0000,,JODOH
Dialogue: 0,0:00:14.79,0:00:17.01,sign,,0000,0000,0000,,PERSEMBAHAN
Dialogue: 0,0:00:45.28,0:00:46.54,sign,,0000,0000,0000,,AIJO RENTARO
Dialogue: 0,0:00:49.25,0:00:49.60,sign,,0000,0000,0000,,HANAZONO HAKARI - INDA KARANE
Dialogue: 0,0:01:28.23,0:01:29.44,sign,,0000,0000,0000,,CERITA CINTA
Dialogue: 0,0:01:29.44,0:01:34.49,sign,,0000,0000,0000,,BOLEH TANYA CERITA CINTAMU?
Dialogue: 0,0:13:06.60,0:13:09.17,sign,,0000,0000,0000,,KEJUTAN
Dialogue: 0,0:00:20.13,0:00:23.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jodoh.
Dialogue: 0,0:00:24.26,0:00:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah
Dialogue: 0,0:00:28.70,0:00:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pasangan asmara yang ditakdirkan\Nhanya ada satu saat manusia lahir ke dunia.
Dialogue: 0,0:00:36.32,0:00:38.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetapi di sini!
Dialogue: 0,0:00:38.33,0:00:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada seorang pemuda\Nyang ditakdirkan memiliki 100 jodoh!
Dialogue: 0,0:00:44.15,0:00:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya adalah...
Dialogue: 0,0:00:46.55,0:00:49.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aijo Rentaro!
Dialogue: 0,0:00:49.61,0:00:54.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bersumpah dari lubuk hati\Nuntuk mencintai dan membahagiakan
Dialogue: 0,0:00:54.33,0:00:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua jodoh yang ia temui!
Dialogue: 0,0:00:57.92,0:01:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarnya yang sekarang ada sebel...,\Nsebelas?!
Dialogue: 0,0:01:04.95,0:01:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, barusan muncul\Ngadis yang tidak kukenal, ya?!
Dialogue: 0,0:01:08.92,0:01:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh? Apa mungkin ada kesalahan\Nsaat disunting?
Dialogue: 0,0:01:12.81,0:01:13.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana boleh begitu!
Dialogue: 0,0:01:13.88,0:01:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di anime harusnya baru ada 11 pacar!
Dialogue: 0,0:01:16.25,0:01:19.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagu pembukanya masih belum ada?\NOke, baik.
Dialogue: 0,0:01:19.61,0:01:21.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Langsung masuk jeda iklan saja.
Dialogue: 0,0:01:21.60,0:01:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaran lanjut setelah iklan!
Dialogue: 0,0:01:23.32,0:01:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Narator!\NTunggu dulu!
Dialogue: 0,0:01:26.32,0:01:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah.
Dialogue: 0,0:01:34.78,0:01:37.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh tanya cerita cintamu?
Dialogue: 0,0:01:37.24,0:01:41.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini, kami akan melakukan wawancara\Ndi pusat perbelanjaan ini.
Dialogue: 0,0:01:41.41,0:01:45.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekali di sana\Nada rombongan gadis,
Dialogue: 0,0:01:45.04,0:01:47.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mari kita hampiri mereka!
Dialogue: 0,0:01:48.92,0:01:50.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktunya pas sekali?
Dialogue: 0,0:01:50.46,0:01:52.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan rekayasa, lo!
Dialogue: 0,0:01:53.18,0:01:55.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Begitu, ya?\N- Harum, harum sekali!
Dialogue: 0,0:01:55.01,0:01:57.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ini juga cocok sekali denganku!\N- Tentu saja oke.
Dialogue: 0,0:01:57.30,0:01:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Beli dulu baru dimakan!\N- "Benar".
Dialogue: 0,0:01:59.52,0:02:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pipi bocil...
Dialogue: 0,0:02:01.64,0:02:03.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu sudah cuci tangan belum?
Dialogue: 0,0:02:03.14,0:02:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, boleh minta waktu kalian sebentar?
Dialogue: 0,0:02:06.52,0:02:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami dari acara "Boleh Tanya Cerita Cintamu?"\Ndan sedang ada wawancara langsung.
Dialogue: 0,0:02:12.24,0:02:13.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku selalu nonton!
Dialogue: 0,0:02:13.99,0:02:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:02:15.49,0:02:19.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa di antara kalian ada yang punya pacar?
Dialogue: 0,0:02:21.45,0:02:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya punya?!
Dialogue: 0,0:02:23.66,0:02:24.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:02:24.79,0:02:26.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mereka semua punya pacar!
Dialogue: 0,0:02:26.88,0:02:30.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya kita akan dapat banyak\Ncerita cinta yang mendebarkan!
Dialogue: 0,0:02:30.42,0:02:36.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, saat seperti apa kalian\Nterakhir kalinya merasa disayang pacar?!
Dialogue: 0,0:02:37.14,0:02:39.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, terakhir kali, ya?
Dialogue: 0,0:02:39.60,0:02:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hak sepatuku patah saat kencan.
Dialogue: 0,0:02:42.39,0:02:47.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi saat hampir terjatuh, dia langsung\Nmemapahku digendong seperti tuan putri.
Dialogue: 0,0:02:47.86,0:02:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah! Luar biasa!
Dialogue: 0,0:02:49.19,0:02:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti pangeran berkuda putih saja!
Dialogue: 0,0:02:52.74,0:02:57.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, dia terus membopongku selama kencan.
Dialogue: 0,0:02:57.28,0:02:59.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia sendiri yang jadi kuda putihnya?!
Dialogue: 0,0:02:59.20,0:03:03.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa pacarnya seperti pahlawan\Ndi Quest Naga Satu saja?
Dialogue: 0,0:03:04.58,0:03:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana denganmu?
Dialogue: 0,0:03:07.08,0:03:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang dicari acara ini adalah cerita cinta\Nyang mengena ke penonton.
Dialogue: 0,0:03:10.42,0:03:13.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis yang kelihatan rendah hati\Ndan pemalu ini pasti punya!
Dialogue: 0,0:03:14.51,0:03:17.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, pengait beha saya patah.
Dialogue: 0,0:03:17.13,0:03:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia mau menahan bagian bra\Nyang rusak itu seharian penuh.
Dialogue: 0,0:03:21.64,0:03:23.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pacar yang pengertian sekali!
Dialogue: 0,0:03:23.60,0:03:25.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan ditahan pakai peniti?
Dialogue: 0,0:03:25.98,0:03:29.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan kalian pasangan kikuk\Nyang sangat mesra?
Dialogue: 0,0:03:29.15,0:03:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan...
Dialogue: 0,0:03:30.06,0:03:34.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soalnya, pakai berapa puluh peniti pun\Ntetap akan lepas.
Dialogue: 0,0:03:35.99,0:03:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia tahan terus dengan tangannya.
Dialogue: 0,0:03:38.32,0:03:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daripada kikuk mesra,\Nlebih ke kikuk mencengkeram!
Dialogue: 0,0:03:42.41,0:03:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebenarnya, sebesar apa\Nyang kamu sembunyikan di sana?
Dialogue: 0,0:03:46.79,0:03:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf! Ti-Tidak sebesar itu!
Dialogue: 0,0:03:52.13,0:03:53.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghilang?
Dialogue: 0,0:03:54.84,0:03:57.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Anda?
Dialogue: 0,0:03:58.26,0:03:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Kalau saya..."
Dialogue: 0,0:03:59.59,0:04:01.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bi-Bicaranya pakai ponsel pintar?!
Dialogue: 0,0:04:02.01,0:04:07.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Agar bisa menyamakan topik pembicaraan\Ndengan saya yang suka membaca."
Dialogue: 0,0:04:07.43,0:04:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia teliti "menghafal" buku\Njuga menulis catatan di tangannya."
Dialogue: 0,0:04:13.27,0:04:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tubuhnya sampai penuh tulisan."
Dialogue: 0,0:04:15.15,0:04:16.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa sejenis kutukan?
Dialogue: 0,0:04:16.74,0:04:19.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pa-Pacarmu benar-benar pengertian...
Dialogue: 0,0:04:19.86,0:04:22.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti Hoichi si Tanpa Telinga...
Dialogue: 0,0:04:22.16,0:04:27.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tapi dia lebih hebat dari itu,\Nbahkan telinganya juga penuh tulisan."
Dialogue: 0,0:04:27.29,0:04:28.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar pacar terbaik!
Dialogue: 0,0:04:28.87,0:04:31.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau Anda?
Dialogue: 0,0:04:31.83,0:04:34.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kami melewati jembatan waktu kencan.
Dialogue: 0,0:04:34.88,0:04:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sadar kalau aku takut ketinggian.
Dialogue: 0,0:04:37.55,0:04:41.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu! Pasti dia menggenggam\Ntanganmu sampai seberang, ya?!
Dialogue: 0,0:04:43.80,0:04:46.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menggendongku dan berenang\Nsampai seberang.
Dialogue: 0,0:04:46.18,0:04:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata cuma kencan elegan di atas air!
Dialogue: 0,0:04:49.14,0:04:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, selanjutnya Anda!
Dialogue: 0,0:04:50.98,0:04:52.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, I am?
Dialogue: 0,0:04:52.52,0:04:55.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia orang luar negeri?
Dialogue: 0,0:04:55.02,0:04:56.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungan cinta antar negara?!
Dialogue: 0,0:04:57.36,0:04:59.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski I am berpakaian ala koboi,
Dialogue: 0,0:04:59.70,0:05:04.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi fak banget menunggang kuda,\Ntiap kali pasti jadi catastrophe.
Dialogue: 0,0:05:04.41,0:05:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:05:05.66,0:05:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, demi I am yang seperti itu,\NDarling menemaniku latihan rodeo together.
Dialogue: 0,0:05:11.17,0:05:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, latihan menunggang kuda sama pacar, ya?
Dialogue: 0,0:05:14.29,0:05:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita yang bagus sekali!
Dialogue: 0,0:05:18.01,0:05:19.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}No! No!
Dialogue: 0,0:05:19.59,0:05:21.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku merodeo Darling.
Dialogue: 0,0:05:21.72,0:05:24.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak, kencan berkuda yang seru sekali!
Dialogue: 0,0:05:24.35,0:05:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I am juga mau merodeo Darling!
Dialogue: 0,0:05:27.18,0:05:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kalau Anda bagaimana?!
Dialogue: 0,0:05:28.72,0:05:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku?
Dialogue: 0,0:05:29.85,0:05:36.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Anu, orang yang menjadi pacarku,\Nsangat mendukungku.
Dialogue: 0,0:05:36.94,0:05:41.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, pria yang selalu mendukung\Nmemang yang terbaik, ya.
Dialogue: 0,0:05:41.36,0:05:43.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Benar!
Dialogue: 0,0:05:43.49,0:05:47.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:05:47.16,0:05:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat aku jatuh dan tubuhku hampir\Nmenimpa serangga...
Dialogue: 0,0:05:50.66,0:05:52.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tangan dan kakinya hancur untuk...
Dialogue: 0,0:05:52.92,0:05:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata mendukung secara fisik?!
Dialogue: 0,0:05:55.92,0:05:57.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Iku, kenapa kamu mengikutiku?\N- Kalau Anda bagaimana?
Dialogue: 0,0:05:57.96,0:05:59.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau aku...
Dialogue: 0,0:05:59.55,0:06:05.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum lama ini menjalankan rencana\Nbercocok tanam sempurna di ruang tertutup.
Dialogue: 0,0:06:05.05,0:06:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia menolak dengan sekuat tenaga,\Njadi rencananya gagal.
Dialogue: 0,0:06:09.31,0:06:13.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi jadi terasa kalau dia\Nbetul-betul menyayangiku.
Dialogue: 0,0:06:13.35,0:06:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sekuat tenaga menutup matanya, ya?
Dialogue: 0,0:06:16.15,0:06:18.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria yang sopan sekali.
Dialogue: 0,0:06:18.02,0:06:19.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...
Dialogue: 0,0:06:19.07,0:06:21.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menghantamkan kepala ke dinding\Nsampai pingsan.
Dialogue: 0,0:06:21.86,0:06:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan pendekar gila!\NTapi pria sopan yang gila!
Dialogue: 0,0:06:25.03,0:06:28.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Serang, Berser-CAR!\N- "Dia lelaki yang dikenal sebagai Berserker."
Dialogue: 0,0:06:28.78,0:06:30.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya?
Dialogue: 0,0:06:30.12,0:06:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi ternyata sebuah Car.
Dialogue: 0,0:06:32.00,0:06:33.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan Car yang artinya mobil.
Dialogue: 0,0:06:33.91,0:06:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus, bagaimana kalau Anda?!
Dialogue: 0,0:06:36.38,0:06:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempo hari, dia kupukul sampai luka sedikit\Nbuat menutupi malu.
Dialogue: 0,0:06:40.50,0:06:43.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, dia sama sekali tidak marah.
Dialogue: 0,0:06:43.13,0:06:43.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah!
Dialogue: 0,0:06:43.72,0:06:47.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak marah kalau cuma dilukai sedikit,\Npacar yang sangat baik hati!
Dialogue: 0,0:06:47.72,0:06:50.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, kalau dibilang sedikit...
Dialogue: 0,0:06:50.47,0:06:52.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia cuman patah tulang parah\Ndi sekujur tubuhnya.
Dialogue: 0,0:06:52.39,0:06:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak marah, kok.
Dialogue: 0,0:06:53.35,0:06:54.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:06:54.35,0:06:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata monster yang sangat baik hati!
Dialogue: 0,0:06:56.73,0:06:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan bunuh dia, ya.
Dialogue: 0,0:06:58.65,0:07:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku tidak melakukannya dengan sengaja!
Dialogue: 0,0:07:00.98,0:07:02.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru karena itu.
Dialogue: 0,0:07:02.61,0:07:04.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oke, kalau Anda?!
Dialogue: 0,0:07:06.70,0:07:10.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kulitku terlalu halus,\Nteh hitam yang kupegang tumpah
Dialogue: 0,0:07:10.28,0:07:13.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan hampir saja mengotori bajuku.
Dialogue: 0,0:07:13.25,0:07:15.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacar Anda menangkap cangkir itu, ya?!
Dialogue: 0,0:07:15.62,0:07:17.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Antipanas!
Dialogue: 0,0:07:17.12,0:07:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyedot semuanya\Ntanpa sisa setetes pun.
Dialogue: 0,0:07:20.09,0:07:21.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia penyedot debu!
Dialogue: 0,0:07:21.88,0:07:23.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Rentaro memang juara soal makanan!
Dialogue: 0,0:07:23.59,0:07:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daun teh itu juga makhluk hidup!
Dialogue: 0,0:07:25.59,0:07:27.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Anda?!
Dialogue: 0,0:07:27.43,0:07:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Momiji ingin jadi pemijat profesional,\Njadi untuk latihan memijat lengan bawah
Dialogue: 0,0:07:32.76,0:07:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia latihan sampai lengannya kaku\Nseperti robot Astro berlengan besi, ya?!
Dialogue: 0,0:07:37.23,0:07:37.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:07:37.90,0:07:41.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang jadi seperti robot,\Ntapi yang anggota kru Topi Jerami.
Dialogue: 0,0:07:42.19,0:07:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Franky sebelum jeda dua tahun!
Dialogue: 0,0:07:45.53,0:07:50.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua bisa begitu, apa pacar\Nzaman sekarang itu monster semua?
Dialogue: 0,0:07:50.53,0:07:53.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua pacar yang diceritakan\Nadalah orang yang sama.
Dialogue: 0,0:07:53.54,0:07:55.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tidak mungkin...
Dialogue: 0,0:07:55.95,0:07:57.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak mungkin terjadi.
Dialogue: 0,0:07:58.42,0:08:00.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, bagaimana dengan anda?!
Dialogue: 0,0:08:00.79,0:08:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melewati gunung dan sungai\Nmengejar burung...
Dialogue: 0,0:08:02.54,0:08:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atlet kejar kacamata!
Dialogue: 0,0:08:04.80,0:08:07.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengambilkan matsutake legendaris\Ndari area babi ganas.
Dialogue: 0,0:08:07.51,0:08:09.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster pemburu matsutake!
Dialogue: 0,0:08:09.97,0:08:11.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi aku yang suka latihan kelewat batas,
Dialogue: 0,0:08:11.72,0:08:13.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dia coba dulu sampai batas tubuhnya.
Dialogue: 0,0:08:13.60,0:08:15.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci percobaan!
Dialogue: 0,0:08:15.14,0:08:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau mencoba obat baruku.
Dialogue: 0,0:08:16.27,0:08:18.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci percobaan sungguhan!
Dialogue: 0,0:08:22.48,0:08:26.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya sudah, yang terakhir Anda.
Dialogue: 0,0:08:26.49,0:08:31.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat membawa saya kencan ke tempat\Ndengan pemandangan indah.
Dialogue: 0,0:08:31.45,0:08:36.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia menyiapkan kejutan untuk\Nmembuka mata saya yang selalu tertutup.
Dialogue: 0,0:08:37.15,0:08:38.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kejutan!
Dialogue: 0,0:08:38.65,0:08:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah bumbu asmara terbaik\Nyang diidamkan para wanita!
Dialogue: 0,0:08:43.75,0:08:44.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia!
Dialogue: 0,0:08:44.80,0:08:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarnya, beda dengan pacar mereka!
Dialogue: 0,0:08:48.59,0:08:50.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai ke akar-akarnya pun\Ntidak ada bedanya.
Dialogue: 0,0:08:50.84,0:08:54.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di bukit yang kami kunjungi terakhir\Nsaat kencan, dia bilang padaku.
Dialogue: 0,0:08:54.60,0:08:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mei, sebenarnya
Dialogue: 0,0:08:57.93,0:09:00.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepanjang hari ini\Naku memakai kostum Frieza.
Dialogue: 0,0:09:00.94,0:09:01.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu.
Dialogue: 0,0:09:01.73,0:09:04.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yak, ternyata kejutan bikin kaget!
Dialogue: 0,0:09:05.73,0:09:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah wawancara sebanyak ini,\Ntapi nihil cerita cinta yang mengena.
Dialogue: 0,0:09:09.70,0:09:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat sekali.
Dialogue: 0,0:09:11.36,0:09:14.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini terus,\Nsiaran episode ini bisa hancur
Dialogue: 0,0:09:14.87,0:09:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebur.
Dialogue: 0,0:09:20.12,0:09:24.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, kami dari acara TV\N"Boleh Tanya Soal Cerita Cintamu?".
Dialogue: 0,0:09:24.13,0:09:24.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:24.84,0:09:27.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kutonton sejak umur nol tahun!
Dialogue: 0,0:09:27.55,0:09:29.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda lucu juga.
Dialogue: 0,0:09:29.88,0:09:31.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kamu punya pacar?
Dialogue: 0,0:09:31.84,0:09:33.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Iya, anu...
Dialogue: 0,0:09:34.01,0:09:34.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!
Dialogue: 0,0:09:34.93,0:09:36.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bagus sekali!
Dialogue: 0,0:09:36.43,0:09:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatan polos dan seperti\Npria teladan yang ideal!
Dialogue: 0,0:09:40.14,0:09:45.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak ini pasti tidak mungkin\Npacaran sama monster!
Dialogue: 0,0:09:45.15,0:09:48.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritakanlah, kisah cinta yang mengena\Ndan membangkitkan harapan!
Dialogue: 0,0:09:48.11,0:09:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:09:49.15,0:09:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang hebat dari pacarmu?
Dialogue: 0,0:09:53.07,0:09:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarku itu...
Dialogue: 0,0:09:56.16,0:09:57.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa melemaskan badan kaku dengan pijatannya.
Dialogue: 0,0:09:57.58,0:09:59.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa menghafal banyak buku baris demi baris.
Dialogue: 0,0:09:59.12,0:10:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat seksi padahal masih SMA.
Dialogue: 0,0:10:00.33,0:10:01.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peka ke segala penyimpangan.
Dialogue: 0,0:10:01.46,0:10:01.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat cantik.
Dialogue: 0,0:10:01.96,0:10:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat kaya bisa beli segalanya.
Dialogue: 0,0:10:03.21,0:10:04.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terus berjuang sampai badannya hancur.
Dialogue: 0,0:10:04.88,0:10:06.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa membuat obat\Nseperti alat ajaib Doraemon.
Dialogue: 0,0:10:06.71,0:10:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalkulasinya sempurna seperti akal imitasi.
Dialogue: 0,0:10:08.21,0:10:09.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsundere alami.
Dialogue: 0,0:10:09.25,0:10:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang Amerika padahal orang Jepang.
Dialogue: 0,0:10:10.38,0:10:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tingginya dua meter dan\Nlebih kuat dari beruang.
Dialogue: 0,0:10:12.01,0:10:13.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa makan tanpa batas.
Dialogue: 0,0:10:13.05,0:10:14.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa apa saja sambil menutup mata.
Dialogue: 0,0:10:14.26,0:10:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bisa menghilang dari...\N- Cukup!
Dialogue: 0,0:10:15.18,0:10:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata monster juga!
Dialogue: 0,0:10:17.14,0:10:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei! Apa maksudmu monster?!
Dialogue: 0,0:10:18.76,0:10:20.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pacarku itu makhluk terimut di dunia ini!
Dialogue: 0,0:10:20.77,0:10:22.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, matikan kameranya!
Dialogue: 0,0:10:25.73,0:10:28.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betulan ada gadis yang tidak kukenal!
Dialogue: 0,0:10:28.73,0:10:30.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, ini episode satu musim ketiga, kan?!
Dialogue: 0,0:10:30.94,0:10:32.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku kelewatan?!
Dialogue: 0,0:10:32.49,0:10:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, dari informasi yang baru masuk...
Dialogue: 0,0:10:35.57,0:10:38.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Katanya, Pak Sutradara lagi iseng.
Dialogue: 0,0:10:38.66,0:10:39.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sato Hikaru ampas!
Dialogue: 0,0:10:39.58,0:10:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, OP? Lagu pembuka sudah sampai?!
Dialogue: 0,0:10:41.75,0:10:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore!
Dialogue: 0,0:10:42.54,0:10:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo putar lagu pembukanya!
Dialogue: 0,0:10:44.04,0:10:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, terserahmu saja!
Dialogue: 0,0:11:00.89,0:11:06.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}100 Pacar yang Sungguh Sangat Amat\NBenar-benar Mencintaimu Musim Ketiga
Dialogue: 0,0:12:17.67,0:12:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tempatnya.
Dialogue: 0,0:12:19.72,0:12:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama sekali\Naku tidak ke rumah Paman Hiro.
Dialogue: 0,0:12:23.97,0:12:25.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rumahnya dekat.
Dialogue: 0,0:12:25.18,0:12:29.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sering main ke sini\Nsebelum Paman Hiro jadi sibuk.
Dialogue: 0,0:12:29.73,0:12:30.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu.
Dialogue: 0,0:12:31.10,0:12:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku diminta menjaga putrinya karena\NPaman tiba-tiba harus pergi.
Dialogue: 0,0:12:35.19,0:12:37.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku belum pernah\Ndipertemukan sama dia.
Dialogue: 0,0:12:38.40,0:12:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari dulu Paman Hiro memang berlebihan\Nmemujiku sebagai anak baik.
Dialogue: 0,0:12:45.62,0:12:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman Hiro, awas!
Dialogue: 0,0:12:49.71,0:12:52.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar bego!\NMau mati, ya?!
Dialogue: 0,0:12:54.13,0:12:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal cuma kutolong dari truk tangki.
Dialogue: 0,0:12:58.47,0:12:59.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah.
Dialogue: 0,0:12:59.47,0:13:03.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putrinya, Chiyo itu baru masuk SMP\Nitu adalah sepupu.
Dialogue: 0,0:13:04.05,0:13:06.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, harusnya tidak bakal ada kejutan.
Dialogue: 0,0:13:09.18,0:13:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja?!
Dialogue: 0,0:13:11.81,0:13:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal belum lama ini\Ndia masih pakai ransel anak SD.
Dialogue: 0,0:13:15.36,0:13:18.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin tidak akan jadi masalah,\NKomite Produksi?
Dialogue: 0,0:13:20.36,0:13:21.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin mau melakukan ini?!
Dialogue: 0,0:13:23.37,0:13:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu, namaku Iin Chiyo.
Dialogue: 0,0:13:26.03,0:13:28.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku Aijo Rentaro.
Dialogue: 0,0:13:30.46,0:13:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya kita belum pernah ketemu?
Dialogue: 0,0:13:32.75,0:13:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:34.13,0:13:37.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya, beberapa menit lalu\Ndi bagian pertama.
Dialogue: 0,0:13:38.67,0:13:42.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, saya tidak mengerti apa maksudnya.
Dialogue: 0,0:13:42.01,0:13:42.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:13:43.18,0:13:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, benar juga.
Dialogue: 0,0:13:45.72,0:13:46.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ya.
Dialogue: 0,0:13:46.85,0:13:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:13:48.06,0:13:50.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anu, silakan masuk.
Dialogue: 0,0:13:56.36,0:13:58.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:13:59.23,0:14:01.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:14:03.66,0:14:05.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu melompat sejauh itu!
Dialogue: 0,0:14:05.66,0:14:07.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Adu, duh...
Dialogue: 0,0:14:07.20,0:14:09.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Kak Renta...
Dialogue: 0,0:14:16.25,0:14:17.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?!
Dialogue: 0,0:14:17.67,0:14:21.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, kalau lihat\Nsesuatu yang berantakan,
Dialogue: 0,0:14:21.42,0:14:23.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku jadi pengin merapikannya.
Dialogue: 0,0:14:23.30,0:14:25.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, ujung kemejaku keluar karena tadi.
Dialogue: 0,0:14:26.76,0:14:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa wajahmu segarang itu?!
Dialogue: 0,0:14:29.89,0:14:31.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai menggeram?!
Dialogue: 0,0:14:33.02,0:14:34.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa kurapikan sendiri!
Dialogue: 0,0:14:36.15,0:14:38.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Be-Begini sudah tidak apa-apa, 'kan?
Dialogue: 0,0:14:39.15,0:14:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa lagi?!
Dialogue: 0,0:14:40.94,0:14:42.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, kusut.
Dialogue: 0,0:14:44.53,0:14:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, sudah tidak sopan begini!
Dialogue: 0,0:14:47.28,0:14:50.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, kok.\NTerima kasih, ya.
Dialogue: 0,0:14:53.83,0:14:55.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah membuatkanku teh.
Dialogue: 0,0:14:55.87,0:14:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, lagi bikin PR? Rajin sekali.
Dialogue: 0,0:14:57.83,0:14:58.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak juga.
Dialogue: 0,0:14:58.75,0:15:02.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ketua kelas, jadi harus\Nmemberi contoh ke teman sekelas.
Dialogue: 0,0:15:02.80,0:15:04.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia ternyata ketua kelas.
Dialogue: 0,0:15:04.38,0:15:07.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang terasa seperti itu,\Ndia rajin dan disiplin.
Dialogue: 0,0:15:10.93,0:15:12.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku!
Dialogue: 0,0:15:14.68,0:15:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Handuknya kutaruh di sini, ya.
Dialogue: 0,0:15:17.77,0:15:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, iya!
Dialogue: 0,0:15:22.44,0:15:27.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar, seharusnya aku datang merawat dia,\Nkenapa rasanya malah aku yang dirawat?
Dialogue: 0,0:15:27.03,0:15:30.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, ya.\NSudah merepotkanmu begini.
Dialogue: 0,0:15:30.37,0:15:32.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kamu baru SMP kelas satu.
Dialogue: 0,0:15:32.87,0:15:33.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:15:33.79,0:15:37.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti yang Kakak tahu,\Nkami cuma tinggal berdua.
Dialogue: 0,0:15:37.79,0:15:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:39.04,0:15:41.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman Hiro itu ayah tunggal.
Dialogue: 0,0:15:41.80,0:15:45.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena aku putri satu-satunya,\Njadi harus bisa diharapkan.
Dialogue: 0,0:15:48.93,0:15:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, dingin!
Dialogue: 0,0:15:52.26,0:15:54.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?!
Dialogue: 0,0:15:54.47,0:15:56.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Airnya tiba-tiba!
Dialogue: 0,0:15:56.94,0:15:59.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air panasnya tidak mau keluar!
Dialogue: 0,0:15:59.69,0:16:01.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak mau berhenti juga!\N- Biar kuperiksa alat pemanasnya!
Dialogue: 0,0:16:05.82,0:16:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-A-Ada apa?!
Dialogue: 0,0:16:09.07,0:16:11.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenop pintunya tidak mau berputar!
Dialogue: 0,0:16:11.07,0:16:14.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kakak pakai baju dulu saja\Nuntuk menghangatkan diri.
Dialogue: 0,0:16:16.08,0:16:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, kalau begini terus bisa masuk angin!
Dialogue: 0,0:16:19.75,0:16:24.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku harus melayani tamu\Ndengan baik.
Dialogue: 0,0:16:24.38,0:16:27.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harusnya aku lebih baik lagi!
Dialogue: 0,0:16:27.72,0:16:30.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus melayani dengan baik!\NMelayani dengan baik!
Dialogue: 0,0:16:30.93,0:16:32.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus melayani!
Dialogue: 0,0:16:32.26,0:16:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf!
Dialogue: 0,0:16:35.85,0:16:39.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Chiyo, mencoba menghangatkanku?
Dialogue: 0,0:16:39.85,0:16:43.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal badannya sekecil ini,\Nhanya sepersekian dari diriku.
Dialogue: 0,0:16:43.90,0:16:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi dia begitu sepenuh hati.
Dialogue: 0,0:16:46.57,0:16:49.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, aku terus merepotkanmu begini.
Dialogue: 0,0:16:50.24,0:16:52.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, lagi-lagi aku...
Dialogue: 0,0:16:53.32,0:16:56.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyo hebat sekali, bisa begitu disiplin.
Dialogue: 0,0:16:56.12,0:16:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyo benar-benar hebat!
Dialogue: 0,0:16:58.20,0:17:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iin itu benar-benar disiplin, ya...
Dialogue: 0,0:17:00.92,0:17:03.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-kata yang selalu dilontarkan padaku...
Dialogue: 0,0:17:03.96,0:17:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak perlu memaksakan\Ndirimu untuk sedisiplin ini.
Dialogue: 0,0:17:09.72,0:17:13.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini masih gadis kecil kelas satu SMP.
Dialogue: 0,0:17:13.93,0:17:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:17:15.47,0:17:17.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf kalau aku bilang begini.
Dialogue: 0,0:17:17.77,0:17:21.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena kamu ketua kelas.
Dialogue: 0,0:17:21.09,0:17:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kamu putri tunggal rumah ini.
Dialogue: 0,0:17:23.69,0:17:27.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu jadi kelihatan seperti memaksakan diri\Nlebih besar dari ukuran tubuhmu.
Dialogue: 0,0:17:27.73,0:17:31.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal badanmu masih sekecil ini.
Dialogue: 0,0:17:32.41,0:17:34.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya.
Dialogue: 0,0:17:34.37,0:17:38.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya terganggu dengan\Npenyimpangan kecil dan merapikannya.
Dialogue: 0,0:17:38.87,0:17:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua orang lalu bilang\Nkalau aku disiplin dan rajin.
Dialogue: 0,0:17:42.87,0:17:46.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu aku senang karena dipuji.\N- Betulan luar biasa!
Dialogue: 0,0:17:47.42,0:17:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejak kapan, ya?
Dialogue: 0,0:17:49.30,0:17:53.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semakin dipuji, aku jadi merasa\Nharus lebih disiplin lagi.
Dialogue: 0,0:17:53.97,0:17:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:17:55.39,0:17:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal Kak Rentaro baru kutemui hari ini,\Ntapi kenapa bisa.
Dialogue: 0,0:17:59.52,0:18:02.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal baru melihatku\Nselama beberapa puluh menit.
Dialogue: 0,0:18:06.15,0:18:08.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin ini tidak masalah?!\NYakin, nih?!
Dialogue: 0,0:18:08.69,0:18:10.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja masalah.
Dialogue: 0,0:18:10.49,0:18:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tidak normal.
Dialogue: 0,0:18:11.78,0:18:13.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak diperbolehkan!
Dialogue: 0,0:18:13.45,0:18:16.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kami ini adalah sepupu.
Dialogue: 0,0:18:20.91,0:18:24.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}E-Eh, kenapa ini?! Aduh!
Dialogue: 0,0:18:24.46,0:18:25.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Chiyo?
Dialogue: 0,0:18:30.96,0:18:34.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harus bagaimana ini?!
Dialogue: 0,0:18:34.09,0:18:35.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di-Dik Chiyo?!
Dialogue: 0,0:18:36.97,0:18:39.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Rentaro, aku mencintaimu!
Dialogue: 0,0:18:40.60,0:18:42.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, Dik Chiyo.
Dialogue: 0,0:18:42.77,0:18:45.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kudengarkan,\Njadi kamu tenang dulu, ya.
Dialogue: 0,0:18:45.85,0:18:47.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi bagaimana rasanya?
Dialogue: 0,0:18:47.31,0:18:50.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa hoki mesra-mesraan beruntun?
Dialogue: 0,0:18:50.11,0:18:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sesuai rencanaku!
Dialogue: 0,0:18:52.69,0:18:53.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman Hiro?!
Dialogue: 0,0:18:54.49,0:18:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan?!
Dialogue: 0,0:18:57.74,0:18:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peluru plastik di pintu masuk.
Dialogue: 0,0:19:00.49,0:19:02.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gelas yang tumpah.
Dialogue: 0,0:19:02.75,0:19:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemanas air mati.
Dialogue: 0,0:19:05.25,0:19:07.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu tidak mau terbuka.
Dialogue: 0,0:19:07.50,0:19:09.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kacamata yang lepas.
Dialogue: 0,0:19:09.71,0:19:11.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang melakukan itu semua!
Dialogue: 0,0:19:11.84,0:19:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kenapa melakukan itu?
Dialogue: 0,0:19:13.97,0:19:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyoku yang paling berharga di dunia!
Dialogue: 0,0:19:16.13,0:19:21.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampai mati pun tidak akan kuserahkan kecuali\Nke Rentaro si anak paling baik di dunia!
Dialogue: 0,0:19:21.39,0:19:25.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah, aku tidak ingin\Nmempertemukan kalian sebelum dewasa.
Dialogue: 0,0:19:25.52,0:19:30.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau dia nanti jadi seperti adikmu\Nterus tidak bisa jadi kandidat asmara.
Dialogue: 0,0:19:30.40,0:19:32.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:32.69,0:19:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah kenapa, belakangan ini ada\Nbanyak gadis yang mengelilingimu!
Dialogue: 0,0:19:37.07,0:19:38.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman jadi panik banget!
Dialogue: 0,0:19:38.62,0:19:43.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, kalau ada sebanyak itu,\Nberarti belum ada yang kau pilih jadi pacar!
Dialogue: 0,0:19:43.91,0:19:47.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana?!\NTebakanku benar, 'kan?!
Dialogue: 0,0:19:47.25,0:19:49.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, semuanya pacarku.
Dialogue: 0,0:19:49.17,0:19:50.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ha, apa?!
Dialogue: 0,0:19:50.13,0:19:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak begitu paham perkataanmu.
Dialogue: 0,0:19:53.00,0:19:57.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dibalik, berarti ketambahan\Nsatu kerabat itu tidak apa-apa, 'kan?!
Dialogue: 0,0:19:57.13,0:20:00.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak begitu paham\Napa yang Paman katakan.
Dialogue: 0,0:20:00.14,0:20:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayolah, kamu mau, ya!
Dialogue: 0,0:20:02.01,0:20:04.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mau pacaran sama Chiyo, ya!
Dialogue: 0,0:20:04.85,0:20:06.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata memang bawaan keluarga?!
Dialogue: 0,0:20:09.15,0:20:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:20:11.06,0:20:12.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku ini?!
Dialogue: 0,0:20:12.98,0:20:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah menyatakan cinta ke kakak sepupuku!
Dialogue: 0,0:20:15.49,0:20:20.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, anu, begini, tadi itu...
Dialogue: 0,0:20:20.11,0:20:21.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman Hiro.
Dialogue: 0,0:20:22.62,0:20:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku.
Dialogue: 0,0:20:24.08,0:20:29.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti itu, aku tidak bisa\Nmenerima pernyataan cinta Dik Chiyo.
Dialogue: 0,0:20:33.63,0:20:35.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau habis itu?
Dialogue: 0,0:20:35.38,0:20:38.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, bukan itu maksudku.
Dialogue: 0,0:20:39.22,0:20:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau itu cinta yang digiring orang sekitar\Ntanpa memikirkan perasaan Dik Chiyo.
Dialogue: 0,0:20:45.52,0:20:48.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta tidak akan terpengaruh\Norang lain dan hubungan.
Dialogue: 0,0:20:48.85,0:20:53.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serta selalu bebas mengikuti\Nperasaan pemiliknya itulah
Dialogue: 0,0:20:53.65,0:20:56.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}membuatnya begitu asli dan mulia.
Dialogue: 0,0:20:58.44,0:21:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjadikannya sesuatu yang berharga.
Dialogue: 0,0:21:00.82,0:21:02.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerewet, bodoh!
Dialogue: 0,0:21:02.37,0:21:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak dipengaruhi hubungan\Ndan selalu bebas.
Dialogue: 0,0:21:06.41,0:21:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sejalan dengan perasaan pemiliknya.
Dialogue: 0,0:21:11.00,0:21:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ini mencintai Kak Rentaro!
Dialogue: 0,0:21:15.04,0:21:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Debaran ini bukan karena ulah Ayah!
Dialogue: 0,0:21:19.30,0:21:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena Kak Rentaro...
Dialogue: 0,0:21:21.26,0:21:24.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengatakan hal yang\Nselama ini ingin kudengar.
Dialogue: 0,0:21:24.47,0:21:26.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi karena Kak Rentaro sendiri!
Dialogue: 0,0:21:26.81,0:21:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu mengatakan ini padamu\Nyang adalah sepupuku itu begitu bodoh.
Dialogue: 0,0:21:30.81,0:21:35.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan dianggap anak tidak normal.
Dialogue: 0,0:21:36.07,0:21:37.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi!
Dialogue: 0,0:21:38.32,0:21:39.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu!
Dialogue: 0,0:21:40.32,0:21:43.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintai Kak Rentaro!
Dialogue: 0,0:21:43.78,0:21:44.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mohon!
Dialogue: 0,0:21:45.45,0:21:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kamu menjadi pacarku?
Dialogue: 0,0:21:49.54,0:21:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa aku tadi bicara sok hebat.
Dialogue: 0,0:21:53.37,0:21:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah justru aku yang terbelenggu\Noleh hubungan tidak penting?!
Dialogue: 0,0:21:59.63,0:22:02.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepupu atau bukan tidak ada hubungannya!
Dialogue: 0,0:22:02.05,0:22:05.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mencintaimu!\NItu yang terpenting!
Dialogue: 0,0:22:05.30,0:22:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan aku berpacaran denganmu!
Dialogue: 0,0:22:07.85,0:22:09.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hore, akhirnya berhasil!
Dialogue: 0,0:22:09.72,0:22:12.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Home run pembalik keadaan!
Dialogue: 0,0:22:12.56,0:22:15.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yay, waktunya masak nasi merah!
Dialogue: 0,0:23:45.99,0:23:47.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat cucu, nih!
Dialogue: 0,0:23:47.57,0:23:49.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masih terlalu cepat!
