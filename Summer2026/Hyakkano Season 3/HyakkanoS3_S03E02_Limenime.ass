Dialogue: 0,0:02:07.52,0:02:08.91,sign,,0000,0000,0000,,"BPO: BADAN PENGAWAS ETIKA DAN"
Dialogue: 0,0:02:15.28,0:02:17.91,sign,,0000,0000,0000,,"KOMITE PRODUKSI 100 PACAR"
Dialogue: 0,0:03:09.00,0:03:10.59,sign,,0000,0000,0000,,KETAT
Dialogue: 0,0:03:40.38,0:03:40.60,sign,,0000,0000,0000,,KLIK!
Dialogue: 0,0:04:51.02,0:04:51.33,sign,,0000,0000,0000,,KRUYUK, KRUYUK
Dialogue: 0,0:05:28.19,0:05:30.56,sign,,0000,0000,0000,,MALAIKAT
Dialogue: 0,0:12:45.50,0:12:49.16,sign,,0000,0000,0000,,"EKSKUL KORAN"
Dialogue: 0,0:13:45.94,0:13:49.05,sign,,0000,0000,0000,,GADIS CANTIK DENGAN PONI\NYANG PENUH TEKA-TEKI!
Dialogue: 0,0:14:11.34,0:14:13.84,sign,,0000,0000,0000,,SELANJUTNYA AKAN KAMI UNGKAP WAJAH ASLINYA
Dialogue: 0,0:14:24.96,0:14:26.59,sign,,0000,0000,0000,,RUANG KEPALA YAYASAN
Dialogue: 0,0:15:15.70,0:15:16.93,sign,,0000,0000,0000,,AKU KALAH
Dialogue: 0,0:20:26.74,0:20:29.51,sign,,0000,0000,0000,,EKSKUL KORAN
Dialogue: 0,0:20:29.51,0:20:30.05,sign,,0000,0000,0000,,TENTU SAJA!
Dialogue: 0,0:21:38.45,0:21:42.46,sign,,0000,0000,0000,,"CANTIK!"
Dialogue: 0,0:00:23.88,0:00:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}100 Pacar yang Sungguh Sangat Amat\NBenar-benar Mencintaimu Musim Ketiga
Dialogue: 0,0:01:40.50,0:01:42.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oleh karena itu...
Dialogue: 0,0:01:43.01,0:01:48.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maukah kalian menerima\NIin Chiyo sebagai pacar baruku?
Dialogue: 0,0:01:48.71,0:01:50.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sa-Salam kenal!
Dialogue: 0,0:01:50.90,0:01:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya siswi kelas satu\NSMP Afiliasi Universitas Ohananomitsu
Dialogue: 0,0:01:54.13,0:01:56.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan adik sepupu Kak Rentaro, Iin Chiyo.
Dialogue: 0,0:01:56.68,0:01:58.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerabat sekaligus gadis kecil?!
Dialogue: 0,0:01:59.52,0:02:00.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak!
Dialogue: 0,0:02:00.55,0:02:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yakin tidak bakal bawa banyak masalah?!
Dialogue: 0,0:02:02.98,0:02:05.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena sudah tayang,\Njadi kurasa tidak masalah.
Dialogue: 0,0:02:05.42,0:02:07.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menganggap remeh BPO, ya?
Dialogue: 0,0:02:07.52,0:02:08.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}PENYIARAN JEPANG Kurasa tidak, sih...
Dialogue: 0,0:02:09.40,0:02:11.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka sudah siap menghadapinya.
Dialogue: 0,0:02:12.40,0:02:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Gawat!\N- Mustahil! Mustahil!
Dialogue: 0,0:02:15.28,0:02:17.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelihatannya ada yang belum siap, tuh.
Dialogue: 0,0:02:18.33,0:02:22.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya akan berusaha agar\Ntidak merepotkan kalian.
Dialogue: 0,0:02:22.32,0:02:24.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, mohon bantuan kakak semua!
Dialogue: 0,0:02:24.42,0:02:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senang bertemu denganmu juga!
Dialogue: 0,0:02:33.75,0:02:35.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?!
Dialogue: 0,0:02:35.86,0:02:39.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Dik Chiyo lihat penyimpangan,\Ndia jadi ingin meluruskannya.
Dialogue: 0,0:02:39.65,0:02:42.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, akan kuperbaiki!\NBiar kuperbaiki!
Dialogue: 0,0:02:44.39,0:02:47.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini, aku tidak bisa\Ntampil seksi menggoda Rentaro...
Dialogue: 0,0:02:49.53,0:02:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau lari, ujung rokku melilit kaki\Ndan membuat tersandung!
Dialogue: 0,0:02:53.23,0:02:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakari!
Dialogue: 0,0:02:54.67,0:02:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagian, kenapa kau lari?
Dialogue: 0,0:02:58.82,0:03:00.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Ada apa?
Dialogue: 0,0:03:00.71,0:03:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau meluruskanku juga?
Dialogue: 0,0:03:02.67,0:03:05.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak masalah kalau cuma rok.
Dialogue: 0,0:03:05.09,0:03:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pita! Lalu kaus kaki longgar!
Dialogue: 0,0:03:07.96,0:03:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hah?!
Dialogue: 0,0:03:12.70,0:03:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi seperti kucing yang dipaksa pakai baju.
Dialogue: 0,0:03:15.59,0:03:17.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu mata palsu!
Dialogue: 0,0:03:17.82,0:03:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bulu mata palsu?!
Dialogue: 0,0:03:19.71,0:03:21.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}To-Tolong hentikan!
Dialogue: 0,0:03:21.73,0:03:24.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata itu bagian terpenting dari riasan!
Dialogue: 0,0:03:24.19,0:03:25.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, bulu mata palsu indah...!
Dialogue: 0,0:03:25.84,0:03:27.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:03:27.84,0:03:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak terlalu ada bedanya, tuh.
Dialogue: 0,0:03:30.14,0:03:32.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lihat aku!
Dialogue: 0,0:03:32.17,0:03:33.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Larinya cepat amat!
Dialogue: 0,0:03:33.08,0:03:35.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petugas loper koran memang hebat.
Dialogue: 0,0:03:35.49,0:03:37.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponimu terlalu panjang!
Dialogue: 0,0:03:38.83,0:03:40.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakai jepit rambut!
Dialogue: 0,0:03:40.61,0:03:42.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tidak!\N- Kak Meme!
Dialogue: 0,0:03:43.42,0:03:46.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mataku... Mataku!
Dialogue: 0,0:03:46.12,0:03:47.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kata-kata terakhir Muska!
Dialogue: 0,0:03:47.38,0:03:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Meme, ini, pakailah kacamata hitam\Nyang kupinjam dari Kak Mimimi."
Dialogue: 0,0:03:54.86,0:03:57.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia malah jadi kayak preman."
Dialogue: 0,0:03:57.59,0:03:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut kusut!
Dialogue: 0,0:04:02.37,0:04:05.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Ra-Rambutku ini memang keriting."
Dialogue: 0,0:04:14.68,0:04:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan mainan pukul tikus tanah, lho.
Dialogue: 0,0:04:17.11,0:04:18.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahasamu tidak sopan!
Dialogue: 0,0:04:19.04,0:04:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia itu kakak kelas!
Dialogue: 0,0:04:20.51,0:04:21.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tua darimu!
Dialogue: 0,0:04:21.64,0:04:24.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya, tahu, berisik sekali, ah.
Dialogue: 0,0:04:24.27,0:04:27.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu bukan permainan pukul tikus tanah, lho.
Dialogue: 0,0:04:27.01,0:04:28.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu pakai "lho"!
Dialogue: 0,0:04:28.88,0:04:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, tidak perlu sedetail itu, 'kan?
Dialogue: 0,0:04:31.21,0:04:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak perlu pakai "lho"!
Dialogue: 0,0:04:36.94,0:04:38.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berisik, ah!
Dialogue: 0,0:04:38.22,0:04:39.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Lha", "Lho" terus dari tadi!
Dialogue: 0,0:04:42.83,0:04:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lha, lho, lha, lah?
Dialogue: 0,0:04:49.45,0:04:51.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lah, sosis?
Dialogue: 0,0:04:51.34,0:04:53.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cara hidup yang sungguh tidak efisien.
Dialogue: 0,0:04:53.90,0:04:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untung saja masih ada sisa\Ndari bekal makan siangku.
Dialogue: 0,0:04:57.15,0:04:58.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosis!
Dialogue: 0,0:04:58.72,0:05:01.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekalku hari ini sepuluh persen\Nlebih banyak dari biasanya.
Dialogue: 0,0:05:01.91,0:05:04.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemungkinan besar lauk ayahku\Ntercampur masuk ke sini.
Dialogue: 0,0:05:04.55,0:05:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Nano...
Dialogue: 0,0:05:06.32,0:05:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makan makananmu sendiri!
Dialogue: 0,0:05:09.97,0:05:11.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah kenyang.
Dialogue: 0,0:05:11.46,0:05:13.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asupan berlebih itu tidak berguna.
Dialogue: 0,0:05:13.36,0:05:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus bersyukur pada nyawa makanan!
Dialogue: 0,0:05:15.18,0:05:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak akan sampai\Nke makhluk yang sudah mati.
Dialogue: 0,0:05:18.00,0:05:19.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih bisa ke surga!
Dialogue: 0,0:05:19.19,0:05:22.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsep tidak ilmiah seperti itu\Ntidaklah nyata.
Dialogue: 0,0:05:24.80,0:05:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini juga...
Dialogue: 0,0:05:25.99,0:05:28.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ikut malaikat maut juga, Bang!
Dialogue: 0,0:05:32.18,0:05:34.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ini benar-benar kurang realistis...
Dialogue: 0,0:05:34.92,0:05:37.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nano bisa kalah debat?!
Dialogue: 0,0:05:37.19,0:05:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, babi yang sudah mati.
Dialogue: 0,0:05:39.40,0:05:41.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, aku mau muntah karena kenyang.
Dialogue: 0,0:05:41.69,0:05:43.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:05:43.03,0:05:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hahari saja yang boleh muntah!
Dialogue: 0,0:05:45.44,0:05:46.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?!
Dialogue: 0,0:05:46.46,0:05:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat pembuat muntah jadi pelangi!
Dialogue: 0,0:05:48.78,0:05:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukannya itu tugas sinematografer\Ndari studio Bibury?
Dialogue: 0,0:05:52.47,0:05:54.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepemilikan obat berbahaya!
Dialogue: 0,0:05:54.84,0:05:55.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:05:55.95,0:05:57.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harus disita!
Dialogue: 0,0:05:57.67,0:05:58.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sini semuanya!
Dialogue: 0,0:06:02.29,0:06:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat!
Dialogue: 0,0:06:03.40,0:06:05.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembalikan obat Kusuri!
Dialogue: 0,0:06:06.47,0:06:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Obat!
Dialogue: 0,0:06:07.53,0:06:09.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku butuh obat!
Dialogue: 0,0:06:09.28,0:06:11.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia jadi sakau!
Dialogue: 0,0:06:11.11,0:06:13.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Obat! Aku butuh obat!\N- Biar kumintakan obat ke Tuan Matsumoto!
Dialogue: 0,0:06:13.97,0:06:15.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apotek Matsumoto Kiyoshi?
Dialogue: 0,0:06:15.15,0:06:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Dik Chiyo?\N- Nona Chiyo?
Dialogue: 0,0:06:15.82,0:06:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin pembantu sempurna\Nseperti Kak Mei bisa menyimpang?!
Dialogue: 0,0:06:19.73,0:06:21.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengemudi dengan mata tertutup!
Dialogue: 0,0:06:23.19,0:06:24.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tindakan yang sangat berbahaya!
Dialogue: 0,0:06:28.02,0:06:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa kubuka!\NPadahal tadi sudah terbuka!
Dialogue: 0,0:06:31.04,0:06:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mei!
Dialogue: 0,0:06:32.32,0:06:33.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau seperti ini...
Dialogue: 0,0:06:33.44,0:06:36.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu Hahari, ayo main batu, gunting,\Npukul pantat denganku!!
Dialogue: 0,0:06:36.78,0:06:37.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantat?!
Dialogue: 0,0:06:37.68,0:06:41.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau melihat Bu Hahari kesakitan,\Nmata Kak Mei pasti akan terbuka!
Dialogue: 0,0:06:41.40,0:06:42.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paham!
Dialogue: 0,0:06:42.67,0:06:44.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Batu, gunting, kertas!
Dialogue: 0,0:06:44.38,0:06:46.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang kalah, sial!
Dialogue: 0,0:06:46.39,0:06:47.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kupukul, ya.
Dialogue: 0,0:06:47.96,0:06:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:06:55.90,0:06:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima ini!
Dialogue: 0,0:06:56.88,0:06:58.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:06:59.75,0:07:03.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh pantat yang montok!
Dialogue: 0,0:07:03.68,0:07:05.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kulakukan lagi?
Dialogue: 0,0:07:05.34,0:07:07.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:07:10.16,0:07:12.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♫ Di ujung perasaan cinta
Dialogue: 0,0:07:12.53,0:07:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus!\NBagus sekali, Dik Iku!
Dialogue: 0,0:07:15.04,0:07:17.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, sakit!
Dialogue: 0,0:07:17.01,0:07:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Bisa full combo!
Dialogue: 0,0:07:21.09,0:07:23.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keberadaan kalian menyimpang!
Dialogue: 0,0:07:23.81,0:07:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Keberadaan kami yang menyimpang?
Dialogue: 0,0:07:26.85,0:07:27.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketatnya!
Dialogue: 0,0:07:29.19,0:07:32.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu belajar ini dari mana?
Dialogue: 0,0:07:32.09,0:07:33.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Chiyo!
Dialogue: 0,0:07:33.35,0:07:37.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini masih pertemuan pertama kalian,\Njadi tidak perlu seketat itu.
Dialogue: 0,0:07:37.02,0:07:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, aku juga?
Dialogue: 0,0:07:38.45,0:07:42.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai pacar mereka,\Naku ingin selalu jadi lurus.
Dialogue: 0,0:07:42.23,0:07:45.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bilang saja kalau ada yang menyimpang,\Npasti akan kuluruskan!
Dialogue: 0,0:07:45.44,0:07:46.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpacaran dengan 12 orang!
Dialogue: 0,0:07:50.53,0:07:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terlalu cinta ke mereka semua!\NMustahil buat pilih satu saja!
Dialogue: 0,0:07:54.69,0:07:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana aku harus meluruskannya?!
Dialogue: 0,0:07:57.71,0:08:00.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua penyimpangan sudah diluruskan!
Dialogue: 0,0:08:03.46,0:08:05.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan lihat aku!
Dialogue: 0,0:08:06.54,0:08:07.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awas!
Dialogue: 0,0:08:07.43,0:08:10.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kenapa rok panjang sesulit ini buat lari?!\N- Obat!
Dialogue: 0,0:08:10.51,0:08:14.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang hentikan, hei!
Dialogue: 0,0:08:15.23,0:08:17.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:08:20.56,0:08:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seseorang harus membantah ini semua...
Dialogue: 0,0:08:22.72,0:08:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kubilang, berhenti kalian semua!
Dialogue: 0,0:08:27.80,0:08:30.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosis! Sosis!
Dialogue: 0,0:08:30.85,0:08:34.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memangnya ini pemandangan\Nyang ingin kulihat?
Dialogue: 0,0:08:38.21,0:08:40.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku yang membuat mereka menyimpang?
Dialogue: 0,0:08:40.82,0:08:43.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan lihat aku!
Dialogue: 0,0:08:47.06,0:08:49.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak...\NIni semua salahku...
Dialogue: 0,0:08:49.51,0:08:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Malah...
Dialogue: 0,0:08:57.34,0:09:00.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah jadi pemandangan neraka begini!
Dialogue: 0,0:09:02.31,0:09:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Isinya orang aneh semua!
Dialogue: 0,0:09:05.10,0:09:06.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu baik-baik saja, Dik Chiyo?
Dialogue: 0,0:09:06.93,0:09:09.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini, pakai kacamatamu.
Dialogue: 0,0:09:11.33,0:09:13.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya minta maaf...
Dialogue: 0,0:09:13.12,0:09:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:09:13.79,0:09:15.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu ini kenapa, sih?
Dialogue: 0,0:09:15.67,0:09:16.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tidak apa-apa?
Dialogue: 0,0:09:16.92,0:09:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ada yang bisa saya bantu?
Dialogue: 0,0:09:18.40,0:09:20.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa perutmu sakit?
Dialogue: 0,0:09:20.14,0:09:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:09:21.19,0:09:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Chiyo cuma bakal jadi sedikit panik\Nkalau kacamatanya lepas.
Dialogue: 0,0:09:26.55,0:09:30.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, ternyata punya sisi\Nkekanak-kanakan juga, ya.
Dialogue: 0,0:09:30.26,0:09:32.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Tetapi, untuk ukuran yang paling muda,"
Dialogue: 0,0:09:32.04,0:09:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal mereka semenyimpang itu,\Ntapi langsung khawatir saat aku menangis.
Dialogue: 0,0:09:37.57,0:09:40.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti sekarang...
Dialogue: 0,0:09:40.61,0:09:43.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka hanya terlihat menyimpang,\Ntapi di dalamnya...
Dialogue: 0,0:09:45.36,0:09:46.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya minta maaf!
Dialogue: 0,0:09:46.58,0:09:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata sejak awal kakak-kakak semua\Ntidaklah menyimpang!
Dialogue: 0,0:09:50.82,0:09:53.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal saya tidak tahu apa pun soal kalian.
Dialogue: 0,0:09:53.55,0:09:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Malah bilang menyimpang ini-itu\Ntanpa coba cari tahu dulu.
Dialogue: 0,0:09:57.07,0:10:01.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal justru saya\Nyang sebenarnya menyimpang!
Dialogue: 0,0:10:01.34,0:10:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iin...
Dialogue: 0,0:10:06.08,0:10:08.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chiyo, lihat ini baik-baik.
Dialogue: 0,0:10:08.54,0:10:09.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hakari?
Dialogue: 0,0:10:12.37,0:10:13.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:10:13.73,0:10:15.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa sekarang malah ciuman?!
Dialogue: 0,0:10:15.47,0:10:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu penyimpa...
Dialogue: 0,0:10:18.68,0:10:21.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini mungkin terlihat menyimpang bagimu.
Dialogue: 0,0:10:21.83,0:10:27.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, inilah gaya hidup Keluarga Rentaro\Ndan kebahagiaan kami.
Dialogue: 0,0:10:27.36,0:10:29.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah begitu, Karane?
Dialogue: 0,0:10:30.52,0:10:34.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu...\NSudah jelas, dong!
Dialogue: 0,0:10:34.31,0:10:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rentaro, ayo!\NKita ciuman!
Dialogue: 0,0:10:46.71,0:10:51.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal itu seharusnya menyimpang,\Ntapi kenapa kelihatan begitu bahagia?
Dialogue: 0,0:10:51.10,0:10:53.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir, tadi juga begitu.
Dialogue: 0,0:10:53.73,0:10:57.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah diri mereka yang sebenarnya.
Dialogue: 0,0:10:57.34,0:10:59.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cuma aku yang tidak tahu di sini.
Dialogue: 0,0:11:00.75,0:11:02.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang bentuk cinta yang benar.
Dialogue: 0,0:11:04.28,0:11:06.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kak Rentaro.
Dialogue: 0,0:11:07.14,0:11:10.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf, saya juga...
Dialogue: 0,0:11:11.37,0:11:14.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saya juga mau ciuman!
Dialogue: 0,0:11:14.29,0:11:16.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Seperti semuanya.\N- Aku ingin tahu.
Dialogue: 0,0:11:16.24,0:11:18.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang bentuk cinta yang benar.
Dialogue: 0,0:11:18.29,0:11:19.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dik Chiyo.
Dialogue: 0,0:11:30.50,0:11:32.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak menggeram?
Dialogue: 0,0:11:32.75,0:11:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ciuman, dan mereka semua,\Nternyata memang tidak menyimpang.
Dialogue: 0,0:11:40.30,0:11:40.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah...
Dialogue: 0,0:11:40.89,0:11:41.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejujurnya...
Dialogue: 0,0:11:41.61,0:11:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami rasanya...
Dialogue: 0,0:11:42.22,0:11:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang menyimpang...
Dialogue: 0,0:11:44.11,0:11:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia kelihatannya bisa terima\Nwaktu kupaksa saat momennya pas.
Dialogue: 0,0:11:48.08,0:11:49.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sudahlah!
Dialogue: 0,0:11:50.50,0:11:53.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Selamat datang di keluarga Rentaro!
Dialogue: 0,0:11:54.47,0:11:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya!
Dialogue: 0,0:11:55.61,0:11:57.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini tidak menyimpang,
Dialogue: 0,0:11:57.15,0:12:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya jadi tidak ada\Nyang menyimpang di dunia ini.
Dialogue: 0,0:12:00.92,0:12:02.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yah, sudahlah!
Dialogue: 0,0:12:03.88,0:12:06.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mimimi juga mau ke atap?
Dialogue: 0,0:12:06.57,0:12:08.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Meme juga, ya.
Dialogue: 0,0:12:09.84,0:12:12.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, dia cantik sekali!
Dialogue: 0,0:12:12.46,0:12:15.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah itu Kak Utsukushisugi\Ndari tahun kedua?!
Dialogue: 0,0:12:15.17,0:12:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, dia yang dibicarakan itu?!
Dialogue: 0,0:12:16.97,0:12:18.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!
Dialogue: 0,0:12:19.72,0:12:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mimimi ini hebat sekali.
Dialogue: 0,0:12:23.00,0:12:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski jadi pusat perhatian,\Ntetap bisa percaya diri.
Dialogue: 0,0:12:26.23,0:12:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hidup dengan kepercayaan diriku.
Dialogue: 0,0:12:28.44,0:12:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cantik itu wajar bila dilihat.
Dialogue: 0,0:12:30.95,0:12:32.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Justru aku marah kalau tidak dilihat.
Dialogue: 0,0:12:32.95,0:12:34.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Percaya dirinya seperti penipu tabrakan?!
Dialogue: 0,0:12:35.24,0:12:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, Kakak benar-benar hebat.
Dialogue: 0,0:12:37.78,0:12:40.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak punya\Nkepercayaan diri seperti itu.
Dialogue: 0,0:12:40.96,0:12:41.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meme...
Dialogue: 0,0:12:43.71,0:12:45.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, halo!
Dialogue: 0,0:12:45.50,0:12:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketua ekskul koran, Kijineta Toruru!
Dialogue: 0,0:12:49.77,0:12:50.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tororo?
Dialogue: 0,0:12:50.71,0:12:51.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toruru!
Dialogue: 0,0:12:52.24,0:12:53.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa dia kenalanmu?
Dialogue: 0,0:12:53.79,0:12:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Se-Sepertinya ingin menulis artikel\Nsoal diriku di koran sekolah,
Dialogue: 0,0:12:58.22,0:12:59.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}padahal sudah kutolak.
Dialogue: 0,0:12:59.73,0:13:00.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar!
Dialogue: 0,0:13:00.63,0:13:04.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siswi cantik nan misterius yang tersembunyi\Ndi balik teka-teki rambut poni!
Dialogue: 0,0:13:04.64,0:13:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jiwa wartawanku langsung terpicu!
Dialogue: 0,0:13:07.50,0:13:11.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku sudah tahu soal nama, kelas,\Nsampai keahliannya merajut boneka,
Dialogue: 0,0:13:11.73,0:13:14.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tapi selalu saja menghilang\Ndan tidak bisa kupotret.
Dialogue: 0,0:13:16.69,0:13:18.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku terlalu malu...
Dialogue: 0,0:13:18.65,0:13:22.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itulah aku sudah menjalani\Nlatihan yang sangat keras.
Dialogue: 0,0:13:22.35,0:13:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Demi bisa memotretmu hari ini!
Dialogue: 0,0:13:26.59,0:13:28.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsentrasi penuh.
Dialogue: 0,0:13:32.46,0:13:33.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernapasan Wartawan!
Dialogue: 0,0:13:33.68,0:13:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan yang kamu maksud\Nbukannya cuma baca Kimetsu?
Dialogue: 0,0:13:36.48,0:13:39.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Torurururururu!
Dialogue: 0,0:13:41.30,0:13:43.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keesokan harinya setelah ini dan itu.
Dialogue: 0,0:13:49.52,0:13:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, lama.
Dialogue: 0,0:13:52.36,0:13:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu habis apa, sih, Rentaro?
Dialogue: 0,0:13:54.45,0:13:56.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meme dalam masalah besar, tahu!
Dialogue: 0,0:13:56.73,0:13:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, maaf.
Dialogue: 0,0:13:58.12,0:13:59.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Termasuk yang sudah dibagikan,
Dialogue: 0,0:13:59.89,0:14:03.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengumpulkan semua koran sekolah\Nyang dicetak sebanyak 299 kopi.
Dialogue: 0,0:14:03.44,0:14:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diberantas habis rupanya?!
Dialogue: 0,0:14:04.71,0:14:07.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artikel yang ditulis tanpa persetujuan\Nsama dengan kekerasan.
Dialogue: 0,0:14:07.75,0:14:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mata harus dibalas mata.
Dialogue: 0,0:14:08.96,0:14:11.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, tolong lihat bagian ini!
Dialogue: 0,0:14:14.10,0:14:16.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi ke Ekskul Koran dulu, ya.
Dialogue: 0,0:14:16.62,0:14:18.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia berniat untuk perang."
Dialogue: 0,0:14:18.74,0:14:21.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu dulu, Dik Rentaro.
Dialogue: 0,0:14:21.21,0:14:24.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebagai kepala yayasan,\Ntolong serahkan ini padaku.
Dialogue: 0,0:14:27.07,0:14:31.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih sudah datang, Kijineta Totoro.
Dialogue: 0,0:14:31.55,0:14:32.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nama saya Toruru!
Dialogue: 0,0:14:33.00,0:14:35.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah membaca koran sekolah.
Dialogue: 0,0:14:35.62,0:14:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan seenaknya membuat siswa jadi artikel\Nkalau dia tidak menginginkannya.
Dialogue: 0,0:14:40.95,0:14:43.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau nanti mengulanginya lagi,
Dialogue: 0,0:14:43.45,0:14:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aktivitas Ekskul Koran akan kuhentikan\Ntanpa batas waktu.
Dialogue: 0,0:14:48.86,0:14:51.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ibu Kepala Yayasan, tolong lihat ini.
Dialogue: 0,0:14:58.29,0:15:01.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau ini tidak dilihat\Nsebagai kontak fisik tak berdosa,
Dialogue: 0,0:15:01.92,0:15:06.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}melainkan tindakan cabul para siswa yang\Nmelibatkan kepala yayasan dan putrinya.
Dialogue: 0,0:15:06.24,0:15:07.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hanya Bu Kepala,
Dialogue: 0,0:15:07.68,0:15:11.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi potensi para siswa ikut\Nmendapat suatu sanksi sosial
Dialogue: 0,0:15:11.85,0:15:14.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}rasanya sangat mungkin terjadi.
Dialogue: 0,0:15:16.94,0:15:19.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah kau pemilik kuasa tertinggi?
Dialogue: 0,0:15:19.02,0:15:22.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau tidak di sini,\Ndi mana lagi Ibunda mau berguna?
Dialogue: 0,0:15:22.80,0:15:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak berguna!
Dialogue: 0,0:15:24.15,0:15:27.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tetekmu masih yang paling besar,\Njadi tenang saja.
Dialogue: 0,0:15:27.35,0:15:28.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada kegunaannya.
Dialogue: 0,0:15:28.94,0:15:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nyonya Hahari, kasihan sekali...
Dialogue: 0,0:15:30.66,0:15:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bisa jadi masalah\Nkarena kenyataannya memang begitu.
Dialogue: 0,0:15:34.90,0:15:37.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan mengawal Meme selama 24 jam.
Dialogue: 0,0:15:37.89,0:15:41.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau Ekskul Koran berani\Nmenyorotkan kameranya...
Dialogue: 0,0:15:41.05,0:15:43.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar aku yang menghancurkan semuanya.
Dialogue: 0,0:15:43.56,0:15:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa tidak terlalu kejam\Nmeski itu musuh pacar Kakak?!
Dialogue: 0,0:15:46.06,0:15:48.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga akan ikut bantu!
Dialogue: 0,0:15:48.02,0:15:51.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau berdiri di depan kamera,\Naku bisa jadi tameng hidup!
Dialogue: 0,0:15:51.49,0:15:53.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Izinkan saya juga ikut membantu.
Dialogue: 0,0:15:53.94,0:15:57.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Perisaiku tidak akan bisa ditembus\Noleh serangan apa pun."
Dialogue: 0,0:15:57.24,0:15:58.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo lakukan!
Dialogue: 0,0:15:58.60,0:16:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita semua akan melindungi Meme!
Dialogue: 0,0:16:01.22,0:16:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua...
Dialogue: 0,0:16:05.44,0:16:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, apakah boleh seperti itu?
Dialogue: 0,0:16:08.33,0:16:10.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal ini masalahku sendiri.
Dialogue: 0,0:16:10.56,0:16:13.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, semuanya mau berkorban demi diriku...
Dialogue: 0,0:16:13.55,0:16:15.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maaf!
Dialogue: 0,0:16:15.59,0:16:21.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kijineta bilang, kalau dia sudah latihan\Ndengan keras agar bisa memotret diriku.
Dialogue: 0,0:16:21.97,0:16:26.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ka-Kalau aku juga latihan,
Dialogue: 0,0:16:26.16,0:16:30.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin kualitas misdirection milikku\Nakan meningkat dan bisa lari dari kamera!
Dialogue: 0,0:16:30.21,0:16:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Latihan itu bagus!
Dialogue: 0,0:16:32.00,0:16:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Asal kerja ke...
Dialogue: 0,0:16:32.70,0:16:34.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku punya ide bagus!
Dialogue: 0,0:16:45.60,0:16:47.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak!
Dialogue: 0,0:16:47.06,0:16:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:16:48.40,0:16:51.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisa berkembang lebih jauh\Nkalau latihannya makin kejam.
Dialogue: 0,0:16:51.30,0:16:53.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak benci sama yang seperti itu!
Dialogue: 0,0:16:53.67,0:16:55.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, Iku juga mau pakai?!
Dialogue: 0,0:17:00.12,0:17:03.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Apa kau kira bisa membodohi..."
Dialogue: 0,0:17:03.24,0:17:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"mataku ini?"
Dialogue: 0,0:17:04.97,0:17:06.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak!
Dialogue: 0,0:17:08.26,0:17:10.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Dia cepat sekali kaburnya."
Dialogue: 0,0:17:22.77,0:17:24.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meme!
Dialogue: 0,0:17:29.21,0:17:33.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku bisa pura-pura jadi Meme\Nbuat masuk ke baju kalian semua.
Dialogue: 0,0:17:33.15,0:17:34.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu di mana?!
Dialogue: 0,0:17:35.49,0:17:37.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa, Nano?
Dialogue: 0,0:17:37.04,0:17:39.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu bukan makhluk yang aku cari.
Dialogue: 0,0:17:39.29,0:17:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu dia, di sana!
Dialogue: 0,0:17:40.91,0:17:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bu-Bukan berarti aku ini Meme, ya!
Dialogue: 0,0:17:43.77,0:17:44.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:17:45.12,0:17:46.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu dia!
Dialogue: 0,0:17:46.50,0:17:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini ninja, ya?!
Dialogue: 0,0:17:48.71,0:17:49.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu dia!
Dialogue: 0,0:17:50.00,0:17:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang kau ninja?!
Dialogue: 0,0:17:51.93,0:17:53.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu dia!
Dialogue: 0,0:17:53.12,0:17:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini ninja, ya?!
Dialogue: 0,0:17:55.29,0:17:56.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, itu dia!
Dialogue: 0,0:17:56.72,0:17:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini ninja, ya?!
Dialogue: 0,0:18:00.58,0:18:01.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}I-Itu dia!
Dialogue: 0,0:18:01.51,0:18:03.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Kau ini ninja?
Dialogue: 0,0:18:07.83,0:18:12.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini buruk, kualitas misdirection\Nsama sekali tidak meningkat.
Dialogue: 0,0:18:12.20,0:18:15.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya, memang mustahil buatku.
Dialogue: 0,0:18:15.70,0:18:17.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Maafkan aku...
Dialogue: 0,0:18:17.72,0:18:21.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal kalian sudah mau membantuku,\Ntapi sekarang sudah tidak perlu.
Dialogue: 0,0:18:21.81,0:18:23.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski dia memotret wajah asliku...
Dialogue: 0,0:18:23.88,0:18:25.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan! Kamu jangan menyerah...
Dialogue: 0,0:18:27.04,0:18:29.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakure Meme, lihatlah aku!
Dialogue: 0,0:18:31.55,0:18:33.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, bajuku?
Dialogue: 0,0:18:33.96,0:18:37.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana menurutmu,\Npenampilanku yang sekarang ini?
Dialogue: 0,0:18:39.87,0:18:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ba-Bagaimana apanya?
Dialogue: 0,0:18:42.65,0:18:43.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah aku can...
Dialogue: 0,0:18:44.67,0:18:45.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tik?
Dialogue: 0,0:18:45.89,0:18:47.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, bukan.
Dialogue: 0,0:18:47.37,0:18:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baju ini adalah baju rajutanmu.
Dialogue: 0,0:18:50.99,0:18:56.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya dirimu bisa membuatku\Njadi secantik ini!
Dialogue: 0,0:18:57.99,0:19:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus percaya diri, Kakure Meme.
Dialogue: 0,0:19:01.16,0:19:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu itu manusia yang jauh lebih hebat\Ndari yang kamu kira.
Dialogue: 0,0:19:05.94,0:19:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kak Mimimi.
Dialogue: 0,0:19:10.01,0:19:11.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya...
Dialogue: 0,0:19:23.25,0:19:24.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tororu?
Dialogue: 0,0:19:24.09,0:19:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Toruru!
Dialogue: 0,0:19:25.20,0:19:27.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setidaknya, biarkan aku menyebut nama dulu.
Dialogue: 0,0:19:30.42,0:19:32.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raut mukanya terasa beda dari yang dulu.
Dialogue: 0,0:19:32.98,0:19:33.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi...
Dialogue: 0,0:19:33.87,0:19:37.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati rambut poni tersibak\Nkarena angin kencang hari ini!
Dialogue: 0,0:19:39.79,0:19:41.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsentrasi penuh.
Dialogue: 0,0:19:41.12,0:19:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernapasan Wartawan!
Dialogue: 0,0:19:47.20,0:19:48.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dapat!
Dialogue: 0,0:19:48.28,0:19:48.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari lihat.
Dialogue: 0,0:19:48.89,0:19:51.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti apa wajah asli gadis tertutup poni?
Dialogue: 0,0:19:53.46,0:19:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?!
Dialogue: 0,0:19:54.42,0:19:56.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangankan wajah,\Nsosoknya pun tidak terpotret!
Dialogue: 0,0:19:56.88,0:19:58.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:19:58.60,0:20:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ada di sini.
Dialogue: 0,0:20:01.85,0:20:03.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekali lagi...
Dialogue: 0,0:20:03.53,0:20:05.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsentrasi penuh.
Dialogue: 0,0:20:07.36,0:20:09.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernapasan Wartawan!
Dialogue: 0,0:20:14.78,0:20:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ma-Masih belum!
Dialogue: 0,0:20:18.04,0:20:19.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Konsentrasi penuh.
Dialogue: 0,0:20:20.74,0:20:22.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernapasan Wartawan!
Dialogue: 0,0:20:23.75,0:20:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Torurururu!
Dialogue: 0,0:20:30.06,0:20:32.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napasmu terengah-engah, lho.
Dialogue: 0,0:20:34.38,0:20:37.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini aku yang kalah!
Dialogue: 0,0:20:37.58,0:20:41.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi, foto ini sangat cantik,\Njadi akan kujadikan artikel, ya!
Dialogue: 0,0:20:41.64,0:20:43.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja!\NItu yang aku harapkan!
Dialogue: 0,0:20:44.36,0:20:45.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh!
Dialogue: 0,0:20:45.98,0:20:48.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Air mataku bikin tidak bisa lihat ke depan!
Dialogue: 0,0:20:49.10,0:20:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu berhasil, Meme.
Dialogue: 0,0:20:51.66,0:20:53.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti-Tidak...
Dialogue: 0,0:20:53.34,0:20:57.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini berkat rencana Kak Mimimi dan Rentaro.
Dialogue: 0,0:20:57.08,0:20:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sukses, ya.
Dialogue: 0,0:21:02.99,0:21:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah baju rajutanmu.
Dialogue: 0,0:21:04.76,0:21:09.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Artinya dirimu bisa membuatku\Njadi secantik ini!
Dialogue: 0,0:21:11.27,0:21:16.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misdirection mengalihkan perhatian orang\Ndengan membuat benda lain mencolok.
Dialogue: 0,0:21:16.45,0:21:18.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meme yang ahli membuat hal jadi mencolok
Dialogue: 0,0:21:18.71,0:21:21.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan Kak Mimimi yang sangat mencolok.
Dialogue: 0,0:21:21.27,0:21:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, sebagai ganti boneka rajut...
Dialogue: 0,0:21:23.93,0:21:28.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata misdirection bisa dilakukan\Ndengan membuat Kak Mimimi menonjol.
Dialogue: 0,0:21:28.51,0:21:31.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, itu karena kalian\Nberdua memang hebat.
Dialogue: 0,0:21:31.42,0:21:34.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecantikanku sendiri memang\Nsudah jadi pusat perhatian.
Dialogue: 0,0:21:34.75,0:21:38.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja efeknya akan berlipat ganda\Nkalau sengaja dibuat mencolok!
Dialogue: 0,0:21:38.45,0:21:42.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kuberi nama, Misdirection Beautyflow!
Dialogue: 0,0:21:42.78,0:21:45.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak...
Dialogue: 0,0:21:45.09,0:21:46.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, Meme.
Dialogue: 0,0:21:47.20,0:21:49.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu mungkin belum menyadarinya.
Dialogue: 0,0:21:50.07,0:21:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi ini karena kepercayaan dirimu...
Dialogue: 0,0:21:55.46,0:21:58.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke-Kecantikan macam apa itu?!
Dialogue: 0,0:21:58.90,0:22:03.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meme, jadi kamu ternyata secantik itu?!
Dialogue: 0,0:22:03.60,0:22:08.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}A-Aku dibilang cantik sama Kak Mimimi?!\NTi-Tidak mungkin!
Dialogue: 0,0:22:08.62,0:22:11.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi kamu, Meme?!
Dialogue: 0,0:22:11.74,0:22:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu harus mengajariku rahasia kecantikanmu!
Dialogue: 0,0:22:15.49,0:22:19.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meme!
