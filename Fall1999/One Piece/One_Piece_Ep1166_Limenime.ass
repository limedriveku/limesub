Dialogue: 0,0:17:52.87,0:17:55.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Semua orang sudah masuk ke mode pemabuk.{\b0}
Dialogue: 0,0:17:55.05,0:17:57.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jadi, sudah tidak jelas lagi\Ntentang perjamuan ini.{\b0}
Dialogue: 0,0:17:58.04,0:18:00.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah kau sudah makan rusa besarnya?{\b0}
Dialogue: 0,0:18:00.55,0:18:01.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sudah.{\b0}
Dialogue: 0,0:18:02.21,0:18:03.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar juga.{\b0}
Dialogue: 0,0:18:04.40,0:18:07.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku merasa harta karun di dalam\Nkastel akan menghilang.{\b0}
Dialogue: 0,0:18:07.60,0:18:09.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bagaimana menurutmu, Road?{\b0}
Dialogue: 0,0:18:10.34,0:18:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Mataku kurang baik, aku\Npasti tidak bisa melihat apa-apa.{\b0}
Dialogue: 0,0:18:14.85,0:18:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Nami, jadi ini tujuanmu.{\b0}
Dialogue: 0,0:18:17.97,0:18:18.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apa?{\b0}
Dialogue: 0,0:18:18.84,0:18:19.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tatapan itu!{\b0}
Dialogue: 0,0:18:26.83,0:18:29.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Memintaku bergabung\Ndengan Kelompok Kesatria Dewa.{\b0}
Dialogue: 0,0:18:32.59,0:18:34.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ternyata begitu masalahnya.{\b0}
Dialogue: 0,0:18:44.32,0:18:46.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku mengerti.{\b0}
Dialogue: 0,0:18:46.76,0:18:48.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau begitu, aku akan menolaknya{\b0}
Dialogue: 0,0:18:49.61,0:18:51.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}sekali lagi!{\b0}
Dialogue: 0,0:18:55.28,0:18:57.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Karena aku sudah terlahir di dunia ini,{\b0}
Dialogue: 0,0:18:57.55,0:19:00.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}mengapa aku harus repot-repot\Nmenjadi sampah?{\b0}
Dialogue: 0,0:19:03.56,0:19:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih telah mengundangku\Nbergabung dengan kesatria terhormat dunia.{\b0}
Dialogue: 0,0:19:10.95,0:19:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Berarti kalian ini adalah Tenryuubito, ya?{\b0}
Dialogue: 0,0:19:21.16,0:19:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bagaimana dengan informasinya?{\b0}
Dialogue: 0,0:19:22.69,0:19:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Para anggota badan intelijen\Nyang diutus ke Elbaph,{\b0}
Dialogue: 0,0:19:26.65,0:19:31.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}akhirnya tinggalkan pesan "Burung gagak\Nraksasa telah muncul", lalu hilang kontak.{\b0}
Dialogue: 0,0:19:31.87,0:19:34.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kita belum mengetahui kelemahannya.{\b0}
Dialogue: 0,0:19:36.35,0:19:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Namun, aku sudah menahan diri dari tadi,\Ntetapi dia benar-benar tidak sopan.{\b0}
Dialogue: 0,0:19:44.63,0:19:46.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tinggal bunuh saja dia, 'kan?{\b0}
Dialogue: 0,0:19:49.64,0:19:51.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jangan terburu-buru, Gunko.{\b0}
Dialogue: 0,0:19:55.62,0:19:57.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Makanlah mereka, Serigala Raksasa.{\b0}
Dialogue: 0,0:20:02.97,0:20:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, napasnya menghembus ke tubuhku.{\b0}
Dialogue: 0,0:20:14.49,0:20:15.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, Serigala Raksasa.{\b0}
Dialogue: 0,0:20:24.97,0:20:26.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Serigala Raksasa.{\b0}
Dialogue: 0,0:20:28.64,0:20:31.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bagaimana jika aku bilang\Naku bisa menyelamatkan makhluk ini?{\b0}
Dialogue: 0,0:20:31.79,0:20:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah kau akan mengubah pikiranmu?{\b0}
Dialogue: 0,0:20:44.33,0:20:47.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Begitu rupanya, kau ingin melakukan\Nkesepakatan seperti ini denganku?{\b0}
Dialogue: 0,0:20:47.09,0:20:48.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau begitu,{\b0}
Dialogue: 0,0:20:52.02,0:20:55.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}inilah takdirmu, temanku.{\b0}
Dialogue: 0,0:20:56.35,0:20:57.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Matilah dengan tenang.{\b0}
Dialogue: 0,0:21:00.76,0:21:03.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku juga merasa sedih dan marah,{\b0}
Dialogue: 0,0:21:03.66,0:21:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}tetapi seorang prajurit harus mati\Ndengan cara seorang prajurit.{\b0}
Dialogue: 0,0:21:05.85,0:21:07.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jangan berontak dengan menyedihkan!{\b0}
Dialogue: 0,0:21:15.77,0:21:18.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku akan menelan amarah ini{\b0}
Dialogue: 0,0:21:21.17,0:21:23.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}dan menghancurkan dunia ini.{\b0}
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪{\b0}
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪{\b0}
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪{\b0}
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪{\b0}
Dialogue: 0,0:22:13.61,0:22:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪{\b0}
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪{\b0}
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪{\b0}
Dialogue: 0,0:22:33.79,0:22:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪{\b0}
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪{\b0}
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪{\b0}
Dialogue: 0,0:23:05.01,0:23:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Di Desa Elbaph ada sebuah\NKastel Aurust raksasa.{\b0}
Dialogue: 0,0:23:08.22,0:23:11.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sangat kontras dengan Luffy dan lainnya\Nyang menjelajahi kastel dengan antusias,{\b0}
Dialogue: 0,0:23:11.31,0:23:14.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}saat ini Dunia Bawah diliputi\Noleh suasana yang tegang.{\b0}
Dialogue: 0,0:23:14.24,0:23:16.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Loki sedang berhadapan dengan dua\Norang dari Kelompok Kesatria Dewa.{\b0}
Dialogue: 0,0:23:16.84,0:23:21.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sementara identitas pria Rambut Merah itu\Nakhirnya akan segera terungkap.{\b0}
Dialogue: 0,0:23:21.02,0:23:22.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Episode selanjutnya, One Piece.{\b0}
Dialogue: 0,0:23:22.43,0:23:30.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Komandan Kelompok Kesatria Dewa,\NShamrock muncul.\N[Komandan Kelompok Kesatria Dewa,\NShamrock Muncul]{\b0}
Dialogue: 0,0:23:25.73,0:23:27.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku akan menjadi Raja Bajak Laut!{\b0}
