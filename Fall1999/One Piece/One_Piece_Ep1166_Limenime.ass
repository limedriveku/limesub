Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berlarilah\Nsampai tiba di sana ♪{\b0}
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪{\b0}
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Lautan yang begitu biru dan jernih ♪{\b0}
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Serpihan keajaiban yang bertebaran ♪{\b0}
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Jumlahnya tidak terhitung lagi ♪{\b0}
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kita pun dipertemukan karenanya ♪{\b0}
Dialogue: 0,0:00:37.72,0:00:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪{\b0}
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Titik akhir masih belum terlihat juga ♪{\b0}
Dialogue: 0,0:00:44.38,0:00:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪{\b0}
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Demi melihat senyuman itu ♪{\b0}
Dialogue: 0,0:00:51.09,0:00:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪{\b0}
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪{\b0}
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪{\b0}
Dialogue: 0,0:01:04.62,0:01:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Belum ada yang berubah ♪{\b0}
Dialogue: 0,0:01:08.70,0:01:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berlarilah ♪{\b0}
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪{\b0}
Dialogue: 0,0:01:17.27,0:01:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪{\b0}
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪{\b0}
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪{\b0}
Dialogue: 0,0:01:42.37,0:01:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak mengatakannya?{\b0}
Dialogue: 0,0:01:51.17,0:01:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sakit sekali!{\b0}
Dialogue: 0,0:01:53.03,0:01:54.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau kenapa?{\b0}
Dialogue: 0,0:02:03.20,0:02:06.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, bertahanlah, apa yang sedang terjadi?{\b0}
Dialogue: 0,0:02:07.79,0:02:10.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sangat sombong, dasar tidak sopan.{\b0}
Dialogue: 0,0:02:11.64,0:02:13.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kapan aku bertanya kepadamu?{\b0}
Dialogue: 0,0:02:17.14,0:02:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku sedang memerintahkanmu.{\b0}
Dialogue: 0,0:02:20.56,0:02:21.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jawablah aku.{\b0}
Dialogue: 0,0:02:32.69,0:02:33.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aduh!{\b0}
Dialogue: 0,0:02:53.67,0:03:01.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bertemu Loki,\NGunko dari Kelompok Kesatria Dewa.{\b0}
Dialogue: 0,0:03:08.45,0:03:09.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar-benar sangat enak.{\b0}
Dialogue: 0,0:03:10.11,0:03:13.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Rusa besar ini rasanya seperti dinosaurus!{\b0}
Dialogue: 0,0:03:17.91,0:03:19.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hebat sekali kalian bisa memburunya.{\b0}
Dialogue: 0,0:03:19.67,0:03:22.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Rusa besar memang enak, tetapi buas.{\b0}
Dialogue: 0,0:03:23.47,0:03:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bahaya bukan apa-apa demi para penyelamat.{\b0}
Dialogue: 0,0:03:29.18,0:03:32.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih, Hajrudin, Stansen.{\b0}
Dialogue: 0,0:03:35.85,0:03:37.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak perlu sungkan.{\b0}
Dialogue: 0,0:03:37.54,0:03:39.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Masih ada banyak.{\b0}
Dialogue: 0,0:03:39.28,0:03:40.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Makanlah sepuasnya.{\b0}
Dialogue: 0,0:03:49.95,0:03:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maaf membuat kalian menunggu.{\b0}
Dialogue: 0,0:03:51.04,0:03:52.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Makanlah sampai puas.{\b0}
Dialogue: 0,0:03:55.96,0:03:58.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Oh, Colon, cara makanmu sangat beringas.{\b0}
Dialogue: 0,0:03:59.95,0:04:04.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Manusia yang datang ke\NDunia Matahari cukup langka.{\b0}
Dialogue: 0,0:04:04.74,0:04:05.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benarkah?{\b0}
Dialogue: 0,0:04:07.50,0:04:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Banyak orang tidak tahu\Ncara naik ke pulau.{\b0}
Dialogue: 0,0:04:09.62,0:04:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Mengira Dunia Bawah yang penuh dengan\Nbinatang buas berbahaya adalah Elbaph,{\b0}
Dialogue: 0,0:04:14.02,0:04:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}lalu mereka melarikan diri begitu saja.{\b0}
Dialogue: 0,0:04:23.66,0:04:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah kau pernah\Nbertarung dengan Oars itu?{\b0}
Dialogue: 0,0:04:26.47,0:04:30.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Orang itu adalah prajurit sadis\Nyang melegenda di antara Suku Raksasa.{\b0}
Dialogue: 0,0:04:31.84,0:04:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar sekali.{\b0}
Dialogue: 0,0:04:33.36,0:04:35.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Orang itu setidaknya tiga kali\Nlebih besar dari kalian,{\b0}
Dialogue: 0,0:04:35.31,0:04:38.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}lalu orang yang memberikan\Nserangan terakhir kepadanya{\b0}
Dialogue: 0,0:04:38.74,0:04:39.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}adalah aku.{\b0}
Dialogue: 0,0:04:43.95,0:04:46.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Kapten Usopp!\N- Kapten Usopp!{\b0}
Dialogue: 0,0:04:46.20,0:04:48.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sama seperti yang dikatakan oleh Hajrudin,{\b0}
Dialogue: 0,0:04:48.15,0:04:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}ini benar-benar seorang pahlawan.{\b0}
Dialogue: 0,0:04:51.73,0:04:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau adalah manusia ikan, 'kan?{\b0}
Dialogue: 0,0:04:55.15,0:04:58.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sangat cantik, kulitmu\Nbenar-benar berwarna biru.{\b0}
Dialogue: 0,0:04:58.71,0:05:01.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ini pertama kalinya aku\Nmelihat dari jarak dekat.{\b0}
Dialogue: 0,0:05:01.36,0:05:04.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Pulau Manusia Ikan\Nbahkan lebih berwarna-warni.{\b0}
Dialogue: 0,0:05:04.11,0:05:06.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu sama seperti ikan-ikan di laut.{\b0}
Dialogue: 0,0:05:06.75,0:05:08.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Wah, aku sangat ingin pergi melihatnya.{\b0}
Dialogue: 0,0:05:08.96,0:05:11.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku ingin melihat putri duyung,{\b0}
Dialogue: 0,0:05:11.95,0:05:14.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}pasti sangat cantik.{\b0}
Dialogue: 0,0:05:16.76,0:05:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau bertanya apakah\Nputri duyung itu cantik?{\b0}
Dialogue: 0,0:05:22.38,0:05:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Putri duyung...{\b0}
Dialogue: 0,0:05:24.79,0:05:25.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Putri duyung{\b0}
Dialogue: 0,0:05:27.03,0:05:29.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}itu sangat cantik!{\b0}
Dialogue: 0,0:05:31.67,0:05:34.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Teluk Putri Duyung\Nbenar-benar seperti surga.{\b0}
Dialogue: 0,0:05:36.02,0:05:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ayo... ayo kita segera pergi ke sana.{\b0}
Dialogue: 0,0:05:38.76,0:05:40.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Para putri duyung sangat cantik.{\b0}
Dialogue: 0,0:05:41.12,0:05:41.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Namun,{\b0}
Dialogue: 0,0:05:45.15,0:05:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}para saudari Suku Raksasa juga sangat\Ncantik, aku serasa mau terbang ke langit.{\b0}
Dialogue: 0,0:05:49.90,0:05:53.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dasar, Sanji.{\b0}
Dialogue: 0,0:05:53.55,0:05:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sangat imut.{\b0}
Dialogue: 0,0:05:56.96,0:05:59.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dikelilingi oleh wanita cantik\Ndari segala arah!{\b0}
Dialogue: 0,0:06:02.68,0:06:06.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak disangka ternyata banyak raksasa\Nyang belum pernah melaut.{\b0}
Dialogue: 0,0:06:06.81,0:06:07.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar.{\b0}
Dialogue: 0,0:06:07.92,0:06:11.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku kira semua raksasa\NElbaph adalah bajak laut.{\b0}
Dialogue: 0,0:06:11.97,0:06:15.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, lihatlah, ada tulang yang memakai\Nbaju dan bisa bergerak.{\b0}
Dialogue: 0,0:06:16.71,0:06:19.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau ini sebenarnya suku apa?{\b0}
Dialogue: 0,0:06:20.72,0:06:21.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku?{\b0}
Dialogue: 0,0:06:22.30,0:06:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku yang sudah mati\Ndan hanya tersisa tulang.{\b0}
Dialogue: 0,0:06:27.58,0:06:29.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya adalah...{\b0}
Dialogue: 0,0:06:31.48,0:06:34.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Suku apa, ya, Blues?{\b0}
Dialogue: 0,0:06:37.89,0:06:40.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bersulang untuk dunia yang luas!{\b0}
Dialogue: 0,0:06:40.56,0:06:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Bersulang!\N- Bersulang!{\b0}
Dialogue: 0,0:06:48.15,0:06:50.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukankah ini negara yang cukup damai?{\b0}
Dialogue: 0,0:06:51.88,0:06:53.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tasso.{\b0}
Dialogue: 0,0:06:54.42,0:06:55.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tasso.{\b0}
Dialogue: 0,0:07:01.37,0:07:02.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Nami-tasso!{\b0}
Dialogue: 0,0:07:06.84,0:07:08.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Nami-tasso.{\b0}
Dialogue: 0,0:07:08.23,0:07:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Geng Topi Jerami-tasso.{\b0}
Dialogue: 0,0:07:10.74,0:07:13.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku sangat meminta maaf\Natas kejadian tadi.{\b0}
Dialogue: 0,0:07:16.41,0:07:18.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Meskipun aku tidak akan memaafkanmu,{\b0}
Dialogue: 0,0:07:19.52,0:07:21.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}mintalah maaf dengan benar.{\b0}
Dialogue: 0,0:07:23.04,0:07:27.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terhadap Gerth-tasso yang sadis,\Naku tidak bisa untuk tidak jatuh hati.{\b0}
Dialogue: 0,0:07:27.95,0:07:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Begitu rupanya.{\b0}
Dialogue: 0,0:07:30.68,0:07:34.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak perlu dipikirkan,\Nlagi pula tidak ada yang mati.{\b0}
Dialogue: 0,0:07:34.94,0:07:39.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Namun, pada saat itu Usopp\Nyang menghentikan serangan balik kami.{\b0}
Dialogue: 0,0:07:40.15,0:07:44.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Di Pulau Manusia Ikan, ada banyak\NRaja Laut yang mengikutiku.{\b0}
Dialogue: 0,0:07:46.05,0:07:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau bukan karena dia yang menahannya{\b0}
Dialogue: 0,0:07:54.89,0:07:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}kepalamu pasti sudah terbang sejak tadi.{\b0}
Dialogue: 0,0:08:05.07,0:08:09.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Road, apakah kau tahu\Nberapa nilai hadiah mereka?{\b0}
Dialogue: 0,0:08:10.18,0:08:12.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau pasti tidak akan bisa\Nmengalahkan mereka.{\b0}
Dialogue: 0,0:08:12.51,0:08:16.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tentu saja, lain kali kau bisa\Nlangsung menerbangkan kepalanya,{\b0}
Dialogue: 0,0:08:17.29,0:08:18.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Gerth-tasso!{\b0}
Dialogue: 0,0:08:19.31,0:08:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sangat mendebarkan.{\b0}
Dialogue: 0,0:08:21.40,0:08:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Na... namun, itu adalah...{\b0}
Dialogue: 0,0:08:23.63,0:08:27.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu adalah mimpi yang dimiliki\Noleh semua orang yang lahir di Elbaph.{\b0}
Dialogue: 0,0:08:28.33,0:08:32.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Menjadi Dewa Matahari\Ndan menguasai seluruh dunia.{\b0}
Dialogue: 0,0:08:34.95,0:08:36.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari?{\b0}
Dialogue: 0,0:08:42.95,0:08:44.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bicara bodoh apa kau ini?{\b0}
Dialogue: 0,0:08:44.37,0:08:46.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari bukanlah seorang penguasa!{\b0}
Dialogue: 0,0:08:47.02,0:08:49.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar sekali, dia adalah dewa pembebasan!{\b0}
Dialogue: 0,0:08:49.75,0:08:52.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tentu saja bukan, dia adalah\Ndewa kehancuran!{\b0}
Dialogue: 0,0:08:52.50,0:08:54.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Mereka bertengkar.{\b0}
