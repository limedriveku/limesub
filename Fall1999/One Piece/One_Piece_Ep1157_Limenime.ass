Dialogue: 0,0:04:05.85,0:04:08.87,tanda,,0000,0000,0000,,{\an8}[Kastel Bigstein]
Dialogue: 0,0:21:24.68,0:21:30.59,tanda,,0000,0000,0000,,[Bersambung]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:21.28,0:00:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[One Piece\NEpisode 1157]
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:01:41.75,0:01:42.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami!
Dialogue: 0,0:01:43.36,0:01:44.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, cepat bangun!
Dialogue: 0,0:01:54.03,0:01:55.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:01:55.61,0:01:58.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku terlalu banyak minum.
Dialogue: 0,0:02:04.48,0:02:05.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:02:08.91,0:02:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:02:17.31,0:02:18.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang.
Dialogue: 0,0:02:24.15,0:02:25.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:02:32.32,0:02:34.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini hanya halusinasiku?
Dialogue: 0,0:02:34.34,0:02:35.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau dipikir-pikir aku...
Dialogue: 0,0:02:37.42,0:02:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa bisa ada di sini?
Dialogue: 0,0:02:39.89,0:02:43.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seingatku aku sedang naik kapal\NSuku Raksasa dari Egg Head
Dialogue: 0,0:02:43.60,0:02:45.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan sedang berpesta dengan semuanya.
Dialogue: 0,0:02:51.67,0:02:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, apa yang sebenarnya terjadi?
Dialogue: 0,0:02:54.53,0:02:58.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pokoknya, aku harus segera berkumpul\Nkembali dengan Luffy dan yang lainnya.
Dialogue: 0,0:03:03.21,0:03:04.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:03:06.75,0:03:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebingungan Nami,\Npetualangan di Negeri Balok Susun!
Dialogue: 0,0:03:22.43,0:03:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebakaran.
Dialogue: 0,0:03:23.52,0:03:24.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dari arah hutan?
Dialogue: 0,0:03:25.16,0:03:26.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baunya sangat menyengat.
Dialogue: 0,0:03:26.84,0:03:29.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat gunakan air dari mata air\Nuntuk memadamkan apinya.
Dialogue: 0,0:03:29.75,0:03:31.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika apinya merambat\Nsampai ke Pohon Dunia,
Dialogue: 0,0:03:31.53,0:03:33.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}negara ini akan hancur!
Dialogue: 0,0:03:35.54,0:03:36.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:03:45.28,0:03:46.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Prajurit lebah.
Dialogue: 0,0:03:47.41,0:03:49.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:03:50.52,0:03:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang di arah hutan bilang
Dialogue: 0,0:03:52.22,0:03:56.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}getaran tanah barusan adalah suara\Nsaat Yang Mulia "Dewa Telinga" tumbang.
Dialogue: 0,0:03:56.79,0:03:58.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin?
Dialogue: 0,0:03:58.47,0:04:00.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci yang begitu ganas dan raksasa itu?
Dialogue: 0,0:04:01.14,0:04:04.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik segera melapor\Nkepada Yang Mulia "Dewa Matahari".
Dialogue: 0,0:04:07.66,0:04:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih hidup.
Dialogue: 0,0:04:12.67,0:04:16.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan membiarkan kalian\Nmenyentuh Nami satu ujung jari pun!
Dialogue: 0,0:04:29.03,0:04:31.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan lebah besar ini?
Dialogue: 0,0:04:31.95,0:04:33.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat pagi, Nami.
Dialogue: 0,0:04:34.52,0:04:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana ini?
Dialogue: 0,0:04:36.35,0:04:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:04:37.87,0:04:40.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seharusnya aku berada\Ndi atas kapal Suku Raksasa.
Dialogue: 0,0:04:42.31,0:04:43.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana tempat ini?
Dialogue: 0,0:04:43.81,0:04:44.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini mimpi?
Dialogue: 0,0:04:45.32,0:04:47.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ataukah kastel di suatu tempat?
Dialogue: 0,0:04:47.88,0:04:49.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ada sesuatu yang salah denganku?
Dialogue: 0,0:04:49.42,0:04:52.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak ingat\Nkapan aku berganti pakaian.
Dialogue: 0,0:04:54.47,0:04:57.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau tidur lagi.
Dialogue: 0,0:05:01.28,0:05:03.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar,\Njangan tinggalkan aku sendirian.
Dialogue: 0,0:05:03.81,0:05:04.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zeus!
Dialogue: 0,0:05:05.10,0:05:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Zeus.
Dialogue: 0,0:05:09.12,0:05:13.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa pun tolong selamatkan aku!
Dialogue: 0,0:05:13.62,0:05:14.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy!
Dialogue: 0,0:05:15.24,0:05:16.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zoro!
Dialogue: 0,0:05:16.59,0:05:18.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sanji!
Dialogue: 0,0:05:19.11,0:05:21.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di saat genting seperti ini,\NUsopp juga boleh.
Dialogue: 0,0:05:21.06,0:05:24.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nami!
Dialogue: 0,0:05:25.63,0:05:26.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp?
Dialogue: 0,0:05:30.46,0:05:32.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh sakit.
Dialogue: 0,0:05:32.82,0:05:36.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, ada apa dengan lantai ini?
Dialogue: 0,0:05:36.86,0:05:38.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Permukaannya tidak rata.
Dialogue: 0,0:05:56.93,0:05:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:06:02.89,0:06:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:06:03.70,0:06:05.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bermaksud menakutimu.
Dialogue: 0,0:06:09.79,0:06:11.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan marah, ya?
Dialogue: 0,0:06:15.84,0:06:18.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kubilang aku\Ntidak bermaksud menakutimu, maaf!
Dialogue: 0,0:06:23.54,0:06:26.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lambat sekali, apakah\Nkarena kakinya terlalu pendek?
Dialogue: 0,0:06:30.71,0:06:34.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Astaga, Usopp, kau ada di mana?
Dialogue: 0,0:06:35.11,0:06:36.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku di sini!
Dialogue: 0,0:06:37.65,0:06:38.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:06:46.63,0:06:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong aku!
Dialogue: 0,0:06:48.65,0:06:50.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata itu kau.
Dialogue: 0,0:06:50.62,0:06:52.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Monster apa lagi itu?
Dialogue: 0,0:06:54.88,0:06:56.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp akan segera mati.
Dialogue: 0,0:06:57.04,0:06:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang akan segera mati!
Dialogue: 0,0:06:58.93,0:07:00.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi di sini?
Dialogue: 0,0:07:01.02,0:07:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini kastel monster?
Dialogue: 0,0:07:04.62,0:07:06.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, giliranmu beraksi, Zeus.
Dialogue: 0,0:07:06.63,0:07:07.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bangun.
Dialogue: 0,0:07:08.27,0:07:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:07:10.13,0:07:11.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah bangun.
Dialogue: 0,0:07:14.67,0:07:17.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami, apakah sudah waktunya makan?
Dialogue: 0,0:07:19.42,0:07:21.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Makanlah Awan Petir yang baru saja\Nkubuat ini sepuasmu!
Dialogue: 0,0:07:21.83,0:07:22.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:07:26.29,0:07:27.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat memanjang, Zeus.
Dialogue: 0,0:07:27.83,0:07:29.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan padaku.
Dialogue: 0,0:07:37.49,0:07:39.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zeus, semangat!
Dialogue: 0,0:07:52.30,0:07:53.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan jatuh.
Dialogue: 0,0:07:56.32,0:07:59.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk saat ini, berikan sambaran petir.
Dialogue: 0,0:08:24.58,0:08:25.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:08:50.74,0:08:52.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perasaanku tidak enak.
Dialogue: 0,0:08:52.59,0:08:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga merasa begitu.
Dialogue: 0,0:08:57.85,0:08:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah...
Dialogue: 0,0:08:59.57,0:09:00.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata benar...
Dialogue: 0,0:09:13.95,0:09:15.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong!
Dialogue: 0,0:09:20.52,0:09:23.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, sulit sekali untuk berlari\Ndi tanah rusak yang tidak rata ini.
Dialogue: 0,0:09:23.40,0:09:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Usopp, apakah kau tahu\Napa yang sudah terjadi?
Dialogue: 0,0:09:26.44,0:09:27.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu apa-apa.
Dialogue: 0,0:09:27.35,0:09:29.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu bangun aku sudah sampai di sini.
Dialogue: 0,0:09:30.74,0:09:34.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei... tempat apa ini?
Dialogue: 0,0:09:41.86,0:09:42.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Janggut?
Dialogue: 0,0:09:43.56,0:09:44.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pakaian ini?
Dialogue: 0,0:09:45.43,0:09:46.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan...
Dialogue: 0,0:09:51.53,0:09:52.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami!
Dialogue: 0,0:09:52.38,0:09:53.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, cepat bangun.
Dialogue: 0,0:09:58.89,0:10:00.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:10:00.97,0:10:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:10:09.77,0:10:10.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah ceritanya.
Dialogue: 0,0:10:10.86,0:10:12.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata suara itu adalah Usopp.
Dialogue: 0,0:10:13.71,0:10:15.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa menjadi seperti ini?
Dialogue: 0,0:10:15.77,0:10:16.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak tahu.
Dialogue: 0,0:10:17.08,0:10:19.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sedang naik kapal Suku Raksasa
Dialogue: 0,0:10:20.12,0:10:21.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan minum terlalu banyak.
Dialogue: 0,0:10:23.79,0:10:25.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal minum,
Dialogue: 0,0:10:26.21,0:10:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}minuman ini benar-benar keras.
Dialogue: 0,0:10:28.42,0:10:31.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini adalah Absinthe.
Dialogue: 0,0:10:31.51,0:10:34.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada nama lainnya yaitu "Peri Hijau".
Dialogue: 0,0:10:34.46,0:10:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, katanya jika meminum minuman itu,\Nbisa menimbulkan halusinasi.
Dialogue: 0,0:10:39.84,0:10:40.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini jalan buntu!
Dialogue: 0,0:10:46.88,0:10:48.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggi sekali.
Dialogue: 0,0:10:56.51,0:10:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini, Usopp?
Dialogue: 0,0:10:59.25,0:11:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami, tadi kau bilang ini\Nhalusinasi, 'kan?
Dialogue: 0,0:11:02.98,0:11:05.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kucing itu
Dialogue: 0,0:11:05.90,0:11:08.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin saja bisa\Nterlihat, tetapi kenyataannya...
Dialogue: 0,0:11:10.65,0:11:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya halusinasi.
Dialogue: 0,0:11:15.44,0:11:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemarilah!
Dialogue: 0,0:11:27.61,0:11:29.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:11:43.43,0:11:44.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:11:48.95,0:11:52.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan!
Dialogue: 0,0:12:20.47,0:12:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh sakit, apakah aku selamat?
Dialogue: 0,0:12:28.62,0:12:31.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp berubah menjadi Brook!
Dialogue: 0,0:12:39.54,0:12:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:12:43.97,0:12:45.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bangunlah.
Dialogue: 0,0:12:45.91,0:12:49.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tinggalkan aku sendirian.
Dialogue: 0,0:12:51.46,0:12:52.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:13:25.18,0:13:26.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa ada singa?
Dialogue: 0,0:13:27.11,0:13:28.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp, kuatkan dirimu.
Dialogue: 0,0:13:28.45,0:13:29.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat bangun.
Dialogue: 0,0:13:29.29,0:13:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan dibunuh.
Dialogue: 0,0:13:30.92,0:13:31.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:13:31.95,0:13:33.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:13:50.35,0:13:52.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan jadikan aku tameng.
Dialogue: 0,0:13:53.06,0:13:54.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan... jangan mendekat!
Dialogue: 0,0:13:54.72,0:13:55.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat!
Dialogue: 0,0:14:04.51,0:14:05.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gear Third...
Dialogue: 0,0:14:14.84,0:14:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami!
Dialogue: 0,0:14:19.67,0:14:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dosa karena telah membuat orang\Nyang kucintai menangis adalah
Dialogue: 0,0:14:22.48,0:14:23.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hukuman mati!
Dialogue: 0,0:14:30.40,0:14:31.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ifrit Jambe...
Dialogue: 0,0:14:36.69,0:14:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Santoryu...
Dialogue: 0,0:14:40.02,0:14:42.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gomu-gomu no...
Dialogue: 0,0:14:42.71,0:14:44.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elephant...
Dialogue: 0,0:14:46.06,0:14:47.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shoulder...
Dialogue: 0,0:14:48.30,0:14:50.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kokujo O Tats...
Dialogue: 0,0:14:54.81,0:14:55.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tsumaki!
Dialogue: 0,0:15:01.04,0:15:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Whip!
Dialogue: 0,0:15:08.30,0:15:09.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strike!
Dialogue: 0,0:15:36.78,0:15:38.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya selamat.
Dialogue: 0,0:15:43.05,0:15:45.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi? Berubah jadi kucing.
Dialogue: 0,0:15:45.63,0:15:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Besar sekali.
Dialogue: 0,0:15:47.59,0:15:50.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, sebaiknya yang ini\Ntidak dimakan saja, ya?
Dialogue: 0,0:15:50.38,0:15:53.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelinci panggang yang tadi sangat enak.
Dialogue: 0,0:15:55.26,0:15:59.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami, aku sangat mengkhawatirkanmu.
Dialogue: 0,0:16:01.93,0:16:04.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sanji, aku sangat takut.
Dialogue: 0,0:16:04.97,0:16:07.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp sudah mati.
Dialogue: 0,0:16:07.56,0:16:09.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang sangat menakutkan.
Dialogue: 0,0:16:09.90,0:16:13.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keinginan terbesar orang itu\Nmungkin adalah mati demi Nami.
Dialogue: 0,0:16:13.21,0:16:14.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku masih hidup tahu.
Dialogue: 0,0:16:15.80,0:16:18.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau ini, beraninya\Nmenjadikanku tameng hidup.
Dialogue: 0,0:16:18.73,0:16:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan kuingat ini.
Dialogue: 0,0:16:35.73,0:16:36.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:16:40.36,0:16:41.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini ada apa lagi?
Dialogue: 0,0:16:41.85,0:16:42.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Datang lagi?
Dialogue: 0,0:16:43.49,0:16:46.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada sesuatu yang lain\Ndan lebih besar di sana.
Dialogue: 0,0:16:46.20,0:16:48.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika itu enak, aku akan\Npergi menghajarnya.
Dialogue: 0,0:16:48.68,0:16:51.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik cari laut dan kapal dulu.
Dialogue: 0,0:16:51.54,0:16:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Entah juga teman-teman\Nyang lain aman atau tidak.
Dialogue: 0,0:16:54.08,0:16:58.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bicara soal makanan, Hachinosu\Ndan pasukan lebah yang kau hajar,
Dialogue: 0,0:17:00.69,0:17:02.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga merupakan bahan makanan\Nyang luar biasa.
Dialogue: 0,0:17:02.55,0:17:04.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilai gizinya sangat tinggi.
Dialogue: 0,0:17:04.74,0:17:07.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ya, ini benar-benar\Nmembuang-buang makanan.
Dialogue: 0,0:17:08.31,0:17:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, 'kan?
Dialogue: 0,0:17:09.10,0:17:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau tidak mengatakannya lebih awal?
Dialogue: 0,0:17:11.60,0:17:13.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa kalian bisa\Nberadaptasi secepat ini?
Dialogue: 0,0:17:13.69,0:17:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini?
Dialogue: 0,0:17:18.27,0:17:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu aku, bagaimana kalian\Nbisa sampai ke sini?
Dialogue: 0,0:17:21.24,0:17:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terbangun di belakang jalan itu.
Dialogue: 0,0:17:24.15,0:17:26.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah menuju ke tempat yang berisik,
Dialogue: 0,0:17:26.44,0:17:29.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku melihat orang ini\Nmengalahkan seekor kelinci raksasa.
Dialogue: 0,0:17:29.14,0:17:32.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp, kucing singa seperti itu\Nharusnya bisa kau kalahkan juga, 'kan?
Dialogue: 0,0:17:32.77,0:17:36.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tiba-tiba saja hampir dimakan\Nkucing aneh, aku jadi panik.
Dialogue: 0,0:17:49.16,0:17:54.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gomu Gomu no Fusen!
Dialogue: 0,0:18:05.43,0:18:07.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:18:07.67,0:18:08.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku terselamatkan.
Dialogue: 0,0:18:09.32,0:18:11.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik itu monster yang besarnya tidak wajar
Dialogue: 0,0:18:11.62,0:18:14.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maupun kastel yang terlihat\Nseperti dibangun dari mainan.
Dialogue: 0,0:18:14.04,0:18:16.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dunia ini bukan halusinasi...
Dialogue: 0,0:18:17.02,0:18:18.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah ini adalah alam mimpi?
Dialogue: 0,0:18:19.68,0:18:20.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:18:21.44,0:18:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ini adalah mimpi,
Dialogue: 0,0:18:24.73,0:18:26.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak akan ada laki-laki yang muncul.
Dialogue: 0,0:18:26.99,0:18:29.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mimpi macam apa yang kau bicarakan itu?
Dialogue: 0,0:18:30.24,0:18:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Nami.
Dialogue: 0,0:18:34.06,0:18:36.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan melompat!
Dialogue: 0,0:19:10.43,0:19:11.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aneh sekali.
Dialogue: 0,0:19:12.39,0:19:14.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak ada angin yang bertiup.
Dialogue: 0,0:19:21.54,0:19:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya.
Dialogue: 0,0:19:23.30,0:19:23.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:19:25.55,0:19:27.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini pohon?
Dialogue: 0,0:19:27.93,0:19:29.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurutku,
Dialogue: 0,0:19:30.60,0:19:32.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berdasarkan penilaianku,
Dialogue: 0,0:19:32.26,0:19:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita mengenakan pakaian prajurit Elbaph.
Dialogue: 0,0:19:36.38,0:19:40.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, di Elbaph negeri para raksasa,
Dialogue: 0,0:19:40.48,0:19:42.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tidak mungkin ada pakaian seukuran kita.
Dialogue: 0,0:19:42.89,0:19:47.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, tempat ini adalah Elbaph,\Nmungkinkah kita yang jadi besar?
Dialogue: 0,0:19:47.43,0:19:49.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah aku seorang raksasa?
Dialogue: 0,0:19:49.46,0:19:50.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin?
Dialogue: 0,0:19:51.31,0:19:53.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun ada teman-teman di sini,
Dialogue: 0,0:19:53.24,0:19:54.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sepertinya tidak semua orang ada di sini.
Dialogue: 0,0:19:54.97,0:19:56.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kau tahu?
Dialogue: 0,0:19:58.17,0:20:00.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Radarku tidak mendeteksi\Nkeberadaan Robin.
Dialogue: 0,0:20:00.76,0:20:01.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau anjing, ya?
Dialogue: 0,0:20:01.96,0:20:06.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, kalau pergi ke arah laut\Nmungkin kita bisa menemukan Sunny.
Dialogue: 0,0:20:06.61,0:20:08.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya pasti ada di sana juga.
Dialogue: 0,0:20:08.46,0:20:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihatlah seberapa luas tempat ini.
Dialogue: 0,0:20:10.33,0:20:12.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak bisa\Nsampai ke tepi laut.
Dialogue: 0,0:20:13.06,0:20:14.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:20:14.42,0:20:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada orang di jalanan.
Dialogue: 0,0:20:16.89,0:20:18.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat apa ini sebenarnya,
Dialogue: 0,0:20:18.70,0:20:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita harus menanyakannya\Ndengan jelas dulu.
Dialogue: 0,0:20:21.41,0:20:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita pergi ke jalanan.
Dialogue: 0,0:20:23.55,0:20:27.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ingin bertanya pada seseorang,\Nmari cari wanita yang cantik saja.
Dialogue: 0,0:20:27.27,0:20:28.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, kau yang serius!
Dialogue: 0,0:20:28.77,0:20:30.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, jalanannya\Nbukan ke arah sana, Zoro.
Dialogue: 0,0:20:30.67,0:20:31.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh, benarkah?
Dialogue: 0,0:20:34.33,0:20:36.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa kau begitu senang?
Dialogue: 0,0:20:36.49,0:20:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau mengerti situasinya?
Dialogue: 0,0:20:37.28,0:20:39.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Betapa anehnya tempat ini.
Dialogue: 0,0:20:40.24,0:20:42.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami, bersemangatlah.
Dialogue: 0,0:20:42.36,0:20:43.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada aku di sini.
Dialogue: 0,0:20:44.53,0:20:46.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun di sini bukan Elbaph,
Dialogue: 0,0:20:46.87,0:20:51.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di dalam hatiku akan selalu ada\Ncinta yang penuh untuk Nami.
Dialogue: 0,0:20:52.51,0:20:54.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku berpikir\Njika di sini adalah Elbaph,
Dialogue: 0,0:20:54.18,0:20:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}setidaknya aku bisa melihat\Nsebongkah emas yang sangat besar.
Dialogue: 0,0:20:57.66,0:20:59.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau berniat mencurinya, 'kan?
Dialogue: 0,0:20:59.76,0:21:03.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, mari pergi ke jalanan\Nuntuk bertanya pada seseorang.
Dialogue: 0,0:21:03.44,0:21:05.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ayo pergi.
Dialogue: 0,0:21:05.95,0:21:07.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualangan dimulai.
Dialogue: 0,0:21:12.72,0:21:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elbaph!
Dialogue: 0,0:21:21.20,0:21:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sangat tinggi besar,\Nmereka semua adalah raksasa.
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
Dialogue: 0,0:23:05.85,0:23:08.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy dan gengnya mulai\Nmenaklukkan negeri misterius.
Dialogue: 0,0:23:08.79,0:23:10.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di depan pemandangan\Nyang terbuat dari balok-balok mainan,
Dialogue: 0,0:23:10.36,0:23:12.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ditemukan kuil Dewa Matahari.
Dialogue: 0,0:23:13.05,0:23:15.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah tempat ini benar-benar Elbaph?
Dialogue: 0,0:23:15.98,0:23:19.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Geng Topi Jerami mencoba melarikan diri\Ndari Negeri Balok Susun.
Dialogue: 0,0:23:19.22,0:23:21.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, suara langkah kaki yang tidak\Nmenyenangkan sedang mendekati mereka.
