Dialogue: 0,0:05:46.26,0:05:51.59,sign,,0000,0000,0000,,{\an8}[Cerberus]
Dialogue: 0,0:09:21.01,0:09:24.97,sign,,0000,0000,0000,,{\an8}[Kastel Aurust]
Dialogue: 0,0:15:05.05,0:15:07.33,sign,,0000,0000,0000,,{\an8}[Sekolah Walrus]
Dialogue: 0,0:15:24.15,0:15:27.79,sign,,0000,0000,0000,,{\an8}[Sekolah Walrus, Kepala Sekolah Kiba]
Dialogue: 0,0:16:21.90,0:16:25.02,sign,,0000,0000,0000,,{\an8}[Perpustakaan Burung Hantu]
Dialogue: 0,0:21:24.62,0:21:30.69,sign,,0000,0000,0000,,[Bersambung]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:21.28,0:00:23.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[One Piece\NEpisode 1168]
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:01:42.72,0:01:44.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup, Gunko.
Dialogue: 0,0:01:46.00,0:01:48.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita ubah rencana pertempurannya.
Dialogue: 0,0:01:55.13,0:01:59.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menempatkan\Npara prajurit Elbaph yang ganas
Dialogue: 0,0:01:59.53,0:02:02.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sejak dahulu\Ntelah menaklukkan New World ini,
Dialogue: 0,0:02:03.24,0:02:08.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk berada di bawah komando\NPemerintah Dunia kita.
Dialogue: 0,0:02:10.07,0:02:17.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejarah kuno, "Kitab Dewa" yang diwariskan\Nsecara turun-temurun di Elbaph.
Dialogue: 0,0:02:42.26,0:02:46.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wajahmu sangat mirip dengannya.
Dialogue: 0,0:02:50.28,0:02:54.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak mungkin tidak ada hubungannya\Ndengan Bajak Laut Rambut Merah, 'kan?
Dialogue: 0,0:03:05.95,0:03:06.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jaga bicaramu.
Dialogue: 0,0:03:07.33,0:03:09.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau tidak perlu tahu.
Dialogue: 0,0:03:09.32,0:03:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar, tetapi
Dialogue: 0,0:03:14.05,0:03:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bajak laut besar dan Tenryuubito,
Dialogue: 0,0:03:17.65,0:03:19.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dua kutub ekstrem di dunia
Dialogue: 0,0:03:20.95,0:03:22.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ternyata memiliki wajah yang sama.
Dialogue: 0,0:03:23.38,0:03:25.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu masih terlalu sulit dipercaya, 'kan?
Dialogue: 0,0:03:36.87,0:03:38.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajak laut itu
Dialogue: 0,0:03:41.63,0:03:46.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah adik kembarku yang terpisah.
Dialogue: 0,0:03:48.21,0:03:50.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pernah kembali sekali ke Tanah Suci,
Dialogue: 0,0:03:51.85,0:03:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi sepertinya dia menyukai\Ndunia bawah yang kotor ini.
Dialogue: 0,0:03:56.07,0:03:57.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah kembali, ya.
Dialogue: 0,0:03:58.53,0:04:02.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu rupanya, garis keturunan\Nkalian membuatku makin marah.
Dialogue: 0,0:04:04.05,0:04:09.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dua bersaudara membuatku\Nmenaruh dendam, ini juga menarik.
Dialogue: 0,0:04:11.01,0:04:13.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua ingatlah dengan baik.
Dialogue: 0,0:04:14.53,0:04:17.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sampai aku melepaskan rantai ini,
Dialogue: 0,0:04:18.24,0:04:20.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau tahu apa yang akan terjadi, 'kan?
Dialogue: 0,0:04:24.04,0:04:25.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku
Dialogue: 0,0:04:27.78,0:04:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah menyaksikan nasib teman-temanku
Dialogue: 0,0:04:31.67,0:04:33.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memikul nasib mereka.
Dialogue: 0,0:04:40.86,0:04:44.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau sedang mengancamku?
Dialogue: 0,0:04:49.87,0:04:52.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan, orang seperti ini tidak perlu...
Dialogue: 0,0:04:52.31,0:04:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, tidak perlu bagiku\Nuntuk turun tangan langsung.
Dialogue: 0,0:05:02.16,0:05:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, Cerberus?
Dialogue: 0,0:05:43.26,0:05:44.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa dia?
Dialogue: 0,0:05:53.64,0:05:54.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah...
Dialogue: 0,0:05:58.57,0:05:59.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pedangku.
Dialogue: 0,0:06:03.55,0:06:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa dengan orang-orang ini?
Dialogue: 0,0:06:06.73,0:06:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat menjijikkan.
Dialogue: 0,0:06:11.80,0:06:13.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akan ketahuan oleh mereka nanti.
Dialogue: 0,0:06:13.88,0:06:16.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan, sembunyikan aura keberadaanmu.
Dialogue: 0,0:06:18.14,0:06:19.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bersiaplah untuk berpindah.
Dialogue: 0,0:06:38.47,0:06:39.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siaga tempur.
Dialogue: 0,0:06:50.84,0:06:51.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini?
Dialogue: 0,0:06:54.33,0:06:55.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kepalanya malah...
Dialogue: 0,0:06:57.05,0:06:57.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali.
Dialogue: 0,0:07:09.88,0:07:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:07:13.13,0:07:14.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti kau!
Dialogue: 0,0:07:15.17,0:07:16.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau masih bisa hidup,
Dialogue: 0,0:07:17.91,0:07:20.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}silakan datang kapan saja\Nuntuk membunuhku.
Dialogue: 0,0:07:23.91,0:07:26.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat itu tiba, aku akan\Nmelayanimu sampai akhir.
Dialogue: 0,0:07:27.60,0:07:29.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:07:43.28,0:07:44.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:07:45.52,0:07:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lelucon macam apa ini?
Dialogue: 0,0:07:52.67,0:07:53.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar saja.
Dialogue: 0,0:08:00.33,0:08:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sialan!
Dialogue: 0,0:08:10.84,0:08:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika tertusuk benda semacam itu,
Dialogue: 0,0:08:17.10,0:08:19.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}benar-benar akan jadi masalah besar!
Dialogue: 0,0:08:23.49,0:08:24.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:08:26.15,0:08:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial!
Dialogue: 0,0:08:30.21,0:08:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenryuubito sialan.
Dialogue: 0,0:08:46.35,0:08:50.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mau menundukkan Elbaph\Ndengan cepat masih terlalu sulit.
Dialogue: 0,0:08:50.90,0:08:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah tadi katanya akan\Nmengubah rencana pertempurannya?
Dialogue: 0,0:08:53.44,0:08:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:08:55.38,0:08:59.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kendalikan anak-anak prajurit\NSuku Raksasa terlebih dahulu,
Dialogue: 0,0:09:05.39,0:09:07.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu panggil satu orang lagi kemari.
Dialogue: 0,0:09:08.89,0:09:09.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:09:28.12,0:09:29.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Omong kosong!
Dialogue: 0,0:09:30.97,0:09:34.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin Shanks menerbangkan\Nkalian tanpa alasan?
Dialogue: 0,0:09:37.68,0:09:42.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, ini sungguhan.
Dialogue: 0,0:09:42.82,0:09:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memang...\Nmemang benar si Rambut Merah.
Dialogue: 0,0:09:49.51,0:09:55.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut Merah sudah sering datang ke\NElbaph, seharusnya kami tidak salah lihat.
Dialogue: 0,0:10:00.41,0:10:02.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu, pasti begitu kejadiannya.
Dialogue: 0,0:10:02.53,0:10:06.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia memuja Shanks,\Njadi berpura-pura menjadi dirinya.
Dialogue: 0,0:10:06.52,0:10:09.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Shanks memang sangat keren, ya.
Dialogue: 0,0:10:10.00,0:10:10.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berpura-pura?
Dialogue: 0,0:10:11.53,0:10:12.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:13.13,0:10:14.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah sangat mirip?
Dialogue: 0,0:10:15.49,0:10:16.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:10:16.86,0:10:17.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Luffy,
Dialogue: 0,0:10:19.26,0:10:22.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}baru-baru ini Rambut Merah\Ndatang ke Elbaph, 'kan?
Dialogue: 0,0:10:22.62,0:10:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak aneh jika dia masih ada di sini.
Dialogue: 0,0:10:25.20,0:10:25.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:10:26.55,0:10:29.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika apa yang kalian katakan benar,\Nitu pasti bukan Shanks.
Dialogue: 0,0:10:30.67,0:10:34.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Shanks adalah orang yang jujur dan adil,\Ndia tidak akan bersikap arogan.
Dialogue: 0,0:10:34.87,0:10:39.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sama sekali tidak akan melakukan hal\Nyang tidak masuk akal seperti ini!
Dialogue: 0,0:10:44.23,0:10:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sangat memercayainya, ya.
Dialogue: 0,0:10:46.93,0:10:47.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:10:48.29,0:10:49.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami, juga begitu, 'kan?
Dialogue: 0,0:10:49.64,0:10:53.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika ada yang menjelek-jelekkan Morimere,\Nkau juga akan marah, 'kan?
Dialogue: 0,0:10:53.69,0:10:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang benar Bell-mère.
Dialogue: 0,0:10:59.64,0:11:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kesimpulannya,
Dialogue: 0,0:11:01.33,0:11:04.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang kalian lihat itu\Nsudah pasti bukan Shanks.
Dialogue: 0,0:11:05.44,0:11:08.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, dia adalah\Norang yang berwajah sama.
Dialogue: 0,0:11:09.14,0:11:11.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau mungkin saudaranya.
Dialogue: 0,0:11:14.70,0:11:16.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saudaranya Shanks?
Dialogue: 0,0:11:17.95,0:11:21.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika dia benar-benar punya saudara,\Norang itu pasti orang baik juga, 'kan?
Dialogue: 0,0:11:21.25,0:11:22.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, omong-omong...
Dialogue: 0,0:11:32.73,0:11:36.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah bertanya\Ntentang keluarganya.
Dialogue: 0,0:11:38.11,0:11:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya dia sudah berada\Ndi kapal bajak laut sejak kecil.
Dialogue: 0,0:11:43.78,0:11:46.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keluarganya pastilah Roger, Rayleigh,\Ndan yang lainnya, 'kan?
Dialogue: 0,0:11:47.00,0:11:48.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajak Laut Roger!
Dialogue: 0,0:11:48.92,0:11:50.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kecuali Buggy.
Dialogue: 0,0:12:14.01,0:12:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Lokasi Franky\N(mengunjungi Pohon Harta Adam)]
Dialogue: 0,0:12:18.31,0:12:19.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sana,
Dialogue: 0,0:12:19.71,0:12:20.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta sebelah sini.
Dialogue: 0,0:12:21.50,0:12:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:12:23.35,0:12:24.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:12:25.24,0:12:26.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya Adam.
Dialogue: 0,0:12:28.88,0:12:33.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Waktu itu, mendapatkan sebagian saja\Nsudah menghabiskan 200 juta.
Dialogue: 0,0:12:36.32,0:12:39.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini masih bisa disebut langka?
Dialogue: 0,0:12:42.27,0:12:45.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ternyata berharga begitu\Ndi luar negeri?
Dialogue: 0,0:12:49.64,0:12:51.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana kalau aku\Nmengambilnya untuk dijual?
Dialogue: 0,0:12:51.85,0:12:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan begitu, posisimu seharusnya\Nmencegah hal itu, 'kan, Ripley?
Dialogue: 0,0:12:54.91,0:12:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjual sedikit saja tidak apa-apa, 'kan?
Dialogue: 0,0:12:57.00,0:12:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku malah dimarahi\Nhabis-habisan oleh Saul, tahu.
Dialogue: 0,0:13:01.24,0:13:04.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah pohon suci,\Njadi tidak boleh ditebang.
Dialogue: 0,0:13:10.23,0:13:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat mirip! Ada apa dengan kepalamu itu?
Dialogue: 0,0:13:15.18,0:13:16.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:13:20.01,0:13:24.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kupikir kita harus menyelundupkannya\Nkeluar tanpa diketahui Suku Raksasa.
Dialogue: 0,0:13:26.67,0:13:28.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pantas saja harganya sangat tinggi.
Dialogue: 0,0:13:30.65,0:13:32.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lihat itu.
Dialogue: 0,0:13:34.91,0:13:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:13:37.31,0:13:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah mural.
Dialogue: 0,0:13:38.82,0:13:39.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mural?
Dialogue: 0,0:13:40.23,0:13:40.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:13:41.64,0:13:44.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coretan anak-anak dari zaman dahulu kala
Dialogue: 0,0:13:44.15,0:13:46.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang diukir pada kulit kayu\Ndan sudah membatu.
Dialogue: 0,0:13:46.93,0:13:50.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu memiliki nilai sejarah\Nsehingga menjadi warisan budaya nasional.
Dialogue: 0,0:13:50.99,0:13:55.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin melihat\Ncoretan itu lebih dekat lagi.
Dialogue: 0,0:13:57.00,0:14:02.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menurut perkiraan, ini digambar\Nsaat 800 atau 900 tahun yang lalu.
Dialogue: 0,0:14:03.32,0:14:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika perkiraan itu tidak salah,
Dialogue: 0,0:14:05.38,0:14:08.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maka itu bertepatan\Ndengan era Void Century.
Dialogue: 0,0:14:13.82,0:14:15.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Void Century?
Dialogue: 0,0:14:17.18,0:14:20.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, kita harus memperlihatkannya\Nkepada Robin.
Dialogue: 0,0:14:21.95,0:14:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beri tahu dia nanti, ya.
Dialogue: 0,0:14:34.75,0:14:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:14:37.11,0:14:39.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ini agak aneh untuk ukuran\Nlukisan dari Elbaph.
Dialogue: 0,0:14:40.62,0:14:43.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini tidak terlihat\Nseperti Suku Raksasa.
Dialogue: 0,0:14:44.93,0:14:48.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:14:48.87,0:14:51.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun ada perang antarsuku,
Dialogue: 0,0:14:51.45,0:14:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seharusnya tidak pernah ada\Nkomunikasi antarsuku.
Dialogue: 0,0:14:54.77,0:14:57.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hal ini makin menjelaskan,
Dialogue: 0,0:14:58.23,0:15:02.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin itu hanya impian anak-anak.
Dialogue: 0,0:15:15.57,0:15:16.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:15:20.67,0:15:23.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sangat bersemangat, bagus sekali.
Dialogue: 0,0:15:34.65,0:15:35.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sini!
Dialogue: 0,0:15:37.62,0:15:39.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:15:39.25,0:15:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Skaldi.
Dialogue: 0,0:15:42.76,0:15:46.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, 5 ditambah 3 sama dengan berapa?
Dialogue: 0,0:15:49.07,0:15:52.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Ylva, nanti saat istirahat\Nkita mau melakukan apa?
Dialogue: 0,0:15:54.06,0:15:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi memetik bunga, lalu...
Dialogue: 0,0:15:56.34,0:15:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin bermain ayunan.
Dialogue: 0,0:15:58.58,0:15:59.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:15:59.77,0:16:02.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin adu panco.
Dialogue: 0,0:16:03.60,0:16:06.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, hanya kau\Nsendiri yang bisa menang, Mag.
Dialogue: 0,0:16:06.47,0:16:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, begitukah?
Dialogue: 0,0:16:09.01,0:16:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:16:11.83,0:16:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, semuanya,\Nkita masih ada di dalam kelas.
Dialogue: 0,0:16:14.75,0:16:15.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:16:18.61,0:16:20.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingin cepat-cepat pergi bermain.
Dialogue: 0,0:16:27.09,0:16:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat seharusnya ada di sebelah sini.
Dialogue: 0,0:16:33.18,0:16:36.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku menemukannya.
Dialogue: 0,0:16:46.26,0:16:48.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Banyak sekali debunya.
Dialogue: 0,0:16:48.34,0:16:50.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, ini benar-benar terlalu kuno.
Dialogue: 0,0:16:54.05,0:16:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini dia.
Dialogue: 0,0:16:56.60,0:16:57.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kitab Dewa?
Dialogue: 0,0:16:58.33,0:17:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat besar dan sangat usang.
Dialogue: 0,0:17:01.52,0:17:03.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdasarkan teks asli inilah
Dialogue: 0,0:17:04.00,0:17:07.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}berbagai mitos dan cerita di Elbaph lahir.
Dialogue: 0,0:17:08.94,0:17:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada bermacam-macam\Ninterpretasi mengenainya.
Dialogue: 0,0:17:12.88,0:17:13.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula,
Dialogue: 0,0:17:14.99,0:17:18.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Matahari yang disembah\Noleh para prajurit Elbaph
Dialogue: 0,0:17:18.72,0:17:21.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}memiliki kepribadian yang berbeda-beda.
Dialogue: 0,0:17:26.23,0:17:29.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang menyebutnya\Nsebagai Dewa Penguasa.
Dialogue: 0,0:17:29.36,0:17:32.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada orang yang menyebutnya\Nsebagai Dewa Pembebas.
Dialogue: 0,0:17:32.68,0:17:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada pula yang menyebutnya\Nsebagai Dewa Penghancur.
Dialogue: 0,0:17:43.92,0:17:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat memuaskan, ya.
Dialogue: 0,0:17:46.03,0:17:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Hajrudin.
Dialogue: 0,0:17:48.46,0:17:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, seperti biasa.
Dialogue: 0,0:17:50.63,0:17:51.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku datang.
Dialogue: 0,0:17:53.16,0:17:55.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali, biarkan mereka melihatnya.
Dialogue: 0,0:18:05.98,0:18:09.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana, Robin, menarik, 'kan?
Dialogue: 0,0:18:09.50,0:18:12.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, sangat menarik.
Dialogue: 0,0:18:13.04,0:18:15.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sama sekali tidak bisa membacanya.
Dialogue: 0,0:18:15.28,0:18:17.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang tertulis di atasnya, Robin?
Dialogue: 0,0:18:18.92,0:18:19.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boleh kubacakan?
Dialogue: 0,0:18:20.05,0:18:21.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:18:22.00,0:18:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ceritanya memiliki tiga bab.
Dialogue: 0,0:18:24.36,0:18:27.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ketiga konon adalah\Ndunia yang sekarang ini.
Dialogue: 0,0:18:28.56,0:18:32.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kata lain, itu adalah hal\Nyang akan terjadi di masa depan.
Dialogue: 0,0:18:33.37,0:18:38.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalamnya disebutkan bahwa sebenarnya\Nwarisan Nika tersembunyi di dunia.
Dialogue: 0,0:18:38.96,0:18:44.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Titik persamaannya itu dia muncul sambil\Ntertawa terbahak-bahak dengan ritme ini.
Dialogue: 0,0:18:45.93,0:18:56.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dum-dum-dum, dum-dum-dum.
Dialogue: 0,0:18:57.07,0:19:05.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dum-dum-dum, dum-dum-dum.
Dialogue: 0,0:19:05.99,0:19:14.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dum-dum-dum, dum-dum-dum.
Dialogue: 0,0:19:15.18,0:19:17.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku akan membacakannya.
Dialogue: 0,0:19:18.98,0:19:20.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia pertama.
Dialogue: 0,0:19:26.70,0:19:28.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Api membakar bumi.
Dialogue: 0,0:19:30.65,0:19:32.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia kalah oleh hasrat.
Dialogue: 0,0:19:33.11,0:19:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka menyentuh matahari yang terlarang.
Dialogue: 0,0:19:36.93,0:19:38.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para budak berdoa.
Dialogue: 0,0:19:38.93,0:19:41.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Matahari menampakkan diri.
Dialogue: 0,0:19:43.15,0:19:47.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Bumi murka,\Nlalu ia menyelimuti dunia
Dialogue: 0,0:19:47.44,0:19:50.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dengan kematian dan kegelapan\Nbersama ular api neraka.
Dialogue: 0,0:19:51.11,0:19:53.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak akan pernah\Nbisa bertemu lagi.
Dialogue: 0,0:20:01.03,0:20:02.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia kedua.
Dialogue: 0,0:20:05.37,0:20:07.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Napas kehidupan lahir dari ketiadaan.
Dialogue: 0,0:20:07.55,0:20:10.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Hutan mengutus monster.
Dialogue: 0,0:20:10.62,0:20:13.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matahari terus-menerus\Nmemperluas api peperangan.
Dialogue: 0,0:20:15.78,0:20:18.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia setengah bulan bermimpi.
Dialogue: 0,0:20:18.79,0:20:21.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia bulan bermimpi.
Dialogue: 0,0:20:21.61,0:20:25.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia membunuh matahari\Ndan menyegel dewa.
Dialogue: 0,0:20:25.41,0:20:28.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Laut mengamuk.
Dialogue: 0,0:20:31.85,0:20:34.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak akan pernah\Nbisa bertemu lagi.
Dialogue: 0,0:20:42.90,0:20:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia ketiga.
Dialogue: 0,0:20:48.48,0:20:50.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kekosongan muncul di tengah kekacauan.
Dialogue: 0,0:20:51.09,0:20:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bayangan yang waktunya tidak tepat\Nmengingat hari yang dijanjikan.
Dialogue: 0,0:20:55.95,0:20:58.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka mendengarkan suara bulan sabit.
Dialogue: 0,0:20:59.51,0:21:02.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dewa Matahari menari dan tertawa.
Dialogue: 0,0:21:03.19,0:21:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Membawa dunia menuju akhir.
Dialogue: 0,0:21:06.65,0:21:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matahari kembali.
Dialogue: 0,0:21:08.88,0:21:10.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Fajar yang baru pun tiba.
Dialogue: 0,0:21:14.67,0:21:17.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka pasti akan bertemu kembali.
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
