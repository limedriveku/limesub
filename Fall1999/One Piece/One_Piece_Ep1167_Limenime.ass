Dialogue: 0,0:00:21.28,0:00:23.32,sign,,0000,0000,0000,,{\an8}[One Piece]\N[Episode 1167]
Dialogue: 0,0:12:58.63,0:13:00.88,sign,,0000,0000,0000,,{\an8}[Desa Barat]
Dialogue: 0,0:14:04.85,0:14:08.44,sign,,0000,0000,0000,,{\an8}[Dunia Bawah]
Dialogue: 0,0:21:24.65,0:21:30.67,sign,,0000,0000,0000,,[Bersambung]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:01:50.12,0:01:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Komandan Kelompok Kesatria Dewa,\NShamrock muncul.
Dialogue: 0,0:01:59.97,0:02:01.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi kita akan sampai.
Dialogue: 0,0:02:11.29,0:02:17.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah tempat tinggal Raja Kejayaan yang\Nnamanya tercatat dalam sejarah Elbaph,
Dialogue: 0,0:02:17.61,0:02:19.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel Aurust.
Dialogue: 0,0:02:19.78,0:02:23.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wah, besar sekali!
Dialogue: 0,0:02:29.35,0:02:30.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita sudah sampai.
Dialogue: 0,0:02:32.03,0:02:32.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy!
Dialogue: 0,0:02:33.49,0:02:36.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya ampun, dia tidak bisa diam sedetik pun.
Dialogue: 0,0:02:37.40,0:02:38.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:02:46.35,0:02:48.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keren sekali.
Dialogue: 0,0:02:49.96,0:02:53.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Untuk ukuran kastel\Nseorang raja, ini terlalu sepi.
Dialogue: 0,0:02:53.99,0:02:56.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Harald telah wafat\N14 tahun yang lalu.
Dialogue: 0,0:02:56.78,0:02:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada orang yang mendekati kastel ini.
Dialogue: 0,0:03:00.57,0:03:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, sepertinya kita bisa masuk dari sini.
Dialogue: 0,0:03:05.77,0:03:07.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meski begitu!
Dialogue: 0,0:03:07.87,0:03:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerbang ini jelas-jelas telah dirusak.
Dialogue: 0,0:03:11.30,0:03:12.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaganya juga tidak ada.
Dialogue: 0,0:03:13.23,0:03:14.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah mungkin ada penyusup?
Dialogue: 0,0:03:15.08,0:03:16.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasanya episode ini fokus\Nke masa lalu yang kelam!
Dialogue: 0,0:03:16.79,0:03:19.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini, jangan-jangan\Nsituasinya gawat?
Dialogue: 0,0:03:19.95,0:03:20.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:03:20.97,0:03:21.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti.
Dialogue: 0,0:03:22.49,0:03:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, kau ini!
Dialogue: 0,0:03:26.91,0:03:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penyusup?
Dialogue: 0,0:03:30.43,0:03:32.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tenang sedikit!
Dialogue: 0,0:03:37.48,0:03:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pintu ini, dirusak dari dalam.
Dialogue: 0,0:03:40.92,0:03:42.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekas kerusakannya juga masih baru.
Dialogue: 0,0:03:43.07,0:03:46.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mengerti, bagaimana\Nsebenarnya dia bisa masuk?
Dialogue: 0,0:03:50.60,0:03:52.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita akan tahu setelah masuk ke sana.
Dialogue: 0,0:03:53.19,0:03:55.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci!
Dialogue: 0,0:03:55.54,0:03:57.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar, Luffy!
Dialogue: 0,0:03:59.16,0:04:00.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, tunggu sebentar.
Dialogue: 0,0:04:03.62,0:04:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci!
Dialogue: 0,0:04:24.65,0:04:27.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel yang sangat besar.
Dialogue: 0,0:04:27.75,0:04:29.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan langit-langitnya\Ntidak terlihat.
Dialogue: 0,0:04:29.91,0:04:32.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu besar,\Naku tidak sanggup berjalan.
Dialogue: 0,0:04:36.26,0:04:38.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sedang apa kau di sana?
Dialogue: 0,0:04:38.63,0:04:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak melakukan apa-apa,\Nhanya saja aku merasa takut.
Dialogue: 0,0:04:45.51,0:04:49.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah ke mari, antarkan kami ke sana.
Dialogue: 0,0:04:52.87,0:04:54.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan senang hati.
Dialogue: 0,0:04:59.92,0:05:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:05:04.71,0:05:05.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini lumayan juga.
Dialogue: 0,0:05:11.52,0:05:14.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Road, kuncinya ada di mana?
Dialogue: 0,0:05:14.95,0:05:18.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau soal itu, sebenarnya, hamba\Njuga hanyalah manusia biasa
Dialogue: 0,0:05:18.81,0:05:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang belum pernah\Nmasuk ke dalam kastel ini.
Dialogue: 0,0:05:21.27,0:05:23.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Kau tidak tahu?
Dialogue: 0,0:05:23.62,0:05:25.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamba merasa malu.
Dialogue: 0,0:05:25.61,0:05:28.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa, untung saja ada kau.
Dialogue: 0,0:05:29.48,0:05:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami-tasso.
Dialogue: 0,0:05:31.04,0:05:33.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga berpikir begitu,\Nbaiklah, ayo maju.
Dialogue: 0,0:05:34.12,0:05:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zoro-tasso.
Dialogue: 0,0:05:46.51,0:05:48.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah bagian dalam kastelnya.
Dialogue: 0,0:05:53.24,0:05:56.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rasa haru dan ketakutan\Nmenyerang secara bersamaan.
Dialogue: 0,0:05:58.15,0:05:59.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar seperti reruntuhan.
Dialogue: 0,0:06:00.00,0:06:00.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:06:01.25,0:06:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam kastel juga ada\Npohon yang sangat besar.
Dialogue: 0,0:06:14.18,0:06:17.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, apakah ada orang?
Dialogue: 0,0:06:20.31,0:06:22.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya ada sesuatu di sebelah sana.
Dialogue: 0,0:06:36.80,0:06:40.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya telah dirusak,\Napakah ini ulah penyusup?
Dialogue: 0,0:06:41.47,0:06:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan.
Dialogue: 0,0:06:42.24,0:06:47.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Harald wafat setelah bertarung sengit\Ndengan Loki.
Dialogue: 0,0:06:47.68,0:06:50.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bekas pertarungan\Npada saat itu masih tersisa.
Dialogue: 0,0:06:50.13,0:06:52.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daya hancurnya benar-benar luar biasa.
Dialogue: 0,0:06:52.59,0:06:54.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun Loki adalah seorang monster,
Dialogue: 0,0:06:54.88,0:06:58.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi Raja Harald juga merupakan\Npejuang hebat yang terkenal.
Dialogue: 0,0:06:58.99,0:07:01.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehancuran kastel memang\Ntidak dapat dihindari.
Dialogue: 0,0:07:04.01,0:07:04.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:07:05.03,0:07:05.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy-tasso.
Dialogue: 0,0:07:15.85,0:07:17.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy-tasso.
Dialogue: 0,0:07:18.11,0:07:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia pergi ke mana?
Dialogue: 0,0:07:20.28,0:07:21.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy-tasso.
Dialogue: 0,0:07:22.06,0:07:24.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah terjadi sesuatu?
Dialogue: 0,0:07:32.43,0:07:36.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lihat, semuanya adalah\Ntulang belulang raksasa yang sangat besar.
Dialogue: 0,0:07:39.23,0:07:41.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa ini, menakutkan sekali!
Dialogue: 0,0:07:42.13,0:07:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamba juga merasa takut.
Dialogue: 0,0:07:44.67,0:07:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika dipikir-pikir lagi,\Nini adalah hal yang wajar.
Dialogue: 0,0:07:47.52,0:07:49.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam kastel terdapat banyak prajurit.
Dialogue: 0,0:07:50.13,0:07:54.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada hari itu, lebih dari 100 orang\Nprajurit dibunuh oleh Loki.
Dialogue: 0,0:07:54.32,0:07:57.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang bertahan hidup hanyalah\NTuan Jarul dan Loki.
Dialogue: 0,0:08:03.01,0:08:04.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Insiden ini terlalu tragis,
Dialogue: 0,0:08:05.28,0:08:09.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sehingga sejak saat itu\Nkastel dilarang untuk dimasuki.
Dialogue: 0,0:08:11.14,0:08:14.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah tempat ini benar-benar\Nsarang arwah penasaran?
Dialogue: 0,0:08:14.44,0:08:16.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Heh, membosankan.
Dialogue: 0,0:08:16.60,0:08:18.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, cepat kalian lihat.
Dialogue: 0,0:08:19.13,0:08:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tengkorak ini besar sekali.
Dialogue: 0,0:08:24.16,0:08:25.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:08:28.01,0:08:29.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ia juga memiliki tanduk.
Dialogue: 0,0:08:30.52,0:08:31.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia teman Oars?
Dialogue: 0,0:08:39.73,0:08:43.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kerangka raksasa ini milik prajurit yang\Npunya garis keturunan Suku Raksasa kuno.
Dialogue: 0,0:08:43.94,0:08:45.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku Raksasa kuno berdarah murni\Nsudah tidak ada lagi,
Dialogue: 0,0:08:45.66,0:08:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi masih ada orang\Nyang mewarisi garis keturunannya.
Dialogue: 0,0:08:49.39,0:08:50.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jujur pada kalian,
Dialogue: 0,0:08:50.55,0:08:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Raja Harald juga sangat tinggi dan kuat.
Dialogue: 0,0:09:02.58,0:09:04.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan lihat ke atas.
Dialogue: 0,0:09:04.70,0:09:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah potret Raja Harald.
Dialogue: 0,0:09:10.28,0:09:12.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar membuatku rindu.
Dialogue: 0,0:09:12.24,0:09:13.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau sangat mencintai perdamaian
Dialogue: 0,0:09:13.63,0:09:17.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan berusaha untuk menghubungkan\NElbaph dengan berbagai negara di dunia.
Dialogue: 0,0:09:17.25,0:09:21.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang-orang menyebut beliau\Nsebagai raja terbaik dalam sejarah Elbaph.
Dialogue: 0,0:09:24.76,0:09:26.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia terlihat sangat kuat.
Dialogue: 0,0:09:27.36,0:09:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luka di kepalanya,
Dialogue: 0,0:09:28.79,0:09:33.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akibat tindakannya merobek tanduk\Nyang melambangkan Suku Raksasa kuno.
Dialogue: 0,0:09:33.82,0:09:38.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena Suku Raksasa kuno akan membuat\Norang teringat pada zaman peperangan.
Dialogue: 0,0:09:42.91,0:09:44.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata beliau memiliki tanduk.
Dialogue: 0,0:09:44.54,0:09:45.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Beliau merobeknya.
Dialogue: 0,0:09:46.93,0:09:48.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tekad yang sungguh luar biasa.
Dialogue: 0,0:09:54.73,0:09:56.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci!
Dialogue: 0,0:09:58.42,0:10:02.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kematian Raja membuat semua orang\Njatuh ke dalam keputusasaan.
Dialogue: 0,0:10:02.08,0:10:05.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, orang yang paling bersedih\Ndan membenci Loki
Dialogue: 0,0:10:05.02,0:10:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah putra Raja Harald yang lain,
Dialogue: 0,0:10:07.47,0:10:08.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yaitu Hajrudin.
Dialogue: 0,0:10:09.47,0:10:10.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Putra Raja?
Dialogue: 0,0:10:11.42,0:10:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajrudin?
Dialogue: 0,0:10:14.24,0:10:15.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata begitu?
Dialogue: 0,0:10:15.77,0:10:19.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudnya, apakah Hajrudin\Ndan Loki bersaudara?
Dialogue: 0,0:10:21.46,0:10:23.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka adalah saudara tiri berbeda ibu.
Dialogue: 0,0:10:23.99,0:10:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum menikah dengan Ratu, beliau\Nmemiliki Hajrudin dengan wanita lain.
Dialogue: 0,0:10:29.96,0:10:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, Elbaph tidak mengizinkan\Nibu Hajrudin menjadi ratu.
Dialogue: 0,0:10:36.85,0:10:37.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa?
Dialogue: 0,0:10:38.92,0:10:43.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena ibunya lahir\Ndi negara raksasa yang lain.
Dialogue: 0,0:10:52.19,0:10:55.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangga ini mengarah ke mana?
Dialogue: 0,0:11:06.21,0:11:09.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, mereka sama-sama Suku Raksasa,\Ntidak ada bedanya, 'kan?
Dialogue: 0,0:11:09.75,0:11:11.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun sama-sama Suku Raksasa,
Dialogue: 0,0:11:12.60,0:11:17.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bukankah kalian bangsa manusia\Njuga saling memperebutkan wilayah?
Dialogue: 0,0:11:17.48,0:11:18.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:11:18.61,0:11:23.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Garis keturunan raksasa dari wilayah lain\Nakan mencemari garis keturunan Elbaph.
Dialogue: 0,0:11:23.90,0:11:27.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terkadang kau cukup diskriminatif terhadap\Norang lain, begitu juga terhadap manusia.
Dialogue: 0,0:11:27.26,0:11:30.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami-tasso sangat berbeda.
Dialogue: 0,0:11:30.40,0:11:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku juga\Ntidak senang, dasar hina.
Dialogue: 0,0:11:33.91,0:11:34.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mengapa kau
Dialogue: 0,0:11:36.23,0:11:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bergabung dengan kapal Hajrudin\Nyang memiliki garis keturunan tidak murni?
Dialogue: 0,0:11:42.62,0:11:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal itu dikarenakan...
Dialogue: 0,0:11:46.16,0:11:47.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan.
Dialogue: 0,0:11:48.15,0:11:49.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu si Road anak rumahan akut!
Dialogue: 0,0:11:49.63,0:11:50.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menjijikkan sekali.
Dialogue: 0,0:11:51.04,0:11:53.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah bermain boneka itu menyenangkan?
Dialogue: 0,0:11:53.25,0:11:54.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar anak rumahan akut.
Dialogue: 0,0:12:10.40,0:12:11.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajrudin.
Dialogue: 0,0:12:21.57,0:12:23.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau bisa menggambar peta navigasi?
Dialogue: 0,0:12:25.93,0:12:27.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:12:29.31,0:12:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ajari aku juga bagaimana cara\Nmenggambar peta navigasi.
Dialogue: 0,0:12:32.73,0:12:34.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita berteman.
Dialogue: 0,0:12:36.74,0:12:38.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman.
Dialogue: 0,0:12:39.77,0:12:44.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu berbeda dengan hamba,\Ndia adalah pria yang sangat jujur.
Dialogue: 0,0:12:45.11,0:12:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun ayahnya adalah seorang raja,\Ndia tidak bisa tinggal di dalam kastel.
Dialogue: 0,0:12:47.76,0:12:51.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia selalu menahan diri ketika ditindas\Nkarena ibunya adalah orang asing,
Dialogue: 0,0:12:51.06,0:12:53.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tetapi dia bisa mengucapkan kata-kata
Dialogue: 0,0:12:53.79,0:12:57.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}seperti dia ingin menyatukan\Nseluruh Suku Raksasa di dunia.
Dialogue: 0,0:13:03.00,0:13:03.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku adalah
Dialogue: 0,0:13:04.44,0:13:08.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pria yang akan menjadi\Nraja bagi seluruh Suku Raksasa!
Dialogue: 0,0:13:10.01,0:13:11.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti bisa melakukannya!
Dialogue: 0,0:13:12.03,0:13:14.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan mengikutimu\Nsampai ke ujung dunia!
Dialogue: 0,0:13:15.93,0:13:19.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah yang disebut dengan pejuang lautan\Nyang pemberani.
Dialogue: 0,0:13:21.82,0:13:25.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hamba ingin membantunya\Nmewujudkan impian tersebut.
Dialogue: 0,0:13:26.62,0:13:29.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa-apaan? Ternyata kau adalah\Norang yang memiliki akal sehat juga.
Dialogue: 0,0:13:29.40,0:13:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat membosankan.
Dialogue: 0,0:13:32.06,0:13:33.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:13:34.63,0:13:36.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian cepat kemari.
Dialogue: 0,0:13:37.10,0:13:39.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini ada apa lagi, Luffy?
Dialogue: 0,0:13:39.79,0:13:41.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada raksasa yang terkapar di sini.
Dialogue: 0,0:14:40.43,0:14:42.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sudah cukup memahaminya, bukan?
Dialogue: 0,0:14:49.56,0:14:50.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi,
Dialogue: 0,0:14:52.18,0:14:54.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku tidak bisa bergerak.
Dialogue: 0,0:14:55.65,0:14:58.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walaupun kau bisa bergerak,\Nhasilnya akan tetap sama.
Dialogue: 0,0:15:19.83,0:15:21.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rakyat jelata sepertimu,
Dialogue: 0,0:15:22.03,0:15:26.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebesar apa pun kau mendambakan untuk jadi\Ndewa, itu hanya omong kosong belaka.
Dialogue: 0,0:15:27.72,0:15:31.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat ini kami telah meletakkan\Nkesempatan tersebut di depan matamu.
Dialogue: 0,0:15:38.37,0:15:39.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu datang lagi?
Dialogue: 0,0:15:46.68,0:15:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Saat kau mempercepat lajumu\Ndan menendang pipi kananku,
Dialogue: 0,0:15:50.12,0:15:52.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}begitu aku menolehkan kepalaku,
Dialogue: 0,0:15:53.49,0:15:56.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kau akan menggunakan tinjumu\Nuntuk memukul daguku.
Dialogue: 0,0:15:58.51,0:16:00.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih banyak atas peringatanmu.
Dialogue: 0,0:16:01.82,0:16:05.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanda panah itu adalah jalur pasti\Nuntuk masa depanku
Dialogue: 0,0:16:06.02,0:16:09.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan merupakan sebuah deklarasi\Nkekerasan yang tidak bisa dihindari.
Dialogue: 0,0:16:09.08,0:16:09.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun,
Dialogue: 0,0:16:10.41,0:16:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku juga bisa menghentikan tanganku.
Dialogue: 0,0:16:17.91,0:16:20.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertanya sekali lagi, Loki.
Dialogue: 0,0:16:28.34,0:16:32.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Gunko, Keluarga Manmayer\N(orang dengan kekuatan buah Arrow-Arrow)]
Dialogue: 0,0:16:29.18,0:16:32.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau mau bergabung\Ndengan Kelompok Kesatria Dewa?
Dialogue: 0,0:16:46.20,0:16:49.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak mau, dasar bodoh.
Dialogue: 0,0:17:21.04,0:17:23.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sialan, ingatlah ini baik-baik.
Dialogue: 0,0:17:36.26,0:17:38.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, itu sudah cukup!
Dialogue: 0,0:17:41.66,0:17:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, apakah kau mau\Nbergabung dengan Kelompok Kesatria Dewa?
Dialogue: 0,0:17:52.12,0:17:53.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat tidak sopan.
Dialogue: 0,0:20:09.49,0:20:11.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup, Gunko.
Dialogue: 0,0:20:14.45,0:20:16.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari kita ubah rencana pertempurannya.
Dialogue: 0,0:20:21.47,0:20:23.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hubungilah Marijoa dulu.
Dialogue: 0,0:20:26.46,0:20:29.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka semua adalah orang-orang\Nyang tidak bisa diandalkan.
Dialogue: 0,0:20:38.45,0:20:42.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awalnya aku ingin menyelesaikan\Nmasalah ini dengan lebih fleksibel.
Dialogue: 0,0:20:51.79,0:20:55.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Komandan Kelompok Kesatria Dewa\N(Bangsawan Dunia)]\N[Keluarga Figarland,\NShamrock (Putra Garling, Kelima Tetua)]
Dialogue: 0,0:20:59.56,0:21:02.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, orang ini sepertinya tidak mau\Nberbicara sampai mati.
Dialogue: 0,0:21:02.80,0:21:04.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah dia memiliki suatu keyakinan?
Dialogue: 0,0:21:05.79,0:21:08.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka memang kekuatan tempur\Nyang luar biasa.
Dialogue: 0,0:21:10.37,0:21:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menempatkan\Npara prajurit Elbaph yang ganas
Dialogue: 0,0:21:14.50,0:21:17.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang sejak dahulu\Ntelah menaklukkan New World ini,
Dialogue: 0,0:21:18.46,0:21:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}untuk berada di bawah komando\NPemerintah Dunia kita.
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
Dialogue: 0,0:23:05.03,0:23:06.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Franky menemukan sebuah mural
Dialogue: 0,0:23:06.28,0:23:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memuat catatan tentang era\N"Void Century" yang jauh di masa lalu.
Dialogue: 0,0:23:10.98,0:23:12.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang tergambar di atasnya
Dialogue: 0,0:23:12.54,0:23:16.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}adalah kisah tentang Tiga Dunia\Ndan Dewa Matahari Nika.
Dialogue: 0,0:23:16.61,0:23:19.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kehancuran dan kelahiran,\Nmasa lalu dan masa depan.
Dialogue: 0,0:23:19.09,0:23:21.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah sebenarnya\Nkebenaran dari dunia ini?
Dialogue: 0,0:23:21.26,0:23:22.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode selanjutnya, One Piece.
Dialogue: 0,0:23:22.54,0:23:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Sejarah Kuno, "Kitab Dewa" yang Diwariskan\NSecara Turun-temurun di Elbaph]
Dialogue: 0,0:23:22.70,0:23:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sejarah kuno, "Kitab Dewa" yang diwariskan\Nsecara turun-temurun di Elbaph.
Dialogue: 0,0:23:26.24,0:23:28.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi Raja Bajak Laut!
