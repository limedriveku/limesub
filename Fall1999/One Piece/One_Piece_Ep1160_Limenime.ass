Dialogue: 0,0:00:21.28,0:00:23.32,tanda,,0,0,0,,{\an8}[One Piece]\N[Episode 1160]
Dialogue: 0,0:13:31.46,0:13:35.93,tanda,,0,0,0,,{\an8}[Buronan]
Dialogue: 0,0:13:51.03,0:13:54.00,tanda,,0,0,0,,{\an8}[Buronan Dorry, Hidup atau Mati]\N[Buronan Brogy, Hidup atau Mati]
Dialogue: 0,0:14:18.22,0:14:21.99,tanda,,0,0,0,,{\an8}[Berita Dunia, Angkatan Laut]
Dialogue: 0,0:14:33.22,0:14:35.91,tanda,,0,0,0,,{\an8}[Membunuh Vegapunk...]
Dialogue: 0,0:21:08.08,0:21:13.65,tanda,,0,0,0,,{\an8}[Elbaph]
Dialogue: 0,0:21:24.66,0:21:30.68,tanda,,0,0,0,,{\an8}[Bersambung]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:02:12.66,0:02:16.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agak berat hati, tetapi kami\Nakan pergi, Negeri Balok Susun.
Dialogue: 0,0:02:16.57,0:02:19.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semoga di luar adalah Elbaph.
Dialogue: 0,0:02:22.38,0:02:28.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gomu-gomu no Kong Gun!
Dialogue: 0,0:02:35.29,0:02:42.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pertemuan di Padang Salju!\NPangeran Loki yang terkutuk.
Dialogue: 0,0:02:48.28,0:02:52.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ke mana Sunny pergi?
Dialogue: 0,0:02:54.31,0:02:55.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Topi Jerami!
Dialogue: 0,0:02:55.94,0:02:57.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Topi Jerami!
Dialogue: 0,0:02:57.68,0:02:59.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Topi Jerami!
Dialogue: 0,0:02:59.79,0:03:01.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepatlah keluar!
Dialogue: 0,0:03:02.06,0:03:03.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Topi Jerami!
Dialogue: 0,0:03:03.98,0:03:05.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Topi Jerami!
Dialogue: 0,0:03:06.21,0:03:07.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah sudah ditemukan?
Dialogue: 0,0:03:07.39,0:03:09.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Belum, tidak ada jejak sama sekali.
Dialogue: 0,0:03:09.64,0:03:10.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa ditemukan.
Dialogue: 0,0:03:11.36,0:03:14.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sudah mencari\Nke seluruh wilayah laut di sekitar sini.
Dialogue: 0,0:03:14.76,0:03:15.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan
Dialogue: 0,0:03:16.30,0:03:18.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}sudah tenggelam ke dasar laut?
Dialogue: 0,0:03:21.77,0:03:24.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, mari kita\Ngeledah dasar lautnya.
Dialogue: 0,0:03:25.61,0:03:29.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajak Laut Prajurit Raksasa,\Nlompatlah ke dalam laut!
Dialogue: 0,0:03:29.24,0:03:30.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:03:31.67,0:03:34.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami datang, Geng Topi Jerami.
Dialogue: 0,0:03:34.61,0:03:36.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bersiap!
Dialogue: 0,0:03:40.38,0:03:43.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudahlah, para prajurit Elbaph.
Dialogue: 0,0:03:49.24,0:03:51.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kau sudah mengetahui sesuatu?
Dialogue: 0,0:03:51.73,0:03:54.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hentikan pencarian.
Dialogue: 0,0:04:11.17,0:04:12.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:04:12.94,0:04:15.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita belum menemukan si Topi Jerami\Ndan yang lainnya.
Dialogue: 0,0:04:15.44,0:04:19.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar, tidak peduli seberapa keras\Nkita mencari, mereka tidak ditemukan.
Dialogue: 0,0:04:20.00,0:04:22.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, mereka pasti baik-baik saja.
Dialogue: 0,0:04:22.64,0:04:26.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, Sunny bukan kapal pemula\Nyang akan tenggelam dengan mudah.
Dialogue: 0,0:04:28.26,0:04:29.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu...
Dialogue: 0,0:04:29.47,0:04:30.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu artinya...
Dialogue: 0,0:04:30.80,0:04:31.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:04:33.00,0:04:34.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka masih hidup.
Dialogue: 0,0:04:34.70,0:04:36.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang-orang itu pasti masih hidup.
Dialogue: 0,0:04:37.88,0:04:38.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:04:39.17,0:04:42.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu juga pernah terjadi\Nsituasi terpisah seperti ini.
Dialogue: 0,0:04:45.90,0:04:47.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ucapan Franky memang benar.
Dialogue: 0,0:04:48.07,0:04:51.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu rupanya, aku pun mengerti.
Dialogue: 0,0:04:51.94,0:04:53.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bos, benar, 'kan?
Dialogue: 0,0:04:55.23,0:04:57.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata kita mengkhawatirkan\Nhal yang sia-sia.
Dialogue: 0,0:04:57.24,0:05:00.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah bertanya kepada\Njaringan informasi hiuku.
Dialogue: 0,0:05:00.83,0:05:04.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka tidak pernah melihat Luffy\Ndan yang lainnya di dalam laut.
Dialogue: 0,0:05:05.26,0:05:09.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika demikian, ada kemungkinan\Nmereka terdampar di sebuah pulau.
Dialogue: 0,0:05:10.19,0:05:14.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian semua sudah berusaha\Nsangat keras untuk membantu kami.
Dialogue: 0,0:05:15.35,0:05:17.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Persediaan makanan\Ndi kapal ini pun sudah habis.
Dialogue: 0,0:05:17.78,0:05:21.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Akan menjadi ironis jika kita membiarkan\Nsemua orang mati kelaparan.
Dialogue: 0,0:05:22.64,0:05:26.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sangat berterima kasih karena kalian\Nsemua telah bantu cari secara langsung.
Dialogue: 0,0:05:26.29,0:05:27.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sangat terharu.
Dialogue: 0,0:05:28.69,0:05:31.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, tujuan kita sudah sangat jelas.
Dialogue: 0,0:05:32.79,0:05:33.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitu, ya.
Dialogue: 0,0:05:34.27,0:05:38.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika teman-temannya sudah berkata begitu,\Nmereka pasti baik-baik saja.
Dialogue: 0,0:05:39.76,0:05:42.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nanti kita tunggu saja mereka di Elbaph.
Dialogue: 0,0:05:42.83,0:05:45.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kawan-Kawan, karena sudah diputuskan,
Dialogue: 0,0:05:45.97,0:05:48.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}mari putar kemudi menuju Elbaph!
Dialogue: 0,0:05:53.97,0:05:55.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari bersulang\Nuntuk kepulangan kita bersama.
Dialogue: 0,0:05:55.61,0:05:58.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bos, minuman keras\Ndan makanannya sudah habis.
Dialogue: 0,0:06:18.36,0:06:21.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita sudah keluar, 'kan?
Dialogue: 0,0:06:22.98,0:06:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dingin sekali.
Dialogue: 0,0:06:28.66,0:06:29.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Salju.
Dialogue: 0,0:06:35.62,0:06:36.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami.
Dialogue: 0,0:06:45.96,0:06:47.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kau baik-baik saja?
Dialogue: 0,0:06:48.52,0:06:49.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau mau pergi ke mana?
Dialogue: 0,0:06:51.51,0:06:54.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dingin sekali, cepatlah kembali ke sini.
Dialogue: 0,0:06:55.47,0:06:56.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Percuma saja, Nami.
Dialogue: 0,0:06:57.00,0:07:01.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejak awal makhluk itu memang\Ntidak berniat untuk pergi bersama kita.
Dialogue: 0,0:07:03.05,0:07:06.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami, jika kau tidak keberatan,\Nsilakan gunakan jubahku.
Dialogue: 0,0:07:06.29,0:07:07.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, Sanji.
Dialogue: 0,0:07:08.26,0:07:10.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, orang bodoh\Ntidak akan terkena flu.
Dialogue: 0,0:07:10.73,0:07:13.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mendengarnya,\Ndasar pendekar pedang bau.
Dialogue: 0,0:07:14.16,0:07:15.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihatlah, Usopp.
Dialogue: 0,0:07:15.75,0:07:16.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:07:19.33,0:07:21.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:07:22.87,0:07:24.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pohon apa ini?
Dialogue: 0,0:07:26.66,0:07:28.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini bukan sebuah ciptaan lagi, 'kan?
Dialogue: 0,0:07:31.74,0:07:32.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami.
Dialogue: 0,0:07:34.50,0:07:35.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya ini...
Dialogue: 0,0:07:36.65,0:07:39.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah berapa ribu tahun usia pohon ini?
Dialogue: 0,0:07:39.11,0:07:42.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya adalah pohon-pohon seperti ini!
Dialogue: 0,0:07:45.39,0:07:48.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terlalu besar, apakah itu gunung?
Dialogue: 0,0:07:48.64,0:07:50.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ukurannya sudah sebesar sebuah pulau.
Dialogue: 0,0:07:50.47,0:07:53.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan, ini bahkan lebih besar\Ndaripada sebuah pulau.
Dialogue: 0,0:07:53.17,0:07:54.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:07:54.48,0:07:57.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semuanya terlalu besar\Nsehingga membuatku merasa pusing.
Dialogue: 0,0:07:58.39,0:07:59.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luar biasa.
Dialogue: 0,0:08:00.50,0:08:01.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, lihatlah.
Dialogue: 0,0:08:07.62,0:08:09.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hebat sekali.
Dialogue: 0,0:08:11.04,0:08:14.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jembatan gantung yang sangat panjang.
Dialogue: 0,0:08:15.81,0:08:20.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah ini memanjang sampai ke atas awan?\NAku tidak bisa melihat ujungnya.
Dialogue: 0,0:08:20.63,0:08:23.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di belakang adalah\Nkastel milik Dewa Matahari.
Dialogue: 0,0:08:23.70,0:08:25.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kita hanya bisa terus maju?
Dialogue: 0,0:08:26.51,0:08:28.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kau merasa takut, Usopp?
Dialogue: 0,0:08:28.35,0:08:30.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Omong... Omong kosong apa kau?\NIni urusan sepele.
Dialogue: 0,0:08:30.94,0:08:33.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, kalau begitu ikutilah aku.
Dialogue: 0,0:08:36.17,0:08:37.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu... tunggu sebentar!
Dialogue: 0,0:08:38.01,0:08:39.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar aku yang memimpin di depan.
Dialogue: 0,0:08:46.67,0:08:47.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:08:58.14,0:08:59.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu... itu adalah raksasa.
Dialogue: 0,0:08:59.52,0:09:01.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka menyeberangi\Njembatan gantung ke arah sini.
Dialogue: 0,0:09:01.23,0:09:02.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepatlah bersembunyi.
Dialogue: 0,0:09:03.22,0:09:03.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luffy.
Dialogue: 0,0:09:07.85,0:09:12.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dasar, kenapa Hajrudin mau menjadikan\Norang aneh seperti itu sebagai rekannya?
Dialogue: 0,0:09:14.75,0:09:18.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu karena dia masih punya kemampuan yang\Ncukup baik sebagai seorang navigator.
Dialogue: 0,0:09:18.41,0:09:20.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku benci orang itu.
Dialogue: 0,0:09:20.28,0:09:23.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dibandingkan dengan Loki,\Ndialah yang lebih memalukan bagi Elbaph.
Dialogue: 0,0:09:23.49,0:09:26.00,tanda,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}[Gerth, Dokter\NKapal Bajak Laut Prajurit Raksasa Baru]
Dialogue: 0,0:09:27.58,0:09:30.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau kau berkata begitu,\NRoad pasti akan merasa senang.
Dialogue: 0,0:09:31.20,0:09:33.67,tanda,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}[Goldberg, Koki\NBajak Laut Prajurit Raksasa Baru]
Dialogue: 0,0:09:34.04,0:09:36.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Piper, kau sudah melihatnya, 'kan?
Dialogue: 0,0:09:36.63,0:09:40.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gagak orang itu telah mengangkut\Nsebuah kapal kecil ke sini.
Dialogue: 0,0:09:43.61,0:09:46.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Para penyusup tentu saja\Nharus segera ditangkap.
Dialogue: 0,0:09:46.50,0:09:49.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, Road malah\Nmenciptakan penyusupnya sendiri.
Dialogue: 0,0:09:51.01,0:09:53.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kegemaran orang itu\Nbenar-benar membuat pusing kepala.
Dialogue: 0,0:09:53.73,0:09:57.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan mencari tahu dan\Nmelaporkannya kepada Tuan Jarul.
Dialogue: 0,0:10:01.36,0:10:03.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari kita berpura-pura\Ntidak tahu dan lewat begitu saja.
Dialogue: 0,0:10:03.17,0:10:05.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah kalian mendengarnya, Kawan-Kawan?
Dialogue: 0,0:10:05.46,0:10:07.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka menyebut tentang Elbaph.
Dialogue: 0,0:10:07.23,0:10:08.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tempat ini pasti adalah...
Dialogue: 0,0:10:08.71,0:10:10.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau diamlah sebentar.
Dialogue: 0,0:10:11.12,0:10:12.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luffy!
Dialogue: 0,0:10:12.29,0:10:13.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:10:13.45,0:10:14.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepatlah bersembunyi.
Dialogue: 0,0:10:14.91,0:10:17.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, orang-orang itu\Nterlihat seperti orang baik.
Dialogue: 0,0:10:17.84,0:10:19.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, mau tanya sebentar, tempat ini...
Dialogue: 0,0:10:19.93,0:10:20.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bodoh.
Dialogue: 0,0:10:20.73,0:10:23.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah mereka tadi bilang akan\Nmenangkap para penyusup?
Dialogue: 0,0:10:23.64,0:10:24.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Luffy.
Dialogue: 0,0:10:25.78,0:10:27.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan menambah kesulitan bagi Nami.
Dialogue: 0,0:10:36.73,0:10:39.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata memang ada wanita cantik\Ndari Suku Raksasa.
Dialogue: 0,0:10:44.42,0:10:46.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah itu hanya halusinasi?
Dialogue: 0,0:10:46.13,0:10:46.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin saja.
Dialogue: 0,0:10:58.37,0:11:00.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang sedang kalian lakukan?
Dialogue: 0,0:11:03.14,0:11:05.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Road, apakah kau ada di sana?
Dialogue: 0,0:11:08.33,0:11:12.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, kalian semua\Nikutilah aku yang hebat ini.
Dialogue: 0,0:11:17.42,0:11:18.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo pergi.
Dialogue: 0,0:11:20.47,0:11:22.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bergoyang sekali.
Dialogue: 0,0:11:24.14,0:11:27.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jembatan gantung ukuran raksasa ini\Npenuh dengan lubang.
Dialogue: 0,0:11:27.55,0:11:28.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami, tenang saja.
Dialogue: 0,0:11:29.16,0:11:32.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu aku sering menyeberangi\Njembatan dengan berjalan di atas tali.
Dialogue: 0,0:11:32.28,0:11:34.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sangat ahli berjalan\Ndi tempat seperti ini.
Dialogue: 0,0:11:35.39,0:11:38.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terkadang ada salju yang turun\Ndengan sangat lebat secara tidak wajar.
Dialogue: 0,0:11:38.64,0:11:40.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jalan di depan masih sangat panjang.
Dialogue: 0,0:11:40.16,0:11:43.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika tidak cepat, kita akan terjebak\Nsaat para raksasa datang.
Dialogue: 0,0:11:48.64,0:11:51.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini adalah ujian, ujian\Nbagi para prajurit yang pemberani.
Dialogue: 0,0:11:58.99,0:12:02.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hutan di bawah sana\Npenuh dengan serigala raksasa.
Dialogue: 0,0:12:02.19,0:12:03.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Heiya!
Dialogue: 0,0:12:08.14,0:12:09.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa, Luffy?
Dialogue: 0,0:12:10.04,0:12:11.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau bisa merasakannya, 'kan?
Dialogue: 0,0:12:16.62,0:12:18.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada perasaan yang mendebarkan.
Dialogue: 0,0:12:18.24,0:12:18.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:12:19.30,0:12:20.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tidak mau pergi ke sana.
Dialogue: 0,0:12:21.20,0:12:22.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, aku...
Dialogue: 0,0:12:22.08,0:12:24.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa membiarkan Bola Lumut\Nyang buta arah ini pergi juga.
Dialogue: 0,0:12:24.53,0:12:27.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak boleh membiarkannya\Nmemasuki hutan mana pun di dunia ini.
Dialogue: 0,0:12:27.11,0:12:31.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya dia adalah pemilik raungan\Nyang terdengar di Negeri Balok Susun.
Dialogue: 0,0:12:32.37,0:12:34.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian pergilah duluan.
Dialogue: 0,0:12:38.67,0:12:40.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu sebentar, Luffy!
Dialogue: 0,0:12:40.27,0:12:41.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau mau pergi ke mana, Luffy?
Dialogue: 0,0:12:41.76,0:12:44.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di bawah sana penuh dengan serigala.
Dialogue: 0,0:12:50.82,0:12:52.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Usopp yang pemberani.
Dialogue: 0,0:12:52.73,0:12:55.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Usopp yang pemberani.
Dialogue: 0,0:13:10.81,0:13:12.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:13:13.22,0:13:14.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami?
Dialogue: 0,0:13:14.92,0:13:16.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menyerang Egg Head?
Dialogue: 0,0:13:17.50,0:13:20.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya, itulah yang tertulis\Ndi surat kabar pagi ini.
Dialogue: 0,0:13:20.84,0:13:23.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengapa mereka\Nmengarang kebohongan semacam itu?
Dialogue: 0,0:13:23.82,0:13:24.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihatlah.
Dialogue: 0,0:13:26.26,0:13:28.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terlalu kecil\Nsehingga tidak terlihat jelas.
Dialogue: 0,0:13:28.92,0:13:30.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar aku yang membacanya.
Dialogue: 0,0:13:33.47,0:13:36.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bangkit dari tidur panjang\Nselama 100 tahun.
Dialogue: 0,0:13:36.32,0:13:39.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajak Laut Prajurit Raksasa\Ntelah hidup kembali.
Dialogue: 0,0:13:42.52,0:13:45.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mereka bersama Luffy si Topi Jerami,\Nsalah satu dari Empat Kaisar Laut,
Dialogue: 0,0:13:45.47,0:13:47.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}telah mengubah\NEgg Head menjadi lautan api.
Dialogue: 0,0:13:51.87,0:13:53.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kapten Bajak Laut Prajurit Raksasa,
Dialogue: 0,0:13:54.70,0:13:56.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Brogy si Raksasa Merah,
Dialogue: 0,0:13:56.79,0:13:58.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dorry si Raksasa Biru.
Dialogue: 0,0:13:58.71,0:14:01.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nilai hadiah mereka berdua\Nadalah 1,8 miliar bounty.
Dialogue: 0,0:14:03.27,0:14:05.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}1... 1,8 miliar?
Dialogue: 0,0:14:06.74,0:14:09.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah sekarang kami\Npunya harga hadiah?
Dialogue: 0,0:14:10.29,0:14:13.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kami sebenarnya tidak berencana\Nuntuk muncul kembali di hadapan dunia.
Dialogue: 0,0:14:13.33,0:14:16.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dulu nilai hadiah para bos masih 100 juta.
Dialogue: 0,0:14:17.19,0:14:18.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang kenaikannya sangat drastis.
Dialogue: 0,0:14:19.03,0:14:22.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}Standar harga 100 tahun yang lalu\Ndan sekarang sudah sangat berbeda.
Dialogue: 0,0:14:22.52,0:14:24.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, sekarang mereka adalah\Npemimpin dari para prajurit Elbaph.
Dialogue: 0,0:14:24.91,0:14:26.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu cukup masuk akal.
Dialogue: 0,0:14:26.57,0:14:27.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Standar harga.
Dialogue: 0,0:14:28.39,0:14:30.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah standar harganya sudah berbeda?
Dialogue: 0,0:14:30.45,0:14:32.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, ya, benar juga.
Dialogue: 0,0:14:33.48,0:14:37.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lalu, kapten kami juga difitnah\Nsebagai pembunuh Vegapunk.
Dialogue: 0,0:14:39.88,0:14:44.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini benar-benar pemutarbalikan fakta\Nseperti yang sudah terjadi sebelumnya.
Dialogue: 0,0:14:44.35,0:14:45.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Membunuhku?
Dialogue: 0,0:14:46.00,0:14:50.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Diamlah, mereka ingin melindungimu\Nsampai saat-saat terakhir, 'kan?
Dialogue: 0,0:14:52.18,0:14:53.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, yang ini...
Dialogue: 0,0:14:54.26,0:14:56.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kapan foto ini diambil?
Dialogue: 0,0:14:56.61,0:14:58.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin di suatu tempat di Egg Head.
Dialogue: 0,0:14:59.32,0:15:02.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Anak buah Berita Ekonomi Dunia\Nada di mana-mana.
Dialogue: 0,0:15:02.20,0:15:06.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa pun yang memotretnya, foto itu\Npasti laku dengan harga sangat mahal.
Dialogue: 0,0:15:07.07,0:15:08.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku ingin tanya.
Dialogue: 0,0:15:09.56,0:15:12.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah Luffy berubah\Nke wujud kebebasannya,
Dialogue: 0,0:15:12.89,0:15:15.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}apakah tanda seperti ini akan\Nselalu muncul di pergelangan tangannya?
Dialogue: 0,0:15:15.50,0:15:18.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang benar\Nada terlihat sesuatu seperti tanda.
Dialogue: 0,0:15:18.77,0:15:23.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Begitukah? Dia aktif sekali bergerak\Nsampai aku tidak memperhatikannya.
Dialogue: 0,0:15:23.86,0:15:25.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini terlihat sangat tidak wajar.
Dialogue: 0,0:15:26.21,0:15:29.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tangannya terlihat buram, tetapi tandanya\Njustru tampak sangat jelas.
Dialogue: 0,0:15:29.87,0:15:32.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau benar-benar bisa memperhatikan\Nhal-hal yang janggal, ya.
Dialogue: 0,0:15:32.41,0:15:35.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku merasa sepertinya\Npernah melihat ini di suatu tempat.
Dialogue: 0,0:15:36.11,0:15:40.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, si Topi Jerami itu, sekarang sudah\Nbisa bersanding dengan si Rambut Merah.
Dialogue: 0,0:15:40.95,0:15:45.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kudengar ada pemuda bernama Hajrudin\Ndari pihak kami yang menjadi bawahanmu.
Dialogue: 0,0:15:46.27,0:15:49.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hajrudin, bagaimanapun juga,\Nadalah putra dari sang Raja.
Dialogue: 0,0:15:49.11,0:15:50.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah maksudnya Raja Elbaph?
Dialogue: 0,0:15:50.88,0:15:52.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata begitu, ya?
Dialogue: 0,0:15:52.27,0:15:55.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat masih kecil, dia adalah\Nbocah nakal yang sangat sembrono.
Dialogue: 0,0:16:02.27,0:16:05.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang-orang itu sebenarnya juga\Nsangat ingin menjemput kalian.
Dialogue: 0,0:16:12.79,0:16:15.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hanya saja, telah terjadi\Nsedikit masalah di Elbaph.
Dialogue: 0,0:16:15.88,0:16:18.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jadi, hanya kami\Npara orang tua ini yang datang.
Dialogue: 0,0:16:18.84,0:16:19.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Masalah?
Dialogue: 0,0:16:20.20,0:16:22.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku baru pertama kali ini mendengarnya.
Dialogue: 0,0:16:24.73,0:16:25.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:16:26.10,0:16:29.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hal ini terjadi saat para pemimpin\Nsedang tidak ada di tempat.
Dialogue: 0,0:16:35.05,0:16:39.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di Elbaph telah lahir kembali\Nseorang pangeran yang resmi.
Dialogue: 0,0:16:59.28,0:17:01.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dingin sekali!
Dialogue: 0,0:17:07.84,0:17:09.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Besar sekali!
Dialogue: 0,0:17:16.06,0:17:17.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}Walaupun Negeri Balok Susun cukup menarik,
Dialogue: 0,0:17:17.99,0:17:20.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}petualangan yang sebenarnya\Nmemang harus seperti ini.
Dialogue: 0,0:17:20.68,0:17:22.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pemilik dari suara raungan itu,
Dialogue: 0,0:17:23.00,0:17:25.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}ternyata bisa mengeluarkan\Nsuara yang sangat keras.
Dialogue: 0,0:17:25.39,0:17:28.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bisakah kau memberiku\Nsepotong daging yang sangat besar?
Dialogue: 0,0:17:34.37,0:17:39.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, kau ada di mana?
Dialogue: 0,0:17:43.85,0:17:45.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang kalian lakukan?
Dialogue: 0,0:18:14.17,0:18:15.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang tadi itu...
Dialogue: 0,0:18:15.93,0:18:17.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah di sebelah sana?
Dialogue: 0,0:18:20.44,0:18:21.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pangeran itu...
Dialogue: 0,0:18:22.89,0:18:26.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pangeran itu dijuluki\Nsebagai Pangeran Terkutuk.
Dialogue: 0,0:18:27.33,0:18:28.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terkutuk?
Dialogue: 0,0:18:28.39,0:18:30.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang itu telah melakukan\Nsegala macam kejahatan.
Dialogue: 0,0:18:30.80,0:18:34.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Beberapa tahun yang lalu,\Ndia telah dijatuhi hukuman penyaliban.
Dialogue: 0,0:18:34.43,0:18:36.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, orang ini hampir saja\Nberhasil melarikan diri.
Dialogue: 0,0:18:36.65,0:18:40.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Seluruh prajurit pun\Ndikerahkan untuk menahannya kembali.
Dialogue: 0,0:18:41.92,0:18:44.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua raksasa Elbaph\Nsampai harus dikerahkan?
Dialogue: 0,0:18:44.42,0:18:46.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana mungkin hal\Nsemacam itu bisa terjadi?
Dialogue: 0,0:18:46.66,0:18:47.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Memang begitulah kenyataannya.
Dialogue: 0,0:18:47.68,0:18:50.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semua paku yang ada\Ndi kepala orang itu terpental keluar.
Dialogue: 0,0:19:00.38,0:19:05.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Demi merebut Buah Iblis legendaris\Nwarisan kerajaan Elbaph,
Dialogue: 0,0:19:06.21,0:19:11.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}dia membunuh ayahnya, Harald,\Nlalu memakan buah tersebut.
Dialogue: 0,0:19:15.34,0:19:17.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan-jangan, nama orang itu adalah...
Dialogue: 0,0:19:22.52,0:19:23.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:19:23.85,0:19:26.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika orang itu dibiarkan bebas lagi,
Dialogue: 0,0:19:28.01,0:19:29.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}dunia ini akan hancur.
Dialogue: 0,0:19:31.18,0:19:32.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang itu adalah,
Dialogue: 0,0:19:35.07,0:19:36.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}noda bagi nama baik Elbaph,
Dialogue: 0,0:19:41.14,0:19:42.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}si Pangeran Terkutuk,
Dialogue: 0,0:19:45.19,0:19:45.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Loki.
Dialogue: 0,0:20:01.57,0:20:03.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebutkan namamu.
Dialogue: 0,0:20:06.54,0:20:07.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namaku adalah Luffy.
Dialogue: 0,0:20:08.67,0:20:11.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku adalah pria yang akan\Nmenjadi Raja Bajak Laut.
Dialogue: 0,0:20:15.65,0:20:16.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Raja?
Dialogue: 0,0:20:17.01,0:20:17.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:18.35,0:20:20.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di mana tempat ini? Lalu, siapa pula kau?
Dialogue: 0,0:20:21.32,0:20:23.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau datang ke sini tanpa mengetahuinya?
Dialogue: 0,0:20:23.38,0:20:23.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar.
Dialogue: 0,0:20:26.85,0:20:30.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika kau mengetahuinya, kau\Npasti tidak akan datang menemuiku.
Dialogue: 0,0:20:32.36,0:20:34.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, biar kuberi tahu padamu.
Dialogue: 0,0:20:40.32,0:20:43.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sini adalah kerajaan\Npara prajurit Elbaph.
Dialogue: 0,0:20:44.67,0:20:46.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}Negeri Wilayah Perang.
Dialogue: 0,0:20:54.95,0:21:02.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Negara terkuat di dunia yang dulunya\Nselalu diliputi oleh konflik.
Dialogue: 0,0:21:14.82,0:21:18.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sementara aku, adalah orang\Nyang akan mengakhiri dunia ini,
Dialogue: 0,0:21:21.76,0:21:23.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dewa Matahari,
Dialogue: 0,0:21:25.13,0:21:26.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Loki.
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
Dialogue: 0,0:23:05.49,0:23:10.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luffy bertemu Loki, Pangeran Terkutuk,\Nyang melakukan kejahatan besar di Elbaph.
Dialogue: 0,0:23:10.81,0:23:13.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Loki, yang mengaku memiliki\Ninformasi terkait Rambut Merah, Shanks,
Dialogue: 0,0:23:14.00,0:23:16.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}telah mengajukan sebuah kesepakatan\Ntertentu kepada Luffy.
Dialogue: 0,0:23:16.97,0:23:20.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya, apa yang sedang\Ndirencanakan oleh Loki?
Dialogue: 0,0:23:20.86,0:23:22.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Episode selanjutnya, One Piece
Dialogue: 0,0:23:22.59,0:23:30.76,tanda,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}[Kesepakatan Berbahaya!\NLoki dari Dunia Bawah dan Luffy]
Dialogue: 0,0:23:22.62,0:23:25.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kesepakatan berbahaya!\NLoki dari dunia bawah dan Luffy.
Dialogue: 0,0:23:26.02,0:23:27.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan menjadi Raja Bajak Laut!
