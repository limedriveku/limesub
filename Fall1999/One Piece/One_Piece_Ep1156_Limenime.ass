Dialogue: 0,0:03:43.85,0:03:47.47,tanda,,0000,0000,0000,,{\an8}[Dua Tahun Lalu, Little Garden]
Dialogue: 0,0:06:47.92,0:06:50.63,tanda,,0000,0000,0000,,{\an8}[New World, Pulau Gartel]
Dialogue: 0,0:07:03.57,0:07:07.63,tanda,,0000,0000,0000,,{\an8}[“Si Kanibal” Bartolomeo]
Dialogue: 0,0:08:02.97,0:08:04.73,tanda,,0000,0000,0000,,{\an8}[Saat Ini]
Dialogue: 0,0:11:12.47,0:11:14.28,tanda,,0000,0000,0000,,{\an8}[Klub Barto]
Dialogue: 0,0:12:52.75,0:12:54.54,tanda,,0000,0000,0000,,{\an8}[Pulau Bajak Laut, Hachinosu]
Dialogue: 0,0:13:56.42,0:13:58.08,tanda,,0000,0000,0000,,{\an8}[Pemerintah Dunia]
Dialogue: 0,0:16:58.82,0:17:04.20,tanda,,0000,0000,0000,,(Den Den Mushi sedang tersambung)
Dialogue: 0,0:22:54.45,0:23:00.53,tanda,,0000,0000,0000,,[Bersambung]
Dialogue: 0,0:00:12.45,0:00:13.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:00:14.04,0:00:14.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:00:16.21,0:00:16.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:00:17.80,0:00:18.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maju!
Dialogue: 0,0:00:25.98,0:00:27.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sudah terbang keluar!
Dialogue: 0,0:00:34.11,0:00:35.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya!
Dialogue: 0,0:00:35.41,0:00:38.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti,\Naku pasti akan pergi ke Elbaf.
Dialogue: 0,0:00:38.82,0:00:40.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pergi ke desa para pejuang.
Dialogue: 0,0:00:41.38,0:00:42.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali, Usopp!
Dialogue: 0,0:00:42.73,0:00:44.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita pasti akan pergi ke sana!
Dialogue: 0,0:00:45.50,0:00:49.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suatu hari nanti, kita akan pergi\Nke kampung halaman para raksasa!
Dialogue: 0,0:00:50.31,0:00:54.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elbaf!
Dialogue: 0,0:00:54.39,0:00:58.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya sangat tinggi besar,\Nmereka semua adalah raksasa.
Dialogue: 0,0:01:01.37,0:01:03.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini akhirnya tiba, Usopp.
Dialogue: 0,0:01:03.83,0:01:04.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:01:05.31,0:01:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mari berangkat, menuju Elbaf!
Dialogue: 0,0:01:13.63,0:01:21.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elbaf yang didambakan,\Npesta reuni besar-besaran.
Dialogue: 0,0:01:28.52,0:01:30.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kelompok Luffy telah meninggalkan Egg Head
Dialogue: 0,0:01:32.85,0:01:35.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan menuju pulau selanjutnya, Elbaf.
Dialogue: 0,0:01:35.38,0:01:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesta mereka masih terus berlanjut.
Dialogue: 0,0:01:42.97,0:01:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, hei, apakah kau\Nmendengarkan, Topi Jerami?
Dialogue: 0,0:01:49.28,0:01:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah kami berpisah\Ndengan kalian di Kota Air...
Dialogue: 0,0:01:52.80,0:01:58.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami memutuskan untuk menemui para bos,\Nlalu pergi ke Little Garden.
Dialogue: 0,0:01:58.09,0:01:59.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, begitu ceritanya.
Dialogue: 0,0:01:59.84,0:02:01.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti akan ada rasa peduli, bukan?
Dialogue: 0,0:02:01.89,0:02:03.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, sudah 100 tahun berlalu.
Dialogue: 0,0:02:03.72,0:02:05.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lalu, coba tebak apa yang terjadi?
Dialogue: 0,0:02:06.07,0:02:09.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka berdua sedang bertarung\Ndengan tangan kosong.
Dialogue: 0,0:02:20.72,0:02:23.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa? Bukankah para paman itu\Nmemiliki senjata?
Dialogue: 0,0:02:24.03,0:02:25.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini...
Dialogue: 0,0:02:34.25,0:02:36.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadi sedikit kecelakaan\Nsehingga semua senjata patah.
Dialogue: 0,0:02:36.22,0:02:37.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu hanya masalah kecil saja.
Dialogue: 0,0:02:38.18,0:02:39.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:02:41.52,0:02:45.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dua orang sekuat itu bertarung,\Nsiapa yang bisa mereka bunuh?
Dialogue: 0,0:02:47.34,0:02:48.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga katamu.
Dialogue: 0,0:02:48.52,0:02:51.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal duel seorang pejuang adalah\Npertarungan hidup dan mati.
Dialogue: 0,0:02:51.54,0:02:56.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kemenangan bisa ditentukan semudah\Nitu, mereka tidak akan bisa jadi bos kami.
Dialogue: 0,0:02:56.37,0:02:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah melihatnya!
Dialogue: 0,0:02:57.77,0:03:01.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertarungan di mana semua serangan\Nadalah satu serangan mematikan.
Dialogue: 0,0:03:01.32,0:03:02.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau pasti sampai tidak percaya\Ndengan matamu sendiri, 'kan?
Dialogue: 0,0:03:02.99,0:03:03.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:03:03.96,0:03:07.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah duel yang tidak menodai\Nreputasi Elbaf.
Dialogue: 0,0:03:11.12,0:03:14.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya mereka malah dihentikan\Noleh sekelompok orang ini.
Dialogue: 0,0:03:14.64,0:03:17.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami juga sempat\Nkembali sebentar ke Elbaf.
Dialogue: 0,0:03:17.79,0:03:19.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kembali untuk mengambil senjata.
Dialogue: 0,0:03:20.07,0:03:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang kembali\Nuntuk mengambil senjata?
Dialogue: 0,0:03:23.00,0:03:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah mereka akan terus bertarung?
Dialogue: 0,0:03:25.50,0:03:26.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu saja.
Dialogue: 0,0:03:27.75,0:03:28.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar tidak habis pikir.
Dialogue: 0,0:03:28.73,0:03:33.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei Nami, apa sebenarnya\Nyang kau pelajari di Little Garden?
Dialogue: 0,0:03:33.92,0:03:36.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, beri tahu dia, Usopp!
Dialogue: 0,0:03:36.88,0:03:40.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Inilah yang disebut dengan\Npertarungan yang sebenarnya.
Dialogue: 0,0:03:41.32,0:03:42.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:03:42.48,0:03:43.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika membuat sebuah perumpamaan...
Dialogue: 0,0:03:43.95,0:03:48.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di dalam hati mereka berdua berkibar\Nbendera yang bernama "Pejuang".
Dialogue: 0,0:03:48.42,0:03:50.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada satu pun yang ingin\Nbendera itu jatuh.
Dialogue: 0,0:03:50.82,0:03:53.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, demi melindungi bendera tersebut,
Dialogue: 0,0:03:53.30,0:03:56.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mereka telah bertarung terus-menerus\Nselama 100 tahun ini.
Dialogue: 0,0:03:59.80,0:04:00.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau mengerti?
Dialogue: 0,0:04:00.92,0:04:05.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar merupakan duel\Nyang mulia bagi para pejuang.
Dialogue: 0,0:04:05.82,0:04:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sosok "Pejuang Laut Pemberani"\Nyang ingin kucapai adalah seperti itu.
Dialogue: 0,0:04:13.39,0:04:14.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian...
Dialogue: 0,0:04:15.29,0:04:18.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian, kita akan pergi ke Elbaf.
Dialogue: 0,0:04:18.06,0:04:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo, minum yang banyak!
Dialogue: 0,0:04:20.38,0:04:22.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dengarkan aku!
Dialogue: 0,0:04:22.91,0:04:24.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau ingin menjadi raksasa?
Dialogue: 0,0:04:24.67,0:04:27.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja tidak, apa sebenarnya\Nyang kau dengarkan?
Dialogue: 0,0:04:35.11,0:04:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah lawan latihan\Nkali ini adalah raksasa?
Dialogue: 0,0:04:39.40,0:04:43.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang hanya tertarik pada pertarungan\Nbenar-benar tidak beruntung.
Dialogue: 0,0:04:43.62,0:04:44.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:04:48.44,0:04:49.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba kau bayangkan.
Dialogue: 0,0:04:50.87,0:04:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti ada banyak wanita\Nyang cantik dan bertubuh besar!
Dialogue: 0,0:04:56.21,0:04:59.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu aku, para kakak\Nyang bertubuh besar!
Dialogue: 0,0:04:59.25,0:05:01.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat, kau memang orang bodoh.
Dialogue: 0,0:05:02.71,0:05:04.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Franky, baunya sangat busuk sejak tadi.
Dialogue: 0,0:05:06.15,0:05:08.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sepertinya disebut Hakarl.
Dialogue: 0,0:05:08.07,0:05:10.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sangat cocok sebagai\Npendamping bir atau kola.
Dialogue: 0,0:05:10.53,0:05:12.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ini sesuai dengan seleramu.
Dialogue: 0,0:05:12.86,0:05:15.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, bir ini benar-benar keras sekali.
Dialogue: 0,0:05:15.40,0:05:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, ini adalah Absinthe.
Dialogue: 0,0:05:18.24,0:05:20.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada nama lainnya yaitu "Peri Hijau".
Dialogue: 0,0:05:23.25,0:05:26.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Peri? Memang terdengar sangat cantik.
Dialogue: 0,0:05:26.72,0:05:28.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Coba cicipi sedikit saja.
Dialogue: 0,0:05:28.97,0:05:31.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada kemungkinan bisa\Nmenyebabkan halusinasi.
Dialogue: 0,0:05:31.03,0:05:31.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hati-hati.
Dialogue: 0,0:05:34.71,0:05:36.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chopper, baik-baik saja, 'kan?
Dialogue: 0,0:05:39.14,0:05:41.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian semua minum terlalu banyak,\Ndasar berengsek!
Dialogue: 0,0:05:41.69,0:05:43.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya sudah terlambat.
Dialogue: 0,0:05:45.65,0:05:47.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chopper sudah mabuk.
Dialogue: 0,0:05:51.86,0:05:52.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga.
Dialogue: 0,0:05:52.65,0:05:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mabuknya sudah meresap sampai ke tulang.
Dialogue: 0,0:05:55.24,0:05:57.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal aku hanya punya tulang belulang.
Dialogue: 0,0:05:58.05,0:05:59.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, Brook!
Dialogue: 0,0:06:02.84,0:06:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo mulai bernyanyi!
Dialogue: 0,0:06:15.06,0:06:15.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anak-Anak!
Dialogue: 0,0:06:19.68,0:06:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Ini adalah kisah\Ntentang seorang pahlawan ♪
Dialogue: 0,0:06:23.20,0:06:26.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kisah tentang seorang pria\Nyang ingin menjadi raja ♪
Dialogue: 0,0:06:27.34,0:06:30.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Setiap kali situasi pertempuran\Nsudah di ambang batas ♪
Dialogue: 0,0:06:30.89,0:06:34.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Dia membalikkan keadaan\Ndengan memakai sandal jepit ♪
Dialogue: 0,0:06:36.95,0:06:37.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hore! ♪
Dialogue: 0,0:06:49.37,0:06:51.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih dari satu bulan yang lalu.
Dialogue: 0,0:06:52.38,0:06:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terjadi sebuah peristiwa\Ndi Pulau Gartel di New World.
Dialogue: 0,0:06:59.98,0:07:03.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serahkan para penjahat itu kepadaku!
Dialogue: 0,0:07:04.35,0:07:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajak laut Bartolomeo yang telah\Nmenghukum penjahat jalanan,
Dialogue: 0,0:07:08.03,0:07:10.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mulai menjual pernak-pernik\NGeng Topi Jerami.
Dialogue: 0,0:07:10.55,0:07:11.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kemudian...
Dialogue: 0,0:07:11.83,0:07:14.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para penduduk pulau.
Dialogue: 0,0:07:15.46,0:07:18.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan mengadakan\Nkegiatan diskon setengah harga!
Dialogue: 0,0:07:23.10,0:07:25.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Apa yang lucu?
Dialogue: 0,0:07:25.52,0:07:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian seharusnya menangis\Nkarena terlalu bahagia.
Dialogue: 0,0:07:28.09,0:07:31.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tahu atau tidak\Nini wilayah kekuasaan siapa?
Dialogue: 0,0:07:41.09,0:07:43.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rambut Merah?
Dialogue: 0,0:07:46.06,0:07:47.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Empat Kaisar!
Dialogue: 0,0:07:49.46,0:07:50.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terserah.
Dialogue: 0,0:07:51.81,0:07:56.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Luffy barulah orang\Nyang memikul era masa depan.
Dialogue: 0,0:07:56.78,0:07:58.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Senior Luffy barulah orangnya.
Dialogue: 0,0:07:59.02,0:08:02.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini tanpa ragu merupakan\Ntindakan yang tidak menghormati Kaisar.
Dialogue: 0,0:08:18.16,0:08:19.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika aku melepaskanmu,\Nbendera yang kupinjamkan
Dialogue: 0,0:08:19.67,0:08:24.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}ke pulau lain dan para bajak laut\Nakan kehilangan wibawanya.
Dialogue: 0,0:08:25.25,0:08:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teman-temanku akan jatuh ke dalam bahaya.
Dialogue: 0,0:08:29.86,0:08:31.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Anda benar sekali.
Dialogue: 0,0:08:34.03,0:08:35.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar minta maaf.
Dialogue: 0,0:08:35.97,0:08:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku yang kurang\Nmempertimbangkannya dengan matang
Dialogue: 0,0:08:39.35,0:08:42.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan melakukan tindakan bodoh\Nkarena ketidaktahuan.
Dialogue: 0,0:08:42.35,0:08:45.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bersedia memberi ganti rugi\Ndengan cara apa pun.
Dialogue: 0,0:08:50.65,0:08:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan memberimu sebuah kesempatan.
Dialogue: 0,0:08:54.93,0:08:57.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke... kesempatan?
Dialogue: 0,0:08:58.22,0:09:00.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda ini adalah racun\Nyang sangat mematikan.
Dialogue: 0,0:09:02.58,0:09:07.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Buat Topi Jerami meminumnya\Ndalam waktu satu bulan.
Dialogue: 0,0:09:13.23,0:09:15.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah meminumnya,\Nbersamaan dengan rasa sakit yang hebat,
Dialogue: 0,0:09:15.31,0:09:19.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}darah akan menyembur dari seluruh tubuh\Nhingga mengakibatkan kematian.
Dialogue: 0,0:09:21.46,0:09:25.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biar bos kalian yang bertanggung jawab\Ndengan cara seperti itu.
Dialogue: 0,0:09:28.14,0:09:30.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa harus Senior Luffy?
Dialogue: 0,0:09:30.11,0:09:31.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah perbuatan kami.
Dialogue: 0,0:09:31.64,0:09:35.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanggung jawabnya bukan\Npada Senior Luffy, tetapi pada kami.
Dialogue: 0,0:09:39.20,0:09:40.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemimpin!
Dialogue: 0,0:09:40.91,0:09:44.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan, dia akan mati!
Dialogue: 0,0:09:44.62,0:09:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia akan mati dengan menyemburkan darah!
Dialogue: 0,0:09:52.34,0:09:53.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begini saja sudah cukup.
Dialogue: 0,0:09:56.61,0:09:57.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengapa jadi begini?
Dialogue: 0,0:09:57.74,0:09:58.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup!
Dialogue: 0,0:10:00.52,0:10:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami ambil bir sumpah setia dan bendera\Nbajak laut Senior Luffy secara sepihak.
Dialogue: 0,0:10:07.12,0:10:10.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, hal ini tidak ada\Nhubungannya dengan Senior Luffy.
Dialogue: 0,0:10:11.03,0:10:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku harap kalian\Ntidak membicarakannya ke luar.
Dialogue: 0,0:10:13.15,0:10:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan membuang waktu berharga Senior,
Dialogue: 0,0:10:17.57,0:10:22.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}meski hanya satu detik saja\Ndemi orang seperti aku.
Dialogue: 0,0:10:23.60,0:10:26.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masalah ini hanya karena\Npreman kecil sepertiku
Dialogue: 0,0:10:26.20,0:10:29.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang memprovokasi Empat Kaisar\Ntanpa izin sehingga akhirnya dibunuh.
Dialogue: 0,0:10:29.95,0:10:31.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal yang sangat lumrah terjadi.
Dialogue: 0,0:10:32.67,0:10:33.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin...
Dialogue: 0,0:10:35.84,0:10:37.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin melihat
Dialogue: 0,0:10:38.09,0:10:42.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}penampilan Senior Luffy\Nsaat menjadi "Raja Bajak Laut".
Dialogue: 0,0:10:42.55,0:10:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semua ini salahku\Nkarena melakukan hal bodoh, sialan.
Dialogue: 0,0:10:46.96,0:10:50.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan-Rekan, kelak\Nkuserahkan sisanya kepada kalian!
Dialogue: 0,0:10:50.32,0:10:53.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Pemimpin!
Dialogue: 0,0:10:53.74,0:10:55.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat tinggal untuk selamanya,
Dialogue: 0,0:10:56.56,0:10:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rekan-Rekan.
Dialogue: 0,0:11:14.29,0:11:15.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia melepaskan kita.
Dialogue: 0,0:11:15.88,0:11:17.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat pergi sejauh-jauhnya!
Dialogue: 0,0:11:19.03,0:11:21.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena benda itu ternyata bukan racun,
Dialogue: 0,0:11:21.35,0:11:24.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}menunjukkan sejak awal dia memang\Ntidak berencana membunuh Senior Luffy.
Dialogue: 0,0:11:24.88,0:11:28.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun dia adalah Empat Kaisar,\Ntadinya kukira dia pria yang mengerikan.
Dialogue: 0,0:11:28.94,0:11:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata dia sangat mudah diajak bicara.
Dialogue: 0,0:11:38.09,0:11:40.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kau tertawakan, Bos?
Dialogue: 0,0:11:41.30,0:11:44.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah hal ini sangat membahagiakan?
Dialogue: 0,0:11:44.81,0:11:47.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata ada orang\Nyang begitu memikirkan Luffy.
Dialogue: 0,0:11:49.88,0:11:53.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Bos, minggir sedikit.
Dialogue: 0,0:11:57.31,0:11:59.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perhitungan tetap harus diselesaikan.
Dialogue: 0,0:12:10.50,0:12:12.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di perairan pantai Pulau Gartel,
Dialogue: 0,0:12:13.70,0:12:16.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kapal Bajak Laut Klub Barto
Dialogue: 0,0:12:17.55,0:12:18.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}telah ditenggelamkan.
Dialogue: 0,0:12:21.17,0:12:23.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mereka tidak diketahui hidup matinya.
Dialogue: 0,0:13:10.57,0:13:12.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Shiryu si Hujan, Kapten Kapal Ke-2\NBajak Laut Jenggot Hitam]
Dialogue: 0,0:13:14.88,0:13:20.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi\Nselama aku tidak ada di sini?
Dialogue: 0,0:13:20.38,0:13:22.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Vasco Shot si Peminum Berat, Kapten Kapal\NKe-8 Bajak Laut Jenggot Hitam]
Dialogue: 0,0:13:23.54,0:13:24.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Pizzaro!
Dialogue: 0,0:13:26.30,0:13:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Avalo Pizzaro si Raja Korup, Kapten Kapal\NKe-4 Bajak Laut Jenggot Hitam]
Dialogue: 0,0:13:27.56,0:13:30.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Teach, ini adalah pesan itu...
Dialogue: 0,0:13:33.46,0:13:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pesan dari Vegapunk.
Dialogue: 0,0:13:33.53,0:13:36.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Laksamana Bajak Laut Jenggot Hitam,\NMarshall D. Teach]
Dialogue: 0,0:13:38.69,0:13:40.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah mendengarnya.
Dialogue: 0,0:13:41.44,0:13:43.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, sakit sekali!
Dialogue: 0,0:13:43.20,0:13:45.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dunia akhirnya akan berubah.
Dialogue: 0,0:13:45.88,0:13:49.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ponegliff tidak lagi menjadi\Nrahasia bawah tanah.
Dialogue: 0,0:13:50.50,0:13:54.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebentar lagi Empat Kaisar akan\Nsaling berebut batu prasasti itu.
Dialogue: 0,0:13:54.76,0:13:57.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemerintah Dunia dan Angkatan Laut\Npasti akan ikut campur juga.
Dialogue: 0,0:13:59.15,0:14:02.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika mengabaikan mereka,\Ntidak akan bisa menang sampai akhir.
Dialogue: 0,0:14:04.21,0:14:07.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kartu truf yang dibutuhkan\Ndi sini adalah Koby.
Dialogue: 0,0:14:09.82,0:14:13.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hasilnya, dia ternyata berhasil kabur.
Dialogue: 0,0:14:14.52,0:14:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maafkan aku, Teach.
Dialogue: 0,0:14:16.85,0:14:17.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengarkan aku dulu.
Dialogue: 0,0:14:17.91,0:14:20.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pertama-tama, Moria telah melarikan diri.
Dialogue: 0,0:14:20.43,0:14:21.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa...
Dialogue: 0,0:14:22.49,0:14:26.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Sanjuan Wolf si Kapal Perang Besar, Kapten\NKapal Ke-7 Bajak Laut Jenggot Hitam]
Dialogue: 0,0:14:23.45,0:14:26.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana lokasi toko ini tadi?
Dialogue: 0,0:14:26.39,0:14:28.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini salah, agak ke kiri lagi.
Dialogue: 0,0:14:29.81,0:14:31.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata keliru, ya.
Dialogue: 0,0:14:31.75,0:14:33.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:14:34.35,0:14:36.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dihancurkan oleh bokongmu.
Dialogue: 0,0:14:36.15,0:14:37.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya jadi hancur.
Dialogue: 0,0:14:38.08,0:14:40.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Moria juga melarikan diri?
Dialogue: 0,0:14:44.62,0:14:45.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, yang barusan itu.
Dialogue: 0,0:14:46.02,0:14:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara yang tadi itu.
Dialogue: 0,0:14:46.65,0:14:47.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu Laksamana?
Dialogue: 0,0:14:47.67,0:14:49.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Laksamana!
Dialogue: 0,0:15:02.12,0:15:03.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Laksamana!
Dialogue: 0,0:15:06.07,0:15:08.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sudah bersiap-siap\Ndan bisa berangkat kapan saja.
Dialogue: 0,0:15:08.84,0:15:10.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia Besar One Piece.
Dialogue: 0,0:15:10.74,0:15:13.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang akan mendapatkan One Piece...
Dialogue: 0,0:15:13.51,0:15:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah kau, Jenggot Hitam, bukan?
Dialogue: 0,0:15:16.49,0:15:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rebutlah dunia dan tunjukkan kepada kami!
Dialogue: 0,0:15:31.74,0:15:33.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Doc Q, Kapten Kapal Ke-9/Dokter\NKapal Bajak Laut Jenggot Hitam]
Dialogue: 0,0:15:34.46,0:15:36.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semangat tempur sedang meluap-luap!
Dialogue: 0,0:15:40.33,0:15:43.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kali ini harus dimanfaatkan dengan baik.
Dialogue: 0,0:15:48.41,0:15:50.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, Kuzan.
Dialogue: 0,0:15:51.27,0:15:53.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan bertanya sekali lagi.
Dialogue: 0,0:15:53.65,0:15:55.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau yang melepaskan Koby?
Dialogue: 0,0:15:54.81,0:15:58.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Kuzan, Kapten Kapal Ke-10\NBajak Laut Jenggot Hitam]
Dialogue: 0,0:15:55.44,0:15:57.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar, tetapi Garp sudah tertangkap.
Dialogue: 0,0:16:00.27,0:16:01.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini benar-benar luar biasa.
Dialogue: 0,0:16:02.05,0:16:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nilainya jauh lebih tinggi\Ndaripada Koby atau siapa pun, 'kan?
Dialogue: 0,0:16:05.13,0:16:06.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diam kau!
Dialogue: 0,0:16:07.97,0:16:10.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, jika dikatakan secara tepat,
Dialogue: 0,0:16:11.66,0:16:13.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku mengira sudah membunuhnya.
Dialogue: 0,0:16:13.42,0:16:15.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak menyangka dia masih hidup.
Dialogue: 0,0:16:15.26,0:16:16.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya sebatas itu saja.
Dialogue: 0,0:16:17.15,0:16:19.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah sebuah pencapaian\Nyang sangat besar, Kuzan.
Dialogue: 0,0:16:19.80,0:16:22.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa lagi selain dirimu\Nyang bisa meringkus orang itu?
Dialogue: 0,0:16:23.14,0:16:26.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, kami harus mengeroyoknya\Nbersama-sama baru bisa menang.
Dialogue: 0,0:16:26.06,0:16:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Arah angin sedang bagus.
Dialogue: 0,0:16:29.44,0:16:30.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:16:31.25,0:16:32.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu...
Dialogue: 0,0:16:34.18,0:16:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan tarik aku!
Dialogue: 0,0:16:37.19,0:16:40.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gadis dari Suku Tiga Mata\Njuga sudah berhasil didapatkan.
Dialogue: 0,0:16:44.29,0:16:45.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan sentuh aku!
Dialogue: 0,0:16:47.09,0:16:49.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, telepon Laffitte.
Dialogue: 0,0:16:59.54,0:17:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Perusahaan Pelayaran,\NMarkas Besar Pelayaran UMIT]
Dialogue: 0,0:17:05.00,0:17:06.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Silakan beri perintah, Laksamana.
Dialogue: 0,0:17:06.50,0:17:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lama sekali kau mengangkatnya.
Dialogue: 0,0:17:08.81,0:17:11.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana dengan Pasukan Revolusioner?
Dialogue: 0,0:17:12.33,0:17:15.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Laffitte, Kapten Kapal Ke-5\NBajak Laut Jenggot Hitam]
Dialogue: 0,0:17:13.44,0:17:17.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Strategi pasokan pangan mereka\Ndilakukan dengan sungguh-sungguh.
Dialogue: 0,0:17:17.58,0:17:21.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lift gelembung di Red Port\Nterus-menerus mengalami kerusakan.
Dialogue: 0,0:17:22.98,0:17:27.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terutama saat mengangkut makanan,\Nitu 100 persen tidak dapat beroperasi.
Dialogue: 0,0:17:27.58,0:17:31.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sejak awal sudah memutus\Npengiriman makanan dari berbagai negara.
Dialogue: 0,0:17:31.57,0:17:34.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Angkatan Laut berusaha keras\Nmenyelamatkan sebagian makanan.
Dialogue: 0,0:17:34.78,0:17:39.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akibatnya lift gelembung yang mengangkut\Nmakanan ke Marijoa malah terjatuh.
Dialogue: 0,0:17:39.05,0:17:43.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika di antara para Tenryuubito\Nsampai ada yang mati kelaparan,
Dialogue: 0,0:17:43.95,0:17:46.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu benar-benar sesuatu\Nyang belum pernah terdengar sebelumnya.
Dialogue: 0,0:17:46.67,0:17:47.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik.
Dialogue: 0,0:17:51.36,0:17:53.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau jangan hanya sibuk menikmatinya saja.
Dialogue: 0,0:17:54.08,0:17:55.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lakukan persiapan.
Dialogue: 0,0:17:57.24,0:17:58.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mengerti.
Dialogue: 0,0:18:03.17,0:18:05.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah sampai di tempat Pizzaro.
Dialogue: 0,0:18:05.60,0:18:07.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:18:07.98,0:18:10.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Akhirnya sampai juga.
Dialogue: 0,0:18:10.91,0:18:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Markas Tuan Teach!
Dialogue: 0,0:18:15.40,0:18:15.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:18:18.25,0:18:20.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Matanya sedang bergerak.
Dialogue: 0,0:18:20.91,0:18:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata itu Devon.
Dialogue: 0,0:18:23.70,0:18:24.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bawa kami naik ke atas.
Dialogue: 0,0:18:26.44,0:18:29.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar!
Dialogue: 0,0:18:30.75,0:18:34.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan... jangan lakukan itu!
Dialogue: 0,0:18:35.87,0:18:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan merasa repot\Nsaat masuk ke pelabuhan.
Dialogue: 0,0:18:39.67,0:18:42.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang aku adalah\Norang yang sedang terluka.
Dialogue: 0,0:18:43.48,0:18:45.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, ini benar-benar gawat!
Dialogue: 0,0:18:45.90,0:18:49.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukankah ini artinya diculik oleh monster?
Dialogue: 0,0:18:50.44,0:18:54.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak-Kakak, cepat pikirkan solusinya!
Dialogue: 0,0:18:54.38,0:18:56.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar berisik sekali.
Dialogue: 0,0:18:57.15,0:19:00.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau membawa orang\Nyang kau bicarakan sebelumnya itu?
Dialogue: 0,0:19:00.54,0:19:01.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:02.71,0:19:06.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimanapun, ini adalah permintaan Teach,\Njadi tidak ada pilihan lain.
Dialogue: 0,0:19:06.78,0:19:07.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya.
Dialogue: 0,0:19:12.32,0:19:15.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah dua hari berlalu\Nsetelah berangkat dari Egg Head.
Dialogue: 0,0:19:21.14,0:19:21.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana di sana?
Dialogue: 0,0:19:21.99,0:19:22.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:19:22.91,0:19:24.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa, di sini juga tidak ada.
Dialogue: 0,0:19:24.37,0:19:26.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:19:27.65,0:19:31.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengenai kapal Great Eirik milik\Nkelompok Bajak Laut Prajurit Raksasa
Dialogue: 0,0:19:31.98,0:19:34.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang masih belum tiba\Ndi Elbaf pada saat ini
Dialogue: 0,0:19:35.06,0:19:36.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}juga ada alasannya.
Dialogue: 0,0:19:37.03,0:19:39.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sebenarnya terjadi?
Dialogue: 0,0:19:39.60,0:19:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah terbangun\Nkarena terlalu banyak minum...
Dialogue: 0,0:19:42.01,0:19:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sunny sudah menghilang
Dialogue: 0,0:19:45.39,0:19:48.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan tidak dapat ditemukan!
Dialogue: 0,0:19:58.19,0:20:00.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku ingat mereka memang\Nberlayar berdampingan.
Dialogue: 0,0:20:01.43,0:20:03.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kapal itu tersapu arus?
Dialogue: 0,0:20:06.01,0:20:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah Luffy dan kawan-kawan\Ntelah menghilang?
Dialogue: 0,0:20:08.34,0:20:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya begitu.
Dialogue: 0,0:20:10.48,0:20:12.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sial, aku tidak bisa tenang!
Dialogue: 0,0:20:12.62,0:20:14.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begini,\Nkita tidak bisa kembali ke Elbaf.
Dialogue: 0,0:20:14.85,0:20:16.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita harus menemukan mereka!
Dialogue: 0,0:20:17.05,0:20:22.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah kapal itu\Nsudah dikunyah hancur oleh ikan?
Dialogue: 0,0:20:22.58,0:20:26.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ikan di sini tidak terbantahkan besarnya,\Njadi jangan berkata begitu.
Dialogue: 0,0:20:26.66,0:20:28.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ke mana sebenarnya mereka pergi?
Dialogue: 0,0:20:30.59,0:20:31.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luffy!
Dialogue: 0,0:20:31.63,0:20:32.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zoro!
Dialogue: 0,0:20:32.50,0:20:34.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Usopp!
Dialogue: 0,0:20:34.43,0:20:35.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sanji!
Dialogue: 0,0:20:36.06,0:20:38.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Chopper!
Dialogue: 0,0:20:38.27,0:20:41.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami!
Dialogue: 0,0:20:47.41,0:20:50.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:20:50.91,0:20:54.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:21:00.16,0:21:02.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:21:03.82,0:21:06.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:21:07.22,0:21:10.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:21:10.41,0:21:13.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:21:13.32,0:21:16.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:21:16.04,0:21:19.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:21:19.98,0:21:23.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:21:23.55,0:21:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:21:26.69,0:21:30.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:21:30.86,0:21:34.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:21:34.67,0:21:39.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:21:40.23,0:21:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:21:44.30,0:21:45.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:21:45.39,0:21:51.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:21:52.87,0:21:59.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:21:59.53,0:22:05.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:22:05.57,0:22:11.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:22:17.17,0:22:18.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami!
Dialogue: 0,0:22:18.77,0:22:19.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, cepat bangun!
Dialogue: 0,0:22:38.29,0:22:39.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sakit sekali.
Dialogue: 0,0:22:40.43,0:22:43.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku terlalu banyak minum.
Dialogue: 0,0:22:51.94,0:22:52.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh?
Dialogue: 0,0:23:04.01,0:23:07.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbangun sendirian di tempat asing,\NNami yang kebingungan.
Dialogue: 0,0:23:08.00,0:23:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lantai dan dinding\Ndengan bentuk yang aneh
Dialogue: 0,0:23:10.11,0:23:12.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serta monster raksasa\Nyang menyerang bertubi-tubi.
Dialogue: 0,0:23:12.76,0:23:15.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ini mimpi atau kenyataan?
Dialogue: 0,0:23:15.80,0:23:18.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Petualangan yang ditempuh\Noleh Geng Topi Jerami
Dialogue: 0,0:23:18.14,0:23:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}terus-menerus memunculkan\Nbahaya dan kegelisahan.
Dialogue: 0,0:23:20.66,0:23:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode selanjutnya, One Piece.
Dialogue: 0,0:23:22.32,0:23:30.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Kebingungan Nami,\NPetualangan di Negeri Balok Susun]
Dialogue: 0,0:23:22.42,0:23:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebingungan Nami,\Npetualangan di Negeri Balok Susun!
Dialogue: 0,0:23:25.50,0:23:27.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi Raja Bajak Laut!
