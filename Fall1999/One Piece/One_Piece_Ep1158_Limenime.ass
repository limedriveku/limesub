Dialogue: 0,0:21:24.68,0:21:30.68,tanda,,0,0,0,,{\b1}{\an8}[Bersambung]{\b0}
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Berlarilah\Nsampai tiba di sana ♪{\b0}
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪{\b0}
Dialogue: 0,0:00:21.28,0:00:23.32,tanda,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}[One Piece\NEpisode 1157]{\b0}
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Lautan yang begitu biru dan jernih ♪{\b0}
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Serpihan keajaiban yang bertebaran ♪{\b0}
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Jumlahnya tidak terhitung lagi ♪{\b0}
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Kita pun dipertemukan karenanya ♪{\b0}
Dialogue: 0,0:00:37.72,0:00:40.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪{\b0}
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Titik akhir masih belum terlihat juga ♪{\b0}
Dialogue: 0,0:00:44.38,0:00:47.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪{\b0}
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Demi melihat senyuman itu ♪{\b0}
Dialogue: 0,0:00:51.09,0:00:55.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪{\b0}
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪{\b0}
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪{\b0}
Dialogue: 0,0:01:04.62,0:01:08.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Belum ada yang berubah ♪{\b0}
Dialogue: 0,0:01:08.70,0:01:09.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Berlarilah ♪{\b0}
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪{\b0}
Dialogue: 0,0:01:17.27,0:01:23.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪{\b0}
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪{\b0}
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪{\b0}
Dialogue: 0,0:01:48.36,0:01:52.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei, jangan pergi dulu,\Nnanti tersesat lagi.{\b0}
Dialogue: 0,0:01:52.70,0:01:55.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku sudah melihatnya,\Nmana mungkin aku bisa tersesat?{\b0}
Dialogue: 0,0:01:55.53,0:01:56.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Baiklah.{\b0}
Dialogue: 0,0:01:57.33,0:01:59.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku tanya, makhluk apa sebenarnya dia itu?{\b0}
Dialogue: 0,0:02:00.03,0:02:02.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Singanya terlihat seperti kucing.{\b0}
Dialogue: 0,0:02:02.22,0:02:05.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tidak, mungkin kucing\Nyang berubah jadi singa.{\b0}
Dialogue: 0,0:02:05.38,0:02:07.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aslinya memang seekor kucing.{\b0}
Dialogue: 0,0:02:07.06,0:02:08.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Seharusnya singa, 'kan?{\b0}
Dialogue: 0,0:02:08.11,0:02:08.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kucing.{\b0}
Dialogue: 0,0:02:08.93,0:02:09.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Singa!{\b0}
Dialogue: 0,0:02:09.82,0:02:10.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kucing!{\b0}
Dialogue: 0,0:02:10.72,0:02:13.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hal seperti itu\Nyang mana saja boleh, 'kan?{\b0}
Dialogue: 0,0:02:13.14,0:02:15.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Segalanya berukuran sangat besar, ya.{\b0}
Dialogue: 0,0:02:15.20,0:02:17.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apakah kelinci itu masih ada?{\b0}
Dialogue: 0,0:02:19.37,0:02:20.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ada sesuatu yang datang.{\b0}
Dialogue: 0,0:02:20.63,0:02:21.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa?{\b0}
Dialogue: 0,0:02:21.98,0:02:23.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Nami, berdirilah di belakangku.{\b0}
Dialogue: 0,0:02:39.90,0:02:41.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ada apa?{\b0}
Dialogue: 0,0:02:45.47,0:02:53.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Menjelajahi negeri misterius!\NRahasia Dewa Matahari.{\b0}
Dialogue: 0,0:03:11.44,0:03:12.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Huf!{\b0}
Dialogue: 0,0:03:16.74,0:03:18.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Keren sekali!{\b0}
Dialogue: 0,0:03:22.20,0:03:23.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku tidak tahan dengan serangga.{\b0}
Dialogue: 0,0:03:23.42,0:03:25.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Serangga sebesar ini, curang sekali!{\b0}
Dialogue: 0,0:03:25.63,0:03:26.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukankah ini belalang?{\b0}
Dialogue: 0,0:03:27.11,0:03:29.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa yang sebenarnya terjadi di sini?{\b0}
Dialogue: 0,0:03:29.04,0:03:31.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Siapa kalian,\Napakah kalian pendatang baru?{\b0}
Dialogue: 0,0:03:31.82,0:03:33.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Paman, siapa kau?{\b0}
Dialogue: 0,0:03:33.28,0:03:34.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tempat apa ini?{\b0}
Dialogue: 0,0:03:34.21,0:03:35.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apakah kau tahu di mana rekan-rekan kami?{\b0}
Dialogue: 0,0:03:35.80,0:03:38.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bisakah kami menunggangi belalang itu?{\b0}
Dialogue: 0,0:03:38.12,0:03:39.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Pertanyaannya terlalu banyak.{\b0}
Dialogue: 0,0:03:40.51,0:03:42.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya tempat apa ini?{\b0}
Dialogue: 0,0:03:42.47,0:03:47.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Maaf, aku ada urusan\Njadi aku akan bicara singkat saja.{\b0}
Dialogue: 0,0:03:48.47,0:03:52.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Semua tanah yang luas ini adalah\Nmilik Dewa Matahari.{\b0}
Dialogue: 0,0:03:53.59,0:03:54.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari?{\b0}
Dialogue: 0,0:03:54.86,0:03:55.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa?{\b0}
Dialogue: 0,0:03:56.25,0:03:57.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Benar sekali.{\b0}
Dialogue: 0,0:03:57.48,0:04:00.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari adalah pencipta negara ini.{\b0}
Dialogue: 0,0:04:00.85,0:04:04.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dia bisa melihat segala sesuatu\Nyang terjadi di sini.{\b0}
Dialogue: 0,0:04:06.00,0:04:07.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa orang itu sangat hebat?{\b0}
Dialogue: 0,0:04:07.54,0:04:09.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tentu saja hebat, dia itu dewa.{\b0}
Dialogue: 0,0:04:09.93,0:04:12.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu adalah Pohon Dunia.{\b0}
Dialogue: 0,0:04:13.15,0:04:17.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari menciptakan negara ini\Ndengan Pohon Dunia sebagai pusatnya{\b0}
Dialogue: 0,0:04:17.18,0:04:19.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}dan mengutus para dewa untuk datang.{\b0}
Dialogue: 0,0:04:20.33,0:04:22.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dengan kata lain, ini adalah\NNegara Para Dewa.{\b0}
Dialogue: 0,0:04:23.42,0:04:27.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Penduduk negara ini sangat menghormati\Ndan takut kepada dewa.{\b0}
Dialogue: 0,0:04:27.71,0:04:28.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Begitu rupanya.{\b0}
Dialogue: 0,0:04:28.98,0:04:30.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Karena ini adalah keyakinan negara ini,{\b0}
Dialogue: 0,0:04:30.86,0:04:32.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}kita juga harus menghormatinya.{\b0}
Dialogue: 0,0:04:32.85,0:04:35.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, di mana bumi dipijak,\Ndi situ langit dijunjung.{\b0}
Dialogue: 0,0:04:35.76,0:04:40.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku adalah penguasa Kastel Bigstein ini\Ndan juga salah satu{\b0}
Dialogue: 0,0:04:41.06,0:04:43.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}dari pelayan Tuan Iscat.{\b0}
Dialogue: 0,0:04:43.98,0:04:45.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jika kalian berharap untuk menghadap Tuan,{\b0}
Dialogue: 0,0:04:45.56,0:04:48.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}mungkin suatu saat nanti bisa terwujud.{\b0}
Dialogue: 0,0:04:49.28,0:04:51.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Eh, ternyata ada orang di dalam kota.{\b0}
Dialogue: 0,0:04:51.30,0:04:52.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukan, itu seekor kucing.{\b0}
Dialogue: 0,0:04:53.02,0:04:53.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kucing?{\b0}
Dialogue: 0,0:04:58.04,0:04:59.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ah, maaf, kucing itu...{\b0}
Dialogue: 0,0:05:02.50,0:05:04.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kalau begitu, aku permisi dulu.{\b0}
Dialogue: 0,0:05:04.87,0:05:08.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Jarum Landak\Nsepertinya sudah lapar juga.{\b0}
Dialogue: 0,0:05:09.59,0:05:10.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Landak?{\b0}
Dialogue: 0,0:05:15.15,0:05:20.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Baru terjadi insiden Dewa Telinga Kelinci\NRaksasa mati dibakar di pinggir jalan.{\b0}
Dialogue: 0,0:05:20.36,0:05:22.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jadi, aku datang terlambat.{\b0}
Dialogue: 0,0:05:22.89,0:05:24.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu... adalah kami yang...{\b0}
Dialogue: 0,0:05:25.94,0:05:28.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini benar-benar sebuah bencana.{\b0}
Dialogue: 0,0:05:30.71,0:05:32.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jika kalian juga lapar,{\b0}
Dialogue: 0,0:05:32.89,0:05:35.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}pergilah ke jalan untuk mengambil fuda.{\b0}
Dialogue: 0,0:05:35.68,0:05:36.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Fuda?{\b0}
Dialogue: 0,0:05:37.01,0:05:38.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu adalah makanan.{\b0}
Dialogue: 0,0:05:38.95,0:05:40.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Makanan!{\b0}
Dialogue: 0,0:05:43.83,0:05:46.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Untuk berjaga-jaga,\Nkuberi tahu kalian dulu.{\b0}
Dialogue: 0,0:05:46.65,0:05:50.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kalian sama sekali tidak boleh\Npergi ke arah kastel itu.{\b0}
Dialogue: 0,0:05:51.30,0:05:51.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kenapa?{\b0}
Dialogue: 0,0:05:52.36,0:05:54.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Di sana adalah kuilnya Dewa Matahari.{\b0}
Dialogue: 0,0:05:55.22,0:05:57.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dijaga oleh prajurit-prajurit yang ganas.{\b0}
Dialogue: 0,0:05:58.30,0:06:02.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Siapa pun yang mendekati kuil tidak akan\Nbisa kembali dalam keadaan hidup.{\b0}
Dialogue: 0,0:06:03.57,0:06:05.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tunggu, nada bicaramu itu.{\b0}
Dialogue: 0,0:06:11.56,0:06:13.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Berhenti!{\b0}
Dialogue: 0,0:06:14.74,0:06:15.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ck!{\b0}
Dialogue: 0,0:06:16.31,0:06:17.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dasar, orang itu!{\b0}
Dialogue: 0,0:06:17.31,0:06:19.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sampai jumpa Paman, terima kasih banyak.{\b0}
Dialogue: 0,0:06:19.99,0:06:21.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Selain itu...{\b0}
Dialogue: 0,0:06:22.45,0:06:23.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Maaf, ya.{\b0}
Dialogue: 0,0:06:26.25,0:06:28.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dasar, Luffy ini!{\b0}
Dialogue: 0,0:06:29.58,0:06:31.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Prajurit yang ganas, ya.{\b0}
Dialogue: 0,0:06:31.73,0:06:34.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bahkan kau pun begini, makanya\NLuffy jadi berkelakuan seperti itu.{\b0}
Dialogue: 0,0:06:34.83,0:06:36.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Renungkanlah kesalahanmu.{\b0}
Dialogue: 0,0:06:36.49,0:06:38.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya mereka itu...{\b0}
Dialogue: 0,0:06:41.38,0:06:44.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa? Kastelnya sudah hancur.{\b0}
Dialogue: 0,0:06:49.65,0:06:51.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Penuh dengan aroma petualangan.{\b0}
Dialogue: 0,0:06:52.02,0:06:53.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Prajurit yang ganas.{\b0}
Dialogue: 0,0:06:53.89,0:06:55.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa.{\b0}
Dialogue: 0,0:06:55.46,0:06:58.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat keluar.{\b0}
Dialogue: 0,0:06:58.72,0:06:59.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ketemu.{\b0}
Dialogue: 0,0:07:00.05,0:07:01.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tunggu sebentar, Luffy!{\b0}
Dialogue: 0,0:07:01.81,0:07:03.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kau pikirkan juga situasi Nami.{\b0}
Dialogue: 0,0:07:03.58,0:07:04.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Percuma, Sanji.{\b0}
Dialogue: 0,0:07:04.94,0:07:07.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jika Luffy sudah jadi seperti itu,\Ntidak akan bisa dihentikan.{\b0}
Dialogue: 0,0:07:07.52,0:07:08.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Besar sekali!{\b0}
Dialogue: 0,0:07:09.62,0:07:11.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa di sini tidak ada permukiman warga?{\b0}
Dialogue: 0,0:07:12.47,0:07:15.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya sepanjang apa jalan ini?{\b0}
Dialogue: 0,0:07:16.21,0:07:17.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat lihat, kastel itu.{\b0}
Dialogue: 0,0:07:18.03,0:07:21.23,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukankah bentuknya sama persis\Ndengan kastel yang tadi?{\b0}
Dialogue: 0,0:07:21.45,0:07:22.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aneh.{\b0}
Dialogue: 0,0:07:27.20,0:07:28.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ada orang yang berlari ke sini.{\b0}
Dialogue: 0,0:07:29.40,0:07:31.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Orang itu juga memakai pakaian Elbaph.{\b0}
Dialogue: 0,0:07:32.58,0:07:33.18,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sudahlah.{\b0}
Dialogue: 0,0:07:33.40,0:07:34.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Biarkan dia lewat duluan.{\b0}
Dialogue: 0,0:07:41.33,0:07:42.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ada apa dengan orang ini?{\b0}
Dialogue: 0,0:07:42.98,0:07:44.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei, sangat berbahaya!{\b0}
Dialogue: 0,0:07:45.32,0:07:46.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jangan menghalangi jalan!{\b0}
Dialogue: 0,0:07:52.33,0:07:54.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Langitnya retak!{\b0}
Dialogue: 0,0:07:59.62,0:08:01.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya apa yang terjadi?{\b0}
Dialogue: 0,0:08:05.69,0:08:08.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat lihat, langit\Ndi sisi kuil itu retak.{\b0}
Dialogue: 0,0:08:09.06,0:08:11.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukan, di sisi lainnya juga begitu.{\b0}
Dialogue: 0,0:08:12.34,0:08:13.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa yang sebenarnya telah terjadi?{\b0}
Dialogue: 0,0:08:13.90,0:08:16.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hari ini, negara ini\Nbenar-benar kacau, ya?{\b0}
Dialogue: 0,0:08:26.38,0:08:29.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Langitnya... retak.{\b0}
Dialogue: 0,0:08:31.07,0:08:33.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini pasti adalah sebuah pembalasan.{\b0}
Dialogue: 0,0:08:33.05,0:08:34.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Fenomena alam yang luar biasa.{\b0}
Dialogue: 0,0:08:34.55,0:08:38.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukankah landak dan kucing\Nyang kita habisi itu adalah dewa?{\b0}
Dialogue: 0,0:08:38.21,0:08:40.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini pasti karena telah membuat dewa murka!{\b0}
Dialogue: 0,0:08:40.55,0:08:41.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Lihatlah baik-baik!{\b0}
Dialogue: 0,0:09:03.70,0:09:04.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu artinya...{\b0}
Dialogue: 0,0:09:05.41,0:09:06.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa yang terjadi?{\b0}
Dialogue: 0,0:09:13.26,0:09:15.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jelas sekali kalau ini adalah\Nsebuah kamar raksasa.{\b0}
Dialogue: 0,0:09:15.87,0:09:19.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Seharusnya ini bukan\Ndi atas kapal Elbaph, 'kan?{\b0}
Dialogue: 0,0:09:19.15,0:09:21.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukan, di kapal tidak ada\Nkamar yang seperti ini.{\b0}
Dialogue: 0,0:09:21.67,0:09:24.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, ada apa dengan kawat besi ini?{\b0}
Dialogue: 0,0:09:25.13,0:09:27.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jika dikatakan di sana ada raksasa,{\b0}
Dialogue: 0,0:09:29.16,0:09:34.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}kita benar-benar seperti hewan peliharaan\Nyang dikurung dalam sangkar besar.{\b0}
Dialogue: 0,0:09:34.55,0:09:36.15,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bagaimana bisa jadi begini?{\b0}
Dialogue: 0,0:09:50.70,0:09:53.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei, suara apa itu?{\b0}
Dialogue: 0,0:09:55.80,0:09:57.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apakah itu teman kita?{\b0}
Dialogue: 0,0:09:58.62,0:10:00.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tolong aku!{\b0}
Dialogue: 0,0:10:40.94,0:10:41.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tinggi sekali.{\b0}
Dialogue: 0,0:10:44.16,0:10:46.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei, kau ada di mana?{\b0}
Dialogue: 0,0:10:46.79,0:10:48.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei!{\b0}
Dialogue: 0,0:10:50.23,0:10:51.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Di sini!{\b0}
Dialogue: 0,0:11:00.15,0:11:01.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Chopper!{\b0}
Dialogue: 0,0:11:01.57,0:11:05.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Senang sekali bisa bertemu\Ndengan kalian semua.{\b0}
Dialogue: 0,0:11:08.38,0:11:10.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Chopper, ada apa dengan kalungmu itu?{\b0}
Dialogue: 0,0:11:10.88,0:11:15.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Entahlah. Begitu bangun sudah ada\Ndi leherku dan di tempat terkutuk begini.{\b0}
Dialogue: 0,0:11:15.78,0:11:18.98,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kalung besinya terlalu keras\Ndan tidak bisa dilepaskan.{\b0}
Dialogue: 0,0:11:19.68,0:11:22.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tadi aku mengira akan mati.{\b0}
Dialogue: 0,0:11:22.87,0:11:23.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jangan bergerak.{\b0}
Dialogue: 0,0:11:25.28,0:11:26.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Akan kupotong kalungnya.{\b0}
Dialogue: 0,0:11:26.51,0:11:27.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Menakutkan sekali!{\b0}
Dialogue: 0,0:11:28.43,0:11:29.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Benda semacam ini,{\b0}
Dialogue: 0,0:11:31.73,0:11:32.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}perkara mudah.{\b0}
Dialogue: 0,0:11:33.70,0:11:35.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Si Kucing Pencuri sungguh hebat.{\b0}
Dialogue: 0,0:11:39.81,0:11:42.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Terima kasih, Nami.{\b0}
Dialogue: 0,0:11:42.27,0:11:44.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kasihan sekali kau, Chopper.{\b0}
Dialogue: 0,0:11:44.43,0:11:46.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sekarang sudah tidak apa-apa.{\b0}
Dialogue: 0,0:11:46.09,0:11:47.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kau berutang budi padaku, ya.{\b0}
Dialogue: 0,0:11:48.81,0:11:50.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukankah tadi kau juga\Nmenangis tersedu-sedu?{\b0}
Dialogue: 0,0:11:50.63,0:11:52.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu adalah urusan yang berbeda.{\b0}
Dialogue: 0,0:11:54.70,0:11:58.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Di dalam kamar raksasa,\Nada pakaian seukuran manusia.{\b0}
Dialogue: 0,0:11:59.45,0:12:01.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Seperti boneka ganti baju, ya.{\b0}
Dialogue: 0,0:12:02.36,0:12:05.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Namun, jika ini dibuat oleh raksasa,{\b0}
Dialogue: 0,0:12:05.82,0:12:09.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari itu\Nbenar-benar terampil, ya.{\b0}
Dialogue: 0,0:12:19.83,0:12:21.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sedang apa kau di sana?{\b0}
Dialogue: 0,0:12:23.16,0:12:24.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat lihat, Sanji.{\b0}
Dialogue: 0,0:12:24.96,0:12:26.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Semuanya adalah balok susun.{\b0}
Dialogue: 0,0:12:28.66,0:12:32.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini benda yang digunakan\Nuntuk membangun seluruh negeri, 'kan?{\b0}
Dialogue: 0,0:12:32.57,0:12:34.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Saat memanggang kelinci,\Nada bau yang menyengat.{\b0}
Dialogue: 0,0:12:34.95,0:12:38.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu karena membakar\Nresin sintetis seperti ini, 'kan?{\b0}
Dialogue: 0,0:12:38.15,0:12:41.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, bukankah tadi kau\Nmenabrak sepotong langit{\b0}
Dialogue: 0,0:12:41.65,0:12:44.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}dan membuat jalanan terlihat\Nseperti tidak ada ujungnya?{\b0}
Dialogue: 0,0:12:45.11,0:12:46.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Itu adalah sebuah cermin.{\b0}
Dialogue: 0,0:12:46.90,0:12:47.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cermin?{\b0}
Dialogue: 0,0:12:48.52,0:12:51.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Berarti orang yang tadi itu\Nadalah diriku sendiri.{\b0}
Dialogue: 0,0:12:51.69,0:12:53.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Benar sekali, lihatlah.{\b0}
Dialogue: 0,0:12:58.01,0:12:59.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ah, bagian dalamnya bisa terlihat.{\b0}
Dialogue: 0,0:12:59.99,0:13:02.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kalau dilihat dari sini\Nhanya tampak seperti kaca biasa.{\b0}
Dialogue: 0,0:13:02.99,0:13:05.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ternyata ada cermin\Nyang seperti sulap begini.{\b0}
Dialogue: 0,0:13:09.35,0:13:13.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Nami, lain kali biarkan aku\Nyang membersihkan kamar perempuan.{\b0}
Dialogue: 0,0:13:13.67,0:13:15.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jangan harap bisa memanfaatkan kesempatan\Nini untuk memasang cermin semacam itu.{\b0}
Dialogue: 0,0:13:15.86,0:13:20.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Maksudnya, raksasa dengan tabiat buruk\Ntelah membangun Negeri Balok Susun{\b0}
Dialogue: 0,0:13:20.07,0:13:23.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}dan memasukkan manusia\Nserta hewan ke dalamnya untuk ditonton?{\b0}
Dialogue: 0,0:13:23.88,0:13:25.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Benar-benar membuat tidak nyaman.{\b0}
Dialogue: 0,0:13:25.57,0:13:28.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kalau begitu,\Napakah di sini adalah Elbaph?{\b0}
Dialogue: 0,0:13:28.45,0:13:31.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Di dalam rumah raksasa di negara raksasa?{\b0}
Dialogue: 0,0:13:34.41,0:13:36.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ternyata memang begitu, ya.{\b0}
Dialogue: 0,0:13:37.54,0:13:39.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Syukurlah.{\b0}
Dialogue: 0,0:13:41.58,0:13:43.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Belum tentu juga, 'kan?{\b0}
Dialogue: 0,0:13:43.78,0:13:47.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Satu-satunya hal yang pasti adalah\Npemilik kamar ini seorang raksasa.{\b0}
Dialogue: 0,0:13:47.87,0:13:49.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kita harus segera keluar.{\b0}
Dialogue: 0,0:13:49.77,0:13:50.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Di mana yang lainnya?{\b0}
Dialogue: 0,0:13:51.50,0:13:53.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Mari kita kabur\Nsebelum raksasanya kembali.{\b0}
Dialogue: 0,0:13:53.82,0:13:57.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sepertinya kita harus kembali\Nke jalanan untuk mengumpulkan informasi.{\b0}
Dialogue: 0,0:13:59.38,0:14:01.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Untuk berjaga-jaga, tidak peduli\Norang aneh macam apa pun yang ditemui,{\b0}
Dialogue: 0,0:14:01.51,0:14:04.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}kita harus menghindari terjadinya\Ngesekan dengan Suku Raksasa.{\b0}
Dialogue: 0,0:14:04.17,0:14:05.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei Luffy, kau paham?{\b0}
Dialogue: 0,0:14:06.21,0:14:07.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jangan terus berulah lagi.{\b0}
Dialogue: 0,0:14:10.64,0:14:13.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bolehkah aku menghajar\Nmakhluk ini hingga terbang?{\b0}
Dialogue: 0,0:14:15.41,0:14:17.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat hajar ia!{\b0}
Dialogue: 0,0:14:19.91,0:14:21.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat lihat ke bawah, ada tikus.{\b0}
Dialogue: 0,0:14:26.01,0:14:28.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jangan, dia merangkak naik.{\b0}
Dialogue: 0,0:14:31.71,0:14:32.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Di atas ada gagak.{\b0}
Dialogue: 0,0:14:34.92,0:14:36.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Mereka datang.{\b0}
Dialogue: 0,0:14:37.19,0:14:40.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa makhluk-makhluk ini\Nadalah prajurit dari kuil?{\b0}
Dialogue: 0,0:14:40.60,0:14:43.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ternyata ini alasan kenapa tidak ada\Nyang bisa kembali hidup-hidup.{\b0}
Dialogue: 0,0:14:43.89,0:14:47.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tempat terkutuk seperti ini\Nmana ada mirip-miripnya dengan kuil?{\b0}
Dialogue: 0,0:14:47.42,0:14:49.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, kelincinya juga sudah dimakan!{\b0}
Dialogue: 0,0:14:49.77,0:14:52.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Mari kita hajar semua\Nhewan itu sampai terbang.{\b0}
Dialogue: 0,0:15:20.12,0:15:22.00,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Mari kita selesaikan dalam satu serangan.{\b0}
Dialogue: 0,0:15:22.00,0:15:24.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jika tidak, saat Dewa Matahari kembali...{\b0}
Dialogue: 0,0:15:26.84,0:15:28.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Baiklah, kalau begitu.{\b0}
Dialogue: 0,0:15:45.27,0:15:46.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Gear Five.{\b0}
Dialogue: 0,0:16:04.57,0:16:07.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Terimalah seranganku!{\b0}
Dialogue: 0,0:16:39.13,0:16:41.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Berhenti kalian, tikus-tikus bau.{\b0}
Dialogue: 0,0:16:56.36,0:16:57.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sudah kukatakan.{\b0}
Dialogue: 0,0:16:58.76,0:16:59.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kubilang berhenti.{\b0}
Dialogue: 0,0:17:12.86,0:17:14.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Chopper, bisakah kau pergi ke sana?{\b0}
Dialogue: 0,0:17:17.16,0:17:19.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku mengerti, apakah ada sesuatu?{\b0}
Dialogue: 0,0:17:20.91,0:17:22.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ada aroma harta karun.{\b0}
Dialogue: 0,0:17:37.75,0:17:39.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aduh!{\b0}
Dialogue: 0,0:17:49.76,0:17:52.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Panas sekali, siapa yang melakukan ini?{\b0}
Dialogue: 0,0:17:52.24,0:17:53.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Luffy, kau sudah keterlaluan!{\b0}
Dialogue: 0,0:17:54.15,0:17:56.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bukan aku yang mengeluarkan\Napi dari pemanas itu.{\b0}
Dialogue: 0,0:18:00.39,0:18:00.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apa...{\b0}
Dialogue: 0,0:18:13.06,0:18:14.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Apakah itu Dewa Matahari?{\b0}
Dialogue: 0,0:18:17.94,0:18:20.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kuil milikku...{\b0}
Dialogue: 0,0:18:22.28,0:18:23.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hei, Luffy.{\b0}
Dialogue: 0,0:18:23.92,0:18:27.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari sudah kembali, cepat lari!{\b0}
Dialogue: 0,0:18:28.02,0:18:28.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Baik.{\b0}
Dialogue: 0,0:18:29.70,0:18:31.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku akan segera datang.{\b0}
Dialogue: 0,0:18:37.33,0:18:39.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bagianku ini akan segera selesai juga!{\b0}
Dialogue: 0,0:18:48.30,0:18:49.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Muginn!{\b0}
Dialogue: 0,0:18:54.48,0:18:56.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Gomu-gomu no{\b0}
Dialogue: 0,0:18:57.79,0:19:02.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dawn Pistol!{\b0}
Dialogue: 0,0:19:09.22,0:19:10.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jormungandr.{\b0}
Dialogue: 0,0:19:11.21,0:19:12.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Harus secepatnya.{\b0}
Dialogue: 0,0:19:13.77,0:19:14.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini adalah...{\b0}
Dialogue: 0,0:19:14.87,0:19:15.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ayo pergi, Nami.{\b0}
Dialogue: 0,0:19:16.04,0:19:16.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Hmm.{\b0}
Dialogue: 0,0:19:21.68,0:19:22.51,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Usopp.{\b0}
Dialogue: 0,0:19:24.24,0:19:25.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepatlah, Luffy.{\b0}
Dialogue: 0,0:19:38.26,0:19:39.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Tidak bisa dimaafkan.{\b0}
Dialogue: 0,0:19:41.11,0:19:42.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Besar sekali, raksasa itu.{\b0}
Dialogue: 0,0:19:43.03,0:19:45.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Benar, kelihatannya memang sangat aneh.{\b0}
Dialogue: 0,0:19:47.01,0:19:47.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Cepat lihat.{\b0}
Dialogue: 0,0:20:10.99,0:20:11.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dia bilang apa?{\b0}
Dialogue: 0,0:20:12.18,0:20:14.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dia bilang, ingatlah ini.{\b0}
Dialogue: 0,0:20:14.26,0:20:15.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Aku mengerti.{\b0}
Dialogue: 0,0:20:15.64,0:20:17.11,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jangan bicarakan itu lagi,\Ncepat lihat ini.{\b0}
Dialogue: 0,0:20:17.11,0:20:19.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Meskipun tidak ada benda berharga...{\b0}
Dialogue: 0,0:20:20.31,0:20:22.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini adalah cetak biru Negeri Balok Susun.{\b0}
Dialogue: 0,0:20:22.85,0:20:24.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Yang artinya, peta?{\b0}
Dialogue: 0,0:20:24.85,0:20:25.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Benar sekali.{\b0}
Dialogue: 0,0:20:26.40,0:20:27.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kerja bagus, Nami.{\b0}
Dialogue: 0,0:20:28.17,0:20:29.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Nami memang hebat!{\b0}
Dialogue: 0,0:20:29.81,0:20:30.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dia datang.{\b0}
Dialogue: 0,0:20:39.34,0:20:45.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Beraninya... beraninya kau\Nmembuat negaraku...{\b0}
Dialogue: 0,0:20:46.46,0:20:48.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kawan-Kawan, bersiaplah.{\b0}
Dialogue: 0,0:20:48.80,0:20:50.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Melewati tanah gersang ini,\Nlalu berlari melewati kastel.{\b0}
Dialogue: 0,0:20:50.84,0:20:53.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Jika lari terus sampai ke ujung,\Nakan ada cermin lagi.{\b0}
Dialogue: 0,0:20:54.16,0:20:58.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Begitu tembok luarnya dihancurkan\Nbersamaan, kita akan sampai di luar.{\b0}
Dialogue: 0,0:21:01.66,0:21:03.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Baik, semuanya dengarkan baik-baik.{\b0}
Dialogue: 0,0:21:04.93,0:21:06.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Bersiap untuk melarikan diri.{\b0}
Dialogue: 0,0:21:09.04,0:21:12.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Ini adalah... bumi sedang bergetar.{\b0}
Dialogue: 0,0:21:13.78,0:21:17.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari sudah marah.{\b0}
Dialogue: 0,0:21:21.32,0:21:23.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Kalian tidak akan dibiarkan kabur!{\b0}
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪{\b0}
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪{\b0}
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪{\b0}
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪{\b0}
Dialogue: 0,0:22:13.61,0:22:16.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪{\b0}
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪{\b0}
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪{\b0}
Dialogue: 0,0:22:33.79,0:22:41.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪{\b0}
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪{\b0}
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪{\b0}
Dialogue: 0,0:23:05.93,0:23:09.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Sebuah permainan petak umpet pemungkas\Ntelah dimulai di Negeri Balok Susun.{\b0}
Dialogue: 0,0:23:09.29,0:23:11.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}{\b1}Dewa Matahari yang ingin menangkap\NLuffy dan kawan-kawan,{\b0}
