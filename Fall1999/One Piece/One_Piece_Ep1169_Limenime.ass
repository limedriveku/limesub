Dialogue: 0,0:00:21.28,0:00:23.32,sign,,0000,0000,0000,,{\an8}[One Piece]\N[Episode 1169]
Dialogue: 0,0:11:15.42,0:11:17.12,sign,,0000,0000,0000,,{\an8}[Misionaris Cinta]
Dialogue: 0,0:11:40.95,0:11:45.34,sign,,0000,0000,0000,,{\an8}[Bocah yang imut dan kuat]
Dialogue: 0,0:18:17.33,0:18:20.01,sign,,0000,0000,0000,,{\an8}[Pemakan Gunung]
Dialogue: 0,0:21:24.61,0:21:30.57,sign,,0000,0000,0000,,[Bersambung]
Dialogue: 0,0:23:22.15,0:23:30.74,sign,,0000,0000,0000,,{\an8}[Merebut Kunci, Luffy VS Scopper Gaban]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:01:41.47,0:01:49.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}[Identitas Asli Legenda "Pemakan Gunung"\Nyang Tersembunyi di Elbaph]
Dialogue: 0,0:01:51.66,0:01:52.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci gembok,
Dialogue: 0,0:01:52.63,0:01:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}di mana kunci gemboknya Loki?
Dialogue: 0,0:02:03.06,0:02:04.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada.
Dialogue: 0,0:02:04.46,0:02:07.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sama sekali tidak ada harta karun.
Dialogue: 0,0:02:14.07,0:02:14.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hup.
Dialogue: 0,0:02:21.73,0:02:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Padahal sudah mencari begitu lamanya,
Dialogue: 0,0:02:23.68,0:02:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sama sekali tidak mungkin selesai.
Dialogue: 0,0:02:27.39,0:02:30.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat ini begitu besar,\Nhari pun sudah hampir gelap.
Dialogue: 0,0:02:34.23,0:02:37.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjaga gerbang pasti tidak mungkin tahu.
Dialogue: 0,0:02:37.48,0:02:40.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau memang sungguh ada yang tahu\Ndi mana kunci gemboknya,
Dialogue: 0,0:02:40.02,0:02:42.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}mungkin hanya Tuan Jarul, bukan?
Dialogue: 0,0:02:42.26,0:02:43.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarul?
Dialogue: 0,0:02:50.18,0:02:51.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yang pak tua pedang itu, ya?
Dialogue: 0,0:02:52.15,0:02:55.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Atau paling banyak masih ada\Nbeberapa tetua yang mengetahuinya.
Dialogue: 0,0:02:56.47,0:02:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau bertanya pada mereka,\Nmaukah mereka memberitahuku?
Dialogue: 0,0:02:59.23,0:03:01.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin mereka mau memberitahumu?
Dialogue: 0,0:03:01.27,0:03:04.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Melepaskan Loki adalah kejahatan berat.
Dialogue: 0,0:03:04.46,0:03:07.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami belum memutuskan untuk melepaskannya.
Dialogue: 0,0:03:08.10,0:03:10.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Zoro benar-benar ketat.
Dialogue: 0,0:03:13.51,0:03:15.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada apa-apa.
Dialogue: 0,0:03:23.70,0:03:24.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat lihat.
Dialogue: 0,0:03:24.95,0:03:25.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelah sini.
Dialogue: 0,0:03:28.17,0:03:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu adalah...
Dialogue: 0,0:03:29.86,0:03:31.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karpet merah?
Dialogue: 0,0:03:31.94,0:03:33.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Reruntuhan megah ini...
Dialogue: 0,0:03:34.27,0:03:36.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan-jangan ini Ruang Tahta?
Dialogue: 0,0:03:41.46,0:03:43.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf mengganggu.
Dialogue: 0,0:03:44.00,0:03:45.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tahta.
Dialogue: 0,0:03:46.74,0:03:50.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ternyata Ruang Tahta.
Dialogue: 0,0:03:51.05,0:03:52.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang Tahta?
Dialogue: 0,0:03:52.75,0:03:53.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tunggu dulu.
Dialogue: 0,0:04:05.76,0:04:06.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itukah tahta?
Dialogue: 0,0:04:07.30,0:04:09.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kursi yang besar sekali.
Dialogue: 0,0:04:11.52,0:04:13.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah hancur sampai seperti ini.
Dialogue: 0,0:04:14.34,0:04:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, langit-langitnya pun berlubang.
Dialogue: 0,0:04:18.73,0:04:20.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini tanda apa?
Dialogue: 0,0:04:22.55,0:04:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tanda?
Dialogue: 0,0:04:24.58,0:04:25.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?
Dialogue: 0,0:04:26.80,0:04:29.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sulit dilihat jika dari sana.
Dialogue: 0,0:04:30.65,0:04:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berdirilah di atas tanganku.
Dialogue: 0,0:05:01.68,0:05:02.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh.
Dialogue: 0,0:05:03.25,0:05:06.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Seperti formasi sihir\Nyang biasa ada di buku.
Dialogue: 0,0:05:06.57,0:05:07.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa itu?
Dialogue: 0,0:05:07.79,0:05:11.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benda yang digunakan untuk memanggil iblis\Ndalam upacara di beberapa negara.
Dialogue: 0,0:05:11.29,0:05:12.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bisa dipanggil?
Dialogue: 0,0:05:13.14,0:05:14.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku kurang jelas tentang itu.
Dialogue: 0,0:05:14.87,0:05:17.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Iblis!
Dialogue: 0,0:05:18.12,0:05:20.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepat keluar!
Dialogue: 0,0:05:20.68,0:05:21.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh membosankan.
Dialogue: 0,0:05:22.20,0:05:23.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mana mungkin keluar?
Dialogue: 0,0:05:24.54,0:05:27.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa ada benda seperti ini\Ndi Ruang Tahta?
Dialogue: 0,0:05:27.75,0:05:29.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh membuat orang merinding.
Dialogue: 0,0:05:32.34,0:05:35.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya aku pernah melihat\Nbenda ini baru-baru ini.
Dialogue: 0,0:05:36.62,0:05:37.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana?
Dialogue: 0,0:05:40.39,0:05:44.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana, ya? Coba kuingat-ingat.
Dialogue: 0,0:05:45.18,0:05:47.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi Jerami Luffy.
Dialogue: 0,0:05:49.57,0:05:51.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah menunggumu.
Dialogue: 0,0:05:51.55,0:05:53.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa? Apakah Iblis?
Dialogue: 0,0:05:53.65,0:05:55.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin?
Dialogue: 0,0:05:57.06,0:05:57.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa itu?
Dialogue: 0,0:06:00.21,0:06:04.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini arwah penasaran orang mati?
Dialogue: 0,0:06:05.69,0:06:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku selalu ingin bertemu denganmu.
Dialogue: 0,0:06:10.92,0:06:12.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan marah!
Dialogue: 0,0:06:12.62,0:06:13.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:06:13.15,0:06:14.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jangan bergerak sembarangan!
Dialogue: 0,0:06:14.74,0:06:20.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tolong jangan marah.\NHamba tidak melakukan apa pun.
Dialogue: 0,0:06:25.75,0:06:27.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cepatlah muncul!
Dialogue: 0,0:06:27.59,0:06:30.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah itu ras iblis yang dipanggil?
Dialogue: 0,0:06:31.60,0:06:32.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kastel ini ternyata...
Dialogue: 0,0:06:35.71,0:06:37.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar-benar terkutuk!
Dialogue: 0,0:06:39.83,0:06:42.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selagi belum dirasuki, cepat lari!
Dialogue: 0,0:06:42.65,0:06:43.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:06:43.62,0:06:44.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lari, Road!
Dialogue: 0,0:06:44.84,0:06:45.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak bisa!
Dialogue: 0,0:06:46.02,0:06:47.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlalu menakutkan!
Dialogue: 0,0:06:47.99,0:06:48.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu.
Dialogue: 0,0:07:02.83,0:07:05.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lepaskan peganganmu!
Dialogue: 0,0:07:19.38,0:07:20.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih.
Dialogue: 0,0:07:23.55,0:07:27.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami-tasso, sungguh maaf.
Dialogue: 0,0:07:29.78,0:07:30.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pukul kau!
Dialogue: 0,0:07:31.94,0:07:33.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pukul aku?
Dialogue: 0,0:07:35.03,0:07:38.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, lumayan juga.
Dialogue: 0,0:07:42.85,0:07:43.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapak?
Dialogue: 0,0:07:44.27,0:07:45.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari mana asalnya?
Dialogue: 0,0:07:46.20,0:07:46.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sana.
Dialogue: 0,0:08:17.61,0:08:18.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-san.
Dialogue: 0,0:08:19.69,0:08:22.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Penduduk Elbaph, Suku Manusia\N(Mantan Bajak Laut), Paman Ya-san]
Dialogue: 0,0:08:22.65,0:08:25.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa? Ya-san?
Dialogue: 0,0:08:27.03,0:08:30.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Elbaph, semua orang memanggil\NYa-san dengan sebutan Paman Ya-san.
Dialogue: 0,0:08:31.51,0:08:33.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia manusia, 'kan?
Dialogue: 0,0:08:35.45,0:08:37.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kau bisa ada di sini?
Dialogue: 0,0:08:37.94,0:08:42.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tadi aku merasakan Haki yang sangat kuat\Ndi dalam kastel ini.
Dialogue: 0,0:08:42.53,0:08:45.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, tampaknya orang itu sudah pergi.
Dialogue: 0,0:08:46.51,0:08:48.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Alhasil malah bertemu kalian.
Dialogue: 0,0:08:49.55,0:08:51.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pernah dengar tentangmu,
Dialogue: 0,0:08:51.97,0:08:53.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Topi Jerami Luffy.
Dialogue: 0,0:08:55.25,0:08:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kabarnya kau telah mengalahkan Kaido.
Dialogue: 0,0:08:58.24,0:08:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negara Wano, ya.
Dialogue: 0,0:09:00.26,0:09:04.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tidak jumpa, aku sungguh ingin\Nmelihat-lihat ke sana lagi.
Dialogue: 0,0:09:04.09,0:09:06.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, kau pernah ke Negara Wano?
Dialogue: 0,0:09:09.11,0:09:11.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah pergi ke sekolah, ‘kan?
Dialogue: 0,0:09:12.46,0:09:15.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa kalian tidak bertemu\Nguru yang bernama Ripley itu?
Dialogue: 0,0:09:16.01,0:09:17.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah bertemu.
Dialogue: 0,0:09:18.07,0:09:20.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-san adalah suaminya.
Dialogue: 0,0:09:22.15,0:09:24.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yaitu ayahnya si mungil\Nbertubuh besar itu.
Dialogue: 0,0:09:33.78,0:09:35.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Si mungil bertubuh besar?
Dialogue: 0,0:09:37.13,0:09:37.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang benar.
Dialogue: 0,0:09:38.23,0:09:42.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, bocah itu bilang ayahnya adalah\NSuku Manusia.
Dialogue: 0,0:09:43.02,0:09:46.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata demikian.\NKalian sudah bertemu Colon dan Ripley.
Dialogue: 0,0:09:47.31,0:09:50.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Colon mewarisi lebih banyak\Ndarah keturunan Suku Raksasa.
Dialogue: 0,0:09:50.53,0:09:54.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Meskipun dia putraku, aku bahkan tak bisa\Nmemeluknya dengan benar.
Dialogue: 0,0:09:54.47,0:09:57.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain itu, dia sudah berusia 20 tahun.
Dialogue: 0,0:10:02.45,0:10:04.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ripley 80 tahun,
Dialogue: 0,0:10:04.58,0:10:06.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lebih tua dariku.
Dialogue: 0,0:10:11.50,0:10:14.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menikah dengan raksasa\Nbenar-benar tidak menguntungkan.
Dialogue: 0,0:10:14.94,0:10:16.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya aku yang makin tua.
Dialogue: 0,0:10:17.52,0:10:19.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Memang katanya demikian.
Dialogue: 0,0:10:20.39,0:10:21.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak, tunggu dulu.
Dialogue: 0,0:10:21.61,0:10:24.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak kusangka sungguh ada\Norang seperti ini.
Dialogue: 0,0:10:24.45,0:10:27.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Singkatnya, terlalu banyak\Nhal yang konyol.
Dialogue: 0,0:10:29.25,0:10:30.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta adalah...
Dialogue: 0,0:10:37.54,0:10:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta itu bebas.
Dialogue: 0,0:10:42.45,0:10:45.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dalam sejarah, banyak suku campuran.
Dialogue: 0,0:10:46.48,0:10:47.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku Buccaneer,
Dialogue: 0,0:10:47.60,0:10:48.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku Dosundada,
Dialogue: 0,0:10:48.82,0:10:50.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku Lengan Panjang, Kaki Panjang,\NLeher Ular,
Dialogue: 0,0:10:50.50,0:10:51.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku Wotan.
Dialogue: 0,0:10:52.10,0:10:54.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku hibrida sulit bertahan.
Dialogue: 0,0:10:54.87,0:10:58.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tapi di setiap zaman selalu ada\Norang-orang dengan pikiran terbuka itu.
Dialogue: 0,0:11:00.03,0:11:01.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau sepertinya tahu banyak.
Dialogue: 0,0:11:02.17,0:11:03.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ini sebenarnya siapa?
Dialogue: 0,0:11:10.54,0:11:15.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Misionaris Cinta.
Dialogue: 0,0:11:21.22,0:11:22.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menyebalkan sekali.
Dialogue: 0,0:11:22.55,0:11:24.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sanji kalau sudah tua nanti,
Dialogue: 0,0:11:24.50,0:11:26.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kiranya akan jadi seperti itu.
Dialogue: 0,0:11:32.69,0:11:34.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Luar biasa!
Dialogue: 0,0:11:34.70,0:11:37.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sanji keren sekali.
Dialogue: 0,0:11:37.56,0:11:40.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kapasitas minumnya hebat sekali.
Dialogue: 0,0:11:41.01,0:11:43.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bocah yang imut dan kuat.
Dialogue: 0,0:11:44.25,0:11:45.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Yeah.
Dialogue: 0,0:11:45.67,0:11:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para kakak juga hebat sekali.
Dialogue: 0,0:11:49.70,0:11:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh luar biasa.
Dialogue: 0,0:11:53.74,0:11:57.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cinta, cinta.
Dialogue: 0,0:11:57.51,0:11:58.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Usopp.
Dialogue: 0,0:11:59.25,0:12:01.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa aku pernah cerita tentang ini padamu?
Dialogue: 0,0:12:02.46,0:12:03.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang apa?
Dialogue: 0,0:12:03.75,0:12:06.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentang pria yang luar biasa kuat itu.
Dialogue: 0,0:12:08.30,0:12:10.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku belum pernah mendengarnya.
Dialogue: 0,0:12:12.71,0:12:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu dia adalah awak kapal\NRaja Bajak Laut.
Dialogue: 0,0:12:17.38,0:12:19.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Awak kapal Raja Bajak Laut?
Dialogue: 0,0:12:19.64,0:12:21.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Belum pernah dengar.
Dialogue: 0,0:12:21.58,0:12:23.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau dengar, cepat ceritakan padaku.
Dialogue: 0,0:12:25.61,0:12:26.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Paman.
Dialogue: 0,0:12:27.59,0:12:30.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sedang mencari kunci gemboknya Loki.
Dialogue: 0,0:12:30.82,0:12:31.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:12:31.90,0:12:34.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu tidak boleh sembarangan dibicarakan.
Dialogue: 0,0:12:34.20,0:12:36.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, mana mungkin dia tahu?
Dialogue: 0,0:12:36.72,0:12:38.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, anggap aku tidak bilang apa-apa.
Dialogue: 0,0:12:38.08,0:12:39.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana mungkin?
Dialogue: 0,0:12:40.51,0:12:42.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau ingin membebaskan Loki itu?
Dialogue: 0,0:12:45.94,0:12:47.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menarik.
Dialogue: 0,0:12:49.22,0:12:53.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling suka\Nlihat orang menyebabkan masalah.
Dialogue: 0,0:12:53.52,0:12:54.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hobi buruk macam apa itu?
Dialogue: 0,0:12:54.99,0:12:57.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan bilang siapa-siapa tentang hal ini!
Dialogue: 0,0:12:58.66,0:12:59.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nona Muda.
Dialogue: 0,0:13:02.33,0:13:05.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Rahasia itu harus...
Dialogue: 0,0:13:06.47,0:13:09.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Disebarkan ke semua orang.
Dialogue: 0,0:13:09.03,0:13:10.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah kukatakan, jangan bilang!
Dialogue: 0,0:13:11.20,0:13:13.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudahlah, Nami-tasso.
Dialogue: 0,0:13:16.86,0:13:17.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu aku tanya kau.
Dialogue: 0,0:13:17.97,0:13:21.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tahukah kau Loki itu pria seperti apa?
Dialogue: 0,0:13:26.42,0:13:29.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika terjadi situasi terburuk,
Dialogue: 0,0:13:29.58,0:13:31.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apa yang akan kau lakukan?
Dialogue: 0,0:13:33.30,0:13:37.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau begitu, aku hajar dia\Nsampai melayang, lalu kurung dia lagi.
Dialogue: 0,0:13:45.92,0:13:51.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu ada seorang pria bernama\NRambut Merah, Shanks yang menangkap Loki.
Dialogue: 0,0:13:52.02,0:13:55.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum itu, tidak ada\Nyang bisa menghentikannya.
Dialogue: 0,0:13:56.33,0:14:00.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau benar-benar yakin bisa menang\Nmelawan bocah seperti itu?
Dialogue: 0,0:14:00.57,0:14:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lagi pula, tahukah kau\Nkemampuan apa yang bisa digunakan Loki?
Dialogue: 0,0:14:04.48,0:14:08.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau sampai dia lepas kendali, seberapa\Nbesar kerusakan yang bisa terjadi,
Dialogue: 0,0:14:08.17,0:14:10.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semua itu sudah kau pikirkan?
Dialogue: 0,0:14:11.24,0:14:13.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Walau kau berhasil mengurungnya lagi,
Dialogue: 0,0:14:14.41,0:14:18.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}itu akan berdampak besar\Npada para Suku Raksasa Elbaph!
Dialogue: 0,0:14:19.28,0:14:22.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Itu juga harus kau pertimbangkan.\N- Baiklah, ayo cari kunci gemboknya.
Dialogue: 0,0:14:22.09,0:14:23.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pada saatnya nanti...
Dialogue: 0,0:14:24.71,0:14:26.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Paman, ceritamu sepertinya panjang sekali.
Dialogue: 0,0:14:26.44,0:14:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendengarkanmu juga buang-buang waktu.
Dialogue: 0,0:14:28.81,0:14:30.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, berhenti!
Dialogue: 0,0:14:30.23,0:14:32.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dengarkan aku!
Dialogue: 0,0:14:32.62,0:14:33.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar.
Dialogue: 0,0:14:33.62,0:14:34.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei.
Dialogue: 0,0:14:34.87,0:14:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku menyerah.
Dialogue: 0,0:14:36.70,0:14:39.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi, sebenarnya di mana harta karunnya?
Dialogue: 0,0:14:41.07,0:14:41.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami-tasso?
Dialogue: 0,0:14:42.44,0:14:44.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maaf, Ya-san. Mereka, itu...
Dialogue: 0,0:14:45.14,0:14:46.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:14:47.39,0:14:50.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia sudah dengan baik hati\Nmemperingatkan kalian.
Dialogue: 0,0:14:51.52,0:14:53.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mendengarnya bicara terlalu merepotkan.
Dialogue: 0,0:15:02.12,0:15:03.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, dengarkan aku!
Dialogue: 0,0:15:11.73,0:15:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah cukup mendengar nasihat kalian.
Dialogue: 0,0:15:14.55,0:15:15.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah takut?
Dialogue: 0,0:15:15.97,0:15:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak bilang begitu.
Dialogue: 0,0:15:18.07,0:15:20.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, kamu pikirkan masak-masak dulu.
Dialogue: 0,0:15:20.88,0:15:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa katamu?
Dialogue: 0,0:15:27.14,0:15:30.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalau mau menghentikanku,\Nbicaralah dengan tinju!
Dialogue: 0,0:15:31.03,0:15:35.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Maksudku, pahami dulu risikonya,\NRoger si bodoh!
Dialogue: 0,0:16:12.65,0:16:13.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Road.
Dialogue: 0,0:16:14.03,0:16:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dorong tahta itu.
Dialogue: 0,0:16:16.39,0:16:16.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:16:21.22,0:16:23.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dulu, di antara\Nawak kapal Raja Bajak Laut,
Dialogue: 0,0:16:24.58,0:16:29.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}selain Roger ada dua bajak laut\Nyang luar biasa kuat.
Dialogue: 0,0:16:31.06,0:16:33.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selain Rayleigh, masih ada satu lagi?
Dialogue: 0,0:16:34.67,0:16:36.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau kenal Rayleigh?
Dialogue: 0,0:16:36.82,0:16:38.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya, aku pernah bertemu dengannya.
Dialogue: 0,0:16:39.05,0:16:42.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang yang dibicarakan adalah\Npria yang satu lagi.
Dialogue: 0,0:16:42.78,0:16:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pernah suatu kali, Roger sedang dirawat\Ndi rumah sakit pegunungan.
Dialogue: 0,0:16:49.81,0:16:52.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu juga ikut dengannya.
Dialogue: 0,0:16:53.18,0:16:57.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sayangnya, mereka justru dikepung\Noleh bajak laut musuh.
Dialogue: 0,0:16:58.30,0:17:00.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu berjalan keluar sendirian.
Dialogue: 0,0:17:03.31,0:17:07.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada ratusan bajak laut di hadapannya.
Dialogue: 0,0:17:09.82,0:17:11.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tinggalkan barang berharga,
Dialogue: 0,0:17:12.11,0:17:14.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}lalu cepat enyah dari sini.
Dialogue: 0,0:17:26.44,0:17:28.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kamu tebak apa yang terjadi setelah itu?
Dialogue: 0,0:17:30.05,0:17:31.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang terjadi?
Dialogue: 0,0:17:47.78,0:17:54.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia hanya dengan dua buah kapak\Nberhasil mengalahkan ratusan bajak laut.
Dialogue: 0,0:17:54.52,0:17:55.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sendirian saja?
Dialogue: 0,0:17:57.34,0:17:58.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya dengan dua buah kapak?
Dialogue: 0,0:17:59.59,0:18:00.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak hanya itu.
Dialogue: 0,0:18:01.80,0:18:05.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di tempat dia bertempur,\Ntidak ada satu pun pohon yang tersisa.
Dialogue: 0,0:18:05.25,0:18:08.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya tersisa sebuah gunung yang gundul.
Dialogue: 0,0:18:10.22,0:18:11.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pasti dia sudah menebang semuanya.
Dialogue: 0,0:18:11.92,0:18:15.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena itu, kemudian\Norang-orang menjulukinya
Dialogue: 0,0:18:18.02,0:18:19.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pemakan Gunung.
Dialogue: 0,0:18:20.21,0:18:24.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu setara\Ndengan Wakil Kapten Silvers Rayleigh.
Dialogue: 0,0:18:24.28,0:18:27.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia disebut Tangan Kiri Raja Bajak Laut.
Dialogue: 0,0:18:29.33,0:18:33.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cerita ini cukup terkenal.\NAku juga pernah dengar.
Dialogue: 0,0:18:33.88,0:18:38.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku benar-benar ingin bertemu pria itu.
Dialogue: 0,0:18:40.70,0:18:41.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ruang rahasia?
Dialogue: 0,0:18:42.32,0:18:43.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini Ruang Harta Karun?
Dialogue: 0,0:18:44.62,0:18:46.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada harta karun di dalamnya?
Dialogue: 0,0:18:46.25,0:18:47.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh mengesankan.
Dialogue: 0,0:18:48.44,0:18:50.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-san, kau baik sekali!
Dialogue: 0,0:18:52.03,0:18:56.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun.
Dialogue: 0,0:18:56.50,0:18:59.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ya-san, bagaimana kau tahu tempat ini?
Dialogue: 0,0:18:59.92,0:19:01.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengeksplorasi adalah hobiku.
Dialogue: 0,0:19:01.67,0:19:02.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun.
Dialogue: 0,0:19:03.22,0:19:04.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun.
Dialogue: 0,0:19:06.70,0:19:18.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Harta karun.
Dialogue: 0,0:19:23.35,0:19:25.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah menemukan harta karun!
Dialogue: 0,0:19:31.87,0:19:32.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa ini?
Dialogue: 0,0:19:34.50,0:19:35.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya kosong.
Dialogue: 0,0:19:36.14,0:19:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini bukan Ruang Harta Karun.
Dialogue: 0,0:19:38.46,0:19:40.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini ruang peti harta.
Dialogue: 0,0:19:42.05,0:19:44.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini memang dulunya Ruang Harta Karun.
Dialogue: 0,0:19:44.79,0:19:46.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penipu. Payah sekali.
Dialogue: 0,0:19:47.31,0:19:48.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan salahkan aku.
Dialogue: 0,0:19:49.30,0:19:51.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah kastel tanpa penghuni.
Dialogue: 0,0:19:51.26,0:19:53.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja jadi incaran pencuri.
Dialogue: 0,0:19:54.37,0:19:55.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, coba kalian lihat.
Dialogue: 0,0:20:05.69,0:20:06.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kunci gembok,
Dialogue: 0,0:20:06.36,0:20:07.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}bagus sekali!
Dialogue: 0,0:20:08.48,0:20:13.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Satu-satunya benda yang tidak diinginkan\Npara pencuri yang kemari adalah ini.
Dialogue: 0,0:20:13.55,0:20:19.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bahkan para penjahat\Ntidak ingin Loki dibebaskan.
Dialogue: 0,0:20:22.71,0:20:25.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bisakah kau merebut kunci gembok ini?
Dialogue: 0,0:20:25.59,0:20:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:26.93,0:20:28.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa?
Dialogue: 0,0:20:28.43,0:20:29.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jadi dia ada di sini.
Dialogue: 0,0:20:30.55,0:20:33.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pria itu sudah tinggal di Elbaph\Nselama lebih dari 20 tahun.
Dialogue: 0,0:20:34.25,0:20:35.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah?
Dialogue: 0,0:20:36.12,0:20:37.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini sungguh mengejutkan.
Dialogue: 0,0:21:00.90,0:21:02.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:21:02.46,0:21:08.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia adalah sosok legendaris\Nyang sejajar dengan Roger dan Rayleigh.
Dialogue: 0,0:21:13.67,0:21:15.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Kiri Raja Bajak Laut,
Dialogue: 0,0:21:17.26,0:21:19.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Scopper Gaban.
Dialogue: 0,0:21:21.70,0:21:23.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cobalah rebut dari tanganku.
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
Dialogue: 0,0:23:04.91,0:23:09.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dengan kunci untuk membebaskan Loki\Ndi tangannya, Gaban mengadang Luffy.
Dialogue: 0,0:23:09.42,0:23:11.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di balik sikapnya\Nyang tampak acuh tak acuh,
Dialogue: 0,0:23:11.89,0:23:14.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tersembunyi Haki dan kemampuan fisik\Nyang luar biasa kuat.
Dialogue: 0,0:23:15.00,0:23:17.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tangan Kiri Raja Bajak Laut\Nyang legendaris
Dialogue: 0,0:23:17.38,0:23:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}akan segera menunjukkan kekuatannya\Nyang luar biasa.
Dialogue: 0,0:23:20.16,0:23:22.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode selanjutnya, One Piece.
Dialogue: 0,0:23:22.27,0:23:25.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Merebut Kunci, Luffy VS Scopper Gaban.
Dialogue: 0,0:23:25.75,0:23:27.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi Raja Bajak Laut!
