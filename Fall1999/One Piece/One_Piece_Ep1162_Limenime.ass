Dialogue: 0,0:00:21.28,0:00:23.32,tanda,,0000,0000,0000,,{\an8}[One Piece]\N[Episode 1162]
Dialogue: 0,0:04:08.44,0:04:12.30,tanda,,0000,0000,0000,,{\an8}[Dunia Bawah]
Dialogue: 0,0:06:04.77,0:06:09.58,tanda,,0000,0000,0000,,{\an8}[Dunia Bawah]
Dialogue: 0,0:06:18.38,0:06:21.84,tanda,,0000,0000,0000,,{\an8}[Colon, Bocah Elbaph]
Dialogue: 0,0:13:02.24,0:13:06.32,tanda,,0000,0000,0000,,{\an8}[Elbaph, Dunia Matahari (Lantai Dua)]
Dialogue: 0,0:21:26.38,0:21:30.68,tanda,,0000,0000,0000,,[Bersambung]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:01:42.36,0:01:49.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Keharuan yang luar biasa!\NPemandangan impian Elbaph.
Dialogue: 0,0:02:11.29,0:02:13.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini adalah Elbaph.
Dialogue: 0,0:02:17.30,0:02:21.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini ada para prajurit laut\Nyang pemberani!
Dialogue: 0,0:02:33.92,0:02:36.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mengapa
Dialogue: 0,0:02:42.62,0:02:45.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus dikejar oleh raksasa?
Dialogue: 0,0:02:48.16,0:02:49.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami, lihat ke sana!
Dialogue: 0,0:03:01.86,0:03:03.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ternyata di sini adalah
Dialogue: 0,0:03:27.57,0:03:29.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tempat yang didambakan.
Dialogue: 0,0:03:29.97,0:03:32.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iklimnya sangat berbeda\Ndengan yang di bawah.
Dialogue: 0,0:03:35.48,0:03:37.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada waktu untuk terharu.
Dialogue: 0,0:03:38.62,0:03:42.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di mana kalian?
Dialogue: 0,0:03:45.79,0:03:48.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian tidak akan dibiarkan kabur!
Dialogue: 0,0:03:49.13,0:03:51.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu wujud raksasa!
Dialogue: 0,0:03:51.47,0:03:53.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang dilakukan orang itu?
Dialogue: 0,0:03:53.40,0:03:54.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terima kasih, Sanji.
Dialogue: 0,0:03:55.54,0:03:58.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang yang mengganggu akan dibenci.
Dialogue: 0,0:03:58.45,0:03:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih baik tebas saja dia.
Dialogue: 0,0:03:59.98,0:04:01.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ja... Jangan!
Dialogue: 0,0:04:01.77,0:04:03.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak ingin membuat masalah\Ndengan Suku Raksasa.
Dialogue: 0,0:04:03.99,0:04:04.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:04:05.36,0:04:07.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ada ide bagus?
Dialogue: 0,0:04:26.25,0:04:31.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Jembatan gantung yang menghubungkan\NDunia Bawah dan Dunia Matahari]
Dialogue: 0,0:04:35.71,0:04:36.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terbangnya kejauhan!
Dialogue: 0,0:04:37.22,0:04:38.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, Sunny!
Dialogue: 0,0:04:41.18,0:04:44.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, itu kapal kita!
Dialogue: 0,0:04:52.86,0:04:54.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau adalah Luffy, 'kan?
Dialogue: 0,0:04:56.35,0:04:57.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Imut sekali!
Dialogue: 0,0:04:58.01,0:05:00.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku paling suka manusia kecil.
Dialogue: 0,0:05:01.60,0:05:04.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, tetapi aku\Ntidak sama dengan orang itu.
Dialogue: 0,0:05:04.56,0:05:06.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku berbeda dari si aneh Road.
Dialogue: 0,0:05:07.14,0:05:07.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Road?
Dialogue: 0,0:05:08.51,0:05:12.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tidak akan mengurung manusia\Nseperti yang dilakukan orang itu.
Dialogue: 0,0:05:12.04,0:05:14.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku hanya ingin berteman dengan manusia.
Dialogue: 0,0:05:14.11,0:05:18.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gerth, sekarang bukan waktunya\Nmembicarakan hal ini.
Dialogue: 0,0:05:18.73,0:05:20.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, maaf.
Dialogue: 0,0:05:20.75,0:05:22.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tahu tentang kalian.
Dialogue: 0,0:05:23.03,0:05:25.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian dibawa ke sini dengan paksa, 'kan?
Dialogue: 0,0:05:26.09,0:05:28.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga tidak ingin begini.
Dialogue: 0,0:05:28.67,0:05:31.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hal ini dilakukan\Noleh si aneh yang kami kenal.
Dialogue: 0,0:05:31.28,0:05:32.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sungguh minta maaf.
Dialogue: 0,0:05:33.07,0:05:34.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah si kepala tengkorak itu?
Dialogue: 0,0:05:35.15,0:05:38.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar kau baru saja\Nterbang dari Dunia Bawah,
Dialogue: 0,0:05:39.15,0:05:40.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}apakah kau jatuh?
Dialogue: 0,0:05:44.19,0:05:49.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan beri tahu siapa pun kita pernah\Nbertemu dan tentang janji kita, Luffy.
Dialogue: 0,0:05:50.24,0:05:52.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Soal itu...
Dialogue: 0,0:05:52.97,0:05:54.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mengeluarkan banyak keringat!
Dialogue: 0,0:05:54.81,0:05:56.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di kondisi sedingin ini?
Dialogue: 0,0:05:56.47,0:05:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu, maksudku yang itu...
Dialogue: 0,0:05:58.50,0:06:00.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak apa-apa.
Dialogue: 0,0:06:01.58,0:06:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kalau kau baik-baik saja.
Dialogue: 0,0:06:15.48,0:06:19.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suku Manusia yang sedang\Ndicari oleh para bos,
Dialogue: 0,0:06:19.75,0:06:21.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sebenarnya orang seperti apa, ya?
Dialogue: 0,0:06:40.73,0:06:42.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Great Eirik!
Dialogue: 0,0:06:42.47,0:06:44.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bajak Laut Prajurit Raksasa telah kembali!
Dialogue: 0,0:06:44.89,0:06:45.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah!
Dialogue: 0,0:06:46.05,0:06:47.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, lama sekali, ya.
Dialogue: 0,0:06:48.82,0:06:50.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi menyapa dulu.
Dialogue: 0,0:06:58.72,0:07:03.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, para kapten!\NMau minum segelas di kedai?
Dialogue: 0,0:07:09.92,0:07:12.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Gawat, sepertinya mereka\Nmau langsung naik ke atas.
Dialogue: 0,0:07:13.13,0:07:16.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Kalau ada tamu,\Nlebih baik naik ke atas, 'kan?
Dialogue: 0,0:07:16.93,0:07:20.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu orang-orang itu mulai minum,\Nmereka bisa minum selama tiga hari.
Dialogue: 0,0:07:21.08,0:07:23.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika kau pergi ke Dunia Matahari,\Nbawalah ini.
Dialogue: 0,0:07:23.77,0:07:25.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Barang kesukaan Ripley.
Dialogue: 0,0:07:25.99,0:07:28.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga membawakan\Nsedikit barang kesukaan ayahmu.
Dialogue: 0,0:07:28.38,0:07:29.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini persik panggang.
Dialogue: 0,0:07:31.42,0:07:35.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, tahukah kau tentang bajak laut yang\Ndibawa pulang Kapten Dorry and Brogy?
Dialogue: 0,0:07:36.11,0:07:39.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sepertinya bernama Ludy, 'kan?
Dialogue: 0,0:07:39.63,0:07:40.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja bukan!
Dialogue: 0,0:07:41.12,0:07:44.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Orang itu baru saja menjadi\Nsalah satu dari Empat Kaisar.
Dialogue: 0,0:07:44.31,0:07:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bos Rambut Merah juga\Npernah mengatakannya.
Dialogue: 0,0:07:46.94,0:07:51.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan lupakan\Nnama ini, Luffy si Topi Jerami.
Dialogue: 0,0:07:52.52,0:07:53.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namanya Luffy.
Dialogue: 0,0:07:56.90,0:07:57.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku pergi dulu!
Dialogue: 0,0:07:58.08,0:07:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, Nak!
Dialogue: 0,0:07:59.98,0:08:04.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sampaikan pada para bos, camilan\Nteman minum akan segera dikirim ke sana.
Dialogue: 0,0:08:04.16,0:08:05.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik, aku mengerti!
Dialogue: 0,0:08:25.59,0:08:29.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, itu Great Eirik!
Dialogue: 0,0:08:58.12,0:08:59.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelangi!
Dialogue: 0,0:09:01.37,0:09:03.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelangi yang indah telah muncul!
Dialogue: 0,0:09:03.60,0:09:07.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini pertama kalinya aku\Nmerasakan pelangi dari jarak sedekat ini.
Dialogue: 0,0:09:07.67,0:09:09.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini terlalu besar, bukan?
Dialogue: 0,0:09:10.56,0:09:13.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah di sisi lain sedang hujan?
Dialogue: 0,0:09:14.10,0:09:15.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kedatangan yang tepat!
Dialogue: 0,0:09:16.17,0:09:18.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kebetulan sekarang ada\Npelangi yang membentang.
Dialogue: 0,0:09:18.46,0:09:20.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, kalau begitu mari kita menumpang!
Dialogue: 0,0:09:26.37,0:09:29.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah pelangi bisa dilihat\Ndari sudut seperti ini?
Dialogue: 0,0:09:29.62,0:09:30.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Terlihat sangat jelas!
Dialogue: 0,0:09:31.27,0:09:34.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setiap kali melihatnya,\Nselalu terasa ajaib dan indah.
Dialogue: 0,0:09:34.31,0:09:36.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah ajaib begitu?
Dialogue: 0,0:09:36.75,0:09:38.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilukis dengan painter ini.
Dialogue: 0,0:09:39.60,0:09:40.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dilukis?
Dialogue: 0,0:09:41.88,0:09:44.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kau yang membuat\Npelangi ini muncul?
Dialogue: 0,0:09:45.11,0:09:46.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tentu saja.
Dialogue: 0,0:09:46.95,0:09:48.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah mendekati kaki gunung,
Dialogue: 0,0:09:48.72,0:09:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}kita akan naik.
Dialogue: 0,0:09:49.99,0:09:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baik!
Dialogue: 0,0:09:51.57,0:09:54.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Oh ya, kalian harus berpegangan\Nerat pada kami.
Dialogue: 0,0:09:54.75,0:09:56.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Karena kapal akan\Nberlayar secara vertikal.
Dialogue: 0,0:09:56.98,0:09:58.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Vertikal?
Dialogue: 0,0:09:58.30,0:09:58.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa?
Dialogue: 0,0:10:05.02,0:10:06.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar!
Dialogue: 0,0:10:13.81,0:10:15.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berangkat!
Dialogue: 0,0:10:16.85,0:10:18.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa... Apa yang terjadi?!
Dialogue: 0,0:10:18.21,0:10:20.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ah, aku lupa mengatakannya.
Dialogue: 0,0:10:21.18,0:10:24.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Elbaph berada di atas pohon itu,
Dialogue: 0,0:10:25.05,0:10:28.45,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jadi kita langsung menyeberangi\Npelangi untuk naik ke atas.
Dialogue: 0,0:10:28.72,0:10:31.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu sampai, mari kita\Nmulai pesta yang meriah!
Dialogue: 0,0:10:31.91,0:10:34.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bukan hal itu yang harus dijelaskan, 'kan?
Dialogue: 0,0:10:34.27,0:10:35.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kau bilang menyeberangi pelangi?
Dialogue: 0,0:10:35.78,0:10:38.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sekarang kapal ini\Nsedang berlayar di mana?
Dialogue: 0,0:10:38.30,0:10:42.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Pelangi terbentuk dari pembiasan\Ncahaya yang menyinari tetesan air hujan.
Dialogue: 0,0:10:44.08,0:10:47.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apa yang sedang kalian bicarakan?
Dialogue: 0,0:10:48.96,0:10:51.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Tentu saja pelangi bisa diseberangi.
Dialogue: 0,0:10:51.94,0:10:53.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah memang begitu?
Dialogue: 0,0:11:11.04,0:11:15.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Ternyata benar-benar bisa diseberangi!
Dialogue: 0,0:11:19.27,0:11:22.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hari ini angin searah, hari\Nyang bagus untuk pelayaran pelangi.
Dialogue: 0,0:11:22.92,0:11:25.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tidak ada hambatan di arus pelangi.
Dialogue: 0,0:11:25.93,0:11:29.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cukup mendayung sekali,\Nkapal akan terus bergerak maju.
Dialogue: 0,0:11:30.01,0:11:33.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jika Luffy dan yang lainnya melihat ini,\Nmereka pasti akan berteriak kegirangan.
Dialogue: 0,0:11:33.81,0:11:36.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku sudah berteriak!
Dialogue: 0,0:11:36.99,0:11:38.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga!
Dialogue: 0,0:11:42.73,0:11:46.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali, rasanya\Nseperti laut tujuh warna!
Dialogue: 0,0:11:46.94,0:11:49.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berkilau dan ada suaranya, imut sekali!
Dialogue: 0,0:11:50.09,0:11:52.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Masih ada banyak hal\Nyang tidak diketahui, ya.
Dialogue: 0,0:11:52.81,0:11:53.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Iya.
Dialogue: 0,0:11:53.95,0:11:56.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Let's Sing (*Mari bernyanyi bersama)!
Dialogue: 0,0:12:12.63,0:12:16.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Mengantarkan bir Binks\Nyang nikmat untukmu ♪
Dialogue: 0,0:12:16.24,0:12:17.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei!
Dialogue: 0,0:12:18.25,0:12:20.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Para bos Dorry and Brogy!
Dialogue: 0,0:12:20.83,0:12:22.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah si Topi Jerami ada?
Dialogue: 0,0:12:23.89,0:12:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku tadi sempat berpikir kapal siapa ini.
Dialogue: 0,0:12:25.47,0:12:27.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hajrudin, Stansen!
Dialogue: 0,0:12:28.56,0:12:30.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sudah lama tidak bertemu!
Dialogue: 0,0:12:30.07,0:12:31.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia Besi!
Dialogue: 0,0:12:34.75,0:12:38.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu ya, apakah si Topi Jerami\Ndan yang lainnya akan tiba agak terlambat?
Dialogue: 0,0:12:38.58,0:12:42.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami sengaja berburu\Nrusa besar untuk mereka.
Dialogue: 0,0:12:44.04,0:12:45.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Daging rusa besar enak sekali!
Dialogue: 0,0:12:46.02,0:12:47.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku jadi lapar.
Dialogue: 0,0:12:47.78,0:12:50.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, jika ada sisa,\Nbaru akan diberikan pada kalian, ya!
Dialogue: 0,0:12:51.17,0:12:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini makanan yang disiapkan\Nuntuk Geng Topi Jerami.
Dialogue: 0,0:12:55.67,0:12:57.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, terserah kau saja.
Dialogue: 0,0:13:17.41,0:13:20.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian sudah ketemu!
Dialogue: 0,0:13:22.85,0:13:25.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:13:27.21,0:13:28.43,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Boneka hidupku
Dialogue: 0,0:13:28.63,0:13:31.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang terbaik,
Dialogue: 0,0:13:31.66,0:13:33.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}cepat kembali!
Dialogue: 0,0:13:33.48,0:13:34.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan mendekat!
Dialogue: 0,0:13:34.75,0:13:36.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jangan ke sini!
Dialogue: 0,0:13:36.88,0:13:39.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ekspresi pilu itu...
Dialogue: 0,0:13:41.63,0:13:43.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sebelum ketahuan oleh semua orang,
Dialogue: 0,0:13:43.82,0:13:45.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}aku harus mengurung\Nkalian dengan lebih rapat
Dialogue: 0,0:13:45.60,0:13:48.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}dan memelihara kalian seumur hidup!
Dialogue: 0,0:13:48.61,0:13:49.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Nami-tasso!
Dialogue: 0,0:13:50.17,0:13:51.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Cho-tasso!
Dialogue: 0,0:14:01.67,0:14:03.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aduh, ampun!
Dialogue: 0,0:14:03.84,0:14:05.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Serius?
Dialogue: 0,0:14:05.16,0:14:08.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Perangkap semacam ini\Nbahkan tidak akan bisa mengelabui hewan.
Dialogue: 0,0:14:08.52,0:14:10.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kalian keterlaluan, Zoro, Sanji!
Dialogue: 0,0:14:11.32,0:14:12.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagaimana ini sekarang?
Dialogue: 0,0:14:13.03,0:14:15.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku bahkan tidak bergerak,\Ntidak apa-apa, 'kan?
Dialogue: 0,0:14:17.60,0:14:21.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kurang ajar,\Nkalian manusia-manusia kerdil!
Dialogue: 0,0:14:21.02,0:14:22.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baiklah, ayo pergi!
Dialogue: 0,0:14:23.13,0:14:25.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin segera\Nmelihat Negeri Raksasa!
Dialogue: 0,0:14:25.84,0:14:26.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketemu!
Dialogue: 0,0:14:32.66,0:14:35.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, Geng Topi Jerami juga ada di sana!
Dialogue: 0,0:14:36.10,0:14:39.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suara ini adalah... Gerth-tasso!
Dialogue: 0,0:14:40.07,0:14:42.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mungkinkah dia datang untuk membantuku?
Dialogue: 0,0:14:45.34,0:14:47.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ketahuan!
Dialogue: 0,0:14:59.46,0:15:02.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hentikan, Road!
Dialogue: 0,0:15:02.79,0:15:05.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dasar kau si aneh!
Dialogue: 0,0:15:20.60,0:15:22.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak Raksasa yang cantik!
Dialogue: 0,0:15:24.19,0:15:25.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Manusia kecil!
Dialogue: 0,0:15:26.20,0:15:29.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lihat, sudah tidak ada\Nbukti kalau kita menyerang.
Dialogue: 0,0:15:30.21,0:15:31.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benar juga.
Dialogue: 0,0:15:32.51,0:15:33.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei,
Dialogue: 0,0:15:33.95,0:15:35.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya!
Dialogue: 0,0:15:35.66,0:15:36.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Luffy!
Dialogue: 0,0:15:40.46,0:15:41.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sunny juga baik-baik saja!
Dialogue: 0,0:15:41.96,0:15:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Syukurlah!
Dialogue: 0,0:15:45.20,0:15:47.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Halo, kalian Geng Topi Jerami, 'kan?
Dialogue: 0,0:15:48.37,0:15:49.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku Gerth.
Dialogue: 0,0:15:50.10,0:15:51.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia Goldberg.
Dialogue: 0,0:15:52.06,0:15:54.57,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami adalah rekan Hajrudin.
Dialogue: 0,0:15:55.63,0:15:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Jarang-jarang kalian berkunjung ke sini,
Dialogue: 0,0:15:57.12,0:15:59.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}maaf sekali karena membuat kalian\Nmengalami kejadian seperti ini.
Dialogue: 0,0:15:59.65,0:16:02.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selanjutnya, biarkan kami\Nyang memandu jalan.
Dialogue: 0,0:16:03.88,0:16:05.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kakak Cantik Gerth\Nmemandu jalan untuk kita!
Dialogue: 0,0:16:05.90,0:16:09.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami semua tidak tahu apa\Nyang sebenarnya terjadi.
Dialogue: 0,0:16:09.94,0:16:12.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kami akan menjelaskannya kepada kalian\Ndan membuatnya menebus kesalahannya,
Dialogue: 0,0:16:12.75,0:16:14.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Suruh si aneh ini...
Dialogue: 0,0:16:15.08,0:16:17.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Lebih tepatnya si mesum, 'kan?
Dialogue: 0,0:16:18.59,0:16:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Usopp.
Dialogue: 0,0:16:21.18,0:16:23.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kudengar di lantai ini ada desa Elbaph!
Dialogue: 0,0:16:24.03,0:16:26.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Benarkah? Aku ingin sekali melihatnya!
Dialogue: 0,0:16:26.46,0:16:27.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku juga ingin melihatnya!
Dialogue: 0,0:16:32.92,0:16:36.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Setelah berjalan lurus menembus hutan ini,\Nkalian akan melihat lapisan awan.
Dialogue: 0,0:16:36.75,0:16:39.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitu duduk di atas awan,\Ndesa akan langsung terlihat.
Dialogue: 0,0:16:39.52,0:16:41.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita juga harus berangkat!
Dialogue: 0,0:17:00.25,0:17:01.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itu Awan Pulau!
Dialogue: 0,0:17:01.62,0:17:04.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, bagaimana jika ternyata\Nberbeda dengan Awan Pulau?
Dialogue: 0,0:17:04.70,0:17:05.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah berbeda?
Dialogue: 0,0:17:05.85,0:17:08.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dia bilang awan itu bisa diduduki.
Dialogue: 0,0:17:28.42,0:17:29.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:17:36.96,0:17:40.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kita bisa melihatnya\Nsetelah menembus awan itu.
Dialogue: 0,0:17:47.68,0:17:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elbaph memiliki total 3 lantai.
Dialogue: 0,0:17:51.22,0:17:54.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Dari atas ke bawah adalah Dunia Langit,\NDunia Matahari, dan Dunia Bawah.
Dialogue: 0,0:17:54.91,0:17:58.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tempat tinggal kami adalah\NDunia Matahari yang disinari mentari.
Dialogue: 0,0:17:58.38,0:18:00.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di lantai ini terdapat beberapa desa.
Dialogue: 0,0:18:00.97,0:18:04.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, areanya terlalu luas untuk bisa\Nmelihat seluruh pemandangannya.
Dialogue: 0,0:18:04.95,0:18:07.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Desa Elbaph ada di depan.
Dialogue: 0,0:18:11.49,0:18:12.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ada apa?
Dialogue: 0,0:18:12.35,0:18:14.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ti... Tidak apa-apa.
Dialogue: 0,0:18:15.07,0:18:19.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hanya saja, saat berpikir\Nbahwa di depan adalah desa para guruku...
Dialogue: 0,0:18:25.68,0:18:27.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ayo pergi, Teman-Teman!
Dialogue: 0,0:18:29.96,0:18:31.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu sebentar, Usopp!
Dialogue: 0,0:18:32.18,0:18:33.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Tunggu!
Dialogue: 0,0:18:33.47,0:18:35.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku mau jadi yang pertama sampai!
Dialogue: 0,0:18:38.90,0:18:40.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Itulah desa kami.
Dialogue: 0,0:18:41.42,0:18:43.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Selamat datang di Elbaph,
Dialogue: 0,0:18:53.38,0:18:54.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Negeri Raksasa!
Dialogue: 0,0:19:36.34,0:19:40.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Elbaph!
Dialogue: 0,0:19:41.84,0:19:46.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Semuanya, kelak aku pasti\Nakan pergi ke Elbaph,
Dialogue: 0,0:19:46.54,0:19:48.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}pergi ke desa para prajurit!
Dialogue: 0,0:19:49.11,0:19:51.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Bagus sekali, Usopp!\NKita pasti akan pergi ke sana!
Dialogue: 0,0:19:55.94,0:19:58.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Sesuatu yang besar membawa kekaguman.
Dialogue: 0,0:19:59.24,0:20:03.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Siapa yang bisa melukiskan keindahan\Npemandangan ini dengan kata-kata?
Dialogue: 0,0:20:03.89,0:20:06.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di sini adalah Pulau Elbaph,\NNegeri Wilayah Perang,
Dialogue: 0,0:20:07.67,0:20:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}yang umumnya disebut sebagai Elbaph.
Dialogue: 0,0:20:11.46,0:20:13.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Ini adalah negeri para raksasa.
Dialogue: 0,0:20:14.17,0:20:16.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Mulai dari bunga, rumput, pohon,
Dialogue: 0,0:20:17.35,0:20:19.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}serangga, ikan, burung,
Dialogue: 0,0:20:20.03,0:20:21.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}hingga berbagai macam hewan,
Dialogue: 0,0:20:21.62,0:20:24.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}semuanya berukuran sangat besar\Nhingga menakjubkan.
Dialogue: 0,0:20:25.20,0:20:30.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Wahai para petualang,\Nnikmatilah momen ini sepuasnya!
Dialogue: 0,0:20:32.36,0:20:34.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Hei, si Topi Jerami!
Dialogue: 0,0:20:35.50,0:20:38.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Eh, bukankah ini Hajrudin?
Dialogue: 0,0:20:38.47,0:20:41.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kalian sudah sampai?\NKami sempat mencari kalian ke mana-mana!
Dialogue: 0,0:20:41.95,0:20:44.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Apakah kalian baru sampai sekarang?
Dialogue: 0,0:20:44.01,0:20:47.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Baguslah kita bisa berkumpul\Nhasilnya sangat luar biasa!
Dialogue: 0,0:20:52.71,0:20:55.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Kenapa kalian bisa berada di atas pelangi?
Dialogue: 0,0:20:56.85,0:20:59.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}- Elbaph hebat sekali!
Dialogue: 0,0:21:01.67,0:21:03.82,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Biarkan kami naik juga!
Dialogue: 0,0:21:04.06,0:21:08.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Namun, mengenai tanah Elbaph\Nyang megah dan misterius ini,
Dialogue: 0,0:21:09.80,0:21:13.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}jika aku harus mencatatkan\Nsesuatu di sini,
Dialogue: 0,0:21:14.42,0:21:18.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}tolong ingatlah kalimat ini dengan baik,
Dialogue: 0,0:21:19.63,0:21:22.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}"Jangan tinggal lama di tempat ini."
Dialogue: 0,0:21:23.33,0:21:26.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Penjelajah, Louis Arnote.
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
Dialogue: 0,0:23:04.38,0:23:05.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Diburu oleh seluruh dunia,
Dialogue: 0,0:23:06.21,0:23:08.94,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Robin yang telah melewati jurang\Nkeputusasaan sepanjang jalannya,
Dialogue: 0,0:23:08.95,0:23:13.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}sangat memercayai ucapan Saul, sahabatnya,\N"Suatu hari kau pasti bertemu rekanmu."
Dialogue: 0,0:23:13.57,0:23:15.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Begitulah dia bertahan hidup\Nselama 22 tahun.
Dialogue: 0,0:23:16.00,0:23:17.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Di Elbaph yang akhirnya\Nberhasil dia capai ini,
Dialogue: 0,0:23:17.89,0:23:20.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}momen yang telah lama\Ndinantikan akhirnya tiba.
Dialogue: 0,0:23:21.13,0:23:22.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Episode selanjutnya, One Piece.
Dialogue: 0,0:23:22.49,0:23:30.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\an8}[Menginginkan Pujianmu!\NReuni Robin dan Saul]
Dialogue: 0,0:23:22.54,0:23:25.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Menginginkan pujianmu!\NReuni Robin dan Saul.
Dialogue: 0,0:23:25.83,0:23:28.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}Aku akan menjadi Raja Bajak Laut!
