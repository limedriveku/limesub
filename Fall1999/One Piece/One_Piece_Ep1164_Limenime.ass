Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berlarilah\Nsampai tiba di sana ♪{\b0}
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪{\b0}
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Lautan yang begitu biru dan jernih ♪{\b0}
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Serpihan keajaiban yang bertebaran ♪{\b0}
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Jumlahnya tidak terhitung lagi ♪{\b0}
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kita pun dipertemukan karenanya ♪{\b0}
Dialogue: 0,0:00:37.72,0:00:40.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪{\b0}
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Titik akhir masih belum terlihat juga ♪{\b0}
Dialogue: 0,0:00:44.38,0:00:47.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪{\b0}
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Demi melihat senyuman itu ♪{\b0}
Dialogue: 0,0:00:51.09,0:00:55.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪{\b0}
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪{\b0}
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪{\b0}
Dialogue: 0,0:01:04.62,0:01:08.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Belum ada yang berubah ♪{\b0}
Dialogue: 0,0:01:08.70,0:01:09.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berlarilah ♪{\b0}
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪{\b0}
Dialogue: 0,0:01:17.27,0:01:23.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪{\b0}
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪{\b0}
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪{\b0}
Dialogue: 0,0:01:41.39,0:01:49.13,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Pikiran Saul!\NKehendak Ohara yang diwariskan.{\b0}
Dialogue: 0,0:01:51.06,0:01:51.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baiklah.{\b0}
Dialogue: 0,0:01:58.50,0:01:59.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Paman Saul.{\b0}
Dialogue: 0,0:02:12.70,0:02:17.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sebelumnya bawahanku\Nsudah banyak Anda bantu.{\b0}
Dialogue: 0,0:02:18.20,0:02:19.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih banyak.{\b0}
Dialogue: 0,0:02:21.15,0:02:23.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu... mohon bimbingannya.{\b0}
Dialogue: 0,0:02:24.66,0:02:25.81,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu...{\b0}
Dialogue: 0,0:02:26.80,0:02:29.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau belajar dari mana?{\b0}
Dialogue: 0,0:02:29.66,0:02:33.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ke depannya mohon...{\b0}
Dialogue: 0,0:02:33.06,0:02:35.66,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hal itu disebut keadilan\Ndan kebajikan, 'kan?{\b0}
Dialogue: 0,0:02:37.31,0:02:38.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar sekali.{\b0}
Dialogue: 0,0:02:38.81,0:02:41.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ke depannya, mohon...{\b0}
Dialogue: 0,0:02:43.32,0:02:46.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Biar aku perkenalkan, dia adalah{\b0}
Dialogue: 0,0:02:46.96,0:02:47.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Luffy.{\b0}
Dialogue: 0,0:02:51.81,0:02:52.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku tahu.{\b0}
Dialogue: 0,0:02:53.34,0:02:54.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Luffy.{\b0}
Dialogue: 0,0:02:55.09,0:02:57.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ke depannya tolong\Nsering-sering hukum aku.{\b0}
Dialogue: 0,0:02:58.13,0:03:01.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Luffy, yang ingin kau katakan\Nadalah "Tolong ingat nama aku", 'kan?{\b0}
Dialogue: 0,0:03:01.71,0:03:02.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ah, benarkah?{\b0}
Dialogue: 0,0:03:06.46,0:03:07.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau ini orang terkenal.{\b0}
Dialogue: 0,0:03:08.20,0:03:10.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku dulu adalah seorang Angkatan Laut,{\b0}
Dialogue: 0,0:03:10.84,0:03:14.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}sehingga sangat mengerti\Nseberapa hebatnya seorang Empat Kaisar.{\b0}
Dialogue: 0,0:03:32.23,0:03:35.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau sudah bertemu dengannya, Robin.{\b0}
Dialogue: 0,0:03:36.93,0:03:39.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ya, apa yang dikatakan Saul itu benar.{\b0}
Dialogue: 0,0:03:40.95,0:03:42.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku benar-benar telah bertemu{\b0}
Dialogue: 0,0:03:49.99,0:03:54.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}dengan teman sejati yang dengan tulus\Nmelindungi orang sepertiku.{\b0}
Dialogue: 0,0:04:03.55,0:04:07.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Kami akan melindungimu seumur hidup.\N- Kami akan melindungimu seumur hidup.{\b0}
Dialogue: 0,0:04:10.49,0:04:13.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Astaga, bukan apa-apa,\Nini sudah menjadi hal yang wajar.{\b0}
Dialogue: 0,0:04:33.62,0:04:36.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Namun, kalian benar-benar\Ndatang dari jauh.{\b0}
Dialogue: 0,0:04:36.57,0:04:38.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Selamat datang di Elbaph,{\b0}
Dialogue: 0,0:04:38.71,0:04:40.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}teman-temannya Robin.{\b0}
Dialogue: 0,0:04:40.80,0:04:43.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Pertama-tama izinkan aku\Nmengucapkan terima kasih.{\b0}
Dialogue: 0,0:04:44.06,0:04:47.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih banyak karena kalian\Ntelah melindungi Robin.{\b0}
Dialogue: 0,0:04:49.81,0:04:52.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ke depannya aku juga mohon bantuan kalian.{\b0}
Dialogue: 0,0:04:53.75,0:04:55.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Serahkan saja pada kami.{\b0}
Dialogue: 0,0:04:55.34,0:04:59.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, Saul!{\b0}
Dialogue: 0,0:05:01.11,0:05:03.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ini aku!{\b0}
Dialogue: 0,0:05:03.86,0:05:05.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau ini siapa?{\b0}
Dialogue: 0,0:05:05.36,0:05:07.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Lama tidak berjumpa.{\b0}
Dialogue: 0,0:05:08.88,0:05:10.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah kabarmu baik?{\b0}
Dialogue: 0,0:05:10.86,0:05:12.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukan begitu, aku tidak mengenalmu.{\b0}
Dialogue: 0,0:05:13.18,0:05:15.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, kenapa kau bisa terbang?{\b0}
Dialogue: 0,0:05:15.23,0:05:16.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau benar-benar lamban.{\b0}
Dialogue: 0,0:05:17.18,0:05:20.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku ini Vegapunk.{\b0}
Dialogue: 0,0:05:20.56,0:05:21.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apa?{\b0}
Dialogue: 0,0:05:23.55,0:05:24.48,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah yang ini?{\b0}
Dialogue: 0,0:05:26.10,0:05:27.96,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar, maaf merepotkanmu.{\b0}
Dialogue: 0,0:05:28.93,0:05:30.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Biar aku yang menurunkannya.{\b0}
Dialogue: 0,0:05:30.77,0:05:34.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benda ini dibawa keluar dari Egg Head\Nsesuai dengan instruksi Vegapunk.{\b0}
Dialogue: 0,0:05:35.15,0:05:36.68,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Namun, apa isi di dalamnya?{\b0}
Dialogue: 0,0:05:38.22,0:05:40.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ini adalah aku.{\b0}
Dialogue: 0,0:05:41.90,0:05:42.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sudah.{\b0}
Dialogue: 0,0:05:42.74,0:05:44.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih, kau sangat membantu.{\b0}
Dialogue: 0,0:05:44.98,0:05:46.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apa maksud dari "Ini adalah aku"?{\b0}
Dialogue: 0,0:05:47.44,0:05:49.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau soal itu...{\b0}
Dialogue: 0,0:05:53.28,0:05:55.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kloning dari Vegapunk?{\b0}
Dialogue: 0,0:05:56.92,0:06:01.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar, di dalam sini ada sesuatu yang\Nberbeda dengan pengaturan kloning kami.{\b0}
Dialogue: 0,0:06:02.02,0:06:05.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu sebuah tubuh kloning\Nyang direplikasi secara sempurna.{\b0}
Dialogue: 0,0:06:05.04,0:06:05.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Omong-omong,{\b0}
Dialogue: 0,0:06:05.76,0:06:09.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}yang datang ke Elbaph 20 tahun yang lalu{\b0}
Dialogue: 0,0:06:10.70,0:06:13.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}adalah diriku yang ini.{\b0}
Dialogue: 0,0:06:16.49,0:06:20.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jika Tubuh Asli absen berbulan-bulan\Ndari lab, pemerintah pasti curiga.{\b0}
Dialogue: 0,0:06:22.94,0:06:26.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar-benar Paman\Nyang suka membuat masalah.{\b0}
Dialogue: 0,0:06:26.82,0:06:27.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hanya saja,{\b0}
Dialogue: 0,0:06:28.58,0:06:32.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}meskipun dimasukkan ke dalam cairan\Ninkubator dan berhasil dibawa keluar,{\b0}
Dialogue: 0,0:06:34.68,0:06:37.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}tidak ada alat untuk mengeluarkannya\Ndengan aman.{\b0}
Dialogue: 0,0:06:38.37,0:06:44.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jadi, aku akan tinggal di sini\Ndan membangun lab penelitian yang baru.{\b0}
Dialogue: 0,0:06:44.49,0:06:47.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Laboratorium penelitian\NVegapunk yang baru?{\b0}
Dialogue: 0,0:06:47.89,0:06:49.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau begitu, setelah kau\Nmenyelesaikannya,{\b0}
Dialogue: 0,0:06:49.73,0:06:52.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}apakah ayahku juga bisa pulih kembali?{\b0}
Dialogue: 0,0:06:54.18,0:06:55.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tentu saja, Bonney.{\b0}
Dialogue: 0,0:06:56.06,0:06:56.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Syukurlah!{\b0}
Dialogue: 0,0:06:57.36,0:06:59.49,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ini benar-benar hal yang sangat baik.{\b0}
Dialogue: 0,0:07:01.62,0:07:03.79,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau kau benar-benar Vegapunk,{\b0}
Dialogue: 0,0:07:04.22,0:07:07.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}ini adalah reuni yang menyenangkan\Nsetelah 20 tahun lamanya.{\b0}
Dialogue: 0,0:07:07.42,0:07:11.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Namun, kau tidak punya kepala besar\Ndan kenapa kau menjadi perempuan?{\b0}
Dialogue: 0,0:07:11.90,0:07:15.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak apa-apa, nanti akan\Nkujelaskan perlahan padamu.{\b0}
Dialogue: 0,0:07:21.69,0:07:22.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bersiap.{\b0}
Dialogue: 0,0:07:23.50,0:07:24.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Guru!\N- Guru!{\b0}
Dialogue: 0,0:07:25.12,0:07:26.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah sudah selesai?{\b0}
Dialogue: 0,0:07:26.25,0:07:28.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah sudah boleh pergi bermain?{\b0}
Dialogue: 0,0:07:28.51,0:07:31.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maaf, sekarang sudah boleh.{\b0}
Dialogue: 0,0:07:31.53,0:07:33.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih atas bantuan kalian.{\b0}
Dialogue: 0,0:07:34.40,0:07:36.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah ini anak-anak Suku Raksasa?{\b0}
Dialogue: 0,0:07:38.57,0:07:43.01,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya mata air ini juga\Nmerupakan tempat bermain anak-anak.{\b0}
Dialogue: 0,0:07:44.21,0:07:46.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Demi mendukung sandiwara Guru Saul,{\b0}
Dialogue: 0,0:07:46.25,0:07:48.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}mereka tinggal di samping\Ndan terdiam sejenak.{\b0}
Dialogue: 0,0:07:48.84,0:07:51.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Padahal aku sudah berlatih berkali-kali.{\b0}
Dialogue: 0,0:07:55.14,0:07:57.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Guru Saul terjatuh...{\b0}
Dialogue: 0,0:07:57.77,0:07:59.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Air masuk ke dalam hidung!{\b0}
Dialogue: 0,0:08:00.94,0:08:03.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Gawat!{\b0}
Dialogue: 0,0:08:03.35,0:08:05.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukan, ini terlalu jauh!{\b0}
Dialogue: 0,0:08:11.50,0:08:13.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maaf sudah mengejutkan kalian.{\b0}
Dialogue: 0,0:08:13.78,0:08:17.32,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukan, padahal sudah akting sampai\Nsejauh ini kenapa langsung ketahuan?{\b0}
Dialogue: 0,0:08:17.32,0:08:19.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maaf belum sempat memperkenalkan diri.{\b0}
Dialogue: 0,0:08:19.22,0:08:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku adalah Ange, asisten Guru Saul.{\b0}
Dialogue: 0,0:08:19.78,0:08:22.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}[Ange, Pustakawan\NPerpustakaan Burung Hantu (Asisten Saul)]{\b0}
Dialogue: 0,0:08:22.86,0:08:24.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maaf menyapa kalian dari atas sini.{\b0}
Dialogue: 0,0:08:25.35,0:08:29.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Di sini ada perpustakaan\Ndan sekolah terbaik di Elbaph.{\b0}
Dialogue: 0,0:08:30.17,0:08:31.03,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Perpustakaan?{\b0}
Dialogue: 0,0:08:31.44,0:08:34.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jika berkenan, aku akan\Nmengajak kalian berkeliling.{\b0}
Dialogue: 0,0:08:36.90,0:08:38.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sepertinya ini tempat\Nyang sangat menyenangkan.{\b0}
Dialogue: 0,0:08:38.67,0:08:43.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah bisa melihat pendidikan bakat\Npara prajurit Elbaph?{\b0}
Dialogue: 0,0:08:46.72,0:08:48.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku pergi dulu, Usopp.{\b0}
Dialogue: 0,0:08:48.33,0:08:49.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tunggu sebentar.{\b0}
Dialogue: 0,0:08:49.09,0:08:50.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dia sudah pergi.{\b0}
Dialogue: 0,0:08:54.32,0:08:56.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Berhenti, Luffy.{\b0}
Dialogue: 0,0:08:57.68,0:08:58.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu adalah{\b0}
Dialogue: 0,0:09:06.97,0:09:10.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}sekolah anak-anak Elbaph,\NSekolah Singa Laut.{\b0}
Dialogue: 0,0:09:11.54,0:09:16.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sekolah itu didirikan 20 tahun lalu oleh\NGuru Saul atas permintaan raja sebelumnya.{\b0}
Dialogue: 0,0:09:16.63,0:09:18.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kelihatannya sangat menarik.{\b0}
Dialogue: 0,0:09:18.24,0:09:21.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dengan kata lain ini adalah\Ntempat pelatihan prajurit, 'kan?{\b0}
Dialogue: 0,0:09:21.62,0:09:23.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ange, Gerth,{\b0}
Dialogue: 0,0:09:23.98,0:09:27.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}bawa semuanya jalan-jalan\Nke tempat yang mereka suka.{\b0}
Dialogue: 0,0:09:27.47,0:09:30.53,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku ingin membawa Robin\Nmelihat-lihat perpustakaan.{\b0}
Dialogue: 0,0:09:30.82,0:09:31.71,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baik.{\b0}
Dialogue: 0,0:09:32.36,0:09:33.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Serahkan saja padaku.{\b0}
Dialogue: 0,0:09:35.85,0:09:39.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalau begitu, bagi yang ingin\Nmelihat sekolah silakan ikuti aku.{\b0}
Dialogue: 0,0:09:39.31,0:09:41.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Untuk tempat lainnya akan aku pandu.{\b0}
Dialogue: 0,0:09:42.87,0:09:46.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sekolah, ya? Ini mengingatkanku pada dojo.{\b0}
Dialogue: 0,0:09:48.78,0:09:51.75,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku juga ingin pergi\Nke sekolah, jadi rindu.{\b0}
Dialogue: 0,0:09:51.88,0:09:53.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ayo pergi, Zoro.{\b0}
Dialogue: 0,0:09:54.22,0:09:55.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Chopper, ayo pergi.{\b0}
Dialogue: 0,0:09:56.95,0:09:59.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku ingin pergi ke perpustakaan.{\b0}
Dialogue: 0,0:10:00.10,0:10:02.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Kalau begitu aku akan menemanimu, Nami.\N- Apakah bukunya juga sangat besar?{\b0}
Dialogue: 0,0:10:02.35,0:10:05.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak peduli apa yang terjadi,\Naku akan melindungimu.{\b0}
Dialogue: 0,0:10:06.91,0:10:09.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bagaimana denganmu, Franky?{\b0}
Dialogue: 0,0:10:11.90,0:10:14.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya aku sejak tadi{\b0}
Dialogue: 0,0:10:24.51,0:10:27.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}sangat tertarik dengan pohon besar ini.{\b0}
Dialogue: 0,0:10:33.64,0:10:35.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Besar sekali.{\b0}
Dialogue: 0,0:10:39.48,0:10:41.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ini adalah negara raksasa.{\b0}
Dialogue: 0,0:10:41.47,0:10:43.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ada kurcaci kecil.{\b0}
Dialogue: 0,0:10:43.12,0:10:46.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kami akan menangkap kalian\Nuntuk dijadikan tawanan.{\b0}
Dialogue: 0,0:10:46.00,0:10:47.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah harus ditebas?{\b0}
Dialogue: 0,0:10:47.26,0:10:48.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hentikan, Bodoh!{\b0}
Dialogue: 0,0:10:48.87,0:10:50.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tunggu sebentar!{\b0}
Dialogue: 0,0:10:51.24,0:10:52.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalian tidak bisa kabur.{\b0}
Dialogue: 0,0:10:52.79,0:10:54.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tangkap dia.{\b0}
Dialogue: 0,0:10:54.23,0:10:55.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baiklah, ayo kita bertarung.{\b0}
Dialogue: 0,0:10:56.48,0:10:58.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Majulah, Bocah tengik.{\b0}
Dialogue: 0,0:10:58.48,0:11:02.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar juga, mereka ini\Npara calon prajurit masa depan.{\b0}
Dialogue: 0,0:11:04.22,0:11:05.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei!{\b0}
Dialogue: 0,0:11:07.86,0:11:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak boleh mengejar manusia kecil!{\b0}
Dialogue: 0,0:11:10.54,0:11:12.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Juga tidak boleh memanggil "kurcaci".{\b0}
Dialogue: 0,0:11:12.60,0:11:13.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maafkan kami.{\b0}
Dialogue: 0,0:11:13.69,0:11:14.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Lemah sekali.{\b0}
Dialogue: 0,0:11:15.26,0:11:18.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah mereka benar-benar\Nanak-anak dari desa prajurit?{\b0}
Dialogue: 0,0:11:20.02,0:11:22.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jangan memanggil dengan sebutan\Nbocah atau semacamnya.{\b0}
Dialogue: 0,0:11:22.39,0:11:23.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar.{\b0}
Dialogue: 0,0:11:23.72,0:11:26.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, ada yang tidak beres, 'kan?{\b0}
Dialogue: 0,0:11:27.40,0:11:29.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Memanggil kami kurcaci juga tidak apa-apa.{\b0}
Dialogue: 0,0:11:30.74,0:11:35.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kelak kalian juga akan melaut untuk perang\Nmelawan orang-orang ganas itu, 'kan?{\b0}
Dialogue: 0,0:11:38.79,0:11:40.44,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ada apa, apa yang terjadi?{\b0}
Dialogue: 0,0:11:40.84,0:11:41.61,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hal seperti itu...{\b0}
Dialogue: 0,0:11:41.61,0:11:43.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kami sama sekali tidak mau bertarung.{\b0}
Dialogue: 0,0:11:43.09,0:11:44.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukankah itu sangat berbahaya?{\b0}
Dialogue: 0,0:11:45.76,0:11:48.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukankah kalian ini\Nprajurit cadangan Elbaph?{\b0}
Dialogue: 0,0:11:50.06,0:11:51.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak boleh memanggil dengan kata kasar.{\b0}
Dialogue: 0,0:11:51.64,0:11:55.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar, kami tidak berencana\Nmenjadi prajurit.{\b0}
Dialogue: 0,0:11:58.34,0:11:59.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kenapa?{\b0}
Dialogue: 0,0:12:00.23,0:12:01.89,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu sudah ketinggalan zaman.{\b0}
Dialogue: 0,0:12:04.32,0:12:05.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Anak-anak zaman sekarang{\b0}
Dialogue: 0,0:12:06.77,0:12:09.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}mana mungkin menyukai hal semacam itu?{\b0}
Dialogue: 0,0:12:11.59,0:12:12.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Siapa itu?{\b0}
Dialogue: 0,0:12:12.31,0:12:14.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apa maksud dari ketinggalan zaman?{\b0}
Dialogue: 0,0:12:14.77,0:12:16.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, sebaiknya jangan berdiri di sana.{\b0}
Dialogue: 0,0:12:17.04,0:12:19.18,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar, itu bisa marah.{\b0}
Dialogue: 0,0:12:20.89,0:12:22.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, tempat itu adalah...{\b0}
Dialogue: 0,0:12:31.72,0:12:33.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tubuh dari Guru Ripley.{\b0}
Dialogue: 0,0:12:34.52,0:12:36.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Di atas tubuh raksasa!{\b0}
Dialogue: 0,0:12:36.98,0:12:37.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maafkan kami.{\b0}
Dialogue: 0,0:12:39.18,0:12:41.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak apa-apa, lagi pula tidak berat.{\b0}
Dialogue: 0,0:12:41.54,0:12:44.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Oh ya, karena Anda adalah guru,\Ntolong beri tahu kami.{\b0}
Dialogue: 0,0:12:44.64,0:12:47.84,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kenapa anak-anak ini\Ntidak ingin menjadi prajurit lagi?{\b0}
Dialogue: 0,0:12:49.84,0:12:55.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kukira semua orang Elbaph\Nmendambakan untuk menjadi prajurit.{\b0}
Dialogue: 0,0:12:56.51,0:12:58.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah kau merasa terpukul?{\b0}
Dialogue: 0,0:12:58.58,0:13:03.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kekacauan dunia oleh prajurit Elbaph\Nsudah terjadi 100 tahun lalu.{\b0}
Dialogue: 0,0:13:07.56,0:13:11.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kata-kata kotor, kekerasan,\Npenjarahan, perang?{\b0}
Dialogue: 0,0:13:12.09,0:13:13.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Eh, aduh.{\b0}
Dialogue: 0,0:13:13.87,0:13:16.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sekarang sudah bukan\Nzaman seperti itu lagi.{\b0}
Dialogue: 0,0:13:20.30,0:13:21.23,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Selamat datang.{\b0}
Dialogue: 0,0:13:21.25,0:13:22.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku sudah mendengarnya dari Saul.{\b0}
Dialogue: 0,0:13:22.88,0:13:25.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalian ini Geng Topi Jerami, 'kan?{\b0}
Dialogue: 0,0:13:25.59,0:13:27.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar, mohon bantuannya.{\b0}
Dialogue: 0,0:13:28.11,0:13:30.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Maaf ya, anak-anak\Ndi tempat kami ini agak berisik.{\b0}
Dialogue: 0,0:13:31.51,0:13:34.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bukan, perkataanmu itu\Njuga tidak benar, 'kan?{\b0}
Dialogue: 0,0:13:35.52,0:13:37.95,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku ini adalah contoh buruknya.{\b0}
Dialogue: 0,0:13:38.65,0:13:40.52,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Guru keterlaluan sekali.{\b0}
Dialogue: 0,0:13:41.02,0:13:44.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Luffy, rupanya kalian ada di sini.{\b0}
Dialogue: 0,0:13:45.46,0:13:48.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak disangka Elbaph\Nbukan lagi markas prajurit.{\b0}
Dialogue: 0,0:13:55.17,0:13:57.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Raja Harald yang bijak pernah berkata,{\b0}
Dialogue: 0,0:13:57.61,0:14:00.98,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}daripada bertarung, perdagangan\Ndengan negara lain harus lebih diutamakan.{\b0}
Dialogue: 0,0:14:00.98,0:14:04.90,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sambil menentang para tetua dari\Nsetiap desa yang mementingkan tradisi,{\b0}
Dialogue: 0,0:14:04.90,0:14:07.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}beliau juga mendorong adanya reformasi.{\b0}
Dialogue: 0,0:14:07.08,0:14:08.38,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Raja Harald?{\b0}
Dialogue: 0,0:14:09.35,0:14:14.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu adalah nama raja hebat\Nyang ingin mereformasi negara ini.{\b0}
Dialogue: 0,0:14:14.89,0:14:19.56,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hanya saja, Raja Harald dalam usahanya\Nmencapai impian telah dibunuh{\b0}
Dialogue: 0,0:14:20.57,0:14:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}oleh putra kandungnya sendiri.{\b0}
Dialogue: 0,0:14:23.59,0:14:26.26,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Negara tidak mengizinkan\Nputranya untuk naik takhta.{\b0}
Dialogue: 0,0:14:26.26,0:14:28.80,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sekarang Elbaph tidak memiliki raja.{\b0}
Dialogue: 0,0:14:29.95,0:14:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baiklah, kelas sejarah telah berakhir.{\b0}
Dialogue: 0,0:14:33.86,0:14:37.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kalian semua, bawa orang-orang ini\Nberkeliling sekolah.{\b0}
Dialogue: 0,0:14:37.29,0:14:39.00,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Baik.\N- Baik.{\b0}
Dialogue: 0,0:14:39.05,0:14:40.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku ingin menjadi penunjuk jalan.{\b0}
Dialogue: 0,0:14:40.37,0:14:41.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Biar aku yang menjadi penunjuk jalan.{\b0}
Dialogue: 0,0:14:41.35,0:14:42.04,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku juga ingin menjadi penunjuk jalan.{\b0}
Dialogue: 0,0:14:42.04,0:14:43.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baiklah, aku mengerti.{\b0}
Dialogue: 0,0:14:46.89,0:14:48.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku juga ingin memandu.{\b0}
Dialogue: 0,0:14:53.58,0:14:55.64,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Manusia kecil, tidak apa-apa, 'kan?{\b0}
Dialogue: 0,0:14:58.29,0:14:59.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih.{\b0}
Dialogue: 0,0:15:01.13,0:15:01.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tuan Kapten.{\b0}
Dialogue: 0,0:15:04.16,0:15:06.16,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kenapa kau tidak dalam wujud putih?{\b0}
Dialogue: 0,0:15:06.37,0:15:08.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Padahal aku cukup menantikannya.{\b0}
Dialogue: 0,0:15:09.01,0:15:11.36,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Itu adalah wujud kebebasanku.{\b0}
Dialogue: 0,0:15:13.08,0:15:14.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kebebasan?{\b0}
Dialogue: 0,0:15:20.29,0:15:22.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sebenarnya di dalam mitologi Elbaph,{\b0}
Dialogue: 0,0:15:22.37,0:15:25.37,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}terdapat seorang prajurit\Ndengan wujud seperti itu.{\b0}
Dialogue: 0,0:15:26.96,0:15:28.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku sampai merasa takjub.{\b0}
Dialogue: 0,0:15:28.71,0:15:31.34,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, kamilah generasi\Nprajurit yang terakhir.{\b0}
Dialogue: 0,0:15:31.34,0:15:35.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Guru, cepatlah.{\b0}
Dialogue: 0,0:15:35.67,0:15:36.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baiklah.{\b0}
Dialogue: 0,0:15:38.20,0:15:39.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ayo pergi, manusia kecil.{\b0}
Dialogue: 0,0:15:48.07,0:15:51.42,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Begitu ya, aku kira-kira\Nsudah mendengarnya.{\b0}
Dialogue: 0,0:15:52.38,0:15:57.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Pada saat itu, aku kembali ke Elbaph\Ndengan nyawa yang hanya tersisa setengah.{\b0}
Dialogue: 0,0:15:58.78,0:16:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sungguh tidak rela melepas literatur yang\Ndijaga cendekiawan dengan taruhan nyawa.{\b0}
Dialogue: 0,0:16:04.00,0:16:08.33,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jadi aku minta tolong Hajrudin dan lainnya\Nuntuk membawaku kembali ke Ohara.{\b0}
Dialogue: 0,0:16:17.79,0:16:18.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kemudian,{\b0}
Dialogue: 0,0:16:19.40,0:16:23.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}saat melihat buku-buku kecil itu\Nternyata masih utuh tersimpan,{\b0}
Dialogue: 0,0:16:23.53,0:16:25.17,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}aku sampai menangis.{\b0}
Dialogue: 0,0:16:27.68,0:16:29.41,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Baiklah Robin, silakan masuk.{\b0}
Dialogue: 0,0:16:30.91,0:16:33.02,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hati-hati dengan buku itu, ya.{\b0}
Dialogue: 0,0:16:57.74,0:16:58.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Robin.{\b0}
Dialogue: 0,0:17:14.67,0:17:15.40,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Cepat lihat.{\b0}
Dialogue: 0,0:17:24.00,0:17:25.20,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah kau terkejut?{\b0}
Dialogue: 0,0:17:26.43,0:17:29.24,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Semua buku pada masa itu,\Ntelah berubah menjadi ukuran raksasa.{\b0}
Dialogue: 0,0:17:29.24,0:17:31.97,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Buku yang dibawa ke sini\Nsemuanya akan membesar.{\b0}
Dialogue: 0,0:17:36.26,0:17:37.27,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Selamat datang{\b0}
Dialogue: 0,0:17:37.66,0:17:40.19,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}di Perpustakaan Burung Hantu\Nyang ajaib ini.{\b0}
Dialogue: 0,0:17:41.47,0:17:45.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Semua literatur yang diselamatkan Ohara\Nsaat 22 tahun yang lalu ada di sini.{\b0}
Dialogue: 0,0:17:46.78,0:17:48.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak ada satu buku pun yang tertinggal.{\b0}
Dialogue: 0,0:17:48.91,0:17:52.11,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Semuanya dibawa kembali\Nsetelah dicari di setiap sudut.{\b0}
Dialogue: 0,0:17:53.03,0:17:54.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Semuanya telah dibawa kembali!{\b0}
Dialogue: 0,0:18:01.18,0:18:02.72,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Cepat selamatkan buku-bukunya!{\b0}
Dialogue: 0,0:18:02.72,0:18:04.47,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Biarkan sejarah diwariskan\Nke generasi selanjutnya.{\b0}
Dialogue: 0,0:18:04.47,0:18:06.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Setidaknya, meninggalkan\Nlebih banyak satu buku juga bagus.{\b0}
Dialogue: 0,0:18:06.59,0:18:09.35,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Setidaknya, meninggalkan\Nlebih banyak satu kalimat juga bagus.{\b0}
Dialogue: 0,0:18:09.35,0:18:12.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Harus membuat catatan\Npara leluhur dari ribuan tahun yang lalu{\b0}
Dialogue: 0,0:18:14.12,0:18:16.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}tersampaikan hingga ke masa depan.{\b0}
Dialogue: 0,0:18:21.02,0:18:23.93,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Ini adalah perpustakaan\Nterbaik di seluruh dunia.{\b0}
Dialogue: 0,0:18:26.90,0:18:31.50,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Robin, apakah kau menyukai buku?{\b0}
Dialogue: 0,0:18:39.65,0:18:43.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak disangka akan ada hari di mana\Naku bisa memperlihatkannya kepadamu.{\b0}
Dialogue: 0,0:18:56.45,0:18:59.54,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau juga cukup menganggur, Tuan Mosa.{\b0}
Dialogue: 0,0:19:00.23,0:19:01.60,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apakah mengganggumu?{\b0}
Dialogue: 0,0:19:02.79,0:19:06.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tidak juga, kebetulan aku\Njuga sedang menghabiskan waktu.{\b0}
Dialogue: 0,0:19:07.98,0:19:10.31,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Lagi pula, aku punya banyak waktu.{\b0}
Dialogue: 0,0:19:11.80,0:19:14.30,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Pengalaman mengerikan\Nyang kau ceritakan sebelumnya,{\b0}
Dialogue: 0,0:19:14.30,0:19:16.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}apakah kau belum bisa\Nmengatasinya sampai sekarang?{\b0}
Dialogue: 0,0:19:16.06,0:19:20.22,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Iya, kalau diingat sekarang saja\Nmasih membuatku merinding.{\b0}
Dialogue: 0,0:19:16.08,0:19:23.29,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}[Den Den Mushi Siaran Salju\N(Tipe Pengenalan Suara Tahan Dingin)]{\b0}
Dialogue: 0,0:19:21.18,0:19:23.09,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku juga sangat kesal.{\b0}
Dialogue: 0,0:19:25.01,0:19:28.07,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Padahal aku tidak bisa melihatmu\Ndan belum pernah bertemu denganmu,{\b0}
Dialogue: 0,0:19:28.07,0:19:29.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}juga tidak tahu ada takdir apa{\b0}
Dialogue: 0,0:19:30.25,0:19:32.51,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}aku sudah menjadi teman lama denganmu.{\b0}
Dialogue: 0,0:19:33.05,0:19:35.25,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Seandainya aku ada di tempat kejadian,{\b0}
Dialogue: 0,0:19:36.60,0:19:39.73,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}pasti sudah membantumu\Nmenghancurkan seluruh area itu{\b0}
Dialogue: 0,0:19:40.28,0:19:41.99,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}dan membunuh semua orang!{\b0}
Dialogue: 0,0:19:42.71,0:19:45.91,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku... aku sama sekali\Ntidak berpikir sampai sejauh itu.{\b0}
Dialogue: 0,0:19:47.12,0:19:48.92,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Makanya kubilang kau itu naif!{\b0}
Dialogue: 0,0:19:50.00,0:19:53.86,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Dengar, orang bodoh yang pernah lolos\Ntak boleh diberi kesempatan bangkit lagi.{\b0}
Dialogue: 0,0:19:53.86,0:19:56.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jika tidak, dia akan datang\Nuntuk balas dendam.{\b0}
Dialogue: 0,0:19:56.05,0:19:57.63,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Terima kasih.{\b0}
Dialogue: 0,0:19:58.01,0:19:58.55,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Apa?{\b0}
Dialogue: 0,0:19:58.78,0:20:01.28,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Di balik kata-kata kasarmu ini,{\b0}
Dialogue: 0,0:20:01.64,0:20:03.58,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}tersembunyi kelembutanmu.{\b0}
Dialogue: 0,0:20:03.95,0:20:05.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku baru-baru ini menyadari hal itu.{\b0}
Dialogue: 0,0:20:05.70,0:20:08.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, menjijikkan sekali!{\b0}
Dialogue: 0,0:20:08.73,0:20:10.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Benar-benar membuatku kesal.{\b0}
Dialogue: 0,0:20:10.68,0:20:12.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Jangan terlalu terbawa suasana.{\b0}
Dialogue: 0,0:20:12.08,0:20:15.05,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kelembutan apa, jangan\Nbicara seperti itu lagi.{\b0}
Dialogue: 0,0:20:16.84,0:20:18.77,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tolong jangan terlalu berteriak.{\b0}
Dialogue: 0,0:20:19.58,0:20:21.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tutup mulutmu, Tuan Mosa.{\b0}
Dialogue: 0,0:20:21.64,0:20:24.70,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Tunggu saja setelah rantai\Nini kulepas, awas saja kau!{\b0}
Dialogue: 0,0:20:35.19,0:20:37.39,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Hei, bukankah pestanya belum dimulai?{\b0}
Dialogue: 0,0:20:39.20,0:20:41.14,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Mari kita tunggu sambil minum.{\b0}
Dialogue: 0,0:20:41.39,0:20:43.10,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Kau minum terlalu banyak.{\b0}
Dialogue: 0,0:20:51.21,0:20:54.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}- Minumlah!\N- Minumlah!{\b0}
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪{\b0}
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪{\b0}
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪{\b0}
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪{\b0}
Dialogue: 0,0:22:13.61,0:22:16.67,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪{\b0}
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪{\b0}
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪{\b0}
Dialogue: 0,0:22:33.79,0:22:41.88,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪{\b0}
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪{\b0}
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪{\b0}
Dialogue: 0,0:23:04.50,0:23:07.12,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Pesta Elbaph kini resmi dimulai.{\b0}
Dialogue: 0,0:23:07.70,0:23:09.62,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Geng Topi Jerami\Ndan para raksasa bersulang bersama{\b0}
Dialogue: 0,0:23:09.62,0:23:13.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}sambil mengenang masa lalu\Nsaat mereka pertama kali bertemu.{\b0}
Dialogue: 0,0:23:13.20,0:23:17.69,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Sementara itu, penyusup misterius\Ntengah mengincar Loki.{\b0}
Dialogue: 0,0:23:17.72,0:23:20.15,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Konspirasi yang mengerikan\Nmulai terlihat pergerakannya.{\b0}
Dialogue: 0,0:23:20.15,0:23:21.59,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Episode selanjutnya, One Piece.{\b0}
Dialogue: 0,0:23:21.59,0:23:30.78,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}[Bir Persahabatan sebagai Sambutan\Ndan Penyusup yang Mencari Loki]{\b0}
Dialogue: 0,0:23:21.66,0:23:25.46,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Bir persahabatan sebagai sambutan\Ndan penyusup yang mencari Loki.{\b0}
Dialogue: 0,0:23:25.83,0:23:28.08,Default,,0000,0000,0000,,{\blur3}{\fad(00,40)}{\b1}Aku akan menjadi Raja Bajak Laut!{\b0}
