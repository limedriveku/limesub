Dialogue: 0,0:05:02.09,0:05:03.55,tanda,,0,0,0,,(Kenapa menyalahkanku?)
Dialogue: 0,0:05:40.80,0:05:42.23,tanda,,0,0,0,,(Aku juga tidak punya pilihan lain.)
Dialogue: 0,0:12:55.31,0:12:57.96,tanda,,0,0,0,,(Sudah jatuh.)
Dialogue: 0,0:14:09.92,0:14:12.07,tanda,,0,0,0,,(Sial sekali, meong.)
Dialogue: 0,0:21:24.66,0:21:30.59,tanda,,0,0,0,,{\an8}[Bersambung]
Dialogue: 0,0:00:11.81,0:00:15.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berlarilah\Nsampai tiba di sana ♪
Dialogue: 0,0:00:15.31,0:00:19.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Sampai perasaanku\Ntersampaikan kepadamu ♪
Dialogue: 0,0:00:21.28,0:00:23.32,tanda,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}[One Piece\NEpisode 1159]
Dialogue: 0,0:00:24.56,0:00:27.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Lautan yang begitu biru dan jernih ♪
Dialogue: 0,0:00:28.22,0:00:30.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Serpihan keajaiban yang bertebaran ♪
Dialogue: 0,0:00:31.62,0:00:34.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Jumlahnya tidak terhitung lagi ♪
Dialogue: 0,0:00:34.81,0:00:37.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kita pun dipertemukan karenanya ♪
Dialogue: 0,0:00:37.72,0:00:40.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Perjalanan yang panjang\Nlangkah kaki tidak terhenti ♪
Dialogue: 0,0:00:40.44,0:00:44.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Titik akhir masih belum terlihat juga ♪
Dialogue: 0,0:00:44.38,0:00:47.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Namun kita pasti akan\Nmelompati segala rintangan ♪
Dialogue: 0,0:00:47.95,0:00:50.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Demi melihat senyuman itu ♪
Dialogue: 0,0:00:51.09,0:00:55.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Jika tenggelam dalam kebingungan\Ntidak akan bisa menerangi jalan di depan ♪
Dialogue: 0,0:00:55.26,0:00:58.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Mengolah kelemahanmu dengan teliti\Nhingga ia berubah menjadi nutrisi ♪
Dialogue: 0,0:00:59.07,0:01:04.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kita yang berjuang sekuat tenaga\Ntetap saja ♪
Dialogue: 0,0:01:04.62,0:01:08.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Belum ada yang berubah ♪
Dialogue: 0,0:01:08.70,0:01:09.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berlarilah ♪
Dialogue: 0,0:01:09.78,0:01:15.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Sampai tiba di sana\Nsampai perasaan tersampaikan kepadamu ♪
Dialogue: 0,0:01:17.27,0:01:23.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Meski belum menjadi legenda\Nmemangnya kenapa! ♪
Dialogue: 0,0:01:23.93,0:01:29.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Peta itu bersinar terang\Nsuatu hari kita menoleh sambil tersenyum ♪
Dialogue: 0,0:01:29.97,0:01:36.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kini tidak lagi bimbang\Npara pejuang teruslah maju ke depan ♪
Dialogue: 0,0:01:44.55,0:01:45.96,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa dimaafkan.
Dialogue: 0,0:01:46.85,0:01:48.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Beraninya kau membuat ruanganku...
Dialogue: 0,0:01:50.08,0:01:51.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kuil dewaku.
Dialogue: 0,0:01:55.97,0:01:57.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hewan peliharaanku...
Dialogue: 0,0:01:59.28,0:02:02.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ehem, para pelayanku.
Dialogue: 0,0:02:06.55,0:02:08.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa dimaafkan.
Dialogue: 0,0:02:08.56,0:02:14.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boneka hidupku, para boneka hidup.
Dialogue: 0,0:02:16.15,0:02:24.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hancurkan Miniatur Taman!\NLari dari Negeri Balok Susun.
Dialogue: 0,0:02:24.94,0:02:28.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Beraninya menghancurkan negaraku.
Dialogue: 0,0:02:29.44,0:02:30.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisa dimaafkan.
Dialogue: 0,0:02:33.23,0:02:35.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sepertinya ada pergerakan dari Tuan Iscat.
Dialogue: 0,0:02:35.26,0:02:38.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dewa Matahari, mohon redam amarah Anda.
Dialogue: 0,0:02:46.81,0:02:47.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat lihat!
Dialogue: 0,0:02:48.09,0:02:49.95,Default,,0,0,0,,{\blur3}{\fad(00,40)}Langit di sana, api di sana.
Dialogue: 0,0:02:50.21,0:02:52.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begini terus, negara akan hancur.
Dialogue: 0,0:02:53.10,0:02:54.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dunia akan berakhir.
Dialogue: 0,0:02:55.57,0:02:57.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian tidak akan kubiarkan kabur!
Dialogue: 0,0:02:57.80,0:02:59.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berhenti!
Dialogue: 0,0:03:00.10,0:03:02.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang itu terlalu menakutkan.
Dialogue: 0,0:03:03.04,0:03:05.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dewa apanya, bukankah ini iblis?
Dialogue: 0,0:03:06.36,0:03:08.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajingan itu.
Dialogue: 0,0:03:13.07,0:03:14.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini harus lewat mana, ya?
Dialogue: 0,0:03:14.62,0:03:16.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biar kulihat, ke kanan saja.
Dialogue: 0,0:03:18.60,0:03:20.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iscat.
Dialogue: 0,0:03:22.60,0:03:23.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah di sebelah sana?
Dialogue: 0,0:03:28.63,0:03:30.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jangan kabur!
Dialogue: 0,0:03:31.32,0:03:32.60,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei Luffy, cepat lihat.
Dialogue: 0,0:03:32.61,0:03:33.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah sampai jalanan.
Dialogue: 0,0:03:33.54,0:03:34.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:03:34.47,0:03:36.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gelombang itu, apakah tidak masalah?
Dialogue: 0,0:03:36.49,0:03:39.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah semua ini terbuat dari balok susun?
Dialogue: 0,0:03:39.94,0:03:41.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hebat sekali!
Dialogue: 0,0:03:41.56,0:03:43.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sekarang bukan waktunya untuk kagum.
Dialogue: 0,0:03:47.73,0:03:49.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gawat, kita akan terkejar.
Dialogue: 0,0:03:49.60,0:03:51.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana ini, apakah kita\Nmemutar untuk menghindar?
Dialogue: 0,0:03:51.29,0:03:52.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tebas saja langsung.
Dialogue: 0,0:03:52.11,0:03:53.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak, lihat aku akan\Nmenendangnya sampai mati.
Dialogue: 0,0:03:53.73,0:03:54.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak.
Dialogue: 0,0:03:56.21,0:03:57.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau menabrak!
Dialogue: 0,0:03:57.65,0:03:59.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mau menabrak!
Dialogue: 0,0:04:00.91,0:04:03.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terbanglah, Kucing.
Dialogue: 0,0:04:06.52,0:04:07.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Iscat.
Dialogue: 0,0:04:19.31,0:04:21.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang itu sudah susah payah menyusunnya.
Dialogue: 0,0:04:21.26,0:04:24.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebisa mungkin jangan sampai\Nmerusaknya saat kita kabur.
Dialogue: 0,0:04:30.27,0:04:31.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kehilangan kecepatan!
Dialogue: 0,0:04:39.93,0:04:41.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Kucing Raksasa.
Dialogue: 0,0:04:43.46,0:04:44.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa, Nami?
Dialogue: 0,0:04:45.22,0:04:46.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terima kasih, Sanji.
Dialogue: 0,0:04:47.35,0:04:48.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lepaskan, hei.
Dialogue: 0,0:04:49.76,0:04:50.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dan kau juga.
Dialogue: 0,0:04:53.97,0:04:55.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini benar-benar sebuah\Nkekacauan besar, ya.
Dialogue: 0,0:04:55.62,0:04:57.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah kubilang tebas saja\Nagar langsung selesai.
Dialogue: 0,0:04:57.90,0:05:00.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah jadi begini, mau bagaimana lagi?
Dialogue: 0,0:05:00.38,0:05:02.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya berhati-hatilah.
Dialogue: 0,0:05:06.56,0:05:09.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lompatan yang begitu bodoh dan ceroboh.
Dialogue: 0,0:05:11.62,0:05:14.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menghancurkan dunia yang kuciptakan,
Dialogue: 0,0:05:15.26,0:05:16.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}dosanya tidak terampuni.
Dialogue: 0,0:05:18.88,0:05:19.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia datang.
Dialogue: 0,0:05:21.44,0:05:22.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah.
Dialogue: 0,0:05:26.27,0:05:28.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berlarilah, Kucing Raksasa!
Dialogue: 0,0:05:35.83,0:05:37.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iscat.
Dialogue: 0,0:05:37.62,0:05:40.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa kau membantu mereka?
Dialogue: 0,0:05:42.24,0:05:43.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berhenti kau.
Dialogue: 0,0:05:49.12,0:05:52.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengan menunggangi kucing,\Nsekejap saja sampai ke ujung dunia, ya.
Dialogue: 0,0:05:52.95,0:05:54.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukankah ini masih memanjang?
Dialogue: 0,0:05:54.82,0:05:58.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanya Luffy, lihatlah\Ncetak biru negara ini.
Dialogue: 0,0:05:59.84,0:06:01.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang kau lakukan?
Dialogue: 0,0:06:02.14,0:06:03.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak apa-apa, aku sudah mengingatnya.
Dialogue: 0,0:06:03.88,0:06:06.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ah, benarkah?
Dialogue: 0,0:06:10.69,0:06:11.82,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat lihat, Luffy.
Dialogue: 0,0:06:12.09,0:06:14.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di sana terpantul pintu cermin yang tadi.
Dialogue: 0,0:06:15.49,0:06:16.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Eh, benar!
Dialogue: 0,0:06:16.43,0:06:20.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat awan-awan ini dengan baik,\Nitu hanya kapas yang digantung.
Dialogue: 0,0:06:25.66,0:06:27.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata memang benar.
Dialogue: 0,0:06:29.02,0:06:32.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlihat sangat luas, tetapi ini\Nhanya sebuah ruangan bagi raksasa.
Dialogue: 0,0:06:32.86,0:06:37.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cermin di segala sisi, jadi\Npemandangannya terlihat tidak berujung.
Dialogue: 0,0:06:37.34,0:06:39.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Makanya sekejap saja sudah sampai.
Dialogue: 0,0:06:39.04,0:06:41.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selanjutnya, cukup berjalan lurus saja.
Dialogue: 0,0:06:41.31,0:06:43.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini sudah melewati setengah negara.
Dialogue: 0,0:06:45.07,0:06:46.37,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebentar lagi sampai.
Dialogue: 0,0:06:47.57,0:06:48.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ternyata begitu.
Dialogue: 0,0:06:51.20,0:06:52.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Setelah melihat cetak biru,
Dialogue: 0,0:06:52.72,0:06:55.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}apakah kau kira sudah memahami\Nseluruh dunia ini?
Dialogue: 0,0:06:55.99,0:06:59.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah gaya bicara orang itu\Nterdengar seperti gaya bicara samurai?
Dialogue: 0,0:06:59.36,0:07:03.62,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, tempat ini asalnya memang\Ndisiapkan khusus untuk Suku Raksasa.
Dialogue: 0,0:07:03.77,0:07:04.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jaring?
Dialogue: 0,0:07:06.64,0:07:09.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika tertangkap, entah akan\Ndiperlakukan seperti apa.
Dialogue: 0,0:07:09.36,0:07:11.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepat, cepat pergi ke arah dinding itu.
Dialogue: 0,0:07:15.28,0:07:18.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dirancang menjadi sebuah fasilitas\Nyang bahkan Suku Raksasa pun
Dialogue: 0,0:07:18.31,0:07:21.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}tidak dapat meloloskan diri darinya.
Dialogue: 0,0:07:31.34,0:07:33.25,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajingan.
Dialogue: 0,0:07:33.26,0:07:37.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tadi kau sendiri yang melakukannya, 'kan?
Dialogue: 0,0:07:37.14,0:07:39.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meskipun kalian kabur\Nsampai ke dinding sana,
Dialogue: 0,0:07:41.08,0:07:44.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}tetap tidak akan bisa menghancurkannya.
Dialogue: 0,0:07:52.00,0:07:55.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, di sana hanyalah jalan buntu.
Dialogue: 0,0:07:55.40,0:07:56.28,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gawat.
Dialogue: 0,0:07:56.60,0:07:57.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana ini?
Dialogue: 0,0:07:57.67,0:07:59.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Padahal tinggal sedikit lagi.
Dialogue: 0,0:07:59.30,0:08:01.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, menyingkirlah, Kucing Raksasa.
Dialogue: 0,0:08:06.21,0:08:07.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mengapa Tuan Iscat bersikap seperti itu?
Dialogue: 0,0:08:07.89,0:08:10.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa orang yang menungganginya itu?
Dialogue: 0,0:08:10.17,0:08:12.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kemarilah, para boneka hidup.
Dialogue: 0,0:08:13.84,0:08:16.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kembalilah ke sisiku.
Dialogue: 0,0:08:25.27,0:08:26.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cepatlah.
Dialogue: 0,0:08:29.53,0:08:30.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Maju.
Dialogue: 0,0:08:44.65,0:08:46.44,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terjang!
Dialogue: 0,0:08:49.12,0:08:51.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berhenti, Iscat!
Dialogue: 0,0:08:52.36,0:08:56.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang-orang itu, beraninya mereka\Nmembuat jaring logamnya menjadi...
Dialogue: 0,0:09:01.34,0:09:03.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boneka yang lemah meskipun meronta,
Dialogue: 0,0:09:03.92,0:09:06.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}tetap tidak bisa mengubah\Nalur cerita yang kutulis.
Dialogue: 0,0:09:06.68,0:09:09.41,Default,,0,0,0,,{\blur3}{\fad(00,40)}Iscat, kau juga mengerti, 'kan?
Dialogue: 0,0:09:09.76,0:09:12.22,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hukuman bagi pengkhianat itu sangat berat.
Dialogue: 0,0:09:15.80,0:09:17.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia bilang kau berisik sekali dan cerewet.
Dialogue: 0,0:09:18.00,0:09:20.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa, beraninya kau pada majikan...
Dialogue: 0,0:09:21.16,0:09:25.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, percuma saja, di depan\Nmasih ada Dewa Telinga yang kejam.
Dialogue: 0,0:09:27.32,0:09:29.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mohon tunggu sebentar, Tuan Iscat.
Dialogue: 0,0:09:31.08,0:09:32.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dewa Matahari.
Dialogue: 0,0:09:33.35,0:09:35.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya Dewa Telinga...
Dialogue: 0,0:09:35.70,0:09:39.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hari ini sudah mati terbakar\Nkarena alasan yang tidak diketahui.
Dialogue: 0,0:09:39.05,0:09:42.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat kami sedang berduka\Ndan merasa sangat tidak beruntung,
Dialogue: 0,0:09:42.93,0:09:45.45,Default,,0,0,0,,{\blur3}{\fad(00,40)}terjadi lagi kejadian aneh\Ndi mana langit retak.
Dialogue: 0,0:09:45.46,0:09:47.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Selain itu, Kastel Bigstein juga hancur.
Dialogue: 0,0:09:47.89,0:09:49.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tuan Iscat jatuh ke dalam kegilaan.
Dialogue: 0,0:09:49.71,0:09:51.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar hari yang terkutuk.
Dialogue: 0,0:09:53.31,0:09:54.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah dia sudah dikalahkan?
Dialogue: 0,0:09:55.29,0:09:56.63,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mana mungkin?
Dialogue: 0,0:09:56.87,0:10:00.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kelinci karnivor yang kejam itu,\Nsi Kelinci Rakus.
Dialogue: 0,0:10:03.48,0:10:07.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat kami menemukannya,\Nkeadaannya sudah seperti ini.
Dialogue: 0,0:10:14.86,0:10:17.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mohon redam amarah Anda.
Dialogue: 0,0:10:20.58,0:10:22.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Redam amarah Anda.
Dialogue: 0,0:10:27.69,0:10:29.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dewa Matahari.
Dialogue: 0,0:10:31.62,0:10:32.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar imut!
Dialogue: 0,0:10:34.04,0:10:35.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Patut dihormati.
Dialogue: 0,0:10:35.14,0:10:37.04,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini juga bagian dari dunia.
Dialogue: 0,0:10:38.68,0:10:42.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di dalam miniatur taman yang tertutup,\Ntelah terjadi cerita di luar skenario.
Dialogue: 0,0:10:42.77,0:10:43.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku telah meremehkan mereka.
Dialogue: 0,0:10:43.90,0:10:46.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}Geng ini benar-benar\Nmembuat bersemangat, ya.
Dialogue: 0,0:10:47.82,0:10:50.05,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dunia yang aku ciptakan ini,
Dialogue: 0,0:10:50.32,0:10:52.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}telah melahirkan kejahatan dan pahlawan.
Dialogue: 0,0:10:52.90,0:10:54.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejarah sedang diciptakan!
Dialogue: 0,0:10:55.78,0:11:00.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Inilah kesenangan dari boneka hidup\Ndi dunia kecil milikku.
Dialogue: 0,0:11:04.81,0:11:06.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang itu sedang mentertawakan apa?
Dialogue: 0,0:11:34.62,0:11:37.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mungkin saja ini\Nkesempatan yang langka, ya.
Dialogue: 0,0:11:38.77,0:11:41.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pintu keluar darurat masih terbuka lebar.
Dialogue: 0,0:11:42.15,0:11:44.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mari kabur selagi ada kesempatan.
Dialogue: 0,0:11:44.23,0:11:45.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pergi beri tahu yang lainnya.
Dialogue: 0,0:11:47.35,0:11:48.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Merontalah.
Dialogue: 0,0:11:48.56,0:11:50.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Merontalah di dalam telapak tanganku.
Dialogue: 0,0:11:51.14,0:11:54.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meskipun Hajrudin mengakui kalian,\Naku tidak akan mengakuinya.
Dialogue: 0,0:12:02.24,0:12:03.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hajrudin?
Dialogue: 0,0:12:05.26,0:12:06.39,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajingan.
Dialogue: 0,0:12:07.38,0:12:08.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya siapa kau ini?
Dialogue: 0,0:12:12.29,0:12:14.90,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, apa yang akan kalian lakukan?
Dialogue: 0,0:12:18.16,0:12:20.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di belakang pohon besar itu\Nadalah dindingnya.
Dialogue: 0,0:12:20.02,0:12:20.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baik.
Dialogue: 0,0:12:20.98,0:12:22.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, bagaimana cara keluarnya?
Dialogue: 0,0:12:23.28,0:12:25.33,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau sampai tertangkap lagi akan gawat.
Dialogue: 0,0:12:25.34,0:12:27.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak akan kubiarkan dia menangkap kita.
Dialogue: 0,0:12:28.23,0:12:30.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jarak tembak di sini sudah cukup.
Dialogue: 0,0:12:32.41,0:12:34.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jurus maut, Pop Green...
Dialogue: 0,0:12:36.11,0:12:37.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dokuro Bakuhatsu So!
Dialogue: 0,0:13:14.11,0:13:15.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rusak lagi, ya.
Dialogue: 0,0:13:17.48,0:13:19.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, maaf, ya.
Dialogue: 0,0:13:20.03,0:13:21.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hal semacam itu tidak penting lagi.
Dialogue: 0,0:13:21.58,0:13:22.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu penting!
Dialogue: 0,0:13:22.50,0:13:24.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kau sudah merusak terlalu banyak.
Dialogue: 0,0:13:24.07,0:13:26.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku tahu, aku yang salah.
Dialogue: 0,0:13:26.54,0:13:28.07,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baguslah kalau tahu salah.
Dialogue: 0,0:13:28.49,0:13:30.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlepas dari itu, cepat lihat, Luffy.
Dialogue: 0,0:13:30.41,0:13:31.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cerminnya memang sudah pecah.
Dialogue: 0,0:13:31.71,0:13:33.43,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dindingnya sangat keras, ya.
Dialogue: 0,0:13:33.89,0:13:35.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar sekali.
Dialogue: 0,0:13:35.77,0:13:38.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalian tidak akan bisa menghancurkannya.
Dialogue: 0,0:13:38.22,0:13:40.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Mustahil bisa melarikan diri.
Dialogue: 0,0:13:42.61,0:13:44.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagus, benar-benar bagus.
Dialogue: 0,0:13:45.54,0:13:47.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Boneka lemah yang melawan takdir.
Dialogue: 0,0:13:48.01,0:13:50.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menarik, skenario yang luar biasa.
Dialogue: 0,0:13:54.55,0:13:57.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kehampaan, keputusasaan,\Nitu juga bagian dari dunia.
Dialogue: 0,0:13:57.43,0:13:58.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kegagalan,
Dialogue: 0,0:13:58.48,0:13:59.53,Default,,0,0,0,,{\blur3}{\fad(00,40)}kekecewaan,
Dialogue: 0,0:14:00.04,0:14:01.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}juga merupakan sejarah.
Dialogue: 0,0:14:02.70,0:14:04.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dari tadi terus saja mengoceh tanpa henti.
Dialogue: 0,0:14:04.87,0:14:06.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sebenarnya sedang bicara apa dia?
Dialogue: 0,0:14:07.71,0:14:09.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, Kucing Raksasa,\Napakah masih bisa maju?
Dialogue: 0,0:14:19.44,0:14:20.56,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Maju, Kucing Raksasa.\N- Sungguh boneka hidup yang imut.
Dialogue: 0,0:14:20.57,0:14:21.57,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Jangan lambat.\N- Sungguh boneka hidup yang imut.
Dialogue: 0,0:14:21.58,0:14:23.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Orang itu mulai bergerak.
Dialogue: 0,0:14:23.28,0:14:24.80,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berlarilah, Kucing Raksasa!
Dialogue: 0,0:14:24.81,0:14:26.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak bisakah lebih cepat sedikit?
Dialogue: 0,0:14:26.82,0:14:28.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Kita akan terkejar.\N- Sudah lama tidak merasa sesemangat ini.
Dialogue: 0,0:14:28.14,0:14:28.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tebas saja dia.\N- Sudah lama tidak merasa sesemangat ini.
Dialogue: 0,0:14:28.82,0:14:29.54,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Tendang dia sampai jatuh.\N- Sudah lama tidak merasa sesemangat ini.
Dialogue: 0,0:14:29.55,0:14:30.48,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kucing Raksasa!
Dialogue: 0,0:14:31.85,0:14:33.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dia bilang kau sangat berisik.
Dialogue: 0,0:14:33.76,0:14:34.93,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lemah dan lucu,
Dialogue: 0,0:14:35.20,0:14:36.38,Default,,0,0,0,,{\blur3}{\fad(00,40)}tetapi juga berani.
Dialogue: 0,0:14:36.50,0:14:38.31,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sangat terharu sampai air mata\Ntidak bisa berhenti mengalir.
Dialogue: 0,0:14:38.32,0:14:40.59,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar-benar bagus\Nsudah membawa kalian kemari.
Dialogue: 0,0:14:40.60,0:14:41.58,Default,,0,0,0,,{\blur3}{\fad(00,40)}Luffy-tasso.
Dialogue: 0,0:14:42.72,0:14:43.71,Default,,0,0,0,,{\blur3}{\fad(00,40)}Zoro-tasso.
Dialogue: 0,0:14:43.84,0:14:45.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}San-tasso.
Dialogue: 0,0:14:45.55,0:14:46.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Uso-tasso.
Dialogue: 0,0:14:46.89,0:14:47.67,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bicara tentangku?
Dialogue: 0,0:14:47.68,0:14:48.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Cho-tasso.
Dialogue: 0,0:14:49.85,0:14:50.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami-tasso.
Dialogue: 0,0:14:50.84,0:14:51.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tunggu sebentar.
Dialogue: 0,0:14:52.20,0:14:54.27,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kenapa dia mengenal kita?
Dialogue: 0,0:14:54.79,0:14:55.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa itu, "Tasso"?
Dialogue: 0,0:15:06.41,0:15:08.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa yang sedang dilakukan orang itu?
Dialogue: 0,0:15:08.20,0:15:10.08,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terlepas dari hal itu, sekarang bagaimana?
Dialogue: 0,0:15:10.09,0:15:12.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begini terus, kita akan terkejar.
Dialogue: 0,0:15:12.14,0:15:13.66,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengarkan aku, Usopp.
Dialogue: 0,0:15:13.94,0:15:17.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Jika itu adalah bencana alam,\Nberarti ini bukan salah siapa pun, ya?
Dialogue: 0,0:15:17.50,0:15:20.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu memang benar, gempa bumi, banjir,\Npetir, dan semacamnya,
Dialogue: 0,0:15:20.84,0:15:23.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}tidak bisa juga bilang siapa pelakunya.
Dialogue: 0,0:15:23.30,0:15:27.29,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kita benar-benar telah mengalami\Nhal yang sangat mengerikan, ya.
Dialogue: 0,0:15:32.92,0:15:35.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejujurnya orang itu sangat membuat emosi.
Dialogue: 0,0:15:36.01,0:15:38.77,Default,,0,0,0,,{\blur3}{\fad(00,40)}Benar, tetapi bagi Suku Raksasa...
Dialogue: 0,0:15:38.78,0:15:39.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengerti, Nami.
Dialogue: 0,0:15:40.26,0:15:44.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku mengerti kemarahanmu, aku juga\Nselalu merasa geram pada orang itu.
Dialogue: 0,0:15:44.74,0:15:46.12,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku selalu berpikir,
Dialogue: 0,0:15:46.51,0:15:47.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}bajingan itu,
Dialogue: 0,0:15:48.22,0:15:51.19,Default,,0,0,0,,{\blur3}{\fad(00,40)}beraninya menggantikan pakaian Nami!
Dialogue: 0,0:15:54.48,0:15:55.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ayo bertindak.
Dialogue: 0,0:15:55.77,0:15:57.49,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bukan, tunggu sebentar Sanji.
Dialogue: 0,0:15:57.50,0:15:58.92,Default,,0,0,0,,{\blur3}{\fad(00,40)}Dengarkan orang bicara dulu.
Dialogue: 0,0:15:58.93,0:16:00.99,Default,,0,0,0,,{\blur3}{\fad(00,40)}Siapa juga yang mau\Ndengar omongan pria bau?
Dialogue: 0,0:16:01.00,0:16:02.64,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini tidak boleh, Sanji.
Dialogue: 0,0:16:03.19,0:16:04.14,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami, kenapa?
Dialogue: 0,0:16:04.51,0:16:08.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lagi pula, pasti akan ada\NHukuman Langit yang turun.
Dialogue: 0,0:16:34.39,0:16:36.73,Default,,0,0,0,,{\blur3}{\fad(00,40)}Muginn, ada apa denganmu?
Dialogue: 0,0:16:37.16,0:16:39.40,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa lagi yang kau bawa kemari?
Dialogue: 0,0:16:50.62,0:16:52.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, ini Geng Topi Jerami.
Dialogue: 0,0:16:53.00,0:16:56.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bajak Laut Prajurit Raksasa\Nseharusnya sedang pergi menjemput mereka.
Dialogue: 0,0:16:56.86,0:16:58.72,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di mana kau memungut mereka?
Dialogue: 0,0:17:00.63,0:17:01.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidak ketahuan, 'kan?
Dialogue: 0,0:17:01.95,0:17:03.75,Default,,0,0,0,,{\blur3}{\fad(00,40)}Tidurnya nyenyak sekali, ya.
Dialogue: 0,0:17:04.06,0:17:08.13,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apa mungkin rute menuju Egg Head\Nmelewati Zona Kabut Tidur?
Dialogue: 0,0:17:12.45,0:17:15.16,Default,,0,0,0,,{\blur3}{\fad(00,40)}Namun, ini benar-benar kesempatan emas.
Dialogue: 0,0:17:15.80,0:17:17.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Geng Topi Jerami.
Dialogue: 0,0:17:19.47,0:17:21.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sejujurnya aku dengar si Hajrudin itu
Dialogue: 0,0:17:21.95,0:17:24.81,Default,,0,0,0,,{\blur3}{\fad(00,40)}ternyata menjadi anak buah\Norang ini tanpa izin.
Dialogue: 0,0:17:25.17,0:17:26.97,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini benar-benar membuat emosi!
Dialogue: 0,0:17:29.19,0:17:30.70,Default,,0,0,0,,{\blur3}{\fad(00,40)}Hei, tunggu dulu, Hajrudin.
Dialogue: 0,0:17:30.71,0:17:33.01,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sudah dengar, apakah kau gila?
Dialogue: 0,0:17:34.23,0:17:38.47,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku anggota Bajak Laut Prajurit Raksasa\NBaru juga jadi anak buah orang ini?
Dialogue: 0,0:17:38.56,0:17:40.79,Default,,0,0,0,,{\blur3}{\fad(00,40)}Prajurit Elbaph terkuat di dunia,
Dialogue: 0,0:17:41.01,0:17:43.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}ternyata menjadi anak buah\Nmanusia bertubuh kecil?
Dialogue: 0,0:17:43.43,0:17:46.32,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah tidak punya harga diri?
Dialogue: 0,0:17:47.91,0:17:50.78,Default,,0,0,0,,{\blur3}{\fad(00,40)}Lihat tubuh yang lemah ini.
Dialogue: 0,0:17:50.79,0:17:54.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Penampilan saat tidur tanpa pertahanan,\Nbenar-benar memalukan.
Dialogue: 0,0:18:00.01,0:18:03.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang di sebelah sini, aku... aku boleh...
Dialogue: 0,0:18:04.25,0:18:05.55,Default,,0,0,0,,{\blur3}{\fad(00,40)}Nami-tasso!
Dialogue: 0,0:18:21.44,0:18:23.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Biarkan kalian tidur sebentar lagi saja.
Dialogue: 0,0:18:23.85,0:18:25.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Saat terbangun nanti...
Dialogue: 0,0:18:28.83,0:18:32.09,Default,,0,0,0,,{\blur3}{\fad(00,40)}Menghilang tanpa jejak seperti ini\Njuga sangat bagus, ya.
Dialogue: 0,0:18:32.97,0:18:36.30,Default,,0,0,0,,{\blur3}{\fad(00,40)}Buat keributan di sini selamanya\Ndan hiduplah bersama aku.
Dialogue: 0,0:18:36.46,0:18:40.26,Default,,0,0,0,,{\blur3}{\fad(00,40)}Meskipun tidak mau berada di bawah kalian,\Nkalau jadi bos kalian...
Dialogue: 0,0:18:46.29,0:18:49.69,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ada apa ini? Aku tidak ingat pernah\Nmembuat awan seperti ini.
Dialogue: 0,0:18:49.87,0:18:51.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Sudah siap, Zeus?
Dialogue: 0,0:18:54.87,0:18:57.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku sangat bersemangat, Nami.
Dialogue: 0,0:18:58.10,0:19:00.03,Default,,0,0,0,,{\blur3}{\fad(00,40)}Kalau begitu, tolong bantuannya.
Dialogue: 0,0:19:01.51,0:19:02.84,Default,,0,0,0,,{\blur3}{\fad(00,40)}Raitei.
Dialogue: 0,0:19:04.81,0:19:07.50,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku pergi dulu.
Dialogue: 0,0:19:26.94,0:19:29.42,Default,,0,0,0,,{\blur3}{\fad(00,40)}- Dewa Matahari!
Dialogue: 0,0:19:47.51,0:19:49.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bodoh, kau melakukannya berlebihan!
Dialogue: 0,0:19:50.04,0:19:52.17,Default,,0,0,0,,{\blur3}{\fad(00,40)}Bagaimana membereskan ini sekarang?
Dialogue: 0,0:19:55.08,0:19:57.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Ini Hukuman Langit,\Njadi mau bagaimana lagi?
Dialogue: 0,0:20:01.01,0:20:03.61,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu jelas-jelas kau\Nyang melakukannya, 'kan?
Dialogue: 0,0:20:05.76,0:20:09.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Baiklah, majulah seperti ini,\NKucing Raksasa!
Dialogue: 0,0:20:18.06,0:20:19.86,Default,,0,0,0,,{\blur3}{\fad(00,40)}Terbanglah, Kucing Raksasa.
Dialogue: 0,0:20:29.98,0:20:31.89,Default,,0,0,0,,{\blur3}{\fad(00,40)}Berikan sedikit Gear Fourth.
Dialogue: 0,0:20:37.84,0:20:41.24,Default,,0,0,0,,{\blur3}{\fad(00,40)}Agak berat hati, tetapi kami\Nakan pergi, Negeri Balok Susun.
Dialogue: 0,0:20:42.10,0:20:44.10,Default,,0,0,0,,{\blur3}{\fad(00,40)}Apakah akhirnya bisa pergi ke luar?
Dialogue: 0,0:20:44.60,0:20:46.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Rasakan itu, raksasa mesum.
Dialogue: 0,0:20:47.09,0:20:50.20,Default,,0,0,0,,{\blur3}{\fad(00,40)}Semoga di luar adalah Elbaph.
Dialogue: 0,0:20:52.80,0:20:59.46,Default,,0,0,0,,{\blur3}{\fad(00,40)}Gomu-gomu no Kong Gun!
Dialogue: 0,0:21:16.43,0:21:18.02,Default,,0,0,0,,{\blur3}{\fad(00,40)}Itu dunia luar!
Dialogue: 0,0:21:34.17,0:21:42.87,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berusaha keras membuka mata lebar-lebar\Nuntuk memastikan situasi di depan ♪
Dialogue: 0,0:21:45.08,0:21:52.85,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Otak penuh khayalan dan keputusasaan\Nentah kenapa selalu agak menyimpang ♪
Dialogue: 0,0:21:53.19,0:22:02.21,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Kenangan-kenangan buruk selalu\Nmuncul kembali dengan sangat jelas ♪
Dialogue: 0,0:22:04.11,0:22:12.06,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Memunguti kebosanan tidak berarti\Nrasanya hampir jadi orang lain ♪
Dialogue: 0,0:22:13.61,0:22:16.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Masa depan seperti apa\Nyang sebenarnya menjadi milikku ♪
Dialogue: 0,0:22:16.69,0:22:22.76,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Berdiri di sini dan sejauh apa pun\Nmencari tetap tidak terlihat ♪
Dialogue: 0,0:22:22.89,0:22:33.65,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Menentang angin dan robek ilusi salah\Nserta membuangnya ke celah takdir ♪
Dialogue: 0,0:22:33.79,0:22:41.91,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Orang-orang terus berputar dalam siklus\Nkenyataan yang begitu keras ini ♪
Dialogue: 0,0:22:41.92,0:22:48.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Hari esok begitu riuh hingga tidak ada\Nwaktu untuk berdoa akan segera tiba ♪
Dialogue: 0,0:22:49.12,0:22:57.74,Default,,0,0,0,,{\blur3}{\fad(00,40)}♪ Lihat masa depan itu\Nkarena ia adalah milikku ♪
Dialogue: 0,0:23:05.46,0:23:08.83,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di hadapan Geng Topi Jerami yang terbang\Nmenjauhi Negeri Balok Susun,
Dialogue: 0,0:23:08.84,0:23:11.94,Default,,0,0,0,,{\blur3}{\fad(00,40)}terbentang pemandangan salju luas\Ndan jembatan gantung raksasa.
Dialogue: 0,0:23:11.95,0:23:14.35,Default,,0,0,0,,{\blur3}{\fad(00,40)}Yang menanti mereka itu surga atau neraka?
Dialogue: 0,0:23:14.75,0:23:17.36,Default,,0,0,0,,{\blur3}{\fad(00,40)}Di hadapan Luffy yang maju sendirian,
Dialogue: 0,0:23:17.68,0:23:20.68,Default,,0,0,0,,{\blur3}{\fad(00,40)}pemilik raungan mengerikan\Ntelah menampakkan diri.
Dialogue: 0,0:23:20.91,0:23:22.34,Default,,0,0,0,,{\blur3}{\fad(00,40)}Episode selanjutnya, One Piece.
Dialogue: 0,0:23:22.35,0:23:25.52,Default,,0,0,0,,{\blur3}{\fad(00,40)}Pertemuan di Padang Salju!\NPangeran Loki yang terkutuk.
Dialogue: 0,0:23:22.39,0:23:30.72,tanda,,0,0,0,,{\blur3}{\fad(00,40)}{\an8}[Pertemuan di Padang Salju!\NPangeran Loki yang Terkutuk]
Dialogue: 0,0:23:25.78,0:23:27.88,Default,,0,0,0,,{\blur3}{\fad(00,40)}Aku akan menjadi Raja Bajak Laut!
